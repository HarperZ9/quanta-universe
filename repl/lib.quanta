/// Change directory
pub struct CdMagic;

impl LineMagic for CdMagic {
    fn execute(&self, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        let path = if args.is_empty() {
            std::env::var("HOME").unwrap_or_else(|_| ".".to_string())
        } else {
            args.to_string()
        };

        std::env::set_current_dir(&path)
            .map_err(|e| MagicError::IoError(e.to_string()))?;

        Ok(MagicResult::Output(format!("Changed to {}", path)))
    }

    fn help(&self) -> &str {
        "%cd path - Change directory"
    }
}

