// WORKSPACE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Workspace for saving/restoring REPL sessions
pub struct Workspace {
    /// Workspace name
    pub name: String,
    /// Saved bindings
    pub bindings: HashMap<String, SerializedValue>,
    /// History
    pub history: Vec<String>,
    /// Active modules
    pub modules: Vec<String>,
    /// Configuration
    pub config: ReplConfig,
    /// Metadata
    pub metadata: WorkspaceMetadata,
}

#[derive(Clone)]
pub struct WorkspaceMetadata {
    pub created: String,
    pub modified: String,
    pub description: String,
    pub tags: Vec<String>,
}

#[derive(Clone)]
pub enum SerializedValue {
    Null,
    Bool(bool),
    Int(i64),
    Float(f64),
    String(String),
    Array(Vec<SerializedValue>),
    Object(HashMap<String, SerializedValue>),
}

impl Workspace {
    pub fn new(name: &str) -> Self {
        Workspace {
            name: name.to_string(),
            bindings: HashMap::new(),
            history: Vec::new(),
            modules: Vec::new(),
            config: ReplConfig::default(),
            metadata: WorkspaceMetadata {
                created: chrono_now(),
                modified: chrono_now(),
                description: String::new(),
                tags: Vec::new(),
            },
        }
    }

    /// Save workspace to file
    pub fn save(&self, path: &str) -> Result<(), String> {
        // Serialize and write (placeholder)
        Ok(())
    }

    /// Load workspace from file
    pub fn load(path: &str) -> Result<Self, String> {
        // Read and deserialize (placeholder)
        Ok(Workspace::new("default"))
    }

    /// Capture current REPL state
    pub fn capture(&mut self, repl: &Repl) {
        self.bindings.clear();
        for (name, value) in &repl.context.bindings {
            self.bindings.insert(name.clone(), Self::serialize_value(value));
        }
        self.metadata.modified = chrono_now();
    }

    /// Restore to REPL
    pub fn restore(&self, repl: &mut Repl) {
        for (name, value) in &self.bindings {
            if let Some(v) = Self::deserialize_value(value) {
                repl.context.bindings.insert(name.clone(), v);
            }
        }
    }

    fn serialize_value(value: &Value) -> SerializedValue {
        match value {
            Value::Unit => SerializedValue::Null,
            Value::Bool(b) => SerializedValue::Bool(*b),
            Value::Int(i) => SerializedValue::Int(*i),
            Value::Float(f) => SerializedValue::Float(*f),
            Value::String(s) => SerializedValue::String(s.clone()),
            Value::Array(arr) => SerializedValue::Array(
                arr.iter().map(Self::serialize_value).collect()
            ),
            _ => SerializedValue::Null,
        }
    }

    fn deserialize_value(value: &SerializedValue) -> Option<Value> {
        match value {
            SerializedValue::Null => Some(Value::Unit),
            SerializedValue::Bool(b) => Some(Value::Bool(*b)),
            SerializedValue::Int(i) => Some(Value::Int(*i)),
            SerializedValue::Float(f) => Some(Value::Float(*f)),
            SerializedValue::String(s) => Some(Value::String(s.clone())),
            SerializedValue::Array(arr) => {
                let values: Vec<Value> = arr.iter()
                    .filter_map(Self::deserialize_value)
                    .collect();
                Some(Value::Array(values))
            }
            SerializedValue::Object(_) => None,
        }
    }
}

/// Workspace manager
pub struct WorkspaceManager {
    /// Available workspaces
    workspaces: HashMap<String, Workspace>,
    /// Current workspace
    current: Option<String>,
    /// Workspace directory
    workspace_dir: String,
}

impl WorkspaceManager {
    pub fn new(workspace_dir: &str) -> Self {
        WorkspaceManager {
            workspaces: HashMap::new(),
            current: None,
            workspace_dir: workspace_dir.to_string(),
        }
    }

    /// Create new workspace
    pub fn create(&mut self, name: &str) -> &mut Workspace {
        self.workspaces.insert(name.to_string(), Workspace::new(name));
        self.workspaces.get_mut(name).unwrap()
    }

    /// Switch workspace
    pub fn switch(&mut self, name: &str) -> Option<&mut Workspace> {
        if self.workspaces.contains_key(name) {
            self.current = Some(name.to_string());
            self.workspaces.get_mut(name)
        } else {
            None
        }
    }

    /// List workspaces
    pub fn list(&self) -> Vec<&String> {
        self.workspaces.keys().collect()
    }

    /// Delete workspace
    pub fn delete(&mut self, name: &str) -> bool {
        if self.current.as_deref() == Some(name) {
            self.current = None;
        }
        self.workspaces.remove(name).is_some()
    }

    /// Save all workspaces
    pub fn save_all(&self) -> Result<(), String> {
        for (name, workspace) in &self.workspaces {
            let path = format!("{}/{}.workspace", self.workspace_dir, name);
            workspace.save(&path)?;
        }
        Ok(())
    }

    /// Load all workspaces
    pub fn load_all(&mut self) -> Result<(), String> {
        // Load from directory (placeholder)
        Ok(())
    }
}

fn chrono_now() -> String {
    "2025-12-24T00:00:00Z".to_string()
}

