// JUPYTER NOTEBOOK INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Jupyter kernel protocol support
pub struct JupyterKernel {
    /// Session ID
    session_id: String,
    /// Execution counter
    execution_count: usize,
    /// REPL context
    context: ReplContext,
    /// Magic registry
    magics: MagicCommandRegistry,
    /// Kernel info
    info: KernelInfo,
    /// Message handlers
    handlers: HashMap<String, Box<dyn MessageHandler>>,
}

#[derive(Clone)]
pub struct KernelInfo {
    pub protocol_version: String,
    pub implementation: String,
    pub implementation_version: String,
    pub language_info: LanguageInfo,
    pub banner: String,
}

#[derive(Clone)]
pub struct LanguageInfo {
    pub name: String,
    pub version: String,
    pub mimetype: String,
    pub file_extension: String,
    pub pygments_lexer: String,
    pub codemirror_mode: String,
}

impl Default for KernelInfo {
    fn default() -> Self {
        KernelInfo {
            protocol_version: "5.3".to_string(),
            implementation: "quanta".to_string(),
            implementation_version: "2.0.0".to_string(),
            language_info: LanguageInfo {
                name: "quantalang".to_string(),
                version: "2.0.0".to_string(),
                mimetype: "text/x-quanta".to_string(),
                file_extension: ".quanta".to_string(),
                pygments_lexer: "rust".to_string(),
                codemirror_mode: "rust".to_string(),
            },
            banner: "QUANTA-UNIVERSE Kernel v2.0.0\nQuantum Computing Language".to_string(),
        }
    }
}

impl JupyterKernel {
    pub fn new() -> Self {
        JupyterKernel {
            session_id: uuid_v4(),
            execution_count: 0,
            context: ReplContext::new(),
            magics: MagicCommandRegistry::new(),
            info: KernelInfo::default(),
            handlers: HashMap::new(),
        }
    }

    /// Handle kernel_info_request
    pub fn kernel_info(&self) -> KernelInfo {
        self.info.clone()
    }

    /// Handle execute_request
    pub fn execute(&mut self, code: &str, silent: bool, store_history: bool) -> ExecuteResult {
        self.execution_count += 1;

        let mut evaluator = Evaluator::new(ReplContext::new());

        // Check for magics
        if code.starts_with("%%") {
            // Cell magic
            if let Some(idx) = code.find('\n') {
                let first_line = &code[2..idx];
                let parts: Vec<&str> = first_line.splitn(2, ' ').collect();
                let name = parts[0];
                let args = parts.get(1).copied().unwrap_or("");
                let body = &code[idx + 1..];

                match self.magics.execute_cell_magic(name, args, body, &mut self.context) {
                    Ok(result) => return self.magic_to_execute_result(result),
                    Err(e) => return ExecuteResult::Error {
                        ename: "MagicError".to_string(),
                        evalue: format!("{:?}", e),
                        traceback: vec![],
                    },
                }
            }
        } else if code.starts_with("%") {
            // Line magic
            let parts: Vec<&str> = code[1..].splitn(2, ' ').collect();
            let name = parts[0];
            let args = parts.get(1).copied().unwrap_or("");

            match self.magics.execute_line_magic(name, args, &mut self.context) {
                Ok(result) => return self.magic_to_execute_result(result),
                Err(e) => return ExecuteResult::Error {
                    ename: "MagicError".to_string(),
                    evalue: format!("{:?}", e),
                    traceback: vec![],
                },
            }
        }

        // Regular code execution
        match evaluator.eval(code) {
            Ok(EvalResult::Value(value)) => {
                ExecuteResult::Ok {
                    execution_count: self.execution_count,
                    data: HashMap::from([
                        ("text/plain".to_string(), value.display()),
                    ]),
                }
            }
            Ok(EvalResult::Output(output)) => {
                ExecuteResult::Ok {
                    execution_count: self.execution_count,
                    data: HashMap::from([
                        ("text/plain".to_string(), output),
                    ]),
                }
            }
            Ok(_) => {
                ExecuteResult::Ok {
                    execution_count: self.execution_count,
                    data: HashMap::new(),
                }
            }
            Err(e) => {
                ExecuteResult::Error {
                    ename: "EvalError".to_string(),
                    evalue: format!("{:?}", e),
                    traceback: vec![],
                }
            }
        }
    }

    fn magic_to_execute_result(&self, result: MagicResult) -> ExecuteResult {
        match result {
            MagicResult::None => ExecuteResult::Ok {
                execution_count: self.execution_count,
                data: HashMap::new(),
            },
            MagicResult::Output(s) => ExecuteResult::Ok {
                execution_count: self.execution_count,
                data: HashMap::from([("text/plain".to_string(), s)]),
            },
            MagicResult::Value(v) => ExecuteResult::Ok {
                execution_count: self.execution_count,
                data: HashMap::from([("text/plain".to_string(), v.display())]),
            },
            MagicResult::Display(d) => {
                let mut data = HashMap::new();
                match d {
                    DisplayData::Html(s) => { data.insert("text/html".to_string(), s); }
                    DisplayData::Markdown(s) => { data.insert("text/markdown".to_string(), s); }
                    DisplayData::Latex(s) => { data.insert("text/latex".to_string(), s); }
                    DisplayData::Json(s) => { data.insert("application/json".to_string(), s); }
                    _ => {}
                }
                ExecuteResult::Ok { execution_count: self.execution_count, data }
            },
            MagicResult::Timing(t) => ExecuteResult::Ok {
                execution_count: self.execution_count,
                data: HashMap::from([
                    ("text/plain".to_string(), format!("{} loops, best of {}: {:?} per loop",
                        t.iterations, t.iterations, t.mean)),
                ]),
            },
        }
    }

    /// Handle complete_request
    pub fn complete(&self, code: &str, cursor_pos: usize) -> CompleteResult {
        let completer = Completer::new();
        let prefix = &code[..cursor_pos];
        let completions = completer.complete(prefix, &self.context);

        CompleteResult {
            matches: completions.iter().map(|c| c.text.clone()).collect(),
            cursor_start: cursor_pos - prefix.split_whitespace().last().map(|w| w.len()).unwrap_or(0),
            cursor_end: cursor_pos,
            metadata: HashMap::new(),
        }
    }

    /// Handle inspect_request
    pub fn inspect(&self, code: &str, cursor_pos: usize, detail_level: usize) -> InspectResult {
        let word = code[..cursor_pos].split_whitespace().last().unwrap_or("");

        if let Some(value) = self.context.get(word) {
            InspectResult {
                found: true,
                data: HashMap::from([
                    ("text/plain".to_string(), format!("{}: {}", word, value.type_name())),
                ]),
            }
        } else {
            InspectResult {
                found: false,
                data: HashMap::new(),
            }
        }
    }

    /// Handle is_complete_request
    pub fn is_complete(&self, code: &str) -> IsCompleteResult {
        // Check for balanced brackets
        let mut braces = 0i32;
        let mut parens = 0i32;
        let mut brackets = 0i32;
        let mut in_string = false;

        for c in code.chars() {
            if in_string {
                if c == '"' { in_string = false; }
                continue;
            }
            match c {
                '"' => in_string = true,
                '{' => braces += 1,
                '}' => braces -= 1,
                '(' => parens += 1,
                ')' => parens -= 1,
                '[' => brackets += 1,
                ']' => brackets -= 1,
                _ => {}
            }
        }

        if braces == 0 && parens == 0 && brackets == 0 && !in_string {
            IsCompleteResult::Complete
        } else if braces < 0 || parens < 0 || brackets < 0 {
            IsCompleteResult::Invalid
        } else {
            IsCompleteResult::Incomplete { indent: "    ".to_string() }
        }
    }

    /// Handle shutdown_request
    pub fn shutdown(&mut self, restart: bool) {
        if restart {
            self.context = ReplContext::new();
            self.execution_count = 0;
        }
    }
}

pub enum ExecuteResult {
    Ok {
        execution_count: usize,
        data: HashMap<String, String>,
    },
    Error {
        ename: String,
        evalue: String,
        traceback: Vec<String>,
    },
}

pub struct CompleteResult {
    pub matches: Vec<String>,
    pub cursor_start: usize,
    pub cursor_end: usize,
    pub metadata: HashMap<String, String>,
}

pub struct InspectResult {
    pub found: bool,
    pub data: HashMap<String, String>,
}

pub enum IsCompleteResult {
    Complete,
    Incomplete { indent: String },
    Invalid,
    Unknown,
}

pub trait MessageHandler: Send + Sync {
    fn handle(&self, content: &[u8]) -> Vec<u8>;
}

fn uuid_v4() -> String {
    // Simple UUID v4 generator (placeholder)
    "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx".to_string()
}

