/// Show environment variables
pub struct EnvMagic;

impl LineMagic for EnvMagic {
    fn execute(&self, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        if args.is_empty() {
            let mut output = String::new();
            for (key, value) in std::env::vars() {
                output.push_str(&format!("{}={}\n", key, value));
            }
            Ok(MagicResult::Output(output))
        } else {
            let value = std::env::var(args).unwrap_or_else(|_| "undefined".to_string());
            Ok(MagicResult::Output(format!("{}={}", args, value)))
        }
    }

    fn help(&self) -> &str {
        "%env [VAR] - Show environment variables"
    }
}

