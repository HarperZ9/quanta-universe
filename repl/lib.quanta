/// List variables (detailed)
pub struct WhosMagic;

impl LineMagic for WhosMagic {
    fn execute(&self, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        let mut output = String::from("Variable   Type       Value\n");
        output.push_str("────────── ────────── ──────────\n");

        for (name, value) in &ctx.bindings {
            output.push_str(&format!("{:<10} {:<10} {}\n",
                name, value.type_name(), value.display()));
        }

        Ok(MagicResult::Output(output))
    }

    fn help(&self) -> &str {
        "%whos - List all interactive variables with details"
    }
}

