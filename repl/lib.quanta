// INPUT HANDLING
// ═══════════════════════════════════════════════════════════════════════════════

/// History manager
pub struct History {
    entries: VecDeque<String>,
    max_size: usize,
    position: usize,
}

impl History {
    pub fn new(max_size: usize) -> Self {
        History {
            entries: VecDeque::with_capacity(max_size),
            max_size,
            position: 0,
        }
    }

    pub fn add(&mut self, entry: String) {
        if !entry.is_empty() {
            // Don't add duplicates
            if self.entries.back() != Some(&entry) {
                if self.entries.len() >= self.max_size {
                    self.entries.pop_front();
                }
                self.entries.push_back(entry);
            }
        }
        self.position = self.entries.len();
    }

    pub fn previous(&mut self) -> Option<&String> {
        if self.position > 0 {
            self.position -= 1;
            self.entries.get(self.position)
        } else {
            None
        }
    }

    pub fn next(&mut self) -> Option<&String> {
        if self.position < self.entries.len() {
            self.position += 1;
            self.entries.get(self.position)
        } else {
            None
        }
    }

    pub fn search(&self, prefix: &str) -> Vec<&String> {
        self.entries.iter()
            .filter(|e| e.starts_with(prefix))
            .collect()
    }

    pub fn load(&mut self, path: &str) -> Result<(), String> {
        // Load history from file
        Ok(())
    }

    pub fn save(&self, path: &str) -> Result<(), String> {
        // Save history to file
        Ok(())
    }
}

/// Auto-completion engine
pub struct Completer {
    keywords: Vec<String>,
    builtins: Vec<String>,
}

impl Completer {
    pub fn new() -> Self {
        Completer {
            keywords: vec![
                "let", "mut", "fn", "pub", "struct", "enum", "impl", "trait",
                "if", "else", "match", "for", "while", "loop", "break", "continue",
                "return", "use", "mod", "type", "where", "async", "await",
                "true", "false", "self", "Self", "super", "crate",
            ].into_iter().map(String::from).collect(),
            builtins: vec![
                "println!", "print!", "format!", "vec!", "assert!", "assert_eq!",
                "dbg!", "todo!", "unimplemented!", "panic!",
            ].into_iter().map(String::from).collect(),
        }
    }

    pub fn complete(&self, input: &str, context: &ReplContext) -> Vec<Completion> {
        let mut completions = Vec::new();

        // Get the word being typed
        let word = input.split_whitespace().last().unwrap_or("");

        // Complete keywords
        for kw in &self.keywords {
            if kw.starts_with(word) {
                completions.push(Completion {
                    text: kw.clone(),
                    kind: CompletionKind::Keyword,
                    detail: None,
                });
            }
        }

        // Complete builtins
        for builtin in &self.builtins {
            if builtin.starts_with(word) {
                completions.push(Completion {
                    text: builtin.clone(),
                    kind: CompletionKind::Macro,
                    detail: None,
                });
            }
        }

        // Complete from context
        for (name, value) in context.list_bindings() {
            if name.starts_with(word) {
                completions.push(Completion {
                    text: name.clone(),
                    kind: CompletionKind::Variable,
                    detail: Some(value.type_name().to_string()),
                });
            }
        }

        completions
    }
}

pub struct Completion {
    pub text: String,
    pub kind: CompletionKind,
    pub detail: Option<String>,
}

#[derive(Clone, Copy)]
pub enum CompletionKind {
    Keyword,
    Variable,
    Function,
    Type,
    Module,
    Macro,
    Field,
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYNTAX HIGHLIGHTING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct Highlighter {
    theme: Theme,
    keywords: Vec<&'static str>,
}

impl Highlighter {
    pub fn new(theme: Theme) -> Self {
        Highlighter {
            theme,
            keywords: vec![
                "let", "mut", "fn", "pub", "struct", "enum", "impl", "trait",
                "if", "else", "match", "for", "while", "loop", "break", "continue",
                "return", "use", "mod", "type", "where", "async", "await",
                "true", "false", "self", "Self", "super", "crate",
            ],
        }
    }

    pub fn highlight(&self, input: &str) -> String {
        let mut result = String::new();
        let mut chars = input.chars().peekable();

        while let Some(c) = chars.next() {
            if c.is_alphabetic() || c == '_' {
                // Identifier or keyword
                let mut word = c.to_string();
                while let Some(&next) = chars.peek() {
                    if next.is_alphanumeric() || next == '_' {
                        word.push(chars.next().unwrap());
                    } else {
                        break;
                    }
                }

                if self.keywords.contains(&word.as_str()) {
                    result.push_str(self.theme.keyword.ansi_code());
                    result.push_str(&word);
                    result.push_str(Color::reset());
                } else if word.chars().next().unwrap().is_uppercase() {
                    result.push_str(self.theme.type_name.ansi_code());
                    result.push_str(&word);
                    result.push_str(Color::reset());
                } else {
                    result.push_str(&word);
                }
            } else if c == '"' {
                // String literal
                result.push_str(self.theme.string.ansi_code());
                result.push(c);
                while let Some(next) = chars.next() {
                    result.push(next);
                    if next == '"' {
                        break;
                    }
                    if next == '\\' {
                        if let Some(escaped) = chars.next() {
                            result.push(escaped);
                        }
                    }
                }
                result.push_str(Color::reset());
            } else if c.is_digit(10) {
                // Number
                result.push_str(self.theme.number.ansi_code());
                result.push(c);
                while let Some(&next) = chars.peek() {
                    if next.is_digit(10) || next == '.' || next == '_' {
                        result.push(chars.next().unwrap());
                    } else {
                        break;
                    }
                }
                result.push_str(Color::reset());
            } else if c == '/' && chars.peek() == Some(&'/') {
                // Comment
                result.push_str(self.theme.comment.ansi_code());
                result.push(c);
                while let Some(next) = chars.next() {
                    result.push(next);
                }
                result.push_str(Color::reset());
            } else {
                result.push(c);
            }
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EVALUATOR
// ═══════════════════════════════════════════════════════════════════════════════

pub struct Evaluator {
    context: ReplContext,
}

impl Evaluator {
    pub fn new(context: ReplContext) -> Self {
        Evaluator { context }
    }

    pub fn eval(&mut self, input: &str) -> Result<EvalResult, EvalError> {
        let input = input.trim();

        // Handle REPL commands
        if input.starts_with(':') {
            return self.eval_command(input);
        }

        // Handle variable binding
        if input.starts_with("let ") {
            return self.eval_let(input);
        }

        // Handle expression
        self.eval_expr(input)
    }

    fn eval_command(&mut self, input: &str) -> Result<EvalResult, EvalError> {
        let parts: Vec<&str> = input.splitn(2, ' ').collect();
        let cmd = parts[0];
        let args = parts.get(1).map(|s| *s).unwrap_or("");

        match cmd {
            ":help" | ":h" | ":?" => {
                Ok(EvalResult::Output(HELP_TEXT.to_string()))
            }
            ":quit" | ":q" | ":exit" => {
                Ok(EvalResult::Quit)
            }
            ":clear" | ":c" => {
                Ok(EvalResult::Clear)
            }
            ":type" | ":t" => {
                if let Some(value) = self.context.get(args) {
                    Ok(EvalResult::Output(format!("{}: {}", args, value.type_name())))
                } else {
                    Err(EvalError::UndefinedVariable(args.to_string()))
                }
            }
            ":bindings" | ":b" => {
                let mut output = String::new();
                for (name, value) in self.context.list_bindings() {
                    output.push_str(&format!("{}: {} = {}\n", name, value.type_name(), value.display()));
                }
                Ok(EvalResult::Output(output))
            }
            ":load" | ":l" => {
                self.load_file(args)?;
                Ok(EvalResult::Output(format!("Loaded {}", args)))
            }
            ":reset" => {
                self.context = ReplContext::new();
                Ok(EvalResult::Output("Context reset".to_string()))
            }
            ":time" => {
                Ok(EvalResult::ToggleTiming)
            }
            _ => {
                Err(EvalError::UnknownCommand(cmd.to_string()))
            }
        }
    }

    fn eval_let(&mut self, input: &str) -> Result<EvalResult, EvalError> {
        // Parse: let [mut] name [: type] = expr
        let input = input.strip_prefix("let ").unwrap().trim();

        let (name, expr) = if let Some(idx) = input.find('=') {
            let name = input[..idx].trim().to_string();
            let expr = input[idx + 1..].trim();
            (name, expr)
        } else {
            return Err(EvalError::SyntaxError("Expected '=' in let binding".to_string()));
        };

        // Remove mut and type annotation
        let name = name.replace("mut ", "").trim().to_string();
        let name = if let Some(idx) = name.find(':') {
            name[..idx].trim().to_string()
        } else {
            name
        };

        // Evaluate expression
        let result = self.eval_expr(expr)?;
        if let EvalResult::Value(value) = result {
            self.context.define(&name, value.clone());
            Ok(EvalResult::Value(value))
        } else {
            Err(EvalError::SyntaxError("Invalid expression".to_string()))
        }
    }

    fn eval_expr(&mut self, input: &str) -> Result<EvalResult, EvalError> {
        // Simple expression evaluator
        let input = input.trim();

        // Check for literals
        if input == "true" {
            return Ok(EvalResult::Value(Value::Bool(true)));
        }
        if input == "false" {
            return Ok(EvalResult::Value(Value::Bool(false)));
        }
        if input.starts_with('"') && input.ends_with('"') {
            let s = input[1..input.len()-1].to_string();
            return Ok(EvalResult::Value(Value::String(s)));
        }
        if let Ok(i) = input.parse::<i64>() {
            return Ok(EvalResult::Value(Value::Int(i)));
        }
        if let Ok(f) = input.parse::<f64>() {
            return Ok(EvalResult::Value(Value::Float(f)));
        }

        // Check for variable reference
        if let Some(value) = self.context.get(input) {
            return Ok(EvalResult::Value(value.clone()));
        }

        // Check for simple binary operations
        if let Some(result) = self.eval_binary_op(input) {
            return result;
        }

        // Check for function calls
        if input.contains('(') && input.ends_with(')') {
            return self.eval_function_call(input);
        }

        Err(EvalError::SyntaxError(format!("Cannot evaluate: {}", input)))
    }

    fn eval_binary_op(&mut self, input: &str) -> Option<Result<EvalResult, EvalError>> {
        let ops = ["+", "-", "*", "/", "%", "==", "!=", "<", ">", "<=", ">=", "&&", "||"];

        for op in ops {
            if let Some(idx) = input.find(op) {
                let left = input[..idx].trim();
                let right = input[idx + op.len()..].trim();

                let left_val = match self.eval_expr(left) {
                    Ok(EvalResult::Value(v)) => v,
                    Err(e) => return Some(Err(e)),
                    _ => return None,
                };

                let right_val = match self.eval_expr(right) {
                    Ok(EvalResult::Value(v)) => v,
                    Err(e) => return Some(Err(e)),
                    _ => return None,
                };

                let result = match (op, &left_val, &right_val) {
                    ("+", Value::Int(a), Value::Int(b)) => Value::Int(a + b),
                    ("+", Value::Float(a), Value::Float(b)) => Value::Float(a + b),
                    ("+", Value::String(a), Value::String(b)) => Value::String(format!("{}{}", a, b)),
                    ("-", Value::Int(a), Value::Int(b)) => Value::Int(a - b),
                    ("-", Value::Float(a), Value::Float(b)) => Value::Float(a - b),
                    ("*", Value::Int(a), Value::Int(b)) => Value::Int(a * b),
                    ("*", Value::Float(a), Value::Float(b)) => Value::Float(a * b),
                    ("/", Value::Int(a), Value::Int(b)) => Value::Int(a / b),
                    ("/", Value::Float(a), Value::Float(b)) => Value::Float(a / b),
                    ("%", Value::Int(a), Value::Int(b)) => Value::Int(a % b),
                    ("==", Value::Int(a), Value::Int(b)) => Value::Bool(a == b),
                    ("==", Value::Bool(a), Value::Bool(b)) => Value::Bool(a == b),
                    ("!=", Value::Int(a), Value::Int(b)) => Value::Bool(a != b),
                    ("<", Value::Int(a), Value::Int(b)) => Value::Bool(a < b),
                    (">", Value::Int(a), Value::Int(b)) => Value::Bool(a > b),
                    ("<=", Value::Int(a), Value::Int(b)) => Value::Bool(a <= b),
                    (">=", Value::Int(a), Value::Int(b)) => Value::Bool(a >= b),
                    ("&&", Value::Bool(a), Value::Bool(b)) => Value::Bool(*a && *b),
                    ("||", Value::Bool(a), Value::Bool(b)) => Value::Bool(*a || *b),
                    _ => return Some(Err(EvalError::TypeError(format!(
                        "Cannot apply {} to {} and {}",
                        op, left_val.type_name(), right_val.type_name()
                    )))),
                };

                return Some(Ok(EvalResult::Value(result)));
            }
        }

        None
    }

    fn eval_function_call(&mut self, input: &str) -> Result<EvalResult, EvalError> {
        let paren_idx = input.find('(').unwrap();
        let func_name = input[..paren_idx].trim();
        let args_str = &input[paren_idx + 1..input.len() - 1];

        // Built-in functions
        match func_name {
            "println!" => {
                let output = if args_str.starts_with('"') {
                    args_str[1..args_str.len()-1].to_string()
                } else {
                    match self.eval_expr(args_str)? {
                        EvalResult::Value(v) => v.display(),
                        _ => args_str.to_string(),
                    }
                };
                println!("{}", output);
                Ok(EvalResult::Value(Value::Unit))
            }
            "sqrt" => {
                match self.eval_expr(args_str)? {
                    EvalResult::Value(Value::Float(f)) => Ok(EvalResult::Value(Value::Float(f.sqrt()))),
                    EvalResult::Value(Value::Int(i)) => Ok(EvalResult::Value(Value::Float((i as f64).sqrt()))),
                    _ => Err(EvalError::TypeError("sqrt requires a number".to_string())),
                }
            }
            "sin" => {
                match self.eval_expr(args_str)? {
                    EvalResult::Value(Value::Float(f)) => Ok(EvalResult::Value(Value::Float(f.sin()))),
                    _ => Err(EvalError::TypeError("sin requires a float".to_string())),
                }
            }
            "cos" => {
                match self.eval_expr(args_str)? {
                    EvalResult::Value(Value::Float(f)) => Ok(EvalResult::Value(Value::Float(f.cos()))),
                    _ => Err(EvalError::TypeError("cos requires a float".to_string())),
                }
            }
            "abs" => {
                match self.eval_expr(args_str)? {
                    EvalResult::Value(Value::Int(i)) => Ok(EvalResult::Value(Value::Int(i.abs()))),
                    EvalResult::Value(Value::Float(f)) => Ok(EvalResult::Value(Value::Float(f.abs()))),
                    _ => Err(EvalError::TypeError("abs requires a number".to_string())),
                }
            }
            _ => Err(EvalError::UndefinedFunction(func_name.to_string())),
        }
    }

    fn load_file(&mut self, path: &str) -> Result<(), EvalError> {
        // Load and execute file
        Ok(())
    }
}

#[derive(Debug)]
pub enum EvalResult {
    Value(Value),
    Output(String),
    Quit,
    Clear,
    ToggleTiming,
}

#[derive(Debug)]
pub enum EvalError {
    SyntaxError(String),
    TypeError(String),
    UndefinedVariable(String),
    UndefinedFunction(String),
    UnknownCommand(String),
    IoError(String),
}

const HELP_TEXT: &str = r#"
QUANTA REPL Commands:
  :help, :h, :?     Show this help
  :quit, :q, :exit  Exit the REPL
  :clear, :c        Clear the screen
  :type <name>      Show the type of a binding
  :bindings, :b     List all bindings
  :load <file>      Load and execute a file
  :reset            Reset the context
  :time             Toggle timing display

Keyboard shortcuts:
  Up/Down           Navigate history
  Tab               Auto-complete
  Ctrl+C            Cancel current input
  Ctrl+D            Exit (same as :quit)
"#;

// ═══════════════════════════════════════════════════════════════════════════════
// REPL MAIN
// ═══════════════════════════════════════════════════════════════════════════════

/// The main REPL
pub struct Repl {
    config: ReplConfig,
    context: ReplContext,
    history: History,
    completer: Completer,
    highlighter: Highlighter,
    evaluator: Evaluator,
    show_timing: bool,
}

impl Repl {
    pub fn new() -> Self {
        let config = ReplConfig::default();
        let context = ReplContext::new();
        let history = History::new(config.history_size);
        let completer = Completer::new();
        let highlighter = Highlighter::new(config.theme.clone());
        let evaluator = Evaluator::new(ReplContext::new());

        Repl {
            config,
            context,
            history,
            completer,
            highlighter,
            evaluator,
            show_timing: false,
        }
    }

    pub fn with_config(config: ReplConfig) -> Self {
        let context = ReplContext::new();
        let history = History::new(config.history_size);
        let completer = Completer::new();
        let highlighter = Highlighter::new(config.theme.clone());
        let evaluator = Evaluator::new(ReplContext::new());

        Repl {
            config,
            context,
            history,
            completer,
            highlighter,
            evaluator,
            show_timing: false,
        }
    }

    /// Run the REPL
    pub fn run(&mut self) {
        self.print_banner();

        // Load history
        let _ = self.history.load(&self.config.history_file);

        loop {
            // Print prompt
            print!("{}", self.config.prompt);
            flush();

            // Read input
            let mut input = String::new();
            match stdin().read_line(&mut input) {
                Ok(0) => break, // EOF
                Ok(_) => {}
                Err(_) => continue,
            }

            let input = input.trim();
            if input.is_empty() {
                continue;
            }

            // Handle multi-line input
            let input = self.read_multiline(input);

            // Add to history
            self.history.add(input.clone());

            // Evaluate
            let start = Instant::now();
            match self.evaluator.eval(&input) {
                Ok(EvalResult::Value(value)) => {
                    if self.config.show_types {
                        println!("{}: {} = {}",
                            Color::Gray.ansi_code(),
                            value.type_name(),
                            Color::reset());
                    }
                    println!("{}", value.display());

                    if self.show_timing {
                        println!("{}({}ms){}",
                            Color::Gray.ansi_code(),
                            start.elapsed().as_millis(),
                            Color::reset());
                    }
                }
                Ok(EvalResult::Output(output)) => {
                    println!("{}", output);
                }
                Ok(EvalResult::Quit) => {
                    println!("Goodbye!");
                    break;
                }
                Ok(EvalResult::Clear) => {
                    print!("\x1b[2J\x1b[H"); // Clear screen
                }
                Ok(EvalResult::ToggleTiming) => {
                    self.show_timing = !self.show_timing;
                    println!("Timing display: {}", if self.show_timing { "on" } else { "off" });
                }
                Err(e) => {
                    println!("{}Error: {:?}{}",
                        self.config.theme.error.ansi_code(),
                        e,
                        Color::reset());
                }
            }
        }

        // Save history
        let _ = self.history.save(&self.config.history_file);
    }

    fn print_banner(&self) {
        println!("╔═══════════════════════════════════════════════════════════════╗");
        println!("║  QUANTA-UNIVERSE REPL v2.0.0                                  ║");
        println!("║  \"Quantum Shell\"                                              ║");
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("Type :help for help, :quit to exit");
        println!();
    }

    fn read_multiline(&mut self, first_line: &str) -> String {
        let mut input = first_line.to_string();

        // Check if we need more lines (unclosed braces, parens, etc.)
        while self.needs_continuation(&input) {
            print!("{}", self.config.continuation_prompt);
            flush();

            let mut line = String::new();
            match stdin().read_line(&mut line) {
                Ok(0) => break,
                Ok(_) => {
                    input.push('\n');
                    input.push_str(line.trim());
                }
                Err(_) => break,
            }
        }

        input
    }

    fn needs_continuation(&self, input: &str) -> bool {
        let mut braces = 0;
        let mut parens = 0;
        let mut brackets = 0;
        let mut in_string = false;

        for c in input.chars() {
            if in_string {
                if c == '"' {
                    in_string = false;
                }
                continue;
            }

            match c {
                '"' => in_string = true,
                '{' => braces += 1,
                '}' => braces -= 1,
                '(' => parens += 1,
                ')' => parens -= 1,
                '[' => brackets += 1,
                ']' => brackets -= 1,
                _ => {}
            }
        }

        braces > 0 || parens > 0 || brackets > 0
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN ENTRY POINT
// ═══════════════════════════════════════════════════════════════════════════════

pub fn main() {
    let mut repl = Repl::new();
    repl.run();
}

fn flush() {
    stdout().flush().unwrap();
}

