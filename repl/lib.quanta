// ADVANCED REPL: MAGIC COMMANDS
// ═══════════════════════════════════════════════════════════════════════════════

/// Magic command system (inspired by IPython)
pub struct MagicCommandRegistry {
    /// Line magics (%command)
    line_magics: HashMap<String, Box<dyn LineMagic>>,
    /// Cell magics (%%command)
    cell_magics: HashMap<String, Box<dyn CellMagic>>,
    /// Magic aliases
    aliases: HashMap<String, String>,
}

impl MagicCommandRegistry {
    pub fn new() -> Self {
        let mut registry = MagicCommandRegistry {
            line_magics: HashMap::new(),
            cell_magics: HashMap::new(),
            aliases: HashMap::new(),
        };

        // Register built-in line magics
        registry.register_line_magic("time", Box::new(TimeMagic));
        registry.register_line_magic("timeit", Box::new(TimeitMagic { iterations: 100 }));
        registry.register_line_magic("run", Box::new(RunMagic));
        registry.register_line_magic("load", Box::new(LoadMagic));
        registry.register_line_magic("save", Box::new(SaveMagic));
        registry.register_line_magic("who", Box::new(WhoMagic));
        registry.register_line_magic("whos", Box::new(WhosMagic));
        registry.register_line_magic("reset", Box::new(ResetMagic));
        registry.register_line_magic("clear", Box::new(ClearMagic));
        registry.register_line_magic("pwd", Box::new(PwdMagic));
        registry.register_line_magic("cd", Box::new(CdMagic));
        registry.register_line_magic("ls", Box::new(LsMagic));
        registry.register_line_magic("env", Box::new(EnvMagic));
        registry.register_line_magic("edit", Box::new(EditMagic));
        registry.register_line_magic("history", Box::new(HistoryMagic));
        registry.register_line_magic("profile", Box::new(ProfileMagic));
        registry.register_line_magic("debug", Box::new(DebugMagic));
        registry.register_line_magic("pdb", Box::new(PdbMagic));
        registry.register_line_magic("doc", Box::new(DocMagic));
        registry.register_line_magic("source", Box::new(SourceMagic));
        registry.register_line_magic("lsmagic", Box::new(LsMagicMagic));
        registry.register_line_magic("alias", Box::new(AliasMagic));
        registry.register_line_magic("unalias", Box::new(UnaliasMagic));
        registry.register_line_magic("macro", Box::new(MacroMagic));
        registry.register_line_magic("store", Box::new(StoreMagic));
        registry.register_line_magic("recall", Box::new(RecallMagic));
        registry.register_line_magic("pip", Box::new(PipMagic));
        registry.register_line_magic("system", Box::new(SystemMagic));
        registry.register_line_magic("writefile", Box::new(WriteFileMagic));
        registry.register_line_magic("xmode", Box::new(XModeMagic));
        registry.register_line_magic("precision", Box::new(PrecisionMagic));

        // Register built-in cell magics
        registry.register_cell_magic("timeit", Box::new(CellTimeitMagic));
        registry.register_cell_magic("capture", Box::new(CaptureMagic));
        registry.register_cell_magic("bash", Box::new(BashMagic));
        registry.register_cell_magic("sql", Box::new(SqlMagic));
        registry.register_cell_magic("html", Box::new(HtmlMagic));
        registry.register_cell_magic("markdown", Box::new(MarkdownMagic));
        registry.register_cell_magic("latex", Box::new(LatexMagic));
        registry.register_cell_magic("javascript", Box::new(JavaScriptMagic));
        registry.register_cell_magic("python", Box::new(PythonMagic));
        registry.register_cell_magic("rust", Box::new(RustMagic));
        registry.register_cell_magic("file", Box::new(FileMagic));
        registry.register_cell_magic("debug", Box::new(CellDebugMagic));

        // Common aliases
        registry.aliases.insert("r".to_string(), "run".to_string());
        registry.aliases.insert("h".to_string(), "history".to_string());
        registry.aliases.insert("d".to_string(), "doc".to_string());
        registry.aliases.insert("!".to_string(), "system".to_string());

        registry
    }

    pub fn register_line_magic(&mut self, name: &str, magic: Box<dyn LineMagic>) {
        self.line_magics.insert(name.to_string(), magic);
    }

    pub fn register_cell_magic(&mut self, name: &str, magic: Box<dyn CellMagic>) {
        self.cell_magics.insert(name.to_string(), magic);
    }

    pub fn execute_line_magic(&self, name: &str, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        let name = self.aliases.get(name).map(|s| s.as_str()).unwrap_or(name);

        if let Some(magic) = self.line_magics.get(name) {
            magic.execute(args, ctx)
        } else {
            Err(MagicError::UnknownMagic(name.to_string()))
        }
    }

    pub fn execute_cell_magic(&self, name: &str, args: &str, body: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        if let Some(magic) = self.cell_magics.get(name) {
            magic.execute(args, body, ctx)
        } else {
            Err(MagicError::UnknownMagic(name.to_string()))
        }
    }

    pub fn list_magics(&self) -> (Vec<&String>, Vec<&String>) {
        let line_magics: Vec<_> = self.line_magics.keys().collect();
        let cell_magics: Vec<_> = self.cell_magics.keys().collect();
        (line_magics, cell_magics)
    }
}

/// Line magic trait (%command args)
pub trait LineMagic: Send + Sync {
    fn execute(&self, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError>;
    fn help(&self) -> &str;
}

/// Cell magic trait (%%command args\nbody)
pub trait CellMagic: Send + Sync {
    fn execute(&self, args: &str, body: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError>;
    fn help(&self) -> &str;
}

#[derive(Debug)]
pub enum MagicResult {
    None,
    Output(String),
    Value(Value),
    Display(DisplayData),
    Timing(TimingInfo),
}

#[derive(Debug)]
pub struct TimingInfo {
    pub wall_time: Duration,
    pub cpu_time: Duration,
    pub iterations: usize,
    pub mean: Duration,
    pub std_dev: Duration,
}

#[derive(Debug)]
pub enum MagicError {
    UnknownMagic(String),
    InvalidArguments(String),
    ExecutionError(String),
    IoError(String),
}

/// Time execution of a single statement
pub struct TimeMagic;

impl LineMagic for TimeMagic {
    fn execute(&self, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        let start = Instant::now();
        // Execute the expression (placeholder)
        let wall_time = start.elapsed();

        Ok(MagicResult::Timing(TimingInfo {
            wall_time,
            cpu_time: wall_time,
            iterations: 1,
            mean: wall_time,
            std_dev: Duration::from_secs(0),
        }))
    }

    fn help(&self) -> &str {
        "%time statement - Time execution of a single statement"
    }
}

/// Time execution with multiple iterations
pub struct TimeitMagic {
    iterations: usize,
}

impl LineMagic for TimeitMagic {
    fn execute(&self, args: &str, ctx: &mut ReplContext) -> Result<MagicResult, MagicError> {
        let mut times = Vec::with_capacity(self.iterations);

        for _ in 0..self.iterations {
            let start = Instant::now();
            // Execute (placeholder)
            times.push(start.elapsed());
        }

        let total: Duration = times.iter().sum();
        let mean = total / self.iterations as u32;

        // Calculate std dev
        let variance: f64 = times.iter()
            .map(|t| {
                let diff = t.as_nanos() as f64 - mean.as_nanos() as f64;
                diff * diff
            })
            .sum::<f64>() / self.iterations as f64;
        let std_dev = Duration::from_nanos(variance.sqrt() as u64);

        Ok(MagicResult::Timing(TimingInfo {
            wall_time: total,
            cpu_time: total,
            iterations: self.iterations,
            mean,
            std_dev,
        }))
    }

    fn help(&self) -> &str {
        "%timeit statement - Time execution with multiple iterations"
    }
}

