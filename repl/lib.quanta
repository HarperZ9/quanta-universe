// ═══════════════════════════════════════════════════════════════════════════════
// RICH OUTPUT FORMATTING
// ═══════════════════════════════════════════════════════════════════════════════

/// Rich display data
#[derive(Debug, Clone)]
pub enum DisplayData {
    Plain(String),
    Html(String),
    Markdown(String),
    Latex(String),
    JavaScript(String),
    Json(String),
    Svg(String),
    Png(Vec<u8>),
    Jpeg(Vec<u8>),
    Table(TableData),
    Chart(ChartData),
    Progress(ProgressData),
    Tree(TreeData),
}

/// Table rendering
#[derive(Debug, Clone)]
pub struct TableData {
    pub headers: Vec<String>,
    pub rows: Vec<Vec<String>>,
    pub style: TableStyle,
}

impl TableData {
    pub fn new(headers: Vec<String>, rows: Vec<Vec<String>>) -> Self {
        TableData {
            headers,
            rows,
            style: TableStyle::default(),
        }
    }

    pub fn render(&self) -> String {
        let mut output = String::new();
        let col_widths = self.calculate_column_widths();

        // Header separator
        output.push_str(&self.render_separator(&col_widths, '┌', '┬', '┐'));

        // Headers
        output.push('│');
        for (i, header) in self.headers.iter().enumerate() {
            output.push_str(&format!(" {:^width$} │", header, width = col_widths[i]));
        }
        output.push('\n');

        // Header-body separator
        output.push_str(&self.render_separator(&col_widths, '├', '┼', '┤'));

        // Rows
        for row in &self.rows {
            output.push('│');
            for (i, cell) in row.iter().enumerate() {
                let width = col_widths.get(i).copied().unwrap_or(10);
                output.push_str(&format!(" {:<width$} │", cell, width = width));
            }
            output.push('\n');
        }

        // Footer separator
        output.push_str(&self.render_separator(&col_widths, '└', '┴', '┘'));

        output
    }

    fn calculate_column_widths(&self) -> Vec<usize> {
        let mut widths: Vec<usize> = self.headers.iter().map(|h| h.len()).collect();

        for row in &self.rows {
            for (i, cell) in row.iter().enumerate() {
                if i < widths.len() {
                    widths[i] = widths[i].max(cell.len());
                }
            }
        }

        widths
    }

    fn render_separator(&self, widths: &[usize], left: char, mid: char, right: char) -> String {
        let mut sep = String::new();
        sep.push(left);
        for (i, &width) in widths.iter().enumerate() {
            sep.push_str(&"─".repeat(width + 2));
            if i < widths.len() - 1 {
                sep.push(mid);
            }
        }
        sep.push(right);
        sep.push('\n');
        sep
    }
}

#[derive(Debug, Clone)]
pub struct TableStyle {
    pub border: bool,
    pub header_style: TextStyle,
    pub row_style: TextStyle,
    pub alternate_rows: bool,
}

impl Default for TableStyle {
    fn default() -> Self {
        TableStyle {
            border: true,
            header_style: TextStyle::Bold,
            row_style: TextStyle::Normal,
            alternate_rows: true,
        }
    }
}

#[derive(Debug, Clone, Copy)]
pub enum TextStyle {
    Normal,
    Bold,
    Italic,
    Underline,
    Dim,
}

/// Chart rendering (ASCII art)
#[derive(Debug, Clone)]
pub struct ChartData {
    pub chart_type: ChartType,
    pub title: Option<String>,
    pub data: Vec<DataPoint>,
    pub width: usize,
    pub height: usize,
}

#[derive(Debug, Clone)]
pub enum ChartType {
    Bar,
    Line,
    Scatter,
    Histogram,
    Pie,
    Sparkline,
}

#[derive(Debug, Clone)]
pub struct DataPoint {
    pub label: String,
    pub value: f64,
    pub color: Option<Color>,
}

impl ChartData {
    pub fn bar(title: &str, data: Vec<(&str, f64)>) -> Self {
        ChartData {
            chart_type: ChartType::Bar,
            title: Some(title.to_string()),
            data: data.into_iter().map(|(l, v)| DataPoint {
                label: l.to_string(),
                value: v,
                color: None,
            }).collect(),
            width: 60,
            height: 20,
        }
    }

    pub fn render(&self) -> String {
        match self.chart_type {
            ChartType::Bar => self.render_bar(),
            ChartType::Sparkline => self.render_sparkline(),
            _ => self.render_bar(),
        }
    }

    fn render_bar(&self) -> String {
        let mut output = String::new();

        if let Some(title) = &self.title {
            output.push_str(&format!("  {}\n", title));
            output.push_str(&"─".repeat(self.width));
            output.push('\n');
        }

        let max_value = self.data.iter().map(|d| d.value).fold(0.0, f64::max);
        let max_label_len = self.data.iter().map(|d| d.label.len()).max().unwrap_or(0);
        let bar_width = self.width - max_label_len - 15;

        for point in &self.data {
            let bar_len = ((point.value / max_value) * bar_width as f64) as usize;
            output.push_str(&format!("{:>width$} │{} {:>8.2}\n",
                point.label,
                "█".repeat(bar_len),
                point.value,
                width = max_label_len
            ));
        }

        output
    }

    fn render_sparkline(&self) -> String {
        let blocks = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];
        let values: Vec<f64> = self.data.iter().map(|d| d.value).collect();
        let min = values.iter().fold(f64::INFINITY, |a, &b| a.min(b));
        let max = values.iter().fold(f64::NEG_INFINITY, |a, &b| a.max(b));
        let range = max - min;

        let mut output = String::new();
        for &value in &values {
            let normalized = if range > 0.0 {
                (value - min) / range
            } else {
                0.5
            };
            let index = (normalized * 7.0) as usize;
            output.push(blocks[index.min(7)]);
        }
        output
    }
}

/// Progress bar
#[derive(Debug, Clone)]
pub struct ProgressData {
    pub current: usize,
    pub total: usize,
    pub message: String,
    pub width: usize,
    pub style: ProgressStyle,
}

#[derive(Debug, Clone)]
pub enum ProgressStyle {
    Bar,
    Spinner,
    Dots,
}

impl ProgressData {
    pub fn new(current: usize, total: usize) -> Self {
        ProgressData {
            current,
            total,
            message: String::new(),
            width: 40,
            style: ProgressStyle::Bar,
        }
    }

    pub fn render(&self) -> String {
        let percentage = (self.current as f64 / self.total as f64) * 100.0;
        let filled = ((percentage / 100.0) * self.width as f64) as usize;
        let empty = self.width - filled;

        format!("[{}{}] {:>5.1}% {} ({}/{})",
            "█".repeat(filled),
            "░".repeat(empty),
            percentage,
            self.message,
            self.current,
            self.total
        )
    }
}

/// Tree data for hierarchical display
#[derive(Debug, Clone)]
pub struct TreeData {
    pub root: TreeNode,
    pub show_lines: bool,
}

#[derive(Debug, Clone)]
pub struct TreeNode {
    pub label: String,
    pub children: Vec<TreeNode>,
    pub expanded: bool,
}

impl TreeData {
    pub fn render(&self) -> String {
        let mut output = String::new();
        self.render_node(&self.root, "", true, &mut output);
        output
    }

    fn render_node(&self, node: &TreeNode, prefix: &str, is_last: bool, output: &mut String) {
        let connector = if is_last { "└── " } else { "├── " };
        output.push_str(prefix);
        output.push_str(connector);
        output.push_str(&node.label);
        output.push('\n');

        let new_prefix = format!("{}{}", prefix, if is_last { "    " } else { "│   " });

        for (i, child) in node.children.iter().enumerate() {
            let is_last_child = i == node.children.len() - 1;
            self.render_node(child, &new_prefix, is_last_child, output);
        }
    }
}

