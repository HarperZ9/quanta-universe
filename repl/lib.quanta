// PLUGIN SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// REPL plugin interface
pub trait ReplPlugin: Send + Sync {
    /// Plugin name
    fn name(&self) -> &str;

    /// Plugin version
    fn version(&self) -> &str;

    /// Initialize plugin
    fn init(&mut self, ctx: &mut ReplContext) -> Result<(), PluginError>;

    /// Cleanup plugin
    fn cleanup(&mut self) -> Result<(), PluginError>;

    /// Handle input (before evaluation)
    fn pre_eval(&mut self, input: &str) -> Option<String> {
        None
    }

    /// Handle output (after evaluation)
    fn post_eval(&mut self, result: &EvalResult) -> Option<String> {
        None
    }

    /// Register commands
    fn commands(&self) -> Vec<PluginCommand> {
        Vec::new()
    }

    /// Register completions
    fn completions(&self, prefix: &str) -> Vec<Completion> {
        Vec::new()
    }
}

#[derive(Debug)]
pub enum PluginError {
    InitFailed(String),
    LoadFailed(String),
    CommandError(String),
}

pub struct PluginCommand {
    pub name: String,
    pub description: String,
    pub handler: Box<dyn Fn(&str, &mut ReplContext) -> Result<String, String> + Send + Sync>,
}

/// Plugin manager
pub struct PluginManager {
    /// Loaded plugins
    plugins: Vec<Box<dyn ReplPlugin>>,
    /// Plugin search paths
    search_paths: Vec<String>,
    /// Plugin registry
    registry: HashMap<String, PluginInfo>,
}

pub struct PluginInfo {
    pub name: String,
    pub version: String,
    pub path: String,
    pub enabled: bool,
}

impl PluginManager {
    pub fn new() -> Self {
        PluginManager {
            plugins: Vec::new(),
            search_paths: vec![
                "~/.quanta/plugins".to_string(),
                "/usr/local/share/quanta/plugins".to_string(),
            ],
            registry: HashMap::new(),
        }
    }

    /// Load plugin by name
    pub fn load(&mut self, name: &str) -> Result<(), PluginError> {
        // Load plugin (placeholder)
        Ok(())
    }

    /// Unload plugin
    pub fn unload(&mut self, name: &str) -> Result<(), PluginError> {
        self.plugins.retain(|p| p.name() != name);
        Ok(())
    }

    /// List loaded plugins
    pub fn list(&self) -> Vec<(&str, &str)> {
        self.plugins.iter().map(|p| (p.name(), p.version())).collect()
    }

    /// Discover available plugins
    pub fn discover(&mut self) {
        // Scan search paths (placeholder)
    }

    /// Call pre_eval hooks
    pub fn pre_eval(&mut self, input: &str) -> String {
        let mut result = input.to_string();
        for plugin in &mut self.plugins {
            if let Some(transformed) = plugin.pre_eval(&result) {
                result = transformed;
            }
        }
        result
    }

    /// Call post_eval hooks
    pub fn post_eval(&mut self, eval_result: &EvalResult) -> Option<String> {
        for plugin in &mut self.plugins {
            if let Some(output) = plugin.post_eval(eval_result) {
                return Some(output);
            }
        }
        None
    }

    /// Get all plugin commands
    pub fn commands(&self) -> Vec<&PluginCommand> {
        self.plugins.iter()
            .flat_map(|p| p.commands().iter())
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEBUGGER INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Integrated debugger for REPL
pub struct ReplDebugger {
    /// Breakpoints
    breakpoints: Vec<Breakpoint>,
    /// Watch expressions
    watches: Vec<WatchExpression>,
    /// Debug mode
    mode: DebugMode,
    /// Call stack
    stack: Vec<StackFrame>,
    /// Current frame index
    current_frame: usize,
}

#[derive(Clone)]
pub struct Breakpoint {
    pub id: usize,
    pub location: BreakpointLocation,
    pub condition: Option<String>,
    pub hit_count: usize,
    pub enabled: bool,
}

#[derive(Clone)]
pub enum BreakpointLocation {
    Line { file: String, line: usize },
    Function { name: String },
    Exception { type_name: String },
}

#[derive(Clone)]
pub struct WatchExpression {
    pub id: usize,
    pub expression: String,
    pub last_value: Option<Value>,
}

#[derive(Clone, Copy)]
pub enum DebugMode {
    Running,
    Paused,
    StepInto,
    StepOver,
    StepOut,
}

#[derive(Clone)]
pub struct StackFrame {
    pub function: String,
    pub file: String,
    pub line: usize,
    pub locals: HashMap<String, Value>,
}

impl ReplDebugger {
    pub fn new() -> Self {
        ReplDebugger {
            breakpoints: Vec::new(),
            watches: Vec::new(),
            mode: DebugMode::Running,
            stack: Vec::new(),
            current_frame: 0,
        }
    }

    /// Add breakpoint
    pub fn add_breakpoint(&mut self, location: BreakpointLocation) -> usize {
        let id = self.breakpoints.len();
        self.breakpoints.push(Breakpoint {
            id,
            location,
            condition: None,
            hit_count: 0,
            enabled: true,
        });
        id
    }

    /// Remove breakpoint
    pub fn remove_breakpoint(&mut self, id: usize) -> bool {
        if let Some(idx) = self.breakpoints.iter().position(|b| b.id == id) {
            self.breakpoints.remove(idx);
            true
        } else {
            false
        }
    }

    /// Toggle breakpoint
    pub fn toggle_breakpoint(&mut self, id: usize) -> bool {
        if let Some(bp) = self.breakpoints.iter_mut().find(|b| b.id == id) {
            bp.enabled = !bp.enabled;
            true
        } else {
            false
        }
    }

    /// List breakpoints
    pub fn list_breakpoints(&self) -> &[Breakpoint] {
        &self.breakpoints
    }

    /// Add watch expression
    pub fn add_watch(&mut self, expression: &str) -> usize {
        let id = self.watches.len();
        self.watches.push(WatchExpression {
            id,
            expression: expression.to_string(),
            last_value: None,
        });
        id
    }

    /// Remove watch
    pub fn remove_watch(&mut self, id: usize) -> bool {
        if let Some(idx) = self.watches.iter().position(|w| w.id == id) {
            self.watches.remove(idx);
            true
        } else {
            false
        }
    }

    /// Step into
    pub fn step_into(&mut self) {
        self.mode = DebugMode::StepInto;
    }

    /// Step over
    pub fn step_over(&mut self) {
        self.mode = DebugMode::StepOver;
    }

    /// Step out
    pub fn step_out(&mut self) {
        self.mode = DebugMode::StepOut;
    }

    /// Continue execution
    pub fn continue_execution(&mut self) {
        self.mode = DebugMode::Running;
    }

    /// Get current stack
    pub fn stack(&self) -> &[StackFrame] {
        &self.stack
    }

    /// Select stack frame
    pub fn select_frame(&mut self, index: usize) -> bool {
        if index < self.stack.len() {
            self.current_frame = index;
            true
        } else {
            false
        }
    }

    /// Get locals for current frame
    pub fn locals(&self) -> Option<&HashMap<String, Value>> {
        self.stack.get(self.current_frame).map(|f| &f.locals)
    }

    /// Evaluate expression in current context
    pub fn evaluate(&self, expr: &str) -> Result<Value, String> {
        // Evaluate in debug context (placeholder)
        Ok(Value::Unit)
    }

    /// Format stack trace
    pub fn format_stack(&self) -> String {
        let mut output = String::new();
        for (i, frame) in self.stack.iter().enumerate() {
            let marker = if i == self.current_frame { ">" } else { " " };
            output.push_str(&format!("{} #{}: {} at {}:{}\n",
                marker, i, frame.function, frame.file, frame.line));
        }
        output
    }
}

