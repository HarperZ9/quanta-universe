module repl

use foundation::io::{println, print, stdin, stdout, flush}
use foundation::collections::{Vec, HashMap, VecDeque}
use foundation::time::Instant

// ═══════════════════════════════════════════════════════════════════════════════
// REPL CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone)]
pub struct ReplConfig {
    pub prompt: String,
    pub continuation_prompt: String,
    pub history_size: usize,
    pub history_file: String,
    pub auto_complete: bool,
    pub syntax_highlight: bool,
    pub show_types: bool,
    pub show_timing: bool,
    pub theme: Theme,
}

impl Default for ReplConfig {
    fn default() -> Self {
        ReplConfig {
            prompt: "quanta> ".to_string(),
            continuation_prompt: "     .. ".to_string(),
            history_size: 1000,
            history_file: "~/.quanta/history".to_string(),
            auto_complete: true,
            syntax_highlight: true,
            show_types: true,
            show_timing: false,
            theme: Theme::default(),
        }
    }
}

#[derive(Clone)]
pub struct Theme {
    pub keyword: Color,
    pub string: Color,
    pub number: Color,
    pub comment: Color,
    pub function: Color,
    pub type_name: Color,
    pub operator: Color,
    pub error: Color,
    pub output: Color,
}

impl Default for Theme {
    fn default() -> Self {
        Theme {
            keyword: Color::Magenta,
            string: Color::Green,
            number: Color::Cyan,
            comment: Color::Gray,
            function: Color::Blue,
            type_name: Color::Yellow,
            operator: Color::White,
            error: Color::Red,
            output: Color::White,
        }
    }
}

#[derive(Clone, Copy)]
pub enum Color {
    Black,
    Red,
    Green,
    Yellow,
    Blue,
    Magenta,
    Cyan,
    White,
    Gray,
}

impl Color {
    pub fn ansi_code(&self) -> &str {
        match self {
            Color::Black => "\x1b[30m",
            Color::Red => "\x1b[31m",
            Color::Green => "\x1b[32m",
            Color::Yellow => "\x1b[33m",
            Color::Blue => "\x1b[34m",
            Color::Magenta => "\x1b[35m",
            Color::Cyan => "\x1b[36m",
            Color::White => "\x1b[37m",
            Color::Gray => "\x1b[90m",
        }
    }

    pub fn reset() -> &'static str {
        "\x1b[0m"
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPL STATE
// ═══════════════════════════════════════════════════════════════════════════════

/// REPL execution context
pub struct ReplContext {
    /// Variable bindings
    pub bindings: HashMap<String, Value>,
    /// Loaded modules
    pub modules: HashMap<String, ModuleContext>,
    /// Type definitions
    pub types: HashMap<String, TypeDef>,
    /// Function definitions
    pub functions: HashMap<String, FunctionDef>,
    /// Import aliases
    pub imports: HashMap<String, String>,
}

impl ReplContext {
    pub fn new() -> Self {
        let mut ctx = ReplContext {
            bindings: HashMap::new(),
            modules: HashMap::new(),
            types: HashMap::new(),
            functions: HashMap::new(),
            imports: HashMap::new(),
        };

        // Add built-in bindings
        ctx.bindings.insert("true".to_string(), Value::Bool(true));
        ctx.bindings.insert("false".to_string(), Value::Bool(false));
        ctx.bindings.insert("PI".to_string(), Value::Float(3.14159265358979));
        ctx.bindings.insert("E".to_string(), Value::Float(2.71828182845904));

        ctx
    }

    pub fn define(&mut self, name: &str, value: Value) {
        self.bindings.insert(name.to_string(), value);
    }

    pub fn get(&self, name: &str) -> Option<&Value> {
        self.bindings.get(name)
    }

    pub fn list_bindings(&self) -> Vec<(&String, &Value)> {
        self.bindings.iter().collect()
    }
}

#[derive(Clone, Debug)]
pub enum Value {
    Unit,
    Bool(bool),
    Int(i64),
    Float(f64),
    String(String),
    Char(char),
    Array(Vec<Value>),
    Tuple(Vec<Value>),
    Struct(String, HashMap<String, Value>),
    Function(String),
    Module(String),
}

impl Value {
    pub fn type_name(&self) -> &str {
        match self {
            Value::Unit => "()",
            Value::Bool(_) => "bool",
            Value::Int(_) => "i64",
            Value::Float(_) => "f64",
            Value::String(_) => "String",
            Value::Char(_) => "char",
            Value::Array(_) => "Vec",
            Value::Tuple(_) => "tuple",
            Value::Struct(name, _) => name,
            Value::Function(name) => name,
            Value::Module(name) => name,
        }
    }

    pub fn display(&self) -> String {
        match self {
            Value::Unit => "()".to_string(),
            Value::Bool(b) => b.to_string(),
            Value::Int(i) => i.to_string(),
            Value::Float(f) => format!("{:.6}", f),
            Value::String(s) => format!("\"{}\"", s),
            Value::Char(c) => format!("'{}'", c),
            Value::Array(arr) => {
                let items: Vec<String> = arr.iter().map(|v| v.display()).collect();
                format!("[{}]", items.join(", "))
            }
            Value::Tuple(items) => {
                let items: Vec<String> = items.iter().map(|v| v.display()).collect();
                format!("({})", items.join(", "))
            }
            Value::Struct(name, fields) => {
                let fields: Vec<String> = fields.iter()
                    .map(|(k, v)| format!("{}: {}", k, v.display()))
                    .collect();
                format!("{} {{ {} }}", name, fields.join(", "))
            }
            Value::Function(name) => format!("<fn {}>", name),
            Value::Module(name) => format!("<module {}>", name),
        }
    }
}

pub struct ModuleContext {
    pub name: String,
    pub exports: Vec<String>,
}

pub struct TypeDef {
    pub name: String,
    pub fields: Vec<(String, String)>,
}

pub struct FunctionDef {
    pub name: String,
    pub params: Vec<(String, String)>,
    pub return_type: String,
    pub body: String,
}

