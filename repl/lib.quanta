// CODE SNIPPETS AND TEMPLATES
// ═══════════════════════════════════════════════════════════════════════════════

/// Code snippet manager
pub struct SnippetManager {
    /// Snippets by category
    snippets: HashMap<String, Vec<Snippet>>,
    /// User snippets
    user_snippets: Vec<Snippet>,
    /// Snippet directory
    snippet_dir: String,
}

#[derive(Clone)]
pub struct Snippet {
    pub name: String,
    pub description: String,
    pub prefix: String,
    pub body: String,
    pub placeholders: Vec<Placeholder>,
    pub category: String,
}

#[derive(Clone)]
pub struct Placeholder {
    pub index: usize,
    pub name: String,
    pub default: Option<String>,
    pub choices: Vec<String>,
}

impl SnippetManager {
    pub fn new(snippet_dir: &str) -> Self {
        let mut manager = SnippetManager {
            snippets: HashMap::new(),
            user_snippets: Vec::new(),
            snippet_dir: snippet_dir.to_string(),
        };

        // Add built-in snippets
        manager.add_builtin_snippets();
        manager
    }

    fn add_builtin_snippets(&mut self) {
        // Function snippet
        self.add_snippet(Snippet {
            name: "function".to_string(),
            description: "Create a function".to_string(),
            prefix: "fn".to_string(),
            body: "fn ${1:name}(${2:params}) -> ${3:ReturnType} {\n    ${0}\n}".to_string(),
            placeholders: vec![
                Placeholder { index: 1, name: "name".to_string(), default: None, choices: vec![] },
                Placeholder { index: 2, name: "params".to_string(), default: None, choices: vec![] },
                Placeholder { index: 3, name: "ReturnType".to_string(), default: Some("()".to_string()), choices: vec![] },
            ],
            category: "basic".to_string(),
        });

        // Struct snippet
        self.add_snippet(Snippet {
            name: "struct".to_string(),
            description: "Create a struct".to_string(),
            prefix: "struct".to_string(),
            body: "struct ${1:Name} {\n    ${2:field}: ${3:Type},\n}".to_string(),
            placeholders: vec![
                Placeholder { index: 1, name: "Name".to_string(), default: None, choices: vec![] },
                Placeholder { index: 2, name: "field".to_string(), default: None, choices: vec![] },
                Placeholder { index: 3, name: "Type".to_string(), default: None, choices: vec![] },
            ],
            category: "basic".to_string(),
        });

        // Enum snippet
        self.add_snippet(Snippet {
            name: "enum".to_string(),
            description: "Create an enum".to_string(),
            prefix: "enum".to_string(),
            body: "enum ${1:Name} {\n    ${2:Variant},\n}".to_string(),
            placeholders: vec![
                Placeholder { index: 1, name: "Name".to_string(), default: None, choices: vec![] },
                Placeholder { index: 2, name: "Variant".to_string(), default: None, choices: vec![] },
            ],
            category: "basic".to_string(),
        });

        // Match snippet
        self.add_snippet(Snippet {
            name: "match".to_string(),
            description: "Match expression".to_string(),
            prefix: "match".to_string(),
            body: "match ${1:expr} {\n    ${2:pattern} => ${3:value},\n    _ => ${0},\n}".to_string(),
            placeholders: vec![
                Placeholder { index: 1, name: "expr".to_string(), default: None, choices: vec![] },
                Placeholder { index: 2, name: "pattern".to_string(), default: None, choices: vec![] },
                Placeholder { index: 3, name: "value".to_string(), default: None, choices: vec![] },
            ],
            category: "control".to_string(),
        });

        // Test snippet
        self.add_snippet(Snippet {
            name: "test".to_string(),
            description: "Create a test function".to_string(),
            prefix: "test".to_string(),
            body: "#[test]\nfn test_${1:name}() {\n    ${0}\n}".to_string(),
            placeholders: vec![
                Placeholder { index: 1, name: "name".to_string(), default: None, choices: vec![] },
            ],
            category: "testing".to_string(),
        });
    }

    pub fn add_snippet(&mut self, snippet: Snippet) {
        let category = snippet.category.clone();
        self.snippets
            .entry(category)
            .or_insert_with(Vec::new)
            .push(snippet);
    }

    /// Find snippets by prefix
    pub fn find_by_prefix(&self, prefix: &str) -> Vec<&Snippet> {
        let mut results = Vec::new();
        for snippets in self.snippets.values() {
            for snippet in snippets {
                if snippet.prefix.starts_with(prefix) || snippet.name.starts_with(prefix) {
                    results.push(snippet);
                }
            }
        }
        results
    }

    /// Expand snippet
    pub fn expand(&self, snippet: &Snippet, values: &HashMap<usize, String>) -> String {
        let mut result = snippet.body.clone();

        // Replace placeholders
        for placeholder in &snippet.placeholders {
            let replacement = values.get(&placeholder.index)
                .cloned()
                .or_else(|| placeholder.default.clone())
                .unwrap_or_default();

            result = result.replace(
                &format!("${{{}}}", placeholder.index),
                &replacement
            );
            result = result.replace(
                &format!("${{{}:{}}}", placeholder.index, placeholder.name),
                &replacement
            );
        }

        // Remove final cursor placeholder
        result = result.replace("${0}", "");

        result
    }

    /// List categories
    pub fn categories(&self) -> Vec<&String> {
        self.snippets.keys().collect()
    }

    /// List snippets in category
    pub fn in_category(&self, category: &str) -> Vec<&Snippet> {
        self.snippets.get(category).map(|v| v.iter().collect()).unwrap_or_default()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INLINE TESTING
// ═══════════════════════════════════════════════════════════════════════════════

/// Inline test runner for REPL
pub struct InlineTestRunner {
    /// Test results
    results: Vec<TestResult>,
    /// Test filters
    filters: Vec<String>,
    /// Verbose output
    verbose: bool,
}

pub struct TestResult {
    pub name: String,
    pub passed: bool,
    pub duration: Duration,
    pub message: Option<String>,
    pub location: Option<String>,
}

impl InlineTestRunner {
    pub fn new() -> Self {
        InlineTestRunner {
            results: Vec::new(),
            filters: Vec::new(),
            verbose: false,
        }
    }

    /// Run test function
    pub fn run_test<F>(&mut self, name: &str, test: F)
    where
        F: FnOnce() -> Result<(), String>,
    {
        let start = Instant::now();
        let result = test();
        let duration = start.elapsed();

        self.results.push(TestResult {
            name: name.to_string(),
            passed: result.is_ok(),
            duration,
            message: result.err(),
            location: None,
        });
    }

    /// Run assertion
    pub fn assert(&mut self, name: &str, condition: bool, message: &str) {
        self.results.push(TestResult {
            name: name.to_string(),
            passed: condition,
            duration: Duration::from_secs(0),
            message: if condition { None } else { Some(message.to_string()) },
            location: None,
        });
    }

    /// Assert equality
    pub fn assert_eq<T: PartialEq + std::fmt::Debug>(&mut self, name: &str, left: T, right: T) {
        let passed = left == right;
        let message = if passed {
            None
        } else {
            Some(format!("assertion failed: {:?} != {:?}", left, right))
        };

        self.results.push(TestResult {
            name: name.to_string(),
            passed,
            duration: Duration::from_secs(0),
            message,
            location: None,
        });
    }

    /// Get summary
    pub fn summary(&self) -> TestSummary {
        let passed = self.results.iter().filter(|r| r.passed).count();
        let failed = self.results.iter().filter(|r| !r.passed).count();
        let total_duration: Duration = self.results.iter().map(|r| r.duration).sum();

        TestSummary {
            passed,
            failed,
            total: self.results.len(),
            duration: total_duration,
        }
    }

    /// Format results
    pub fn format_results(&self) -> String {
        let mut output = String::new();

        for result in &self.results {
            let status = if result.passed { "✓" } else { "✗" };
            let color = if result.passed { Color::Green } else { Color::Red };

            output.push_str(&format!("{}{} {}{} ({:?})\n",
                color.ansi_code(),
                status,
                result.name,
                Color::reset(),
                result.duration
            ));

            if !result.passed {
                if let Some(msg) = &result.message {
                    output.push_str(&format!("    {}\n", msg));
                }
            }
        }

        let summary = self.summary();
        output.push_str(&format!("\n{} passed, {} failed ({:?})\n",
            summary.passed, summary.failed, summary.duration));

        output
    }

    /// Clear results
    pub fn clear(&mut self) {
        self.results.clear();
    }
}

pub struct TestSummary {
    pub passed: usize,
    pub failed: usize,
    pub total: usize,
    pub duration: Duration,
}

use std::time::Duration;

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENTATION BROWSER
// ═══════════════════════════════════════════════════════════════════════════════

/// Documentation browser for REPL
pub struct DocBrowser {
    /// Documentation index
    index: HashMap<String, DocEntry>,
    /// Search index
    search_index: Vec<String>,
    /// History
    history: Vec<String>,
    /// Bookmarks
    bookmarks: Vec<String>,
}

#[derive(Clone)]
pub struct DocEntry {
    pub name: String,
    pub kind: DocKind,
    pub signature: Option<String>,
    pub description: String,
    pub examples: Vec<DocExample>,
    pub see_also: Vec<String>,
    pub since: Option<String>,
    pub deprecated: Option<String>,
}

#[derive(Clone)]
pub enum DocKind {
    Module,
    Function,
    Struct,
    Enum,
    Trait,
    Type,
    Constant,
    Macro,
}

#[derive(Clone)]
pub struct DocExample {
    pub description: Option<String>,
    pub code: String,
    pub output: Option<String>,
}

impl DocBrowser {
    pub fn new() -> Self {
        DocBrowser {
            index: HashMap::new(),
            search_index: Vec::new(),
            history: Vec::new(),
            bookmarks: Vec::new(),
        }
    }

    /// Lookup documentation
    pub fn lookup(&mut self, name: &str) -> Option<&DocEntry> {
        if let Some(entry) = self.index.get(name) {
            self.history.push(name.to_string());
            Some(entry)
        } else {
            None
        }
    }

    /// Search documentation
    pub fn search(&self, query: &str) -> Vec<&DocEntry> {
        let query_lower = query.to_lowercase();
        self.index.values()
            .filter(|e| e.name.to_lowercase().contains(&query_lower) ||
                       e.description.to_lowercase().contains(&query_lower))
            .collect()
    }

    /// Add bookmark
    pub fn bookmark(&mut self, name: &str) {
        if !self.bookmarks.contains(&name.to_string()) {
            self.bookmarks.push(name.to_string());
        }
    }

    /// Remove bookmark
    pub fn unbookmark(&mut self, name: &str) {
        self.bookmarks.retain(|b| b != name);
    }

    /// List bookmarks
    pub fn list_bookmarks(&self) -> &[String] {
        &self.bookmarks
    }

    /// Go back in history
    pub fn back(&mut self) -> Option<&DocEntry> {
        self.history.pop();
        self.history.last().and_then(|name| self.index.get(name))
    }

    /// Format entry for display
    pub fn format_entry(&self, entry: &DocEntry) -> String {
        let mut output = String::new();

        // Header
        let kind = match entry.kind {
            DocKind::Module => "module",
            DocKind::Function => "fn",
            DocKind::Struct => "struct",
            DocKind::Enum => "enum",
            DocKind::Trait => "trait",
            DocKind::Type => "type",
            DocKind::Constant => "const",
            DocKind::Macro => "macro",
        };

        output.push_str(&format!("{} {}\n", kind, entry.name));
        output.push_str(&"─".repeat(60));
        output.push('\n');

        // Signature
        if let Some(sig) = &entry.signature {
            output.push_str(&format!("\n{}\n", sig));
        }

        // Description
        output.push_str(&format!("\n{}\n", entry.description));

        // Examples
        if !entry.examples.is_empty() {
            output.push_str("\n## Examples\n\n");
            for example in &entry.examples {
                if let Some(desc) = &example.description {
                    output.push_str(&format!("{}\n\n", desc));
                }
                output.push_str(&format!("```\n{}\n```\n", example.code));
                if let Some(out) = &example.output {
                    output.push_str(&format!("// Output: {}\n", out));
                }
            }
        }

        // See also
        if !entry.see_also.is_empty() {
            output.push_str("\n## See also\n\n");
            for related in &entry.see_also {
                output.push_str(&format!("- {}\n", related));
            }
        }

        // Deprecation warning
        if let Some(deprecated) = &entry.deprecated {
            output.push_str(&format!("\n⚠️  Deprecated: {}\n", deprecated));
        }

        output
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPL TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_value_display() {
        assert_eq!(Value::Int(42).display(), "42");
        assert_eq!(Value::Float(3.14).display(), "3.140000");
        assert_eq!(Value::Bool(true).display(), "true");
        assert_eq!(Value::String("hello".to_string()).display(), "\"hello\"");
    }

    #[test]
    fn test_history() {
        let mut history = History::new(10);
        history.add("first".to_string());
        history.add("second".to_string());
        history.add("third".to_string());

        assert_eq!(history.previous(), Some(&"third".to_string()));
        assert_eq!(history.previous(), Some(&"second".to_string()));
        assert_eq!(history.next(), Some(&"third".to_string()));
    }

    #[test]
    fn test_completer() {
        let completer = Completer::new();
        let ctx = ReplContext::new();

        let completions = completer.complete("le", &ctx);
        assert!(completions.iter().any(|c| c.text == "let"));
    }

    #[test]
    fn test_highlighter() {
        let highlighter = Highlighter::new(Theme::default());
        let highlighted = highlighter.highlight("let x = 42");
        assert!(highlighted.contains("\x1b[35m")); // keyword color
    }

    #[test]
    fn test_table_render() {
        let table = TableData::new(
            vec!["Name".to_string(), "Value".to_string()],
            vec![
                vec!["x".to_string(), "42".to_string()],
                vec!["y".to_string(), "100".to_string()],
            ],
        );

        let rendered = table.render();
        assert!(rendered.contains("Name"));
        assert!(rendered.contains("42"));
    }

    #[test]
    fn test_chart_bar() {
        let chart = ChartData::bar("Test", vec![
            ("A", 10.0),
            ("B", 20.0),
            ("C", 15.0),
        ]);

        let rendered = chart.render();
        assert!(rendered.contains("Test"));
        assert!(rendered.contains("█"));
    }

    #[test]
    fn test_progress_bar() {
        let progress = ProgressData::new(50, 100);
        let rendered = progress.render();
        assert!(rendered.contains("50.0%"));
    }

    #[test]
    fn test_magic_registry() {
        let registry = MagicCommandRegistry::new();
        let (line, cell) = registry.list_magics();

        assert!(line.iter().any(|m| *m == "time"));
        assert!(cell.iter().any(|m| *m == "bash"));
    }

    #[test]
    fn test_jupyter_kernel() {
        let mut kernel = JupyterKernel::new();

        // Test execute
        let result = kernel.execute("let x = 42", false, true);
        match result {
            ExecuteResult::Ok { execution_count, .. } => {
                assert_eq!(execution_count, 1);
            }
            _ => panic!("Expected Ok result"),
        }
    }

    #[test]
    fn test_workspace() {
        let mut workspace = Workspace::new("test");
        workspace.bindings.insert("x".to_string(), SerializedValue::Int(42));

        assert_eq!(workspace.name, "test");
        assert!(workspace.bindings.contains_key("x"));
    }

    #[test]
    fn test_snippet_manager() {
        let manager = SnippetManager::new("~/.quanta/snippets");

        let snippets = manager.find_by_prefix("fn");
        assert!(!snippets.is_empty());
    }

    #[test]
    fn test_inline_test_runner() {
        let mut runner = InlineTestRunner::new();

        runner.run_test("passes", || Ok(()));
        runner.run_test("fails", || Err("error".to_string()));

        let summary = runner.summary();
        assert_eq!(summary.passed, 1);
        assert_eq!(summary.failed, 1);
    }

    #[test]
    fn test_repl_debugger() {
        let mut debugger = ReplDebugger::new();

        let id = debugger.add_breakpoint(BreakpointLocation::Line {
            file: "test.quanta".to_string(),
            line: 10,
        });

        assert_eq!(debugger.list_breakpoints().len(), 1);
        assert!(debugger.toggle_breakpoint(id));
        assert!(debugger.remove_breakpoint(id));
        assert!(debugger.list_breakpoints().is_empty());
    }

    #[test]
    fn test_tree_render() {
        let tree = TreeData {
            root: TreeNode {
                label: "root".to_string(),
                children: vec![
                    TreeNode {
                        label: "child1".to_string(),
                        children: vec![],
                        expanded: true,
                    },
                    TreeNode {
                        label: "child2".to_string(),
                        children: vec![],
                        expanded: true,
                    },
                ],
                expanded: true,
            },
            show_lines: true,
        };

        let rendered = tree.render();
        assert!(rendered.contains("root"));
        assert!(rendered.contains("child1"));
    }

    #[test]
    fn test_is_complete() {
        let kernel = JupyterKernel::new();

        assert!(matches!(kernel.is_complete("let x = 42"), IsCompleteResult::Complete));
        assert!(matches!(kernel.is_complete("fn foo() {"), IsCompleteResult::Incomplete { .. }));
        assert!(matches!(kernel.is_complete("let x = }"), IsCompleteResult::Invalid));
    }

    #[test]
    fn test_sparkline() {
        let chart = ChartData {
            chart_type: ChartType::Sparkline,
            title: None,
            data: vec![
                DataPoint { label: "".to_string(), value: 1.0, color: None },
                DataPoint { label: "".to_string(), value: 5.0, color: None },
                DataPoint { label: "".to_string(), value: 3.0, color: None },
                DataPoint { label: "".to_string(), value: 8.0, color: None },
                DataPoint { label: "".to_string(), value: 2.0, color: None },
            ],
            width: 40,
            height: 1,
        };

        let rendered = chart.render();
        assert_eq!(rendered.len(), 5);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SESSION RECORDING AND PLAYBACK
// ═══════════════════════════════════════════════════════════════════════════════

/// Records REPL sessions for playback and sharing
pub struct SessionRecorder {
    pub session_id: String,
    pub events: Vec<SessionEvent>,
    pub metadata: SessionMetadata,
    pub start_time: Instant,
    pub recording: bool,
    pub output_path: Option<String>,
}

/// Metadata about a recorded session
pub struct SessionMetadata {
    pub title: String,
    pub author: String,
    pub description: String,
    pub tags: Vec<String>,
    pub created_at: u64,
    pub duration_ms: u64,
    pub language_version: String,
    pub environment: HashMap<String, String>,
}

/// A single event in a recorded session
pub struct SessionEvent {
    pub timestamp_ms: u64,
    pub event_type: SessionEventType,
    pub content: String,
    pub metadata: HashMap<String, String>,
}

/// Types of session events
pub enum SessionEventType {
    Input,              // User input
    Output,             // Program output
    Error,              // Error message
    Stdout,             // Standard output
    Stderr,             // Standard error
    SystemMessage,      // System message
    VariableChange,     // Variable was changed
    FunctionDefined,    // Function was defined
    ModuleLoaded,       // Module was loaded
    TimingInfo,         // Execution timing
    DebugEvent,         // Debug event
    MagicCommand,       // Magic command executed
    Completion,         // Completion suggestion shown
    Annotation,         // User annotation/comment
}

impl SessionRecorder {
    pub fn new() -> Self {
        Self {
            session_id: format!("session_{}", std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_millis()),
            events: Vec::new(),
            metadata: SessionMetadata::default(),
            start_time: Instant::now(),
            recording: false,
            output_path: None,
        }
    }

    pub fn start(&mut self) {
        self.recording = true;
        self.start_time = Instant::now();
        self.record_event(SessionEventType::SystemMessage, "Session recording started");
    }

    pub fn stop(&mut self) {
        self.recording = false;
        self.metadata.duration_ms = self.start_time.elapsed().as_millis() as u64;
        self.record_event(SessionEventType::SystemMessage, "Session recording stopped");
    }

    pub fn record_event(&mut self, event_type: SessionEventType, content: &str) {
        if !self.recording && !matches!(event_type, SessionEventType::SystemMessage) {
            return;
        }

        self.events.push(SessionEvent {
            timestamp_ms: self.start_time.elapsed().as_millis() as u64,
            event_type,
            content: content.to_string(),
            metadata: HashMap::new(),
        });
    }

    pub fn record_input(&mut self, input: &str) {
        self.record_event(SessionEventType::Input, input);
    }

    pub fn record_output(&mut self, output: &str) {
        self.record_event(SessionEventType::Output, output);
    }

    pub fn record_error(&mut self, error: &str) {
        self.record_event(SessionEventType::Error, error);
    }

    pub fn add_annotation(&mut self, annotation: &str) {
        self.record_event(SessionEventType::Annotation, annotation);
    }

    pub fn export_json(&self) -> String {
        format!(r#"{{
            "session_id": "{}",
            "metadata": {{
                "title": "{}",
                "author": "{}",
                "duration_ms": {}
            }},
            "events": {}
        }}"#,
            self.session_id,
            self.metadata.title,
            self.metadata.author,
            self.metadata.duration_ms,
            self.events.len()
        )
    }

    pub fn export_markdown(&self) -> String {
        let mut md = format!("# {}\n\n", self.metadata.title);
        md.push_str(&format!("Author: {}\n", self.metadata.author));
        md.push_str(&format!("Duration: {}ms\n\n", self.metadata.duration_ms));
        md.push_str("---\n\n");

        for event in &self.events {
            match event.event_type {
                SessionEventType::Input => {
                    md.push_str(&format!("```quanta\n{}\n```\n\n", event.content));
                }
                SessionEventType::Output => {
                    md.push_str(&format!("> {}\n\n", event.content));
                }
                SessionEventType::Annotation => {
                    md.push_str(&format!("*{}*\n\n", event.content));
                }
                _ => {}
            }
        }

        md
    }
}

/// Plays back recorded sessions
pub struct SessionPlayer {
    pub session: Option<RecordedSession>,
    pub current_event: usize,
    pub playback_speed: f64,
    pub paused: bool,
    pub callbacks: SessionCallbacks,
}

/// A recorded session for playback
pub struct RecordedSession {
    pub session_id: String,
    pub metadata: SessionMetadata,
    pub events: Vec<SessionEvent>,
}

/// Callbacks for session playback
pub struct SessionCallbacks {
    pub on_input: Option<Box<dyn Fn(&str) + Send + Sync>>,
    pub on_output: Option<Box<dyn Fn(&str) + Send + Sync>>,
    pub on_error: Option<Box<dyn Fn(&str) + Send + Sync>>,
    pub on_complete: Option<Box<dyn Fn() + Send + Sync>>,
}

impl SessionPlayer {
    pub fn new() -> Self {
        Self {
            session: None,
            current_event: 0,
            playback_speed: 1.0,
            paused: true,
            callbacks: SessionCallbacks::default(),
        }
    }

    pub fn load(&mut self, session: RecordedSession) {
        self.session = Some(session);
        self.current_event = 0;
    }

    pub fn play(&mut self) {
        self.paused = false;
    }

    pub fn pause(&mut self) {
        self.paused = true;
    }

    pub fn step(&mut self) -> Option<&SessionEvent> {
        if let Some(ref session) = self.session {
            if self.current_event < session.events.len() {
                let event = &session.events[self.current_event];
                self.current_event += 1;
                return Some(event);
            }
        }
        None
    }

    pub fn seek(&mut self, event_index: usize) {
        self.current_event = event_index;
    }

    pub fn set_speed(&mut self, speed: f64) {
        self.playback_speed = speed.max(0.1).min(10.0);
    }
}

impl Default for SessionMetadata {
    fn default() -> Self {
        Self {
            title: "Untitled Session".to_string(),
            author: "Unknown".to_string(),
            description: String::new(),
            tags: Vec::new(),
            created_at: 0,
            duration_ms: 0,
            language_version: "1.0.0".to_string(),
            environment: HashMap::new(),
        }
    }
}

impl Default for SessionCallbacks {
    fn default() -> Self {
        Self {
            on_input: None,
            on_output: None,
            on_error: None,
            on_complete: None,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LITERATE PROGRAMMING SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Literate programming support for REPL
pub struct LiterateMode {
    pub document: LiterateDocument,
    pub current_cell: usize,
    pub execution_order: Vec<usize>,
    pub outputs: HashMap<usize, CellOutput>,
}

/// A literate programming document
pub struct LiterateDocument {
    pub cells: Vec<DocumentCell>,
    pub metadata: DocumentMetadata,
    pub title: String,
}

/// A cell in a literate document
pub struct DocumentCell {
    pub id: usize,
    pub cell_type: CellType,
    pub source: String,
    pub outputs: Vec<CellOutput>,
    pub execution_count: Option<u32>,
    pub metadata: CellMetadata,
}

/// Types of cells
pub enum CellType {
    Code,
    Markdown,
    Raw,
    Heading,
    Equation,
}

/// Output from a cell
pub struct CellOutput {
    pub output_type: OutputType,
    pub data: OutputData,
    pub execution_count: Option<u32>,
}

/// Types of cell outputs
pub enum OutputType {
    Stream,
    DisplayData,
    ExecuteResult,
    Error,
}

/// Data in cell output
pub enum OutputData {
    Text(String),
    Html(String),
    Latex(String),
    Json(String),
    Image { format: String, data: Vec<u8> },
    Svg(String),
}

/// Metadata for cells
pub struct CellMetadata {
    pub collapsed: bool,
    pub scrollable: bool,
    pub editable: bool,
    pub deletable: bool,
    pub tags: Vec<String>,
}

/// Document-level metadata
pub struct DocumentMetadata {
    pub language: String,
    pub kernel: String,
    pub authors: Vec<String>,
    pub created: u64,
    pub modified: u64,
}

impl LiterateMode {
    pub fn new() -> Self {
        Self {
            document: LiterateDocument {
                cells: Vec::new(),
                metadata: DocumentMetadata::default(),
                title: "Untitled".to_string(),
            },
            current_cell: 0,
            execution_order: Vec::new(),
            outputs: HashMap::new(),
        }
    }

    pub fn add_cell(&mut self, cell_type: CellType, source: &str) -> usize {
        let id = self.document.cells.len();
        self.document.cells.push(DocumentCell {
            id,
            cell_type,
            source: source.to_string(),
            outputs: Vec::new(),
            execution_count: None,
            metadata: CellMetadata::default(),
        });
        id
    }

    pub fn execute_cell(&mut self, cell_id: usize) -> Result<CellOutput, String> {
        if cell_id >= self.document.cells.len() {
            return Err("Cell not found".to_string());
        }

        let cell = &mut self.document.cells[cell_id];
        match cell.cell_type {
            CellType::Code => {
                // Execute code cell
                let output = CellOutput {
                    output_type: OutputType::ExecuteResult,
                    data: OutputData::Text("Executed".to_string()),
                    execution_count: cell.execution_count,
                };
                cell.outputs.push(output.clone());
                self.execution_order.push(cell_id);
                Ok(output)
            }
            _ => Ok(CellOutput {
                output_type: OutputType::DisplayData,
                data: OutputData::Text(cell.source.clone()),
                execution_count: None,
            }),
        }
    }

    pub fn run_all(&mut self) -> Vec<Result<CellOutput, String>> {
        (0..self.document.cells.len())
            .map(|id| self.execute_cell(id))
            .collect()
    }

    pub fn export_notebook(&self) -> String {
        // Export to Jupyter-compatible format
        format!(r#"{{
            "cells": {},
            "metadata": {{}},
            "nbformat": 4,
            "nbformat_minor": 5
        }}"#, self.document.cells.len())
    }

    pub fn export_html(&self) -> String {
        let mut html = String::from("<!DOCTYPE html>\n<html>\n<head>\n<style>");
        html.push_str("body { font-family: sans-serif; max-width: 900px; margin: auto; }");
        html.push_str(".cell { margin: 1em 0; } .code { background: #f5f5f5; padding: 1em; }");
        html.push_str("</style>\n</head>\n<body>\n");
        html.push_str(&format!("<h1>{}</h1>\n", self.document.title));

        for cell in &self.document.cells {
            html.push_str("<div class=\"cell\">\n");
            match cell.cell_type {
                CellType::Code => {
                    html.push_str(&format!("<pre class=\"code\">{}</pre>\n", cell.source));
                }
                CellType::Markdown => {
                    html.push_str(&format!("<div class=\"markdown\">{}</div>\n", cell.source));
                }
                _ => {}
            }
            html.push_str("</div>\n");
        }

        html.push_str("</body>\n</html>");
        html
    }
}

impl Default for DocumentMetadata {
    fn default() -> Self {
        Self {
            language: "quanta".to_string(),
            kernel: "quanta_kernel".to_string(),
            authors: Vec::new(),
            created: 0,
            modified: 0,
        }
    }
}

impl Default for CellMetadata {
    fn default() -> Self {
        Self {
            collapsed: false,
            scrollable: true,
            editable: true,
            deletable: true,
            tags: Vec::new(),
        }
    }
}

impl Clone for CellOutput {
    fn clone(&self) -> Self {
        Self {
            output_type: match self.output_type {
                OutputType::Stream => OutputType::Stream,
                OutputType::DisplayData => OutputType::DisplayData,
                OutputType::ExecuteResult => OutputType::ExecuteResult,
                OutputType::Error => OutputType::Error,
            },
            data: match &self.data {
                OutputData::Text(s) => OutputData::Text(s.clone()),
                OutputData::Html(s) => OutputData::Html(s.clone()),
                OutputData::Latex(s) => OutputData::Latex(s.clone()),
                OutputData::Json(s) => OutputData::Json(s.clone()),
                OutputData::Image { format, data } => OutputData::Image {
                    format: format.clone(),
                    data: data.clone(),
                },
                OutputData::Svg(s) => OutputData::Svg(s.clone()),
            },
            execution_count: self.execution_count,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-LANGUAGE REPL INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Multi-language REPL support
pub struct PolyglotRepl {
    pub languages: HashMap<String, Box<dyn LanguageBackend + Send + Sync>>,
    pub current_language: String,
    pub shared_context: SharedContext,
    pub bridge: LanguageBridge,
}

/// Backend trait for different languages
pub trait LanguageBackend {
    fn name(&self) -> &str;
    fn version(&self) -> &str;
    fn execute(&mut self, code: &str) -> LanguageResult;
    fn complete(&self, code: &str, cursor: usize) -> Vec<CompletionItem>;
    fn is_complete(&self, code: &str) -> bool;
    fn reset(&mut self);
}

/// Result from language execution
pub struct LanguageResult {
    pub success: bool,
    pub output: String,
    pub error: Option<String>,
    pub exports: HashMap<String, ExportedValue>,
}

/// A value exported between languages
pub struct ExportedValue {
    pub name: String,
    pub value_type: ExportType,
    pub data: Vec<u8>,
    pub source_language: String,
}

/// Types of exported values
pub enum ExportType {
    Integer,
    Float,
    String,
    Boolean,
    Array,
    Object,
    Function,
    Binary,
}

/// Shared context between languages
pub struct SharedContext {
    pub variables: HashMap<String, ExportedValue>,
    pub functions: HashMap<String, ExportedValue>,
    pub types: HashMap<String, TypeDefinition>,
}

/// Type definition for cross-language types
pub struct TypeDefinition {
    pub name: String,
    pub fields: Vec<FieldDefinition>,
    pub source_language: String,
}

/// Field in a type definition
pub struct FieldDefinition {
    pub name: String,
    pub field_type: String,
    pub optional: bool,
}

/// Bridge for language interop
pub struct LanguageBridge {
    pub conversions: HashMap<(String, String), Box<dyn ValueConverter + Send + Sync>>,
}

/// Trait for converting values between languages
pub trait ValueConverter {
    fn convert(&self, value: &ExportedValue) -> Result<ExportedValue, String>;
}

impl PolyglotRepl {
    pub fn new() -> Self {
        let mut languages = HashMap::new();
        languages.insert("quanta".to_string(), Box::new(QuantaBackend::new()) as Box<dyn LanguageBackend + Send + Sync>);

        Self {
            languages,
            current_language: "quanta".to_string(),
            shared_context: SharedContext::default(),
            bridge: LanguageBridge::default(),
        }
    }

    pub fn add_language<L: LanguageBackend + Send + Sync + 'static>(&mut self, backend: L) {
        self.languages.insert(backend.name().to_string(), Box::new(backend));
    }

    pub fn switch_language(&mut self, language: &str) -> Result<(), String> {
        if self.languages.contains_key(language) {
            self.current_language = language.to_string();
            Ok(())
        } else {
            Err(format!("Unknown language: {}", language))
        }
    }

    pub fn execute(&mut self, code: &str) -> LanguageResult {
        if let Some(backend) = self.languages.get_mut(&self.current_language) {
            let result = backend.execute(code);

            // Export any new values to shared context
            for (name, value) in &result.exports {
                self.shared_context.variables.insert(name.clone(), ExportedValue {
                    name: name.clone(),
                    value_type: value.value_type.clone(),
                    data: value.data.clone(),
                    source_language: self.current_language.clone(),
                });
            }

            result
        } else {
            LanguageResult {
                success: false,
                output: String::new(),
                error: Some("No language backend".to_string()),
                exports: HashMap::new(),
            }
        }
    }

    pub fn list_languages(&self) -> Vec<&str> {
        self.languages.keys().map(|s| s.as_str()).collect()
    }

    pub fn import_from(&mut self, language: &str, name: &str) -> Result<(), String> {
        if let Some(value) = self.shared_context.variables.get(name) {
            if value.source_language != self.current_language {
                // Convert value if needed
                let key = (value.source_language.clone(), self.current_language.clone());
                if let Some(converter) = self.bridge.conversions.get(&key) {
                    let converted = converter.convert(value)?;
                    // Make available in current language
                    Ok(())
                } else {
                    // Direct copy if no conversion needed
                    Ok(())
                }
            } else {
                Ok(())
            }
        } else {
            Err(format!("Variable '{}' not found", name))
        }
    }
}

/// QuantaLang backend
pub struct QuantaBackend {
    pub context: HashMap<String, String>,
}

impl QuantaBackend {
    pub fn new() -> Self {
        Self { context: HashMap::new() }
    }
}

impl LanguageBackend for QuantaBackend {
    fn name(&self) -> &str { "quanta" }
    fn version(&self) -> &str { "1.0.0" }

    fn execute(&mut self, code: &str) -> LanguageResult {
        // Execute QuantaLang code
        LanguageResult {
            success: true,
            output: "Executed".to_string(),
            error: None,
            exports: HashMap::new(),
        }
    }

    fn complete(&self, _code: &str, _cursor: usize) -> Vec<CompletionItem> {
        Vec::new()
    }

    fn is_complete(&self, code: &str) -> bool {
        !code.ends_with('{') && !code.ends_with('(')
    }

    fn reset(&mut self) {
        self.context.clear();
    }
}

impl Clone for ExportType {
    fn clone(&self) -> Self {
        match self {
            ExportType::Integer => ExportType::Integer,
            ExportType::Float => ExportType::Float,
            ExportType::String => ExportType::String,
            ExportType::Boolean => ExportType::Boolean,
            ExportType::Array => ExportType::Array,
            ExportType::Object => ExportType::Object,
            ExportType::Function => ExportType::Function,
            ExportType::Binary => ExportType::Binary,
        }
    }
}

impl Default for SharedContext {
    fn default() -> Self {
        Self {
            variables: HashMap::new(),
            functions: HashMap::new(),
            types: HashMap::new(),
        }
    }
}

impl Default for LanguageBridge {
    fn default() -> Self {
        Self {
            conversions: HashMap::new(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLLABORATION MODE
// ═══════════════════════════════════════════════════════════════════════════════

/// Collaborative REPL for multiple users
pub struct CollaborativeRepl {
    pub session_id: String,
    pub participants: HashMap<String, Participant>,
    pub shared_state: SharedState,
    pub message_queue: VecDeque<CollabMessage>,
    pub config: CollabConfig,
}

/// A participant in the collaborative session
pub struct Participant {
    pub id: String,
    pub name: String,
    pub role: ParticipantRole,
    pub cursor_position: usize,
    pub selection: Option<Selection>,
    pub last_active: u64,
    pub color: String,
}

/// Participant roles
pub enum ParticipantRole {
    Owner,
    Editor,
    Viewer,
    Commenter,
}

/// Selection range
pub struct Selection {
    pub start: usize,
    pub end: usize,
}

/// Shared state for collaboration
pub struct SharedState {
    pub document: String,
    pub history: Vec<String>,
    pub variables: HashMap<String, String>,
    pub version: u64,
    pub operations: Vec<Operation>,
}

/// An operation for OT (Operational Transformation)
pub struct Operation {
    pub op_type: OperationType,
    pub position: usize,
    pub content: String,
    pub author: String,
    pub timestamp: u64,
    pub version: u64,
}

/// Types of operations
pub enum OperationType {
    Insert,
    Delete,
    Retain,
}

/// Messages for collaboration
pub struct CollabMessage {
    pub message_type: CollabMessageType,
    pub sender: String,
    pub payload: String,
    pub timestamp: u64,
}

/// Types of collaboration messages
pub enum CollabMessageType {
    Join,
    Leave,
    Operation,
    CursorMove,
    Selection,
    Chat,
    Execute,
    Sync,
}

/// Configuration for collaboration
pub struct CollabConfig {
    pub max_participants: usize,
    pub allow_anonymous: bool,
    pub require_password: bool,
    pub auto_save_interval: Duration,
    pub sync_interval: Duration,
}

impl CollaborativeRepl {
    pub fn new(session_id: &str) -> Self {
        Self {
            session_id: session_id.to_string(),
            participants: HashMap::new(),
            shared_state: SharedState::default(),
            message_queue: VecDeque::new(),
            config: CollabConfig::default(),
        }
    }

    pub fn join(&mut self, participant: Participant) -> Result<(), String> {
        if self.participants.len() >= self.config.max_participants {
            return Err("Session full".to_string());
        }

        self.broadcast(CollabMessage {
            message_type: CollabMessageType::Join,
            sender: "system".to_string(),
            payload: format!("{} joined the session", participant.name),
            timestamp: 0,
        });

        self.participants.insert(participant.id.clone(), participant);
        Ok(())
    }

    pub fn leave(&mut self, participant_id: &str) {
        if let Some(p) = self.participants.remove(participant_id) {
            self.broadcast(CollabMessage {
                message_type: CollabMessageType::Leave,
                sender: "system".to_string(),
                payload: format!("{} left the session", p.name),
                timestamp: 0,
            });
        }
    }

    pub fn apply_operation(&mut self, op: Operation) -> Result<(), String> {
        // Apply OT transformation
        match op.op_type {
            OperationType::Insert => {
                self.shared_state.document.insert_str(op.position, &op.content);
            }
            OperationType::Delete => {
                let end = (op.position + op.content.len()).min(self.shared_state.document.len());
                self.shared_state.document.drain(op.position..end);
            }
            OperationType::Retain => {}
        }

        self.shared_state.version += 1;
        self.shared_state.operations.push(op);
        Ok(())
    }

    pub fn broadcast(&mut self, message: CollabMessage) {
        self.message_queue.push_back(message);
    }

    pub fn sync(&self) -> SyncPayload {
        SyncPayload {
            document: self.shared_state.document.clone(),
            version: self.shared_state.version,
            participants: self.participants.keys().cloned().collect(),
        }
    }
}

/// Sync payload
pub struct SyncPayload {
    pub document: String,
    pub version: u64,
    pub participants: Vec<String>,
}

impl Default for SharedState {
    fn default() -> Self {
        Self {
            document: String::new(),
            history: Vec::new(),
            variables: HashMap::new(),
            version: 0,
            operations: Vec::new(),
        }
    }
}

impl Default for CollabConfig {
    fn default() -> Self {
        Self {
            max_participants: 10,
            allow_anonymous: false,
            require_password: false,
            auto_save_interval: Duration::from_secs(30),
            sync_interval: Duration::from_millis(100),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPL ANALYTICS AND METRICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Analytics for REPL usage
pub struct ReplAnalytics {
    pub session_id: String,
    pub metrics: ReplMetrics,
    pub command_history: Vec<CommandRecord>,
    pub error_log: Vec<ErrorRecord>,
    pub performance_samples: Vec<PerformanceSample>,
}

/// Metrics for REPL usage
pub struct ReplMetrics {
    pub total_commands: u64,
    pub successful_commands: u64,
    pub failed_commands: u64,
    pub total_execution_time_ms: u64,
    pub average_execution_time_ms: f64,
    pub unique_functions_used: HashSet<String>,
    pub unique_modules_loaded: HashSet<String>,
    pub magic_commands_used: HashMap<String, u64>,
    pub completion_usage: CompletionMetrics,
    pub session_duration_ms: u64,
}

/// Metrics for completion usage
pub struct CompletionMetrics {
    pub suggestions_shown: u64,
    pub suggestions_accepted: u64,
    pub suggestions_rejected: u64,
    pub average_position_selected: f64,
}

/// Record of a command execution
pub struct CommandRecord {
    pub command: String,
    pub timestamp: u64,
    pub execution_time_ms: u64,
    pub success: bool,
    pub error_type: Option<String>,
}

/// Record of an error
pub struct ErrorRecord {
    pub error_type: String,
    pub message: String,
    pub command: String,
    pub timestamp: u64,
    pub stack_trace: Option<String>,
}

/// Performance sample
pub struct PerformanceSample {
    pub timestamp: u64,
    pub cpu_usage: f64,
    pub memory_usage_mb: f64,
    pub active_variables: usize,
    pub gc_collections: u64,
}

impl ReplAnalytics {
    pub fn new(session_id: &str) -> Self {
        Self {
            session_id: session_id.to_string(),
            metrics: ReplMetrics::default(),
            command_history: Vec::new(),
            error_log: Vec::new(),
            performance_samples: Vec::new(),
        }
    }

    pub fn record_command(&mut self, command: &str, execution_time_ms: u64, success: bool, error: Option<String>) {
        self.metrics.total_commands += 1;
        self.metrics.total_execution_time_ms += execution_time_ms;

        if success {
            self.metrics.successful_commands += 1;
        } else {
            self.metrics.failed_commands += 1;
        }

        self.metrics.average_execution_time_ms =
            self.metrics.total_execution_time_ms as f64 / self.metrics.total_commands as f64;

        self.command_history.push(CommandRecord {
            command: command.to_string(),
            timestamp: 0,
            execution_time_ms,
            success,
            error_type: error.clone(),
        });

        if let Some(err) = error {
            self.error_log.push(ErrorRecord {
                error_type: "RuntimeError".to_string(),
                message: err,
                command: command.to_string(),
                timestamp: 0,
                stack_trace: None,
            });
        }
    }

    pub fn record_magic_usage(&mut self, magic_name: &str) {
        *self.metrics.magic_commands_used.entry(magic_name.to_string()).or_insert(0) += 1;
    }

    pub fn record_completion(&mut self, shown: bool, accepted: bool, position: Option<usize>) {
        if shown {
            self.metrics.completion_usage.suggestions_shown += 1;
        }
        if accepted {
            self.metrics.completion_usage.suggestions_accepted += 1;
        } else if shown {
            self.metrics.completion_usage.suggestions_rejected += 1;
        }
    }

    pub fn sample_performance(&mut self, cpu: f64, memory: f64, variables: usize, gc: u64) {
        self.performance_samples.push(PerformanceSample {
            timestamp: 0,
            cpu_usage: cpu,
            memory_usage_mb: memory,
            active_variables: variables,
            gc_collections: gc,
        });
    }

    pub fn generate_report(&self) -> AnalyticsReport {
        AnalyticsReport {
            session_id: self.session_id.clone(),
            total_commands: self.metrics.total_commands,
            success_rate: if self.metrics.total_commands > 0 {
                self.metrics.successful_commands as f64 / self.metrics.total_commands as f64 * 100.0
            } else {
                0.0
            },
            average_execution_time_ms: self.metrics.average_execution_time_ms,
            most_used_commands: self.get_most_used_commands(10),
            common_errors: self.get_common_errors(5),
            performance_summary: self.get_performance_summary(),
        }
    }

    fn get_most_used_commands(&self, limit: usize) -> Vec<(String, u64)> {
        let mut counts: HashMap<String, u64> = HashMap::new();
        for record in &self.command_history {
            *counts.entry(record.command.clone()).or_insert(0) += 1;
        }
        let mut sorted: Vec<_> = counts.into_iter().collect();
        sorted.sort_by(|a, b| b.1.cmp(&a.1));
        sorted.truncate(limit);
        sorted
    }

    fn get_common_errors(&self, limit: usize) -> Vec<(String, u64)> {
        let mut counts: HashMap<String, u64> = HashMap::new();
        for record in &self.error_log {
            *counts.entry(record.error_type.clone()).or_insert(0) += 1;
        }
        let mut sorted: Vec<_> = counts.into_iter().collect();
        sorted.sort_by(|a, b| b.1.cmp(&a.1));
        sorted.truncate(limit);
        sorted
    }

    fn get_performance_summary(&self) -> PerformanceSummary {
        let samples = &self.performance_samples;
        if samples.is_empty() {
            return PerformanceSummary::default();
        }

        let avg_cpu = samples.iter().map(|s| s.cpu_usage).sum::<f64>() / samples.len() as f64;
        let avg_mem = samples.iter().map(|s| s.memory_usage_mb).sum::<f64>() / samples.len() as f64;
        let max_mem = samples.iter().map(|s| s.memory_usage_mb).fold(0.0f64, f64::max);

        PerformanceSummary {
            average_cpu_usage: avg_cpu,
            average_memory_mb: avg_mem,
            peak_memory_mb: max_mem,
            sample_count: samples.len(),
        }
    }
}

/// Analytics report
pub struct AnalyticsReport {
    pub session_id: String,
    pub total_commands: u64,
    pub success_rate: f64,
    pub average_execution_time_ms: f64,
    pub most_used_commands: Vec<(String, u64)>,
    pub common_errors: Vec<(String, u64)>,
    pub performance_summary: PerformanceSummary,
}

/// Performance summary
pub struct PerformanceSummary {
    pub average_cpu_usage: f64,
    pub average_memory_mb: f64,
    pub peak_memory_mb: f64,
    pub sample_count: usize,
}

impl Default for ReplMetrics {
    fn default() -> Self {
        Self {
            total_commands: 0,
            successful_commands: 0,
            failed_commands: 0,
            total_execution_time_ms: 0,
            average_execution_time_ms: 0.0,
            unique_functions_used: HashSet::new(),
            unique_modules_loaded: HashSet::new(),
            magic_commands_used: HashMap::new(),
            completion_usage: CompletionMetrics::default(),
            session_duration_ms: 0,
        }
    }
}

impl Default for CompletionMetrics {
    fn default() -> Self {
        Self {
            suggestions_shown: 0,
            suggestions_accepted: 0,
            suggestions_rejected: 0,
            average_position_selected: 0.0,
        }
    }
}

impl Default for PerformanceSummary {
    fn default() -> Self {
        Self {
            average_cpu_usage: 0.0,
            average_memory_mb: 0.0,
            peak_memory_mb: 0.0,
            sample_count: 0,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECURITY SANDBOXING
// ═══════════════════════════════════════════════════════════════════════════════

/// Security sandbox for REPL execution
pub struct ReplSandbox {
    pub config: SandboxConfig,
    pub permissions: SandboxPermissions,
    pub resource_limits: ResourceLimits,
    pub audit_log: Vec<AuditEntry>,
}

/// Sandbox configuration
pub struct SandboxConfig {
    pub enabled: bool,
    pub isolation_level: IsolationLevel,
    pub network_policy: NetworkPolicy,
    pub filesystem_policy: FilesystemPolicy,
}

/// Isolation levels
pub enum IsolationLevel {
    None,           // No isolation
    Process,        // Separate process
    Container,      // Docker container
    VM,             // Virtual machine
    Wasm,           // WebAssembly sandbox
}

/// Network policy
pub struct NetworkPolicy {
    pub allow_network: bool,
    pub allowed_hosts: Vec<String>,
    pub blocked_hosts: Vec<String>,
    pub allowed_ports: Vec<u16>,
    pub max_connections: usize,
}

/// Filesystem policy
pub struct FilesystemPolicy {
    pub allow_read: bool,
    pub allow_write: bool,
    pub allowed_paths: Vec<String>,
    pub blocked_paths: Vec<String>,
    pub max_file_size_bytes: usize,
}

/// Permissions for sandboxed code
pub struct SandboxPermissions {
    pub can_import: bool,
    pub can_spawn_process: bool,
    pub can_access_env: bool,
    pub can_use_ffi: bool,
    pub can_use_reflection: bool,
    pub allowed_modules: HashSet<String>,
    pub blocked_functions: HashSet<String>,
}

/// Resource limits
pub struct ResourceLimits {
    pub max_memory_mb: usize,
    pub max_cpu_time_ms: u64,
    pub max_wall_time_ms: u64,
    pub max_stack_depth: usize,
    pub max_output_bytes: usize,
}

/// Audit log entry
pub struct AuditEntry {
    pub timestamp: u64,
    pub action: AuditAction,
    pub allowed: bool,
    pub details: String,
}

/// Audit actions
pub enum AuditAction {
    ModuleImport(String),
    FunctionCall(String),
    FileRead(String),
    FileWrite(String),
    NetworkConnect(String),
    ProcessSpawn(String),
    EnvAccess(String),
}

impl ReplSandbox {
    pub fn new() -> Self {
        Self {
            config: SandboxConfig::default(),
            permissions: SandboxPermissions::default(),
            resource_limits: ResourceLimits::default(),
            audit_log: Vec::new(),
        }
    }

    pub fn check_permission(&mut self, action: &AuditAction) -> bool {
        let allowed = match action {
            AuditAction::ModuleImport(module) => {
                self.permissions.can_import &&
                    (self.permissions.allowed_modules.is_empty() ||
                     self.permissions.allowed_modules.contains(module))
            }
            AuditAction::FunctionCall(func) => {
                !self.permissions.blocked_functions.contains(func)
            }
            AuditAction::FileRead(path) => {
                self.config.filesystem_policy.allow_read &&
                    self.check_path_allowed(path)
            }
            AuditAction::FileWrite(path) => {
                self.config.filesystem_policy.allow_write &&
                    self.check_path_allowed(path)
            }
            AuditAction::NetworkConnect(host) => {
                self.config.network_policy.allow_network &&
                    self.check_host_allowed(host)
            }
            AuditAction::ProcessSpawn(_) => {
                self.permissions.can_spawn_process
            }
            AuditAction::EnvAccess(_) => {
                self.permissions.can_access_env
            }
        };

        self.audit_log.push(AuditEntry {
            timestamp: 0,
            action: match action {
                AuditAction::ModuleImport(s) => AuditAction::ModuleImport(s.clone()),
                AuditAction::FunctionCall(s) => AuditAction::FunctionCall(s.clone()),
                AuditAction::FileRead(s) => AuditAction::FileRead(s.clone()),
                AuditAction::FileWrite(s) => AuditAction::FileWrite(s.clone()),
                AuditAction::NetworkConnect(s) => AuditAction::NetworkConnect(s.clone()),
                AuditAction::ProcessSpawn(s) => AuditAction::ProcessSpawn(s.clone()),
                AuditAction::EnvAccess(s) => AuditAction::EnvAccess(s.clone()),
            },
            allowed,
            details: format!("{:?}", action),
        });

        allowed
    }

    fn check_path_allowed(&self, path: &str) -> bool {
        let policy = &self.config.filesystem_policy;

        // Check blocked paths first
        for blocked in &policy.blocked_paths {
            if path.starts_with(blocked) {
                return false;
            }
        }

        // Check allowed paths
        if policy.allowed_paths.is_empty() {
            return true;
        }

        for allowed in &policy.allowed_paths {
            if path.starts_with(allowed) {
                return true;
            }
        }

        false
    }

    fn check_host_allowed(&self, host: &str) -> bool {
        let policy = &self.config.network_policy;

        // Check blocked hosts first
        for blocked in &policy.blocked_hosts {
            if host.contains(blocked) {
                return false;
            }
        }

        // Check allowed hosts
        if policy.allowed_hosts.is_empty() {
            return true;
        }

        for allowed in &policy.allowed_hosts {
            if host.contains(allowed) {
                return true;
            }
        }

        false
    }

    pub fn get_audit_summary(&self) -> AuditSummary {
        let mut summary = AuditSummary::default();

        for entry in &self.audit_log {
            summary.total_actions += 1;
            if entry.allowed {
                summary.allowed_actions += 1;
            } else {
                summary.blocked_actions += 1;
            }
        }

        summary
    }
}

/// Audit summary
pub struct AuditSummary {
    pub total_actions: u64,
    pub allowed_actions: u64,
    pub blocked_actions: u64,
}

impl Default for SandboxConfig {
    fn default() -> Self {
        Self {
            enabled: false,
            isolation_level: IsolationLevel::None,
            network_policy: NetworkPolicy::default(),
            filesystem_policy: FilesystemPolicy::default(),
        }
    }
}

impl Default for NetworkPolicy {
    fn default() -> Self {
        Self {
            allow_network: true,
            allowed_hosts: Vec::new(),
            blocked_hosts: Vec::new(),
            allowed_ports: Vec::new(),
            max_connections: 100,
        }
    }
}

impl Default for FilesystemPolicy {
    fn default() -> Self {
        Self {
            allow_read: true,
            allow_write: true,
            allowed_paths: Vec::new(),
            blocked_paths: Vec::new(),
            max_file_size_bytes: 100 * 1024 * 1024, // 100MB
        }
    }
}

impl Default for SandboxPermissions {
    fn default() -> Self {
        Self {
            can_import: true,
            can_spawn_process: false,
            can_access_env: true,
            can_use_ffi: false,
            can_use_reflection: true,
            allowed_modules: HashSet::new(),
            blocked_functions: HashSet::new(),
        }
    }
}

impl Default for ResourceLimits {
    fn default() -> Self {
        Self {
            max_memory_mb: 512,
            max_cpu_time_ms: 30000,
            max_wall_time_ms: 60000,
            max_stack_depth: 1000,
            max_output_bytes: 10 * 1024 * 1024, // 10MB
        }
    }
}

impl Default for AuditSummary {
    fn default() -> Self {
        Self {
            total_actions: 0,
            allowed_actions: 0,
            blocked_actions: 0,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENDED UNIT TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod enterprise_tests {
    use super::*;

    #[test]
    fn test_session_recorder() {
        let mut recorder = SessionRecorder::new();
        recorder.start();
        recorder.record_input("let x = 42");
        recorder.record_output("42");
        recorder.stop();

        assert!(!recorder.session_id.is_empty());
        assert!(recorder.events.len() >= 2);
    }

    #[test]
    fn test_literate_mode() {
        let mut literate = LiterateMode::new();
        let id = literate.add_cell(CellType::Code, "let x = 1 + 2");
        assert_eq!(id, 0);

        let result = literate.execute_cell(0);
        assert!(result.is_ok());
    }

    #[test]
    fn test_polyglot_repl() {
        let mut repl = PolyglotRepl::new();
        assert!(repl.list_languages().contains(&"quanta"));

        let result = repl.execute("let x = 42");
        assert!(result.success);
    }

    #[test]
    fn test_collaborative_repl() {
        let mut collab = CollaborativeRepl::new("test-session");

        let participant = Participant {
            id: "user1".to_string(),
            name: "Alice".to_string(),
            role: ParticipantRole::Editor,
            cursor_position: 0,
            selection: None,
            last_active: 0,
            color: "#ff0000".to_string(),
        };

        assert!(collab.join(participant).is_ok());
        assert_eq!(collab.participants.len(), 1);
    }

    #[test]
    fn test_repl_analytics() {
        let mut analytics = ReplAnalytics::new("test");
        analytics.record_command("let x = 1", 10, true, None);
        analytics.record_command("invalid", 5, false, Some("SyntaxError".to_string()));

        assert_eq!(analytics.metrics.total_commands, 2);
        assert_eq!(analytics.metrics.successful_commands, 1);
        assert_eq!(analytics.metrics.failed_commands, 1);

        let report = analytics.generate_report();
        assert_eq!(report.success_rate, 50.0);
    }

    #[test]
    fn test_sandbox() {
        let mut sandbox = ReplSandbox::new();

        let allowed = sandbox.check_permission(&AuditAction::ModuleImport("std".to_string()));
        assert!(allowed);

        sandbox.permissions.can_spawn_process = false;
        let blocked = sandbox.check_permission(&AuditAction::ProcessSpawn("bash".to_string()));
        assert!(!blocked);

        let summary = sandbox.get_audit_summary();
        assert_eq!(summary.total_actions, 2);
    }

    #[test]
    fn test_session_player() {
        let mut player = SessionPlayer::new();
        player.set_speed(2.0);
        assert_eq!(player.playback_speed, 2.0);

        player.play();
        assert!(!player.paused);

        player.pause();
        assert!(player.paused);
    }

    #[test]
    fn test_export_formats() {
        let recorder = SessionRecorder::new();
        let json = recorder.export_json();
        assert!(json.contains("session_id"));

        let md = recorder.export_markdown();
        assert!(md.contains("# Untitled Session"));
    }

    #[test]
    fn test_network_policy() {
        let mut sandbox = ReplSandbox::new();
        sandbox.config.network_policy.blocked_hosts.push("evil.com".to_string());

        let allowed = sandbox.check_permission(&AuditAction::NetworkConnect("good.com".to_string()));
        assert!(allowed);

        let blocked = sandbox.check_permission(&AuditAction::NetworkConnect("evil.com".to_string()));
        assert!(!blocked);
    }
}
