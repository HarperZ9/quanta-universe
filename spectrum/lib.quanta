// HDR METADATA

/// HDR metadata formats
pub mod hdr_metadata {
    use super::*;

    /// SMPTE ST 2086 Mastering Display Metadata
    #[derive(Clone, Debug)]
    pub struct MasteringDisplayMetadata {
        /// Display primaries in CIE 1931 xy
        pub primaries: DisplayPrimaries,
        /// White point in CIE 1931 xy
        pub white_point: (f64, f64),
        /// Maximum luminance (cd/m²)
        pub max_luminance: f64,
        /// Minimum luminance (cd/m²)
        pub min_luminance: f64,
    }

    #[derive(Clone, Debug)]
    pub struct DisplayPrimaries {
        pub red: (f64, f64),
        pub green: (f64, f64),
        pub blue: (f64, f64),
    }

    impl DisplayPrimaries {
        /// BT.2020 primaries
        pub fn bt2020() -> Self {
            DisplayPrimaries {
                red: (0.708, 0.292),
                green: (0.170, 0.797),
                blue: (0.131, 0.046),
            }
        }

        /// DCI-P3 primaries
        pub fn dci_p3() -> Self {
            DisplayPrimaries {
                red: (0.680, 0.320),
                green: (0.265, 0.690),
                blue: (0.150, 0.060),
            }
        }

        /// sRGB/BT.709 primaries
        pub fn srgb() -> Self {
            DisplayPrimaries {
                red: (0.640, 0.330),
                green: (0.300, 0.600),
                blue: (0.150, 0.060),
            }
        }
    }

    /// SMPTE ST 2094-10 (Dolby Vision)
    #[derive(Clone, Debug)]
    pub struct DolbyVisionMetadata {
        /// Profile (0-9)
        pub profile: u8,
        /// Level (1-13)
        pub level: u8,
        /// RPU (Reference Processing Unit) data
        pub rpu: Option<DolbyVisionRPU>,
    }

    #[derive(Clone, Debug)]
    pub struct DolbyVisionRPU {
        /// Base layer configuration
        pub bl_signal_comp_id: u8,
        /// Enhancement layer configuration
        pub el_signal_comp_id: u8,
        /// Mapping curves
        pub mapping_idc: u8,
        /// Trim metadata
        pub trim: Vec<DolbyVisionTrim>,
    }

    #[derive(Clone, Debug)]
    pub struct DolbyVisionTrim {
        /// Target display luminance
        pub target_max_pq: u16,
        pub target_min_pq: u16,
        /// Trim parameters
        pub trim_slope: i16,
        pub trim_offset: i16,
        pub trim_power: i16,
        pub trim_chroma_weight: i16,
        pub trim_saturation_gain: i16,
        pub ms_weight: i16,
    }

    /// SMPTE ST 2094-40 (HDR10+)
    #[derive(Clone, Debug)]
    pub struct HDR10PlusMetadata {
        /// Application version
        pub application_version: u8,
        /// Targeted system display parameters
        pub targeted_system_display: TargetedSystemDisplay,
        /// Mastering display actual peak luminance
        pub mastering_display_peak_luminance: f64,
        /// Tone mapping information
        pub tone_mapping: ToneMappingInfo,
        /// Color saturation mapping
        pub color_saturation: Option<ColorSaturationMapping>,
    }

    #[derive(Clone, Debug)]
    pub struct TargetedSystemDisplay {
        pub max_luminance: f64,
        pub min_luminance: f64,
        pub primaries: DisplayPrimaries,
    }

    #[derive(Clone, Debug)]
    pub struct ToneMappingInfo {
        /// Knee point
        pub knee_point_x: f64,
        pub knee_point_y: f64,
        /// Bezier curve anchors
        pub bezier_curve_anchors: Vec<f64>,
    }

    #[derive(Clone, Debug)]
    pub struct ColorSaturationMapping {
        pub weight: f64,
    }

    /// Content Light Level (CLL) info
    #[derive(Clone, Copy, Debug)]
    pub struct ContentLightLevel {
        /// Maximum Content Light Level (cd/m²)
        pub max_cll: u16,
        /// Maximum Frame-Average Light Level (cd/m²)
        pub max_fall: u16,
    }

    /// HDR format
    #[derive(Clone, Copy, Debug, PartialEq)]
    pub enum HDRFormat {
        SDR,
        HDR10,
        HDR10Plus,
        DolbyVision,
        HLG,
    }

    /// Electro-Optical Transfer Functions
    pub mod eotf {
        /// PQ (Perceptual Quantizer) - SMPTE ST 2084
        pub fn pq_eotf(e: f64) -> f64 {
            let c1 = 0.8359375;
            let c2 = 18.8515625;
            let c3 = 18.6875;
            let m1 = 0.1593017578125;
            let m2 = 78.84375;

            let e_pow = e.powf(1.0 / m2);
            let num = (e_pow - c1).max(0.0);
            let den = c2 - c3 * e_pow;

            10000.0 * (num / den).powf(1.0 / m1)
        }

        /// Inverse PQ (OETF)
        pub fn pq_oetf(l: f64) -> f64 {
            let c1 = 0.8359375;
            let c2 = 18.8515625;
            let c3 = 18.6875;
            let m1 = 0.1593017578125;
            let m2 = 78.84375;

            let y = (l / 10000.0).powf(m1);
            ((c1 + c2 * y) / (1.0 + c3 * y)).powf(m2)
        }

        /// HLG (Hybrid Log-Gamma) - ARIB STD-B67
        pub fn hlg_eotf(e: f64) -> f64 {
            let a = 0.17883277;
            let b = 1.0 - 4.0 * a;
            let c = 0.5 - a * (4.0 * a).ln();

            if e <= 0.5 {
                e * e / 3.0
            } else {
                ((e - c) / a).exp() + b / 12.0
            }
        }

        /// Inverse HLG (OETF)
        pub fn hlg_oetf(l: f64) -> f64 {
            let a = 0.17883277;
            let b = 1.0 - 4.0 * a;
            let c = 0.5 - a * (4.0 * a).ln();

            if l <= 1.0 / 12.0 {
                (3.0 * l).sqrt()
            } else {
                a * (12.0 * l - b).ln() + c
            }
        }

        /// sRGB EOTF
        pub fn srgb_eotf(e: f64) -> f64 {
            if e <= 0.04045 {
                e / 12.92
            } else {
                ((e + 0.055) / 1.055).powf(2.4)
            }
        }

        /// sRGB OETF
        pub fn srgb_oetf(l: f64) -> f64 {
            if l <= 0.0031308 {
                12.92 * l
            } else {
                1.055 * l.powf(1.0 / 2.4) - 0.055
            }
        }

        /// BT.1886 EOTF (gamma 2.4)
        pub fn bt1886_eotf(e: f64) -> f64 {
            e.powf(2.4)
        }
    }
}

// COLOR HARMONY

/// Color harmony algorithms
pub mod harmony {
    use super::*;

    /// Harmony type
    #[derive(Clone, Copy, Debug, PartialEq)]
    pub enum HarmonyType {
        Complementary,
        Analogous,
        Triadic,
        SplitComplementary,
        Tetradic,
        Square,
        Monochromatic,
    }

    /// Generate harmonious colors from a base color
    pub fn generate(base: RGB, harmony_type: HarmonyType, count: usize) -> Vec<RGB> {
        let hsl = rgb_to_hsl(base);

        let hue_offsets: Vec<f32> = match harmony_type {
            HarmonyType::Complementary => vec![0.0, 180.0],
            HarmonyType::Analogous => vec![-30.0, 0.0, 30.0],
            HarmonyType::Triadic => vec![0.0, 120.0, 240.0],
            HarmonyType::SplitComplementary => vec![0.0, 150.0, 210.0],
            HarmonyType::Tetradic => vec![0.0, 60.0, 180.0, 240.0],
            HarmonyType::Square => vec![0.0, 90.0, 180.0, 270.0],
            HarmonyType::Monochromatic => {
                (0..count).map(|i| 0.0).collect()
            }
            HarmonyType::AnalogousTriad => vec![-40.0, 0.0, 40.0],
            HarmonyType::DoubleSplit => vec![0.0, 150.0, 180.0, 210.0],
        };

        let mut colors = Vec::new();

        for (i, &offset) in hue_offsets.iter().take(count).enumerate() {
            let new_hue = (hsl.0 + offset) % 360.0;
            let new_hue = if new_hue < 0.0 { new_hue + 360.0 } else { new_hue };

            // For monochromatic, vary lightness
            let (s, l) = if harmony_type == HarmonyType::Monochromatic {
                let l_offset = (i as f32 - count as f32 / 2.0) * 0.15;
                (hsl.1, (hsl.2 + l_offset).clamp(0.1, 0.9))
            } else {
                (hsl.1, hsl.2)
            };

            colors.push(hsl_to_rgb((new_hue, s, l)));
        }

        colors
    }

    /// Calculate color harmony score (0-1, higher is more harmonious)
    pub fn calculate_harmony_score(colors: &[RGB]) -> f64 {
        if colors.len() < 2 {
            return 1.0;
        }

        let hsls: Vec<(f32, f32, f32)> = colors.iter().map(|c| rgb_to_hsl(*c)).collect();

        // Check for known harmonious relationships
        let mut score = 0.0;
        let mut pairs = 0;

        for i in 0..hsls.len() {
            for j in (i + 1)..hsls.len() {
                let hue_diff = (hsls[i].0 - hsls[j].0).abs();
                let hue_diff = if hue_diff > 180.0 { 360.0 - hue_diff } else { hue_diff };

                // Score based on golden angle relationships
                let pair_score = if (hue_diff - 0.0).abs() < 15.0 { 0.8 }      // Same hue
                    else if (hue_diff - 30.0).abs() < 15.0 { 0.9 }              // Analogous
                    else if (hue_diff - 60.0).abs() < 15.0 { 0.85 }             // Near analogous
                    else if (hue_diff - 120.0).abs() < 15.0 { 0.95 }            // Triadic
                    else if (hue_diff - 150.0).abs() < 15.0 { 0.9 }             // Split complementary
                    else if (hue_diff - 180.0).abs() < 15.0 { 1.0 }             // Complementary
                    else { 0.5 };

                score += pair_score;
                pairs += 1;
            }
        }

        // Penalize for too similar or too different saturation/lightness
        let sat_variance: f32 = hsls.iter().map(|h| h.1).sum::<f32>() / hsls.len() as f32;
        let light_variance: f32 = hsls.iter().map(|h| h.2).sum::<f32>() / hsls.len() as f32;

        let variance_penalty = 1.0 - ((sat_variance - 0.5).abs() + (light_variance - 0.5).abs()) / 2.0;

        (score / pairs as f64) * variance_penalty as f64
    }

    fn rgb_to_hsl(rgb: RGB) -> (f32, f32, f32) {
        let r = rgb.r;
        let g = rgb.g;
        let b = rgb.b;

        let max = r.max(g).max(b);
        let min = r.min(g).min(b);
        let l = (max + min) / 2.0;

        if max == min {
            return (0.0, 0.0, l);
        }

        let d = max - min;
        let s = if l > 0.5 { d / (2.0 - max - min) } else { d / (max + min) };

        let h = if max == r {
            ((g - b) / d) + if g < b { 6.0 } else { 0.0 }
        } else if max == g {
            ((b - r) / d) + 2.0
        } else {
            ((r - g) / d) + 4.0
        };

        (h * 60.0, s, l)
    }

    fn hsl_to_rgb(hsl: (f32, f32, f32)) -> RGB {
        let (h, s, l) = hsl;

        if s == 0.0 {
            return RGB::new(l, l, l);
        }

        let q = if l < 0.5 { l * (1.0 + s) } else { l + s - l * s };
        let p = 2.0 * l - q;

        let h = h / 360.0;

        fn hue_to_rgb(p: f32, q: f32, mut t: f32) -> f32 {
            if t < 0.0 { t += 1.0; }
            if t > 1.0 { t -= 1.0; }
            if t < 1.0 / 6.0 { return p + (q - p) * 6.0 * t; }
            if t < 1.0 / 2.0 { return q; }
            if t < 2.0 / 3.0 { return p + (q - p) * (2.0 / 3.0 - t) * 6.0; }
            p
        }

        RGB::new(
            hue_to_rgb(p, q, h + 1.0 / 3.0),
            hue_to_rgb(p, q, h),
            hue_to_rgb(p, q, h - 1.0 / 3.0),
        )
    }

    /// Color palette generation
    pub struct PaletteGenerator {
        pub base_color: RGB,
        pub harmony: HarmonyType,
        pub variations: usize,
    }

    impl PaletteGenerator {
        pub fn new(base: RGB, harmony: HarmonyType) -> Self {
            PaletteGenerator {
                base_color: base,
                harmony,
                variations: 3,
            }
        }

        pub fn generate(&self) -> ColorPalette {
            let base_colors = generate(self.base_color, self.harmony, 5);

            let mut all_colors = Vec::new();

            for color in &base_colors {
                // Add base color
                all_colors.push(*color);

                // Add tints (lighter)
                for i in 1..=self.variations {
                    let factor = i as f32 * 0.15;
                    all_colors.push(tint(*color, factor));
                }

                // Add shades (darker)
                for i in 1..=self.variations {
                    let factor = i as f32 * 0.15;
                    all_colors.push(shade(*color, factor));
                }
            }

            ColorPalette { colors: all_colors }
        }
    }

    fn tint(color: RGB, factor: f32) -> RGB {
        RGB::new(
            color.r + (1.0 - color.r) * factor,
            color.g + (1.0 - color.g) * factor,
            color.b + (1.0 - color.b) * factor,
        )
    }

    fn shade(color: RGB, factor: f32) -> RGB {
        RGB::new(
            color.r * (1.0 - factor),
            color.g * (1.0 - factor),
            color.b * (1.0 - factor),
        )
    }

    #[derive(Clone, Debug)]
    pub struct ColorPalette {
        pub colors: Vec<RGB>,
    }

    impl ColorPalette {
        pub fn get_primary(&self) -> Option<RGB> {
            self.colors.first().copied()
        }

        pub fn get_accent(&self, index: usize) -> Option<RGB> {
            self.colors.get(index).copied()
        }

        pub fn contrast_ratio(&self, i: usize, j: usize) -> Option<f64> {
            let c1 = self.colors.get(i)?;
            let c2 = self.colors.get(j)?;

            let l1 = relative_luminance(*c1);
            let l2 = relative_luminance(*c2);

            let (lighter, darker) = if l1 > l2 { (l1, l2) } else { (l2, l1) };
            Some((lighter + 0.05) / (darker + 0.05))
        }
    }

    fn relative_luminance(rgb: RGB) -> f64 {
        fn linearize(c: f32) -> f64 {
            let c = c as f64;
            if c <= 0.03928 { c / 12.92 } else { ((c + 0.055) / 1.055).powf(2.4) }
        }

        0.2126 * linearize(rgb.r) + 0.7152 * linearize(rgb.g) + 0.0722 * linearize(rgb.b)
    }
}

// GAMUT BOUNDARY DESCRIPTOR

/// Gamut boundary description and analysis
pub mod gamut {
    use super::*;

    /// Gamut boundary descriptor
    #[derive(Clone, Debug)]
    pub struct GamutBoundary {
        /// Hue-based boundary slices (lightness × chroma)
        pub slices: Vec<GamutSlice>,
        /// Number of hue divisions
        pub hue_steps: usize,
        /// Number of lightness divisions
        pub lightness_steps: usize,
    }

    #[derive(Clone, Debug)]
    pub struct GamutSlice {
        pub hue: f64,
        /// Maximum chroma at each lightness level
        pub max_chroma: Vec<f64>,
    }

    impl GamutBoundary {
        /// Create gamut boundary for sRGB
        pub fn srgb() -> Self {
            let hue_steps = 36;
            let lightness_steps = 100;

            let mut slices = Vec::new();

            for h in 0..hue_steps {
                let hue = h as f64 * 360.0 / hue_steps as f64;
                let mut max_chroma = vec![0.0; lightness_steps];

                for l in 0..lightness_steps {
                    let lightness = l as f64 / (lightness_steps - 1) as f64;
                    max_chroma[l] = find_max_chroma_srgb(hue, lightness);
                }

                slices.push(GamutSlice { hue, max_chroma });
            }

            GamutBoundary { slices, hue_steps, lightness_steps }
        }

        /// Check if a color is within gamut
        pub fn contains(&self, l: f64, c: f64, h: f64) -> bool {
            let max_c = self.max_chroma_at(l, h);
            c <= max_c
        }

        /// Get maximum chroma at given lightness and hue
        pub fn max_chroma_at(&self, l: f64, h: f64) -> f64 {
            let h_idx = (h / 360.0 * self.hue_steps as f64) as usize % self.hue_steps;
            let l_idx = (l * (self.lightness_steps - 1) as f64).clamp(0.0, (self.lightness_steps - 1) as f64) as usize;

            self.slices[h_idx].max_chroma[l_idx]
        }

        /// Clip color to gamut boundary
        pub fn clip(&self, l: f64, c: f64, h: f64) -> (f64, f64, f64) {
            let max_c = self.max_chroma_at(l, h);
            (l, c.min(max_c), h)
        }

        /// Map color to gamut using perceptual intent
        pub fn map_perceptual(&self, l: f64, c: f64, h: f64) -> (f64, f64, f64) {
            if self.contains(l, c, h) {
                return (l, c, h);
            }

            // Find the point on gamut boundary that minimizes perceptual difference
            let max_c = self.max_chroma_at(l, h);

            // Compress chroma while preserving hue
            let ratio = max_c / c;
            let new_c = c * ratio;

            // Optionally adjust lightness for better results
            let l_adjust = 1.0 - (1.0 - ratio) * 0.1;
            let new_l = (l * l_adjust).clamp(0.0, 1.0);

            (new_l, new_c, h)
        }

        /// Calculate gamut volume (integral)
        pub fn volume(&self) -> f64 {
            let mut vol = 0.0;

            for slice in &self.slices {
                for &c in &slice.max_chroma {
                    vol += c;
                }
            }

            vol / (self.hue_steps * self.lightness_steps) as f64
        }

        /// Calculate gamut coverage compared to reference
        pub fn coverage(&self, reference: &GamutBoundary) -> f64 {
            let mut covered = 0.0;
            let mut total = 0.0;

            for (i, ref_slice) in reference.slices.iter().enumerate() {
                let our_slice = &self.slices[i % self.slices.len()];

                for (j, &ref_c) in ref_slice.max_chroma.iter().enumerate() {
                    let our_c = our_slice.max_chroma[j % our_slice.max_chroma.len()];

                    total += ref_c;
                    covered += our_c.min(ref_c);
                }
            }

            if total > 0.0 { covered / total } else { 0.0 }
        }
    }

    fn find_max_chroma_srgb(h: f64, l: f64) -> f64 {
        // Binary search for maximum in-gamut chroma
        let mut lo = 0.0;
        let mut hi = 150.0;

        for _ in 0..20 {
            let mid = (lo + hi) / 2.0;
            if is_in_srgb_gamut(l, mid, h) {
                lo = mid;
            } else {
                hi = mid;
            }
        }

        lo
    }

    fn is_in_srgb_gamut(l: f64, c: f64, h: f64) -> bool {
        // Convert LCH to RGB and check bounds
        let a = c * (h * std::f64::consts::PI / 180.0).cos();
        let b = c * (h * std::f64::consts::PI / 180.0).sin();

        // Lab to XYZ
        let fy = (l + 16.0) / 116.0;
        let fx = a / 500.0 + fy;
        let fz = fy - b / 200.0;

        let xn = 95.047;
        let yn = 100.0;
        let zn = 108.883;

        let x = xn * lab_f_inv(fx);
        let y = yn * lab_f_inv(fy);
        let z = zn * lab_f_inv(fz);

        // XYZ to sRGB
        let r = 3.2404542 * x / 100.0 - 1.5371385 * y / 100.0 - 0.4985314 * z / 100.0;
        let g = -0.9692660 * x / 100.0 + 1.8760108 * y / 100.0 + 0.0415560 * z / 100.0;
        let b = 0.0556434 * x / 100.0 - 0.2040259 * y / 100.0 + 1.0572252 * z / 100.0;

        r >= 0.0 && r <= 1.0 && g >= 0.0 && g <= 1.0 && b >= 0.0 && b <= 1.0
    }

    fn lab_f_inv(t: f64) -> f64 {
        let delta = 6.0 / 29.0;
        if t > delta {
            t.powi(3)
        } else {
            3.0 * delta * delta * (t - 4.0 / 29.0)
        }
    }
}

// COLOR DIFFERENCE FORMULAS

/// Advanced color difference metrics
pub mod delta_e {
    use super::*;

    /// CIE76 (Euclidean distance in Lab)
    pub fn cie76(lab1: (f64, f64, f64), lab2: (f64, f64, f64)) -> f64 {
        ((lab1.0 - lab2.0).powi(2) +
         (lab1.1 - lab2.1).powi(2) +
         (lab1.2 - lab2.2).powi(2)).sqrt()
    }

    /// CIE94 (weighted formula for graphics arts)
    pub fn cie94(lab1: (f64, f64, f64), lab2: (f64, f64, f64), textile: bool) -> f64 {
        let (k_l, k1, k2) = if textile {
            (2.0, 0.048, 0.014)
        } else {
            (1.0, 0.045, 0.015)
        };

        let c1 = (lab1.1.powi(2) + lab1.2.powi(2)).sqrt();
        let c2 = (lab2.1.powi(2) + lab2.2.powi(2)).sqrt();

        let delta_l = lab1.0 - lab2.0;
        let delta_a = lab1.1 - lab2.1;
        let delta_b = lab1.2 - lab2.2;
        let delta_c = c1 - c2;

        let delta_h_sq = delta_a.powi(2) + delta_b.powi(2) - delta_c.powi(2);
        let delta_h = if delta_h_sq > 0.0 { delta_h_sq.sqrt() } else { 0.0 };

        let sl = 1.0;
        let sc = 1.0 + k1 * c1;
        let sh = 1.0 + k2 * c1;

        ((delta_l / (k_l * sl)).powi(2) +
         (delta_c / sc).powi(2) +
         (delta_h / sh).powi(2)).sqrt()
    }

    /// CIEDE2000 (most accurate for small color differences)
    pub fn ciede2000(lab1: (f64, f64, f64), lab2: (f64, f64, f64)) -> f64 {
        let (l1, a1, b1) = lab1;
        let (l2, a2, b2) = lab2;

        let c1 = (a1.powi(2) + b1.powi(2)).sqrt();
        let c2 = (a2.powi(2) + b2.powi(2)).sqrt();
        let c_avg = (c1 + c2) / 2.0;

        let g = 0.5 * (1.0 - (c_avg.powi(7) / (c_avg.powi(7) + 25.0f64.powi(7))).sqrt());

        let a1_prime = a1 * (1.0 + g);
        let a2_prime = a2 * (1.0 + g);

        let c1_prime = (a1_prime.powi(2) + b1.powi(2)).sqrt();
        let c2_prime = (a2_prime.powi(2) + b2.powi(2)).sqrt();

        let h1_prime = if a1_prime == 0.0 && b1 == 0.0 {
            0.0
        } else {
            let h = b1.atan2(a1_prime).to_degrees();
            if h < 0.0 { h + 360.0 } else { h }
        };

        let h2_prime = if a2_prime == 0.0 && b2 == 0.0 {
            0.0
        } else {
            let h = b2.atan2(a2_prime).to_degrees();
            if h < 0.0 { h + 360.0 } else { h }
        };

        let delta_l_prime = l2 - l1;
        let delta_c_prime = c2_prime - c1_prime;

        let delta_h_prime = if c1_prime * c2_prime == 0.0 {
            0.0
        } else {
            let diff = h2_prime - h1_prime;
            if diff.abs() <= 180.0 {
                diff
            } else if diff > 180.0 {
                diff - 360.0
            } else {
                diff + 360.0
            }
        };

        let delta_h_prime_rad = 2.0 * (c1_prime * c2_prime).sqrt() *
            (delta_h_prime / 2.0 * std::f64::consts::PI / 180.0).sin();

        let l_avg_prime = (l1 + l2) / 2.0;
        let c_avg_prime = (c1_prime + c2_prime) / 2.0;

        let h_avg_prime = if c1_prime * c2_prime == 0.0 {
            h1_prime + h2_prime
        } else if (h1_prime - h2_prime).abs() <= 180.0 {
            (h1_prime + h2_prime) / 2.0
        } else if h1_prime + h2_prime < 360.0 {
            (h1_prime + h2_prime + 360.0) / 2.0
        } else {
            (h1_prime + h2_prime - 360.0) / 2.0
        };

        let t = 1.0 -
            0.17 * ((h_avg_prime - 30.0).to_radians().cos()) +
            0.24 * ((2.0 * h_avg_prime).to_radians().cos()) +
            0.32 * ((3.0 * h_avg_prime + 6.0).to_radians().cos()) -
            0.20 * ((4.0 * h_avg_prime - 63.0).to_radians().cos());

        let delta_theta = 30.0 * (-(((h_avg_prime - 275.0) / 25.0).powi(2))).exp();
        let rc = 2.0 * (c_avg_prime.powi(7) / (c_avg_prime.powi(7) + 25.0f64.powi(7))).sqrt();
        let sl = 1.0 + 0.015 * (l_avg_prime - 50.0).powi(2) /
            (20.0 + (l_avg_prime - 50.0).powi(2)).sqrt();
        let sc = 1.0 + 0.045 * c_avg_prime;
        let sh = 1.0 + 0.015 * c_avg_prime * t;
        let rt = -(2.0 * delta_theta).to_radians().sin() * rc;

        let kl = 1.0;
        let kc = 1.0;
        let kh = 1.0;

        ((delta_l_prime / (kl * sl)).powi(2) +
         (delta_c_prime / (kc * sc)).powi(2) +
         (delta_h_prime_rad / (kh * sh)).powi(2) +
         rt * (delta_c_prime / (kc * sc)) * (delta_h_prime_rad / (kh * sh))).sqrt()
    }

    /// CMC l:c (for textile color matching)
    pub fn cmc(lab1: (f64, f64, f64), lab2: (f64, f64, f64), l: f64, c: f64) -> f64 {
        let c1 = (lab1.1.powi(2) + lab1.2.powi(2)).sqrt();
        let c2 = (lab2.1.powi(2) + lab2.2.powi(2)).sqrt();

        let h1 = lab1.2.atan2(lab1.1).to_degrees();
        let h1 = if h1 < 0.0 { h1 + 360.0 } else { h1 };

        let delta_l = lab1.0 - lab2.0;
        let delta_c = c1 - c2;
        let delta_a = lab1.1 - lab2.1;
        let delta_b = lab1.2 - lab2.2;
        let delta_h = (delta_a.powi(2) + delta_b.powi(2) - delta_c.powi(2)).sqrt();

        let f = (c1.powi(4) / (c1.powi(4) + 1900.0)).sqrt();
        let t = if h1 >= 164.0 && h1 <= 345.0 {
            0.56 + (0.2 * (h1 + 168.0).to_radians().cos()).abs()
        } else {
            0.36 + (0.4 * (h1 + 35.0).to_radians().cos()).abs()
        };

        let sl = if lab1.0 < 16.0 { 0.511 } else { 0.040975 * lab1.0 / (1.0 + 0.01765 * lab1.0) };
        let sc = 0.0638 * c1 / (1.0 + 0.0131 * c1) + 0.638;
        let sh = sc * (f * t + 1.0 - f);

        ((delta_l / (l * sl)).powi(2) +
         (delta_c / (c * sc)).powi(2) +
         (delta_h / sh).powi(2)).sqrt()
    }

    /// DIN99 color difference
    pub fn din99(lab1: (f64, f64, f64), lab2: (f64, f64, f64)) -> f64 {
        fn to_din99(lab: (f64, f64, f64)) -> (f64, f64, f64) {
            let l99 = 105.509 * ((1.0 + 0.0158 * lab.0).ln());
            let e = lab.1 * 0.7.to_radians().cos() + lab.2 * 0.7.to_radians().sin();
            let f = lab.2 * 0.7.to_radians().cos() - lab.1 * 0.7.to_radians().sin();
            let g = 0.045 * e * (0.045 * e / (1.0 + 0.045 * e)).exp();
            let c99 = (e.powi(2) + f.powi(2)).sqrt() / (1.0 + 0.045 * (e.powi(2) + f.powi(2)).sqrt());
            let h = f.atan2(e);
            let a99 = c99 * h.cos();
            let b99 = c99 * h.sin();
            (l99, a99, b99)
        }

        let din1 = to_din99(lab1);
        let din2 = to_din99(lab2);

        ((din1.0 - din2.0).powi(2) +
         (din1.1 - din2.1).powi(2) +
         (din1.2 - din2.2).powi(2)).sqrt()
    }
}

// TESTS

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_precision_tiers() {
        assert!(PrecisionTier::Compatible.gamut_coverage() < PrecisionTier::Absolute.gamut_coverage());
    }
    
    #[test]
    fn test_srgb_roundtrip() {
        let original = RGB::new(0.5, 0.3, 0.8);
        let linear = convert::srgb_to_linear(original);
        let back = convert::linear_to_srgb(linear);
        
        assert!((original.r - back.r).abs() < 0.001);
        assert!((original.g - back.g).abs() < 0.001);
        assert!((original.b - back.b).abs() < 0.001);
    }
    
    #[test]
    fn test_oklab_roundtrip() {
        let original = RGB::new(0.5, 0.3, 0.8);
        let linear = convert::srgb_to_linear(original);
        let oklab = convert::linear_srgb_to_oklab(linear);
        let back_linear = convert::oklab_to_linear_srgb(oklab);
        
        assert!((linear.r - back_linear.r).abs() < 0.001);
        assert!((linear.g - back_linear.g).abs() < 0.001);
        assert!((linear.b - back_linear.b).abs() < 0.001);
    }
    
    #[test]
    fn test_tonemappers() {
        let hdr = RGB::new(5.0, 3.0, 1.0);
        
        let reinhard = tonemap::reinhard(hdr);
        assert!(reinhard.r <= 1.0 && reinhard.g <= 1.0 && reinhard.b <= 1.0);
        
        let aces = tonemap::aces(hdr);
        assert!(aces.r <= 1.0 && aces.g <= 1.0 && aces.b <= 1.0);
        
        let quanta = tonemap::quanta_adaptive(hdr);
        assert!(quanta.r <= 1.0 && quanta.g <= 1.0 && quanta.b <= 1.0);
    }
    
    #[test]
    fn test_pipeline() {
        let pipeline = TitanPipeline::new(PrecisionTier::Professional);
        let input = RGB::new(0.8, 0.6, 0.4);
        let output = pipeline.process(input);
        
        assert!(output.r >= 0.0 && output.r <= 1.0);
        assert!(output.g >= 0.0 && output.g <= 1.0);
        assert!(output.b >= 0.0 && output.b <= 1.0);
    }
}
