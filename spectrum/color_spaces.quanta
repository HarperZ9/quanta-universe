// ============================================================================
// FUNDAMENTAL COLOR TYPES
// ============================================================================

/// CIE 1931 XYZ tristimulus values
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct XYZ {
    pub x: f64,
    pub y: f64,
    pub z: f64,
}

impl XYZ {
    pub const fn new(x: f64, y: f64, z: f64) -> Self {
        XYZ { x, y, z }
    }

    pub const fn zero() -> Self {
        XYZ { x: 0.0, y: 0.0, z: 0.0 }
    }

    /// D65 standard illuminant (daylight)
    pub const D65: XYZ = XYZ { x: 0.95047, y: 1.0, z: 1.08883 };

    /// D50 standard illuminant (horizon light)
    pub const D50: XYZ = XYZ { x: 0.96422, y: 1.0, z: 0.82521 };

    /// D55 standard illuminant
    pub const D55: XYZ = XYZ { x: 0.95682, y: 1.0, z: 0.92149 };

    /// D75 standard illuminant
    pub const D75: XYZ = XYZ { x: 0.94972, y: 1.0, z: 1.22638 };

    /// Illuminant A (incandescent)
    pub const A: XYZ = XYZ { x: 1.09850, y: 1.0, z: 0.35585 };

    /// Illuminant E (equal energy)
    pub const E: XYZ = XYZ { x: 1.0, y: 1.0, z: 1.0 };

    /// CIE Illuminant C
    pub const C: XYZ = XYZ { x: 0.98074, y: 1.0, z: 1.18232 };

    /// DCI-P3 white point (theater)
    pub const DCI: XYZ = XYZ { x: 0.89459, y: 1.0, z: 0.95441 };

    /// Convert to xyY chromaticity
    pub fn to_xyY(&self) -> xyY {
        let sum = self.x + self.y + self.z;
        if sum == 0.0 {
            return xyY::new(0.0, 0.0, 0.0);
        }
        xyY::new(self.x / sum, self.y / sum, self.y)
    }

    /// Luminance (Y component)
    pub fn luminance(&self) -> f64 {
        self.y
    }

    /// Scale by factor
    pub fn scale(&self, factor: f64) -> Self {
        XYZ::new(self.x * factor, self.y * factor, self.z * factor)
    }

    /// Add two XYZ colors
    pub fn add(&self, other: &XYZ) -> Self {
        XYZ::new(self.x + other.x, self.y + other.y, self.z + other.z)
    }

    /// Interpolate between two XYZ colors
    pub fn lerp(&self, other: &XYZ, t: f64) -> Self {
        XYZ::new(
            self.x + (other.x - self.x) * t,
            self.y + (other.y - self.y) * t,
            self.z + (other.z - self.z) * t,
        )
    }
}

/// CIE xyY chromaticity coordinates
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct xyY {
    pub x: f64,  // x chromaticity [0, 1]
    pub y: f64,  // y chromaticity [0, 1]
    pub Y: f64,  // Luminance
}

impl xyY {
    pub const fn new(x: f64, y: f64, Y: f64) -> Self {
        xyY { x, y, Y }
    }

    /// Convert to XYZ
    pub fn to_xyz(&self) -> XYZ {
        if self.y == 0.0 {
            return XYZ::zero();
        }
        let X = self.x * self.Y / self.y;
        let Z = (1.0 - self.x - self.y) * self.Y / self.y;
        XYZ::new(X, self.Y, Z)
    }

    /// Get chromaticity as (x, y) pair
    pub fn chromaticity(&self) -> (f64, f64) {
        (self.x, self.y)
    }
}

/// Linear RGB with arbitrary primaries
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct LinearRGB {
    pub r: f64,
    pub g: f64,
    pub b: f64,
}

impl LinearRGB {
    pub const fn new(r: f64, g: f64, b: f64) -> Self {
        LinearRGB { r, g, b }
    }

    pub const fn black() -> Self {
        LinearRGB { r: 0.0, g: 0.0, b: 0.0 }
    }

    pub const fn white() -> Self {
        LinearRGB { r: 1.0, g: 1.0, b: 1.0 }
    }

    /// Clamp to [0, 1] range
    pub fn saturate(&self) -> Self {
        LinearRGB::new(
            self.r.clamp(0.0, 1.0),
            self.g.clamp(0.0, 1.0),
            self.b.clamp(0.0, 1.0),
        )
    }

    /// Check if within gamut
    pub fn is_in_gamut(&self) -> bool {
        self.r >= 0.0 && self.r <= 1.0 &&
        self.g >= 0.0 && self.g <= 1.0 &&
        self.b >= 0.0 && self.b <= 1.0
    }

    /// Scale by factor
    pub fn scale(&self, factor: f64) -> Self {
        LinearRGB::new(self.r * factor, self.g * factor, self.b * factor)
    }

    /// Component-wise multiply
    pub fn multiply(&self, other: &LinearRGB) -> Self {
        LinearRGB::new(self.r * other.r, self.g * other.g, self.b * other.b)
    }

    /// Add two colors
    pub fn add(&self, other: &LinearRGB) -> Self {
        LinearRGB::new(self.r + other.r, self.g + other.g, self.b + other.b)
    }

    /// Lerp between colors
    pub fn lerp(&self, other: &LinearRGB, t: f64) -> Self {
        LinearRGB::new(
            self.r + (other.r - self.r) * t,
            self.g + (other.g - self.g) * t,
            self.b + (other.b - self.b) * t,
        )
    }

    /// Maximum component
    pub fn max_component(&self) -> f64 {
        self.r.max(self.g).max(self.b)
    }

    /// Minimum component
    pub fn min_component(&self) -> f64 {
        self.r.min(self.g).min(self.b)
    }
}

/// Encoded sRGB (gamma-compressed)
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct sRGB {
    pub r: f64,
    pub g: f64,
    pub b: f64,
}

impl sRGB {
    pub const fn new(r: f64, g: f64, b: f64) -> Self {
        sRGB { r, g, b }
    }

    /// From 8-bit values
    pub fn from_u8(r: u8, g: u8, b: u8) -> Self {
        sRGB::new(r as f64 / 255.0, g as f64 / 255.0, b as f64 / 255.0)
    }

    /// To 8-bit values
    pub fn to_u8(&self) -> (u8, u8, u8) {
        (
            (self.r.clamp(0.0, 1.0) * 255.0 + 0.5) as u8,
            (self.g.clamp(0.0, 1.0) * 255.0 + 0.5) as u8,
            (self.b.clamp(0.0, 1.0) * 255.0 + 0.5) as u8,
        )
    }

    /// From hex string (#RRGGBB or RRGGBB)
    pub fn from_hex(hex: &str) -> Option<Self> {
        let hex = hex.trim_start_matches('#');
        if hex.len() != 6 {
            return None;
        }
        let r = u8::from_str_radix(&hex[0..2], 16).ok()?;
        let g = u8::from_str_radix(&hex[2..4], 16).ok()?;
        let b = u8::from_str_radix(&hex[4..6], 16).ok()?;
        Some(sRGB::from_u8(r, g, b))
    }

    /// To hex string
    pub fn to_hex(&self) -> String {
        let (r, g, b) = self.to_u8();
        format!("#{:02X}{:02X}{:02X}", r, g, b)
    }

    /// Convert to linear RGB
    pub fn to_linear(&self) -> LinearRGB {
        LinearRGB::new(
            srgb_eotf(self.r),
            srgb_eotf(self.g),
            srgb_eotf(self.b),
        )
    }

    /// Convert from linear RGB
    pub fn from_linear(linear: &LinearRGB) -> Self {
        sRGB::new(
            srgb_oetf(linear.r),
            srgb_oetf(linear.g),
            srgb_oetf(linear.b),
        )
    }
}

// ============================================================================
// CIE LAB AND RELATED SPACES
// ============================================================================

/// CIE L*a*b* (CIELAB) perceptually uniform color space
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Lab {
    pub L: f64,  // Lightness [0, 100]
    pub a: f64,  // Green-Red axis [-128, 127]
    pub b: f64,  // Blue-Yellow axis [-128, 127]
}

impl Lab {
    pub const fn new(L: f64, a: f64, b: f64) -> Self {
        Lab { L, a, b }
    }

    /// Chroma (colorfulness)
    pub fn chroma(&self) -> f64 {
        (self.a * self.a + self.b * self.b).sqrt()
    }

    /// Hue angle in radians
    pub fn hue_radians(&self) -> f64 {
        self.b.atan2(self.a)
    }

    /// Hue angle in degrees [0, 360)
    pub fn hue_degrees(&self) -> f64 {
        let h = self.b.atan2(self.a).to_degrees();
        if h < 0.0 { h + 360.0 } else { h }
    }

    /// Convert to LCH
    pub fn to_lch(&self) -> LCH {
        LCH::new(self.L, self.chroma(), self.hue_degrees())
    }

    /// Convert from XYZ with white point
    pub fn from_xyz(xyz: &XYZ, white: &XYZ) -> Self {
        let fx = lab_f(xyz.x / white.x);
        let fy = lab_f(xyz.y / white.y);
        let fz = lab_f(xyz.z / white.z);

        Lab::new(
            116.0 * fy - 16.0,
            500.0 * (fx - fy),
            200.0 * (fy - fz),
        )
    }

    /// Convert to XYZ with white point
    pub fn to_xyz(&self, white: &XYZ) -> XYZ {
        let fy = (self.L + 16.0) / 116.0;
        let fx = self.a / 500.0 + fy;
        let fz = fy - self.b / 200.0;

        XYZ::new(
            white.x * lab_f_inv(fx),
            white.y * lab_f_inv(fy),
            white.z * lab_f_inv(fz),
        )
    }
}

/// CIE L*C*h (cylindrical Lab)
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct LCH {
    pub L: f64,  // Lightness [0, 100]
    pub C: f64,  // Chroma [0, ~230]
    pub h: f64,  // Hue [0, 360)
}

impl LCH {
    pub const fn new(L: f64, C: f64, h: f64) -> Self {
        LCH { L, C, h }
    }

    /// Convert to Lab
    pub fn to_lab(&self) -> Lab {
        let h_rad = self.h.to_radians();
        Lab::new(
            self.L,
            self.C * h_rad.cos(),
            self.C * h_rad.sin(),
        )
    }

    /// Interpolate hue (shortest path)
    pub fn lerp_hue(h1: f64, h2: f64, t: f64) -> f64 {
        let diff = h2 - h1;
        let diff = if diff > 180.0 {
            diff - 360.0
        } else if diff < -180.0 {
            diff + 360.0
        } else {
            diff
        };
        let h = h1 + diff * t;
        if h < 0.0 { h + 360.0 } else if h >= 360.0 { h - 360.0 } else { h }
    }
}

/// CIE L*u*v* color space
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Luv {
    pub L: f64,  // Lightness [0, 100]
    pub u: f64,  // u* coordinate
    pub v: f64,  // v* coordinate
}

impl Luv {
    pub const fn new(L: f64, u: f64, v: f64) -> Self {
        Luv { L, u, v }
    }

    /// Convert from XYZ with white point
    pub fn from_xyz(xyz: &XYZ, white: &XYZ) -> Self {
        let yr = xyz.y / white.y;
        let L = if yr > CIE_EPSILON {
            116.0 * yr.cbrt() - 16.0
        } else {
            CIE_KAPPA * yr
        };

        let (u_prime, v_prime) = Self::uv_prime(xyz);
        let (un_prime, vn_prime) = Self::uv_prime(white);

        Luv::new(
            L,
            13.0 * L * (u_prime - un_prime),
            13.0 * L * (v_prime - vn_prime),
        )
    }

    /// Convert to XYZ with white point
    pub fn to_xyz(&self, white: &XYZ) -> XYZ {
        if self.L == 0.0 {
            return XYZ::zero();
        }

        let (un_prime, vn_prime) = Self::uv_prime(white);
        let u_prime = self.u / (13.0 * self.L) + un_prime;
        let v_prime = self.v / (13.0 * self.L) + vn_prime;

        let Y = if self.L > CIE_KAPPA * CIE_EPSILON {
            ((self.L + 16.0) / 116.0).powi(3)
        } else {
            self.L / CIE_KAPPA
        } * white.y;

        let X = Y * 9.0 * u_prime / (4.0 * v_prime);
        let Z = Y * (12.0 - 3.0 * u_prime - 20.0 * v_prime) / (4.0 * v_prime);

        XYZ::new(X, Y, Z)
    }

    fn uv_prime(xyz: &XYZ) -> (f64, f64) {
        let denom = xyz.x + 15.0 * xyz.y + 3.0 * xyz.z;
        if denom == 0.0 {
            (0.0, 0.0)
        } else {
            (4.0 * xyz.x / denom, 9.0 * xyz.y / denom)
        }
    }

    /// Chroma
    pub fn chroma(&self) -> f64 {
        (self.u * self.u + self.v * self.v).sqrt()
    }

    /// Saturation
    pub fn saturation(&self) -> f64 {
        if self.L == 0.0 { 0.0 } else { self.chroma() / self.L }
    }
}

// ============================================================================
// OKLAB - PERCEPTUALLY UNIFORM COLOR SPACE
// ============================================================================

/// Oklab perceptually uniform color space (Björn Ottosson)
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Oklab {
    pub L: f64,  // Lightness [0, 1]
    pub a: f64,  // Green-Red
    pub b: f64,  // Blue-Yellow
}

impl Oklab {
    pub const fn new(L: f64, a: f64, b: f64) -> Self {
        Oklab { L, a, b }
    }

    /// Chroma
    pub fn chroma(&self) -> f64 {
        (self.a * self.a + self.b * self.b).sqrt()
    }

    /// Hue in degrees
    pub fn hue(&self) -> f64 {
        let h = self.b.atan2(self.a).to_degrees();
        if h < 0.0 { h + 360.0 } else { h }
    }

    /// Convert from linear sRGB
    pub fn from_linear_srgb(rgb: &LinearRGB) -> Self {
        let l = 0.4122214708 * rgb.r + 0.5363325363 * rgb.g + 0.0514459929 * rgb.b;
        let m = 0.2119034982 * rgb.r + 0.6806995451 * rgb.g + 0.1073969566 * rgb.b;
        let s = 0.0883024619 * rgb.r + 0.2817188376 * rgb.g + 0.6299787005 * rgb.b;

        let l_ = l.cbrt();
        let m_ = m.cbrt();
        let s_ = s.cbrt();

        Oklab::new(
            0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_,
            1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_,
            0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_,
        )
    }

    /// Convert to linear sRGB
    pub fn to_linear_srgb(&self) -> LinearRGB {
        let l_ = self.L + 0.3963377774 * self.a + 0.2158037573 * self.b;
        let m_ = self.L - 0.1055613458 * self.a - 0.0638541728 * self.b;
        let s_ = self.L - 0.0894841775 * self.a - 1.2914855480 * self.b;

        let l = l_ * l_ * l_;
        let m = m_ * m_ * m_;
        let s = s_ * s_ * s_;

        LinearRGB::new(
             4.0767416621 * l - 3.3077115913 * m + 0.2309699292 * s,
            -1.2684380046 * l + 2.6097574011 * m - 0.3413193965 * s,
            -0.0041960863 * l - 0.7034186147 * m + 1.7076147010 * s,
        )
    }

    /// Convert to Oklch
    pub fn to_oklch(&self) -> Oklch {
        Oklch::new(self.L, self.chroma(), self.hue())
    }
}

/// Oklch cylindrical representation of Oklab
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Oklch {
    pub L: f64,  // Lightness [0, 1]
    pub C: f64,  // Chroma
    pub h: f64,  // Hue [0, 360)
}

impl Oklch {
    pub const fn new(L: f64, C: f64, h: f64) -> Self {
        Oklch { L, C, h }
    }

    /// Convert to Oklab
    pub fn to_oklab(&self) -> Oklab {
        let h_rad = self.h.to_radians();
        Oklab::new(
            self.L,
            self.C * h_rad.cos(),
            self.C * h_rad.sin(),
        )
    }

    /// Interpolate in Oklch (preserves hue better)
    pub fn lerp(&self, other: &Oklch, t: f64) -> Oklch {
        Oklch::new(
            self.L + (other.L - self.L) * t,
            self.C + (other.C - self.C) * t,
            LCH::lerp_hue(self.h, other.h, t),
        )
    }
}

// ============================================================================
// JZAZBZ - HIGH DYNAMIC RANGE PERCEPTUAL SPACE
// ============================================================================

/// JzAzBz perceptually uniform HDR color space
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct JzAzBz {
    pub Jz: f64,  // Lightness
    pub az: f64,  // Red-Green
    pub bz: f64,  // Yellow-Blue
}

impl JzAzBz {
    pub const fn new(Jz: f64, az: f64, bz: f64) -> Self {
        JzAzBz { Jz, az, bz }
    }

    // JzAzBz constants
    const B: f64 = 1.15;
    const G: f64 = 0.66;
    const C1: f64 = 0.8359375;        // 3424 / 4096
    const C2: f64 = 18.8515625;       // 2413 / 128
    const C3: f64 = 18.6875;          // 2392 / 128
    const N: f64 = 0.15930175781;     // 2610 / 16384
    const P: f64 = 134.034375;        // 1.7 * 2523 / 32
    const D: f64 = -0.56;
    const D0: f64 = 1.6295499532821566e-11;

    /// Convert from XYZ (absolute, in cd/m²)
    pub fn from_xyz_abs(xyz: &XYZ) -> Self {
        let xp = Self::B * xyz.x - (Self::B - 1.0) * xyz.z;
        let yp = Self::G * xyz.y - (Self::G - 1.0) * xyz.x;

        let lp = 0.41478972 * xp + 0.579999 * yp + 0.0146480 * xyz.z;
        let mp = -0.2015100 * xp + 1.120649 * yp + 0.0531008 * xyz.z;
        let sp = -0.0166008 * xp + 0.264800 * yp + 0.6684799 * xyz.z;

        let l = Self::pq_encode(lp);
        let m = Self::pq_encode(mp);
        let s = Self::pq_encode(sp);

        let iz = 0.5 * (l + m);
        let az = 3.524000 * l - 4.066708 * m + 0.542708 * s;
        let bz = 0.199076 * l + 1.096799 * m - 1.295875 * s;

        let jz = ((1.0 + Self::D) * iz) / (1.0 + Self::D * iz) - Self::D0;

        JzAzBz::new(jz, az, bz)
    }

    /// Convert to XYZ (absolute, in cd/m²)
    pub fn to_xyz_abs(&self) -> XYZ {
        let jz = self.Jz + Self::D0;
        let iz = jz / (1.0 + Self::D - Self::D * jz);

        let l = iz + 0.1386050432715393 * self.az + 0.05804731615611886 * self.bz;
        let m = iz - 0.1386050432715393 * self.az - 0.05804731615611886 * self.bz;
        let s = iz - 0.09601924202631895 * self.az - 0.8118918960560388 * self.bz;

        let lp = Self::pq_decode(l);
        let mp = Self::pq_decode(m);
        let sp = Self::pq_decode(s);

        let xp =  1.9242264357876067 * lp - 1.0047923125953657 * mp + 0.037651404030618 * sp;
        let yp =  0.35031676209499907 * lp + 0.7264811939316552 * mp - 0.06538442294808501 * sp;
        let z  = -0.09098281098284752 * lp - 0.3127282905230739 * mp + 1.5227665613052603 * sp;

        let x = (xp + (Self::B - 1.0) * z) / Self::B;
        let y = (yp + (Self::G - 1.0) * x) / Self::G;

        XYZ::new(x, y, z)
    }

    fn pq_encode(x: f64) -> f64 {
        let xp = (x / 10000.0).max(0.0);
        let num = Self::C1 + Self::C2 * xp.powf(Self::N);
        let den = 1.0 + Self::C3 * xp.powf(Self::N);
        (num / den).powf(Self::P)
    }

    fn pq_decode(x: f64) -> f64 {
        let xp = x.powf(1.0 / Self::P);
        let num = (Self::C1 - xp).max(0.0);
        let den = Self::C3 * xp - Self::C2;
        10000.0 * (num / den).powf(1.0 / Self::N)
    }

    /// Chroma
    pub fn chroma(&self) -> f64 {
        (self.az * self.az + self.bz * self.bz).sqrt()
    }

    /// Hue in degrees
    pub fn hue(&self) -> f64 {
        let h = self.bz.atan2(self.az).to_degrees();
        if h < 0.0 { h + 360.0 } else { h }
    }
}

/// JzCzhz cylindrical representation
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct JzCzhz {
    pub Jz: f64,
    pub Cz: f64,
    pub hz: f64,
}

impl JzCzhz {
    pub const fn new(Jz: f64, Cz: f64, hz: f64) -> Self {
        JzCzhz { Jz, Cz, hz }
    }

    pub fn from_jzazbz(jzazbz: &JzAzBz) -> Self {
        JzCzhz::new(jzazbz.Jz, jzazbz.chroma(), jzazbz.hue())
    }

    pub fn to_jzazbz(&self) -> JzAzBz {
        let h_rad = self.hz.to_radians();
        JzAzBz::new(self.Jz, self.Cz * h_rad.cos(), self.Cz * h_rad.sin())
    }
}

// ============================================================================
// ICTCP - DOLBY HDR COLOR SPACE
// ============================================================================

/// ICtCp color space (Dolby HDR)
#[repr(C)]
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct ICtCp {
    pub I: f64,   // Intensity
    pub Ct: f64,  // Tritan (blue-yellow)
    pub Cp: f64,  // Protan (red-green)
}

impl ICtCp {
    pub const fn new(I: f64, Ct: f64, Cp: f64) -> Self {
        ICtCp { I, Ct, Cp }
    }

    /// Convert from XYZ (absolute, cd/m²)
    pub fn from_xyz_abs(xyz: &XYZ) -> Self {
        // XYZ to LMS
        let L =  0.3592 * xyz.x + 0.6976 * xyz.y - 0.0358 * xyz.z;
        let M = -0.1922 * xyz.x + 1.1004 * xyz.y + 0.0755 * xyz.z;
        let S =  0.0070 * xyz.x + 0.0749 * xyz.y + 0.8434 * xyz.z;

        // PQ encode
        let Lp = pq_oetf(L / 10000.0);
        let Mp = pq_oetf(M / 10000.0);
        let Sp = pq_oetf(S / 10000.0);

        // LMS' to ICtCp
        ICtCp::new(
            0.5 * Lp + 0.5 * Mp,
            1.613769531 * Lp - 3.323486328 * Mp + 1.709716797 * Sp,
            4.378173828 * Lp - 4.245605469 * Mp - 0.132568359 * Sp,
        )
    }

    /// Convert to XYZ (absolute, cd/m²)
    pub fn to_xyz_abs(&self) -> XYZ {
        // ICtCp to LMS'
        let Lp = self.I + 0.00860904 * self.Ct + 0.11103 * self.Cp;
        let Mp = self.I - 0.00860904 * self.Ct - 0.11103 * self.Cp;
        let Sp = self.I + 0.56003 * self.Ct - 0.32068 * self.Cp;

        // PQ decode
        let L = pq_eotf(Lp) * 10000.0;
        let M = pq_eotf(Mp) * 10000.0;
        let S = pq_eotf(Sp) * 10000.0;

        // LMS to XYZ
        XYZ::new(
             2.0702 * L - 1.3265 * M + 0.2067 * S,
             0.3650 * L + 0.6806 * M - 0.0453 * S,
            -0.0496 * L - 0.0494 * M + 1.1880 * S,
        )
    }
}

