    use super::ColorMatrix3x3;

    /// sRGB to XYZ (D65)
    pub const SRGB_TO_XYZ: ColorMatrix3x3 = ColorMatrix3x3 {
        m: [
            [0.4124564, 0.3575761, 0.1804375],
