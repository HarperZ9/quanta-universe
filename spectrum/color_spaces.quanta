// ============================================================================
// UNIT TESTS
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    const EPSILON: f64 = 1e-5;

    fn approx_eq(a: f64, b: f64) -> bool {
        (a - b).abs() < EPSILON
    }

    #[test]
    fn test_xyz_to_xyY_roundtrip() {
        let xyz = XYZ::new(0.5, 0.6, 0.7);
        let xyY = xyz.to_xyY();
        let back = xyY.to_xyz();
        assert!(approx_eq(xyz.x, back.x));
        assert!(approx_eq(xyz.y, back.y));
        assert!(approx_eq(xyz.z, back.z));
    }

    #[test]
    fn test_srgb_linear_roundtrip() {
        let srgb = sRGB::new(0.5, 0.3, 0.8);
        let linear = srgb.to_linear();
        let back = sRGB::from_linear(&linear);
        assert!(approx_eq(srgb.r, back.r));
        assert!(approx_eq(srgb.g, back.g));
        assert!(approx_eq(srgb.b, back.b));
    }

    #[test]
    fn test_lab_xyz_roundtrip() {
        let xyz = XYZ::new(0.4, 0.5, 0.6);
        let lab = Lab::from_xyz(&xyz, &XYZ::D65);
        let back = lab.to_xyz(&XYZ::D65);
        assert!(approx_eq(xyz.x, back.x));
        assert!(approx_eq(xyz.y, back.y));
        assert!(approx_eq(xyz.z, back.z));
    }

    #[test]
    fn test_lab_lch_roundtrip() {
        let lab = Lab::new(50.0, 30.0, -20.0);
        let lch = lab.to_lch();
        let back = lch.to_lab();
        assert!(approx_eq(lab.L, back.L));
        assert!(approx_eq(lab.a, back.a));
        assert!(approx_eq(lab.b, back.b));
    }

    #[test]
    fn test_oklab_srgb_roundtrip() {
        let linear = LinearRGB::new(0.5, 0.3, 0.2);
        let oklab = Oklab::from_linear_srgb(&linear);
        let back = oklab.to_linear_srgb();
        assert!(approx_eq(linear.r, back.r));
        assert!(approx_eq(linear.g, back.g));
        assert!(approx_eq(linear.b, back.b));
    }

    #[test]
    fn test_hsl_roundtrip() {
        let srgb = sRGB::new(0.8, 0.4, 0.2);
        let hsl = HSL::from_srgb(&srgb);
        let back = hsl.to_srgb();
        assert!(approx_eq(srgb.r, back.r));
        assert!(approx_eq(srgb.g, back.g));
        assert!(approx_eq(srgb.b, back.b));
    }

    #[test]
    fn test_hsv_roundtrip() {
        let srgb = sRGB::new(0.6, 0.2, 0.9);
        let hsv = HSV::from_srgb(&srgb);
        let back = hsv.to_srgb();
        assert!(approx_eq(srgb.r, back.r));
        assert!(approx_eq(srgb.g, back.g));
        assert!(approx_eq(srgb.b, back.b));
    }

    #[test]
    fn test_acescg_xyz_roundtrip() {
        let acescg = ACEScg::new(0.5, 0.4, 0.3);
        let xyz = acescg.to_xyz();
        let back = ACEScg::from_xyz(&xyz);
        assert!(approx_eq(acescg.r, back.r));
        assert!(approx_eq(acescg.g, back.g));
        assert!(approx_eq(acescg.b, back.b));
    }

    #[test]
    fn test_srgb_hex() {
        let srgb = sRGB::from_hex("#FF8040").unwrap();
        assert_eq!(srgb.to_hex(), "#FF8040");
    }

    #[test]
    fn test_white_points() {
        assert!(approx_eq(XYZ::D65.y, 1.0));
        assert!(approx_eq(XYZ::D50.y, 1.0));
    }

    #[test]
    fn test_matrix_inverse() {
        let m = matrices::SRGB_TO_XYZ;
        let inv = m.inverse().unwrap();
        let identity = m.multiply(&inv);

        for i in 0..3 {
            for j in 0..3 {
                let expected = if i == j { 1.0 } else { 0.0 };
                assert!((identity.m[i][j] - expected).abs() < 1e-10);
            }
        }
    }

    #[test]
    fn test_luv_xyz_roundtrip() {
        let xyz = XYZ::new(0.3, 0.4, 0.5);
        let luv = Luv::from_xyz(&xyz, &XYZ::D65);
        let back = luv.to_xyz(&XYZ::D65);
        assert!(approx_eq(xyz.x, back.x));
        assert!(approx_eq(xyz.y, back.y));
        assert!(approx_eq(xyz.z, back.z));
    }

    #[test]
    fn test_pq_roundtrip() {
        let v = 0.5;
        let encoded = pq_oetf(v);
        let decoded = pq_eotf(encoded);
        assert!(approx_eq(v, decoded));
    }

    #[test]
    fn test_hlg_roundtrip() {
        let v = 0.5;
        let encoded = hlg_oetf(v);
        let decoded = hlg_eotf(encoded);
        assert!(approx_eq(v, decoded));
    }
}
