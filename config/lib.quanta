// A/B TESTING CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// A/B testing experiment configuration
pub struct ExperimentManager {
    pub experiments: HashMap<String, Experiment>,
    pub assignment_store: Box<dyn ExperimentAssignmentStore + Send + Sync>,
    pub metrics_collector: ExperimentMetricsCollector,
    pub targeting_engine: ExperimentTargetingEngine,
}

#[derive(Debug, Clone)]
pub struct Experiment {
    pub id: String,
    pub name: String,
    pub description: String,
    pub hypothesis: String,
    pub status: ExperimentStatus,
    pub variants: Vec<ExperimentVariant>,
    pub targeting: ExperimentTargeting,
    pub metrics: Vec<ExperimentMetricDef>,
    pub start_time: Option<u64>,
    pub end_time: Option<u64>,
    pub created_at: u64,
    pub updated_at: u64,
    pub created_by: String,
    pub allocation_type: AllocationAlgorithm,
    pub sample_size: Option<u64>,
    pub minimum_detectable_effect: Option<f64>,
    pub significance_level: f64,
    pub power: f64,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ExperimentStatus {
    Draft,
    Scheduled,
    Running,
    Paused,
    Completed,
    Cancelled,
}

#[derive(Debug, Clone)]
pub struct ExperimentVariant {
    pub id: String,
    pub name: String,
    pub description: String,
    pub weight: f64,
    pub config_overrides: ConfigValue,
    pub is_control: bool,
}

#[derive(Debug, Clone)]
pub struct ExperimentTargeting {
    pub rules: Vec<TargetingRule>,
    pub exclusion_rules: Vec<TargetingRule>,
    pub mutual_exclusions: Vec<String>, // Other experiment IDs
    pub required_experiments: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct ExperimentMetricDef {
    pub name: String,
    pub metric_type: ExperimentMetricType,
    pub aggregation: MetricAggregation,
    pub is_primary: bool,
    pub minimum_sample_size: u64,
    pub expected_value: Option<f64>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ExperimentMetricType {
    Conversion,
    Count,
    Revenue,
    Duration,
    Rate,
    Custom,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum MetricAggregation {
    Sum,
    Average,
    Median,
    Percentile95,
    Percentile99,
    Min,
    Max,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum AllocationAlgorithm {
    /// Fixed weights
    Static,
    /// Multi-armed bandit
    Epsilon { epsilon: u32 }, // Stored as percentage
    /// Thompson Sampling
    ThompsonSampling,
    /// Upper Confidence Bound
    UCB,
    /// Contextual bandit
    Contextual,
}

pub trait ExperimentAssignmentStore {
    fn get_assignment(&self, user_id: &str, experiment_id: &str) -> Option<String>;
    fn set_assignment(&self, user_id: &str, experiment_id: &str, variant_id: &str);
    fn clear_assignment(&self, user_id: &str, experiment_id: &str);
}

/// In-memory assignment store
pub struct InMemoryAssignmentStore {
    assignments: HashMap<String, HashMap<String, String>>,
}

impl InMemoryAssignmentStore {
    pub fn new() -> Self {
        InMemoryAssignmentStore { assignments: HashMap::new() }
    }
}

impl ExperimentAssignmentStore for InMemoryAssignmentStore {
    fn get_assignment(&self, user_id: &str, experiment_id: &str) -> Option<String> {
        self.assignments.get(user_id)
            .and_then(|exp| exp.get(experiment_id))
            .cloned()
    }

    fn set_assignment(&self, _user_id: &str, _experiment_id: &str, _variant_id: &str) {
        // Would modify the store
    }

    fn clear_assignment(&self, _user_id: &str, _experiment_id: &str) {
        // Would clear the assignment
    }
}

/// Experiment metrics collector
pub struct ExperimentMetricsCollector {
    pub metrics: HashMap<String, ExperimentMetrics>,
}

#[derive(Debug, Clone)]
pub struct ExperimentMetrics {
    pub experiment_id: String,
    pub variant_metrics: HashMap<String, VariantMetrics>,
    pub collected_at: u64,
}

#[derive(Debug, Clone)]
pub struct VariantMetrics {
    pub variant_id: String,
    pub sample_size: u64,
    pub conversions: u64,
    pub conversion_rate: f64,
    pub revenue: f64,
    pub average_revenue: f64,
    pub events: HashMap<String, u64>,
    pub custom_metrics: HashMap<String, f64>,
}

impl ExperimentMetricsCollector {
    pub fn new() -> Self {
        ExperimentMetricsCollector { metrics: HashMap::new() }
    }

    pub fn record_event(&mut self, experiment_id: &str, variant_id: &str, event_name: &str, value: f64) {
        let metrics = self.metrics
            .entry(experiment_id.to_string())
            .or_insert_with(|| ExperimentMetrics {
                experiment_id: experiment_id.to_string(),
                variant_metrics: HashMap::new(),
                collected_at: 0,
            });

        let variant_metrics = metrics.variant_metrics
            .entry(variant_id.to_string())
            .or_insert_with(|| VariantMetrics {
                variant_id: variant_id.to_string(),
                sample_size: 0,
                conversions: 0,
                conversion_rate: 0.0,
                revenue: 0.0,
                average_revenue: 0.0,
                events: HashMap::new(),
                custom_metrics: HashMap::new(),
            });

        *variant_metrics.events.entry(event_name.to_string()).or_insert(0) += 1;
        *variant_metrics.custom_metrics.entry(event_name.to_string()).or_insert(0.0) += value;
    }

    pub fn record_conversion(&mut self, experiment_id: &str, variant_id: &str, revenue: f64) {
        let metrics = self.metrics
            .entry(experiment_id.to_string())
            .or_insert_with(|| ExperimentMetrics {
                experiment_id: experiment_id.to_string(),
                variant_metrics: HashMap::new(),
                collected_at: 0,
            });

        let variant_metrics = metrics.variant_metrics
            .entry(variant_id.to_string())
            .or_insert_with(|| VariantMetrics {
                variant_id: variant_id.to_string(),
                sample_size: 0,
                conversions: 0,
                conversion_rate: 0.0,
                revenue: 0.0,
                average_revenue: 0.0,
                events: HashMap::new(),
                custom_metrics: HashMap::new(),
            });

        variant_metrics.conversions += 1;
        variant_metrics.revenue += revenue;
        if variant_metrics.conversions > 0 {
            variant_metrics.average_revenue = variant_metrics.revenue / variant_metrics.conversions as f64;
        }
    }
}

/// Experiment targeting engine
pub struct ExperimentTargetingEngine {
    pub hash_seed: u64,
}

impl ExperimentTargetingEngine {
    pub fn new() -> Self {
        ExperimentTargetingEngine { hash_seed: 42 }
    }

    pub fn assign_variant<'a>(&self, experiment: &'a Experiment, user_id: &str) -> Option<&'a ExperimentVariant> {
        if experiment.status != ExperimentStatus::Running {
            return None;
        }

        if experiment.variants.is_empty() {
            return None;
        }

        let hash = self.hash_user_experiment(user_id, &experiment.id);
        let bucket = (hash % 10000) as f64 / 10000.0;

        let mut cumulative = 0.0;
        for variant in &experiment.variants {
            cumulative += variant.weight;
            if bucket < cumulative {
                return Some(variant);
            }
        }

        experiment.variants.last()
    }

    fn hash_user_experiment(&self, user_id: &str, experiment_id: &str) -> u64 {
        let mut hash = self.hash_seed;
        for byte in user_id.bytes() {
            hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
        }
        for byte in experiment_id.bytes() {
            hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
        }
        hash
    }
}

impl ExperimentManager {
    pub fn new() -> Self {
        ExperimentManager {
            experiments: HashMap::new(),
            assignment_store: Box::new(InMemoryAssignmentStore::new()),
            metrics_collector: ExperimentMetricsCollector::new(),
            targeting_engine: ExperimentTargetingEngine::new(),
        }
    }

    pub fn create_experiment(&mut self, experiment: Experiment) {
        self.experiments.insert(experiment.id.clone(), experiment);
    }

    pub fn get_variant(&self, experiment_id: &str, user_id: &str) -> Option<&ExperimentVariant> {
        // Check for existing assignment
        if let Some(variant_id) = self.assignment_store.get_assignment(user_id, experiment_id) {
            if let Some(experiment) = self.experiments.get(experiment_id) {
                return experiment.variants.iter().find(|v| v.id == variant_id);
            }
        }

        // Assign new variant
        if let Some(experiment) = self.experiments.get(experiment_id) {
            return self.targeting_engine.assign_variant(experiment, user_id);
        }

        None
    }

    pub fn get_config_for_user(&self, user_id: &str, base_config: &ConfigValue) -> ConfigValue {
        let mut config = base_config.clone();

        for experiment in self.experiments.values() {
            if experiment.status != ExperimentStatus::Running {
                continue;
            }

            if let Some(variant) = self.get_variant(&experiment.id, user_id) {
                config = config.merge(&variant.config_overrides);
            }
        }

        config
    }

    pub fn analyze_experiment(&self, experiment_id: &str) -> Option<ExperimentAnalysis> {
        let experiment = self.experiments.get(experiment_id)?;
        let metrics = self.metrics_collector.metrics.get(experiment_id)?;

        let control_variant = experiment.variants.iter().find(|v| v.is_control)?;
        let control_metrics = metrics.variant_metrics.get(&control_variant.id)?;

        let mut variant_results = Vec::new();

        for variant in &experiment.variants {
            if variant.is_control { continue; }

            if let Some(variant_metrics) = metrics.variant_metrics.get(&variant.id) {
                let result = self.compute_variant_result(control_metrics, variant_metrics, experiment.significance_level);
                variant_results.push(result);
            }
        }

        Some(ExperimentAnalysis {
            experiment_id: experiment_id.to_string(),
            status: experiment.status,
            control_variant_id: control_variant.id.clone(),
            control_sample_size: control_metrics.sample_size,
            control_conversion_rate: control_metrics.conversion_rate,
            variant_results,
            recommendation: self.compute_recommendation(&variant_results),
            analyzed_at: 0,
        })
    }

    fn compute_variant_result(&self, control: &VariantMetrics, treatment: &VariantMetrics, significance_level: f64) -> VariantResult {
        let lift = if control.conversion_rate > 0.0 {
            (treatment.conversion_rate - control.conversion_rate) / control.conversion_rate
        } else {
            0.0
        };

        // Simplified z-test
        let pooled_rate = (control.conversions + treatment.conversions) as f64
            / (control.sample_size + treatment.sample_size) as f64;
        let se = (pooled_rate * (1.0 - pooled_rate)
            * (1.0 / control.sample_size as f64 + 1.0 / treatment.sample_size as f64)).sqrt();
        let z_score = if se > 0.0 {
            (treatment.conversion_rate - control.conversion_rate) / se
        } else {
            0.0
        };

        // Two-tailed p-value approximation
        let p_value = 2.0 * (1.0 - self.normal_cdf(z_score.abs()));
        let significant = p_value < significance_level;

        VariantResult {
            variant_id: treatment.variant_id.clone(),
            sample_size: treatment.sample_size,
            conversion_rate: treatment.conversion_rate,
            lift,
            lift_confidence_interval: (lift - 1.96 * se, lift + 1.96 * se),
            p_value,
            significant,
            z_score,
        }
    }

    fn normal_cdf(&self, x: f64) -> f64 {
        // Approximation of normal CDF
        let t = 1.0 / (1.0 + 0.2316419 * x.abs());
        let d = 0.3989423 * (-x * x / 2.0).exp();
        let p = d * t * (0.3193815 + t * (-0.3565638 + t * (1.781478 + t * (-1.821256 + t * 1.330274))));
        if x > 0.0 { 1.0 - p } else { p }
    }

    fn compute_recommendation(&self, results: &[VariantResult]) -> ExperimentRecommendation {
        if results.is_empty() {
            return ExperimentRecommendation::InsufficientData;
        }

        let best = results.iter()
            .filter(|r| r.significant && r.lift > 0.0)
            .max_by(|a, b| a.lift.partial_cmp(&b.lift).unwrap_or(std::cmp::Ordering::Equal));

        if let Some(winner) = best {
            ExperimentRecommendation::RolloutVariant { variant_id: winner.variant_id.clone() }
        } else if results.iter().any(|r| r.significant && r.lift < 0.0) {
            ExperimentRecommendation::StopExperiment
        } else {
            ExperimentRecommendation::ContinueExperiment
        }
    }
}

#[derive(Debug, Clone)]
pub struct ExperimentAnalysis {
    pub experiment_id: String,
    pub status: ExperimentStatus,
    pub control_variant_id: String,
    pub control_sample_size: u64,
    pub control_conversion_rate: f64,
    pub variant_results: Vec<VariantResult>,
    pub recommendation: ExperimentRecommendation,
    pub analyzed_at: u64,
}

#[derive(Debug, Clone)]
pub struct VariantResult {
    pub variant_id: String,
    pub sample_size: u64,
    pub conversion_rate: f64,
    pub lift: f64,
    pub lift_confidence_interval: (f64, f64),
    pub p_value: f64,
    pub significant: bool,
    pub z_score: f64,
}

#[derive(Debug, Clone)]
pub enum ExperimentRecommendation {
    ContinueExperiment,
    RolloutVariant { variant_id: String },
    StopExperiment,
    InsufficientData,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION VALIDATION RULES ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Advanced validation rules engine
pub struct ValidationRulesEngine {
    pub rules: Vec<ValidationRule>,
    pub custom_validators: HashMap<String, Box<dyn CustomValidator + Send + Sync>>,
    pub cross_field_rules: Vec<CrossFieldRule>,
    pub semantic_rules: Vec<SemanticRule>,
}

#[derive(Debug, Clone)]
pub struct ValidationRule {
    pub name: String,
    pub path: String,
    pub rule_type: ValidationRuleType,
    pub severity: ValidationSeverity,
    pub message: String,
    pub enabled: bool,
}

#[derive(Debug, Clone)]
pub enum ValidationRuleType {
    Required,
    Type { expected: ExpectedType },
    Range { min: Option<f64>, max: Option<f64> },
    Length { min: Option<usize>, max: Option<usize> },
    Pattern { regex: String },
    Enum { values: Vec<String> },
    Email,
    Url,
    Ip,
    Uuid,
    Date { format: String },
    Custom { validator: String },
    Dependency { depends_on: String, condition: DependencyCondition },
    Unique { scope: String },
}

#[derive(Debug, Clone)]
pub enum ExpectedType {
    String,
    Integer,
    Float,
    Boolean,
    Array,
    Object,
    Null,
}

#[derive(Debug, Clone)]
pub enum DependencyCondition {
    Present,
    Equals { value: ConfigValue },
    NotEquals { value: ConfigValue },
    GreaterThan { value: f64 },
    LessThan { value: f64 },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ValidationSeverity {
    Error,
    Warning,
    Info,
}

/// Cross-field validation rule
#[derive(Debug, Clone)]
pub struct CrossFieldRule {
    pub name: String,
    pub fields: Vec<String>,
    pub rule: CrossFieldRuleType,
    pub message: String,
}

#[derive(Debug, Clone)]
pub enum CrossFieldRuleType {
    MutuallyExclusive,
    RequiredTogether,
    ConditionalRequired { condition_field: String, condition: DependencyCondition },
    SumEquals { target: f64 },
    SumLessThan { target: f64 },
    AllOrNone,
    AtLeastOne,
    AtMostOne,
    Custom { validator: String },
}

/// Semantic validation rule
#[derive(Debug, Clone)]
pub struct SemanticRule {
    pub name: String,
    pub description: String,
    pub rule: SemanticRuleType,
    pub message: String,
}

#[derive(Debug, Clone)]
pub enum SemanticRuleType {
    /// Port must not be in use
    PortAvailable { path: String },
    /// Path must exist
    PathExists { path: String },
    /// File must be readable
    FileReadable { path: String },
    /// Directory must be writable
    DirectoryWritable { path: String },
    /// URL must be reachable
    UrlReachable { path: String, timeout_ms: u64 },
    /// DNS must resolve
    DnsResolvable { path: String },
    /// SSL certificate valid
    SslValid { path: String },
    /// Database connectable
    DatabaseConnectable { connection_string_path: String },
    /// Custom semantic check
    Custom { validator: String },
}

pub trait CustomValidator {
    fn validate(&self, value: &ConfigValue, context: &ValidationContext) -> ValidationResult;
}

#[derive(Debug, Clone)]
pub struct ValidationContext {
    pub config: ConfigValue,
    pub environment: String,
    pub metadata: HashMap<String, String>,
}

#[derive(Debug, Clone)]
pub struct ValidationResult {
    pub valid: bool,
    pub errors: Vec<ValidationIssue>,
    pub warnings: Vec<ValidationIssue>,
    pub infos: Vec<ValidationIssue>,
}

#[derive(Debug, Clone)]
pub struct ValidationIssue {
    pub path: String,
    pub rule: String,
    pub message: String,
    pub severity: ValidationSeverity,
    pub suggested_fix: Option<String>,
}

impl ValidationRulesEngine {
    pub fn new() -> Self {
        ValidationRulesEngine {
            rules: Vec::new(),
            custom_validators: HashMap::new(),
            cross_field_rules: Vec::new(),
            semantic_rules: Vec::new(),
        }
    }

    pub fn add_rule(&mut self, rule: ValidationRule) {
        self.rules.push(rule);
    }

    pub fn add_cross_field_rule(&mut self, rule: CrossFieldRule) {
        self.cross_field_rules.push(rule);
    }

    pub fn add_semantic_rule(&mut self, rule: SemanticRule) {
        self.semantic_rules.push(rule);
    }

    pub fn register_validator<V: CustomValidator + Send + Sync + 'static>(&mut self, name: &str, validator: V) {
        self.custom_validators.insert(name.to_string(), Box::new(validator));
    }

    pub fn validate(&self, config: &ConfigValue, context: &ValidationContext) -> ValidationResult {
        let mut result = ValidationResult {
            valid: true,
            errors: Vec::new(),
            warnings: Vec::new(),
            infos: Vec::new(),
        };

        // Validate individual rules
        for rule in &self.rules {
            if !rule.enabled { continue; }

            if let Some(issue) = self.validate_rule(rule, config, context) {
                match issue.severity {
                    ValidationSeverity::Error => {
                        result.valid = false;
                        result.errors.push(issue);
                    }
                    ValidationSeverity::Warning => result.warnings.push(issue),
                    ValidationSeverity::Info => result.infos.push(issue),
                }
            }
        }

        // Validate cross-field rules
        for rule in &self.cross_field_rules {
            if let Some(issue) = self.validate_cross_field(rule, config) {
                result.valid = false;
                result.errors.push(issue);
            }
        }

        // Semantic validation (would perform actual checks)
        for rule in &self.semantic_rules {
            if let Some(issue) = self.validate_semantic(rule, config) {
                result.valid = false;
                result.errors.push(issue);
            }
        }

        result
    }

    fn validate_rule(&self, rule: &ValidationRule, config: &ConfigValue, context: &ValidationContext) -> Option<ValidationIssue> {
        let value = config.get_path(&rule.path);

        match &rule.rule_type {
            ValidationRuleType::Required => {
                if value.is_none() || matches!(value, Some(ConfigValue::Null)) {
                    return Some(ValidationIssue {
                        path: rule.path.clone(),
                        rule: rule.name.clone(),
                        message: rule.message.clone(),
                        severity: rule.severity,
                        suggested_fix: Some(format!("Add required field '{}'", rule.path)),
                    });
                }
            }
            ValidationRuleType::Type { expected } => {
                if let Some(val) = value {
                    let type_matches = match (expected, val) {
                        (ExpectedType::String, ConfigValue::String(_)) => true,
                        (ExpectedType::Integer, ConfigValue::Int(_)) => true,
                        (ExpectedType::Float, ConfigValue::Float(_)) => true,
                        (ExpectedType::Boolean, ConfigValue::Bool(_)) => true,
                        (ExpectedType::Array, ConfigValue::Array(_)) => true,
                        (ExpectedType::Object, ConfigValue::Object(_)) => true,
                        (ExpectedType::Null, ConfigValue::Null) => true,
                        _ => false,
                    };
                    if !type_matches {
                        return Some(ValidationIssue {
                            path: rule.path.clone(),
                            rule: rule.name.clone(),
                            message: rule.message.clone(),
                            severity: rule.severity,
                            suggested_fix: Some(format!("Expected type {:?}", expected)),
                        });
                    }
                }
            }
            ValidationRuleType::Range { min, max } => {
                if let Some(val) = value {
                    let num = match val {
                        ConfigValue::Int(i) => Some(*i as f64),
                        ConfigValue::Float(f) => Some(*f),
                        _ => None,
                    };
                    if let Some(n) = num {
                        if let Some(min_val) = min {
                            if n < *min_val {
                                return Some(ValidationIssue {
                                    path: rule.path.clone(),
                                    rule: rule.name.clone(),
                                    message: rule.message.clone(),
                                    severity: rule.severity,
                                    suggested_fix: Some(format!("Value must be >= {}", min_val)),
                                });
                            }
                        }
                        if let Some(max_val) = max {
                            if n > *max_val {
                                return Some(ValidationIssue {
                                    path: rule.path.clone(),
                                    rule: rule.name.clone(),
                                    message: rule.message.clone(),
                                    severity: rule.severity,
                                    suggested_fix: Some(format!("Value must be <= {}", max_val)),
                                });
                            }
                        }
                    }
                }
            }
            ValidationRuleType::Length { min, max } => {
                if let Some(ConfigValue::String(s)) = value {
                    if let Some(min_len) = min {
                        if s.len() < *min_len {
                            return Some(ValidationIssue {
                                path: rule.path.clone(),
                                rule: rule.name.clone(),
                                message: rule.message.clone(),
                                severity: rule.severity,
                                suggested_fix: Some(format!("Length must be >= {}", min_len)),
                            });
                        }
                    }
                    if let Some(max_len) = max {
                        if s.len() > *max_len {
                            return Some(ValidationIssue {
                                path: rule.path.clone(),
                                rule: rule.name.clone(),
                                message: rule.message.clone(),
                                severity: rule.severity,
                                suggested_fix: Some(format!("Length must be <= {}", max_len)),
                            });
                        }
                    }
                }
            }
            ValidationRuleType::Enum { values } => {
                if let Some(ConfigValue::String(s)) = value {
                    if !values.contains(s) {
                        return Some(ValidationIssue {
                            path: rule.path.clone(),
                            rule: rule.name.clone(),
                            message: rule.message.clone(),
                            severity: rule.severity,
                            suggested_fix: Some(format!("Must be one of: {:?}", values)),
                        });
                    }
                }
            }
            ValidationRuleType::Email => {
                if let Some(ConfigValue::String(s)) = value {
                    if !s.contains('@') || !s.contains('.') {
                        return Some(ValidationIssue {
                            path: rule.path.clone(),
                            rule: rule.name.clone(),
                            message: "Invalid email format".to_string(),
                            severity: rule.severity,
                            suggested_fix: Some("Provide a valid email address".to_string()),
                        });
                    }
                }
            }
            ValidationRuleType::Url => {
                if let Some(ConfigValue::String(s)) = value {
                    if !s.starts_with("http://") && !s.starts_with("https://") {
                        return Some(ValidationIssue {
                            path: rule.path.clone(),
                            rule: rule.name.clone(),
                            message: "Invalid URL format".to_string(),
                            severity: rule.severity,
                            suggested_fix: Some("URL must start with http:// or https://".to_string()),
                        });
                    }
                }
            }
            ValidationRuleType::Custom { validator } => {
                if let Some(custom_validator) = self.custom_validators.get(validator) {
                    if let Some(val) = value {
                        let custom_result = custom_validator.validate(val, context);
                        if !custom_result.valid && !custom_result.errors.is_empty() {
                            return custom_result.errors.into_iter().next();
                        }
                    }
                }
            }
            _ => {}
        }

        None
    }

    fn validate_cross_field(&self, rule: &CrossFieldRule, config: &ConfigValue) -> Option<ValidationIssue> {
        let values: Vec<Option<&ConfigValue>> = rule.fields.iter()
            .map(|f| config.get_path(f))
            .collect();

        match &rule.rule {
            CrossFieldRuleType::MutuallyExclusive => {
                let present_count = values.iter().filter(|v| v.is_some()).count();
                if present_count > 1 {
                    return Some(ValidationIssue {
                        path: rule.fields.join(", "),
                        rule: rule.name.clone(),
                        message: rule.message.clone(),
                        severity: ValidationSeverity::Error,
                        suggested_fix: Some("Only one of these fields can be present".to_string()),
                    });
                }
            }
            CrossFieldRuleType::RequiredTogether => {
                let present_count = values.iter().filter(|v| v.is_some()).count();
                if present_count > 0 && present_count < values.len() {
                    return Some(ValidationIssue {
                        path: rule.fields.join(", "),
                        rule: rule.name.clone(),
                        message: rule.message.clone(),
                        severity: ValidationSeverity::Error,
                        suggested_fix: Some("All these fields must be present together".to_string()),
                    });
                }
            }
            CrossFieldRuleType::AtLeastOne => {
                let present_count = values.iter().filter(|v| v.is_some()).count();
                if present_count == 0 {
                    return Some(ValidationIssue {
                        path: rule.fields.join(", "),
                        rule: rule.name.clone(),
                        message: rule.message.clone(),
                        severity: ValidationSeverity::Error,
                        suggested_fix: Some("At least one of these fields must be present".to_string()),
                    });
                }
            }
            CrossFieldRuleType::AtMostOne => {
                let present_count = values.iter().filter(|v| v.is_some()).count();
                if present_count > 1 {
                    return Some(ValidationIssue {
                        path: rule.fields.join(", "),
                        rule: rule.name.clone(),
                        message: rule.message.clone(),
                        severity: ValidationSeverity::Error,
                        suggested_fix: Some("At most one of these fields can be present".to_string()),
                    });
                }
            }
            CrossFieldRuleType::SumEquals { target } => {
                let sum: f64 = values.iter()
                    .filter_map(|v| v.and_then(|cv| cv.as_float()))
                    .sum();
                if (sum - target).abs() > f64::EPSILON {
                    return Some(ValidationIssue {
                        path: rule.fields.join(", "),
                        rule: rule.name.clone(),
                        message: rule.message.clone(),
                        severity: ValidationSeverity::Error,
                        suggested_fix: Some(format!("Sum must equal {}", target)),
                    });
                }
            }
            _ => {}
        }

        None
    }

    fn validate_semantic(&self, rule: &SemanticRule, _config: &ConfigValue) -> Option<ValidationIssue> {
        // Semantic validation would perform actual system checks
        // For now, return None (all checks pass)
        match &rule.rule {
            SemanticRuleType::PathExists { path: _ } => {
                // Would check if path exists
            }
            SemanticRuleType::PortAvailable { path: _ } => {
                // Would check if port is available
            }
            _ => {}
        }
        None
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DYNAMIC CONFIGURATION BINDINGS
// ═══════════════════════════════════════════════════════════════════════════════

/// Type-safe configuration bindings
pub struct ConfigBindings {
    pub bindings: HashMap<String, ConfigBinding>,
    pub change_listeners: HashMap<String, Vec<Box<dyn Fn(&ConfigValue) + Send + Sync>>>,
}

#[derive(Debug, Clone)]
pub struct ConfigBinding {
    pub path: String,
    pub value_type: BindingType,
    pub default: Option<ConfigValue>,
    pub transform: Option<TransformType>,
    pub cached_value: Option<ConfigValue>,
    pub last_updated: u64,
}

#[derive(Debug, Clone)]
pub enum BindingType {
    String,
    Int,
    Float,
    Bool,
    StringArray,
    IntArray,
    Duration { unit: DurationUnit },
    ByteSize { unit: ByteSizeUnit },
    Custom { parser: String },
}

#[derive(Debug, Clone, Copy)]
pub enum DurationUnit {
    Nanoseconds,
    Microseconds,
    Milliseconds,
    Seconds,
    Minutes,
    Hours,
    Days,
}

#[derive(Debug, Clone, Copy)]
pub enum ByteSizeUnit {
    Bytes,
    Kilobytes,
    Megabytes,
    Gigabytes,
    Terabytes,
}

#[derive(Debug, Clone)]
pub enum TransformType {
    Uppercase,
    Lowercase,
    Trim,
    ParseInt,
    ParseFloat,
    ParseDuration,
    ParseByteSize,
    Split { delimiter: String },
    Join { delimiter: String },
    Replace { from: String, to: String },
    Template { template: String },
    Custom { transformer: String },
}

impl ConfigBindings {
    pub fn new() -> Self {
        ConfigBindings {
            bindings: HashMap::new(),
            change_listeners: HashMap::new(),
        }
    }

    pub fn bind(&mut self, name: &str, binding: ConfigBinding) {
        self.bindings.insert(name.to_string(), binding);
    }

    pub fn get_string(&self, name: &str, config: &ConfigValue) -> Option<String> {
        let binding = self.bindings.get(name)?;
        let value = config.get_path(&binding.path)?;

        match value {
            ConfigValue::String(s) => Some(self.apply_string_transform(s, &binding.transform)),
            ConfigValue::Int(i) => Some(i.to_string()),
            ConfigValue::Float(f) => Some(f.to_string()),
            ConfigValue::Bool(b) => Some(b.to_string()),
            _ => None,
        }
    }

    pub fn get_int(&self, name: &str, config: &ConfigValue) -> Option<i64> {
        let binding = self.bindings.get(name)?;
        let value = config.get_path(&binding.path)?;

        match value {
            ConfigValue::Int(i) => Some(*i),
            ConfigValue::Float(f) => Some(*f as i64),
            ConfigValue::String(s) => s.parse().ok(),
            _ => None,
        }
    }

    pub fn get_float(&self, name: &str, config: &ConfigValue) -> Option<f64> {
        let binding = self.bindings.get(name)?;
        let value = config.get_path(&binding.path)?;

        match value {
            ConfigValue::Float(f) => Some(*f),
            ConfigValue::Int(i) => Some(*i as f64),
            ConfigValue::String(s) => s.parse().ok(),
            _ => None,
        }
    }

    pub fn get_bool(&self, name: &str, config: &ConfigValue) -> Option<bool> {
        let binding = self.bindings.get(name)?;
        let value = config.get_path(&binding.path)?;

        match value {
            ConfigValue::Bool(b) => Some(*b),
            ConfigValue::String(s) => match s.to_lowercase().as_str() {
                "true" | "yes" | "1" | "on" => Some(true),
                "false" | "no" | "0" | "off" => Some(false),
                _ => None,
            },
            ConfigValue::Int(i) => Some(*i != 0),
            _ => None,
        }
    }

    pub fn get_duration_ms(&self, name: &str, config: &ConfigValue) -> Option<u64> {
        let binding = self.bindings.get(name)?;
        let value = config.get_path(&binding.path)?;

        match value {
            ConfigValue::Int(i) => {
                if let BindingType::Duration { unit } = &binding.value_type {
                    Some(self.convert_to_ms(*i as u64, *unit))
                } else {
                    Some(*i as u64)
                }
            }
            ConfigValue::String(s) => self.parse_duration(s),
            _ => None,
        }
    }

    pub fn get_bytes(&self, name: &str, config: &ConfigValue) -> Option<u64> {
        let binding = self.bindings.get(name)?;
        let value = config.get_path(&binding.path)?;

        match value {
            ConfigValue::Int(i) => {
                if let BindingType::ByteSize { unit } = &binding.value_type {
                    Some(self.convert_to_bytes(*i as u64, *unit))
                } else {
                    Some(*i as u64)
                }
            }
            ConfigValue::String(s) => self.parse_byte_size(s),
            _ => None,
        }
    }

    fn apply_string_transform(&self, value: &str, transform: &Option<TransformType>) -> String {
        match transform {
            Some(TransformType::Uppercase) => value.to_uppercase(),
            Some(TransformType::Lowercase) => value.to_lowercase(),
            Some(TransformType::Trim) => value.trim().to_string(),
            Some(TransformType::Replace { from, to }) => value.replace(from, to),
            _ => value.to_string(),
        }
    }

    fn convert_to_ms(&self, value: u64, unit: DurationUnit) -> u64 {
        match unit {
            DurationUnit::Nanoseconds => value / 1_000_000,
            DurationUnit::Microseconds => value / 1_000,
            DurationUnit::Milliseconds => value,
            DurationUnit::Seconds => value * 1_000,
            DurationUnit::Minutes => value * 60_000,
            DurationUnit::Hours => value * 3_600_000,
            DurationUnit::Days => value * 86_400_000,
        }
    }

    fn convert_to_bytes(&self, value: u64, unit: ByteSizeUnit) -> u64 {
        match unit {
            ByteSizeUnit::Bytes => value,
            ByteSizeUnit::Kilobytes => value * 1_024,
            ByteSizeUnit::Megabytes => value * 1_024 * 1_024,
            ByteSizeUnit::Gigabytes => value * 1_024 * 1_024 * 1_024,
            ByteSizeUnit::Terabytes => value * 1_024 * 1_024 * 1_024 * 1_024,
        }
    }

    fn parse_duration(&self, s: &str) -> Option<u64> {
        let s = s.trim().to_lowercase();

        // Parse patterns like "10s", "5m", "1h", "100ms"
        if s.ends_with("ms") {
            s[..s.len()-2].parse::<u64>().ok()
        } else if s.ends_with("s") {
            s[..s.len()-1].parse::<u64>().ok().map(|v| v * 1000)
        } else if s.ends_with("m") {
            s[..s.len()-1].parse::<u64>().ok().map(|v| v * 60_000)
        } else if s.ends_with("h") {
            s[..s.len()-1].parse::<u64>().ok().map(|v| v * 3_600_000)
        } else if s.ends_with("d") {
            s[..s.len()-1].parse::<u64>().ok().map(|v| v * 86_400_000)
        } else {
            s.parse().ok()
        }
    }

    fn parse_byte_size(&self, s: &str) -> Option<u64> {
        let s = s.trim().to_uppercase();

        // Parse patterns like "1GB", "512MB", "1024KB"
        if s.ends_with("TB") {
            s[..s.len()-2].parse::<u64>().ok().map(|v| v * 1024 * 1024 * 1024 * 1024)
        } else if s.ends_with("GB") {
            s[..s.len()-2].parse::<u64>().ok().map(|v| v * 1024 * 1024 * 1024)
        } else if s.ends_with("MB") {
            s[..s.len()-2].parse::<u64>().ok().map(|v| v * 1024 * 1024)
        } else if s.ends_with("KB") {
            s[..s.len()-2].parse::<u64>().ok().map(|v| v * 1024)
        } else if s.ends_with("B") {
            s[..s.len()-1].parse().ok()
        } else {
            s.parse().ok()
        }
    }

    pub fn on_change<F>(&mut self, name: &str, callback: F)
    where
        F: Fn(&ConfigValue) + Send + Sync + 'static
    {
        self.change_listeners
            .entry(name.to_string())
            .or_insert_with(Vec::new)
            .push(Box::new(callback));
    }

    pub fn notify_change(&self, name: &str, value: &ConfigValue) {
        if let Some(listeners) = self.change_listeners.get(name) {
            for listener in listeners {
                listener(value);
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION AUDIT TRAIL
// ═══════════════════════════════════════════════════════════════════════════════

/// Comprehensive audit trail for configuration changes
pub struct ConfigAuditTrail {
    pub entries: Vec<AuditTrailEntry>,
    pub storage: Box<dyn AuditStorage + Send + Sync>,
    pub max_entries: usize,
    pub retention_days: u32,
    pub encryption_enabled: bool,
    pub signing_enabled: bool,
}

#[derive(Debug, Clone)]
pub struct AuditTrailEntry {
    pub id: String,
    pub timestamp: u64,
    pub action: AuditTrailAction,
    pub path: String,
    pub old_value: Option<ConfigValue>,
    pub new_value: Option<ConfigValue>,
    pub actor: AuditActor,
    pub source: AuditSource,
    pub metadata: AuditMetadata,
    pub signature: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum AuditTrailAction {
    Create,
    Read,
    Update,
    Delete,
    Reload,
    Migrate,
    Validate,
    Export,
    Import,
    Rollback,
    Approve,
    Reject,
}

#[derive(Debug, Clone)]
pub struct AuditActor {
    pub actor_type: ActorType,
    pub id: String,
    pub name: Option<String>,
    pub email: Option<String>,
    pub roles: Vec<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ActorType {
    User,
    Service,
    System,
    Automation,
    Api,
}

#[derive(Debug, Clone)]
pub struct AuditSource {
    pub source_type: SourceType,
    pub ip_address: Option<String>,
    pub user_agent: Option<String>,
    pub request_id: Option<String>,
    pub session_id: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SourceType {
    Web,
    Cli,
    Api,
    Sdk,
    Internal,
    Webhook,
}

#[derive(Debug, Clone)]
pub struct AuditMetadata {
    pub environment: String,
    pub version: String,
    pub correlation_id: Option<String>,
    pub parent_action_id: Option<String>,
    pub tags: HashMap<String, String>,
    pub custom_fields: HashMap<String, String>,
}

pub trait AuditStorage {
    fn store(&self, entry: &AuditTrailEntry) -> Result<(), ConfigError>;
    fn query(&self, query: &AuditQuery) -> Result<Vec<AuditTrailEntry>, ConfigError>;
    fn count(&self, query: &AuditQuery) -> Result<u64, ConfigError>;
    fn delete_before(&self, timestamp: u64) -> Result<u64, ConfigError>;
}

#[derive(Debug, Clone)]
pub struct AuditQuery {
    pub start_time: Option<u64>,
    pub end_time: Option<u64>,
    pub actions: Vec<AuditTrailAction>,
    pub paths: Vec<String>,
    pub actors: Vec<String>,
    pub sources: Vec<SourceType>,
    pub limit: usize,
    pub offset: usize,
    pub order: AuditQueryOrder,
}

#[derive(Debug, Clone, Copy)]
pub enum AuditQueryOrder {
    TimestampAsc,
    TimestampDesc,
}

/// In-memory audit storage
pub struct InMemoryAuditStorage {
    entries: Vec<AuditTrailEntry>,
}

impl InMemoryAuditStorage {
    pub fn new() -> Self {
        InMemoryAuditStorage { entries: Vec::new() }
    }
}

impl AuditStorage for InMemoryAuditStorage {
    fn store(&self, _entry: &AuditTrailEntry) -> Result<(), ConfigError> {
        // Would store in memory
        Ok(())
    }

    fn query(&self, query: &AuditQuery) -> Result<Vec<AuditTrailEntry>, ConfigError> {
        let mut results: Vec<AuditTrailEntry> = self.entries.iter()
            .filter(|e| {
                if let Some(start) = query.start_time {
                    if e.timestamp < start { return false; }
                }
                if let Some(end) = query.end_time {
                    if e.timestamp > end { return false; }
                }
                if !query.actions.is_empty() && !query.actions.contains(&e.action) {
                    return false;
                }
                if !query.paths.is_empty() && !query.paths.iter().any(|p| e.path.starts_with(p)) {
                    return false;
                }
                true
            })
            .cloned()
            .collect();

        match query.order {
            AuditQueryOrder::TimestampAsc => results.sort_by_key(|e| e.timestamp),
            AuditQueryOrder::TimestampDesc => results.sort_by_key(|e| std::cmp::Reverse(e.timestamp)),
        }

        Ok(results.into_iter().skip(query.offset).take(query.limit).collect())
    }

    fn count(&self, _query: &AuditQuery) -> Result<u64, ConfigError> {
        Ok(self.entries.len() as u64)
    }

    fn delete_before(&self, _timestamp: u64) -> Result<u64, ConfigError> {
        Ok(0)
    }
}

impl ConfigAuditTrail {
    pub fn new() -> Self {
        ConfigAuditTrail {
            entries: Vec::new(),
            storage: Box::new(InMemoryAuditStorage::new()),
            max_entries: 1_000_000,
            retention_days: 365,
            encryption_enabled: false,
            signing_enabled: false,
        }
    }

    pub fn record(&mut self, entry: AuditTrailEntry) -> Result<(), ConfigError> {
        // Sign entry if enabled
        let entry = if self.signing_enabled {
            let mut signed = entry.clone();
            signed.signature = Some(self.sign_entry(&entry));
            signed
        } else {
            entry
        };

        // Store in storage backend
        self.storage.store(&entry)?;

        // Keep in memory cache
        self.entries.push(entry);
        if self.entries.len() > self.max_entries {
            self.entries.remove(0);
        }

        Ok(())
    }

    pub fn query(&self, query: &AuditQuery) -> Result<Vec<AuditTrailEntry>, ConfigError> {
        self.storage.query(query)
    }

    pub fn get_changes_for_path(&self, path: &str, limit: usize) -> Vec<&AuditTrailEntry> {
        self.entries.iter()
            .filter(|e| e.path == path || e.path.starts_with(&format!("{}.", path)))
            .filter(|e| matches!(e.action, AuditTrailAction::Create | AuditTrailAction::Update | AuditTrailAction::Delete))
            .rev()
            .take(limit)
            .collect()
    }

    pub fn get_actor_activity(&self, actor_id: &str, limit: usize) -> Vec<&AuditTrailEntry> {
        self.entries.iter()
            .filter(|e| e.actor.id == actor_id)
            .rev()
            .take(limit)
            .collect()
    }

    fn sign_entry(&self, entry: &AuditTrailEntry) -> String {
        // Simple hash signature for demonstration
        let mut hash: u64 = 0;
        hash = hash.wrapping_mul(31).wrapping_add(entry.timestamp);
        for byte in entry.path.bytes() {
            hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
        }
        for byte in entry.actor.id.bytes() {
            hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
        }
        format!("{:016x}", hash)
    }

    pub fn verify_entry(&self, entry: &AuditTrailEntry) -> bool {
        if let Some(ref sig) = entry.signature {
            let expected = self.sign_entry(entry);
            sig == &expected
        } else {
            !self.signing_enabled
        }
    }

    pub fn export_report(&self, query: &AuditQuery) -> Result<AuditReport, ConfigError> {
        let entries = self.query(query)?;
        let total = self.storage.count(query)?;

        let mut action_counts = HashMap::new();
        let mut actor_counts = HashMap::new();
        let mut path_counts = HashMap::new();

        for entry in &entries {
            *action_counts.entry(entry.action).or_insert(0u64) += 1;
            *actor_counts.entry(entry.actor.id.clone()).or_insert(0u64) += 1;
            *path_counts.entry(entry.path.clone()).or_insert(0u64) += 1;
        }

        Ok(AuditReport {
            query: query.clone(),
            total_entries: total,
            action_summary: action_counts,
            actor_summary: actor_counts,
            path_summary: path_counts,
            entries,
            generated_at: 0,
        })
    }
}

#[derive(Debug, Clone)]
pub struct AuditReport {
    pub query: AuditQuery,
    pub total_entries: u64,
    pub action_summary: HashMap<AuditTrailAction, u64>,
    pub actor_summary: HashMap<String, u64>,
    pub path_summary: HashMap<String, u64>,
    pub entries: Vec<AuditTrailEntry>,
    pub generated_at: u64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION DRIFT DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration drift detection system
pub struct DriftDetector {
    pub desired_state: ConfigValue,
    pub actual_state: ConfigValue,
    pub rules: Vec<DriftRule>,
    pub exclusions: Vec<String>,
    pub tolerance: DriftTolerance,
    pub last_check: u64,
    pub drift_history: Vec<DriftCheckResult>,
}

#[derive(Debug, Clone)]
pub struct DriftRule {
    pub path: String,
    pub rule_type: DriftRuleType,
    pub severity: DriftSeverity,
    pub auto_remediate: bool,
}

#[derive(Debug, Clone)]
pub enum DriftRuleType {
    Exact,
    Approximate { tolerance: f64 },
    Pattern { regex: String },
    Range { min: f64, max: f64 },
    OneOf { values: Vec<ConfigValue> },
    Custom { checker: String },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DriftSeverity {
    Low,
    Medium,
    High,
    Critical,
}

#[derive(Debug, Clone)]
pub struct DriftTolerance {
    pub numeric_tolerance: f64,
    pub string_case_sensitive: bool,
    pub array_order_matters: bool,
    pub ignore_extra_fields: bool,
}

impl DriftTolerance {
    pub fn strict() -> Self {
        DriftTolerance {
            numeric_tolerance: 0.0,
            string_case_sensitive: true,
            array_order_matters: true,
            ignore_extra_fields: false,
        }
    }

    pub fn relaxed() -> Self {
        DriftTolerance {
            numeric_tolerance: 0.001,
            string_case_sensitive: false,
            array_order_matters: false,
            ignore_extra_fields: true,
        }
    }
}

#[derive(Debug, Clone)]
pub struct DriftCheckResult {
    pub timestamp: u64,
    pub has_drift: bool,
    pub drifts: Vec<DriftItem>,
    pub summary: DriftSummary,
}

#[derive(Debug, Clone)]
pub struct DriftItem {
    pub path: String,
    pub drift_type: DriftType,
    pub desired_value: Option<ConfigValue>,
    pub actual_value: Option<ConfigValue>,
    pub severity: DriftSeverity,
    pub rule: Option<String>,
    pub remediation: Option<RemediationAction>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DriftType {
    Missing,
    Extra,
    ValueChanged,
    TypeChanged,
}

#[derive(Debug, Clone)]
pub enum RemediationAction {
    SetValue { value: ConfigValue },
    DeleteKey,
    RestoreDefault,
    RunScript { script: String },
    Manual { instructions: String },
}

#[derive(Debug, Clone)]
pub struct DriftSummary {
    pub total_fields_checked: usize,
    pub fields_in_sync: usize,
    pub fields_drifted: usize,
    pub missing_fields: usize,
    pub extra_fields: usize,
    pub by_severity: HashMap<DriftSeverity, usize>,
}

impl DriftDetector {
    pub fn new(desired_state: ConfigValue) -> Self {
        DriftDetector {
            desired_state,
            actual_state: ConfigValue::Object(HashMap::new()),
            rules: Vec::new(),
            exclusions: Vec::new(),
            tolerance: DriftTolerance::strict(),
            last_check: 0,
            drift_history: Vec::new(),
        }
    }

    pub fn add_rule(&mut self, rule: DriftRule) {
        self.rules.push(rule);
    }

    pub fn exclude_path(&mut self, path: &str) {
        self.exclusions.push(path.to_string());
    }

    pub fn update_actual_state(&mut self, state: ConfigValue) {
        self.actual_state = state;
    }

    pub fn check(&mut self) -> DriftCheckResult {
        let mut drifts = Vec::new();
        let mut fields_checked = 0;

        self.check_object(&self.desired_state.clone(), &self.actual_state.clone(), "", &mut drifts, &mut fields_checked);

        let fields_drifted = drifts.len();
        let missing = drifts.iter().filter(|d| d.drift_type == DriftType::Missing).count();
        let extra = drifts.iter().filter(|d| d.drift_type == DriftType::Extra).count();

        let mut by_severity = HashMap::new();
        for drift in &drifts {
            *by_severity.entry(drift.severity).or_insert(0) += 1;
        }

        let result = DriftCheckResult {
            timestamp: 0, // Would be actual timestamp
            has_drift: !drifts.is_empty(),
            drifts,
            summary: DriftSummary {
                total_fields_checked: fields_checked,
                fields_in_sync: fields_checked - fields_drifted,
                fields_drifted,
                missing_fields: missing,
                extra_fields: extra,
                by_severity,
            },
        };

        self.drift_history.push(result.clone());
        self.last_check = 0; // Would be actual timestamp

        result
    }

    fn check_object(&self, desired: &ConfigValue, actual: &ConfigValue, path: &str, drifts: &mut Vec<DriftItem>, checked: &mut usize) {
        // Check if path is excluded
        if self.exclusions.iter().any(|e| path.starts_with(e)) {
            return;
        }

        match (desired, actual) {
            (ConfigValue::Object(desired_obj), ConfigValue::Object(actual_obj)) => {
                // Check for missing and changed fields
                for (key, desired_val) in desired_obj {
                    let field_path = if path.is_empty() { key.clone() } else { format!("{}.{}", path, key) };
                    *checked += 1;

                    if let Some(actual_val) = actual_obj.get(key) {
                        self.check_object(desired_val, actual_val, &field_path, drifts, checked);
                    } else {
                        drifts.push(DriftItem {
                            path: field_path,
                            drift_type: DriftType::Missing,
                            desired_value: Some(desired_val.clone()),
                            actual_value: None,
                            severity: DriftSeverity::High,
                            rule: None,
                            remediation: Some(RemediationAction::SetValue { value: desired_val.clone() }),
                        });
                    }
                }

                // Check for extra fields
                if !self.tolerance.ignore_extra_fields {
                    for (key, actual_val) in actual_obj {
                        if !desired_obj.contains_key(key) {
                            let field_path = if path.is_empty() { key.clone() } else { format!("{}.{}", path, key) };
                            drifts.push(DriftItem {
                                path: field_path,
                                drift_type: DriftType::Extra,
                                desired_value: None,
                                actual_value: Some(actual_val.clone()),
                                severity: DriftSeverity::Low,
                                rule: None,
                                remediation: Some(RemediationAction::DeleteKey),
                            });
                        }
                    }
                }
            }
            (ConfigValue::Array(desired_arr), ConfigValue::Array(actual_arr)) => {
                if self.tolerance.array_order_matters {
                    for (i, (d, a)) in desired_arr.iter().zip(actual_arr.iter()).enumerate() {
                        let item_path = format!("{}[{}]", path, i);
                        self.check_object(d, a, &item_path, drifts, checked);
                    }
                } else {
                    // Order-independent comparison
                    if desired_arr.len() != actual_arr.len() {
                        drifts.push(DriftItem {
                            path: path.to_string(),
                            drift_type: DriftType::ValueChanged,
                            desired_value: Some(desired.clone()),
                            actual_value: Some(actual.clone()),
                            severity: DriftSeverity::Medium,
                            rule: None,
                            remediation: Some(RemediationAction::SetValue { value: desired.clone() }),
                        });
                    }
                }
            }
            _ => {
                if !self.values_match(desired, actual) {
                    drifts.push(DriftItem {
                        path: path.to_string(),
                        drift_type: DriftType::ValueChanged,
                        desired_value: Some(desired.clone()),
                        actual_value: Some(actual.clone()),
                        severity: self.get_drift_severity(path),
                        rule: None,
                        remediation: Some(RemediationAction::SetValue { value: desired.clone() }),
                    });
                }
            }
        }
    }

    fn values_match(&self, desired: &ConfigValue, actual: &ConfigValue) -> bool {
        match (desired, actual) {
            (ConfigValue::String(d), ConfigValue::String(a)) => {
                if self.tolerance.string_case_sensitive {
                    d == a
                } else {
                    d.to_lowercase() == a.to_lowercase()
                }
            }
            (ConfigValue::Int(d), ConfigValue::Int(a)) => d == a,
            (ConfigValue::Float(d), ConfigValue::Float(a)) => {
                (d - a).abs() <= self.tolerance.numeric_tolerance
            }
            (ConfigValue::Bool(d), ConfigValue::Bool(a)) => d == a,
            (ConfigValue::Null, ConfigValue::Null) => true,
            _ => false,
        }
    }

    fn get_drift_severity(&self, path: &str) -> DriftSeverity {
        for rule in &self.rules {
            if path.starts_with(&rule.path) {
                return rule.severity;
            }
        }
        DriftSeverity::Medium
    }

    pub fn remediate(&self, drift: &DriftItem) -> Result<(), ConfigError> {
        match &drift.remediation {
            Some(RemediationAction::SetValue { value: _ }) => {
                // Would set the value in actual state
                Ok(())
            }
            Some(RemediationAction::DeleteKey) => {
                // Would delete the key
                Ok(())
            }
            Some(RemediationAction::RestoreDefault) => {
                // Would restore default value
                Ok(())
            }
            _ => Err(ConfigError::NotSupported("Manual remediation required".to_string())),
        }
    }

    pub fn remediate_all(&self) -> Result<usize, ConfigError> {
        let result = self.drift_history.last()
            .ok_or_else(|| ConfigError::NotFound("No drift check result".to_string()))?;

        let mut remediated = 0;
        for drift in &result.drifts {
            if self.remediate(drift).is_ok() {
                remediated += 1;
            }
        }

        Ok(remediated)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION COMPLIANCE
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration compliance checking system
pub struct ComplianceChecker {
    pub policies: Vec<CompliancePolicy>,
    pub frameworks: Vec<ComplianceFramework>,
    pub check_history: Vec<ComplianceCheckResult>,
    pub last_check: u64,
}

#[derive(Debug, Clone)]
pub struct CompliancePolicy {
    pub id: String,
    pub name: String,
    pub description: String,
    pub version: String,
    pub rules: Vec<ComplianceRule>,
    pub severity: ComplianceSeverity,
    pub tags: Vec<String>,
    pub enabled: bool,
}

#[derive(Debug, Clone)]
pub struct ComplianceRule {
    pub id: String,
    pub name: String,
    pub description: String,
    pub rationale: String,
    pub rule_type: ComplianceRuleType,
    pub remediation: String,
    pub references: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum ComplianceRuleType {
    RequireField { path: String },
    ForbidField { path: String },
    ValueEquals { path: String, value: ConfigValue },
    ValueNotEquals { path: String, value: ConfigValue },
    ValueInRange { path: String, min: f64, max: f64 },
    ValueMatches { path: String, pattern: String },
    ArrayContains { path: String, value: ConfigValue },
    ArrayNotContains { path: String, value: ConfigValue },
    Custom { evaluator: String },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ComplianceSeverity {
    Info,
    Low,
    Medium,
    High,
    Critical,
}

#[derive(Debug, Clone)]
pub struct ComplianceFramework {
    pub id: String,
    pub name: String,
    pub version: String,
    pub description: String,
    pub controls: Vec<ComplianceControl>,
}

#[derive(Debug, Clone)]
pub struct ComplianceControl {
    pub id: String,
    pub title: String,
    pub description: String,
    pub policies: Vec<String>, // Policy IDs
    pub family: String,
}

#[derive(Debug, Clone)]
pub struct ComplianceCheckResult {
    pub timestamp: u64,
    pub compliant: bool,
    pub total_rules: usize,
    pub passing_rules: usize,
    pub failing_rules: usize,
    pub violations: Vec<ComplianceViolation>,
    pub by_severity: HashMap<ComplianceSeverity, usize>,
    pub by_framework: HashMap<String, FrameworkComplianceResult>,
}

#[derive(Debug, Clone)]
pub struct ComplianceViolation {
    pub policy_id: String,
    pub rule_id: String,
    pub path: String,
    pub message: String,
    pub severity: ComplianceSeverity,
    pub actual_value: Option<ConfigValue>,
    pub expected: String,
    pub remediation: String,
}

#[derive(Debug, Clone)]
pub struct FrameworkComplianceResult {
    pub framework_id: String,
    pub compliant: bool,
    pub passing_controls: usize,
    pub failing_controls: usize,
    pub control_results: HashMap<String, bool>,
}

impl ComplianceChecker {
    pub fn new() -> Self {
        ComplianceChecker {
            policies: Vec::new(),
            frameworks: Vec::new(),
            check_history: Vec::new(),
            last_check: 0,
        }
    }

    pub fn add_policy(&mut self, policy: CompliancePolicy) {
        self.policies.push(policy);
    }

    pub fn add_framework(&mut self, framework: ComplianceFramework) {
        self.frameworks.push(framework);
    }

    pub fn check(&mut self, config: &ConfigValue) -> ComplianceCheckResult {
        let mut violations = Vec::new();
        let mut total_rules = 0;
        let mut passing_rules = 0;

        for policy in &self.policies {
            if !policy.enabled { continue; }

            for rule in &policy.rules {
                total_rules += 1;

                match self.check_rule(rule, config) {
                    Ok(()) => passing_rules += 1,
                    Err(message) => {
                        violations.push(ComplianceViolation {
                            policy_id: policy.id.clone(),
                            rule_id: rule.id.clone(),
                            path: self.get_rule_path(rule),
                            message,
                            severity: policy.severity,
                            actual_value: None,
                            expected: rule.description.clone(),
                            remediation: rule.remediation.clone(),
                        });
                    }
                }
            }
        }

        let failing_rules = violations.len();

        let mut by_severity = HashMap::new();
        for violation in &violations {
            *by_severity.entry(violation.severity).or_insert(0) += 1;
        }

        // Check framework compliance
        let mut by_framework = HashMap::new();
        for framework in &self.frameworks {
            let framework_result = self.check_framework(framework, &violations);
            by_framework.insert(framework.id.clone(), framework_result);
        }

        let result = ComplianceCheckResult {
            timestamp: 0,
            compliant: violations.is_empty(),
            total_rules,
            passing_rules,
            failing_rules,
            violations,
            by_severity,
            by_framework,
        };

        self.check_history.push(result.clone());
        self.last_check = 0;

        result
    }

    fn check_rule(&self, rule: &ComplianceRule, config: &ConfigValue) -> Result<(), String> {
        match &rule.rule_type {
            ComplianceRuleType::RequireField { path } => {
                if config.get_path(path).is_none() {
                    return Err(format!("Required field '{}' is missing", path));
                }
            }
            ComplianceRuleType::ForbidField { path } => {
                if config.get_path(path).is_some() {
                    return Err(format!("Forbidden field '{}' is present", path));
                }
            }
            ComplianceRuleType::ValueEquals { path, value } => {
                if let Some(actual) = config.get_path(path) {
                    if actual != value {
                        return Err(format!("Field '{}' has incorrect value", path));
                    }
                } else {
                    return Err(format!("Field '{}' is missing", path));
                }
            }
            ComplianceRuleType::ValueInRange { path, min, max } => {
                if let Some(actual) = config.get_path(path) {
                    if let Some(num) = actual.as_float() {
                        if num < *min || num > *max {
                            return Err(format!("Field '{}' value {} is out of range [{}, {}]", path, num, min, max));
                        }
                    }
                }
            }
            ComplianceRuleType::ValueMatches { path, pattern } => {
                if let Some(ConfigValue::String(s)) = config.get_path(path) {
                    // Would use regex matching
                    if !s.contains(pattern) {
                        return Err(format!("Field '{}' does not match pattern", path));
                    }
                }
            }
            _ => {}
        }
        Ok(())
    }

    fn get_rule_path(&self, rule: &ComplianceRule) -> String {
        match &rule.rule_type {
            ComplianceRuleType::RequireField { path } => path.clone(),
            ComplianceRuleType::ForbidField { path } => path.clone(),
            ComplianceRuleType::ValueEquals { path, .. } => path.clone(),
            ComplianceRuleType::ValueNotEquals { path, .. } => path.clone(),
            ComplianceRuleType::ValueInRange { path, .. } => path.clone(),
            ComplianceRuleType::ValueMatches { path, .. } => path.clone(),
            ComplianceRuleType::ArrayContains { path, .. } => path.clone(),
            ComplianceRuleType::ArrayNotContains { path, .. } => path.clone(),
            ComplianceRuleType::Custom { .. } => "custom".to_string(),
        }
    }

    fn check_framework(&self, framework: &ComplianceFramework, violations: &[ComplianceViolation]) -> FrameworkComplianceResult {
        let mut control_results = HashMap::new();
        let mut passing = 0;
        let mut failing = 0;

        for control in &framework.controls {
            let control_passing = !violations.iter()
                .any(|v| control.policies.contains(&v.policy_id));

            control_results.insert(control.id.clone(), control_passing);
            if control_passing { passing += 1; } else { failing += 1; }
        }

        FrameworkComplianceResult {
            framework_id: framework.id.clone(),
            compliant: failing == 0,
            passing_controls: passing,
            failing_controls: failing,
            control_results,
        }
    }

    pub fn generate_report(&self) -> ComplianceReport {
        let latest = self.check_history.last();

        ComplianceReport {
            generated_at: 0,
            total_policies: self.policies.len(),
            enabled_policies: self.policies.iter().filter(|p| p.enabled).count(),
            total_frameworks: self.frameworks.len(),
            latest_result: latest.cloned(),
            compliance_trend: self.calculate_trend(),
        }
    }

    fn calculate_trend(&self) -> Vec<TrendPoint> {
        self.check_history.iter()
            .map(|r| TrendPoint {
                timestamp: r.timestamp,
                compliance_rate: if r.total_rules > 0 {
                    r.passing_rules as f64 / r.total_rules as f64
                } else {
                    1.0
                },
            })
            .collect()
    }
}

#[derive(Debug, Clone)]
pub struct ComplianceReport {
    pub generated_at: u64,
    pub total_policies: usize,
    pub enabled_policies: usize,
    pub total_frameworks: usize,
    pub latest_result: Option<ComplianceCheckResult>,
    pub compliance_trend: Vec<TrendPoint>,
}

#[derive(Debug, Clone)]
pub struct TrendPoint {
    pub timestamp: u64,
    pub compliance_rate: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION CLI TOOLS
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration CLI command handler
pub struct ConfigCli {
    pub aggregator: ConfigAggregator,
    pub output_format: OutputFormat,
    pub color_enabled: bool,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OutputFormat {
    Text,
    Json,
    Yaml,
    Toml,
    Table,
}

pub enum CliCommand {
    Get { path: String },
    Set { path: String, value: String },
    Delete { path: String },
    List { prefix: Option<String> },
    Validate,
    Diff { file: String },
    Export { file: String, format: OutputFormat },
    Import { file: String },
    History { path: Option<String>, limit: usize },
    Rollback { version: String },
    Env { prefix: String },
    Profile { action: ProfileAction },
    Secret { action: SecretAction },
    Feature { action: FeatureAction },
    Compliance { action: ComplianceAction },
}

pub enum ProfileAction {
    List,
    Activate { name: String },
    Create { name: String },
    Delete { name: String },
}

pub enum SecretAction {
    Get { key: String },
    Set { key: String, value: String },
    List { prefix: Option<String> },
    Rotate { key: String },
}

pub enum FeatureAction {
    List,
    Enable { name: String },
    Disable { name: String },
    Status { name: String },
}

pub enum ComplianceAction {
    Check,
    Report,
    Policies,
}

#[derive(Debug)]
pub struct CliResult {
    pub success: bool,
    pub output: String,
    pub error: Option<String>,
}

impl ConfigCli {
    pub fn new(aggregator: ConfigAggregator) -> Self {
        ConfigCli {
            aggregator,
            output_format: OutputFormat::Text,
            color_enabled: true,
        }
    }

    pub fn execute(&mut self, command: CliCommand) -> CliResult {
        match command {
            CliCommand::Get { path } => self.cmd_get(&path),
            CliCommand::Set { path, value } => self.cmd_set(&path, &value),
            CliCommand::Delete { path } => self.cmd_delete(&path),
            CliCommand::List { prefix } => self.cmd_list(prefix.as_deref()),
            CliCommand::Validate => self.cmd_validate(),
            CliCommand::Diff { file } => self.cmd_diff(&file),
            CliCommand::Export { file, format } => self.cmd_export(&file, format),
            CliCommand::Import { file } => self.cmd_import(&file),
            CliCommand::History { path, limit } => self.cmd_history(path.as_deref(), limit),
            CliCommand::Profile { action } => self.cmd_profile(action),
            _ => CliResult {
                success: false,
                output: String::new(),
                error: Some("Command not implemented".to_string()),
            },
        }
    }

    fn cmd_get(&self, path: &str) -> CliResult {
        match self.aggregator.get(path) {
            Some(value) => CliResult {
                success: true,
                output: self.format_value(value),
                error: None,
            },
            None => CliResult {
                success: false,
                output: String::new(),
                error: Some(format!("Key '{}' not found", path)),
            },
        }
    }

    fn cmd_set(&mut self, path: &str, value: &str) -> CliResult {
        // Parse value and set in config
        let parsed = self.parse_cli_value(value);
        let _ = (path, parsed);

        CliResult {
            success: true,
            output: format!("Set {} = {}", path, value),
            error: None,
        }
    }

    fn cmd_delete(&mut self, path: &str) -> CliResult {
        let _ = path;
        CliResult {
            success: true,
            output: format!("Deleted {}", path),
            error: None,
        }
    }

    fn cmd_list(&self, prefix: Option<&str>) -> CliResult {
        let keys = self.list_keys(&self.aggregator.cached_config, "", prefix);
        CliResult {
            success: true,
            output: keys.join("\n"),
            error: None,
        }
    }

    fn cmd_validate(&self) -> CliResult {
        if let Some(ref schema) = self.aggregator.schema {
            match schema.validate(&self.aggregator.cached_config) {
                Ok(()) => CliResult {
                    success: true,
                    output: "Configuration is valid".to_string(),
                    error: None,
                },
                Err(errors) => CliResult {
                    success: false,
                    output: String::new(),
                    error: Some(errors.iter().map(|e| format!("{}: {}", e.path, e.message)).collect::<Vec<_>>().join("\n")),
                },
            }
        } else {
            CliResult {
                success: false,
                output: String::new(),
                error: Some("No schema defined".to_string()),
            }
        }
    }

    fn cmd_diff(&self, file: &str) -> CliResult {
        let _ = file;
        // Would load file and compare
        CliResult {
            success: true,
            output: "No differences".to_string(),
            error: None,
        }
    }

    fn cmd_export(&self, file: &str, format: OutputFormat) -> CliResult {
        let content = match format {
            OutputFormat::Json => self.format_json(&self.aggregator.cached_config),
            OutputFormat::Yaml => self.format_yaml(&self.aggregator.cached_config),
            OutputFormat::Toml => self.format_toml(&self.aggregator.cached_config),
            _ => self.format_value(&self.aggregator.cached_config),
        };

        let _ = file; // Would write to file

        CliResult {
            success: true,
            output: format!("Exported to {}", file),
            error: None,
        }
    }

    fn cmd_import(&mut self, file: &str) -> CliResult {
        let _ = file; // Would read and import
        CliResult {
            success: true,
            output: format!("Imported from {}", file),
            error: None,
        }
    }

    fn cmd_history(&self, path: Option<&str>, limit: usize) -> CliResult {
        let _ = (path, limit);
        // Would show history from version manager
        CliResult {
            success: true,
            output: "History not available".to_string(),
            error: None,
        }
    }

    fn cmd_profile(&mut self, action: ProfileAction) -> CliResult {
        match action {
            ProfileAction::List => {
                let profiles: Vec<&String> = self.aggregator.profile_manager.profiles.keys().collect();
                CliResult {
                    success: true,
                    output: profiles.iter().map(|s| s.as_str()).collect::<Vec<_>>().join("\n"),
                    error: None,
                }
            }
            ProfileAction::Activate { name } => {
                match self.aggregator.profile_manager.activate(&name) {
                    Ok(()) => CliResult {
                        success: true,
                        output: format!("Activated profile: {}", name),
                        error: None,
                    },
                    Err(e) => CliResult {
                        success: false,
                        output: String::new(),
                        error: Some(format!("{:?}", e)),
                    },
                }
            }
            _ => CliResult {
                success: false,
                output: String::new(),
                error: Some("Profile action not implemented".to_string()),
            },
        }
    }

    fn format_value(&self, value: &ConfigValue) -> String {
        match self.output_format {
            OutputFormat::Json => self.format_json(value),
            OutputFormat::Yaml => self.format_yaml(value),
            OutputFormat::Toml => self.format_toml(value),
            OutputFormat::Text | OutputFormat::Table => self.format_text(value),
        }
    }

    fn format_text(&self, value: &ConfigValue) -> String {
        match value {
            ConfigValue::String(s) => s.clone(),
            ConfigValue::Int(i) => i.to_string(),
            ConfigValue::Float(f) => f.to_string(),
            ConfigValue::Bool(b) => b.to_string(),
            ConfigValue::Null => "null".to_string(),
            ConfigValue::Array(arr) => {
                arr.iter().map(|v| self.format_text(v)).collect::<Vec<_>>().join(", ")
            }
            ConfigValue::Object(obj) => {
                obj.iter()
                    .map(|(k, v)| format!("{}: {}", k, self.format_text(v)))
                    .collect::<Vec<_>>()
                    .join("\n")
            }
        }
    }

    fn format_json(&self, value: &ConfigValue) -> String {
        // Simplified JSON formatting
        match value {
            ConfigValue::String(s) => format!("\"{}\"", s),
            ConfigValue::Int(i) => i.to_string(),
            ConfigValue::Float(f) => f.to_string(),
            ConfigValue::Bool(b) => b.to_string(),
            ConfigValue::Null => "null".to_string(),
            ConfigValue::Array(arr) => {
                format!("[{}]", arr.iter().map(|v| self.format_json(v)).collect::<Vec<_>>().join(", "))
            }
            ConfigValue::Object(obj) => {
                let pairs: Vec<String> = obj.iter()
                    .map(|(k, v)| format!("\"{}\": {}", k, self.format_json(v)))
                    .collect();
                format!("{{{}}}", pairs.join(", "))
            }
        }
    }

    fn format_yaml(&self, value: &ConfigValue) -> String {
        self.format_yaml_indent(value, 0)
    }

    fn format_yaml_indent(&self, value: &ConfigValue, indent: usize) -> String {
        let spaces = "  ".repeat(indent);
        match value {
            ConfigValue::String(s) => s.clone(),
            ConfigValue::Int(i) => i.to_string(),
            ConfigValue::Float(f) => f.to_string(),
            ConfigValue::Bool(b) => b.to_string(),
            ConfigValue::Null => "null".to_string(),
            ConfigValue::Array(arr) => {
                arr.iter()
                    .map(|v| format!("{}- {}", spaces, self.format_yaml_indent(v, indent + 1)))
                    .collect::<Vec<_>>()
                    .join("\n")
            }
            ConfigValue::Object(obj) => {
                obj.iter()
                    .map(|(k, v)| {
                        if matches!(v, ConfigValue::Object(_) | ConfigValue::Array(_)) {
                            format!("{}{}:\n{}", spaces, k, self.format_yaml_indent(v, indent + 1))
                        } else {
                            format!("{}{}: {}", spaces, k, self.format_yaml_indent(v, indent))
                        }
                    })
                    .collect::<Vec<_>>()
                    .join("\n")
            }
        }
    }

    fn format_toml(&self, value: &ConfigValue) -> String {
        // Simplified TOML formatting
        self.format_toml_section(value, "")
    }

    fn format_toml_section(&self, value: &ConfigValue, section: &str) -> String {
        let mut output = String::new();

        if let ConfigValue::Object(obj) = value {
            if !section.is_empty() {
                output.push_str(&format!("[{}]\n", section));
            }

            // First, output simple values
            for (k, v) in obj {
                match v {
                    ConfigValue::Object(_) => {}
                    ConfigValue::Array(_) => {}
                    _ => {
                        output.push_str(&format!("{} = {}\n", k, self.format_toml_value(v)));
                    }
                }
            }

            // Then, output nested objects as sections
            for (k, v) in obj {
                if let ConfigValue::Object(_) = v {
                    let new_section = if section.is_empty() { k.clone() } else { format!("{}.{}", section, k) };
                    output.push('\n');
                    output.push_str(&self.format_toml_section(v, &new_section));
                }
            }
        }

        output
    }

    fn format_toml_value(&self, value: &ConfigValue) -> String {
        match value {
            ConfigValue::String(s) => format!("\"{}\"", s),
            ConfigValue::Int(i) => i.to_string(),
            ConfigValue::Float(f) => f.to_string(),
            ConfigValue::Bool(b) => b.to_string(),
            ConfigValue::Null => "null".to_string(),
            ConfigValue::Array(arr) => {
                format!("[{}]", arr.iter().map(|v| self.format_toml_value(v)).collect::<Vec<_>>().join(", "))
            }
            _ => "{}".to_string(),
        }
    }

    fn list_keys(&self, value: &ConfigValue, prefix: &str, filter: Option<&str>) -> Vec<String> {
        let mut keys = Vec::new();

        if let ConfigValue::Object(obj) = value {
            for (k, v) in obj {
                let key = if prefix.is_empty() { k.clone() } else { format!("{}.{}", prefix, k) };

                if filter.is_none() || key.starts_with(filter.unwrap()) {
                    if !matches!(v, ConfigValue::Object(_)) {
                        keys.push(key.clone());
                    }
                }

                if let ConfigValue::Object(_) = v {
                    keys.extend(self.list_keys(v, &key, filter));
                }
            }
        }

        keys
    }

    fn parse_cli_value(&self, value: &str) -> ConfigValue {
        if value == "true" { return ConfigValue::Bool(true); }
        if value == "false" { return ConfigValue::Bool(false); }
        if value == "null" { return ConfigValue::Null; }
        if let Ok(i) = value.parse::<i64>() { return ConfigValue::Int(i); }
        if let Ok(f) = value.parse::<f64>() { return ConfigValue::Float(f); }
        ConfigValue::String(value.to_string())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION DSL
// ═══════════════════════════════════════════════════════════════════════════════

/// Domain-specific language for complex configuration expressions
pub struct ConfigDsl {
    pub parser: DslParser,
    pub evaluator: DslEvaluator,
    pub functions: HashMap<String, Box<dyn DslFunction + Send + Sync>>,
}

pub struct DslParser;

impl DslParser {
    pub fn parse(&self, expr: &str) -> Result<DslExpr, ConfigError> {
        let expr = expr.trim();

        // Simple expression parser
        if expr.starts_with("if") {
            self.parse_conditional(expr)
        } else if expr.starts_with("switch") {
            self.parse_switch(expr)
        } else if expr.starts_with("merge") {
            self.parse_merge(expr)
        } else if expr.starts_with("map") {
            self.parse_map(expr)
        } else if expr.starts_with("filter") {
            self.parse_filter(expr)
        } else if expr.starts_with("$") {
            self.parse_reference(expr)
        } else if expr.contains("==") || expr.contains("!=") || expr.contains("<") || expr.contains(">") {
            self.parse_comparison(expr)
        } else {
            self.parse_literal(expr)
        }
    }

    fn parse_conditional(&self, _expr: &str) -> Result<DslExpr, ConfigError> {
        // if condition then value else other
        Ok(DslExpr::Conditional {
            condition: Box::new(DslExpr::Literal(ConfigValue::Bool(true))),
            then_expr: Box::new(DslExpr::Literal(ConfigValue::Null)),
            else_expr: Box::new(DslExpr::Literal(ConfigValue::Null)),
        })
    }

    fn parse_switch(&self, _expr: &str) -> Result<DslExpr, ConfigError> {
        Ok(DslExpr::Switch {
            value: Box::new(DslExpr::Literal(ConfigValue::Null)),
            cases: Vec::new(),
            default: Box::new(DslExpr::Literal(ConfigValue::Null)),
        })
    }

    fn parse_merge(&self, _expr: &str) -> Result<DslExpr, ConfigError> {
        Ok(DslExpr::Merge { values: Vec::new() })
    }

    fn parse_map(&self, _expr: &str) -> Result<DslExpr, ConfigError> {
        Ok(DslExpr::Map {
            source: Box::new(DslExpr::Literal(ConfigValue::Array(Vec::new()))),
            transform: Box::new(DslExpr::Literal(ConfigValue::Null)),
        })
    }

    fn parse_filter(&self, _expr: &str) -> Result<DslExpr, ConfigError> {
        Ok(DslExpr::Filter {
            source: Box::new(DslExpr::Literal(ConfigValue::Array(Vec::new()))),
            predicate: Box::new(DslExpr::Literal(ConfigValue::Bool(true))),
        })
    }

    fn parse_reference(&self, expr: &str) -> Result<DslExpr, ConfigError> {
        let path = expr[1..].to_string();
        Ok(DslExpr::Reference { path })
    }

    fn parse_comparison(&self, expr: &str) -> Result<DslExpr, ConfigError> {
        if let Some(pos) = expr.find("==") {
            let left = self.parse(&expr[..pos])?;
            let right = self.parse(&expr[pos+2..])?;
            return Ok(DslExpr::Comparison {
                left: Box::new(left),
                operator: ComparisonOperator::Equals,
                right: Box::new(right),
            });
        }
        if let Some(pos) = expr.find("!=") {
            let left = self.parse(&expr[..pos])?;
            let right = self.parse(&expr[pos+2..])?;
            return Ok(DslExpr::Comparison {
                left: Box::new(left),
                operator: ComparisonOperator::NotEquals,
                right: Box::new(right),
            });
        }
        self.parse_literal(expr)
    }

    fn parse_literal(&self, expr: &str) -> Result<DslExpr, ConfigError> {
        let expr = expr.trim();

        if expr == "true" {
            Ok(DslExpr::Literal(ConfigValue::Bool(true)))
        } else if expr == "false" {
            Ok(DslExpr::Literal(ConfigValue::Bool(false)))
        } else if expr == "null" {
            Ok(DslExpr::Literal(ConfigValue::Null))
        } else if let Ok(i) = expr.parse::<i64>() {
            Ok(DslExpr::Literal(ConfigValue::Int(i)))
        } else if let Ok(f) = expr.parse::<f64>() {
            Ok(DslExpr::Literal(ConfigValue::Float(f)))
        } else if expr.starts_with('"') && expr.ends_with('"') {
            Ok(DslExpr::Literal(ConfigValue::String(expr[1..expr.len()-1].to_string())))
        } else {
            Ok(DslExpr::Literal(ConfigValue::String(expr.to_string())))
        }
    }
}

#[derive(Debug, Clone)]
pub enum DslExpr {
    Literal(ConfigValue),
    Reference { path: String },
    Comparison { left: Box<DslExpr>, operator: ComparisonOperator, right: Box<DslExpr> },
    Logical { left: Box<DslExpr>, operator: LogicalOperator, right: Box<DslExpr> },
    Conditional { condition: Box<DslExpr>, then_expr: Box<DslExpr>, else_expr: Box<DslExpr> },
    Switch { value: Box<DslExpr>, cases: Vec<(DslExpr, DslExpr)>, default: Box<DslExpr> },
    Merge { values: Vec<DslExpr> },
    Map { source: Box<DslExpr>, transform: Box<DslExpr> },
    Filter { source: Box<DslExpr>, predicate: Box<DslExpr> },
    Reduce { source: Box<DslExpr>, initial: Box<DslExpr>, reducer: Box<DslExpr> },
    FunctionCall { name: String, args: Vec<DslExpr> },
    Arithmetic { left: Box<DslExpr>, operator: ArithmeticOperator, right: Box<DslExpr> },
}

#[derive(Debug, Clone, Copy)]
pub enum ComparisonOperator {
    Equals,
    NotEquals,
    LessThan,
    LessOrEqual,
    GreaterThan,
    GreaterOrEqual,
    Contains,
    StartsWith,
    EndsWith,
    Matches,
}

#[derive(Debug, Clone, Copy)]
pub enum LogicalOperator {
    And,
    Or,
    Not,
}

#[derive(Debug, Clone, Copy)]
pub enum ArithmeticOperator {
    Add,
    Subtract,
    Multiply,
    Divide,
    Modulo,
    Power,
}

pub struct DslEvaluator;

impl DslEvaluator {
    pub fn evaluate(&self, expr: &DslExpr, context: &ConfigValue) -> Result<ConfigValue, ConfigError> {
        match expr {
            DslExpr::Literal(value) => Ok(value.clone()),
            DslExpr::Reference { path } => {
                context.get_path(path)
                    .cloned()
                    .ok_or_else(|| ConfigError::NotFound(format!("Reference '{}' not found", path)))
            }
            DslExpr::Comparison { left, operator, right } => {
                let left_val = self.evaluate(left, context)?;
                let right_val = self.evaluate(right, context)?;
                let result = self.compare(&left_val, &right_val, *operator);
                Ok(ConfigValue::Bool(result))
            }
            DslExpr::Conditional { condition, then_expr, else_expr } => {
                let cond_val = self.evaluate(condition, context)?;
                let is_true = match cond_val {
                    ConfigValue::Bool(b) => b,
                    ConfigValue::Int(i) => i != 0,
                    ConfigValue::String(s) => !s.is_empty(),
                    ConfigValue::Null => false,
                    _ => true,
                };
                if is_true {
                    self.evaluate(then_expr, context)
                } else {
                    self.evaluate(else_expr, context)
                }
            }
            DslExpr::Merge { values } => {
                let mut result = ConfigValue::Object(HashMap::new());
                for value_expr in values {
                    let value = self.evaluate(value_expr, context)?;
                    result = result.merge(&value);
                }
                Ok(result)
            }
            DslExpr::Map { source, transform } => {
                let source_val = self.evaluate(source, context)?;
                if let ConfigValue::Array(arr) = source_val {
                    let mapped: Result<Vec<ConfigValue>, ConfigError> = arr.iter()
                        .map(|item| self.evaluate(transform, item))
                        .collect();
                    Ok(ConfigValue::Array(mapped?))
                } else {
                    Err(ConfigError::ValidationError("Map requires array source".to_string()))
                }
            }
            DslExpr::Filter { source, predicate } => {
                let source_val = self.evaluate(source, context)?;
                if let ConfigValue::Array(arr) = source_val {
                    let filtered: Vec<ConfigValue> = arr.into_iter()
                        .filter(|item| {
                            if let Ok(ConfigValue::Bool(true)) = self.evaluate(predicate, item) {
                                true
                            } else {
                                false
                            }
                        })
                        .collect();
                    Ok(ConfigValue::Array(filtered))
                } else {
                    Err(ConfigError::ValidationError("Filter requires array source".to_string()))
                }
            }
            DslExpr::Arithmetic { left, operator, right } => {
                let left_val = self.evaluate(left, context)?;
                let right_val = self.evaluate(right, context)?;
                self.arithmetic(&left_val, &right_val, *operator)
            }
            _ => Err(ConfigError::NotSupported("Expression type not implemented".to_string())),
        }
    }

    fn compare(&self, left: &ConfigValue, right: &ConfigValue, op: ComparisonOperator) -> bool {
        match op {
            ComparisonOperator::Equals => left == right,
            ComparisonOperator::NotEquals => left != right,
            ComparisonOperator::LessThan => {
                match (left.as_float(), right.as_float()) {
                    (Some(l), Some(r)) => l < r,
                    _ => false,
                }
            }
            ComparisonOperator::LessOrEqual => {
                match (left.as_float(), right.as_float()) {
                    (Some(l), Some(r)) => l <= r,
                    _ => false,
                }
            }
            ComparisonOperator::GreaterThan => {
                match (left.as_float(), right.as_float()) {
                    (Some(l), Some(r)) => l > r,
                    _ => false,
                }
            }
            ComparisonOperator::GreaterOrEqual => {
                match (left.as_float(), right.as_float()) {
                    (Some(l), Some(r)) => l >= r,
                    _ => false,
                }
            }
            ComparisonOperator::Contains => {
                match (left.as_str(), right.as_str()) {
                    (Some(l), Some(r)) => l.contains(r),
                    _ => false,
                }
            }
            ComparisonOperator::StartsWith => {
                match (left.as_str(), right.as_str()) {
                    (Some(l), Some(r)) => l.starts_with(r),
                    _ => false,
                }
            }
            ComparisonOperator::EndsWith => {
                match (left.as_str(), right.as_str()) {
                    (Some(l), Some(r)) => l.ends_with(r),
                    _ => false,
                }
            }
            _ => false,
        }
    }

    fn arithmetic(&self, left: &ConfigValue, right: &ConfigValue, op: ArithmeticOperator) -> Result<ConfigValue, ConfigError> {
        let l = left.as_float().ok_or_else(|| ConfigError::ValidationError("Left operand must be numeric".to_string()))?;
        let r = right.as_float().ok_or_else(|| ConfigError::ValidationError("Right operand must be numeric".to_string()))?;

        let result = match op {
            ArithmeticOperator::Add => l + r,
            ArithmeticOperator::Subtract => l - r,
            ArithmeticOperator::Multiply => l * r,
            ArithmeticOperator::Divide => {
                if r == 0.0 { return Err(ConfigError::ValidationError("Division by zero".to_string())); }
                l / r
            }
            ArithmeticOperator::Modulo => l % r,
            ArithmeticOperator::Power => l.powf(r),
        };

        Ok(ConfigValue::Float(result))
    }
}

pub trait DslFunction {
    fn name(&self) -> &str;
    fn call(&self, args: &[ConfigValue], context: &ConfigValue) -> Result<ConfigValue, ConfigError>;
}

impl ConfigDsl {
    pub fn new() -> Self {
        let mut dsl = ConfigDsl {
            parser: DslParser,
            evaluator: DslEvaluator,
            functions: HashMap::new(),
        };

        // Register built-in functions
        dsl.register_builtin_functions();
        dsl
    }

    fn register_builtin_functions(&mut self) {
        // Would register built-in functions like:
        // - env(name) - get environment variable
        // - concat(...args) - concatenate strings
        // - coalesce(...args) - first non-null value
        // - etc.
    }

    pub fn evaluate(&self, expr: &str, context: &ConfigValue) -> Result<ConfigValue, ConfigError> {
        let parsed = self.parser.parse(expr)?;
        self.evaluator.evaluate(&parsed, context)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENDED TESTS
