#[cfg(test)]
mod extended_tests {
    use super::*;

    #[test]
    fn test_latency_histogram() {
        let mut hist = LatencyHistogram::new();
        hist.observe(0.001);
        hist.observe(0.010);
        hist.observe(0.100);
        hist.observe(0.500);

        assert_eq!(hist.count, 4);
        assert!(hist.min <= 0.001);
        assert!(hist.max >= 0.500);
    }

    #[test]
    fn test_config_monitor() {
        let mut monitor = ConfigMonitor::new();

        monitor.record_access("app.name", AccessOperation::Read, 1.5);
        monitor.record_access("app.name", AccessOperation::Read, 2.0);
        monitor.record_change("app.version");

        let export = monitor.export_metrics();
        assert_eq!(export.change_counts.get("app.version"), Some(&1));
    }

    #[test]
    fn test_experiment_manager() {
        let mut manager = ExperimentManager::new();

        let experiment = Experiment {
            id: "test-exp".to_string(),
            name: "Test Experiment".to_string(),
            description: "Testing".to_string(),
            hypothesis: "Test hypothesis".to_string(),
            status: ExperimentStatus::Running,
            variants: vec![
                ExperimentVariant {
                    id: "control".to_string(),
                    name: "Control".to_string(),
                    description: "Control group".to_string(),
                    weight: 0.5,
                    config_overrides: ConfigValue::Object(HashMap::new()),
                    is_control: true,
                },
                ExperimentVariant {
                    id: "treatment".to_string(),
                    name: "Treatment".to_string(),
                    description: "Treatment group".to_string(),
                    weight: 0.5,
                    config_overrides: ConfigValue::Object(HashMap::new()),
                    is_control: false,
                },
            ],
            targeting: ExperimentTargeting {
                rules: Vec::new(),
                exclusion_rules: Vec::new(),
                mutual_exclusions: Vec::new(),
                required_experiments: Vec::new(),
            },
            metrics: Vec::new(),
            start_time: None,
            end_time: None,
            created_at: 0,
            updated_at: 0,
            created_by: "test".to_string(),
            allocation_type: AllocationAlgorithm::Static,
            sample_size: None,
            minimum_detectable_effect: None,
            significance_level: 0.05,
            power: 0.8,
        };

        manager.create_experiment(experiment);

        let variant = manager.get_variant("test-exp", "user-123");
        assert!(variant.is_some());
    }

    #[test]
    fn test_validation_rules_engine() {
        let mut engine = ValidationRulesEngine::new();

        engine.add_rule(ValidationRule {
            name: "require-name".to_string(),
            path: "name".to_string(),
            rule_type: ValidationRuleType::Required,
            severity: ValidationSeverity::Error,
            message: "Name is required".to_string(),
            enabled: true,
        });

        engine.add_rule(ValidationRule {
            name: "validate-port".to_string(),
            path: "port".to_string(),
            rule_type: ValidationRuleType::Range { min: Some(1.0), max: Some(65535.0) },
            severity: ValidationSeverity::Error,
            message: "Port must be between 1 and 65535".to_string(),
            enabled: true,
        });

        let valid_config = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("name".to_string(), ConfigValue::String("test".to_string()));
            m.insert("port".to_string(), ConfigValue::Int(8080));
            m
        });

        let context = ValidationContext {
            config: valid_config.clone(),
            environment: "test".to_string(),
            metadata: HashMap::new(),
        };

        let result = engine.validate(&valid_config, &context);
        assert!(result.valid);
        assert!(result.errors.is_empty());
    }

    #[test]
    fn test_config_bindings() {
        let mut bindings = ConfigBindings::new();

        bindings.bind("timeout", ConfigBinding {
            path: "server.timeout".to_string(),
            value_type: BindingType::Duration { unit: DurationUnit::Seconds },
            default: Some(ConfigValue::Int(30)),
            transform: None,
            cached_value: None,
            last_updated: 0,
        });

        let config = ConfigValue::Object({
            let mut m = HashMap::new();
            let mut server = HashMap::new();
            server.insert("timeout".to_string(), ConfigValue::Int(60));
            m.insert("server".to_string(), ConfigValue::Object(server));
            m
        });

        let timeout = bindings.get_duration_ms("timeout", &config);
        assert_eq!(timeout, Some(60000)); // 60 seconds in ms
    }

    #[test]
    fn test_drift_detector() {
        let desired = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("version".to_string(), ConfigValue::String("1.0.0".to_string()));
            m.insert("debug".to_string(), ConfigValue::Bool(false));
            m
        });

        let mut detector = DriftDetector::new(desired);

        let actual = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("version".to_string(), ConfigValue::String("1.0.0".to_string()));
            m.insert("debug".to_string(), ConfigValue::Bool(true)); // Drifted!
            m
        });

        detector.update_actual_state(actual);
        let result = detector.check();

        assert!(result.has_drift);
        assert_eq!(result.drifts.len(), 1);
        assert_eq!(result.drifts[0].path, "debug");
    }

    #[test]
    fn test_compliance_checker() {
        let mut checker = ComplianceChecker::new();

        checker.add_policy(CompliancePolicy {
            id: "security-policy".to_string(),
            name: "Security Policy".to_string(),
            description: "Basic security requirements".to_string(),
            version: "1.0".to_string(),
            rules: vec![
                ComplianceRule {
                    id: "require-tls".to_string(),
                    name: "Require TLS".to_string(),
                    description: "TLS must be enabled".to_string(),
                    rationale: "Encrypt data in transit".to_string(),
                    rule_type: ComplianceRuleType::ValueEquals {
                        path: "tls.enabled".to_string(),
                        value: ConfigValue::Bool(true),
                    },
                    remediation: "Set tls.enabled = true".to_string(),
                    references: vec![],
                },
            ],
            severity: ComplianceSeverity::High,
            tags: vec!["security".to_string()],
            enabled: true,
        });

        let compliant_config = ConfigValue::Object({
            let mut m = HashMap::new();
            let mut tls = HashMap::new();
            tls.insert("enabled".to_string(), ConfigValue::Bool(true));
            m.insert("tls".to_string(), ConfigValue::Object(tls));
            m
        });

        let result = checker.check(&compliant_config);
        assert!(result.compliant);
    }

    #[test]
    fn test_config_cli() {
        let aggregator = ConfigAggregator::new();
        let cli = ConfigCli::new(aggregator);

        let result = cli.cmd_validate();
        // No schema defined, should fail
        assert!(!result.success);
    }

    #[test]
    fn test_config_dsl() {
        let dsl = ConfigDsl::new();

        let context = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("x".to_string(), ConfigValue::Int(10));
            m.insert("y".to_string(), ConfigValue::Int(20));
            m
        });

        let result = dsl.evaluate("$x", &context);
        assert_eq!(result.ok(), Some(ConfigValue::Int(10)));

        let result = dsl.evaluate("true", &context);
        assert_eq!(result.ok(), Some(ConfigValue::Bool(true)));
    }

    #[test]
    fn test_audit_trail() {
        let mut audit = ConfigAuditTrail::new();

        let entry = AuditTrailEntry {
            id: "1".to_string(),
            timestamp: 0,
            action: AuditTrailAction::Update,
            path: "app.name".to_string(),
            old_value: Some(ConfigValue::String("old".to_string())),
            new_value: Some(ConfigValue::String("new".to_string())),
