// ═══════════════════════════════════════════════════════════════════════════════
// FEATURE FLAGS
// ═══════════════════════════════════════════════════════════════════════════════

/// Feature flag system
#[derive(Debug, Clone)]
pub struct FeatureFlag {
    pub name: String,
    pub description: String,
    pub enabled: bool,
    pub rollout_percentage: f64,
    pub targeting: FeatureTargeting,
    pub variants: Vec<FeatureVariant>,
    pub created_at: u64,
    pub updated_at: u64,
}

#[derive(Debug, Clone)]
pub struct FeatureTargeting {
    pub rules: Vec<TargetingRule>,
    pub default_variant: String,
}

#[derive(Debug, Clone)]
pub struct TargetingRule {
    pub condition: TargetingCondition,
    pub variant: String,
}

#[derive(Debug, Clone)]
pub enum TargetingCondition {
    UserIn { user_ids: Vec<String> },
    GroupIn { groups: Vec<String> },
    Percentage { value: f64 },
    Environment { env: String },
    Custom { key: String, operator: ConditionOperator, value: String },
    And { conditions: Vec<TargetingCondition> },
    Or { conditions: Vec<TargetingCondition> },
    Not { condition: Box<TargetingCondition> },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ConditionOperator {
    Equals,
    NotEquals,
    Contains,
    StartsWith,
    EndsWith,
    GreaterThan,
    LessThan,
    In,
    NotIn,
    Matches,
}

#[derive(Debug, Clone)]
pub struct FeatureVariant {
    pub name: String,
    pub weight: f64,
    pub payload: Option<ConfigValue>,
}

/// Feature flag manager
pub struct FeatureManager {
    pub flags: HashMap<String, FeatureFlag>,
    pub providers: Vec<Box<dyn FeatureFlagProvider + Send + Sync>>,
    pub evaluator: FeatureEvaluator,
    pub cache: FeatureFlagCache,
}

pub trait FeatureFlagProvider {
    fn name(&self) -> &str;
    fn load_flags(&self) -> Result<Vec<FeatureFlag>, ConfigError>;
    fn save_flag(&self, flag: &FeatureFlag) -> Result<(), ConfigError>;
    fn delete_flag(&self, name: &str) -> Result<(), ConfigError>;
}

pub struct FeatureEvaluator {
    pub seed: u64,
}

impl FeatureEvaluator {
    pub fn new() -> Self {
        FeatureEvaluator { seed: 12345 }
    }

    pub fn evaluate(&self, flag: &FeatureFlag, context: &EvaluationContext) -> EvaluationResult {
        if !flag.enabled {
            return EvaluationResult {
                enabled: false,
                variant: None,
                reason: EvaluationReason::Disabled,
            };
        }

        // Check targeting rules
        for rule in &flag.targeting.rules {
            if self.matches_condition(&rule.condition, context) {
                let variant = flag.variants.iter()
                    .find(|v| v.name == rule.variant)
                    .cloned();
                return EvaluationResult {
                    enabled: true,
                    variant,
                    reason: EvaluationReason::TargetingRule,
                };
            }
        }

        // Check rollout percentage
        let hash = self.hash_context(context, &flag.name);
        let percentage = (hash % 10000) as f64 / 100.0;

        if percentage < flag.rollout_percentage {
            let variant = self.select_variant(&flag.variants, hash);
            EvaluationResult {
                enabled: true,
                variant,
                reason: EvaluationReason::Rollout,
            }
        } else {
            EvaluationResult {
                enabled: false,
                variant: None,
                reason: EvaluationReason::RolloutExcluded,
            }
        }
    }

    fn matches_condition(&self, condition: &TargetingCondition, context: &EvaluationContext) -> bool {
        match condition {
            TargetingCondition::UserIn { user_ids } => {
                context.user_id.as_ref().map_or(false, |id| user_ids.contains(id))
            }
            TargetingCondition::GroupIn { groups } => {
                context.groups.iter().any(|g| groups.contains(g))
            }
            TargetingCondition::Percentage { value } => {
                let hash = self.hash_context(context, "percentage");
                (hash % 10000) as f64 / 100.0 < *value
            }
            TargetingCondition::Environment { env } => {
                &context.environment == env
            }
            TargetingCondition::Custom { key, operator, value } => {
                context.attributes.get(key).map_or(false, |v| {
                    self.compare_values(v, value, *operator)
                })
            }
            TargetingCondition::And { conditions } => {
                conditions.iter().all(|c| self.matches_condition(c, context))
            }
            TargetingCondition::Or { conditions } => {
                conditions.iter().any(|c| self.matches_condition(c, context))
            }
            TargetingCondition::Not { condition } => {
                !self.matches_condition(condition, context)
            }
        }
    }

    fn compare_values(&self, actual: &str, expected: &str, operator: ConditionOperator) -> bool {
        match operator {
            ConditionOperator::Equals => actual == expected,
            ConditionOperator::NotEquals => actual != expected,
            ConditionOperator::Contains => actual.contains(expected),
            ConditionOperator::StartsWith => actual.starts_with(expected),
            ConditionOperator::EndsWith => actual.ends_with(expected),
            ConditionOperator::GreaterThan => actual > expected,
            ConditionOperator::LessThan => actual < expected,
            ConditionOperator::In => expected.split(',').any(|v| v.trim() == actual),
            ConditionOperator::NotIn => !expected.split(',').any(|v| v.trim() == actual),
            ConditionOperator::Matches => true, // Regex match would go here
        }
    }

    fn hash_context(&self, context: &EvaluationContext, salt: &str) -> u64 {
        // Simple hash for demonstration
        let mut hash: u64 = self.seed;
        if let Some(ref id) = context.user_id {
            for byte in id.bytes() { hash = hash.wrapping_mul(31).wrapping_add(byte as u64); }
        }
        for byte in salt.bytes() { hash = hash.wrapping_mul(31).wrapping_add(byte as u64); }
        hash
    }

    fn select_variant(&self, variants: &[FeatureVariant], hash: u64) -> Option<FeatureVariant> {
        if variants.is_empty() { return None; }

        let total_weight: f64 = variants.iter().map(|v| v.weight).sum();
        let mut target = (hash % 10000) as f64 / 10000.0 * total_weight;

        for variant in variants {
            target -= variant.weight;
            if target <= 0.0 {
                return Some(variant.clone());
            }
        }

        variants.last().cloned()
    }
}

#[derive(Debug, Clone)]
pub struct EvaluationContext {
    pub user_id: Option<String>,
    pub groups: Vec<String>,
    pub environment: String,
    pub attributes: HashMap<String, String>,
}

#[derive(Debug, Clone)]
pub struct EvaluationResult {
    pub enabled: bool,
    pub variant: Option<FeatureVariant>,
    pub reason: EvaluationReason,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum EvaluationReason {
    Disabled,
    TargetingRule,
    Rollout,
    RolloutExcluded,
    Default,
    Error,
}

