            source: AuditSource {
                source_type: SourceType::Api,
                ip_address: Some("127.0.0.1".to_string()),
                user_agent: None,
                request_id: None,
                session_id: None,
            },
            metadata: AuditMetadata {
                environment: "test".to_string(),
                version: "1.0".to_string(),
                correlation_id: None,
                parent_action_id: None,
                tags: HashMap::new(),
                custom_fields: HashMap::new(),
            },
            signature: None,
        };

        assert!(audit.record(entry).is_ok());
    }

    #[test]
    fn test_duration_parsing() {
        let bindings = ConfigBindings::new();

        assert_eq!(bindings.parse_duration("100ms"), Some(100));
        assert_eq!(bindings.parse_duration("5s"), Some(5000));
        assert_eq!(bindings.parse_duration("1m"), Some(60000));
        assert_eq!(bindings.parse_duration("1h"), Some(3600000));
    }

    #[test]
    fn test_byte_size_parsing() {
        let bindings = ConfigBindings::new();

        assert_eq!(bindings.parse_byte_size("1024B"), Some(1024));
        assert_eq!(bindings.parse_byte_size("1KB"), Some(1024));
        assert_eq!(bindings.parse_byte_size("1MB"), Some(1024 * 1024));
        assert_eq!(bindings.parse_byte_size("1GB"), Some(1024 * 1024 * 1024));
    }

    #[test]
    fn test_cross_field_validation() {
        let mut engine = ValidationRulesEngine::new();

        engine.add_cross_field_rule(CrossFieldRule {
            name: "weights-sum".to_string(),
            fields: vec!["weight_a".to_string(), "weight_b".to_string(), "weight_c".to_string()],
            rule: CrossFieldRuleType::SumEquals { target: 1.0 },
            message: "Weights must sum to 1.0".to_string(),
        });

        let valid_config = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("weight_a".to_string(), ConfigValue::Float(0.3));
            m.insert("weight_b".to_string(), ConfigValue::Float(0.5));
            m.insert("weight_c".to_string(), ConfigValue::Float(0.2));
            m
        });

        let context = ValidationContext {
            config: valid_config.clone(),
            environment: "test".to_string(),
            metadata: HashMap::new(),
        };

        let result = engine.validate(&valid_config, &context);
        assert!(result.valid);
    }

    #[test]
    fn test_normal_cdf_approximation() {
        let manager = ExperimentManager::new();

        // Test some known values
        let cdf_0 = manager.normal_cdf(0.0);
        assert!((cdf_0 - 0.5).abs() < 0.01);

        let cdf_2 = manager.normal_cdf(2.0);
        assert!(cdf_2 > 0.97);
    }
}
