// DEPLOYMENT CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Deployment configuration for CD pipelines
pub struct DeploymentConfig {
    pub strategy: DeploymentStrategy,
    pub replicas: u32,
    pub resources: ResourceRequirements,
    pub health_probes: HealthProbes,
    pub scaling: AutoScalingConfig,
    pub rollout: RolloutConfig,
    pub affinity: AffinityConfig,
    pub tolerations: Vec<Toleration>,
    pub security_context: SecurityContext,
}

#[derive(Debug, Clone)]
pub enum DeploymentStrategy {
    RollingUpdate { max_surge: u32, max_unavailable: u32 },
    Recreate,
    BlueGreen { preview_replicas: u32 },
    Canary { steps: Vec<CanaryStep> },
}

#[derive(Debug, Clone)]
pub struct CanaryStep {
    pub weight: u32,
    pub pause_duration_seconds: Option<u64>,
    pub analysis: Option<CanaryAnalysis>,
}

#[derive(Debug, Clone)]
pub struct CanaryAnalysis {
    pub metrics: Vec<AnalysisMetric>,
    pub failure_limit: u32,
    pub success_condition: String,
}

#[derive(Debug, Clone)]
pub struct AnalysisMetric {
    pub name: String,
    pub provider: MetricProvider,
    pub query: String,
    pub interval_seconds: u64,
    pub count: u32,
}

#[derive(Debug, Clone)]
pub enum MetricProvider {
    Prometheus { address: String },
    Datadog { api_key: String },
    CloudWatch { region: String },
    NewRelic { api_key: String },
}

#[derive(Debug, Clone)]
pub struct ResourceRequirements {
    pub requests: ResourceSpec,
    pub limits: ResourceSpec,
}

#[derive(Debug, Clone)]
pub struct ResourceSpec {
    pub cpu: String,        // e.g., "500m", "2"
    pub memory: String,     // e.g., "512Mi", "2Gi"
    pub ephemeral_storage: Option<String>,
    pub gpu: Option<u32>,
}

#[derive(Debug, Clone)]
pub struct HealthProbes {
    pub liveness: ProbeConfig,
    pub readiness: ProbeConfig,
    pub startup: Option<ProbeConfig>,
}

#[derive(Debug, Clone)]
pub struct ProbeConfig {
    pub probe_type: ProbeType,
    pub initial_delay_seconds: u32,
    pub period_seconds: u32,
    pub timeout_seconds: u32,
    pub success_threshold: u32,
    pub failure_threshold: u32,
}

#[derive(Debug, Clone)]
pub enum ProbeType {
    HttpGet { path: String, port: u16 },
    TcpSocket { port: u16 },
    Exec { command: Vec<String> },
    Grpc { port: u16 },
}

#[derive(Debug, Clone)]
pub struct AutoScalingConfig {
    pub enabled: bool,
    pub min_replicas: u32,
    pub max_replicas: u32,
    pub metrics: Vec<ScalingMetric>,
    pub behavior: ScalingBehavior,
}

#[derive(Debug, Clone)]
pub struct ScalingMetric {
    pub metric_type: ScalingMetricType,
    pub target_value: f64,
    pub target_type: TargetType,
}

#[derive(Debug, Clone)]
pub enum ScalingMetricType {
    CpuUtilization,
    MemoryUtilization,
    RequestsPerSecond,
    Custom { name: String },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TargetType {
    Value,
    Utilization,
    AverageValue,
}

#[derive(Debug, Clone)]
pub struct ScalingBehavior {
    pub scale_up: ScalingPolicy,
    pub scale_down: ScalingPolicy,
}

#[derive(Debug, Clone)]
pub struct ScalingPolicy {
    pub stabilization_window_seconds: u32,
    pub policies: Vec<PolicyRule>,
    pub select_policy: SelectPolicy,
}

#[derive(Debug, Clone)]
pub struct PolicyRule {
    pub rule_type: PolicyType,
    pub value: u32,
    pub period_seconds: u32,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum PolicyType {
    Pods,
    Percent,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SelectPolicy {
    Max,
    Min,
    Disabled,
}

#[derive(Debug, Clone)]
pub struct RolloutConfig {
    pub max_surge: String,
    pub max_unavailable: String,
    pub progress_deadline_seconds: u32,
    pub revision_history_limit: u32,
}

#[derive(Debug, Clone)]
pub struct AffinityConfig {
    pub node_affinity: Option<NodeAffinity>,
    pub pod_affinity: Option<PodAffinity>,
    pub pod_anti_affinity: Option<PodAntiAffinity>,
}

#[derive(Debug, Clone)]
pub struct NodeAffinity {
    pub required: Vec<NodeSelector>,
    pub preferred: Vec<PreferredScheduling>,
}

#[derive(Debug, Clone)]
pub struct NodeSelector {
    pub match_expressions: Vec<LabelSelector>,
}

#[derive(Debug, Clone)]
pub struct LabelSelector {
    pub key: String,
    pub operator: LabelOperator,
    pub values: Vec<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LabelOperator {
    In,
    NotIn,
    Exists,
    DoesNotExist,
}

#[derive(Debug, Clone)]
pub struct PreferredScheduling {
    pub weight: u32,
    pub preference: NodeSelector,
}

#[derive(Debug, Clone)]
pub struct PodAffinity {
    pub required: Vec<PodAffinityTerm>,
    pub preferred: Vec<WeightedPodAffinityTerm>,
}

#[derive(Debug, Clone)]
pub struct PodAntiAffinity {
    pub required: Vec<PodAffinityTerm>,
    pub preferred: Vec<WeightedPodAffinityTerm>,
}

#[derive(Debug, Clone)]
pub struct PodAffinityTerm {
    pub label_selector: Vec<LabelSelector>,
    pub topology_key: String,
    pub namespaces: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct WeightedPodAffinityTerm {
    pub weight: u32,
    pub pod_affinity_term: PodAffinityTerm,
}

#[derive(Debug, Clone)]
pub struct Toleration {
    pub key: Option<String>,
    pub operator: TolerationOperator,
    pub value: Option<String>,
    pub effect: Option<TaintEffect>,
    pub toleration_seconds: Option<u64>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TolerationOperator {
    Exists,
    Equal,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TaintEffect {
    NoSchedule,
    PreferNoSchedule,
    NoExecute,
}

#[derive(Debug, Clone)]
pub struct SecurityContext {
    pub run_as_user: Option<u64>,
    pub run_as_group: Option<u64>,
    pub run_as_non_root: bool,
    pub read_only_root_filesystem: bool,
    pub privileged: bool,
    pub allow_privilege_escalation: bool,
    pub capabilities: CapabilitiesConfig,
    pub seccomp_profile: Option<SeccompProfile>,
}

#[derive(Debug, Clone)]
pub struct CapabilitiesConfig {
    pub add: Vec<String>,
    pub drop: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum SeccompProfile {
    Unconfined,
    RuntimeDefault,
    Localhost { profile_path: String },
}

impl DeploymentConfig {
    pub fn new() -> Self {
        DeploymentConfig {
            strategy: DeploymentStrategy::RollingUpdate { max_surge: 1, max_unavailable: 0 },
            replicas: 3,
            resources: ResourceRequirements {
                requests: ResourceSpec {
                    cpu: "100m".to_string(),
                    memory: "128Mi".to_string(),
                    ephemeral_storage: None,
                    gpu: None,
                },
                limits: ResourceSpec {
                    cpu: "500m".to_string(),
                    memory: "512Mi".to_string(),
                    ephemeral_storage: None,
                    gpu: None,
                },
            },
            health_probes: HealthProbes {
                liveness: ProbeConfig {
                    probe_type: ProbeType::HttpGet { path: "/health".to_string(), port: 8080 },
                    initial_delay_seconds: 10,
                    period_seconds: 10,
                    timeout_seconds: 5,
                    success_threshold: 1,
                    failure_threshold: 3,
                },
                readiness: ProbeConfig {
                    probe_type: ProbeType::HttpGet { path: "/ready".to_string(), port: 8080 },
                    initial_delay_seconds: 5,
                    period_seconds: 5,
                    timeout_seconds: 3,
                    success_threshold: 1,
                    failure_threshold: 3,
                },
                startup: None,
            },
            scaling: AutoScalingConfig {
                enabled: true,
                min_replicas: 2,
                max_replicas: 10,
                metrics: vec![
                    ScalingMetric {
                        metric_type: ScalingMetricType::CpuUtilization,
                        target_value: 70.0,
                        target_type: TargetType::Utilization,
                    }
                ],
                behavior: ScalingBehavior {
                    scale_up: ScalingPolicy {
                        stabilization_window_seconds: 0,
                        policies: vec![PolicyRule {
                            rule_type: PolicyType::Percent,
                            value: 100,
                            period_seconds: 15,
                        }],
                        select_policy: SelectPolicy::Max,
                    },
                    scale_down: ScalingPolicy {
                        stabilization_window_seconds: 300,
                        policies: vec![PolicyRule {
                            rule_type: PolicyType::Percent,
                            value: 10,
                            period_seconds: 60,
                        }],
                        select_policy: SelectPolicy::Min,
                    },
                },
            },
            rollout: RolloutConfig {
                max_surge: "25%".to_string(),
                max_unavailable: "0".to_string(),
                progress_deadline_seconds: 600,
                revision_history_limit: 10,
            },
            affinity: AffinityConfig {
                node_affinity: None,
                pod_affinity: None,
                pod_anti_affinity: Some(PodAntiAffinity {
                    required: Vec::new(),
                    preferred: vec![
                        WeightedPodAffinityTerm {
                            weight: 100,
                            pod_affinity_term: PodAffinityTerm {
                                label_selector: vec![],
                                topology_key: "kubernetes.io/hostname".to_string(),
                                namespaces: Vec::new(),
                            },
                        }
                    ],
                }),
            },
            tolerations: Vec::new(),
            security_context: SecurityContext {
                run_as_user: Some(1000),
                run_as_group: Some(1000),
                run_as_non_root: true,
                read_only_root_filesystem: true,
                privileged: false,
                allow_privilege_escalation: false,
                capabilities: CapabilitiesConfig {
                    add: Vec::new(),
                    drop: vec!["ALL".to_string()],
                },
                seccomp_profile: Some(SeccompProfile::RuntimeDefault),
            },
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION AGGREGATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Central configuration aggregator
pub struct ConfigAggregator {
    pub providers: Vec<Box<dyn ConfigProvider + Send + Sync>>,
    pub schema: Option<ConfigSchema>,
    pub template_engine: ConfigTemplateEngine,
    pub version_manager: ConfigVersionManager,
    pub hot_reload: HotReloadManager,
    pub profile_manager: ProfileManager,
    pub secrets_manager: SecretsManager,
    pub feature_manager: FeatureManager,
    pub cached_config: ConfigValue,
}

impl ConfigAggregator {
    pub fn new() -> Self {
        ConfigAggregator {
            providers: Vec::new(),
            schema: None,
            template_engine: ConfigTemplateEngine::new(),
            version_manager: ConfigVersionManager::new(SemanticVersion::new(1, 0, 0)),
            hot_reload: HotReloadManager::new(ConfigValue::Object(HashMap::new())),
            profile_manager: ProfileManager::new(),
            secrets_manager: SecretsManager {
                providers: Vec::new(),
                cache: SecretsCache {
                    secrets: HashMap::new(),
                    max_size: 1000,
                    default_ttl_ms: 300000,
                },
                encryption: EncryptionConfig {
                    algorithm: EncryptionAlgorithm::Aes256Gcm,
                    key_id: "default".to_string(),
                    key_rotation_period: 86400000,
                },
                audit: SecretsAuditLog {
                    entries: Vec::new(),
                    max_entries: 10000,
                },
            },
            feature_manager: FeatureManager {
                flags: HashMap::new(),
                providers: Vec::new(),
                evaluator: FeatureEvaluator::new(),
                cache: FeatureFlagCache {
                    flags: HashMap::new(),
                    ttl_ms: 60000,
                },
            },
            cached_config: ConfigValue::Object(HashMap::new()),
        }
    }

    pub fn add_provider<P: ConfigProvider + Send + Sync + 'static>(&mut self, provider: P) {
        self.providers.push(Box::new(provider));
        self.providers.sort_by(|a, b| a.priority().cmp(&b.priority()));
    }

    pub fn set_schema(&mut self, schema: ConfigSchema) {
        self.schema = Some(schema);
    }

    pub fn load(&mut self) -> Result<ConfigValue, ConfigError> {
        let mut merged = ConfigValue::Object(HashMap::new());

        // Load from all providers in priority order
        for provider in &self.providers {
            let config = provider.load()?;
            merged = merged.merge(&config);
        }

        // Apply profile settings
        let profile_config = self.profile_manager.get_resolved_config();
        merged = merged.merge(&profile_config);

        // Apply templates
        merged = self.template_engine.render_config(&merged)?;

        // Validate against schema
        if let Some(ref schema) = self.schema {
            schema.validate(&merged)?;
        }

        self.cached_config = merged.clone();
        self.hot_reload.current_config = merged.clone();

        Ok(merged)
    }

    pub fn get(&self, path: &str) -> Option<&ConfigValue> {
        self.cached_config.get_path(path)
    }

    pub fn reload(&mut self) -> Result<ConfigValue, ConfigError> {
        let old_config = self.cached_config.clone();
        let new_config = self.load()?;

        let diff = ConfigDiff::compute(&old_config, &new_config);
        if diff.has_changes() {
            // Create snapshot before applying changes
            self.version_manager.create_snapshot(&old_config, Some("Auto-snapshot before reload"));
        }

        Ok(new_config)
    }
}

