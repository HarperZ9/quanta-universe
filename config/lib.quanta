// ═══════════════════════════════════════════════════════════════════════════════
// GLOBAL CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

use std::sync::{RwLock, OnceCell};

static CONFIG: OnceCell<RwLock<UniverseConfig>> = OnceCell::new();

/// Get the global configuration
pub fn config() -> &'static RwLock<UniverseConfig> {
    CONFIG.get_or_init(|| RwLock::new(UniverseConfig::default()))
}

/// Initialize configuration from file
pub fn init(path: &Path) -> Result<(), ConfigError> {
    let cfg = UniverseConfig::load(path)?;
    let _ = CONFIG.set(RwLock::new(cfg));
    Ok(())
}

/// Get a read-only view of configuration
pub fn get() -> UniverseConfig {
    config().read().unwrap().clone()
}

/// Update configuration
pub fn update<F>(f: F) where F: FnOnce(&mut UniverseConfig) {
    let mut cfg = config().write().unwrap();
    f(&mut cfg);
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION SCHEMA AND VALIDATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration schema types for validation
#[derive(Debug, Clone, PartialEq)]
pub enum SchemaType {
    String { min_length: Option<usize>, max_length: Option<usize>, pattern: Option<String> },
    Integer { min: Option<i64>, max: Option<i64> },
    Float { min: Option<f64>, max: Option<f64> },
    Boolean,
    Array { items: Box<SchemaType>, min_items: Option<usize>, max_items: Option<usize> },
    Object { properties: HashMap<String, SchemaProperty>, required: Vec<String> },
    Enum { values: Vec<String> },
    OneOf { schemas: Vec<SchemaType> },
    AnyOf { schemas: Vec<SchemaType> },
    AllOf { schemas: Vec<SchemaType> },
    Ref { reference: String },
    Null,
    Any,
}

#[derive(Debug, Clone)]
pub struct SchemaProperty {
    pub schema_type: SchemaType,
    pub description: Option<String>,
    pub default: Option<ConfigValue>,
    pub deprecated: bool,
    pub secret: bool,
}

/// Configuration value types
#[derive(Debug, Clone, PartialEq)]
pub enum ConfigValue {
    Null,
    Bool(bool),
    Int(i64),
    Float(f64),
    String(String),
    Array(Vec<ConfigValue>),
    Object(HashMap<String, ConfigValue>),
}

impl ConfigValue {
    pub fn as_bool(&self) -> Option<bool> {
        match self { ConfigValue::Bool(b) => Some(*b), _ => None }
    }

    pub fn as_int(&self) -> Option<i64> {
        match self { ConfigValue::Int(i) => Some(*i), _ => None }
    }

    pub fn as_float(&self) -> Option<f64> {
        match self {
            ConfigValue::Float(f) => Some(*f),
            ConfigValue::Int(i) => Some(*i as f64),
            _ => None,
        }
    }

    pub fn as_str(&self) -> Option<&str> {
        match self { ConfigValue::String(s) => Some(s), _ => None }
    }

    pub fn as_array(&self) -> Option<&Vec<ConfigValue>> {
        match self { ConfigValue::Array(a) => Some(a), _ => None }
    }

    pub fn as_object(&self) -> Option<&HashMap<String, ConfigValue>> {
        match self { ConfigValue::Object(o) => Some(o), _ => None }
    }

    pub fn get(&self, key: &str) -> Option<&ConfigValue> {
        self.as_object().and_then(|o| o.get(key))
    }

    pub fn get_path(&self, path: &str) -> Option<&ConfigValue> {
        let mut current = self;
        for part in path.split('.') {
            current = current.get(part)?;
        }
        Some(current)
    }

    pub fn merge(&self, other: &ConfigValue) -> ConfigValue {
        match (self, other) {
            (ConfigValue::Object(a), ConfigValue::Object(b)) => {
                let mut merged = a.clone();
                for (k, v) in b {
                    if let Some(existing) = merged.get(k) {
                        merged.insert(k.clone(), existing.merge(v));
                    } else {
                        merged.insert(k.clone(), v.clone());
                    }
                }
                ConfigValue::Object(merged)
            }
            _ => other.clone(),
        }
    }
}

/// Configuration schema definition
#[derive(Debug, Clone)]
pub struct ConfigSchema {
    pub name: String,
    pub version: String,
    pub root: SchemaType,
    pub definitions: HashMap<String, SchemaType>,
}

impl ConfigSchema {
    pub fn new(name: &str, version: &str) -> Self {
        ConfigSchema {
            name: name.to_string(),
            version: version.to_string(),
            root: SchemaType::Object {
                properties: HashMap::new(),
                required: Vec::new(),
            },
            definitions: HashMap::new(),
        }
    }

    pub fn validate(&self, value: &ConfigValue) -> Result<(), Vec<ValidationError>> {
        let mut errors = Vec::new();
        self.validate_type(&self.root, value, "", &mut errors);
        if errors.is_empty() { Ok(()) } else { Err(errors) }
    }

    fn validate_type(&self, schema: &SchemaType, value: &ConfigValue, path: &str, errors: &mut Vec<ValidationError>) {
        match (schema, value) {
            (SchemaType::String { min_length, max_length, pattern }, ConfigValue::String(s)) => {
                if let Some(min) = min_length {
                    if s.len() < *min {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("String length {} is less than minimum {}", s.len(), min),
                        });
                    }
                }
                if let Some(max) = max_length {
                    if s.len() > *max {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("String length {} exceeds maximum {}", s.len(), max),
                        });
                    }
                }
                if let Some(pat) = pattern {
                    // Regex validation would go here
                    let _ = pat;
                }
            }
            (SchemaType::Integer { min, max }, ConfigValue::Int(i)) => {
                if let Some(min_val) = min {
                    if i < min_val {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Integer {} is less than minimum {}", i, min_val),
                        });
                    }
                }
                if let Some(max_val) = max {
                    if i > max_val {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Integer {} exceeds maximum {}", i, max_val),
                        });
                    }
                }
            }
            (SchemaType::Float { min, max }, ConfigValue::Float(f)) => {
                if let Some(min_val) = min {
                    if f < min_val {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Float {} is less than minimum {}", f, min_val),
                        });
                    }
                }
                if let Some(max_val) = max {
                    if f > max_val {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Float {} exceeds maximum {}", f, max_val),
                        });
                    }
                }
            }
            (SchemaType::Boolean, ConfigValue::Bool(_)) => {}
            (SchemaType::Array { items, min_items, max_items }, ConfigValue::Array(arr)) => {
                if let Some(min) = min_items {
                    if arr.len() < *min {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Array length {} is less than minimum {}", arr.len(), min),
                        });
                    }
                }
                if let Some(max) = max_items {
                    if arr.len() > *max {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Array length {} exceeds maximum {}", arr.len(), max),
                        });
                    }
                }
                for (i, item) in arr.iter().enumerate() {
                    let item_path = format!("{}[{}]", path, i);
                    self.validate_type(items, item, &item_path, errors);
                }
            }
            (SchemaType::Object { properties, required }, ConfigValue::Object(obj)) => {
                for req in required {
                    if !obj.contains_key(req) {
                        errors.push(ValidationError {
                            path: path.to_string(),
                            message: format!("Required property '{}' is missing", req),
                        });
                    }
                }
                for (key, prop) in properties {
                    if let Some(value) = obj.get(key) {
                        let prop_path = if path.is_empty() { key.clone() } else { format!("{}.{}", path, key) };
                        self.validate_type(&prop.schema_type, value, &prop_path, errors);
                    }
                }
            }
            (SchemaType::Enum { values }, ConfigValue::String(s)) => {
                if !values.contains(s) {
                    errors.push(ValidationError {
                        path: path.to_string(),
                        message: format!("Value '{}' is not one of: {:?}", s, values),
                    });
                }
            }
            (SchemaType::Null, ConfigValue::Null) => {}
            (SchemaType::Any, _) => {}
            (SchemaType::Ref { reference }, value) => {
                if let Some(def) = self.definitions.get(reference) {
                    self.validate_type(def, value, path, errors);
                }
            }
            (SchemaType::OneOf { schemas }, value) => {
                let mut valid_count = 0;
                for schema in schemas {
                    let mut sub_errors = Vec::new();
                    self.validate_type(schema, value, path, &mut sub_errors);
                    if sub_errors.is_empty() { valid_count += 1; }
                }
                if valid_count != 1 {
                    errors.push(ValidationError {
                        path: path.to_string(),
                        message: format!("Value must match exactly one schema, matched {}", valid_count),
                    });
                }
            }
            (SchemaType::AnyOf { schemas }, value) => {
                let mut any_valid = false;
                for schema in schemas {
                    let mut sub_errors = Vec::new();
                    self.validate_type(schema, value, path, &mut sub_errors);
                    if sub_errors.is_empty() { any_valid = true; break; }
                }
                if !any_valid {
                    errors.push(ValidationError {
                        path: path.to_string(),
                        message: "Value must match at least one schema".to_string(),
                    });
                }
            }
            (SchemaType::AllOf { schemas }, value) => {
                for schema in schemas {
                    self.validate_type(schema, value, path, errors);
                }
            }
            _ => {
                errors.push(ValidationError {
                    path: path.to_string(),
                    message: format!("Type mismatch: expected {:?}", schema),
                });
            }
        }
    }
}

#[derive(Debug, Clone)]
pub struct ValidationError {
    pub path: String,
    pub message: String,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION PROVIDERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Trait for configuration providers
pub trait ConfigProvider {
    fn name(&self) -> &str;
    fn priority(&self) -> i32;
    fn load(&self) -> Result<ConfigValue, ConfigError>;
    fn supports_watch(&self) -> bool { false }
    fn watch(&self, _callback: Box<dyn Fn(ConfigValue) + Send>) -> Result<WatchHandle, ConfigError> {
        Err(ConfigError::NotSupported("watch".to_string()))
    }
}

/// Handle for configuration watches
pub struct WatchHandle {
    pub id: u64,
    pub provider: String,
    cancel: Box<dyn Fn() + Send>,
}

impl WatchHandle {
    pub fn cancel(self) {
        (self.cancel)();
    }
}

/// File-based configuration provider
pub struct FileConfigProvider {
    pub path: PathBuf,
    pub format: ConfigFormat,
    pub watch_enabled: bool,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ConfigFormat {
    Toml,
    Yaml,
    Json,
    Ini,
    Properties,
}

impl FileConfigProvider {
    pub fn new(path: PathBuf, format: ConfigFormat) -> Self {
        FileConfigProvider { path, format, watch_enabled: false }
    }

    pub fn with_watch(mut self) -> Self {
        self.watch_enabled = true;
        self
    }

    fn parse_toml(&self, content: &str) -> Result<ConfigValue, ConfigError> {
        // TOML parser implementation
        let mut root = HashMap::new();
        let mut current_section = String::new();

        for line in content.lines() {
            let line = line.trim();
            if line.is_empty() || line.starts_with('#') { continue; }

            if line.starts_with('[') && line.ends_with(']') {
                current_section = line[1..line.len()-1].to_string();
                continue;
            }

            if let Some((key, value)) = line.split_once('=') {
                let key = key.trim();
                let value = value.trim();
                let parsed_value = self.parse_value(value);

                if current_section.is_empty() {
                    root.insert(key.to_string(), parsed_value);
                } else {
                    let section = root.entry(current_section.clone())
                        .or_insert_with(|| ConfigValue::Object(HashMap::new()));
                    if let ConfigValue::Object(ref mut obj) = section {
                        obj.insert(key.to_string(), parsed_value);
                    }
                }
            }
        }

        Ok(ConfigValue::Object(root))
    }

    fn parse_json(&self, content: &str) -> Result<ConfigValue, ConfigError> {
        // Simple JSON parser
        let content = content.trim();
        self.parse_json_value(content, &mut 0)
    }

    fn parse_json_value(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        self.skip_whitespace(content, pos);

        if *pos >= content.len() {
            return Err(ConfigError::ParseError("Unexpected end of input".to_string()));
        }

        let ch = content.chars().nth(*pos).unwrap();
        match ch {
            '"' => self.parse_json_string(content, pos),
            't' | 'f' => self.parse_json_bool(content, pos),
            'n' => self.parse_json_null(content, pos),
            '[' => self.parse_json_array(content, pos),
            '{' => self.parse_json_object(content, pos),
            '-' | '0'..='9' => self.parse_json_number(content, pos),
            _ => Err(ConfigError::ParseError(format!("Unexpected character: {}", ch))),
        }
    }

    fn skip_whitespace(&self, content: &str, pos: &mut usize) {
        while *pos < content.len() {
            let ch = content.chars().nth(*pos).unwrap();
            if ch.is_whitespace() { *pos += 1; } else { break; }
        }
    }

    fn parse_json_string(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        *pos += 1; // Skip opening quote
        let start = *pos;
        let mut escaped = false;

        while *pos < content.len() {
            let ch = content.chars().nth(*pos).unwrap();
            if escaped {
                escaped = false;
            } else if ch == '\\' {
                escaped = true;
            } else if ch == '"' {
                let value = content[start..*pos].to_string();
                *pos += 1;
                return Ok(ConfigValue::String(value));
            }
            *pos += 1;
        }
        Err(ConfigError::ParseError("Unterminated string".to_string()))
    }

    fn parse_json_bool(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        if content[*pos..].starts_with("true") {
            *pos += 4;
            Ok(ConfigValue::Bool(true))
        } else if content[*pos..].starts_with("false") {
            *pos += 5;
            Ok(ConfigValue::Bool(false))
        } else {
            Err(ConfigError::ParseError("Invalid boolean".to_string()))
        }
    }

    fn parse_json_null(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        if content[*pos..].starts_with("null") {
            *pos += 4;
            Ok(ConfigValue::Null)
        } else {
            Err(ConfigError::ParseError("Invalid null".to_string()))
        }
    }

    fn parse_json_number(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        let start = *pos;
        let mut has_decimal = false;

        while *pos < content.len() {
            let ch = content.chars().nth(*pos).unwrap();
            if ch == '.' { has_decimal = true; *pos += 1; }
            else if ch == '-' || ch == '+' || ch == 'e' || ch == 'E' || ch.is_ascii_digit() { *pos += 1; }
            else { break; }
        }

        let num_str = &content[start..*pos];
        if has_decimal {
            num_str.parse::<f64>()
                .map(ConfigValue::Float)
                .map_err(|_| ConfigError::ParseError("Invalid float".to_string()))
        } else {
            num_str.parse::<i64>()
                .map(ConfigValue::Int)
                .map_err(|_| ConfigError::ParseError("Invalid integer".to_string()))
        }
    }

    fn parse_json_array(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        *pos += 1; // Skip [
        let mut arr = Vec::new();

        loop {
            self.skip_whitespace(content, pos);
            if *pos >= content.len() {
                return Err(ConfigError::ParseError("Unterminated array".to_string()));
            }
            if content.chars().nth(*pos).unwrap() == ']' {
                *pos += 1;
                return Ok(ConfigValue::Array(arr));
            }
            if !arr.is_empty() {
                if content.chars().nth(*pos).unwrap() != ',' {
                    return Err(ConfigError::ParseError("Expected comma".to_string()));
                }
                *pos += 1;
            }
            arr.push(self.parse_json_value(content, pos)?);
        }
    }

    fn parse_json_object(&self, content: &str, pos: &mut usize) -> Result<ConfigValue, ConfigError> {
        *pos += 1; // Skip {
        let mut obj = HashMap::new();

        loop {
            self.skip_whitespace(content, pos);
            if *pos >= content.len() {
                return Err(ConfigError::ParseError("Unterminated object".to_string()));
            }
            if content.chars().nth(*pos).unwrap() == '}' {
                *pos += 1;
                return Ok(ConfigValue::Object(obj));
            }
            if !obj.is_empty() {
                if content.chars().nth(*pos).unwrap() != ',' {
                    return Err(ConfigError::ParseError("Expected comma".to_string()));
                }
                *pos += 1;
                self.skip_whitespace(content, pos);
            }

            let key = match self.parse_json_string(content, pos)? {
                ConfigValue::String(s) => s,
                _ => return Err(ConfigError::ParseError("Expected string key".to_string())),
            };

            self.skip_whitespace(content, pos);
            if content.chars().nth(*pos).unwrap() != ':' {
                return Err(ConfigError::ParseError("Expected colon".to_string()));
            }
            *pos += 1;

            let value = self.parse_json_value(content, pos)?;
            obj.insert(key, value);
        }
    }

    fn parse_value(&self, value: &str) -> ConfigValue {
        let value = value.trim_matches('"').trim_matches('\'');
        if value == "true" { return ConfigValue::Bool(true); }
        if value == "false" { return ConfigValue::Bool(false); }
        if let Ok(i) = value.parse::<i64>() { return ConfigValue::Int(i); }
        if let Ok(f) = value.parse::<f64>() { return ConfigValue::Float(f); }
        ConfigValue::String(value.to_string())
    }
}

impl ConfigProvider for FileConfigProvider {
    fn name(&self) -> &str { "file" }
    fn priority(&self) -> i32 { 100 }

    fn load(&self) -> Result<ConfigValue, ConfigError> {
        let content = read_to_string(&self.path)
            .map_err(|e| ConfigError::IoError(e.to_string()))?;

        match self.format {
            ConfigFormat::Toml => self.parse_toml(&content),
            ConfigFormat::Json => self.parse_json(&content),
            ConfigFormat::Yaml => self.parse_toml(&content), // Simplified
            ConfigFormat::Ini => self.parse_toml(&content),
            ConfigFormat::Properties => self.parse_toml(&content),
        }
    }

    fn supports_watch(&self) -> bool { self.watch_enabled }
}

/// Environment variable configuration provider
pub struct EnvConfigProvider {
    pub prefix: String,
    pub separator: String,
    pub lowercase_keys: bool,
}

impl EnvConfigProvider {
    pub fn new(prefix: &str) -> Self {
        EnvConfigProvider {
            prefix: prefix.to_string(),
            separator: "_".to_string(),
            lowercase_keys: true,
        }
    }

    pub fn with_separator(mut self, sep: &str) -> Self {
        self.separator = sep.to_string();
        self
    }
}

impl ConfigProvider for EnvConfigProvider {
    fn name(&self) -> &str { "env" }
    fn priority(&self) -> i32 { 200 }

    fn load(&self) -> Result<ConfigValue, ConfigError> {
        let mut root = HashMap::new();

        for (key, value) in env::vars() {
            if !key.starts_with(&self.prefix) { continue; }

            let key = &key[self.prefix.len()..];
            let key = if key.starts_with("_") { &key[1..] } else { key };

            let parts: Vec<&str> = key.split(&self.separator).collect();
            let mut current = &mut root;

            for (i, part) in parts.iter().enumerate() {
                let part = if self.lowercase_keys { part.to_lowercase() } else { part.to_string() };

                if i == parts.len() - 1 {
                    current.insert(part, self.parse_env_value(&value));
                } else {
                    current = match current.entry(part).or_insert_with(|| ConfigValue::Object(HashMap::new())) {
                        ConfigValue::Object(ref mut obj) => obj,
                        _ => return Err(ConfigError::ParseError("Invalid nested structure".to_string())),
                    };
                }
            }
        }

        Ok(ConfigValue::Object(root))
    }
}

impl EnvConfigProvider {
    fn parse_env_value(&self, value: &str) -> ConfigValue {
        if value == "true" { return ConfigValue::Bool(true); }
        if value == "false" { return ConfigValue::Bool(false); }
        if let Ok(i) = value.parse::<i64>() { return ConfigValue::Int(i); }
        if let Ok(f) = value.parse::<f64>() { return ConfigValue::Float(f); }
        ConfigValue::String(value.to_string())
    }
}

