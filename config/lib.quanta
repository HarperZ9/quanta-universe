/// Root configuration for the entire universe
#[derive(Debug, Clone)]
pub struct UniverseConfig {
    pub version: String,
    pub environment: Environment,
    pub modules: ModulesConfig,
    pub rendering: RenderingConfig,
    pub trading: TradingConfig,
    pub ai: AIConfig,
    pub integration: IntegrationConfig,
    pub logging: LoggingConfig,
    pub paths: PathsConfig,
}

impl UniverseConfig {
    pub fn default() -> Self {
        UniverseConfig {
            version: "2.0.0".to_string(),
            environment: Environment::Development,
            modules: ModulesConfig::default(),
            rendering: RenderingConfig::default(),
            trading: TradingConfig::default(),
            ai: AIConfig::default(),
            integration: IntegrationConfig::default(),
            logging: LoggingConfig::default(),
            paths: PathsConfig::default(),
        }
    }

    pub fn production() -> Self {
        let mut config = Self::default();
        config.environment = Environment::Production;
        config.logging.level = LogLevel::Warn;
        config.rendering.vsync = true;
        config
    }

    /// Load configuration from file
    pub fn load(path: &Path) -> Result<Self, ConfigError> {
        let content = read_to_string(path)
            .map_err(|e| ConfigError::IoError(e.to_string()))?;
        Self::parse(&content)
    }

    /// Save configuration to file
    pub fn save(&self, path: &Path) -> Result<(), ConfigError> {
        let content = self.serialize();
        write_string(path, &content)
            .map_err(|e| ConfigError::IoError(e.to_string()))
    }

    /// Parse configuration from TOML string
    pub fn parse(content: &str) -> Result<Self, ConfigError> {
        // Simple TOML parser for key sections
        let mut config = Self::default();

        for line in content.lines() {
            let line = line.trim();
            if line.is_empty() || line.starts_with('#') {
                continue;
            }

            if let Some((key, value)) = line.split_once('=') {
                let key = key.trim();
                let value = value.trim().trim_matches('"');

                match key {
                    "version" => config.version = value.to_string(),
                    "environment" => {
                        config.environment = match value {
                            "production" => Environment::Production,
                            "staging" => Environment::Staging,
                            _ => Environment::Development,
                        };
                    }
                    "logging.level" => {
                        config.logging.level = match value {
                            "trace" => LogLevel::Trace,
                            "debug" => LogLevel::Debug,
                            "info" => LogLevel::Info,
                            "warn" => LogLevel::Warn,
                            "error" => LogLevel::Error,
                            _ => LogLevel::Info,
                        };
                    }
                    _ => {}
                }
            }
        }

        Ok(config)
    }

    /// Serialize configuration to TOML
    pub fn serialize(&self) -> String {
        let mut output = String::new();

        output.push_str("# QUANTA-UNIVERSE Configuration\n");
        output.push_str(&format!("version = \"{}\"\n", self.version));
        output.push_str(&format!("environment = \"{:?}\"\n", self.environment));
        output.push_str("\n");

        output.push_str("[logging]\n");
        output.push_str(&format!("level = \"{:?}\"\n", self.logging.level));
        output.push_str(&format!("file = \"{}\"\n", self.logging.file.display()));
        output.push_str("\n");

        output.push_str("[rendering]\n");
        output.push_str(&format!("resolution_width = {}\n", self.rendering.resolution.0));
        output.push_str(&format!("resolution_height = {}\n", self.rendering.resolution.1));
        output.push_str(&format!("vsync = {}\n", self.rendering.vsync));
        output.push_str(&format!("hdr = {}\n", self.rendering.hdr));
        output.push_str("\n");

        output.push_str("[trading]\n");
        output.push_str(&format!("paper_trading = {}\n", self.trading.paper_trading));
        output.push_str(&format!("max_position_size = {}\n", self.trading.max_position_size));
        output.push_str("\n");

        output.push_str("[ai]\n");
        output.push_str(&format!("model_cache_size_mb = {}\n", self.ai.model_cache_size_mb));
        output.push_str(&format!("inference_threads = {}\n", self.ai.inference_threads));

        output
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Environment {
    Development,
    Staging,
    Production,
}

