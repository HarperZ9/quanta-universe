        ConfigError::NotSupported(format!("Feature '{}' is not supported", feature))
    }
}

#[derive(Debug)]
pub enum ConfigError {
    IoError(String),
    ParseError(String),
    ValidationError(String),
    NotFound(String),
    NotSupported(String),
    EncryptionError(String),
    NetworkError(String),
    AuthenticationError(String),
    RateLimitError(String),
    TimeoutError(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_default_config() {
        let config = UniverseConfig::default();
        assert_eq!(config.version, "2.0.0");
        assert_eq!(config.environment, Environment::Development);
    }

    #[test]
    fn test_serialize_parse() {
        let config = UniverseConfig::default();
        let serialized = config.serialize();
        let parsed = UniverseConfig::parse(&serialized).unwrap();
        assert_eq!(config.version, parsed.version);
    }

    #[test]
    fn test_rendering_presets() {
        let default = RenderingConfig::default();
        assert_eq!(default.resolution, (1920, 1080));

        let hq = RenderingConfig::high_quality();
        assert_eq!(hq.resolution, (3840, 2160));
        assert!(hq.hdr);
    }

    #[test]
    fn test_config_value_merge() {
        let a = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("x".to_string(), ConfigValue::Int(1));
            m.insert("y".to_string(), ConfigValue::Int(2));
            m
        });
        let b = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("y".to_string(), ConfigValue::Int(3));
            m.insert("z".to_string(), ConfigValue::Int(4));
            m
        });
        let merged = a.merge(&b);
        if let ConfigValue::Object(obj) = merged {
            assert_eq!(obj.get("x"), Some(&ConfigValue::Int(1)));
            assert_eq!(obj.get("y"), Some(&ConfigValue::Int(3)));
            assert_eq!(obj.get("z"), Some(&ConfigValue::Int(4)));
        }
    }

    #[test]
    fn test_config_diff() {
        let old = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("a".to_string(), ConfigValue::Int(1));
            m.insert("b".to_string(), ConfigValue::Int(2));
            m
        });
        let new = ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("a".to_string(), ConfigValue::Int(1));
            m.insert("b".to_string(), ConfigValue::Int(3));
            m.insert("c".to_string(), ConfigValue::Int(4));
            m
        });
        let diff = ConfigDiff::compute(&old, &new);
        assert!(diff.has_changes());
        assert_eq!(diff.added().len(), 1);
        assert_eq!(diff.modified().len(), 1);
    }

    #[test]
    fn test_semantic_version() {
        let v1 = SemanticVersion::new(1, 2, 3);
        let v2 = SemanticVersion::new(1, 2, 4);
        assert!(v1 < v2);

        let parsed = SemanticVersion::parse("2.0.0-beta").unwrap();
        assert_eq!(parsed.major, 2);
        assert_eq!(parsed.prerelease, Some("beta".to_string()));
    }

    #[test]
    fn test_template_engine() {
        let mut engine = ConfigTemplateEngine::new();
        engine.set_variable("name", "world");

        let result = engine.render("Hello ${name}!").unwrap();
        assert_eq!(result, "Hello world!");
    }

    #[test]
    fn test_feature_flag_evaluation() {
        let evaluator = FeatureEvaluator::new();
        let flag = FeatureFlag {
            name: "test-flag".to_string(),
            description: "Test flag".to_string(),
            enabled: true,
            rollout_percentage: 100.0,
            targeting: FeatureTargeting {
                rules: Vec::new(),
                default_variant: "control".to_string(),
            },
            variants: Vec::new(),
            created_at: 0,
            updated_at: 0,
        };
        let context = EvaluationContext {
            user_id: Some("user-123".to_string()),
            groups: Vec::new(),
            environment: "production".to_string(),
            attributes: HashMap::new(),
        };
        let result = evaluator.evaluate(&flag, &context);
        assert!(result.enabled);
    }

    #[test]
    fn test_profile_manager() {
        let mut pm = ProfileManager::new();
        pm.add_profile("dev", ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("debug".to_string(), ConfigValue::Bool(true));
            m
        }));
        pm.add_profile("prod", ConfigValue::Object({
            let mut m = HashMap::new();
            m.insert("debug".to_string(), ConfigValue::Bool(false));
            m
        }));

        pm.activate("prod").unwrap();
        let config = pm.get_resolved_config();
        if let Some(ConfigValue::Bool(debug)) = config.get("debug") {
            assert!(!debug);
        }
    }
}

