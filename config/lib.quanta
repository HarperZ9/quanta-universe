// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION VERSIONING AND MIGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration version manager
pub struct ConfigVersionManager {
    pub current_version: SemanticVersion,
    pub migrations: Vec<ConfigMigration>,
    pub history: Vec<ConfigSnapshot>,
    pub max_history: usize,
}

#[derive(Debug, Clone, PartialEq, Eq, PartialOrd, Ord)]
pub struct SemanticVersion {
    pub major: u32,
    pub minor: u32,
    pub patch: u32,
    pub prerelease: Option<String>,
}

impl SemanticVersion {
    pub fn new(major: u32, minor: u32, patch: u32) -> Self {
        SemanticVersion { major, minor, patch, prerelease: None }
    }

    pub fn parse(s: &str) -> Result<Self, ConfigError> {
        let parts: Vec<&str> = s.split('.').collect();
        if parts.len() < 3 {
            return Err(ConfigError::ParseError("Invalid version format".to_string()));
        }

        let major = parts[0].parse().map_err(|_| ConfigError::ParseError("Invalid major version".to_string()))?;
        let minor = parts[1].parse().map_err(|_| ConfigError::ParseError("Invalid minor version".to_string()))?;

        let (patch_str, prerelease) = if parts[2].contains('-') {
            let p: Vec<&str> = parts[2].splitn(2, '-').collect();
            (p[0], Some(p[1].to_string()))
        } else {
            (parts[2], None)
        };

        let patch = patch_str.parse().map_err(|_| ConfigError::ParseError("Invalid patch version".to_string()))?;

        Ok(SemanticVersion { major, minor, patch, prerelease })
    }

    pub fn to_string(&self) -> String {
        match &self.prerelease {
            Some(pre) => format!("{}.{}.{}-{}", self.major, self.minor, self.patch, pre),
            None => format!("{}.{}.{}", self.major, self.minor, self.patch),
        }
    }
}

pub struct ConfigMigration {
    pub from_version: SemanticVersion,
    pub to_version: SemanticVersion,
    pub description: String,
    pub migrate: Box<dyn Fn(&ConfigValue) -> Result<ConfigValue, ConfigError> + Send + Sync>,
    pub rollback: Box<dyn Fn(&ConfigValue) -> Result<ConfigValue, ConfigError> + Send + Sync>,
}

#[derive(Debug, Clone)]
pub struct ConfigSnapshot {
    pub version: SemanticVersion,
    pub timestamp: u64,
    pub config: ConfigValue,
    pub checksum: String,
    pub author: Option<String>,
    pub message: Option<String>,
}

impl ConfigVersionManager {
    pub fn new(version: SemanticVersion) -> Self {
        ConfigVersionManager {
            current_version: version,
            migrations: Vec::new(),
            history: Vec::new(),
            max_history: 100,
        }
    }

    pub fn add_migration(&mut self, migration: ConfigMigration) {
        self.migrations.push(migration);
        self.migrations.sort_by(|a, b| a.from_version.cmp(&b.from_version));
    }

    pub fn migrate(&self, config: &ConfigValue, from: &SemanticVersion, to: &SemanticVersion) -> Result<ConfigValue, ConfigError> {
        let mut current = config.clone();
        let mut current_version = from.clone();

        while current_version < *to {
            let migration = self.migrations.iter()
                .find(|m| m.from_version == current_version)
                .ok_or_else(|| ConfigError::NotFound(format!("No migration from {}", current_version.to_string())))?;

            current = (migration.migrate)(&current)?;
            current_version = migration.to_version.clone();
        }

        Ok(current)
    }

    pub fn rollback(&self, config: &ConfigValue, from: &SemanticVersion, to: &SemanticVersion) -> Result<ConfigValue, ConfigError> {
        let mut current = config.clone();
        let mut current_version = from.clone();

        while current_version > *to {
            let migration = self.migrations.iter()
                .find(|m| m.to_version == current_version)
                .ok_or_else(|| ConfigError::NotFound(format!("No migration to {}", current_version.to_string())))?;

            current = (migration.rollback)(&current)?;
            current_version = migration.from_version.clone();
        }

        Ok(current)
    }

    pub fn create_snapshot(&mut self, config: &ConfigValue, message: Option<&str>) -> ConfigSnapshot {
        let snapshot = ConfigSnapshot {
            version: self.current_version.clone(),
            timestamp: 0, // Would use actual timestamp
            config: config.clone(),
            checksum: self.compute_checksum(config),
            author: None,
            message: message.map(|s| s.to_string()),
        };

        self.history.push(snapshot.clone());
        if self.history.len() > self.max_history {
            self.history.remove(0);
        }

        snapshot
    }

    fn compute_checksum(&self, config: &ConfigValue) -> String {
        // Simple checksum for demonstration
        format!("{:x}", self.hash_value(config))
    }

    fn hash_value(&self, value: &ConfigValue) -> u64 {
        let mut hash: u64 = 0;
        match value {
            ConfigValue::Null => hash = hash.wrapping_mul(31).wrapping_add(0),
            ConfigValue::Bool(b) => hash = hash.wrapping_mul(31).wrapping_add(*b as u64),
            ConfigValue::Int(i) => hash = hash.wrapping_mul(31).wrapping_add(*i as u64),
            ConfigValue::Float(f) => hash = hash.wrapping_mul(31).wrapping_add((*f * 1000.0) as u64),
            ConfigValue::String(s) => {
                for byte in s.bytes() {
                    hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
                }
            }
            ConfigValue::Array(arr) => {
                for item in arr {
                    hash = hash.wrapping_mul(31).wrapping_add(self.hash_value(item));
                }
            }
            ConfigValue::Object(obj) => {
                for (k, v) in obj {
                    for byte in k.bytes() {
                        hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
                    }
                    hash = hash.wrapping_mul(31).wrapping_add(self.hash_value(v));
                }
            }
        }
        hash
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HOT RELOAD CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Hot reload manager for live configuration updates
pub struct HotReloadManager {
    pub watchers: Vec<FileWatcher>,
    pub debounce_ms: u64,
    pub callbacks: Vec<Box<dyn Fn(&ConfigValue, &ConfigValue) + Send + Sync>>,
    pub current_config: ConfigValue,
    pub pending_changes: Vec<PendingChange>,
    pub validation_enabled: bool,
    pub rollback_on_error: bool,
}

pub struct FileWatcher {
    pub path: PathBuf,
    pub last_modified: u64,
    pub format: ConfigFormat,
}

#[derive(Debug, Clone)]
pub struct PendingChange {
    pub source: String,
    pub old_value: ConfigValue,
    pub new_value: ConfigValue,
    pub timestamp: u64,
}

impl HotReloadManager {
    pub fn new(initial_config: ConfigValue) -> Self {
        HotReloadManager {
            watchers: Vec::new(),
            debounce_ms: 500,
            callbacks: Vec::new(),
            current_config: initial_config,
            pending_changes: Vec::new(),
            validation_enabled: true,
            rollback_on_error: true,
        }
    }

    pub fn watch_file(&mut self, path: PathBuf, format: ConfigFormat) {
        self.watchers.push(FileWatcher {
            path,
            last_modified: 0,
            format,
        });
    }

    pub fn on_change<F>(&mut self, callback: F)
    where
        F: Fn(&ConfigValue, &ConfigValue) + Send + Sync + 'static
    {
        self.callbacks.push(Box::new(callback));
    }

    pub fn apply_change(&mut self, new_config: ConfigValue) -> Result<(), ConfigError> {
        let old_config = self.current_config.clone();

        // Validate new config if enabled
        if self.validation_enabled {
            // Validation logic would go here
        }

        // Apply change
        self.current_config = new_config.clone();

        // Notify callbacks
        for callback in &self.callbacks {
            callback(&old_config, &self.current_config);
        }

        Ok(())
    }

    pub fn rollback(&mut self) -> Result<(), ConfigError> {
        if let Some(change) = self.pending_changes.pop() {
            self.current_config = change.old_value;
            Ok(())
        } else {
            Err(ConfigError::NotFound("No changes to rollback".to_string()))
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION TEMPLATING
// ═══════════════════════════════════════════════════════════════════════════════

/// Template engine for configuration values
pub struct ConfigTemplateEngine {
    pub variables: HashMap<String, String>,
    pub functions: HashMap<String, Box<dyn Fn(&[String]) -> String + Send + Sync>>,
    pub filters: HashMap<String, Box<dyn Fn(&str) -> String + Send + Sync>>,
}

impl ConfigTemplateEngine {
    pub fn new() -> Self {
        let mut engine = ConfigTemplateEngine {
            variables: HashMap::new(),
            functions: HashMap::new(),
            filters: HashMap::new(),
        };

        // Register default functions
        engine.register_function("env", |args| {
            if let Some(name) = args.first() {
                env::var(name).unwrap_or_default()
            } else {
                String::new()
            }
        });

        engine.register_function("default", |args| {
            if args.len() >= 2 {
                if args[0].is_empty() { args[1].clone() } else { args[0].clone() }
            } else {
                args.first().cloned().unwrap_or_default()
            }
        });

        engine.register_function("concat", |args| {
            args.join("")
        });

        // Register default filters
        engine.register_filter("upper", |s| s.to_uppercase());
        engine.register_filter("lower", |s| s.to_lowercase());
        engine.register_filter("trim", |s| s.trim().to_string());
        engine.register_filter("base64", |s| {
            // Simple base64 encoding
            let bytes = s.as_bytes();
            let mut result = String::new();
            for chunk in bytes.chunks(3) {
                let n = (chunk.get(0).copied().unwrap_or(0) as u32) << 16
                      | (chunk.get(1).copied().unwrap_or(0) as u32) << 8
                      | (chunk.get(2).copied().unwrap_or(0) as u32);
                let chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
                result.push(chars.chars().nth(((n >> 18) & 0x3F) as usize).unwrap());
                result.push(chars.chars().nth(((n >> 12) & 0x3F) as usize).unwrap());
                if chunk.len() > 1 {
                    result.push(chars.chars().nth(((n >> 6) & 0x3F) as usize).unwrap());
                }
                if chunk.len() > 2 {
                    result.push(chars.chars().nth((n & 0x3F) as usize).unwrap());
                }
            }
            result
        });

        engine
    }

    pub fn set_variable(&mut self, name: &str, value: &str) {
        self.variables.insert(name.to_string(), value.to_string());
    }

    pub fn register_function<F>(&mut self, name: &str, func: F)
    where
        F: Fn(&[String]) -> String + Send + Sync + 'static
    {
        self.functions.insert(name.to_string(), Box::new(func));
    }

    pub fn register_filter<F>(&mut self, name: &str, filter: F)
    where
        F: Fn(&str) -> String + Send + Sync + 'static
    {
        self.filters.insert(name.to_string(), Box::new(filter));
    }

    pub fn render(&self, template: &str) -> Result<String, ConfigError> {
        let mut result = template.to_string();

        // Process function calls: {{ func(arg1, arg2) }}
        while let Some(start) = result.find("{{") {
            if let Some(end) = result[start..].find("}}") {
                let end = start + end + 2;
                let expr = result[start+2..end-2].trim();
                let value = self.evaluate_expression(expr)?;
                result = format!("{}{}{}", &result[..start], value, &result[end..]);
            } else {
                break;
            }
        }

        // Process variable substitutions: ${VAR}
        while let Some(start) = result.find("${") {
            if let Some(end) = result[start..].find('}') {
                let end = start + end + 1;
                let var_name = &result[start+2..end-1];
                let value = self.variables.get(var_name)
                    .cloned()
                    .unwrap_or_default();
                result = format!("{}{}{}", &result[..start], value, &result[end..]);
            } else {
                break;
            }
        }

        Ok(result)
    }

    fn evaluate_expression(&self, expr: &str) -> Result<String, ConfigError> {
        // Check for filter: value | filter
        if let Some(pipe_pos) = expr.find('|') {
            let value = expr[..pipe_pos].trim();
            let filter_name = expr[pipe_pos+1..].trim();

            let evaluated_value = self.evaluate_expression(value)?;
            if let Some(filter) = self.filters.get(filter_name) {
                return Ok(filter(&evaluated_value));
            }
        }

        // Check for function call: func(args)
        if let Some(paren_pos) = expr.find('(') {
            if expr.ends_with(')') {
                let func_name = expr[..paren_pos].trim();
                let args_str = &expr[paren_pos+1..expr.len()-1];
                let args: Vec<String> = args_str.split(',')
                    .map(|a| a.trim().trim_matches('"').trim_matches('\'').to_string())
                    .collect();

                if let Some(func) = self.functions.get(func_name) {
                    return Ok(func(&args));
                }
            }
        }

        // Check for variable
        if let Some(value) = self.variables.get(expr.trim()) {
            return Ok(value.clone());
        }

        // Return as literal
        Ok(expr.trim_matches('"').trim_matches('\'').to_string())
    }

    pub fn render_config(&self, config: &ConfigValue) -> Result<ConfigValue, ConfigError> {
        match config {
            ConfigValue::String(s) => Ok(ConfigValue::String(self.render(s)?)),
            ConfigValue::Array(arr) => {
                let rendered: Result<Vec<ConfigValue>, ConfigError> = arr.iter()
                    .map(|v| self.render_config(v))
                    .collect();
                Ok(ConfigValue::Array(rendered?))
            }
            ConfigValue::Object(obj) => {
                let mut rendered = HashMap::new();
                for (k, v) in obj {
                    rendered.insert(k.clone(), self.render_config(v)?);
                }
                Ok(ConfigValue::Object(rendered))
            }
            _ => Ok(config.clone()),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION DIFF AND COMPARISON
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration diff engine
pub struct ConfigDiff {
    pub changes: Vec<ConfigChange>,
}

#[derive(Debug, Clone)]
pub struct ConfigChange {
    pub path: String,
    pub change_type: ChangeType,
    pub old_value: Option<ConfigValue>,
    pub new_value: Option<ConfigValue>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ChangeType {
    Added,
    Removed,
    Modified,
    Unchanged,
}

impl ConfigDiff {
    pub fn compute(old: &ConfigValue, new: &ConfigValue) -> Self {
        let mut changes = Vec::new();
        Self::diff_values(old, new, "", &mut changes);
        ConfigDiff { changes }
    }

    fn diff_values(old: &ConfigValue, new: &ConfigValue, path: &str, changes: &mut Vec<ConfigChange>) {
        match (old, new) {
            (ConfigValue::Object(old_obj), ConfigValue::Object(new_obj)) => {
                // Check for removed keys
                for key in old_obj.keys() {
                    if !new_obj.contains_key(key) {
                        let full_path = if path.is_empty() { key.clone() } else { format!("{}.{}", path, key) };
                        changes.push(ConfigChange {
                            path: full_path,
                            change_type: ChangeType::Removed,
                            old_value: old_obj.get(key).cloned(),
                            new_value: None,
                        });
                    }
                }

                // Check for added or modified keys
                for (key, new_val) in new_obj {
                    let full_path = if path.is_empty() { key.clone() } else { format!("{}.{}", path, key) };

                    if let Some(old_val) = old_obj.get(key) {
                        if old_val != new_val {
                            Self::diff_values(old_val, new_val, &full_path, changes);
                        }
                    } else {
                        changes.push(ConfigChange {
                            path: full_path,
                            change_type: ChangeType::Added,
                            old_value: None,
                            new_value: Some(new_val.clone()),
                        });
                    }
                }
            }
            (ConfigValue::Array(old_arr), ConfigValue::Array(new_arr)) => {
                if old_arr.len() != new_arr.len() {
                    changes.push(ConfigChange {
                        path: path.to_string(),
                        change_type: ChangeType::Modified,
                        old_value: Some(ConfigValue::Array(old_arr.clone())),
                        new_value: Some(ConfigValue::Array(new_arr.clone())),
                    });
                } else {
                    for (i, (old_item, new_item)) in old_arr.iter().zip(new_arr.iter()).enumerate() {
                        let item_path = format!("{}[{}]", path, i);
                        Self::diff_values(old_item, new_item, &item_path, changes);
                    }
                }
            }
            _ => {
                if old != new {
                    changes.push(ConfigChange {
                        path: path.to_string(),
                        change_type: ChangeType::Modified,
                        old_value: Some(old.clone()),
                        new_value: Some(new.clone()),
                    });
                }
            }
        }
    }

    pub fn has_changes(&self) -> bool {
        !self.changes.is_empty()
    }

    pub fn added(&self) -> Vec<&ConfigChange> {
        self.changes.iter().filter(|c| c.change_type == ChangeType::Added).collect()
    }

    pub fn removed(&self) -> Vec<&ConfigChange> {
        self.changes.iter().filter(|c| c.change_type == ChangeType::Removed).collect()
    }

    pub fn modified(&self) -> Vec<&ConfigChange> {
        self.changes.iter().filter(|c| c.change_type == ChangeType::Modified).collect()
    }

    pub fn apply(&self, config: &ConfigValue) -> ConfigValue {
        let mut result = config.clone();
        for change in &self.changes {
            match change.change_type {
                ChangeType::Added | ChangeType::Modified => {
                    if let Some(ref new_val) = change.new_value {
                        result = Self::set_path(&result, &change.path, new_val.clone());
                    }
                }
                ChangeType::Removed => {
                    result = Self::remove_path(&result, &change.path);
                }
                ChangeType::Unchanged => {}
            }
        }
        result
    }

    fn set_path(config: &ConfigValue, path: &str, value: ConfigValue) -> ConfigValue {
        if path.is_empty() {
            return value;
        }

        let parts: Vec<&str> = path.splitn(2, '.').collect();
        let key = parts[0];
        let rest = parts.get(1).copied().unwrap_or("");

        match config {
            ConfigValue::Object(obj) => {
                let mut new_obj = obj.clone();
                if rest.is_empty() {
                    new_obj.insert(key.to_string(), value);
                } else {
                    let existing = new_obj.get(key).cloned().unwrap_or(ConfigValue::Object(HashMap::new()));
                    new_obj.insert(key.to_string(), Self::set_path(&existing, rest, value));
                }
                ConfigValue::Object(new_obj)
            }
            _ => config.clone(),
        }
    }

    fn remove_path(config: &ConfigValue, path: &str) -> ConfigValue {
        if path.is_empty() {
            return ConfigValue::Null;
        }

        let parts: Vec<&str> = path.splitn(2, '.').collect();
        let key = parts[0];
        let rest = parts.get(1).copied().unwrap_or("");

        match config {
            ConfigValue::Object(obj) => {
                let mut new_obj = obj.clone();
                if rest.is_empty() {
                    new_obj.remove(key);
                } else if let Some(existing) = new_obj.get(key) {
                    new_obj.insert(key.to_string(), Self::remove_path(existing, rest));
                }
                ConfigValue::Object(new_obj)
            }
            _ => config.clone(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROFILE-BASED CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Profile manager for environment-specific configurations
pub struct ProfileManager {
    pub profiles: HashMap<String, ConfigValue>,
    pub active_profile: String,
    pub inheritance: HashMap<String, Vec<String>>,
    pub overrides: ConfigValue,
}

impl ProfileManager {
    pub fn new() -> Self {
        ProfileManager {
            profiles: HashMap::new(),
            active_profile: "default".to_string(),
            inheritance: HashMap::new(),
            overrides: ConfigValue::Object(HashMap::new()),
        }
    }

    pub fn add_profile(&mut self, name: &str, config: ConfigValue) {
        self.profiles.insert(name.to_string(), config);
    }

    pub fn set_inheritance(&mut self, profile: &str, parents: Vec<String>) {
        self.inheritance.insert(profile.to_string(), parents);
    }

    pub fn activate(&mut self, profile: &str) -> Result<(), ConfigError> {
        if !self.profiles.contains_key(profile) {
            return Err(ConfigError::NotFound(format!("Profile '{}' not found", profile)));
        }
        self.active_profile = profile.to_string();
        Ok(())
    }

    pub fn get_resolved_config(&self) -> ConfigValue {
        let mut config = ConfigValue::Object(HashMap::new());

        // Apply inherited profiles
        if let Some(parents) = self.inheritance.get(&self.active_profile) {
            for parent in parents {
                if let Some(parent_config) = self.profiles.get(parent) {
                    config = config.merge(parent_config);
                }
            }
        }

        // Apply active profile
        if let Some(active_config) = self.profiles.get(&self.active_profile) {
            config = config.merge(active_config);
        }

        // Apply overrides
        config.merge(&self.overrides)
    }

    pub fn set_override(&mut self, path: &str, value: ConfigValue) {
        self.overrides = ConfigDiff::set_path(&self.overrides, path, value);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-TENANCY CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Multi-tenant configuration manager
pub struct TenantConfigManager {
    pub tenants: HashMap<String, TenantConfig>,
    pub global_config: ConfigValue,
    pub feature_flags: FeatureManager,
    pub quotas: HashMap<String, TenantQuota>,
}

#[derive(Debug, Clone)]
pub struct TenantConfig {
    pub tenant_id: String,
    pub name: String,
    pub config: ConfigValue,
    pub tier: TenantTier,
    pub created_at: u64,
    pub enabled: bool,
    pub metadata: HashMap<String, String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TenantTier {
    Free,
    Basic,
    Professional,
    Enterprise,
    Custom,
}

#[derive(Debug, Clone)]
pub struct TenantQuota {
    pub api_requests_per_minute: u64,
    pub storage_bytes: u64,
    pub max_users: u64,
    pub max_projects: u64,
    pub custom_limits: HashMap<String, u64>,
}

impl TenantConfigManager {
    pub fn new(global_config: ConfigValue) -> Self {
        TenantConfigManager {
            tenants: HashMap::new(),
            global_config,
            feature_flags: FeatureManager {
                flags: HashMap::new(),
                providers: Vec::new(),
                evaluator: FeatureEvaluator::new(),
                cache: FeatureFlagCache {
                    flags: HashMap::new(),
                    ttl_ms: 60000,
                },
            },
            quotas: HashMap::new(),
        }
    }

    pub fn add_tenant(&mut self, tenant: TenantConfig) {
        let quota = self.default_quota_for_tier(tenant.tier);
        self.quotas.insert(tenant.tenant_id.clone(), quota);
        self.tenants.insert(tenant.tenant_id.clone(), tenant);
    }

    pub fn get_tenant_config(&self, tenant_id: &str) -> Option<ConfigValue> {
        self.tenants.get(tenant_id).map(|t| {
            self.global_config.merge(&t.config)
        })
    }

    pub fn update_tenant_config(&mut self, tenant_id: &str, config: ConfigValue) -> Result<(), ConfigError> {
        if let Some(tenant) = self.tenants.get_mut(tenant_id) {
            tenant.config = config;
            Ok(())
        } else {
            Err(ConfigError::NotFound(format!("Tenant '{}' not found", tenant_id)))
        }
    }

    fn default_quota_for_tier(&self, tier: TenantTier) -> TenantQuota {
        match tier {
            TenantTier::Free => TenantQuota {
                api_requests_per_minute: 60,
                storage_bytes: 1024 * 1024 * 100, // 100MB
                max_users: 3,
                max_projects: 1,
                custom_limits: HashMap::new(),
            },
            TenantTier::Basic => TenantQuota {
                api_requests_per_minute: 300,
                storage_bytes: 1024 * 1024 * 1024, // 1GB
                max_users: 10,
                max_projects: 5,
                custom_limits: HashMap::new(),
            },
            TenantTier::Professional => TenantQuota {
                api_requests_per_minute: 1000,
                storage_bytes: 1024 * 1024 * 1024 * 10, // 10GB
                max_users: 50,
                max_projects: 25,
                custom_limits: HashMap::new(),
            },
            TenantTier::Enterprise => TenantQuota {
                api_requests_per_minute: 10000,
                storage_bytes: 1024 * 1024 * 1024 * 100, // 100GB
                max_users: u64::MAX,
                max_projects: u64::MAX,
                custom_limits: HashMap::new(),
            },
            TenantTier::Custom => TenantQuota {
                api_requests_per_minute: 0,
                storage_bytes: 0,
                max_users: 0,
                max_projects: 0,
                custom_limits: HashMap::new(),
            },
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SERVICE MESH CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Service mesh configuration for microservices
pub struct ServiceMeshConfig {
    pub services: HashMap<String, ServiceConfig>,
    pub routes: Vec<RouteConfig>,
    pub load_balancing: LoadBalancingConfig,
    pub circuit_breakers: HashMap<String, CircuitBreakerConfig>,
    pub rate_limits: HashMap<String, RateLimitConfig>,
    pub retries: RetryConfig,
    pub timeouts: TimeoutConfig,
    pub tls: TlsConfig,
    pub tracing: TracingConfig,
}

#[derive(Debug, Clone)]
pub struct ServiceConfig {
    pub name: String,
    pub version: String,
    pub endpoints: Vec<EndpointConfig>,
    pub health_check: HealthCheckConfig,
    pub labels: HashMap<String, String>,
}

#[derive(Debug, Clone)]
pub struct EndpointConfig {
    pub host: String,
    pub port: u16,
    pub protocol: Protocol,
    pub weight: u32,
    pub zone: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Protocol {
    Http,
    Https,
    Http2,
    Grpc,
    Tcp,
    Udp,
}

#[derive(Debug, Clone)]
pub struct HealthCheckConfig {
    pub path: String,
    pub interval_ms: u64,
    pub timeout_ms: u64,
    pub unhealthy_threshold: u32,
    pub healthy_threshold: u32,
}

#[derive(Debug, Clone)]
pub struct RouteConfig {
    pub match_rule: RouteMatch,
    pub destination: String,
    pub weight: u32,
    pub headers: HashMap<String, String>,
    pub timeout_ms: Option<u64>,
    pub retries: Option<u32>,
}

#[derive(Debug, Clone)]
pub struct RouteMatch {
    pub path: Option<PathMatch>,
    pub headers: Vec<HeaderMatch>,
    pub methods: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum PathMatch {
    Exact(String),
    Prefix(String),
    Regex(String),
}

#[derive(Debug, Clone)]
pub struct HeaderMatch {
    pub name: String,
    pub match_type: HeaderMatchType,
    pub value: String,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HeaderMatchType {
    Exact,
    Prefix,
    Suffix,
    Regex,
    Present,
}

#[derive(Debug, Clone)]
pub struct LoadBalancingConfig {
    pub strategy: LoadBalancingStrategy,
    pub hash_key: Option<String>,
    pub zone_aware: bool,
    pub panic_threshold: f64,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LoadBalancingStrategy {
    RoundRobin,
    LeastConnections,
    Random,
    WeightedRoundRobin,
    ConsistentHash,
    Maglev,
}

#[derive(Debug, Clone)]
pub struct CircuitBreakerConfig {
    pub enabled: bool,
    pub threshold: u32,
    pub timeout_ms: u64,
    pub half_open_requests: u32,
    pub consecutive_failures: u32,
    pub interval_ms: u64,
}

#[derive(Debug, Clone)]
pub struct RateLimitConfig {
    pub enabled: bool,
    pub requests_per_second: u32,
    pub burst_size: u32,
    pub response_headers: bool,
}

#[derive(Debug, Clone)]
pub struct RetryConfig {
    pub max_retries: u32,
    pub per_try_timeout_ms: u64,
    pub retry_on: Vec<String>,
    pub retriable_status_codes: Vec<u32>,
    pub backoff: BackoffConfig,
}

#[derive(Debug, Clone)]
pub struct BackoffConfig {
    pub base_interval_ms: u64,
    pub max_interval_ms: u64,
    pub multiplier: f64,
    pub jitter: f64,
}

#[derive(Debug, Clone)]
pub struct TimeoutConfig {
    pub connect_timeout_ms: u64,
    pub request_timeout_ms: u64,
    pub idle_timeout_ms: u64,
    pub stream_idle_timeout_ms: u64,
}

#[derive(Debug, Clone)]
pub struct TlsConfig {
    pub enabled: bool,
    pub mutual_tls: bool,
    pub min_version: TlsVersion,
    pub cipher_suites: Vec<String>,
    pub alpn_protocols: Vec<String>,
    pub certificate_path: Option<PathBuf>,
    pub private_key_path: Option<PathBuf>,
    pub ca_certificate_path: Option<PathBuf>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TlsVersion {
    Tls10,
    Tls11,
    Tls12,
    Tls13,
}

#[derive(Debug, Clone)]
pub struct TracingConfig {
    pub enabled: bool,
    pub sampling_rate: f64,
    pub propagation: TracePropagation,
    pub exporter: TraceExporter,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TracePropagation {
    B3,
    W3C,
    Jaeger,
    OpenTelemetry,
}

#[derive(Debug, Clone)]
pub enum TraceExporter {
    Jaeger { endpoint: String },
    Zipkin { endpoint: String },
    Otlp { endpoint: String },
    Console,
}

impl ServiceMeshConfig {
    pub fn new() -> Self {
        ServiceMeshConfig {
            services: HashMap::new(),
            routes: Vec::new(),
            load_balancing: LoadBalancingConfig {
                strategy: LoadBalancingStrategy::RoundRobin,
                hash_key: None,
                zone_aware: false,
                panic_threshold: 0.5,
            },
            circuit_breakers: HashMap::new(),
            rate_limits: HashMap::new(),
            retries: RetryConfig {
                max_retries: 3,
                per_try_timeout_ms: 5000,
                retry_on: vec!["5xx".to_string(), "reset".to_string()],
                retriable_status_codes: vec![502, 503, 504],
                backoff: BackoffConfig {
                    base_interval_ms: 100,
                    max_interval_ms: 10000,
                    multiplier: 2.0,
                    jitter: 0.1,
                },
            },
            timeouts: TimeoutConfig {
                connect_timeout_ms: 5000,
                request_timeout_ms: 30000,
                idle_timeout_ms: 300000,
                stream_idle_timeout_ms: 60000,
            },
            tls: TlsConfig {
                enabled: true,
                mutual_tls: false,
                min_version: TlsVersion::Tls12,
                cipher_suites: Vec::new(),
                alpn_protocols: vec!["h2".to_string(), "http/1.1".to_string()],
                certificate_path: None,
                private_key_path: None,
                ca_certificate_path: None,
            },
            tracing: TracingConfig {
                enabled: true,
                sampling_rate: 0.01,
                propagation: TracePropagation::W3C,
                exporter: TraceExporter::Otlp { endpoint: "http://localhost:4317".to_string() },
            },
        }
    }

    pub fn add_service(&mut self, service: ServiceConfig) {
        self.services.insert(service.name.clone(), service);
    }

    pub fn add_route(&mut self, route: RouteConfig) {
        self.routes.push(route);
    }

    pub fn set_circuit_breaker(&mut self, service: &str, config: CircuitBreakerConfig) {
        self.circuit_breakers.insert(service.to_string(), config);
    }

    pub fn set_rate_limit(&mut self, service: &str, config: RateLimitConfig) {
        self.rate_limits.insert(service.to_string(), config);
    }
}

