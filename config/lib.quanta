// CONFIGURATION MONITORING AND TELEMETRY
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration monitoring system for tracking changes and usage
pub struct ConfigMonitor {
    pub metrics: ConfigMetrics,
    pub alerts: Vec<ConfigAlert>,
    pub alert_rules: Vec<AlertRule>,
    pub event_log: ConfigEventLog,
    pub subscribers: Vec<Box<dyn ConfigEventSubscriber + Send + Sync>>,
    pub sampling_rate: f64,
    pub enabled: bool,
}

/// Configuration metrics collector
pub struct ConfigMetrics {
    pub access_counts: HashMap<String, AccessMetric>,
    pub change_counts: HashMap<String, u64>,
    pub error_counts: HashMap<String, u64>,
    pub latency_histograms: HashMap<String, LatencyHistogram>,
    pub cache_stats: CacheStats,
    pub provider_stats: HashMap<String, ProviderStats>,
}

#[derive(Debug, Clone)]
pub struct AccessMetric {
    pub total_accesses: u64,
    pub unique_accessors: u64,
    pub last_accessed: u64,
    pub average_latency_ms: f64,
    pub peak_latency_ms: f64,
    pub by_operation: HashMap<AccessOperation, u64>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum AccessOperation {
    Read,
    Write,
    Delete,
    Watch,
    Validate,
    Template,
}

#[derive(Debug, Clone)]
pub struct LatencyHistogram {
    pub buckets: Vec<LatencyBucket>,
    pub sum: f64,
    pub count: u64,
    pub min: f64,
    pub max: f64,
}

#[derive(Debug, Clone)]
pub struct LatencyBucket {
    pub le: f64,  // Less than or equal
    pub count: u64,
}

impl LatencyHistogram {
    pub fn new() -> Self {
        LatencyHistogram {
            buckets: vec![
                LatencyBucket { le: 0.001, count: 0 },  // 1ms
                LatencyBucket { le: 0.005, count: 0 },  // 5ms
                LatencyBucket { le: 0.01, count: 0 },   // 10ms
                LatencyBucket { le: 0.025, count: 0 },  // 25ms
                LatencyBucket { le: 0.05, count: 0 },   // 50ms
                LatencyBucket { le: 0.1, count: 0 },    // 100ms
                LatencyBucket { le: 0.25, count: 0 },   // 250ms
                LatencyBucket { le: 0.5, count: 0 },    // 500ms
                LatencyBucket { le: 1.0, count: 0 },    // 1s
                LatencyBucket { le: f64::INFINITY, count: 0 },
            ],
            sum: 0.0,
            count: 0,
            min: f64::INFINITY,
            max: 0.0,
        }
    }

    pub fn observe(&mut self, latency: f64) {
        self.sum += latency;
        self.count += 1;
        if latency < self.min { self.min = latency; }
        if latency > self.max { self.max = latency; }

        for bucket in &mut self.buckets {
            if latency <= bucket.le {
                bucket.count += 1;
            }
        }
    }

    pub fn percentile(&self, p: f64) -> f64 {
        if self.count == 0 { return 0.0; }
        let target = (self.count as f64 * p / 100.0) as u64;

        for (i, bucket) in self.buckets.iter().enumerate() {
            if bucket.count >= target {
                if i == 0 { return bucket.le; }
                let prev = &self.buckets[i - 1];
                // Linear interpolation
                let ratio = (target - prev.count) as f64 / (bucket.count - prev.count) as f64;
                return prev.le + ratio * (bucket.le - prev.le);
            }
        }
        self.max
    }
}

#[derive(Debug, Clone)]
pub struct CacheStats {
    pub hits: u64,
    pub misses: u64,
    pub evictions: u64,
    pub size_bytes: usize,
    pub item_count: usize,
    pub hit_rate: f64,
}

#[derive(Debug, Clone)]
pub struct ProviderStats {
    pub name: String,
    pub load_count: u64,
    pub error_count: u64,
    pub last_load_time: u64,
    pub average_load_latency_ms: f64,
    pub total_bytes_loaded: u64,
}

/// Configuration alert
#[derive(Debug, Clone)]
pub struct ConfigAlert {
    pub id: String,
    pub severity: AlertSeverity,
    pub rule_name: String,
    pub message: String,
    pub config_path: String,
    pub triggered_at: u64,
    pub resolved_at: Option<u64>,
    pub metadata: HashMap<String, String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum AlertSeverity {
    Info,
    Warning,
    Error,
    Critical,
}

/// Alert rule definition
#[derive(Debug, Clone)]
pub struct AlertRule {
    pub name: String,
    pub description: String,
    pub condition: AlertCondition,
    pub severity: AlertSeverity,
    pub actions: Vec<AlertAction>,
    pub cooldown_seconds: u64,
    pub enabled: bool,
    pub last_triggered: Option<u64>,
}

#[derive(Debug, Clone)]
pub enum AlertCondition {
    /// Config path hasn't been read in specified duration
    Stale { path: String, max_age_seconds: u64 },
    /// Error rate exceeds threshold
    ErrorRate { threshold: f64, window_seconds: u64 },
    /// Latency exceeds threshold
    HighLatency { path: String, threshold_ms: f64, percentile: f64 },
    /// Config value matches pattern
    ValueMatch { path: String, pattern: String },
    /// Config value changed
    ValueChanged { path: String },
    /// Custom condition
    Custom { evaluator: String },
    /// Compound conditions
    And { conditions: Vec<AlertCondition> },
    Or { conditions: Vec<AlertCondition> },
    Not { condition: Box<AlertCondition> },
}

#[derive(Debug, Clone)]
pub enum AlertAction {
    Log { level: LogLevel },
    Email { recipients: Vec<String> },
    Webhook { url: String, method: String },
    Slack { channel: String, webhook_url: String },
    PagerDuty { service_key: String },
    Custom { handler: String },
}

/// Configuration event log
pub struct ConfigEventLog {
    pub events: Vec<ConfigEvent>,
    pub max_events: usize,
    pub retention_seconds: u64,
}

#[derive(Debug, Clone)]
pub struct ConfigEvent {
    pub id: String,
    pub event_type: ConfigEventType,
    pub timestamp: u64,
    pub path: String,
    pub old_value: Option<ConfigValue>,
    pub new_value: Option<ConfigValue>,
    pub source: String,
    pub actor: Option<String>,
    pub metadata: HashMap<String, String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ConfigEventType {
    Read,
    Write,
    Delete,
    Reload,
    ValidationError,
    ProviderError,
    CacheHit,
    CacheMiss,
    HotReload,
    MigrationApplied,
    SecretAccessed,
    FeatureFlagEvaluated,
}

/// Trait for config event subscribers
pub trait ConfigEventSubscriber {
    fn on_event(&self, event: &ConfigEvent);
    fn event_types(&self) -> Vec<ConfigEventType>;
}

impl ConfigMonitor {
    pub fn new() -> Self {
        ConfigMonitor {
            metrics: ConfigMetrics {
                access_counts: HashMap::new(),
                change_counts: HashMap::new(),
                error_counts: HashMap::new(),
                latency_histograms: HashMap::new(),
                cache_stats: CacheStats {
                    hits: 0,
                    misses: 0,
                    evictions: 0,
                    size_bytes: 0,
                    item_count: 0,
                    hit_rate: 0.0,
                },
                provider_stats: HashMap::new(),
            },
            alerts: Vec::new(),
            alert_rules: Vec::new(),
            event_log: ConfigEventLog {
                events: Vec::new(),
                max_events: 100000,
                retention_seconds: 86400 * 7, // 7 days
            },
            subscribers: Vec::new(),
            sampling_rate: 1.0,
            enabled: true,
        }
    }

    pub fn record_access(&mut self, path: &str, operation: AccessOperation, latency_ms: f64) {
        if !self.enabled { return; }

        let metric = self.metrics.access_counts
            .entry(path.to_string())
            .or_insert_with(|| AccessMetric {
                total_accesses: 0,
                unique_accessors: 0,
                last_accessed: 0,
                average_latency_ms: 0.0,
                peak_latency_ms: 0.0,
                by_operation: HashMap::new(),
            });

        metric.total_accesses += 1;
        metric.last_accessed = 0; // Would be actual timestamp
        metric.average_latency_ms =
            (metric.average_latency_ms * (metric.total_accesses - 1) as f64 + latency_ms)
            / metric.total_accesses as f64;
        if latency_ms > metric.peak_latency_ms {
            metric.peak_latency_ms = latency_ms;
        }
        *metric.by_operation.entry(operation).or_insert(0) += 1;

        // Record in histogram
        self.metrics.latency_histograms
            .entry(path.to_string())
            .or_insert_with(LatencyHistogram::new)
            .observe(latency_ms / 1000.0);
    }

    pub fn record_change(&mut self, path: &str) {
        *self.metrics.change_counts.entry(path.to_string()).or_insert(0) += 1;
    }

    pub fn record_error(&mut self, path: &str) {
        *self.metrics.error_counts.entry(path.to_string()).or_insert(0) += 1;
    }

    pub fn log_event(&mut self, event: ConfigEvent) {
        // Notify subscribers
        for subscriber in &self.subscribers {
            if subscriber.event_types().contains(&event.event_type) {
                subscriber.on_event(&event);
            }
        }

        // Add to log
        self.event_log.events.push(event);

        // Trim if needed
        if self.event_log.events.len() > self.event_log.max_events {
            self.event_log.events.remove(0);
        }
    }

    pub fn check_alerts(&mut self) -> Vec<ConfigAlert> {
        let mut triggered = Vec::new();

        for rule in &mut self.alert_rules {
            if !rule.enabled { continue; }

            // Check cooldown
            if let Some(last) = rule.last_triggered {
                if 0 < last + rule.cooldown_seconds { // Would use actual time
                    continue;
                }
            }

            if self.evaluate_condition(&rule.condition) {
                let alert = ConfigAlert {
                    id: format!("alert-{}", triggered.len()),
                    severity: rule.severity,
                    rule_name: rule.name.clone(),
                    message: rule.description.clone(),
                    config_path: String::new(),
                    triggered_at: 0,
                    resolved_at: None,
                    metadata: HashMap::new(),
                };
                triggered.push(alert.clone());
                self.alerts.push(alert);
                rule.last_triggered = Some(0);
            }
        }

        triggered
    }

    fn evaluate_condition(&self, condition: &AlertCondition) -> bool {
        match condition {
            AlertCondition::Stale { path, max_age_seconds } => {
                if let Some(metric) = self.metrics.access_counts.get(path) {
                    // Would compare with actual time
                    metric.last_accessed > *max_age_seconds
                } else {
                    true // Never accessed
                }
            }
            AlertCondition::ErrorRate { threshold, window_seconds: _ } => {
                let total_errors: u64 = self.metrics.error_counts.values().sum();
                let total_accesses: u64 = self.metrics.access_counts.values()
                    .map(|m| m.total_accesses)
                    .sum();
                if total_accesses == 0 { return false; }
                (total_errors as f64 / total_accesses as f64) > *threshold
            }
            AlertCondition::HighLatency { path, threshold_ms, percentile } => {
                if let Some(hist) = self.metrics.latency_histograms.get(path) {
                    hist.percentile(*percentile) * 1000.0 > *threshold_ms
                } else {
                    false
                }
            }
            AlertCondition::And { conditions } => {
                conditions.iter().all(|c| self.evaluate_condition(c))
            }
            AlertCondition::Or { conditions } => {
                conditions.iter().any(|c| self.evaluate_condition(c))
            }
            AlertCondition::Not { condition } => {
                !self.evaluate_condition(condition)
            }
            _ => false,
        }
    }

    pub fn export_metrics(&self) -> ConfigMetricsExport {
        ConfigMetricsExport {
            access_counts: self.metrics.access_counts.clone(),
            change_counts: self.metrics.change_counts.clone(),
            error_counts: self.metrics.error_counts.clone(),
            cache_stats: self.metrics.cache_stats.clone(),
            provider_stats: self.metrics.provider_stats.clone(),
            total_events: self.event_log.events.len(),
            active_alerts: self.alerts.iter().filter(|a| a.resolved_at.is_none()).count(),
        }
    }
}

#[derive(Debug, Clone)]
pub struct ConfigMetricsExport {
    pub access_counts: HashMap<String, AccessMetric>,
    pub change_counts: HashMap<String, u64>,
    pub error_counts: HashMap<String, u64>,
    pub cache_stats: CacheStats,
    pub provider_stats: HashMap<String, ProviderStats>,
    pub total_events: usize,
    pub active_alerts: usize,
}

