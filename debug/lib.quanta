#[derive(Debug, Clone)]
pub struct SymbolInfo {
    pub name: String,
    pub address: u64,
    pub size: usize,
    pub symbol_type: SymbolType,
    pub binding: SymbolBinding,
    pub visibility: SymbolVisibility,
    pub section: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SymbolType {
    Function,
    Object,
    Section,
    File,
    Common,
    Tls,
    Unknown,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SymbolBinding {
    Local,
    Global,
    Weak,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SymbolVisibility {
    Default,
    Hidden,
    Protected,
}

#[derive(Debug, Clone)]
pub struct LineMapping {
    pub address: u64,
    pub line: u32,
    pub column: u32,
    pub is_statement: bool,
    pub basic_block: bool,
    pub end_sequence: bool,
    pub prologue_end: bool,
    pub epilogue_begin: bool,
}

#[derive(Debug, Clone)]
pub struct TypeInfo {
    pub name: String,
    pub size: usize,
    pub alignment: usize,
    pub kind: TypeKind,
    pub members: Vec<TypeMember>,
}

#[derive(Debug, Clone)]
pub enum TypeKind {
    Primitive(PrimitiveType),
    Pointer { pointee: u64 },
    Array { element: u64, count: usize },
    Struct,
    Union,
    Enum { values: Vec<(String, i64)> },
    Function { params: Vec<u64>, return_type: u64 },
    Typedef { underlying: u64 },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum PrimitiveType {
    Void,
    Bool,
    Char,
    SignedInt(u8),
    UnsignedInt(u8),
    Float(u8),
}

#[derive(Debug, Clone)]
pub struct TypeMember {
    pub name: String,
    pub type_id: u64,
    pub offset: usize,
    pub bit_size: Option<usize>,
    pub bit_offset: Option<usize>,
}

impl DwarfParser {
    pub fn new() -> Self {
        DwarfParser {
            compilation_units: RwLock::new(Vec::new()),
            symbols: RwLock::new(HashMap::new()),
            line_mappings: RwLock::new(HashMap::new()),
            types: RwLock::new(HashMap::new()),
        }
    }

    pub fn load_debug_info(&self, path: &Path) -> Result<(), String> {
        // In a real implementation, parse DWARF sections from ELF/Mach-O/PE
        let _ = path;
        Ok(())
    }

    pub fn resolve_address(&self, address: u64) -> Option<ResolvedLocation> {
        let symbols = self.symbols.read().unwrap();
        let line_mappings = self.line_mappings.read().unwrap();

        // Find symbol containing address
        let symbol = symbols.values()
            .find(|s| address >= s.address && address < s.address + s.size as u64);

        // Find line mapping
        for (file, mappings) in line_mappings.iter() {
            for mapping in mappings {
                if mapping.address == address {
                    return Some(ResolvedLocation {
                        file: file.clone(),
                        line: mapping.line,
                        column: mapping.column,
                        function: symbol.map(|s| s.name.clone()),
                        offset: symbol.map(|s| address - s.address),
                    });
                }
            }
        }

        symbol.map(|s| ResolvedLocation {
            file: PathBuf::new(),
            line: 0,
            column: 0,
            function: Some(s.name.clone()),
            offset: Some(address - s.address),
        })
    }

    pub fn get_type_info(&self, type_id: u64) -> Option<TypeInfo> {
        self.types.read().unwrap().get(&type_id).cloned()
    }

    pub fn find_function(&self, name: &str) -> Option<SymbolInfo> {
        self.symbols.read().unwrap().values()
            .find(|s| s.name == name && s.symbol_type == SymbolType::Function)
            .cloned()
    }
}

#[derive(Debug, Clone)]
pub struct ResolvedLocation {
    pub file: PathBuf,
    pub line: u32,
    pub column: u32,
    pub function: Option<String>,
    pub offset: Option<u64>,
}

// =============================================================================
// INTERACTIVE REPL DEBUGGER
// =============================================================================

/// Interactive REPL for debugging
pub struct ReplDebugger {
    /// Command history
    history: RwLock<Vec<String>>,
    /// Command aliases
    aliases: RwLock<HashMap<String, String>>,
    /// Custom commands
    custom_commands: RwLock<HashMap<String, Box<dyn ReplCommand + Send + Sync>>>,
    /// Variables set during session
    session_vars: RwLock<HashMap<String, String>>,
}

pub trait ReplCommand {
    fn name(&self) -> &str;
    fn help(&self) -> &str;
    fn execute(&self, args: &[&str]) -> Result<String, String>;
}

impl ReplDebugger {
    pub fn new() -> Self {
        let debugger = ReplDebugger {
            history: RwLock::new(Vec::new()),
            aliases: RwLock::new(HashMap::new()),
            custom_commands: RwLock::new(HashMap::new()),
            session_vars: RwLock::new(HashMap::new()),
        };

        // Set up default aliases
        {
            let mut aliases = debugger.aliases.write().unwrap();
            aliases.insert("c".to_string(), "continue".to_string());
            aliases.insert("n".to_string(), "next".to_string());
            aliases.insert("s".to_string(), "step".to_string());
            aliases.insert("p".to_string(), "print".to_string());
            aliases.insert("bt".to_string(), "backtrace".to_string());
            aliases.insert("q".to_string(), "quit".to_string());
            aliases.insert("b".to_string(), "breakpoint".to_string());
            aliases.insert("w".to_string(), "watch".to_string());
            aliases.insert("d".to_string(), "delete".to_string());
        }

        debugger
    }

    pub fn execute_command(&self, input: &str) -> Result<String, String> {
        let input = input.trim();
        if input.is_empty() {
            return Ok(String::new());
        }

        // Save to history
        self.history.write().unwrap().push(input.to_string());

        // Parse command and arguments
        let parts: Vec<&str> = input.split_whitespace().collect();
        if parts.is_empty() {
            return Ok(String::new());
        }

        let command = parts[0];
        let args = &parts[1..];

        // Check for alias
        let resolved_command = {
            let aliases = self.aliases.read().unwrap();
            aliases.get(command).cloned().unwrap_or_else(|| command.to_string())
        };

        // Check for custom command
        {
            let custom = self.custom_commands.read().unwrap();
            if let Some(cmd) = custom.get(&resolved_command) {
                return cmd.execute(args);
            }
        }

        // Built-in commands
        match resolved_command.as_str() {
            "help" => self.cmd_help(args),
            "continue" => Ok("Continuing execution...".to_string()),
            "next" => Ok("Stepping over...".to_string()),
            "step" => Ok("Stepping into...".to_string()),
            "stepout" => Ok("Stepping out...".to_string()),
            "breakpoint" => self.cmd_breakpoint(args),
            "watch" => self.cmd_watch(args),
            "delete" => self.cmd_delete(args),
            "print" => self.cmd_print(args),
            "display" => self.cmd_display(args),
            "backtrace" => Ok("Stack trace:\n  #0 main\n  #1 _start".to_string()),
            "frame" => self.cmd_frame(args),
            "up" => Ok("Moving up one frame".to_string()),
            "down" => Ok("Moving down one frame".to_string()),
            "info" => self.cmd_info(args),
            "set" => self.cmd_set(args),
            "alias" => self.cmd_alias(args),
            "history" => self.cmd_history(),
            "quit" => Err("quit".to_string()),
            _ => Err(format!("Unknown command: {}", resolved_command)),
        }
    }

    fn cmd_help(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok(r#"Available commands:
  help [command]  - Show help for commands
  continue (c)    - Continue execution
  next (n)        - Step over
  step (s)        - Step into
  stepout         - Step out of function
  breakpoint (b)  - Set breakpoint
  watch (w)       - Set watchpoint
  delete (d)      - Delete breakpoint/watchpoint
  print (p)       - Print expression value
  display         - Display expression on each stop
  backtrace (bt)  - Show call stack
  frame           - Select stack frame
  up/down         - Navigate stack frames
  info            - Show various information
  set             - Set debugger options
  alias           - Define command alias
  history         - Show command history
  quit (q)        - Exit debugger"#.to_string())
        } else {
            Ok(format!("Help for '{}' not available", args[0]))
        }
    }

    fn cmd_breakpoint(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("Usage: breakpoint <location> [condition]".to_string())
        } else {
            Ok(format!("Breakpoint set at {}", args[0]))
        }
    }

    fn cmd_watch(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("Usage: watch <expression>".to_string())
        } else {
            Ok(format!("Watchpoint set on {}", args[0]))
        }
    }

    fn cmd_delete(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("Deleted all breakpoints".to_string())
        } else {
            Ok(format!("Deleted breakpoint {}", args[0]))
        }
    }

    fn cmd_print(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("Usage: print <expression>".to_string())
        } else {
            let expr = args.join(" ");
            Ok(format!("{} = <value>", expr))
        }
    }

    fn cmd_display(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("No display expressions".to_string())
        } else {
            let expr = args.join(" ");
            Ok(format!("Added display: {}", expr))
        }
    }

    fn cmd_frame(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("Current frame: #0".to_string())
        } else {
            Ok(format!("Switched to frame #{}", args[0]))
        }
    }

    fn cmd_info(&self, args: &[&str]) -> Result<String, String> {
        if args.is_empty() {
            Ok("Usage: info <breakpoints|locals|args|registers|threads>".to_string())
        } else {
            match args[0] {
                "breakpoints" => Ok("No breakpoints set".to_string()),
                "locals" => Ok("No local variables".to_string()),
                "args" => Ok("No arguments".to_string()),
                "registers" => Ok("rax=0 rbx=0 rcx=0 rdx=0".to_string()),
                "threads" => Ok("Thread 1 (main)".to_string()),
                _ => Err(format!("Unknown info type: {}", args[0])),
            }
        }
    }

    fn cmd_set(&self, args: &[&str]) -> Result<String, String> {
        if args.len() < 2 {
            Ok("Usage: set <variable> <value>".to_string())
        } else {
            self.session_vars.write().unwrap().insert(args[0].to_string(), args[1].to_string());
            Ok(format!("Set {} = {}", args[0], args[1]))
        }
    }

    fn cmd_alias(&self, args: &[&str]) -> Result<String, String> {
        if args.len() < 2 {
            let aliases = self.aliases.read().unwrap();
            let list: Vec<String> = aliases.iter()
                .map(|(k, v)| format!("  {} = {}", k, v))
                .collect();
            Ok(format!("Aliases:\n{}", list.join("\n")))
        } else {
            self.aliases.write().unwrap().insert(args[0].to_string(), args[1].to_string());
            Ok(format!("Alias '{}' = '{}'", args[0], args[1]))
        }
    }

    fn cmd_history(&self) -> Result<String, String> {
        let history = self.history.read().unwrap();
        let lines: Vec<String> = history.iter()
            .enumerate()
            .map(|(i, cmd)| format!("{:4} {}", i + 1, cmd))
            .collect();
        Ok(lines.join("\n"))
    }

    pub fn add_custom_command<C: ReplCommand + Send + Sync + 'static>(&self, command: C) {
        self.custom_commands.write().unwrap()
            .insert(command.name().to_string(), Box::new(command));
    }
}

// =============================================================================
// CORE DUMP ANALYSIS
// =============================================================================

/// Core dump analyzer
pub struct CoreDumpAnalyzer {
    /// Loaded core dump
    core_dump: RwLock<Option<CoreDump>>,
    /// Analysis results
    analysis: RwLock<Option<CoreDumpAnalysis>>,
}

#[derive(Debug, Clone)]
pub struct CoreDump {
    pub path: PathBuf,
    pub executable: PathBuf,
    pub signal: i32,
    pub pid: u32,
    pub registers: HashMap<String, u64>,
    pub memory_mappings: Vec<MemoryMapping>,
    pub threads: Vec<CoreThread>,
}

#[derive(Debug, Clone)]
pub struct MemoryMapping {
    pub start: u64,
    pub end: u64,
    pub permissions: String,
    pub offset: u64,
    pub device: String,
    pub inode: u64,
    pub pathname: Option<String>,
}

#[derive(Debug, Clone)]
pub struct CoreThread {
    pub tid: u32,
    pub registers: HashMap<String, u64>,
    pub signal: i32,
}

#[derive(Debug, Clone)]
pub struct CoreDumpAnalysis {
    pub crash_location: ResolvedLocation,
    pub crash_reason: CrashReason,
    pub stack_traces: Vec<Vec<ResolvedLocation>>,
    pub probable_cause: String,
    pub recommendations: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum CrashReason {
    SegmentationFault { address: u64, access_type: AccessType },
    FloatingPointException,
    IllegalInstruction,
    BusError,
    Abort,
    StackOverflow,
    Other { signal: i32, description: String },
}

impl CoreDumpAnalyzer {
    pub fn new() -> Self {
        CoreDumpAnalyzer {
            core_dump: RwLock::new(None),
            analysis: RwLock::new(None),
        }
    }

    pub fn load_core_dump(&self, path: &Path, executable: &Path) -> Result<(), String> {
        // In a real implementation, parse the core dump file
        let core = CoreDump {
            path: path.to_path_buf(),
            executable: executable.to_path_buf(),
            signal: 11, // SIGSEGV
            pid: 0,
            registers: HashMap::new(),
            memory_mappings: Vec::new(),
            threads: Vec::new(),
        };

        *self.core_dump.write().unwrap() = Some(core);
        Ok(())
    }

    pub fn analyze(&self) -> Result<CoreDumpAnalysis, String> {
        let core = self.core_dump.read().unwrap();
        let core = core.as_ref().ok_or("No core dump loaded")?;

        let analysis = CoreDumpAnalysis {
            crash_location: ResolvedLocation {
                file: PathBuf::new(),
                line: 0,
                column: 0,
                function: Some("unknown".to_string()),
                offset: None,
            },
            crash_reason: CrashReason::SegmentationFault {
                address: 0,
                access_type: AccessType::Read,
            },
            stack_traces: Vec::new(),
            probable_cause: "Memory access violation".to_string(),
            recommendations: vec![
                "Check for null pointer dereference".to_string(),
                "Verify array bounds".to_string(),
                "Check for use-after-free".to_string(),
            ],
        };

        *self.analysis.write().unwrap() = Some(analysis.clone());
        Ok(analysis)
    }

    pub fn get_memory_at(&self, address: u64, size: usize) -> Option<Vec<u8>> {
        let core = self.core_dump.read().unwrap();
        let core = core.as_ref()?;

        // Find memory mapping containing address
        for mapping in &core.memory_mappings {
            if address >= mapping.start && address + size as u64 <= mapping.end {
                // In a real implementation, read from core file
                return Some(vec![0; size]);
            }
        }

        None
    }

    pub fn get_register(&self, name: &str) -> Option<u64> {
        let core = self.core_dump.read().unwrap();
        core.as_ref()?.registers.get(name).copied()
    }
}

// =============================================================================
// TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_breakpoint_manager() {
        let manager = BreakpointManager::new();

        let source = Source::from_path(PathBuf::from("test.quanta"));
        let breakpoints = vec![
            SourceBreakpoint { line: 10, column: None, condition: None, hit_condition: None, log_message: None },
            SourceBreakpoint { line: 20, column: None, condition: None, hit_condition: None, log_message: None },
        ];

        let result = manager.set_source_breakpoints(&source, breakpoints);

        assert_eq!(result.len(), 2);
        assert!(result[0].id < result[1].id);
    }

    #[test]
    fn test_variable_container() {
        let container = VariableContainer::new();

        let variables = vec![
            Variable {
                name: "x".to_string(),
                value: "42".to_string(),
                var_type: Some("i32".to_string()),
                presentation_hint: None,
                evaluate_name: None,
                variables_reference: 0,
                named_variables: None,
                indexed_variables: None,
                memory_reference: None,
            },
        ];

        let reference = container.create_reference(variables);
        let retrieved = container.get_variables(reference, None, None);

        assert_eq!(retrieved.len(), 1);
        assert_eq!(retrieved[0].name, "x");
    }

    #[test]
    fn test_call_stack_manager() {
        let manager = CallStackManager::new();

        let frame = StackFrame {
            id: 0,
            name: "main".to_string(),
            source: None,
            line: 1,
            column: 0,
            end_line: None,
            end_column: None,
            can_restart: false,
            instruction_pointer_reference: None,
            module_id: None,
            presentation_hint: None,
        };

        manager.push_frame(1, frame);

        let trace = manager.get_stack_trace(1, None, None);
        assert_eq!(trace.len(), 1);
        assert_eq!(trace[0].name, "main");
    }

    #[test]
    fn test_debug_adapter_initialize() {
        let adapter = DebugAdapter::new();

        let request = Request {
            command: "initialize".to_string(),
            arguments: Some(serde_json::json!({
                "clientID": "test",
                "adapterID": "quanta",
            })),
        };

        let response = adapter.handle_request(request);

        assert!(response.success);
        assert!(response.body.is_some());
    }

    #[test]
    fn test_time_travel_debugger() {
        let ttd = TimeTravelDebugger::new();

        let entry = HistoryEntry {
            timestamp: 1,
            thread_id: 1,
            instruction_pointer: 0x1000,
            source_location: SourceLocation {
                file: PathBuf::from("test.quanta"),
                line: 10,
                column: 0,
                function: Some("main".to_string()),
            },
            operation: HistoryOperation::Step,
            before_state: None,
            after_state: None,
        };

        ttd.record_entry(1, entry);
        let result = ttd.step_back(1);
        assert!(result.is_some());
    }

    #[test]
    fn test_memory_analyzer() {
        let analyzer = MemoryAnalyzer::new();

        let alloc = AllocationInfo {
            address: 0x1000,
            size: 1024,
            alignment: 8,
            allocated_at: 0,
            stack_trace: Vec::new(),
            allocation_type: AllocationType::Heap,
            tags: HashSet::new(),
            accessed_from: Vec::new(),
        };

        analyzer.track_allocation(alloc);
        assert!(analyzer.get_allocation_info(0x1000).is_some());

        analyzer.track_free(0x1000);
        assert!(analyzer.get_allocation_info(0x1000).is_none());
        assert!(analyzer.check_use_after_free(0x1000).is_some());
    }

    #[test]
    fn test_vector_clock() {
        let mut clock1 = VectorClock::new();
        clock1.increment(1);
        clock1.increment(1);

        let mut clock2 = VectorClock::new();
        clock2.increment(2);

        assert!(!clock1.happens_before(&clock2));
        assert!(!clock2.happens_before(&clock1));

        clock2.merge(&clock1);
        assert!(clock1.happens_before(&clock2));
    }

    #[test]
    fn test_repl_debugger() {
        let repl = ReplDebugger::new();

        let result = repl.execute_command("help");
        assert!(result.is_ok());

        let result = repl.execute_command("c");
        assert!(result.is_ok());
        assert!(result.unwrap().contains("Continuing"));

        let result = repl.execute_command("set foo bar");
        assert!(result.is_ok());
    }

    #[test]
    fn test_deadlock_detector() {
        let detector = DeadlockDetector::new();

        detector.record_lock_acquire(1, 100);
        detector.record_lock_acquire(2, 200);

        let result = detector.check_for_deadlock(1, 200);
        // No deadlock yet since we don't have a cycle
        assert!(result.is_none());
    }
}

// ============================================================================
// Distributed Debugging - Debug Across Multiple Processes/Nodes
// ============================================================================

/// Distributed debug coordinator for multi-process debugging
pub struct DistributedDebugger {
    /// Connected debug nodes
    nodes: Arc<RwLock<HashMap<NodeId, DebugNode>>>,
    /// Global breakpoints across all nodes
    global_breakpoints: Arc<RwLock<Vec<GlobalBreakpoint>>>,
    /// Message queue for inter-node communication
    message_queue: Arc<RwLock<VecDeque<DebugMessage>>>,
    /// Node discovery service
    discovery: Arc<NodeDiscovery>,
    /// Synchronization state
    sync_state: Arc<RwLock<SyncState>>,
    /// Configuration
    config: DistributedDebugConfig,
}

/// Unique identifier for debug nodes
pub type NodeId = u64;

/// Remote debug node information
pub struct DebugNode {
    /// Node identifier
    pub id: NodeId,
    /// Node address
    pub address: SocketAddr,
    /// Connection state
    pub state: NodeState,
    /// Node capabilities
    pub capabilities: NodeCapabilities,
    /// Last heartbeat timestamp
    pub last_heartbeat: Instant,
    /// Processes on this node
    pub processes: Vec<ProcessInfo>,
    /// Current debug state
    pub debug_state: RemoteDebugState,
}

/// Node connection state
#[derive(Debug, Clone, PartialEq)]
pub enum NodeState {
    Connecting,
    Connected,
    Authenticated,
    Ready,
    Suspended,
    Disconnected,
    Error(String),
}

/// Node debugging capabilities
pub struct NodeCapabilities {
    pub supports_breakpoints: bool,
    pub supports_stepping: bool,
    pub supports_memory_access: bool,
    pub supports_expression_eval: bool,
    pub supports_hot_reload: bool,
    pub supports_time_travel: bool,
    pub max_breakpoints: usize,
    pub supported_languages: Vec<String>,
}

/// Remote debug state
pub struct RemoteDebugState {
    pub is_running: bool,
    pub is_suspended: bool,
    pub suspended_threads: Vec<ThreadId>,
    pub active_breakpoints: Vec<BreakpointId>,
    pub last_stop_reason: Option<StopReason>,
}

/// Stop reason for debugging
#[derive(Debug, Clone)]
pub enum StopReason {
    Breakpoint(BreakpointId),
    Step,
    Pause,
    Exception(String),
    Watchpoint(WatchpointId),
    Signal(i32),
    Exit(i32),
}

/// Global breakpoint synchronized across nodes
pub struct GlobalBreakpoint {
    pub id: BreakpointId,
    pub location: BreakpointLocation,
    pub condition: Option<String>,
    pub hit_count: AtomicU64,
    pub enabled: AtomicBool,
    pub log_message: Option<String>,
    pub target_nodes: Vec<NodeId>,
}

/// Debug message for inter-node communication
pub struct DebugMessage {
    pub id: MessageId,
    pub source: NodeId,
    pub destination: NodeId,
    pub message_type: DebugMessageType,
    pub payload: Vec<u8>,
    pub timestamp: Instant,
    pub requires_ack: bool,
}

pub type MessageId = u64;

/// Types of debug messages
#[derive(Debug, Clone)]
pub enum DebugMessageType {
    /// Breakpoint synchronization
    BreakpointSync,
    /// State synchronization
    StateSync,
    /// Execution control
    ExecutionControl(ExecutionCommand),
    /// Memory request
    MemoryRequest,
    /// Expression evaluation
    ExpressionEval,
    /// Heartbeat
    Heartbeat,
    /// Node discovery
    Discovery,
    /// Acknowledgment
    Ack(MessageId),
}

/// Execution commands
#[derive(Debug, Clone)]
pub enum ExecutionCommand {
    Continue,
    Pause,
    StepOver,
    StepInto,
    StepOut,
    Terminate,
}

/// Node discovery service
pub struct NodeDiscovery {
    /// Known nodes
    known_nodes: RwLock<HashMap<NodeId, SocketAddr>>,
    /// Discovery protocol
    protocol: DiscoveryProtocol,
    /// Multicast group for discovery
    multicast_addr: Option<SocketAddr>,
}

/// Discovery protocol types
pub enum DiscoveryProtocol {
    Multicast,
    Unicast(Vec<SocketAddr>),
    Consul(String),
    Kubernetes(String),
    Manual,
}

/// Synchronization state across nodes
pub struct SyncState {
    /// Logical clock for ordering events
    pub logical_clock: u64,
    /// Vector clock per node
    pub vector_clocks: HashMap<NodeId, VectorClock>,
    /// Pending synchronization operations
    pub pending_ops: VecDeque<SyncOperation>,
    /// Last synchronized state
    pub last_sync: Option<Instant>,
}

/// Synchronization operations
pub struct SyncOperation {
    pub id: u64,
    pub operation_type: SyncOpType,
    pub data: Vec<u8>,
    pub affected_nodes: Vec<NodeId>,
    pub status: SyncStatus,
}

#[derive(Debug, Clone)]
pub enum SyncOpType {
    BreakpointAdd,
    BreakpointRemove,
    StateCapture,
    MemorySnapshot,
    ThreadSync,
}

#[derive(Debug, Clone, PartialEq)]
pub enum SyncStatus {
    Pending,
    InProgress,
    Completed,
    Failed(String),
}

/// Distributed debug configuration
pub struct DistributedDebugConfig {
    pub heartbeat_interval: Duration,
    pub sync_interval: Duration,
    pub message_timeout: Duration,
    pub max_nodes: usize,
    pub enable_encryption: bool,
    pub compression: bool,
    pub retry_attempts: u32,
}

impl DistributedDebugger {
    pub fn new(config: DistributedDebugConfig) -> Self {
        Self {
            nodes: Arc::new(RwLock::new(HashMap::new())),
            global_breakpoints: Arc::new(RwLock::new(Vec::new())),
            message_queue: Arc::new(RwLock::new(VecDeque::new())),
            discovery: Arc::new(NodeDiscovery::new()),
            sync_state: Arc::new(RwLock::new(SyncState::new())),
            config,
        }
    }

    /// Connect to a remote debug node
    pub async fn connect_node(&self, address: SocketAddr) -> Result<NodeId, DebugError> {
        let node_id = self.generate_node_id(&address);

        let node = DebugNode {
            id: node_id,
            address,
            state: NodeState::Connecting,
            capabilities: NodeCapabilities::default(),
            last_heartbeat: Instant::now(),
            processes: Vec::new(),
            debug_state: RemoteDebugState::default(),
        };

        self.nodes.write().unwrap().insert(node_id, node);
        self.perform_handshake(node_id).await?;

        Ok(node_id)
    }

    /// Disconnect from a node
    pub async fn disconnect_node(&self, node_id: NodeId) -> Result<(), DebugError> {
        if let Some(mut node) = self.nodes.write().unwrap().get_mut(&node_id) {
            node.state = NodeState::Disconnected;
        }
        self.nodes.write().unwrap().remove(&node_id);
        Ok(())
    }

    /// Set a global breakpoint across all connected nodes
    pub async fn set_global_breakpoint(
        &self,
        location: BreakpointLocation,
        condition: Option<String>,
    ) -> Result<BreakpointId, DebugError> {
        let bp_id = self.generate_breakpoint_id();
        let nodes: Vec<NodeId> = self.nodes.read().unwrap().keys().copied().collect();

        let global_bp = GlobalBreakpoint {
            id: bp_id,
            location: location.clone(),
            condition: condition.clone(),
            hit_count: AtomicU64::new(0),
            enabled: AtomicBool::new(true),
            log_message: None,
            target_nodes: nodes.clone(),
        };

        self.global_breakpoints.write().unwrap().push(global_bp);

        // Sync to all nodes
        for node_id in nodes {
            self.send_breakpoint_sync(node_id, bp_id, &location, &condition).await?;
        }

        Ok(bp_id)
    }

    /// Continue execution on all suspended nodes
    pub async fn continue_all(&self) -> Result<(), DebugError> {
        let nodes: Vec<NodeId> = self.nodes.read().unwrap()
            .iter()
            .filter(|(_, n)| n.debug_state.is_suspended)
            .map(|(id, _)| *id)
            .collect();

        for node_id in nodes {
            self.send_execution_command(node_id, ExecutionCommand::Continue).await?;
        }

        Ok(())
    }

    /// Pause execution on all running nodes
    pub async fn pause_all(&self) -> Result<(), DebugError> {
        let nodes: Vec<NodeId> = self.nodes.read().unwrap()
            .iter()
            .filter(|(_, n)| n.debug_state.is_running && !n.debug_state.is_suspended)
            .map(|(id, _)| *id)
            .collect();

        for node_id in nodes {
            self.send_execution_command(node_id, ExecutionCommand::Pause).await?;
        }

        Ok(())
    }

    /// Get combined stack trace from all nodes
    pub async fn get_global_stack_trace(&self) -> Result<Vec<GlobalStackFrame>, DebugError> {
        let mut frames = Vec::new();

        for (node_id, node) in self.nodes.read().unwrap().iter() {
            if node.debug_state.is_suspended {
                let node_frames = self.request_stack_trace(*node_id).await?;
                for frame in node_frames {
                    frames.push(GlobalStackFrame {
                        node_id: *node_id,
                        frame,
                    });
                }
            }
        }

        Ok(frames)
    }

    /// Synchronize state across all nodes
    pub async fn synchronize_state(&self) -> Result<(), DebugError> {
        let mut sync_state = self.sync_state.write().unwrap();
        sync_state.logical_clock += 1;

        let sync_op = SyncOperation {
            id: sync_state.logical_clock,
            operation_type: SyncOpType::StateCapture,
            data: self.capture_global_state()?,
            affected_nodes: self.nodes.read().unwrap().keys().copied().collect(),
            status: SyncStatus::Pending,
        };

        sync_state.pending_ops.push_back(sync_op);
        sync_state.last_sync = Some(Instant::now());

        Ok(())
    }

    fn generate_node_id(&self, addr: &SocketAddr) -> NodeId {
        use std::hash::{Hash, Hasher};
        let mut hasher = std::collections::hash_map::DefaultHasher::new();
        addr.hash(&mut hasher);
        hasher.finish()
    }

    fn generate_breakpoint_id(&self) -> BreakpointId {
        static COUNTER: AtomicU64 = AtomicU64::new(1);
        COUNTER.fetch_add(1, Ordering::SeqCst)
    }

    async fn perform_handshake(&self, node_id: NodeId) -> Result<(), DebugError> {
        // Send handshake message
        let msg = DebugMessage {
            id: self.generate_message_id(),
            source: 0, // Local node
            destination: node_id,
            message_type: DebugMessageType::Discovery,
            payload: Vec::new(),
            timestamp: Instant::now(),
            requires_ack: true,
        };

        self.send_message(msg).await?;

        // Update node state
        if let Some(node) = self.nodes.write().unwrap().get_mut(&node_id) {
            node.state = NodeState::Connected;
        }

        Ok(())
    }

    fn generate_message_id(&self) -> MessageId {
        static COUNTER: AtomicU64 = AtomicU64::new(1);
        COUNTER.fetch_add(1, Ordering::SeqCst)
    }

    async fn send_message(&self, msg: DebugMessage) -> Result<(), DebugError> {
        self.message_queue.write().unwrap().push_back(msg);
        Ok(())
    }

    async fn send_breakpoint_sync(
        &self,
        node_id: NodeId,
        bp_id: BreakpointId,
        location: &BreakpointLocation,
        condition: &Option<String>,
    ) -> Result<(), DebugError> {
        let payload = serde_json::to_vec(&(bp_id, location, condition))
            .map_err(|e| DebugError::SerializationError(e.to_string()))?;

        let msg = DebugMessage {
            id: self.generate_message_id(),
            source: 0,
            destination: node_id,
            message_type: DebugMessageType::BreakpointSync,
            payload,
            timestamp: Instant::now(),
            requires_ack: true,
        };

        self.send_message(msg).await
    }

    async fn send_execution_command(
        &self,
        node_id: NodeId,
        command: ExecutionCommand,
    ) -> Result<(), DebugError> {
        let msg = DebugMessage {
            id: self.generate_message_id(),
            source: 0,
            destination: node_id,
            message_type: DebugMessageType::ExecutionControl(command),
            payload: Vec::new(),
            timestamp: Instant::now(),
            requires_ack: true,
        };

        self.send_message(msg).await
    }

    async fn request_stack_trace(&self, node_id: NodeId) -> Result<Vec<StackFrame>, DebugError> {
        // In a real implementation, this would make a network request
        Ok(Vec::new())
    }

    fn capture_global_state(&self) -> Result<Vec<u8>, DebugError> {
        // Capture combined state from all nodes
        Ok(Vec::new())
    }
}

/// Global stack frame with node information
pub struct GlobalStackFrame {
    pub node_id: NodeId,
    pub frame: StackFrame,
}

impl NodeDiscovery {
    pub fn new() -> Self {
        Self {
            known_nodes: RwLock::new(HashMap::new()),
            protocol: DiscoveryProtocol::Manual,
            multicast_addr: None,
        }
    }

    pub fn with_multicast(multicast_addr: SocketAddr) -> Self {
        Self {
            known_nodes: RwLock::new(HashMap::new()),
            protocol: DiscoveryProtocol::Multicast,
            multicast_addr: Some(multicast_addr),
        }
    }

    pub async fn discover_nodes(&self) -> Result<Vec<(NodeId, SocketAddr)>, DebugError> {
        match &self.protocol {
            DiscoveryProtocol::Multicast => self.multicast_discover().await,
            DiscoveryProtocol::Unicast(addrs) => Ok(self.unicast_discover(addrs)),
            DiscoveryProtocol::Consul(url) => self.consul_discover(url).await,
            DiscoveryProtocol::Kubernetes(namespace) => self.k8s_discover(namespace).await,
            DiscoveryProtocol::Manual => Ok(self.known_nodes.read().unwrap()
                .iter()
                .map(|(id, addr)| (*id, *addr))
                .collect()),
        }
    }

    pub fn register_node(&self, id: NodeId, addr: SocketAddr) {
        self.known_nodes.write().unwrap().insert(id, addr);
    }

    async fn multicast_discover(&self) -> Result<Vec<(NodeId, SocketAddr)>, DebugError> {
        // Send multicast discovery packet and collect responses
        Ok(Vec::new())
    }

    fn unicast_discover(&self, addrs: &[SocketAddr]) -> Vec<(NodeId, SocketAddr)> {
        addrs.iter().enumerate().map(|(i, addr)| (i as NodeId, *addr)).collect()
    }

    async fn consul_discover(&self, _url: &str) -> Result<Vec<(NodeId, SocketAddr)>, DebugError> {
        // Query Consul for registered debug nodes
        Ok(Vec::new())
    }

    async fn k8s_discover(&self, _namespace: &str) -> Result<Vec<(NodeId, SocketAddr)>, DebugError> {
        // Query Kubernetes API for debug pods
        Ok(Vec::new())
    }
}

impl SyncState {
    pub fn new() -> Self {
        Self {
            logical_clock: 0,
            vector_clocks: HashMap::new(),
            pending_ops: VecDeque::new(),
            last_sync: None,
        }
    }
}

impl Default for NodeCapabilities {
    fn default() -> Self {
        Self {
            supports_breakpoints: true,
            supports_stepping: true,
            supports_memory_access: true,
            supports_expression_eval: true,
            supports_hot_reload: false,
            supports_time_travel: false,
            max_breakpoints: 1000,
            supported_languages: vec!["quanta".to_string()],
        }
    }
}

impl Default for RemoteDebugState {
    fn default() -> Self {
        Self {
            is_running: false,
            is_suspended: false,
            suspended_threads: Vec::new(),
            active_breakpoints: Vec::new(),
            last_stop_reason: None,
        }
    }
}

impl Default for DistributedDebugConfig {
    fn default() -> Self {
        Self {
            heartbeat_interval: Duration::from_secs(5),
            sync_interval: Duration::from_secs(1),
            message_timeout: Duration::from_secs(30),
            max_nodes: 100,
            enable_encryption: true,
            compression: true,
            retry_attempts: 3,
        }
    }
}

// ============================================================================
// GPU Debugging - Debug GPU Kernels and Memory
// ============================================================================

/// GPU debugger for CUDA/OpenCL/Vulkan compute debugging
pub struct GpuDebugger {
    /// Connected GPU devices
    devices: Vec<GpuDevice>,
    /// Active debug sessions
    sessions: HashMap<u64, GpuDebugSession>,
    /// GPU memory inspector
    memory_inspector: GpuMemoryInspector,
    /// Kernel debugger
    kernel_debugger: KernelDebugger,
    /// Configuration
    config: GpuDebugConfig,
}

/// GPU device information
pub struct GpuDevice {
    pub id: u64,
    pub name: String,
    pub vendor: GpuVendor,
    pub compute_capability: (u32, u32),
    pub total_memory: u64,
    pub available_memory: u64,
    pub max_threads_per_block: u32,
    pub max_blocks: (u32, u32, u32),
    pub warp_size: u32,
    pub supports_debugging: bool,
}

#[derive(Debug, Clone)]
pub enum GpuVendor {
    Nvidia,
    Amd,
    Intel,
    Apple,
    Other(String),
}

/// GPU debug session
pub struct GpuDebugSession {
    pub id: u64,
    pub device_id: u64,
    pub kernel_name: String,
    pub state: GpuDebugState,
    pub breakpoints: Vec<GpuBreakpoint>,
    pub focus: Option<ThreadFocus>,
}

/// GPU debug state
#[derive(Debug, Clone, PartialEq)]
pub enum GpuDebugState {
    Idle,
    Running,
    Suspended,
    Error(String),
}

/// GPU breakpoint
pub struct GpuBreakpoint {
    pub id: BreakpointId,
    pub location: GpuBreakpointLocation,
    pub condition: Option<GpuCondition>,
    pub enabled: bool,
    pub hit_count: u64,
}

/// GPU breakpoint location
pub enum GpuBreakpointLocation {
    /// Source line breakpoint
    SourceLine { file: PathBuf, line: u32 },
    /// Kernel entry
    KernelEntry(String),
    /// Kernel exit
    KernelExit(String),
    /// Memory access
    MemoryAccess { address: u64, access_type: MemoryAccessType },
    /// Thread divergence
    Divergence,
    /// Warp exception
    WarpException,
}

/// GPU conditional expression
pub struct GpuCondition {
    pub expression: String,
    pub thread_filter: Option<ThreadFilter>,
}

/// Thread filter for GPU debugging
pub struct ThreadFilter {
    pub block_x: Option<RangeInclusive<u32>>,
    pub block_y: Option<RangeInclusive<u32>>,
    pub block_z: Option<RangeInclusive<u32>>,
    pub thread_x: Option<RangeInclusive<u32>>,
    pub thread_y: Option<RangeInclusive<u32>>,
    pub thread_z: Option<RangeInclusive<u32>>,
}

/// Thread focus for inspecting specific GPU thread
pub struct ThreadFocus {
    pub block: (u32, u32, u32),
    pub thread: (u32, u32, u32),
}

/// GPU memory inspector
pub struct GpuMemoryInspector {
    /// Tracked allocations
    allocations: HashMap<u64, GpuAllocation>,
    /// Memory access log
    access_log: VecDeque<GpuMemoryAccess>,
    /// Out-of-bounds access detector
    bounds_checker: GpuBoundsChecker,
}

/// GPU memory allocation
pub struct GpuAllocation {
    pub address: u64,
    pub size: u64,
    pub memory_type: GpuMemoryType,
    pub allocated_by: String,
    pub allocation_time: Instant,
}

#[derive(Debug, Clone)]
pub enum GpuMemoryType {
    Global,
    Shared,
    Local,
    Constant,
    Texture,
    Surface,
}

/// GPU memory access record
pub struct GpuMemoryAccess {
    pub address: u64,
    pub size: u32,
    pub access_type: MemoryAccessType,
    pub thread: ThreadFocus,
    pub timestamp: u64,
    pub value: Option<Vec<u8>>,
}

/// GPU bounds checker
pub struct GpuBoundsChecker {
    regions: Vec<MemoryRegion>,
    violations: VecDeque<BoundsViolation>,
}

/// Memory region for bounds checking
pub struct MemoryRegion {
    pub start: u64,
    pub end: u64,
    pub permissions: MemoryPermissions,
    pub name: String,
}

pub struct MemoryPermissions {
    pub read: bool,
    pub write: bool,
    pub execute: bool,
}

/// Bounds violation record
pub struct BoundsViolation {
    pub address: u64,
    pub region: Option<String>,
    pub access_type: MemoryAccessType,
    pub thread: ThreadFocus,
    pub timestamp: Instant,
}

/// Kernel debugger for GPU compute kernels
pub struct KernelDebugger {
    /// Active kernels
    active_kernels: HashMap<u64, KernelInfo>,
    /// Kernel execution history
    execution_history: VecDeque<KernelExecution>,
    /// Divergence analyzer
    divergence_analyzer: DivergenceAnalyzer,
}

/// Kernel information
pub struct KernelInfo {
    pub name: String,
    pub source: Option<String>,
    pub grid_dim: (u32, u32, u32),
    pub block_dim: (u32, u32, u32),
    pub shared_memory: u64,
    pub registers_per_thread: u32,
    pub arguments: Vec<KernelArgument>,
}

/// Kernel argument
pub struct KernelArgument {
    pub name: String,
    pub arg_type: String,
    pub size: u64,
    pub value: Vec<u8>,
}

/// Kernel execution record
pub struct KernelExecution {
    pub kernel_name: String,
    pub start_time: Instant,
    pub end_time: Option<Instant>,
    pub grid_dim: (u32, u32, u32),
    pub block_dim: (u32, u32, u32),
    pub status: KernelStatus,
    pub occupancy: f32,
}

#[derive(Debug, Clone)]
pub enum KernelStatus {
    Running,
    Completed,
    Error(String),
    Timeout,
}

/// Divergence analyzer for detecting thread divergence
pub struct DivergenceAnalyzer {
    divergence_points: Vec<DivergencePoint>,
    warp_states: HashMap<u64, WarpState>,
}

/// Point where thread divergence occurs
pub struct DivergencePoint {
    pub location: SourceLocation,
    pub warp_id: u64,
    pub active_threads: u32,
    pub divergence_type: DivergenceType,
}

#[derive(Debug, Clone)]
pub enum DivergenceType {
    Conditional,
    Loop,
    Return,
    Exception,
}

/// Warp execution state
pub struct WarpState {
    pub warp_id: u64,
    pub active_mask: u64,
    pub converged: bool,
    pub program_counter: u64,
}

/// GPU debug configuration
pub struct GpuDebugConfig {
    pub enable_memory_checking: bool,
    pub enable_bounds_checking: bool,
    pub enable_divergence_detection: bool,
    pub memory_access_log_size: usize,
    pub timeout: Duration,
}

impl GpuDebugger {
    pub fn new(config: GpuDebugConfig) -> Result<Self, DebugError> {
        Ok(Self {
            devices: Self::enumerate_devices()?,
            sessions: HashMap::new(),
            memory_inspector: GpuMemoryInspector::new(),
            kernel_debugger: KernelDebugger::new(),
            config,
        })
    }

    fn enumerate_devices() -> Result<Vec<GpuDevice>, DebugError> {
        // Enumerate available GPU devices
        Ok(Vec::new())
    }

    /// Start debugging a GPU kernel
    pub fn debug_kernel(
        &mut self,
        device_id: u64,
        kernel_name: &str,
    ) -> Result<u64, DebugError> {
        let session_id = self.generate_session_id();

        let session = GpuDebugSession {
            id: session_id,
            device_id,
            kernel_name: kernel_name.to_string(),
            state: GpuDebugState::Idle,
            breakpoints: Vec::new(),
            focus: None,
        };

        self.sessions.insert(session_id, session);
        Ok(session_id)
    }

    /// Set a GPU breakpoint
    pub fn set_breakpoint(
        &mut self,
        session_id: u64,
        location: GpuBreakpointLocation,
        condition: Option<GpuCondition>,
    ) -> Result<BreakpointId, DebugError> {
        let session = self.sessions.get_mut(&session_id)
            .ok_or(DebugError::SessionNotFound)?;

        let bp_id = self.generate_breakpoint_id();

        let breakpoint = GpuBreakpoint {
            id: bp_id,
            location,
            condition,
            enabled: true,
            hit_count: 0,
        };

        session.breakpoints.push(breakpoint);
        Ok(bp_id)
    }

    /// Focus on a specific GPU thread
    pub fn focus_thread(
        &mut self,
        session_id: u64,
        block: (u32, u32, u32),
        thread: (u32, u32, u32),
    ) -> Result<(), DebugError> {
        let session = self.sessions.get_mut(&session_id)
            .ok_or(DebugError::SessionNotFound)?;

        session.focus = Some(ThreadFocus { block, thread });
        Ok(())
    }

    /// Read GPU memory
    pub fn read_gpu_memory(
        &self,
        device_id: u64,
        address: u64,
        size: u64,
    ) -> Result<Vec<u8>, DebugError> {
        self.memory_inspector.read_memory(device_id, address, size)
    }

    /// Get thread-local variables for focused thread
    pub fn get_thread_locals(&self, session_id: u64) -> Result<Vec<Variable>, DebugError> {
        let session = self.sessions.get(&session_id)
            .ok_or(DebugError::SessionNotFound)?;

        let _focus = session.focus.as_ref()
            .ok_or(DebugError::NoThreadFocus)?;

        // Query thread-local variables from GPU
        Ok(Vec::new())
    }

    /// Get divergence analysis
    pub fn analyze_divergence(&self, session_id: u64) -> Result<Vec<DivergencePoint>, DebugError> {
        Ok(self.kernel_debugger.divergence_analyzer.divergence_points.clone())
    }

    fn generate_session_id(&self) -> u64 {
        static COUNTER: AtomicU64 = AtomicU64::new(1);
        COUNTER.fetch_add(1, Ordering::SeqCst)
    }

    fn generate_breakpoint_id(&self) -> BreakpointId {
        static COUNTER: AtomicU64 = AtomicU64::new(1);
        COUNTER.fetch_add(1, Ordering::SeqCst)
    }
}

impl GpuMemoryInspector {
    pub fn new() -> Self {
        Self {
            allocations: HashMap::new(),
            access_log: VecDeque::with_capacity(10000),
            bounds_checker: GpuBoundsChecker::new(),
        }
    }

    pub fn track_allocation(&mut self, alloc: GpuAllocation) {
        self.bounds_checker.add_region(MemoryRegion {
            start: alloc.address,
            end: alloc.address + alloc.size,
            permissions: MemoryPermissions { read: true, write: true, execute: false },
            name: format!("gpu_alloc_{:x}", alloc.address),
        });
        self.allocations.insert(alloc.address, alloc);
    }

    pub fn read_memory(&self, _device_id: u64, _address: u64, size: u64) -> Result<Vec<u8>, DebugError> {
        // Read GPU memory through debug API
        Ok(vec![0; size as usize])
    }

    pub fn log_access(&mut self, access: GpuMemoryAccess) {
        self.access_log.push_back(access);
        if self.access_log.len() > 10000 {
            self.access_log.pop_front();
        }
    }
}

impl GpuBoundsChecker {
    pub fn new() -> Self {
        Self {
            regions: Vec::new(),
            violations: VecDeque::new(),
        }
    }

    pub fn add_region(&mut self, region: MemoryRegion) {
        self.regions.push(region);
    }

    pub fn check_access(&mut self, address: u64, _size: u32, access_type: MemoryAccessType, thread: ThreadFocus) -> bool {
        for region in &self.regions {
            if address >= region.start && address < region.end {
                return true;
            }
        }

        // Record violation
        self.violations.push_back(BoundsViolation {
            address,
            region: None,
            access_type,
            thread,
            timestamp: Instant::now(),
        });

        false
    }
}

impl KernelDebugger {
    pub fn new() -> Self {
        Self {
            active_kernels: HashMap::new(),
            execution_history: VecDeque::with_capacity(1000),
            divergence_analyzer: DivergenceAnalyzer::new(),
        }
    }

    pub fn register_kernel(&mut self, id: u64, info: KernelInfo) {
        self.active_kernels.insert(id, info);
    }

    pub fn record_execution(&mut self, execution: KernelExecution) {
        self.execution_history.push_back(execution);
        if self.execution_history.len() > 1000 {
            self.execution_history.pop_front();
        }
    }
}

impl DivergenceAnalyzer {
    pub fn new() -> Self {
        Self {
            divergence_points: Vec::new(),
            warp_states: HashMap::new(),
        }
    }

    pub fn record_divergence(&mut self, point: DivergencePoint) {
        self.divergence_points.push(point);
    }

    pub fn update_warp_state(&mut self, state: WarpState) {
        self.warp_states.insert(state.warp_id, state);
    }
}

impl Default for GpuDebugConfig {
    fn default() -> Self {
        Self {
            enable_memory_checking: true,
            enable_bounds_checking: true,
            enable_divergence_detection: true,
            memory_access_log_size: 10000,
            timeout: Duration::from_secs(60),
        }
    }
}

// ============================================================================
// Debug Visualization - Generate Debug Session Visualizations
// ============================================================================

/// Debug visualization generator
pub struct DebugVisualizer {
    /// Renderer for different output formats
    renderer: VisualizationRenderer,
    /// Collected visualization data
    data: VisualizationData,
    /// Configuration
    config: VisualizerConfig,
}

/// Visualization data collected during debugging
pub struct VisualizationData {
    /// Call graph nodes and edges
    pub call_graph: CallGraph,
    /// Memory layout snapshots
    pub memory_snapshots: Vec<MemorySnapshot>,
    /// Variable value timeline
    pub value_timeline: HashMap<String, Vec<ValuePoint>>,
    /// Execution flow
    pub execution_flow: Vec<ExecutionNode>,
    /// Thread interactions
    pub thread_diagram: ThreadDiagram,
}

/// Call graph for visualization
pub struct CallGraph {
    pub nodes: Vec<CallGraphNode>,
    pub edges: Vec<CallGraphEdge>,
}

pub struct CallGraphNode {
    pub id: u64,
    pub function_name: String,
    pub file: PathBuf,
    pub line: u32,
    pub call_count: u64,
    pub total_time: Duration,
    pub self_time: Duration,
}

pub struct CallGraphEdge {
    pub from: u64,
    pub to: u64,
    pub call_count: u64,
    pub label: Option<String>,
}

/// Memory snapshot for visualization
pub struct MemorySnapshot {
    pub timestamp: Instant,
    pub heap_usage: u64,
    pub stack_usage: u64,
    pub allocations: Vec<AllocationVisual>,
}

pub struct AllocationVisual {
    pub address: u64,
    pub size: u64,
    pub type_name: String,
    pub color: Color,
}

pub struct Color {
    pub r: u8,
    pub g: u8,
    pub b: u8,
    pub a: u8,
}

/// Value at a point in time
pub struct ValuePoint {
    pub timestamp: u64,
    pub value: String,
    pub location: SourceLocation,
}

/// Execution flow node
pub struct ExecutionNode {
    pub id: u64,
    pub node_type: ExecutionNodeType,
    pub location: SourceLocation,
    pub timestamp: u64,
    pub children: Vec<u64>,
}

#[derive(Debug, Clone)]
pub enum ExecutionNodeType {
    FunctionCall(String),
    Branch { taken: bool, condition: String },
    Loop { iteration: u32 },
    Exception(String),
    Return(String),
}

/// Thread interaction diagram
pub struct ThreadDiagram {
    pub threads: Vec<ThreadTimeline>,
    pub interactions: Vec<ThreadInteraction>,
}

pub struct ThreadTimeline {
    pub thread_id: ThreadId,
    pub events: Vec<ThreadEvent>,
}

pub struct ThreadEvent {
    pub timestamp: u64,
    pub event_type: ThreadEventType,
    pub location: Option<SourceLocation>,
}

#[derive(Debug, Clone)]
pub enum ThreadEventType {
    Start,
    End,
    Suspend,
    Resume,
    Lock(u64),
    Unlock(u64),
    Wait,
    Signal,
    Message { to: ThreadId, data: String },
}

pub struct ThreadInteraction {
    pub from_thread: ThreadId,
    pub to_thread: ThreadId,
    pub interaction_type: InteractionType,
    pub timestamp: u64,
}

#[derive(Debug, Clone)]
pub enum InteractionType {
    Spawn,
    Join,
    MessageSend,
    LockContention,
    ConditionSignal,
}

/// Visualization renderer
pub struct VisualizationRenderer {
    format: OutputFormat,
}

#[derive(Debug, Clone)]
pub enum OutputFormat {
    Svg,
    Html,
    Dot,
    Json,
    Mermaid,
    PlantUml,
}

/// Visualizer configuration
pub struct VisualizerConfig {
    pub format: OutputFormat,
    pub include_call_graph: bool,
    pub include_memory: bool,
    pub include_values: bool,
    pub include_threads: bool,
    pub max_depth: u32,
    pub color_scheme: ColorScheme,
}

pub struct ColorScheme {
    pub function_colors: HashMap<String, Color>,
    pub default_function: Color,
    pub allocation_color: Color,
    pub stack_color: Color,
    pub highlight_color: Color,
}

impl DebugVisualizer {
    pub fn new(config: VisualizerConfig) -> Self {
        Self {
            renderer: VisualizationRenderer::new(config.format.clone()),
            data: VisualizationData::new(),
            config,
        }
    }

    /// Record a function call for call graph
    pub fn record_call(&mut self, caller: &str, callee: &str, location: SourceLocation) {
        let caller_id = self.get_or_create_node(caller, &location);
        let callee_id = self.get_or_create_node(callee, &location);

        // Add or update edge
        if let Some(edge) = self.data.call_graph.edges.iter_mut()
            .find(|e| e.from == caller_id && e.to == callee_id) {
            edge.call_count += 1;
        } else {
            self.data.call_graph.edges.push(CallGraphEdge {
                from: caller_id,
                to: callee_id,
                call_count: 1,
                label: None,
            });
        }
    }

    /// Record a variable value
    pub fn record_value(&mut self, var_name: &str, value: &str, location: SourceLocation) {
        let timestamp = self.current_timestamp();

        self.data.value_timeline
            .entry(var_name.to_string())
            .or_insert_with(Vec::new)
            .push(ValuePoint {
                timestamp,
                value: value.to_string(),
                location,
            });
    }

    /// Take a memory snapshot
    pub fn snapshot_memory(&mut self, allocations: Vec<AllocationVisual>) {
        self.data.memory_snapshots.push(MemorySnapshot {
            timestamp: Instant::now(),
            heap_usage: allocations.iter().map(|a| a.size).sum(),
            stack_usage: 0,
            allocations,
        });
    }

    /// Generate call graph visualization
    pub fn render_call_graph(&self) -> Result<String, DebugError> {
        self.renderer.render_call_graph(&self.data.call_graph)
    }

    /// Generate memory visualization
    pub fn render_memory(&self) -> Result<String, DebugError> {
        self.renderer.render_memory(&self.data.memory_snapshots)
    }

    /// Generate value timeline
    pub fn render_value_timeline(&self, var_name: &str) -> Result<String, DebugError> {
        let timeline = self.data.value_timeline.get(var_name)
            .ok_or(DebugError::VariableNotFound(var_name.to_string()))?;
        self.renderer.render_value_timeline(var_name, timeline)
    }

    /// Generate thread diagram
    pub fn render_thread_diagram(&self) -> Result<String, DebugError> {
        self.renderer.render_thread_diagram(&self.data.thread_diagram)
    }

    /// Generate complete visualization report
    pub fn render_full_report(&self) -> Result<String, DebugError> {
        let mut output = String::new();

        if self.config.include_call_graph {
            output.push_str(&self.render_call_graph()?);
            output.push_str("\n\n");
        }

        if self.config.include_memory && !self.data.memory_snapshots.is_empty() {
            output.push_str(&self.render_memory()?);
            output.push_str("\n\n");
        }

        if self.config.include_threads {
            output.push_str(&self.render_thread_diagram()?);
        }

        Ok(output)
    }

    fn get_or_create_node(&mut self, name: &str, location: &SourceLocation) -> u64 {
        if let Some(node) = self.data.call_graph.nodes.iter().find(|n| n.function_name == name) {
            return node.id;
        }

        let id = self.data.call_graph.nodes.len() as u64;
        self.data.call_graph.nodes.push(CallGraphNode {
            id,
            function_name: name.to_string(),
            file: location.file.clone(),
            line: location.line,
            call_count: 1,
            total_time: Duration::ZERO,
            self_time: Duration::ZERO,
        });
        id
    }

    fn current_timestamp(&self) -> u64 {
        static START: std::sync::OnceLock<Instant> = std::sync::OnceLock::new();
        let start = START.get_or_init(Instant::now);
        start.elapsed().as_nanos() as u64
    }
}

impl VisualizationData {
    pub fn new() -> Self {
        Self {
            call_graph: CallGraph { nodes: Vec::new(), edges: Vec::new() },
            memory_snapshots: Vec::new(),
            value_timeline: HashMap::new(),
            execution_flow: Vec::new(),
            thread_diagram: ThreadDiagram {
                threads: Vec::new(),
                interactions: Vec::new(),
            },
        }
    }
}

impl VisualizationRenderer {
    pub fn new(format: OutputFormat) -> Self {
        Self { format }
    }

    pub fn render_call_graph(&self, graph: &CallGraph) -> Result<String, DebugError> {
        match self.format {
            OutputFormat::Dot => self.call_graph_to_dot(graph),
            OutputFormat::Mermaid => self.call_graph_to_mermaid(graph),
            OutputFormat::Svg => self.call_graph_to_svg(graph),
            _ => self.call_graph_to_dot(graph),
        }
    }

    pub fn render_memory(&self, snapshots: &[MemorySnapshot]) -> Result<String, DebugError> {
        match self.format {
            OutputFormat::Svg => self.memory_to_svg(snapshots),
            OutputFormat::Html => self.memory_to_html(snapshots),
            _ => self.memory_to_svg(snapshots),
        }
    }

    pub fn render_value_timeline(&self, name: &str, timeline: &[ValuePoint]) -> Result<String, DebugError> {
        let mut output = format!("Value timeline for '{}':\n", name);
        for point in timeline {
            output.push_str(&format!("  [{}] {} @ {}:{}\n",
                point.timestamp, point.value, point.location.file.display(), point.location.line));
        }
        Ok(output)
    }

    pub fn render_thread_diagram(&self, diagram: &ThreadDiagram) -> Result<String, DebugError> {
        match self.format {
            OutputFormat::Mermaid => self.thread_diagram_to_mermaid(diagram),
            OutputFormat::PlantUml => self.thread_diagram_to_plantuml(diagram),
            _ => self.thread_diagram_to_mermaid(diagram),
        }
    }

    fn call_graph_to_dot(&self, graph: &CallGraph) -> Result<String, DebugError> {
        let mut output = String::from("digraph CallGraph {\n");
        output.push_str("  rankdir=TB;\n");
        output.push_str("  node [shape=box];\n\n");

        for node in &graph.nodes {
            output.push_str(&format!("  n{} [label=\"{}\\n(calls: {})\"];\n",
                node.id, node.function_name, node.call_count));
        }

        output.push('\n');

        for edge in &graph.edges {
            output.push_str(&format!("  n{} -> n{} [label=\"{}\"];\n",
                edge.from, edge.to, edge.call_count));
        }

        output.push_str("}\n");
        Ok(output)
    }

    fn call_graph_to_mermaid(&self, graph: &CallGraph) -> Result<String, DebugError> {
        let mut output = String::from("graph TD\n");

        for node in &graph.nodes {
            output.push_str(&format!("  n{}[\"{}\"]\n", node.id, node.function_name));
        }

        for edge in &graph.edges {
            output.push_str(&format!("  n{} -->|{}| n{}\n", edge.from, edge.call_count, edge.to));
        }

        Ok(output)
    }

    fn call_graph_to_svg(&self, _graph: &CallGraph) -> Result<String, DebugError> {
        // Generate SVG representation
        Ok("<svg><!-- Call graph SVG --></svg>".to_string())
    }

    fn memory_to_svg(&self, _snapshots: &[MemorySnapshot]) -> Result<String, DebugError> {
        Ok("<svg><!-- Memory visualization SVG --></svg>".to_string())
    }

    fn memory_to_html(&self, snapshots: &[MemorySnapshot]) -> Result<String, DebugError> {
        let mut html = String::from("<html><body><h1>Memory Snapshots</h1>\n");

        for (i, snapshot) in snapshots.iter().enumerate() {
            html.push_str(&format!("<h2>Snapshot {}</h2>\n", i + 1));
            html.push_str(&format!("<p>Heap: {} bytes, Stack: {} bytes</p>\n",
                snapshot.heap_usage, snapshot.stack_usage));
            html.push_str("<ul>\n");

            for alloc in &snapshot.allocations {
                html.push_str(&format!("<li>0x{:x}: {} ({} bytes)</li>\n",
                    alloc.address, alloc.type_name, alloc.size));
            }

            html.push_str("</ul>\n");
        }

        html.push_str("</body></html>");
        Ok(html)
    }

    fn thread_diagram_to_mermaid(&self, diagram: &ThreadDiagram) -> Result<String, DebugError> {
        let mut output = String::from("sequenceDiagram\n");

        for thread in &diagram.threads {
            output.push_str(&format!("  participant T{}\n", thread.thread_id));
        }

        for interaction in &diagram.interactions {
            let arrow = match interaction.interaction_type {
                InteractionType::Spawn => "->>",
                InteractionType::Join => "-->>",
                InteractionType::MessageSend => "->>",
                InteractionType::LockContention => "-->",
                InteractionType::ConditionSignal => "->>",
            };
            output.push_str(&format!("  T{} {} T{}: {:?}\n",
                interaction.from_thread, arrow, interaction.to_thread, interaction.interaction_type));
        }

        Ok(output)
    }

    fn thread_diagram_to_plantuml(&self, diagram: &ThreadDiagram) -> Result<String, DebugError> {
        let mut output = String::from("@startuml\n");

        for thread in &diagram.threads {
            output.push_str(&format!("participant \"Thread {}\" as T{}\n", thread.thread_id, thread.thread_id));
        }

        for interaction in &diagram.interactions {
            output.push_str(&format!("T{} -> T{}: {:?}\n",
                interaction.from_thread, interaction.to_thread, interaction.interaction_type));
        }

        output.push_str("@enduml\n");
        Ok(output)
    }
}

impl Default for VisualizerConfig {
    fn default() -> Self {
        Self {
            format: OutputFormat::Mermaid,
            include_call_graph: true,
            include_memory: true,
            include_values: true,
            include_threads: true,
            max_depth: 10,
            color_scheme: ColorScheme::default(),
        }
    }
}

impl Default for ColorScheme {
    fn default() -> Self {
        Self {
            function_colors: HashMap::new(),
            default_function: Color { r: 100, g: 149, b: 237, a: 255 },
            allocation_color: Color { r: 144, g: 238, b: 144, a: 255 },
            stack_color: Color { r: 255, g: 182, b: 193, a: 255 },
            highlight_color: Color { r: 255, g: 255, b: 0, a: 255 },
        }
    }
}

// ============================================================================
// Debug Session Persistence - Save and Restore Debug Sessions
// ============================================================================

/// Debug session persistence manager
pub struct SessionPersistence {
    /// Storage backend
    storage: Box<dyn SessionStorage>,
    /// Serialization format
    format: SerializationFormat,
    /// Compression enabled
    compression: bool,
}

/// Session storage trait
pub trait SessionStorage: Send + Sync {
    fn save(&self, id: &str, data: &[u8]) -> Result<(), DebugError>;
    fn load(&self, id: &str) -> Result<Vec<u8>, DebugError>;
    fn delete(&self, id: &str) -> Result<(), DebugError>;
    fn list(&self) -> Result<Vec<String>, DebugError>;
}

/// File-based session storage
pub struct FileSessionStorage {
    base_path: PathBuf,
}

/// In-memory session storage
pub struct MemorySessionStorage {
    sessions: RwLock<HashMap<String, Vec<u8>>>,
}

/// Serialization format for sessions
#[derive(Debug, Clone)]
pub enum SerializationFormat {
    Json,
    MessagePack,
    Bincode,
}

/// Complete debug session state
#[derive(Serialize, Deserialize)]
pub struct SessionState {
    pub id: String,
    pub created_at: u64,
    pub updated_at: u64,
    pub program_path: PathBuf,
    pub breakpoints: Vec<SerializedBreakpoint>,
    pub watchpoints: Vec<SerializedWatchpoint>,
    pub variables: Vec<SerializedVariable>,
    pub call_stack: Vec<SerializedStackFrame>,
    pub memory_regions: Vec<SerializedMemoryRegion>,
    pub threads: Vec<SerializedThread>,
    pub settings: SessionSettings,
}

#[derive(Serialize, Deserialize)]
pub struct SerializedBreakpoint {
    pub id: u64,
    pub file: String,
    pub line: u32,
    pub column: Option<u32>,
    pub condition: Option<String>,
    pub hit_count: u64,
    pub enabled: bool,
}

#[derive(Serialize, Deserialize)]
pub struct SerializedWatchpoint {
    pub id: u64,
    pub expression: String,
    pub access_type: String,
    pub enabled: bool,
}

#[derive(Serialize, Deserialize)]
pub struct SerializedVariable {
    pub name: String,
    pub value: String,
    pub var_type: String,
    pub scope: String,
}

#[derive(Serialize, Deserialize)]
pub struct SerializedStackFrame {
    pub id: u64,
    pub name: String,
    pub file: String,
    pub line: u32,
    pub column: u32,
}

#[derive(Serialize, Deserialize)]
pub struct SerializedMemoryRegion {
    pub start: u64,
    pub end: u64,
    pub name: String,
    pub permissions: String,
}

#[derive(Serialize, Deserialize)]
pub struct SerializedThread {
    pub id: u64,
    pub name: String,
    pub state: String,
    pub current_frame: Option<u64>,
}

#[derive(Serialize, Deserialize)]
pub struct SessionSettings {
    pub stop_on_entry: bool,
    pub follow_fork_mode: String,
    pub detach_on_fork: bool,
    pub max_stack_depth: u32,
}

impl SessionPersistence {
    pub fn new(storage: Box<dyn SessionStorage>, format: SerializationFormat) -> Self {
        Self {
            storage,
            format,
            compression: true,
        }
    }

    pub fn with_file_storage(base_path: PathBuf) -> Self {
        Self::new(
            Box::new(FileSessionStorage::new(base_path)),
            SerializationFormat::MessagePack,
        )
    }

    /// Save a debug session
    pub fn save_session(&self, state: &SessionState) -> Result<String, DebugError> {
        let data = self.serialize(state)?;
        let data = if self.compression {
            self.compress(&data)?
        } else {
            data
        };

        self.storage.save(&state.id, &data)?;
        Ok(state.id.clone())
    }

    /// Load a debug session
    pub fn load_session(&self, id: &str) -> Result<SessionState, DebugError> {
        let data = self.storage.load(id)?;
        let data = if self.compression {
            self.decompress(&data)?
        } else {
            data
        };

        self.deserialize(&data)
    }

    /// Delete a saved session
    pub fn delete_session(&self, id: &str) -> Result<(), DebugError> {
        self.storage.delete(id)
    }

    /// List all saved sessions
    pub fn list_sessions(&self) -> Result<Vec<String>, DebugError> {
        self.storage.list()
    }

    fn serialize(&self, state: &SessionState) -> Result<Vec<u8>, DebugError> {
        match self.format {
            SerializationFormat::Json => {
                serde_json::to_vec(state)
                    .map_err(|e| DebugError::SerializationError(e.to_string()))
            }
            SerializationFormat::MessagePack => {
                rmp_serde::to_vec(state)
                    .map_err(|e| DebugError::SerializationError(e.to_string()))
            }
            SerializationFormat::Bincode => {
                bincode::serialize(state)
                    .map_err(|e| DebugError::SerializationError(e.to_string()))
            }
        }
    }

    fn deserialize(&self, data: &[u8]) -> Result<SessionState, DebugError> {
        match self.format {
            SerializationFormat::Json => {
                serde_json::from_slice(data)
                    .map_err(|e| DebugError::DeserializationError(e.to_string()))
            }
            SerializationFormat::MessagePack => {
                rmp_serde::from_slice(data)
                    .map_err(|e| DebugError::DeserializationError(e.to_string()))
            }
            SerializationFormat::Bincode => {
                bincode::deserialize(data)
                    .map_err(|e| DebugError::DeserializationError(e.to_string()))
            }
        }
    }

    fn compress(&self, data: &[u8]) -> Result<Vec<u8>, DebugError> {
        use flate2::write::GzEncoder;
        use flate2::Compression;
        use std::io::Write;

        let mut encoder = GzEncoder::new(Vec::new(), Compression::default());
        encoder.write_all(data)
            .map_err(|e| DebugError::CompressionError(e.to_string()))?;
        encoder.finish()
            .map_err(|e| DebugError::CompressionError(e.to_string()))
    }

    fn decompress(&self, data: &[u8]) -> Result<Vec<u8>, DebugError> {
        use flate2::read::GzDecoder;
        use std::io::Read;

        let mut decoder = GzDecoder::new(data);
        let mut decompressed = Vec::new();
        decoder.read_to_end(&mut decompressed)
            .map_err(|e| DebugError::DecompressionError(e.to_string()))?;
        Ok(decompressed)
    }
}

impl FileSessionStorage {
    pub fn new(base_path: PathBuf) -> Self {
        std::fs::create_dir_all(&base_path).ok();
        Self { base_path }
    }

    fn session_path(&self, id: &str) -> PathBuf {
        self.base_path.join(format!("{}.session", id))
    }
}

impl SessionStorage for FileSessionStorage {
    fn save(&self, id: &str, data: &[u8]) -> Result<(), DebugError> {
        std::fs::write(self.session_path(id), data)
            .map_err(|e| DebugError::IoError(e.to_string()))
    }

    fn load(&self, id: &str) -> Result<Vec<u8>, DebugError> {
        std::fs::read(self.session_path(id))
            .map_err(|e| DebugError::IoError(e.to_string()))
    }

    fn delete(&self, id: &str) -> Result<(), DebugError> {
        std::fs::remove_file(self.session_path(id))
            .map_err(|e| DebugError::IoError(e.to_string()))
    }

    fn list(&self) -> Result<Vec<String>, DebugError> {
        let mut sessions = Vec::new();

        for entry in std::fs::read_dir(&self.base_path)
            .map_err(|e| DebugError::IoError(e.to_string()))?
        {
            if let Ok(entry) = entry {
                if let Some(name) = entry.file_name().to_str() {
                    if name.ends_with(".session") {
                        sessions.push(name.trim_end_matches(".session").to_string());
                    }
                }
            }
        }

        Ok(sessions)
    }
}

impl MemorySessionStorage {
    pub fn new() -> Self {
        Self {
            sessions: RwLock::new(HashMap::new()),
        }
    }
}

impl SessionStorage for MemorySessionStorage {
    fn save(&self, id: &str, data: &[u8]) -> Result<(), DebugError> {
        self.sessions.write().unwrap().insert(id.to_string(), data.to_vec());
        Ok(())
    }

    fn load(&self, id: &str) -> Result<Vec<u8>, DebugError> {
        self.sessions.read().unwrap().get(id)
            .cloned()
            .ok_or(DebugError::SessionNotFound)
    }

    fn delete(&self, id: &str) -> Result<(), DebugError> {
        self.sessions.write().unwrap().remove(id);
        Ok(())
    }

    fn list(&self) -> Result<Vec<String>, DebugError> {
        Ok(self.sessions.read().unwrap().keys().cloned().collect())
    }
}

// ============================================================================
// Debug Extension API - Plugin System for Debugger
// ============================================================================

/// Debug extension manager
pub struct ExtensionManager {
    /// Loaded extensions
    extensions: HashMap<String, Box<dyn DebugExtension>>,
    /// Extension registry
    registry: ExtensionRegistry,
    /// Event bus for extension communication
    event_bus: Arc<ExtensionEventBus>,
}

/// Debug extension trait
pub trait DebugExtension: Send + Sync {
    /// Extension name
    fn name(&self) -> &str;

    /// Extension version
    fn version(&self) -> &str;

    /// Initialize the extension
    fn initialize(&mut self, context: &ExtensionContext) -> Result<(), DebugError>;

    /// Shutdown the extension
    fn shutdown(&mut self) -> Result<(), DebugError>;

    /// Handle debug events
    fn on_event(&mut self, event: &DebugEvent) -> Result<(), DebugError>;

    /// Get extension capabilities
    fn capabilities(&self) -> ExtensionCapabilities;

    /// Execute an extension command
    fn execute_command(&mut self, command: &str, args: &[String]) -> Result<String, DebugError>;
}

/// Extension context provided to extensions
pub struct ExtensionContext {
    pub debug_session: Arc<RwLock<Option<DebugSession>>>,
    pub event_bus: Arc<ExtensionEventBus>,
    pub config: ExtensionConfig,
}

/// Extension configuration
pub struct ExtensionConfig {
    pub data_dir: PathBuf,
    pub settings: HashMap<String, String>,
}

/// Extension capabilities
pub struct ExtensionCapabilities {
    pub provides_visualizations: bool,
    pub provides_formatters: bool,
    pub provides_commands: Vec<String>,
    pub supported_languages: Vec<String>,
    pub supported_events: Vec<String>,
}

/// Debug event for extensions
#[derive(Debug, Clone)]
pub enum DebugEvent {
    SessionStarted(u64),
    SessionEnded(u64),
    BreakpointHit { id: BreakpointId, location: SourceLocation },
    StepCompleted { thread_id: ThreadId, location: SourceLocation },
    ExceptionThrown { thread_id: ThreadId, exception: String },
    VariableChanged { name: String, old_value: String, new_value: String },
    ThreadCreated(ThreadId),
    ThreadExited(ThreadId),
    ModuleLoaded { name: String, path: PathBuf },
    Custom { name: String, data: HashMap<String, String> },
}

/// Extension event bus
pub struct ExtensionEventBus {
    subscribers: RwLock<HashMap<String, Vec<Box<dyn Fn(&DebugEvent) + Send + Sync>>>>,
}

/// Extension registry
pub struct ExtensionRegistry {
    available: HashMap<String, ExtensionInfo>,
}

/// Extension information
pub struct ExtensionInfo {
    pub name: String,
    pub version: String,
    pub author: String,
    pub description: String,
    pub entry_point: String,
}

/// Debug session reference for extensions
pub struct DebugSession {
    pub id: u64,
    pub program: PathBuf,
    pub state: DebugState,
}

#[derive(Debug, Clone)]
pub enum DebugState {
    Running,
    Paused,
    Stopped,
}

impl ExtensionManager {
    pub fn new() -> Self {
        Self {
            extensions: HashMap::new(),
            registry: ExtensionRegistry::new(),
            event_bus: Arc::new(ExtensionEventBus::new()),
        }
    }

    /// Load an extension
    pub fn load_extension(&mut self, name: &str) -> Result<(), DebugError> {
        let info = self.registry.get(name)
            .ok_or(DebugError::ExtensionNotFound(name.to_string()))?;

        let extension = self.create_extension(&info)?;
        self.extensions.insert(name.to_string(), extension);

        // Initialize the extension
        let context = ExtensionContext {
            debug_session: Arc::new(RwLock::new(None)),
            event_bus: self.event_bus.clone(),
            config: ExtensionConfig {
                data_dir: PathBuf::from("extensions").join(name),
                settings: HashMap::new(),
            },
        };

        if let Some(ext) = self.extensions.get_mut(name) {
            ext.initialize(&context)?;
        }

        Ok(())
    }

    /// Unload an extension
    pub fn unload_extension(&mut self, name: &str) -> Result<(), DebugError> {
        if let Some(mut ext) = self.extensions.remove(name) {
            ext.shutdown()?;
        }
        Ok(())
    }

    /// Dispatch an event to all extensions
    pub fn dispatch_event(&mut self, event: &DebugEvent) -> Result<(), DebugError> {
        for ext in self.extensions.values_mut() {
            ext.on_event(event)?;
        }
        self.event_bus.publish(event);
        Ok(())
    }

    /// Execute an extension command
    pub fn execute_command(
        &mut self,
        extension: &str,
        command: &str,
        args: &[String],
    ) -> Result<String, DebugError> {
        let ext = self.extensions.get_mut(extension)
            .ok_or(DebugError::ExtensionNotFound(extension.to_string()))?;
        ext.execute_command(command, args)
    }

    /// List loaded extensions
    pub fn list_extensions(&self) -> Vec<&str> {
        self.extensions.keys().map(|s| s.as_str()).collect()
    }

    /// Register an extension in the registry
    pub fn register_extension(&mut self, info: ExtensionInfo) {
        self.registry.register(info);
    }

    fn create_extension(&self, info: &ExtensionInfo) -> Result<Box<dyn DebugExtension>, DebugError> {
        // Create extension instance based on entry point
        // In a real implementation, this would load a dynamic library
        Err(DebugError::ExtensionLoadFailed(format!(
            "Dynamic loading not implemented for {}", info.name
        )))
    }
}

impl ExtensionEventBus {
    pub fn new() -> Self {
        Self {
            subscribers: RwLock::new(HashMap::new()),
        }
    }

    pub fn subscribe<F>(&self, event_type: &str, handler: F)
    where
        F: Fn(&DebugEvent) + Send + Sync + 'static,
    {
        self.subscribers.write().unwrap()
            .entry(event_type.to_string())
            .or_insert_with(Vec::new)
            .push(Box::new(handler));
    }

    pub fn publish(&self, event: &DebugEvent) {
        let event_type = self.event_type_name(event);

        if let Some(handlers) = self.subscribers.read().unwrap().get(&event_type) {
            for handler in handlers {
                handler(event);
            }
        }

        // Also notify wildcard subscribers
        if let Some(handlers) = self.subscribers.read().unwrap().get("*") {
            for handler in handlers {
                handler(event);
            }
        }
    }

    fn event_type_name(&self, event: &DebugEvent) -> String {
        match event {
            DebugEvent::SessionStarted(_) => "session_started".to_string(),
            DebugEvent::SessionEnded(_) => "session_ended".to_string(),
            DebugEvent::BreakpointHit { .. } => "breakpoint_hit".to_string(),
            DebugEvent::StepCompleted { .. } => "step_completed".to_string(),
            DebugEvent::ExceptionThrown { .. } => "exception_thrown".to_string(),
            DebugEvent::VariableChanged { .. } => "variable_changed".to_string(),
            DebugEvent::ThreadCreated(_) => "thread_created".to_string(),
            DebugEvent::ThreadExited(_) => "thread_exited".to_string(),
            DebugEvent::ModuleLoaded { .. } => "module_loaded".to_string(),
            DebugEvent::Custom { name, .. } => name.clone(),
        }
    }
}

impl ExtensionRegistry {
    pub fn new() -> Self {
        Self {
            available: HashMap::new(),
        }
    }

    pub fn register(&mut self, info: ExtensionInfo) {
        self.available.insert(info.name.clone(), info);
    }

    pub fn get(&self, name: &str) -> Option<&ExtensionInfo> {
        self.available.get(name)
    }

    pub fn list(&self) -> Vec<&ExtensionInfo> {
        self.available.values().collect()
    }
}

// ============================================================================
// Additional Debug Error Variants
// ============================================================================

impl DebugError {
    pub fn session_not_found() -> Self {
        DebugError::SessionNotFound
    }

    pub fn no_thread_focus() -> Self {
        DebugError::NoThreadFocus
    }
}

// Extended error types
#[derive(Debug)]
pub enum DebugError {
    IoError(String),
    SessionNotFound,
    NoThreadFocus,
    VariableNotFound(String),
    SerializationError(String),
    DeserializationError(String),
    CompressionError(String),
    DecompressionError(String),
    ExtensionNotFound(String),
    ExtensionLoadFailed(String),
    NetworkError(String),
    ProtocolError(String),
    TimeoutError,
    InvalidState(String),
}

// ============================================================================
// Extended Unit Tests
// ============================================================================

#[cfg(test)]
mod extended_tests {
    use super::*;

    #[test]
    fn test_distributed_debugger_creation() {
        let config = DistributedDebugConfig::default();
        let debugger = DistributedDebugger::new(config);

        assert!(debugger.nodes.read().unwrap().is_empty());
        assert!(debugger.global_breakpoints.read().unwrap().is_empty());
    }

    #[test]
    fn test_node_discovery() {
        let discovery = NodeDiscovery::new();
        discovery.register_node(1, "127.0.0.1:5000".parse().unwrap());
        discovery.register_node(2, "127.0.0.1:5001".parse().unwrap());

        assert_eq!(discovery.known_nodes.read().unwrap().len(), 2);
    }

    #[test]
    fn test_sync_state() {
        let mut state = SyncState::new();
        state.logical_clock += 1;

        assert_eq!(state.logical_clock, 1);
        assert!(state.vector_clocks.is_empty());
    }

    #[test]
    fn test_gpu_debugger_creation() {
        let config = GpuDebugConfig::default();
        let debugger = GpuDebugger::new(config);

        assert!(debugger.is_ok());
    }

    #[test]
    fn test_gpu_memory_inspector() {
        let mut inspector = GpuMemoryInspector::new();

        let alloc = GpuAllocation {
            address: 0x1000,
            size: 1024,
            memory_type: GpuMemoryType::Global,
            allocated_by: "test".to_string(),
            allocation_time: Instant::now(),
        };

        inspector.track_allocation(alloc);
        assert!(inspector.allocations.contains_key(&0x1000));
    }

    #[test]
    fn test_gpu_bounds_checker() {
        let mut checker = GpuBoundsChecker::new();

        checker.add_region(MemoryRegion {
            start: 0x1000,
            end: 0x2000,
            permissions: MemoryPermissions { read: true, write: true, execute: false },
            name: "test_region".to_string(),
        });

        let thread = ThreadFocus { block: (0, 0, 0), thread: (0, 0, 0) };

        assert!(checker.check_access(0x1500, 4, MemoryAccessType::Read, thread.clone()));
        assert!(!checker.check_access(0x3000, 4, MemoryAccessType::Read, thread));
    }

    #[test]
    fn test_debug_visualizer() {
        let config = VisualizerConfig::default();
        let mut visualizer = DebugVisualizer::new(config);

        let location = SourceLocation {
            file: PathBuf::from("test.quanta"),
            line: 10,
            column: 0,
            function: Some("main".to_string()),
        };

        visualizer.record_call("main", "helper", location.clone());
        visualizer.record_value("x", "42", location);

        assert_eq!(visualizer.data.call_graph.nodes.len(), 2);
        assert_eq!(visualizer.data.call_graph.edges.len(), 1);
        assert!(visualizer.data.value_timeline.contains_key("x"));
    }

    #[test]
    fn test_visualization_renderer_dot() {
        let renderer = VisualizationRenderer::new(OutputFormat::Dot);

        let graph = CallGraph {
            nodes: vec![
                CallGraphNode {
                    id: 0,
                    function_name: "main".to_string(),
                    file: PathBuf::from("test.quanta"),
                    line: 1,
                    call_count: 1,
                    total_time: Duration::ZERO,
                    self_time: Duration::ZERO,
                },
                CallGraphNode {
                    id: 1,
                    function_name: "helper".to_string(),
                    file: PathBuf::from("test.quanta"),
                    line: 10,
                    call_count: 5,
                    total_time: Duration::ZERO,
                    self_time: Duration::ZERO,
                },
            ],
            edges: vec![
                CallGraphEdge {
                    from: 0,
                    to: 1,
                    call_count: 5,
                    label: None,
                },
            ],
        };

        let result = renderer.render_call_graph(&graph);
        assert!(result.is_ok());
        assert!(result.unwrap().contains("digraph"));
    }

    #[test]
    fn test_visualization_renderer_mermaid() {
        let renderer = VisualizationRenderer::new(OutputFormat::Mermaid);

        let graph = CallGraph {
            nodes: vec![
                CallGraphNode {
                    id: 0,
                    function_name: "main".to_string(),
                    file: PathBuf::from("test.quanta"),
                    line: 1,
                    call_count: 1,
                    total_time: Duration::ZERO,
                    self_time: Duration::ZERO,
                },
            ],
            edges: Vec::new(),
        };

        let result = renderer.render_call_graph(&graph);
        assert!(result.is_ok());
        assert!(result.unwrap().contains("graph TD"));
    }

    #[test]
    fn test_memory_session_storage() {
        let storage = MemorySessionStorage::new();

        storage.save("test1", b"hello").unwrap();
        storage.save("test2", b"world").unwrap();

        assert_eq!(storage.load("test1").unwrap(), b"hello");
        assert_eq!(storage.load("test2").unwrap(), b"world");

        let sessions = storage.list().unwrap();
        assert_eq!(sessions.len(), 2);

        storage.delete("test1").unwrap();
        assert!(storage.load("test1").is_err());
    }

    #[test]
    fn test_extension_event_bus() {
        let bus = ExtensionEventBus::new();
        let received = Arc::new(AtomicBool::new(false));
        let received_clone = received.clone();

        bus.subscribe("breakpoint_hit", move |_event| {
            received_clone.store(true, Ordering::SeqCst);
        });

        let event = DebugEvent::BreakpointHit {
            id: 1,
            location: SourceLocation {
                file: PathBuf::from("test.quanta"),
                line: 10,
                column: 0,
                function: None,
            },
        };

        bus.publish(&event);
        assert!(received.load(Ordering::SeqCst));
    }

    #[test]
    fn test_extension_registry() {
        let mut registry = ExtensionRegistry::new();

        registry.register(ExtensionInfo {
            name: "test-ext".to_string(),
            version: "1.0.0".to_string(),
            author: "Test".to_string(),
            description: "Test extension".to_string(),
            entry_point: "test.so".to_string(),
        });

        assert!(registry.get("test-ext").is_some());
        assert!(registry.get("nonexistent").is_none());
        assert_eq!(registry.list().len(), 1);
    }

    #[test]
    fn test_extension_manager() {
        let manager = ExtensionManager::new();

        assert!(manager.list_extensions().is_empty());
    }

    #[test]
    fn test_divergence_analyzer() {
        let mut analyzer = DivergenceAnalyzer::new();

        analyzer.record_divergence(DivergencePoint {
            location: SourceLocation {
                file: PathBuf::from("kernel.quanta"),
                line: 50,
                column: 0,
                function: Some("compute".to_string()),
            },
            warp_id: 0,
            active_threads: 16,
            divergence_type: DivergenceType::Conditional,
        });

        analyzer.update_warp_state(WarpState {
            warp_id: 0,
            active_mask: 0xFFFF,
            converged: false,
            program_counter: 0x1000,
        });

        assert_eq!(analyzer.divergence_points.len(), 1);
        assert!(analyzer.warp_states.contains_key(&0));
    }

    #[test]
    fn test_kernel_debugger() {
        let mut debugger = KernelDebugger::new();

        debugger.register_kernel(1, KernelInfo {
            name: "matrix_multiply".to_string(),
            source: Some("kernel code".to_string()),
            grid_dim: (16, 16, 1),
            block_dim: (256, 1, 1),
            shared_memory: 4096,
            registers_per_thread: 32,
            arguments: Vec::new(),
        });

        assert!(debugger.active_kernels.contains_key(&1));
    }

    #[test]
    fn test_thread_diagram() {
        let diagram = ThreadDiagram {
            threads: vec![
                ThreadTimeline {
                    thread_id: 1,
                    events: vec![
                        ThreadEvent {
                            timestamp: 0,
                            event_type: ThreadEventType::Start,
                            location: None,
                        },
                    ],
                },
            ],
            interactions: vec![
                ThreadInteraction {
                    from_thread: 1,
                    to_thread: 2,
                    interaction_type: InteractionType::Spawn,
                    timestamp: 100,
                },
            ],
        };

        assert_eq!(diagram.threads.len(), 1);
        assert_eq!(diagram.interactions.len(), 1);
    }

    #[test]
    fn test_color_scheme() {
        let scheme = ColorScheme::default();

        assert_eq!(scheme.default_function.r, 100);
        assert!(scheme.function_colors.is_empty());
    }

    #[test]
    fn test_global_breakpoint() {
        let bp = GlobalBreakpoint {
            id: 1,
            location: BreakpointLocation::SourceLine {
                file: PathBuf::from("test.quanta"),
                line: 10
            },
            condition: Some("x > 5".to_string()),
            hit_count: AtomicU64::new(0),
            enabled: AtomicBool::new(true),
            log_message: None,
            target_nodes: vec![1, 2, 3],
        };

        assert!(bp.enabled.load(Ordering::SeqCst));
        bp.hit_count.fetch_add(1, Ordering::SeqCst);
        assert_eq!(bp.hit_count.load(Ordering::SeqCst), 1);
    }

    #[test]
    fn test_session_state_serialization() {
        let state = SessionState {
            id: "test-session".to_string(),
            created_at: 1234567890,
            updated_at: 1234567890,
            program_path: PathBuf::from("/test/program"),
            breakpoints: vec![
                SerializedBreakpoint {
                    id: 1,
                    file: "test.quanta".to_string(),
                    line: 10,
                    column: None,
                    condition: None,
                    hit_count: 0,
                    enabled: true,
                },
            ],
            watchpoints: Vec::new(),
            variables: Vec::new(),
            call_stack: Vec::new(),
            memory_regions: Vec::new(),
            threads: Vec::new(),
            settings: SessionSettings {
                stop_on_entry: true,
                follow_fork_mode: "parent".to_string(),
                detach_on_fork: false,
                max_stack_depth: 100,
            },
        };

        let json = serde_json::to_string(&state);
        assert!(json.is_ok());

        let parsed: Result<SessionState, _> = serde_json::from_str(&json.unwrap());
        assert!(parsed.is_ok());
        assert_eq!(parsed.unwrap().id, "test-session");
    }
}
