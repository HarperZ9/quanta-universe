    Pipe,
    Device,
}

#[derive(Debug, Clone)]
pub struct LockInfo {
    pub id: u64,
    pub name: Option<String>,
    pub lock_type: LockType,
    pub holder: Option<u64>,
    pub waiters: Vec<u64>,
    pub acquisition_stack: Option<Vec<StackFrameInfo>>,
    pub acquired_at: Option<u64>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LockType {
    Mutex,
    RwLockRead,
    RwLockWrite,
    Semaphore,
    Spinlock,
    Condvar,
}

#[derive(Debug, Clone)]
pub struct ChannelInfo {
