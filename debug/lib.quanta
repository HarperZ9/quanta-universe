// =============================================================================
// QUANTA DEBUG - Debug Adapter Protocol Implementation
// =============================================================================
// A full-featured debugger for QuantaLang supporting DAP for IDE integration.
// Provides breakpoints, stepping, variable inspection, and call stack viewing.
// =============================================================================

use quantalang::prelude::*;
use std::collections::{HashMap, HashSet, BTreeMap};
use std::sync::{Arc, RwLock, Mutex, atomic::{AtomicBool, AtomicU64, Ordering}};
use std::path::{Path, PathBuf};
use std::io::{Read, Write, BufReader, BufWriter};
use std::net::{TcpListener, TcpStream};

// =============================================================================
// DEBUG ADAPTER PROTOCOL TYPES
// =============================================================================

/// DAP message base
#[derive(Debug, Clone)]
pub struct ProtocolMessage {
    pub seq: u64,
    pub message_type: MessageType,
}

#[derive(Debug, Clone)]
pub enum MessageType {
    Request(Request),
    Response(Response),
    Event(Event),
}

/// DAP Request
#[derive(Debug, Clone)]
pub struct Request {
    pub command: String,
    pub arguments: Option<serde_json::Value>,
}

/// DAP Response
#[derive(Debug, Clone)]
pub struct Response {
    pub request_seq: u64,
    pub success: bool,
    pub command: String,
    pub message: Option<String>,
    pub body: Option<serde_json::Value>,
}

/// DAP Event
#[derive(Debug, Clone)]
pub struct Event {
    pub event: String,
    pub body: Option<serde_json::Value>,
}

// =============================================================================
// BREAKPOINT TYPES
// =============================================================================

/// Breakpoint identifier
pub type BreakpointId = u64;

/// Source breakpoint request
#[derive(Debug, Clone)]
pub struct SourceBreakpoint {
    pub line: u32,
    pub column: Option<u32>,
    pub condition: Option<String>,
    pub hit_condition: Option<String>,
    pub log_message: Option<String>,
}

/// Resolved breakpoint
#[derive(Debug, Clone)]
pub struct Breakpoint {
    pub id: BreakpointId,
    pub verified: bool,
    pub message: Option<String>,
    pub source: Source,
    pub line: u32,
    pub column: Option<u32>,
    pub end_line: Option<u32>,
    pub end_column: Option<u32>,
    pub instruction_reference: Option<String>,
}

/// Function breakpoint
#[derive(Debug, Clone)]
pub struct FunctionBreakpoint {
    pub name: String,
    pub condition: Option<String>,
    pub hit_condition: Option<String>,
}

/// Exception breakpoint
#[derive(Debug, Clone)]
pub struct ExceptionBreakpoint {
    pub filter_id: String,
    pub label: String,
    pub default: bool,
    pub supports_condition: bool,
    pub description: Option<String>,
}

/// Data breakpoint (watchpoint)
#[derive(Debug, Clone)]
pub struct DataBreakpoint {
    pub data_id: String,
    pub access_type: DataBreakpointAccessType,
    pub condition: Option<String>,
    pub hit_condition: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DataBreakpointAccessType {
    Read,
    Write,
    ReadWrite,
}

// =============================================================================
// SOURCE AND LOCATION TYPES
// =============================================================================

/// Source descriptor
#[derive(Debug, Clone)]
pub struct Source {
    pub name: Option<String>,
    pub path: Option<PathBuf>,
    pub source_reference: Option<u64>,
    pub presentation_hint: Option<SourcePresentationHint>,
    pub origin: Option<String>,
    pub sources: Vec<Source>,
    pub adapter_data: Option<serde_json::Value>,
    pub checksums: Vec<Checksum>,
}

impl Source {
    pub fn from_path(path: PathBuf) -> Self {
        Source {
            name: path.file_name().map(|n| n.to_string_lossy().to_string()),
            path: Some(path),
            source_reference: None,
            presentation_hint: None,
            origin: None,
            sources: Vec::new(),
            adapter_data: None,
            checksums: Vec::new(),
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SourcePresentationHint {
    Normal,
    Emphasize,
    Deemphasize,
}

#[derive(Debug, Clone)]
pub struct Checksum {
    pub algorithm: ChecksumAlgorithm,
    pub checksum: String,
}

#[derive(Debug, Clone, Copy)]
pub enum ChecksumAlgorithm {
    MD5,
    SHA1,
    SHA256,
    Timestamp,
}

// =============================================================================
// STACK AND SCOPE TYPES
// =============================================================================

/// Stack frame
#[derive(Debug, Clone)]
pub struct StackFrame {
    pub id: u64,
    pub name: String,
    pub source: Option<Source>,
    pub line: u32,
    pub column: u32,
    pub end_line: Option<u32>,
    pub end_column: Option<u32>,
    pub can_restart: bool,
    pub instruction_pointer_reference: Option<String>,
    pub module_id: Option<u64>,
    pub presentation_hint: Option<StackFramePresentationHint>,
}

#[derive(Debug, Clone, Copy)]
pub enum StackFramePresentationHint {
    Normal,
    Label,
    Subtle,
}

/// Scope
#[derive(Debug, Clone)]
pub struct Scope {
    pub name: String,
    pub presentation_hint: Option<ScopePresentationHint>,
    pub variables_reference: u64,
    pub named_variables: Option<u32>,
    pub indexed_variables: Option<u32>,
    pub expensive: bool,
    pub source: Option<Source>,
    pub line: Option<u32>,
    pub column: Option<u32>,
    pub end_line: Option<u32>,
    pub end_column: Option<u32>,
}

#[derive(Debug, Clone, Copy)]
pub enum ScopePresentationHint {
    Arguments,
    Locals,
    Registers,
}

/// Variable
#[derive(Debug, Clone)]
pub struct Variable {
    pub name: String,
    pub value: String,
    pub var_type: Option<String>,
    pub presentation_hint: Option<VariablePresentationHint>,
    pub evaluate_name: Option<String>,
    pub variables_reference: u64,
    pub named_variables: Option<u32>,
    pub indexed_variables: Option<u32>,
    pub memory_reference: Option<String>,
}

#[derive(Debug, Clone)]
pub struct VariablePresentationHint {
    pub kind: Option<String>,
    pub attributes: Vec<String>,
    pub visibility: Option<String>,
    pub lazy: bool,
}

// =============================================================================
// THREAD AND EXECUTION TYPES
// =============================================================================

/// Thread
#[derive(Debug, Clone)]
pub struct Thread {
    pub id: u64,
    pub name: String,
}

/// Stop reason
#[derive(Debug, Clone)]
pub enum StopReason {
    Step,
    Breakpoint,
    Exception,
    Pause,
    Entry,
    Goto,
    FunctionBreakpoint,
    DataBreakpoint,
    InstructionBreakpoint,
}

impl StopReason {
    pub fn as_str(&self) -> &'static str {
        match self {
            StopReason::Step => "step",
            StopReason::Breakpoint => "breakpoint",
            StopReason::Exception => "exception",
            StopReason::Pause => "pause",
            StopReason::Entry => "entry",
            StopReason::Goto => "goto",
            StopReason::FunctionBreakpoint => "function breakpoint",
            StopReason::DataBreakpoint => "data breakpoint",
            StopReason::InstructionBreakpoint => "instruction breakpoint",
        }
    }
}

/// Step granularity
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum StepGranularity {
    Statement,
    Line,
    Instruction,
}

