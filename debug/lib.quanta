}

// =============================================================================
// DEBUGGER STATE
// =============================================================================

/// Execution state
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ExecutionState {
    NotStarted,
    Running,
    Stopped,
    Terminated,
}

/// Debugger configuration
#[derive(Debug, Clone)]
pub struct DebugConfig {
    /// Program to debug
    pub program: PathBuf,

    /// Working directory
    pub cwd: Option<PathBuf>,

    /// Command-line arguments
    pub args: Vec<String>,

    /// Environment variables
    pub env: HashMap<String, String>,

    /// Stop at entry point
    pub stop_on_entry: bool,

    /// Source maps directory
    pub source_maps: Option<PathBuf>,

    /// Enable just-my-code filtering
    pub just_my_code: bool,

    /// Maximum call stack depth
    pub max_stack_depth: usize,
}

impl Default for DebugConfig {
    fn default() -> Self {
        DebugConfig {
            program: PathBuf::new(),
            cwd: None,
            args: Vec::new(),
            env: HashMap::new(),
            stop_on_entry: false,
            source_maps: None,
            just_my_code: true,
            max_stack_depth: 1000,
        }
    }
}

// =============================================================================
// BREAKPOINT MANAGER
// =============================================================================

/// Manages all breakpoints
pub struct BreakpointManager {
    next_id: AtomicU64,
    source_breakpoints: RwLock<HashMap<PathBuf, Vec<Breakpoint>>>,
    function_breakpoints: RwLock<HashMap<String, Breakpoint>>,
    data_breakpoints: RwLock<HashMap<String, DataBreakpoint>>,
    exception_filters: RwLock<HashSet<String>>,
}

impl BreakpointManager {
    pub fn new() -> Self {
        BreakpointManager {
            next_id: AtomicU64::new(1),
            source_breakpoints: RwLock::new(HashMap::new()),
            function_breakpoints: RwLock::new(HashMap::new()),
            data_breakpoints: RwLock::new(HashMap::new()),
            exception_filters: RwLock::new(HashSet::new()),
        }
    }

    /// Set source breakpoints for a file
    pub fn set_source_breakpoints(
        &self,
        source: &Source,
        breakpoints: Vec<SourceBreakpoint>,
    ) -> Vec<Breakpoint> {
        let path = source.path.clone().unwrap_or_default();
        let mut result = Vec::new();

        for bp in breakpoints {
            let id = self.next_id.fetch_add(1, Ordering::SeqCst);
            let verified = self.verify_breakpoint_location(&path, bp.line);

            result.push(Breakpoint {
                id,
                verified,
                message: if verified { None } else { Some("Could not verify breakpoint".to_string()) },
                source: source.clone(),
                line: bp.line,
                column: bp.column,
                end_line: None,
                end_column: None,
                instruction_reference: None,
            });
        }

        self.source_breakpoints.write().unwrap().insert(path, result.clone());
        result
    }

    /// Set function breakpoints
    pub fn set_function_breakpoints(&self, breakpoints: Vec<FunctionBreakpoint>) -> Vec<Breakpoint> {
        let mut result = Vec::new();
        let mut map = self.function_breakpoints.write().unwrap();
        map.clear();

        for bp in breakpoints {
            let id = self.next_id.fetch_add(1, Ordering::SeqCst);
            let verified = self.resolve_function(&bp.name).is_some();

            let breakpoint = Breakpoint {
                id,
                verified,
                message: if verified { None } else { Some(format!("Function '{}' not found", bp.name)) },
                source: Source {
                    name: None,
                    path: None,
                    source_reference: None,
                    presentation_hint: None,
                    origin: None,
                    sources: Vec::new(),
                    adapter_data: None,
                    checksums: Vec::new(),
                },
                line: 0,
                column: None,
                end_line: None,
                end_column: None,
                instruction_reference: None,
            };

            map.insert(bp.name, breakpoint.clone());
            result.push(breakpoint);
        }

        result
    }

    /// Set data breakpoints
    pub fn set_data_breakpoints(&self, breakpoints: Vec<DataBreakpoint>) -> Vec<Breakpoint> {
        let mut result = Vec::new();
        let mut map = self.data_breakpoints.write().unwrap();
        map.clear();

        for bp in breakpoints {
            let id = self.next_id.fetch_add(1, Ordering::SeqCst);

            let breakpoint = Breakpoint {
                id,
                verified: true, // Assume verified for data breakpoints
                message: None,
                source: Source {
                    name: None,
                    path: None,
                    source_reference: None,
                    presentation_hint: None,
                    origin: None,
                    sources: Vec::new(),
                    adapter_data: None,
                    checksums: Vec::new(),
                },
                line: 0,
                column: None,
                end_line: None,
                end_column: None,
                instruction_reference: None,
            };

            map.insert(bp.data_id.clone(), bp);
            result.push(breakpoint);
        }

        result
    }

    /// Set exception breakpoint filters
    pub fn set_exception_filters(&self, filters: Vec<String>) {
        let mut set = self.exception_filters.write().unwrap();
        set.clear();
        set.extend(filters);
    }

    /// Check if there's a breakpoint at a location
    pub fn check_breakpoint(&self, path: &Path, line: u32) -> Option<BreakpointId> {
        let breakpoints = self.source_breakpoints.read().unwrap();
        if let Some(file_breakpoints) = breakpoints.get(path) {
            for bp in file_breakpoints {
                if bp.line == line && bp.verified {
                    return Some(bp.id);
                }
            }
        }
        None
    }

    /// Check if there's a function breakpoint
    pub fn check_function_breakpoint(&self, name: &str) -> Option<BreakpointId> {
        let breakpoints = self.function_breakpoints.read().unwrap();
        breakpoints.get(name).map(|bp| bp.id)
    }

    /// Check if exception should break
    pub fn should_break_on_exception(&self, exception_type: &str, is_caught: bool) -> bool {
        let filters = self.exception_filters.read().unwrap();

        if filters.contains("all") {
            return true;
        }

        if !is_caught && filters.contains("uncaught") {
            return true;
        }

        false
    }

    fn verify_breakpoint_location(&self, _path: &Path, _line: u32) -> bool {
        // In a real implementation, this would check if the line contains executable code
        true
    }

    fn resolve_function(&self, _name: &str) -> Option<(PathBuf, u32)> {
        // In a real implementation, this would resolve function name to source location
        None
    }
}

// =============================================================================
// VARIABLE CONTAINER
// =============================================================================

/// Manages variable references for inspection
pub struct VariableContainer {
    next_reference: AtomicU64,
    containers: RwLock<HashMap<u64, VariableScope>>,
}

#[derive(Debug, Clone)]
pub struct VariableScope {
    pub variables: Vec<Variable>,
    pub parent: Option<u64>,
}

impl VariableContainer {
    pub fn new() -> Self {
        VariableContainer {
            next_reference: AtomicU64::new(1),
            containers: RwLock::new(HashMap::new()),
        }
    }

    /// Create a new variable reference
    pub fn create_reference(&self, variables: Vec<Variable>) -> u64 {
        let reference = self.next_reference.fetch_add(1, Ordering::SeqCst);
        self.containers.write().unwrap().insert(reference, VariableScope {
            variables,
            parent: None,
        });
        reference
    }

    /// Get variables for a reference
    pub fn get_variables(&self, reference: u64, start: Option<u32>, count: Option<u32>) -> Vec<Variable> {
        let containers = self.containers.read().unwrap();

        if let Some(scope) = containers.get(&reference) {
            let start = start.unwrap_or(0) as usize;
            let count = count.unwrap_or(scope.variables.len() as u32) as usize;

            scope.variables.iter()
                .skip(start)
                .take(count)
                .cloned()
                .collect()
        } else {
            Vec::new()
        }
    }

    /// Clear all containers
    pub fn clear(&self) {
        self.containers.write().unwrap().clear();
    }
}

// =============================================================================
// CALL STACK MANAGER
// =============================================================================

/// Manages call stack for threads
pub struct CallStackManager {
    stacks: RwLock<HashMap<u64, Vec<StackFrame>>>,
    next_frame_id: AtomicU64,
}

impl CallStackManager {
    pub fn new() -> Self {
        CallStackManager {
            stacks: RwLock::new(HashMap::new()),
            next_frame_id: AtomicU64::new(1),
        }
    }

    /// Push a frame onto a thread's stack
    pub fn push_frame(&self, thread_id: u64, frame: StackFrame) -> u64 {
        let frame_id = self.next_frame_id.fetch_add(1, Ordering::SeqCst);
        let mut frame = frame;
        frame.id = frame_id;

        let mut stacks = self.stacks.write().unwrap();
        stacks.entry(thread_id)
            .or_insert_with(Vec::new)
            .push(frame);

        frame_id
    }

    /// Pop a frame from a thread's stack
    pub fn pop_frame(&self, thread_id: u64) -> Option<StackFrame> {
        let mut stacks = self.stacks.write().unwrap();
        stacks.get_mut(&thread_id).and_then(|s| s.pop())
    }

    /// Get stack trace for a thread
    pub fn get_stack_trace(&self, thread_id: u64, start: Option<u32>, levels: Option<u32>) -> Vec<StackFrame> {
        let stacks = self.stacks.read().unwrap();

        if let Some(stack) = stacks.get(&thread_id) {
            let start = start.unwrap_or(0) as usize;
            let levels = levels.unwrap_or(stack.len() as u32) as usize;

            // Stack is in reverse order (top of stack first)
            stack.iter()
                .rev()
                .skip(start)
                .take(levels)
                .cloned()
                .collect()
        } else {
            Vec::new()
        }
    }

    /// Get a specific frame
    pub fn get_frame(&self, frame_id: u64) -> Option<StackFrame> {
        let stacks = self.stacks.read().unwrap();

        for stack in stacks.values() {
            for frame in stack {
                if frame.id == frame_id {
                    return Some(frame.clone());
                }
            }
        }

        None
    }

    /// Clear all stacks
    pub fn clear(&self) {
        self.stacks.write().unwrap().clear();
    }
}

// =============================================================================
// EXPRESSION EVALUATOR
// =============================================================================

/// Evaluates expressions in debug context
pub struct ExpressionEvaluator {
    // In a real implementation, this would have access to the runtime
}

impl ExpressionEvaluator {
    pub fn new() -> Self {
        ExpressionEvaluator {}
    }

    /// Evaluate an expression in the context of a stack frame
    pub fn evaluate(&self, expression: &str, frame_id: u64, context: EvaluateContext) -> EvaluateResult {
        // This is a simplified implementation
        // A real implementation would parse and evaluate the expression
        // against the actual runtime state

        match context {
            EvaluateContext::Watch | EvaluateContext::Repl => {
                self.evaluate_expression(expression, frame_id)
            }
            EvaluateContext::Hover => {
                self.evaluate_hover(expression, frame_id)
            }
            EvaluateContext::Clipboard => {
                EvaluateResult {
                    result: expression.to_string(),
                    var_type: Some("String".to_string()),
                    presentation_hint: None,
                    variables_reference: 0,
                    named_variables: None,
                    indexed_variables: None,
                    memory_reference: None,
                }
            }
        }
    }

    fn evaluate_expression(&self, expression: &str, _frame_id: u64) -> EvaluateResult {
        // Simplified expression evaluation
        // Try to parse as a simple literal
        if let Ok(n) = expression.parse::<i64>() {
            return EvaluateResult {
                result: n.to_string(),
                var_type: Some("i64".to_string()),
                presentation_hint: None,
                variables_reference: 0,
                named_variables: None,
                indexed_variables: None,
                memory_reference: None,
            };
        }

        if let Ok(f) = expression.parse::<f64>() {
            return EvaluateResult {
                result: f.to_string(),
                var_type: Some("f64".to_string()),
                presentation_hint: None,
                variables_reference: 0,
                named_variables: None,
                indexed_variables: None,
                memory_reference: None,
            };
        }

        if expression == "true" || expression == "false" {
            return EvaluateResult {
                result: expression.to_string(),
                var_type: Some("bool".to_string()),
                presentation_hint: None,
                variables_reference: 0,
                named_variables: None,
                indexed_variables: None,
                memory_reference: None,
            };
        }

        // Default: treat as variable lookup
        EvaluateResult {
            result: format!("<{}>", expression),
            var_type: Some("unknown".to_string()),
            presentation_hint: None,
            variables_reference: 0,
            named_variables: None,
            indexed_variables: None,
            memory_reference: None,
        }
    }

    fn evaluate_hover(&self, expression: &str, frame_id: u64) -> EvaluateResult {
        // For hover, just try to get the value of an identifier
        self.evaluate_expression(expression, frame_id)
    }
}

#[derive(Debug, Clone, Copy)]
pub enum EvaluateContext {
    Watch,
    Repl,
    Hover,
    Clipboard,
}

#[derive(Debug, Clone)]
pub struct EvaluateResult {
    pub result: String,
    pub var_type: Option<String>,
    pub presentation_hint: Option<VariablePresentationHint>,
    pub variables_reference: u64,
    pub named_variables: Option<u32>,
    pub indexed_variables: Option<u32>,
    pub memory_reference: Option<String>,
}

// =============================================================================
// DEBUG ADAPTER
// =============================================================================

/// Main debug adapter
pub struct DebugAdapter {
    config: DebugConfig,
    capabilities: Capabilities,
    state: RwLock<ExecutionState>,
    breakpoint_manager: Arc<BreakpointManager>,
    variable_container: Arc<VariableContainer>,
    call_stack_manager: Arc<CallStackManager>,
    evaluator: ExpressionEvaluator,
    threads: RwLock<HashMap<u64, Thread>>,
    next_seq: AtomicU64,
    initialized: AtomicBool,
    configuration_done: AtomicBool,
}

impl DebugAdapter {
    pub fn new() -> Self {
        DebugAdapter {
            config: DebugConfig::default(),
            capabilities: Capabilities::default(),
            state: RwLock::new(ExecutionState::NotStarted),
            breakpoint_manager: Arc::new(BreakpointManager::new()),
            variable_container: Arc::new(VariableContainer::new()),
            call_stack_manager: Arc::new(CallStackManager::new()),
            evaluator: ExpressionEvaluator::new(),
            threads: RwLock::new(HashMap::new()),
            next_seq: AtomicU64::new(1),
            initialized: AtomicBool::new(false),
            configuration_done: AtomicBool::new(false),
        }
    }

    /// Handle incoming request
    pub fn handle_request(&self, request: Request) -> Response {
        let command = request.command.clone();

        let result = match command.as_str() {
            "initialize" => self.handle_initialize(&request),
            "launch" => self.handle_launch(&request),
            "attach" => self.handle_attach(&request),
            "disconnect" => self.handle_disconnect(&request),
            "terminate" => self.handle_terminate(&request),
            "restart" => self.handle_restart(&request),
            "setBreakpoints" => self.handle_set_breakpoints(&request),
            "setFunctionBreakpoints" => self.handle_set_function_breakpoints(&request),
            "setExceptionBreakpoints" => self.handle_set_exception_breakpoints(&request),
            "dataBreakpointInfo" => self.handle_data_breakpoint_info(&request),
            "setDataBreakpoints" => self.handle_set_data_breakpoints(&request),
            "configurationDone" => self.handle_configuration_done(&request),
            "continue" => self.handle_continue(&request),
            "next" => self.handle_next(&request),
            "stepIn" => self.handle_step_in(&request),
            "stepOut" => self.handle_step_out(&request),
            "stepBack" => self.handle_step_back(&request),
            "pause" => self.handle_pause(&request),
            "stackTrace" => self.handle_stack_trace(&request),
            "scopes" => self.handle_scopes(&request),
            "variables" => self.handle_variables(&request),
            "setVariable" => self.handle_set_variable(&request),
            "source" => self.handle_source(&request),
            "threads" => self.handle_threads(&request),
            "modules" => self.handle_modules(&request),
            "loadedSources" => self.handle_loaded_sources(&request),
            "evaluate" => self.handle_evaluate(&request),
            "setExpression" => self.handle_set_expression(&request),
            "stepInTargets" => self.handle_step_in_targets(&request),
            "gotoTargets" => self.handle_goto_targets(&request),
            "completions" => self.handle_completions(&request),
            "exceptionInfo" => self.handle_exception_info(&request),
            "readMemory" => self.handle_read_memory(&request),
            "writeMemory" => self.handle_write_memory(&request),
            "disassemble" => self.handle_disassemble(&request),
            "cancel" => self.handle_cancel(&request),
            "breakpointLocations" => self.handle_breakpoint_locations(&request),
            _ => Err(format!("Unknown command: {}", command)),
        };

        match result {
            Ok(body) => Response {
                request_seq: 0, // Will be set by caller
                success: true,
                command,
                message: None,
                body: Some(body),
            },
            Err(message) => Response {
                request_seq: 0,
                success: false,
                command,
                message: Some(message),
                body: None,
            },
        }
    }

    // Request handlers

    fn handle_initialize(&self, _request: &Request) -> Result<serde_json::Value, String> {
        self.initialized.store(true, Ordering::SeqCst);

        Ok(serde_json::json!({
            "supportsConfigurationDoneRequest": self.capabilities.supports_configuration_done_request,
            "supportsFunctionBreakpoints": self.capabilities.supports_function_breakpoints,
            "supportsConditionalBreakpoints": self.capabilities.supports_conditional_breakpoints,
            "supportsHitConditionalBreakpoints": self.capabilities.supports_hit_conditional_breakpoints,
            "supportsEvaluateForHovers": self.capabilities.supports_evaluate_for_hovers,
            "supportsStepBack": self.capabilities.supports_step_back,
            "supportsSetVariable": self.capabilities.supports_set_variable,
            "supportsRestartFrame": self.capabilities.supports_restart_frame,
            "supportsStepInTargetsRequest": self.capabilities.supports_step_in_targets_request,
            "supportsCompletionsRequest": self.capabilities.supports_completions_request,
            "supportsModulesRequest": self.capabilities.supports_modules_request,
            "supportsRestartRequest": self.capabilities.supports_restart_request,
            "supportsExceptionOptions": self.capabilities.supports_exception_options,
            "supportsValueFormattingOptions": self.capabilities.supports_value_formatting_options,
            "supportsExceptionInfoRequest": self.capabilities.supports_exception_info_request,
            "supportsTerminateDebuggee": self.capabilities.supports_terminate_debuggee,
            "supportsDelayedStackTraceLoading": self.capabilities.supports_delayed_stack_trace_loading,
            "supportsLoadedSourcesRequest": self.capabilities.supports_loaded_sources_request,
            "supportsLogPoints": self.capabilities.supports_log_points,
            "supportsSetExpression": self.capabilities.supports_set_expression,
            "supportsTerminateRequest": self.capabilities.supports_terminate_request,
            "supportsDataBreakpoints": self.capabilities.supports_data_breakpoints,
            "supportsReadMemoryRequest": self.capabilities.supports_read_memory_request,
            "supportsWriteMemoryRequest": self.capabilities.supports_write_memory_request,
            "supportsDisassembleRequest": self.capabilities.supports_disassemble_request,
            "supportsCancelRequest": self.capabilities.supports_cancel_request,
            "supportsBreakpointLocationsRequest": self.capabilities.supports_breakpoint_locations_request,
            "supportsSteppingGranularity": self.capabilities.supports_stepping_granularity,
            "supportsInstructionBreakpoints": self.capabilities.supports_instruction_breakpoints,
            "supportsExceptionFilterOptions": self.capabilities.supports_exception_filter_options,
            "exceptionBreakpointFilters": self.capabilities.exception_breakpoint_filters.iter().map(|f| {
                serde_json::json!({
                    "filter": f.filter_id,
                    "label": f.label,
                    "default": f.default,
                    "supportsCondition": f.supports_condition,
                    "description": f.description,
                })
            }).collect::<Vec<_>>(),
        }))
    }

    fn handle_launch(&self, request: &Request) -> Result<serde_json::Value, String> {
        if let Some(args) = &request.arguments {
            // Parse launch configuration
            if let Some(program) = args.get("program").and_then(|v| v.as_str()) {
                let mut config = self.config.clone();
                config.program = PathBuf::from(program);

                if let Some(cwd) = args.get("cwd").and_then(|v| v.as_str()) {
                    config.cwd = Some(PathBuf::from(cwd));
                }

                if let Some(args_arr) = args.get("args").and_then(|v| v.as_array()) {
                    config.args = args_arr.iter()
                        .filter_map(|v| v.as_str().map(|s| s.to_string()))
                        .collect();
                }

                if let Some(stop_on_entry) = args.get("stopOnEntry").and_then(|v| v.as_bool()) {
                    config.stop_on_entry = stop_on_entry;
                }

                // Start the program
                *self.state.write().unwrap() = ExecutionState::Running;

                // Add main thread
                self.threads.write().unwrap().insert(1, Thread {
                    id: 1,
                    name: "main".to_string(),
                });
            }
        }

        Ok(serde_json::json!({}))
    }

    fn handle_attach(&self, _request: &Request) -> Result<serde_json::Value, String> {
        // Attach to running process
        *self.state.write().unwrap() = ExecutionState::Running;
        Ok(serde_json::json!({}))
    }

    fn handle_disconnect(&self, _request: &Request) -> Result<serde_json::Value, String> {
        *self.state.write().unwrap() = ExecutionState::Terminated;
        Ok(serde_json::json!({}))
    }

    fn handle_terminate(&self, _request: &Request) -> Result<serde_json::Value, String> {
        *self.state.write().unwrap() = ExecutionState::Terminated;
        Ok(serde_json::json!({}))
    }

    fn handle_restart(&self, _request: &Request) -> Result<serde_json::Value, String> {
        *self.state.write().unwrap() = ExecutionState::Running;
        self.call_stack_manager.clear();
        self.variable_container.clear();
        Ok(serde_json::json!({}))
    }

    fn handle_set_breakpoints(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let source_obj = args.get("source").ok_or("Missing source")?;
        let path = source_obj.get("path")
            .and_then(|v| v.as_str())
            .map(PathBuf::from);

        let source = Source {
            name: source_obj.get("name").and_then(|v| v.as_str()).map(|s| s.to_string()),
            path,
            source_reference: source_obj.get("sourceReference").and_then(|v| v.as_u64()),
            presentation_hint: None,
            origin: None,
            sources: Vec::new(),
            adapter_data: None,
            checksums: Vec::new(),
        };

        let breakpoints: Vec<SourceBreakpoint> = args.get("breakpoints")
            .and_then(|v| v.as_array())
            .map(|arr| arr.iter().map(|bp| SourceBreakpoint {
                line: bp.get("line").and_then(|v| v.as_u64()).unwrap_or(0) as u32,
                column: bp.get("column").and_then(|v| v.as_u64()).map(|c| c as u32),
                condition: bp.get("condition").and_then(|v| v.as_str()).map(|s| s.to_string()),
                hit_condition: bp.get("hitCondition").and_then(|v| v.as_str()).map(|s| s.to_string()),
                log_message: bp.get("logMessage").and_then(|v| v.as_str()).map(|s| s.to_string()),
            }).collect())
            .unwrap_or_default();

        let result = self.breakpoint_manager.set_source_breakpoints(&source, breakpoints);

        Ok(serde_json::json!({
            "breakpoints": result.iter().map(|bp| serde_json::json!({
                "id": bp.id,
                "verified": bp.verified,
                "message": bp.message,
                "line": bp.line,
                "column": bp.column,
            })).collect::<Vec<_>>(),
        }))
    }

    fn handle_set_function_breakpoints(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let breakpoints: Vec<FunctionBreakpoint> = args.get("breakpoints")
            .and_then(|v| v.as_array())
            .map(|arr| arr.iter().map(|bp| FunctionBreakpoint {
                name: bp.get("name").and_then(|v| v.as_str()).unwrap_or("").to_string(),
                condition: bp.get("condition").and_then(|v| v.as_str()).map(|s| s.to_string()),
                hit_condition: bp.get("hitCondition").and_then(|v| v.as_str()).map(|s| s.to_string()),
            }).collect())
            .unwrap_or_default();

        let result = self.breakpoint_manager.set_function_breakpoints(breakpoints);

        Ok(serde_json::json!({
            "breakpoints": result.iter().map(|bp| serde_json::json!({
                "id": bp.id,
                "verified": bp.verified,
                "message": bp.message,
            })).collect::<Vec<_>>(),
        }))
    }

    fn handle_set_exception_breakpoints(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let filters: Vec<String> = args.get("filters")
            .and_then(|v| v.as_array())
            .map(|arr| arr.iter()
                .filter_map(|v| v.as_str().map(|s| s.to_string()))
                .collect())
            .unwrap_or_default();

        self.breakpoint_manager.set_exception_filters(filters);

        Ok(serde_json::json!({}))
    }

    fn handle_data_breakpoint_info(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let name = args.get("name")
            .and_then(|v| v.as_str())
            .ok_or("Missing name")?;

        // In a real implementation, we'd check if data breakpoints are supported for this variable
        Ok(serde_json::json!({
            "dataId": name,
            "description": format!("Watch: {}", name),
            "accessTypes": ["read", "write", "readWrite"],
        }))
    }

    fn handle_set_data_breakpoints(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let breakpoints: Vec<DataBreakpoint> = args.get("breakpoints")
            .and_then(|v| v.as_array())
            .map(|arr| arr.iter().map(|bp| DataBreakpoint {
                data_id: bp.get("dataId").and_then(|v| v.as_str()).unwrap_or("").to_string(),
                access_type: match bp.get("accessType").and_then(|v| v.as_str()) {
                    Some("read") => DataBreakpointAccessType::Read,
                    Some("write") => DataBreakpointAccessType::Write,
                    _ => DataBreakpointAccessType::ReadWrite,
                },
                condition: bp.get("condition").and_then(|v| v.as_str()).map(|s| s.to_string()),
                hit_condition: bp.get("hitCondition").and_then(|v| v.as_str()).map(|s| s.to_string()),
            }).collect())
            .unwrap_or_default();

        let result = self.breakpoint_manager.set_data_breakpoints(breakpoints);

        Ok(serde_json::json!({
            "breakpoints": result.iter().map(|bp| serde_json::json!({
                "id": bp.id,
                "verified": bp.verified,
            })).collect::<Vec<_>>(),
        }))
    }

    fn handle_configuration_done(&self, _request: &Request) -> Result<serde_json::Value, String> {
        self.configuration_done.store(true, Ordering::SeqCst);

        // If stop on entry, send stopped event
        if self.config.stop_on_entry {
            *self.state.write().unwrap() = ExecutionState::Stopped;
        }

        Ok(serde_json::json!({}))
    }

    fn handle_continue(&self, _request: &Request) -> Result<serde_json::Value, String> {
        *self.state.write().unwrap() = ExecutionState::Running;

        Ok(serde_json::json!({
            "allThreadsContinued": true,
        }))
    }

    fn handle_next(&self, _request: &Request) -> Result<serde_json::Value, String> {
        // Step over - execute next line
        *self.state.write().unwrap() = ExecutionState::Stopped;
        Ok(serde_json::json!({}))
    }

    fn handle_step_in(&self, _request: &Request) -> Result<serde_json::Value, String> {
        // Step into - enter function calls
        *self.state.write().unwrap() = ExecutionState::Stopped;
        Ok(serde_json::json!({}))
    }

    fn handle_step_out(&self, _request: &Request) -> Result<serde_json::Value, String> {
        // Step out - return from current function
        *self.state.write().unwrap() = ExecutionState::Stopped;
        Ok(serde_json::json!({}))
    }

    fn handle_step_back(&self, _request: &Request) -> Result<serde_json::Value, String> {
        // Not supported
        Err("Step back is not supported".to_string())
    }

    fn handle_pause(&self, _request: &Request) -> Result<serde_json::Value, String> {
        *self.state.write().unwrap() = ExecutionState::Stopped;
        Ok(serde_json::json!({}))
    }

    fn handle_stack_trace(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let thread_id = args.get("threadId")
            .and_then(|v| v.as_u64())
            .ok_or("Missing threadId")?;

        let start = args.get("startFrame").and_then(|v| v.as_u64()).map(|n| n as u32);
        let levels = args.get("levels").and_then(|v| v.as_u64()).map(|n| n as u32);

        let frames = self.call_stack_manager.get_stack_trace(thread_id, start, levels);

        Ok(serde_json::json!({
            "stackFrames": frames.iter().map(|f| serde_json::json!({
                "id": f.id,
                "name": f.name,
                "source": f.source.as_ref().map(|s| serde_json::json!({
                    "name": s.name,
                    "path": s.path,
                })),
                "line": f.line,
                "column": f.column,
                "canRestart": f.can_restart,
            })).collect::<Vec<_>>(),
            "totalFrames": frames.len(),
        }))
    }

    fn handle_scopes(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let _frame_id = args.get("frameId")
            .and_then(|v| v.as_u64())
            .ok_or("Missing frameId")?;

        // Create scopes for the frame
        let locals_ref = self.variable_container.create_reference(Vec::new());
        let args_ref = self.variable_container.create_reference(Vec::new());

        let scopes = vec![
            Scope {
                name: "Locals".to_string(),
                presentation_hint: Some(ScopePresentationHint::Locals),
                variables_reference: locals_ref,
                named_variables: None,
                indexed_variables: None,
                expensive: false,
                source: None,
                line: None,
                column: None,
                end_line: None,
                end_column: None,
            },
            Scope {
                name: "Arguments".to_string(),
                presentation_hint: Some(ScopePresentationHint::Arguments),
                variables_reference: args_ref,
                named_variables: None,
                indexed_variables: None,
                expensive: false,
                source: None,
                line: None,
                column: None,
                end_line: None,
                end_column: None,
            },
        ];

        Ok(serde_json::json!({
            "scopes": scopes.iter().map(|s| serde_json::json!({
                "name": s.name,
                "variablesReference": s.variables_reference,
                "expensive": s.expensive,
            })).collect::<Vec<_>>(),
        }))
    }

    fn handle_variables(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let reference = args.get("variablesReference")
            .and_then(|v| v.as_u64())
            .ok_or("Missing variablesReference")?;

        let start = args.get("start").and_then(|v| v.as_u64()).map(|n| n as u32);
        let count = args.get("count").and_then(|v| v.as_u64()).map(|n| n as u32);

        let variables = self.variable_container.get_variables(reference, start, count);

        Ok(serde_json::json!({
            "variables": variables.iter().map(|v| serde_json::json!({
                "name": v.name,
                "value": v.value,
                "type": v.var_type,
                "variablesReference": v.variables_reference,
            })).collect::<Vec<_>>(),
        }))
    }

    fn handle_set_variable(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let name = args.get("name")
            .and_then(|v| v.as_str())
            .ok_or("Missing name")?;

        let value = args.get("value")
            .and_then(|v| v.as_str())
            .ok_or("Missing value")?;

        // In a real implementation, this would modify the actual variable
        Ok(serde_json::json!({
            "value": value,
            "type": "unknown",
            "variablesReference": 0,
        }))
    }

    fn handle_source(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let source_reference = args.get("sourceReference")
            .and_then(|v| v.as_u64())
            .ok_or("Missing sourceReference")?;

        // In a real implementation, this would return decompiled or generated source
        Ok(serde_json::json!({
            "content": format!("// Source reference: {}\n// No source available", source_reference),
        }))
    }

    fn handle_threads(&self, _request: &Request) -> Result<serde_json::Value, String> {
        let threads = self.threads.read().unwrap();

        Ok(serde_json::json!({
            "threads": threads.values().map(|t| serde_json::json!({
                "id": t.id,
                "name": t.name,
            })).collect::<Vec<_>>(),
        }))
    }

    fn handle_modules(&self, _request: &Request) -> Result<serde_json::Value, String> {
        Ok(serde_json::json!({
            "modules": [],
            "totalModules": 0,
        }))
    }

    fn handle_loaded_sources(&self, _request: &Request) -> Result<serde_json::Value, String> {
        Ok(serde_json::json!({
            "sources": [],
        }))
    }

    fn handle_evaluate(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let expression = args.get("expression")
            .and_then(|v| v.as_str())
            .ok_or("Missing expression")?;

        let frame_id = args.get("frameId")
            .and_then(|v| v.as_u64())
            .unwrap_or(0);

        let context = match args.get("context").and_then(|v| v.as_str()) {
            Some("watch") => EvaluateContext::Watch,
            Some("repl") => EvaluateContext::Repl,
            Some("hover") => EvaluateContext::Hover,
            Some("clipboard") => EvaluateContext::Clipboard,
            _ => EvaluateContext::Watch,
        };

        let result = self.evaluator.evaluate(expression, frame_id, context);

        Ok(serde_json::json!({
            "result": result.result,
            "type": result.var_type,
            "variablesReference": result.variables_reference,
        }))
    }

    fn handle_set_expression(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let expression = args.get("expression")
            .and_then(|v| v.as_str())
            .ok_or("Missing expression")?;

        let value = args.get("value")
            .and_then(|v| v.as_str())
            .ok_or("Missing value")?;

        Ok(serde_json::json!({
            "value": value,
            "type": "unknown",
            "variablesReference": 0,
        }))
    }

    fn handle_step_in_targets(&self, request: &Request) -> Result<serde_json::Value, String> {
        Ok(serde_json::json!({
            "targets": [],
        }))
    }

    fn handle_goto_targets(&self, request: &Request) -> Result<serde_json::Value, String> {
        Ok(serde_json::json!({
            "targets": [],
        }))
    }

    fn handle_completions(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let text = args.get("text")
            .and_then(|v| v.as_str())
            .unwrap_or("");

        // Provide basic completions
        let completions: Vec<serde_json::Value> = vec![
            serde_json::json!({ "label": "continue", "type": "keyword" }),
            serde_json::json!({ "label": "break", "type": "keyword" }),
            serde_json::json!({ "label": "step", "type": "keyword" }),
            serde_json::json!({ "label": "next", "type": "keyword" }),
            serde_json::json!({ "label": "print", "type": "function" }),
        ].into_iter()
            .filter(|c| {
                let label = c.get("label").and_then(|v| v.as_str()).unwrap_or("");
                label.starts_with(text)
            })
            .collect();

        Ok(serde_json::json!({
            "targets": completions,
        }))
    }

    fn handle_exception_info(&self, request: &Request) -> Result<serde_json::Value, String> {
        Ok(serde_json::json!({
            "exceptionId": "Exception",
            "description": "An exception occurred",
            "breakMode": "always",
        }))
    }

    fn handle_read_memory(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let memory_reference = args.get("memoryReference")
            .and_then(|v| v.as_str())
            .ok_or("Missing memoryReference")?;

        let count = args.get("count")
            .and_then(|v| v.as_u64())
            .ok_or("Missing count")?;

        // In a real implementation, this would read actual memory
        let data = vec![0u8; count as usize];
        let encoded = base64::encode(&data);

        Ok(serde_json::json!({
            "address": memory_reference,
            "data": encoded,
        }))
    }

    fn handle_write_memory(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let memory_reference = args.get("memoryReference")
            .and_then(|v| v.as_str())
            .ok_or("Missing memoryReference")?;

        let data = args.get("data")
            .and_then(|v| v.as_str())
            .ok_or("Missing data")?;

        // Decode and write memory
        let bytes = base64::decode(data).map_err(|e| e.to_string())?;

        Ok(serde_json::json!({
            "bytesWritten": bytes.len(),
        }))
    }

    fn handle_disassemble(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let memory_reference = args.get("memoryReference")
            .and_then(|v| v.as_str())
            .ok_or("Missing memoryReference")?;

        let instruction_count = args.get("instructionCount")
            .and_then(|v| v.as_u64())
            .unwrap_or(10);

        // Generate mock disassembly
        let instructions: Vec<serde_json::Value> = (0..instruction_count).map(|i| {
            serde_json::json!({
                "address": format!("0x{:08x}", i),
                "instruction": "nop",
            })
        }).collect();

        Ok(serde_json::json!({
            "instructions": instructions,
        }))
    }

    fn handle_cancel(&self, _request: &Request) -> Result<serde_json::Value, String> {
        Ok(serde_json::json!({}))
    }

    fn handle_breakpoint_locations(&self, request: &Request) -> Result<serde_json::Value, String> {
        let args = request.arguments.as_ref().ok_or("Missing arguments")?;

        let line = args.get("line")
            .and_then(|v| v.as_u64())
            .ok_or("Missing line")?;

        // Return the line as a valid breakpoint location
        Ok(serde_json::json!({
            "breakpoints": [
                { "line": line },
            ],
        }))
    }

    /// Send an event
    pub fn send_event(&self, event: Event) {
        // In a real implementation, this would send the event through the transport
    }

    /// Create stopped event
    pub fn create_stopped_event(&self, reason: StopReason, thread_id: u64, description: Option<String>) -> Event {
        Event {
            event: "stopped".to_string(),
            body: Some(serde_json::json!({
                "reason": reason.as_str(),
                "threadId": thread_id,
                "description": description,
                "preserveFocusHint": false,
                "allThreadsStopped": true,
            })),
        }
    }

    /// Create output event
    pub fn create_output_event(&self, output: &str, category: &str) -> Event {
        Event {
            event: "output".to_string(),
            body: Some(serde_json::json!({
                "category": category,
                "output": output,
            })),
        }
    }
}

// =============================================================================
// DEBUG SERVER
// =============================================================================

/// Debug server for handling DAP connections
pub struct DebugServer {
    adapter: Arc<DebugAdapter>,
    listener: Option<TcpListener>,
}

impl DebugServer {
    pub fn new() -> Self {
        DebugServer {
            adapter: Arc::new(DebugAdapter::new()),
            listener: None,
        }
    }

    /// Start the debug server on a port
    pub fn start(&mut self, port: u16) -> std::io::Result<()> {
        let listener = TcpListener::bind(format!("127.0.0.1:{}", port))?;
        println!("Debug server listening on port {}", port);

        self.listener = Some(listener);
        Ok(())
    }

    /// Accept a connection and run the debug session
    pub fn accept(&self) -> std::io::Result<()> {
        let listener = self.listener.as_ref().ok_or(std::io::Error::new(
            std::io::ErrorKind::NotConnected,
            "Server not started",
        ))?;

        for stream in listener.incoming() {
            let stream = stream?;
            let adapter = Arc::clone(&self.adapter);

            std::thread::spawn(move || {
                if let Err(e) = handle_connection(stream, adapter) {
                    eprintln!("Connection error: {}", e);
                }
            });
        }

        Ok(())
    }
}

fn handle_connection(mut stream: TcpStream, adapter: Arc<DebugAdapter>) -> std::io::Result<()> {
    let mut buffer = [0u8; 8192];

    loop {
        let n = stream.read(&mut buffer)?;
        if n == 0 {
            break;
        }

        // Parse DAP message
        let content = String::from_utf8_lossy(&buffer[..n]);

        // Extract Content-Length header and body
        if let Some(body_start) = content.find("\r\n\r\n") {
            let body = &content[body_start + 4..];

            if let Ok(json) = serde_json::from_str::<serde_json::Value>(body) {
                if let Some(command) = json.get("command").and_then(|v| v.as_str()) {
                    let request = Request {
                        command: command.to_string(),
                        arguments: json.get("arguments").cloned(),
                    };

                    let mut response = adapter.handle_request(request);
                    response.request_seq = json.get("seq").and_then(|v| v.as_u64()).unwrap_or(0);

                    // Send response
                    let response_json = serde_json::json!({
                        "seq": 0,
                        "type": "response",
                        "request_seq": response.request_seq,
                        "success": response.success,
                        "command": response.command,
                        "message": response.message,
                        "body": response.body,
                    });

                    let response_str = serde_json::to_string(&response_json)?;
                    let header = format!("Content-Length: {}\r\n\r\n", response_str.len());

                    stream.write_all(header.as_bytes())?;
                    stream.write_all(response_str.as_bytes())?;
                    stream.flush()?;
                }
            }
        }
    }

    Ok(())
}

// =============================================================================
// CLI INTERFACE
// =============================================================================

/// Debug command options
#[derive(Debug, Clone)]
pub struct DebugOptions {
    /// Port for DAP server
    pub port: Option<u16>,

    /// Program to debug
    pub program: Option<PathBuf>,

    /// Working directory
    pub cwd: Option<PathBuf>,

    /// Arguments to pass to program
    pub args: Vec<String>,

    /// Stop at entry point
    pub stop_on_entry: bool,

    /// Use stdio instead of TCP
    pub stdio: bool,
}

impl Default for DebugOptions {
    fn default() -> Self {
        DebugOptions {
            port: Some(4711),
            program: None,
            cwd: None,
            args: Vec::new(),
            stop_on_entry: false,
            stdio: false,
        }
    }
}

/// Main entry point
pub fn main() {
    let args: Vec<String> = std::env::args().collect();

    let mut options = DebugOptions::default();
    let mut i = 1;

    while i < args.len() {
        match args[i].as_str() {
            "--port" | "-p" => {
                i += 1;
                if i < args.len() {
                    options.port = args[i].parse().ok();
                }
            }
            "--stdio" => {
                options.stdio = true;
            }
            "--stop-on-entry" => {
                options.stop_on_entry = true;
            }
            "--cwd" => {
                i += 1;
                if i < args.len() {
                    options.cwd = Some(PathBuf::from(&args[i]));
                }
            }
            "--help" | "-h" => {
                print_help();
                return;
            }
            "--version" | "-V" => {
                println!("quanta-debug 1.0.0");
                return;
            }
            arg if !arg.starts_with('-') => {
                if options.program.is_none() {
                    options.program = Some(PathBuf::from(arg));
                } else {
                    options.args.push(arg.to_string());
                }
            }
            _ => {
                eprintln!("Unknown option: {}", args[i]);
                std::process::exit(1);
            }
        }
        i += 1;
    }

    // Start debug server
    let mut server = DebugServer::new();

    if let Some(port) = options.port {
        if let Err(e) = server.start(port) {
            eprintln!("Failed to start debug server: {}", e);
            std::process::exit(1);
        }

        if let Err(e) = server.accept() {
            eprintln!("Server error: {}", e);
            std::process::exit(1);
        }
    }
}

fn print_help() {
    println!("quanta-debug - QuantaLang Debugger

USAGE:
    quanta-debug [OPTIONS] [PROGRAM] [ARGS...]

OPTIONS:
    -p, --port PORT     Port for DAP server (default: 4711)
    --stdio             Use stdio instead of TCP for DAP
    --stop-on-entry     Stop at program entry point
    --cwd PATH          Working directory for debuggee
    -h, --help          Show this help message
    -V, --version       Show version

EXAMPLES:
    quanta-debug --port 4711              Start DAP server on port 4711
    quanta-debug program.quanta           Debug program.quanta
    quanta-debug --stdio                  Use stdio for IDE integration

IDE INTEGRATION:
    VS Code: Install the Quanta Debug extension
    JetBrains: Use the Quanta plugin with built-in debug support
");
}

// =============================================================================
// TIME-TRAVEL DEBUGGING (REVERSE DEBUGGING)
// =============================================================================

/// Time-travel debugger for reverse execution
pub struct TimeTravelDebugger {
    /// Execution history for each thread
    history: RwLock<HashMap<u64, ExecutionHistory>>,
    /// Current position in history
    position: RwLock<HashMap<u64, usize>>,
    /// Recording enabled
    recording: AtomicBool,
    /// Maximum history size per thread
    max_history_size: usize,
    /// Snapshot interval (every N steps)
    snapshot_interval: usize,
}

#[derive(Debug, Clone)]
pub struct ExecutionHistory {
    pub entries: Vec<HistoryEntry>,
    pub snapshots: Vec<StateSnapshot>,
}

#[derive(Debug, Clone)]
pub struct HistoryEntry {
    pub timestamp: u64,
    pub thread_id: u64,
    pub instruction_pointer: u64,
    pub source_location: SourceLocation,
    pub operation: HistoryOperation,
    pub before_state: Option<StateChange>,
    pub after_state: Option<StateChange>,
}

#[derive(Debug, Clone)]
pub struct SourceLocation {
    pub file: PathBuf,
    pub line: u32,
    pub column: u32,
    pub function: Option<String>,
}

#[derive(Debug, Clone)]
pub enum HistoryOperation {
    Step,
    Call { function: String, args: Vec<String> },
    Return { function: String, result: Option<String> },
    Assignment { variable: String, old_value: String, new_value: String },
    MemoryWrite { address: u64, size: usize, old_data: Vec<u8>, new_data: Vec<u8> },
    Syscall { number: u64, args: Vec<u64>, result: i64 },
    Exception { exception_type: String, message: String },
    ThreadCreate { new_thread_id: u64 },
    ThreadExit { exit_code: i32 },
    LockAcquire { lock_id: u64 },
    LockRelease { lock_id: u64 },
    ChannelSend { channel_id: u64, data: String },
    ChannelReceive { channel_id: u64, data: String },
}

#[derive(Debug, Clone)]
pub struct StateChange {
    pub registers: HashMap<String, u64>,
    pub memory_changes: Vec<MemoryChange>,
    pub variable_changes: Vec<VariableChange>,
}

#[derive(Debug, Clone)]
pub struct MemoryChange {
    pub address: u64,
    pub size: usize,
    pub data: Vec<u8>,
}

#[derive(Debug, Clone)]
pub struct VariableChange {
    pub name: String,
    pub scope: u64,
    pub value: String,
    pub var_type: String,
}

#[derive(Debug, Clone)]
pub struct StateSnapshot {
    pub index: usize,
    pub timestamp: u64,
    pub full_state: FullProgramState,
}

#[derive(Debug, Clone)]
pub struct FullProgramState {
    pub threads: HashMap<u64, ThreadState>,
    pub memory: MemorySnapshot,
    pub heap: HeapSnapshot,
    pub globals: HashMap<String, String>,
}

#[derive(Debug, Clone)]
pub struct ThreadState {
    pub id: u64,
    pub name: String,
    pub registers: HashMap<String, u64>,
    pub stack: Vec<StackFrameState>,
    pub status: ThreadStatus,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ThreadStatus {
    Running,
    Sleeping,
    Waiting,
    Blocked,
    Terminated,
}

#[derive(Debug, Clone)]
pub struct StackFrameState {
    pub function: String,
    pub locals: HashMap<String, String>,
    pub return_address: u64,
}

#[derive(Debug, Clone)]
pub struct MemorySnapshot {
    pub pages: HashMap<u64, Vec<u8>>,
    pub permissions: HashMap<u64, MemoryPermissions>,
}

#[derive(Debug, Clone, Copy)]
pub struct MemoryPermissions {
    pub read: bool,
    pub write: bool,
    pub execute: bool,
}

#[derive(Debug, Clone)]
pub struct HeapSnapshot {
    pub allocations: HashMap<u64, HeapAllocation>,
    pub free_list: Vec<HeapBlock>,
}

#[derive(Debug, Clone)]
pub struct HeapAllocation {
    pub address: u64,
    pub size: usize,
    pub allocation_site: SourceLocation,
    pub allocation_time: u64,
    pub data_type: Option<String>,
}

#[derive(Debug, Clone)]
pub struct HeapBlock {
    pub address: u64,
    pub size: usize,
}

impl TimeTravelDebugger {
    pub fn new() -> Self {
        TimeTravelDebugger {
            history: RwLock::new(HashMap::new()),
            position: RwLock::new(HashMap::new()),
            recording: AtomicBool::new(true),
            max_history_size: 1_000_000,
            snapshot_interval: 10_000,
        }
    }

    pub fn start_recording(&self) {
        self.recording.store(true, Ordering::SeqCst);
    }

    pub fn stop_recording(&self) {
        self.recording.store(false, Ordering::SeqCst);
    }

    pub fn record_entry(&self, thread_id: u64, entry: HistoryEntry) {
        if !self.recording.load(Ordering::SeqCst) {
            return;
        }

        let mut history = self.history.write().unwrap();
        let thread_history = history.entry(thread_id).or_insert_with(|| ExecutionHistory {
            entries: Vec::new(),
            snapshots: Vec::new(),
        });

        let index = thread_history.entries.len();
        thread_history.entries.push(entry);

        // Create snapshot at interval
        if index > 0 && index % self.snapshot_interval == 0 {
            if let Some(snapshot) = self.create_snapshot(thread_id, index) {
                thread_history.snapshots.push(snapshot);
            }
        }

        // Trim history if too large
        if thread_history.entries.len() > self.max_history_size {
            let remove_count = self.max_history_size / 10;
            thread_history.entries.drain(0..remove_count);
            thread_history.snapshots.retain(|s| s.index >= remove_count);
            for snapshot in &mut thread_history.snapshots {
                snapshot.index -= remove_count;
            }
        }
    }

    pub fn step_back(&self, thread_id: u64) -> Option<HistoryEntry> {
        let mut position = self.position.write().unwrap();
        let pos = position.entry(thread_id).or_insert(0);

        let history = self.history.read().unwrap();
        if let Some(thread_history) = history.get(&thread_id) {
            if *pos > 0 {
                *pos -= 1;
                return thread_history.entries.get(*pos).cloned();
            }
        }

        None
    }

    pub fn step_forward(&self, thread_id: u64) -> Option<HistoryEntry> {
        let mut position = self.position.write().unwrap();
        let pos = position.entry(thread_id).or_insert(0);

        let history = self.history.read().unwrap();
        if let Some(thread_history) = history.get(&thread_id) {
            if *pos < thread_history.entries.len() - 1 {
                *pos += 1;
                return thread_history.entries.get(*pos).cloned();
            }
        }

        None
    }

    pub fn goto_position(&self, thread_id: u64, index: usize) -> Option<HistoryEntry> {
        let mut position = self.position.write().unwrap();

        let history = self.history.read().unwrap();
        if let Some(thread_history) = history.get(&thread_id) {
            if index < thread_history.entries.len() {
                position.insert(thread_id, index);
                return thread_history.entries.get(index).cloned();
            }
        }

        None
    }

    pub fn restore_to_snapshot(&self, thread_id: u64, snapshot_index: usize) -> Option<FullProgramState> {
        let history = self.history.read().unwrap();
        if let Some(thread_history) = history.get(&thread_id) {
            if let Some(snapshot) = thread_history.snapshots.get(snapshot_index) {
                return Some(snapshot.full_state.clone());
            }
        }
        None
    }

    pub fn find_variable_change(&self, thread_id: u64, variable: &str) -> Vec<usize> {
        let history = self.history.read().unwrap();
        let mut changes = Vec::new();

        if let Some(thread_history) = history.get(&thread_id) {
            for (i, entry) in thread_history.entries.iter().enumerate() {
                if let HistoryOperation::Assignment { variable: var, .. } = &entry.operation {
                    if var == variable {
                        changes.push(i);
                    }
                }
            }
        }

        changes
    }

    fn create_snapshot(&self, _thread_id: u64, index: usize) -> Option<StateSnapshot> {
        // In a real implementation, this would capture the full program state
        Some(StateSnapshot {
            index,
            timestamp: 0,
            full_state: FullProgramState {
                threads: HashMap::new(),
                memory: MemorySnapshot {
                    pages: HashMap::new(),
                    permissions: HashMap::new(),
                },
                heap: HeapSnapshot {
                    allocations: HashMap::new(),
                    free_list: Vec::new(),
                },
                globals: HashMap::new(),
            },
        })
    }
}

// =============================================================================
// HOT CODE REPLACEMENT
// =============================================================================

/// Hot code replacement for live debugging
pub struct HotCodeReplacer {
    /// Loaded modules
    modules: RwLock<HashMap<String, LoadedModule>>,
    /// Replacement history
    replacements: RwLock<Vec<CodeReplacement>>,
    /// Active patches
    patches: RwLock<Vec<CodePatch>>,
    /// HCR enabled
    enabled: AtomicBool,
}

#[derive(Debug, Clone)]
pub struct LoadedModule {
    pub name: String,
    pub path: PathBuf,
    pub version: u64,
    pub code_base: u64,
    pub code_size: usize,
    pub functions: HashMap<String, FunctionInfo>,
    pub loaded_at: u64,
    pub checksum: String,
}

#[derive(Debug, Clone)]
pub struct FunctionInfo {
    pub name: String,
    pub address: u64,
    pub size: usize,
    pub signature: String,
    pub locals: Vec<LocalVariable>,
    pub source_file: Option<PathBuf>,
    pub line_start: u32,
    pub line_end: u32,
}

#[derive(Debug, Clone)]
pub struct LocalVariable {
    pub name: String,
    pub var_type: String,
    pub offset: i32,
    pub is_param: bool,
}

#[derive(Debug, Clone)]
pub struct CodeReplacement {
    pub timestamp: u64,
    pub module_name: String,
    pub function_name: String,
    pub old_code: Vec<u8>,
    pub new_code: Vec<u8>,
    pub success: bool,
    pub error: Option<String>,
}

#[derive(Debug, Clone)]
pub struct CodePatch {
    pub id: u64,
    pub address: u64,
    pub original_bytes: Vec<u8>,
    pub patched_bytes: Vec<u8>,
    pub description: String,
    pub active: bool,
}

impl HotCodeReplacer {
    pub fn new() -> Self {
        HotCodeReplacer {
            modules: RwLock::new(HashMap::new()),
            replacements: RwLock::new(Vec::new()),
            patches: RwLock::new(Vec::new()),
            enabled: AtomicBool::new(true),
        }
    }

    pub fn enable(&self) {
        self.enabled.store(true, Ordering::SeqCst);
    }

    pub fn disable(&self) {
        self.enabled.store(false, Ordering::SeqCst);
    }

    pub fn register_module(&self, module: LoadedModule) {
        self.modules.write().unwrap().insert(module.name.clone(), module);
    }

    pub fn replace_function(&self, module_name: &str, function_name: &str, new_code: Vec<u8>) -> Result<(), String> {
        if !self.enabled.load(Ordering::SeqCst) {
            return Err("Hot code replacement is disabled".to_string());
        }

        let modules = self.modules.read().unwrap();
        let module = modules.get(module_name)
            .ok_or_else(|| format!("Module '{}' not found", module_name))?;

        let function = module.functions.get(function_name)
            .ok_or_else(|| format!("Function '{}' not found in module '{}'", function_name, module_name))?;

        // Check if new code is compatible
        if !self.is_compatible(function, &new_code) {
            return Err("New code is not compatible with the existing function signature".to_string());
        }

        // Save the old code for rollback
        let replacement = CodeReplacement {
            timestamp: 0,
            module_name: module_name.to_string(),
            function_name: function_name.to_string(),
            old_code: Vec::new(), // Would be actual old code
            new_code: new_code.clone(),
            success: true,
            error: None,
        };

        self.replacements.write().unwrap().push(replacement);

        Ok(())
    }

    pub fn rollback_last(&self) -> Result<(), String> {
        let mut replacements = self.replacements.write().unwrap();
        if let Some(replacement) = replacements.pop() {
            // Restore the old code
            let _ = replacement;
            Ok(())
        } else {
            Err("No replacements to rollback".to_string())
        }
    }

    pub fn apply_patch(&self, patch: CodePatch) -> Result<u64, String> {
        let mut patches = self.patches.write().unwrap();
        let id = patch.id;
        patches.push(patch);
        Ok(id)
    }

    pub fn remove_patch(&self, patch_id: u64) -> Result<(), String> {
        let mut patches = self.patches.write().unwrap();
        if let Some(pos) = patches.iter().position(|p| p.id == patch_id) {
            patches.remove(pos);
            Ok(())
        } else {
            Err("Patch not found".to_string())
        }
    }

    fn is_compatible(&self, _function: &FunctionInfo, _new_code: &[u8]) -> bool {
        // Check signature compatibility, stack frame layout, etc.
        true
    }
}

