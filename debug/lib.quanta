/// Debugger for async and concurrent code
pub struct ConcurrentDebugger {
    /// Task tracker
    tasks: RwLock<HashMap<u64, TaskInfo>>,
    /// Lock tracker
    locks: RwLock<HashMap<u64, LockInfo>>,
    /// Channel tracker
    channels: RwLock<HashMap<u64, ChannelInfo>>,
    /// Deadlock detector
    deadlock_detector: DeadlockDetector,
    /// Race detector
    race_detector: RaceDetector,
}

#[derive(Debug, Clone)]
pub struct TaskInfo {
    pub id: u64,
    pub name: String,
    pub state: TaskState,
    pub created_at: u64,
    pub parent_id: Option<u64>,
    pub stack_trace: Vec<StackFrameInfo>,
    pub waiting_on: Option<WaitTarget>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TaskState {
    Created,
    Running,
    Suspended,
    Waiting,
    Completed,
    Cancelled,
    Failed,
}

#[derive(Debug, Clone)]
pub enum WaitTarget {
    Lock(u64),
    Channel(u64),
    Future(u64),
    Sleep(u64),
    Io(IoTarget),
    Task(u64),
}

#[derive(Debug, Clone)]
pub struct IoTarget {
    pub io_type: IoType,
    pub descriptor: u64,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum IoType {
    File,
