                    highlight_bloom: 0.1,
                },
                Genre::SciFi => GenreStyle {
                    contrast: 1.15,
                    desaturation: 0.1,
                    vignette_intensity: 0.2,
                    grain_amount: 0.02,
                    chromatic_aberration: 0.015,
                    shadow_crush: 0.1,
                    highlight_bloom: 0.4,
                },
                Genre::Fantasy => GenreStyle {
                    contrast: 1.1,
                    desaturation: -0.1,
                    vignette_intensity: 0.3,
                    grain_amount: 0.05,
                    chromatic_aberration: 0.0,
                    shadow_crush: 0.05,
                    highlight_bloom: 0.5,
                },
                Genre::Noir => GenreStyle {
                    contrast: 1.5,
                    desaturation: 0.8,
                    vignette_intensity: 0.5,
                    grain_amount: 0.2,
                    chromatic_aberration: 0.0,
                    shadow_crush: 0.4,
                    highlight_bloom: 0.05,
                },
                Genre::Western => GenreStyle {
                    contrast: 1.2,
                    desaturation: 0.15,
                    vignette_intensity: 0.35,
                    grain_amount: 0.1,
                    chromatic_aberration: 0.01,
                    shadow_crush: 0.15,
                    highlight_bloom: 0.2,
                },
                Genre::Documentary => GenreStyle {
                    contrast: 1.05,
                    desaturation: 0.05,
                    vignette_intensity: 0.1,
                    grain_amount: 0.03,
                    chromatic_aberration: 0.0,
                    shadow_crush: 0.02,
                    highlight_bloom: 0.1,
                },
                Genre::ActionBlockbuster => GenreStyle {
                    contrast: 1.25,
                    desaturation: 0.0,
                    vignette_intensity: 0.25,
                    grain_amount: 0.04,
                    chromatic_aberration: 0.02,
                    shadow_crush: 0.1,
                    highlight_bloom: 0.35,
                },
                Genre::IndieDrama => GenreStyle {
                    contrast: 1.0,
                    desaturation: 0.1,
                    vignette_intensity: 0.4,
                    grain_amount: 0.12,
                    chromatic_aberration: 0.0,
                    shadow_crush: 0.05,
                    highlight_bloom: 0.15,
                },
                Genre::Animation => GenreStyle {
                    contrast: 1.1,
                    desaturation: -0.15,
                    vignette_intensity: 0.1,
                    grain_amount: 0.0,
                    chromatic_aberration: 0.0,
