// ═══════════════════════════════════════════════════════════════════════════════
// A/B COMPARISON SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// A/B comparison for presets
pub struct ABComparison {
    pub preset_a: NovaPreset,
    pub preset_b: NovaPreset,
    pub split_position: f32,
    pub split_orientation: SplitOrientation,
    pub show_labels: bool,
    pub animation_enabled: bool,
    pub animation_speed: f32,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum SplitOrientation {
    Vertical,
    Horizontal,
    Diagonal,
    Radial,
}

impl ABComparison {
    pub fn new(a: NovaPreset, b: NovaPreset) -> Self {
        ABComparison {
            preset_a: a,
            preset_b: b,
            split_position: 0.5,
            split_orientation: SplitOrientation::Vertical,
            show_labels: true,
            animation_enabled: false,
            animation_speed: 1.0,
        }
    }

    pub fn set_split(&mut self, position: f32) {
        self.split_position = position.clamp(0.0, 1.0);
    }

    pub fn toggle_orientation(&mut self) {
        self.split_orientation = match self.split_orientation {
            SplitOrientation::Vertical => SplitOrientation::Horizontal,
            SplitOrientation::Horizontal => SplitOrientation::Diagonal,
            SplitOrientation::Diagonal => SplitOrientation::Radial,
            SplitOrientation::Radial => SplitOrientation::Vertical,
        };
    }

    pub fn swap_presets(&mut self) {
        std::mem::swap(&mut self.preset_a, &mut self.preset_b);
    }

    /// Get which preset should be used for a pixel
    pub fn pixel_side(&self, x: f32, y: f32, width: f32, height: f32) -> bool {
        let nx = x / width;
        let ny = y / height;

        match self.split_orientation {
            SplitOrientation::Vertical => nx < self.split_position,
            SplitOrientation::Horizontal => ny < self.split_position,
            SplitOrientation::Diagonal => (nx + ny) / 2.0 < self.split_position,
            SplitOrientation::Radial => {
                let dx = nx - 0.5;
                let dy = ny - 0.5;
                (dx * dx + dy * dy).sqrt() < self.split_position * 0.707
            }
        }
    }

    /// Animate split position
    pub fn update(&mut self, delta_time: f32) {
        if self.animation_enabled {
            self.split_position += delta_time * self.animation_speed * 0.5;
            if self.split_position > 1.0 {
                self.split_position = 0.0;
            }
        }
    }
}

/// Multi-preset comparison (up to 4)
pub struct MultiComparison {
    pub presets: Vec<NovaPreset>,
    pub layout: ComparisonLayout,
    pub active_index: usize,
}

#[derive(Debug, Clone, Copy)]
pub enum ComparisonLayout {
    Grid2x2,
    Horizontal,
    Vertical,
    Single,
}

impl MultiComparison {
    pub fn new() -> Self {
        MultiComparison {
            presets: Vec::new(),
            layout: ComparisonLayout::Grid2x2,
            active_index: 0,
        }
    }

    pub fn add_preset(&mut self, preset: NovaPreset) {
        if self.presets.len() < 4 {
            self.presets.push(preset);
        }
    }

    pub fn remove_preset(&mut self, index: usize) {
        if index < self.presets.len() {
            self.presets.remove(index);
        }
    }

    pub fn cycle_active(&mut self) {
        if !self.presets.is_empty() {
            self.active_index = (self.active_index + 1) % self.presets.len();
        }
    }

    pub fn get_viewport(&self, index: usize, width: f32, height: f32) -> (f32, f32, f32, f32) {
        match self.layout {
            ComparisonLayout::Grid2x2 => {
                let hw = width / 2.0;
                let hh = height / 2.0;
                match index {
                    0 => (0.0, 0.0, hw, hh),
                    1 => (hw, 0.0, hw, hh),
                    2 => (0.0, hh, hw, hh),
                    3 => (hw, hh, hw, hh),
                    _ => (0.0, 0.0, 0.0, 0.0),
                }
            }
            ComparisonLayout::Horizontal => {
                let w = width / self.presets.len().max(1) as f32;
                (w * index as f32, 0.0, w, height)
            }
            ComparisonLayout::Vertical => {
                let h = height / self.presets.len().max(1) as f32;
                (0.0, h * index as f32, width, h)
            }
            ComparisonLayout::Single => {
                if index == self.active_index {
                    (0.0, 0.0, width, height)
                } else {
                    (0.0, 0.0, 0.0, 0.0)
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET EXPORT/IMPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Preset serialization format
#[derive(Debug, Clone, Copy)]
pub enum PresetFormat {
    NovaJson,
    NovaBinary,
    ReShade,
    Unity,
    Unreal,
}

/// Preset exporter
pub struct PresetExporter;

impl PresetExporter {
    pub fn export(preset: &NovaPreset, format: PresetFormat) -> Vec<u8> {
        match format {
            PresetFormat::NovaJson => Self::export_json(preset),
            PresetFormat::NovaBinary => Self::export_binary(preset),
            PresetFormat::ReShade => Self::export_reshade(preset),
            PresetFormat::Unity => Self::export_unity(preset),
            PresetFormat::Unreal => Self::export_unreal(preset),
        }
    }

    fn export_json(preset: &NovaPreset) -> Vec<u8> {
        let mut json = String::new();
        json.push_str("{\n");
        json.push_str(&format!("  \"id\": \"{}\",\n", preset.metadata.id));
        json.push_str(&format!("  \"name\": \"{}\",\n", preset.metadata.name));
        json.push_str(&format!("  \"version\": \"{}\",\n", preset.metadata.version));
        json.push_str("  \"color\": {\n");
        json.push_str(&format!("    \"exposure\": {},\n", preset.color.exposure));
        json.push_str(&format!("    \"contrast\": {},\n", preset.color.contrast));
        json.push_str(&format!("    \"saturation\": {},\n", preset.color.saturation));
        json.push_str(&format!("    \"temperature\": {},\n", preset.color.temperature));
        json.push_str(&format!("    \"tint\": {}\n", preset.color.tint));
        json.push_str("  },\n");
        json.push_str("  \"postProcess\": {\n");
        json.push_str(&format!("    \"ssaoEnabled\": {},\n", preset.post_process.ssao_enabled));
        json.push_str(&format!("    \"bloomEnabled\": {},\n", preset.post_process.bloom_enabled));
        json.push_str(&format!("    \"bloomIntensity\": {}\n", preset.post_process.bloom_intensity));
        json.push_str("  }\n");
        json.push_str("}\n");
        json.into_bytes()
    }

    fn export_binary(preset: &NovaPreset) -> Vec<u8> {
        let mut data = Vec::new();
        // Magic header
        data.extend_from_slice(b"NOVA");
        data.push(1); // Version

        // Metadata length + data
        let id_bytes = preset.metadata.id.as_bytes();
        data.push(id_bytes.len() as u8);
        data.extend_from_slice(id_bytes);

        // Color settings
        data.extend_from_slice(&preset.color.exposure.to_le_bytes());
        data.extend_from_slice(&preset.color.contrast.to_le_bytes());
        data.extend_from_slice(&preset.color.saturation.to_le_bytes());
        data.extend_from_slice(&preset.color.temperature.to_le_bytes());

        data
    }

    fn export_reshade(preset: &NovaPreset) -> Vec<u8> {
        let mut ini = String::new();
        ini.push_str("[Colorfulness.fx]\n");
        ini.push_str(&format!("Saturation={}\n", preset.color.saturation));
        ini.push_str(&format!("Colorfulness={}\n", preset.color.vibrance));
        ini.push_str("\n[Tonemap.fx]\n");
        ini.push_str(&format!("Exposure={}\n", preset.color.exposure));
        ini.push_str(&format!("Contrast={}\n", preset.color.contrast));
        ini.push_str("\n[Bloom.fx]\n");
        ini.push_str(&format!("BloomIntensity={}\n", preset.post_process.bloom_intensity));
        ini.push_str(&format!("BloomThreshold={}\n", preset.post_process.bloom_threshold));
        ini.into_bytes()
    }

    fn export_unity(preset: &NovaPreset) -> Vec<u8> {
        let mut asset = String::new();
        asset.push_str("%YAML 1.1\n");
        asset.push_str("--- !u!114 &11400000\n");
        asset.push_str("MonoBehaviour:\n");
        asset.push_str("  m_Name: NovaPreset\n");
        asset.push_str("  colorGrading:\n");
        asset.push_str(&format!("    exposure: {}\n", preset.color.exposure));
        asset.push_str(&format!("    contrast: {}\n", preset.color.contrast));
        asset.push_str(&format!("    saturation: {}\n", preset.color.saturation));
        asset.push_str("  bloom:\n");
        asset.push_str(&format!("    enabled: {}\n", preset.post_process.bloom_enabled));
        asset.push_str(&format!("    intensity: {}\n", preset.post_process.bloom_intensity));
        asset.into_bytes()
    }

    fn export_unreal(preset: &NovaPreset) -> Vec<u8> {
        let mut blueprint = String::new();
        blueprint.push_str("Begin Object Class=/Script/Engine.PostProcessSettings\n");
        blueprint.push_str(&format!("   bOverride_FilmGrainIntensity={}\n", preset.post_process.grain_enabled));
        blueprint.push_str(&format!("   FilmGrainIntensity={}\n", preset.post_process.grain_intensity));
        blueprint.push_str(&format!("   bOverride_BloomIntensity=True\n"));
        blueprint.push_str(&format!("   BloomIntensity={}\n", preset.post_process.bloom_intensity));
        blueprint.push_str(&format!("   bOverride_AutoExposureBias=True\n"));
        blueprint.push_str(&format!("   AutoExposureBias={}\n", preset.color.exposure));
        blueprint.push_str("End Object\n");
        blueprint.into_bytes()
    }
}

/// Preset importer
pub struct PresetImporter;

impl PresetImporter {
    pub fn detect_format(data: &[u8]) -> Option<PresetFormat> {
        if data.len() < 4 { return None; }

        if &data[0..4] == b"NOVA" {
            return Some(PresetFormat::NovaBinary);
        }

        let text = String::from_utf8_lossy(data);
        if text.contains("{") && text.contains("\"id\"") {
            return Some(PresetFormat::NovaJson);
        }
        if text.contains("[") && text.contains(".fx]") {
            return Some(PresetFormat::ReShade);
        }
        if text.contains("%YAML") {
            return Some(PresetFormat::Unity);
        }
        if text.contains("Begin Object") {
            return Some(PresetFormat::Unreal);
        }

        None
    }

    pub fn import(data: &[u8], format: PresetFormat) -> Option<NovaPreset> {
        match format {
            PresetFormat::NovaBinary => Self::import_binary(data),
            PresetFormat::NovaJson => Self::import_json(data),
            _ => None, // Other formats require conversion
        }
    }

    fn import_binary(data: &[u8]) -> Option<NovaPreset> {
        if data.len() < 5 || &data[0..4] != b"NOVA" {
            return None;
        }

        let mut preset = presets::cinematic_default();
        let mut offset = 5; // Skip header + version

        if offset < data.len() {
            let id_len = data[offset] as usize;
            offset += 1;
            if offset + id_len <= data.len() {
                preset.metadata.id = String::from_utf8_lossy(&data[offset..offset + id_len]).to_string();
                offset += id_len;
            }
        }

        if offset + 16 <= data.len() {
            preset.color.exposure = f32::from_le_bytes([data[offset], data[offset+1], data[offset+2], data[offset+3]]);
            offset += 4;
            preset.color.contrast = f32::from_le_bytes([data[offset], data[offset+1], data[offset+2], data[offset+3]]);
            offset += 4;
            preset.color.saturation = f32::from_le_bytes([data[offset], data[offset+1], data[offset+2], data[offset+3]]);
            offset += 4;
            preset.color.temperature = f32::from_le_bytes([data[offset], data[offset+1], data[offset+2], data[offset+3]]);
        }

        Some(preset)
    }

    fn import_json(data: &[u8]) -> Option<NovaPreset> {
        let text = String::from_utf8_lossy(data);
        let mut preset = presets::cinematic_default();

        // Simple JSON parsing
        for line in text.lines() {
            let line = line.trim();
            if line.contains("\"id\"") {
                if let Some(val) = Self::extract_string_value(line) {
                    preset.metadata.id = val;
                }
            }
            if line.contains("\"name\"") {
                if let Some(val) = Self::extract_string_value(line) {
                    preset.metadata.name = val;
                }
            }
            if line.contains("\"exposure\"") {
                if let Some(val) = Self::extract_number_value(line) {
                    preset.color.exposure = val;
                }
            }
            if line.contains("\"contrast\"") {
                if let Some(val) = Self::extract_number_value(line) {
                    preset.color.contrast = val;
                }
            }
            if line.contains("\"saturation\"") {
                if let Some(val) = Self::extract_number_value(line) {
                    preset.color.saturation = val;
                }
            }
        }

        Some(preset)
    }

    fn extract_string_value(line: &str) -> Option<String> {
        let parts: Vec<&str> = line.split(':').collect();
        if parts.len() >= 2 {
            let val = parts[1].trim().trim_matches(|c| c == '"' || c == ',' || c == ' ');
            return Some(val.to_string());
        }
        None
    }

    fn extract_number_value(line: &str) -> Option<f32> {
        let parts: Vec<&str> = line.split(':').collect();
        if parts.len() >= 2 {
            let val = parts[1].trim().trim_matches(|c| c == ',' || c == ' ');
            return val.parse().ok();
        }
        None
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HDR DISPLAY ADAPTATION
// ═══════════════════════════════════════════════════════════════════════════════

/// HDR display adaptation system
pub struct HDRAdapter {
    pub display_type: DisplayType,
    pub max_luminance: f32,
    pub min_luminance: f32,
    pub sdr_white_level: f32,
    pub hdr_headroom: f32,
    pub gamut: ColorGamut,
}

#[derive(Debug, Clone, Copy)]
pub enum ColorGamut {
    SRGB,
    DCI_P3,
    BT2020,
    AdobeRGB,
}

impl HDRAdapter {
    pub fn new(display_type: DisplayType) -> Self {
        let (max_lum, min_lum, white) = match display_type {
            DisplayType::SDR => (100.0, 0.1, 80.0),
            DisplayType::HDR10 => (1000.0, 0.005, 203.0),
            DisplayType::HDR10Plus => (4000.0, 0.001, 203.0),
            DisplayType::DolbyVision => (10000.0, 0.0001, 203.0),
            DisplayType::HLG => (1000.0, 0.01, 203.0),
        };

        HDRAdapter {
            display_type,
            max_luminance: max_lum,
            min_luminance: min_lum,
            sdr_white_level: white,
            hdr_headroom: max_lum / white,
            gamut: if display_type == DisplayType::SDR { ColorGamut::SRGB } else { ColorGamut::BT2020 },
        }
    }

    pub fn adapt_preset(&self, preset: &NovaPreset) -> NovaPreset {
        let mut adapted = preset.clone();

        match self.display_type {
            DisplayType::SDR => {
                // Compress HDR content for SDR
                adapted.color.exposure -= 0.5;
                adapted.post_process.bloom_intensity *= 0.7;
            }
            DisplayType::HDR10 | DisplayType::HDR10Plus => {
                adapted.color.tonemapper = ToneMapperType::QuantaAdaptive;
                adapted.color.precision_tier = PrecisionTier::Maximum;
                adapted.post_process.bloom_threshold = 1.5;
            }
            DisplayType::DolbyVision => {
                adapted.color.tonemapper = ToneMapperType::QuantaAdaptive;
                adapted.color.precision_tier = PrecisionTier::Maximum;
                adapted.lighting.volumetric_enabled = true;
            }
            DisplayType::HLG => {
                // HLG is backwards compatible
                adapted.color.tonemapper = ToneMapperType::Filmic;
            }
        }

        adapted
    }

    pub fn pq_to_linear(&self, pq: f32) -> f32 {
        let m1 = 0.1593017578125;
        let m2 = 78.84375;
        let c1 = 0.8359375;
        let c2 = 18.8515625;
        let c3 = 18.6875;

        let pq_pow = pq.powf(1.0 / m2);
        let num = (pq_pow - c1).max(0.0);
        let den = c2 - c3 * pq_pow;

        10000.0 * (num / den).powf(1.0 / m1)
    }

    pub fn linear_to_pq(&self, linear: f32) -> f32 {
        let m1 = 0.1593017578125;
        let m2 = 78.84375;
        let c1 = 0.8359375;
        let c2 = 18.8515625;
        let c3 = 18.6875;

        let y = (linear / 10000.0).max(0.0);
        let y_pow = y.powf(m1);
        let num = c1 + c2 * y_pow;
        let den = 1.0 + c3 * y_pow;

        (num / den).powf(m2)
    }

    pub fn hlg_to_linear(&self, hlg: f32) -> f32 {
        let a = 0.17883277;
        let b = 0.28466892;
        let c = 0.55991073;

        if hlg <= 0.5 {
            hlg * hlg / 3.0
        } else {
            ((hlg - c) / a).exp() + b
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TIME OF DAY PRESETS
// ═══════════════════════════════════════════════════════════════════════════════

/// Time-based preset scheduling
pub struct PresetScheduler {
    pub schedules: Vec<ScheduleEntry>,
    pub transition_duration: f32,
    pub current_preset: Option<NovaPreset>,
}

#[derive(Debug, Clone)]
pub struct ScheduleEntry {
    pub start_hour: f32,
    pub end_hour: f32,
    pub preset_id: String,
    pub days: Vec<DayOfWeek>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum DayOfWeek {
    Sunday, Monday, Tuesday, Wednesday, Thursday, Friday, Saturday,
}

impl PresetScheduler {
    pub fn new() -> Self {
        PresetScheduler {
            schedules: Vec::new(),
            transition_duration: 30.0,
            current_preset: None,
        }
    }

    pub fn add_schedule(&mut self, entry: ScheduleEntry) {
        self.schedules.push(entry);
    }

    pub fn get_preset_for_time(&self, hour: f32, day: DayOfWeek, library: &NovaLibrary) -> Option<NovaPreset> {
        for entry in &self.schedules {
            if entry.days.contains(&day) || entry.days.is_empty() {
                let in_range = if entry.start_hour <= entry.end_hour {
                    hour >= entry.start_hour && hour < entry.end_hour
                } else {
                    hour >= entry.start_hour || hour < entry.end_hour
                };

                if in_range {
                    return library.get(&entry.preset_id).cloned();
                }
            }
        }
        None
    }

    pub fn update(&mut self, hour: f32, day: DayOfWeek, library: &NovaLibrary) -> Option<NovaPreset> {
        let target = self.get_preset_for_time(hour, day, library);

        match (&self.current_preset, &target) {
            (None, Some(t)) => {
                self.current_preset = Some(t.clone());
                Some(t.clone())
            }
            (Some(current), Some(target)) if current.metadata.id != target.metadata.id => {
                // Transition to new preset
                self.current_preset = Some(target.clone());
                Some(target.clone())
            }
            (Some(current), _) => Some(current.clone()),
            _ => None,
        }
    }

    pub fn create_day_night_schedule(&mut self) {
        // Dawn
        self.add_schedule(ScheduleEntry {
            start_hour: 5.0,
            end_hour: 7.0,
            preset_id: "cinematic_warm".to_string(),
            days: vec![],
        });

        // Day
        self.add_schedule(ScheduleEntry {
            start_hour: 7.0,
            end_hour: 17.0,
            preset_id: "photo_natural".to_string(),
            days: vec![],
        });

        // Golden hour
        self.add_schedule(ScheduleEntry {
            start_hour: 17.0,
            end_hour: 19.0,
            preset_id: "cinematic_warm".to_string(),
            days: vec![],
        });

        // Night
        self.add_schedule(ScheduleEntry {
            start_hour: 19.0,
            end_hour: 5.0,
            preset_id: "cinematic_cool".to_string(),
            days: vec![],
        });
    }
}

