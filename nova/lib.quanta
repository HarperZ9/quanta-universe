/// Mood-based preset generation system
pub mod mood_generator {
    use super::*;

    /// Emotional mood categories for preset generation
    #[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
    pub enum Mood {
        Joyful,
        Melancholic,
        Tense,
        Peaceful,
        Dramatic,
        Mysterious,
        Nostalgic,
        Energetic,
        Romantic,
        Ominous,
        Ethereal,
        Gritty,
    }

    /// Time of day for lighting adaptation
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum MoodTimeOfDay {
        Dawn,
        GoldenHourMorning,
        Morning,
        Midday,
        Afternoon,
        GoldenHourEvening,
        Dusk,
        BlueHour,
        Night,
        Midnight,
    }

    /// Genre-specific styling
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum Genre {
        Horror,
        SciFi,
        Fantasy,
        Noir,
        Western,
        Documentary,
        ActionBlockbuster,
        IndieDrama,
        Animation,
        HistoricalPeriod,
        Cyberpunk,
        PostApocalyptic,
    }

    /// Mood color mapping for preset generation
    pub struct MoodColorProfile {
        pub primary_hue: f32,
        pub secondary_hue: f32,
        pub saturation_bias: f32,
        pub luminance_bias: f32,
        pub contrast_multiplier: f32,
        pub warmth_bias: f32,
    }

    impl Mood {
        /// Get the color profile associated with this mood
        pub fn color_profile(&self) -> MoodColorProfile {
            match self {
                Mood::Joyful => MoodColorProfile {
                    primary_hue: 45.0,      // Yellow-orange
                    secondary_hue: 180.0,   // Cyan
                    saturation_bias: 0.15,
                    luminance_bias: 0.1,
                    contrast_multiplier: 1.05,
                    warmth_bias: 20.0,
                },
                Mood::Melancholic => MoodColorProfile {
                    primary_hue: 220.0,     // Blue
                    secondary_hue: 280.0,   // Purple
                    saturation_bias: -0.15,
                    luminance_bias: -0.05,
                    contrast_multiplier: 0.95,
                    warmth_bias: -15.0,
                },
                Mood::Tense => MoodColorProfile {
                    primary_hue: 0.0,       // Red
                    secondary_hue: 30.0,    // Orange
                    saturation_bias: 0.05,
                    luminance_bias: -0.1,
                    contrast_multiplier: 1.2,
                    warmth_bias: 5.0,
                },
                Mood::Peaceful => MoodColorProfile {
                    primary_hue: 160.0,     // Teal
                    secondary_hue: 90.0,    // Green
                    saturation_bias: -0.1,
                    luminance_bias: 0.05,
                    contrast_multiplier: 0.9,
                    warmth_bias: 0.0,
                },
                Mood::Dramatic => MoodColorProfile {
                    primary_hue: 30.0,      // Orange
                    secondary_hue: 210.0,   // Blue
                    saturation_bias: 0.1,
                    luminance_bias: -0.05,
                    contrast_multiplier: 1.3,
                    warmth_bias: 10.0,
                },
                Mood::Mysterious => MoodColorProfile {
                    primary_hue: 270.0,     // Purple
                    secondary_hue: 180.0,   // Cyan
                    saturation_bias: 0.0,
                    luminance_bias: -0.15,
                    contrast_multiplier: 1.15,
                    warmth_bias: -5.0,
                },
                Mood::Nostalgic => MoodColorProfile {
                    primary_hue: 35.0,      // Amber
                    secondary_hue: 20.0,    // Sepia
                    saturation_bias: -0.2,
                    luminance_bias: 0.0,
                    contrast_multiplier: 0.85,
                    warmth_bias: 25.0,
                },
                Mood::Energetic => MoodColorProfile {
                    primary_hue: 320.0,     // Magenta
                    secondary_hue: 60.0,    // Yellow
                    saturation_bias: 0.25,
                    luminance_bias: 0.1,
                    contrast_multiplier: 1.1,
                    warmth_bias: 5.0,
                },
                Mood::Romantic => MoodColorProfile {
                    primary_hue: 340.0,     // Pink
                    secondary_hue: 280.0,   // Lavender
                    saturation_bias: 0.05,
                    luminance_bias: 0.05,
                    contrast_multiplier: 0.95,
                    warmth_bias: 15.0,
                },
                Mood::Ominous => MoodColorProfile {
                    primary_hue: 240.0,     // Deep blue
                    secondary_hue: 0.0,     // Red accents
                    saturation_bias: -0.1,
                    luminance_bias: -0.2,
                    contrast_multiplier: 1.25,
                    warmth_bias: -20.0,
                },
                Mood::Ethereal => MoodColorProfile {
                    primary_hue: 200.0,     // Sky blue
                    secondary_hue: 300.0,   // Violet
                    saturation_bias: -0.05,
                    luminance_bias: 0.15,
                    contrast_multiplier: 0.85,
                    warmth_bias: -5.0,
                },
                Mood::Gritty => MoodColorProfile {
                    primary_hue: 40.0,      // Mustard
                    secondary_hue: 180.0,   // Teal
                    saturation_bias: -0.25,
                    luminance_bias: -0.1,
                    contrast_multiplier: 1.15,
                    warmth_bias: 5.0,
                },
            }
        }
    }

    impl MoodTimeOfDay {
        /// Get sun position and color temperature for this time
        pub fn lighting_params(&self) -> (f32, f32, f32) {
            // Returns: (sun_altitude_degrees, color_temperature_kelvin, intensity_multiplier)
            match self {
                MoodTimeOfDay::Dawn => (5.0, 2500.0, 0.3),
                MoodTimeOfDay::GoldenHourMorning => (15.0, 3200.0, 0.6),
                MoodTimeOfDay::Morning => (35.0, 4500.0, 0.85),
                MoodTimeOfDay::Midday => (90.0, 6500.0, 1.0),
                MoodTimeOfDay::Afternoon => (55.0, 5500.0, 0.9),
                MoodTimeOfDay::GoldenHourEvening => (15.0, 3000.0, 0.55),
                MoodTimeOfDay::Dusk => (5.0, 2200.0, 0.25),
                MoodTimeOfDay::BlueHour => (-5.0, 12000.0, 0.15),
                MoodTimeOfDay::Night => (-30.0, 4100.0, 0.05),
                MoodTimeOfDay::Midnight => (-45.0, 4100.0, 0.02),
            }
        }

        /// Get ambient sky color for this time
        pub fn sky_color(&self) -> RGB {
            match self {
                MoodTimeOfDay::Dawn => RGB::new(0.95, 0.6, 0.4),
                MoodTimeOfDay::GoldenHourMorning => RGB::new(1.0, 0.8, 0.5),
                MoodTimeOfDay::Morning => RGB::new(0.6, 0.75, 0.95),
                MoodTimeOfDay::Midday => RGB::new(0.53, 0.81, 0.92),
                MoodTimeOfDay::Afternoon => RGB::new(0.55, 0.78, 0.95),
                MoodTimeOfDay::GoldenHourEvening => RGB::new(1.0, 0.65, 0.35),
                MoodTimeOfDay::Dusk => RGB::new(0.9, 0.45, 0.35),
                MoodTimeOfDay::BlueHour => RGB::new(0.3, 0.4, 0.7),
                MoodTimeOfDay::Night => RGB::new(0.05, 0.08, 0.15),
                MoodTimeOfDay::Midnight => RGB::new(0.02, 0.03, 0.08),
            }
        }
    }

    impl Genre {
