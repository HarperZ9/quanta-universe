// GAME-SPECIFIC PRESETS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod game_presets {
    use super::*;

    pub fn fps_competitive() -> NovaPreset {
        let mut preset = presets::performance_balanced();
        preset.metadata.id = "game_fps_comp".to_string();
        preset.metadata.name = "FPS Competitive".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["CS2".to_string(), "Valorant".to_string(), "Apex".to_string()];

        // High visibility settings
        preset.color.saturation = 1.2;
        preset.color.vibrance = 0.2;
        preset.post_process.sharpening_enabled = true;
        preset.post_process.sharpening_intensity = 0.7;
        preset.post_process.motion_blur_enabled = false;
        preset.post_process.dof_enabled = false;
        preset.performance.target_fps = 144;

        preset
    }

    pub fn rpg_immersive() -> NovaPreset {
        let mut preset = presets::cinematic_fantasy();
        preset.metadata.id = "game_rpg".to_string();
        preset.metadata.name = "RPG Immersive".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["Skyrim".to_string(), "Witcher".to_string(), "Elden Ring".to_string()];

        preset.lighting.volumetric_enabled = true;
        preset.lighting.volumetric_intensity = 1.2;
        preset.effects.god_rays_enabled = true;
        preset.post_process.dof_enabled = true;

        preset
    }

    pub fn horror_atmospheric() -> NovaPreset {
        let mut preset = presets::cinematic_horror();
        preset.metadata.id = "game_horror".to_string();
        preset.metadata.name = "Horror Atmospheric".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["RE".to_string(), "Silent Hill".to_string(), "Outlast".to_string()];

        preset.color.contrast = 1.3;
        preset.post_process.vignette_intensity = 0.7;
        preset.effects.fog_enabled = true;
        preset.effects.fog_density = 0.02;
        preset.lighting.ambient_intensity = 0.6;

        preset
    }

    pub fn racing_dynamic() -> NovaPreset {
        let mut preset = presets::photorealistic_vivid();
        preset.metadata.id = "game_racing".to_string();
        preset.metadata.name = "Racing Dynamic".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["Forza".to_string(), "GT7".to_string(), "NFS".to_string()];

        preset.post_process.motion_blur_enabled = true;
        preset.post_process.motion_blur_intensity = 0.4;
        preset.effects.lens_flare_enabled = true;
        preset.color.vibrance = 0.15;

        preset
    }

    pub fn strategy_clear() -> NovaPreset {
        let mut preset = presets::photorealistic_neutral();
        preset.metadata.id = "game_strategy".to_string();
        preset.metadata.name = "Strategy Clear".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["Civ".to_string(), "Total War".to_string(), "AoE".to_string()];

        // Maximum clarity for UI-heavy games
        preset.post_process.sharpening_enabled = true;
        preset.post_process.sharpening_intensity = 0.6;
        preset.post_process.aa_method = AAMethod::SMAA;
        preset.color.contrast = 1.1;

        preset
    }

    pub fn survival_gritty() -> NovaPreset {
        let mut preset = presets::cinematic_indie();
        preset.metadata.id = "game_survival".to_string();
        preset.metadata.name = "Survival Gritty".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["DayZ".to_string(), "Rust".to_string(), "SCUM".to_string()];

        preset.color.saturation = 0.85;
        preset.color.temperature = 5.0;
        preset.post_process.grain_enabled = true;
        preset.post_process.grain_intensity = 0.04;

        preset
    }

    pub fn simulator_realistic() -> NovaPreset {
        let mut preset = presets::photorealistic_natural();
        preset.metadata.id = "game_simulator".to_string();
        preset.metadata.name = "Simulator Realistic".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["MSFS".to_string(), "DCS".to_string(), "iRacing".to_string()];

        preset.color.tonemapper = ToneMapperType::AgX;
        preset.lighting.volumetric_enabled = true;
        preset.effects.god_rays_enabled = true;
        preset.post_process.dof_enabled = true;
        preset.post_process.dof_aperture = 5.6;

        preset
    }

    pub fn platformer_vibrant() -> NovaPreset {
        let mut preset = presets::stylized_anime();
        preset.metadata.id = "game_platformer".to_string();
        preset.metadata.name = "Platformer Vibrant".to_string();
        preset.metadata.category = PresetCategory::GameSpecific;
        preset.metadata.target_games = vec!["Mario".to_string(), "Celeste".to_string(), "Hollow Knight".to_string()];

        preset.color.saturation = 1.25;
        preset.color.vibrance = 0.2;
        preset.post_process.bloom_intensity = 0.6;
        preset.effects.outline_enabled = false;

        preset
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VALIDATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Preset validator
pub struct PresetValidator;

#[derive(Debug, Clone)]
pub struct ValidationResult {
    pub valid: bool,
    pub warnings: Vec<String>,
    pub errors: Vec<String>,
}

impl PresetValidator {
    pub fn validate(preset: &NovaPreset) -> ValidationResult {
        let mut result = ValidationResult {
            valid: true,
            warnings: Vec::new(),
            errors: Vec::new(),
        };

        // Metadata checks
        if preset.metadata.id.is_empty() {
            result.errors.push("Preset ID is empty".to_string());
            result.valid = false;
        }
        if preset.metadata.name.is_empty() {
            result.errors.push("Preset name is empty".to_string());
            result.valid = false;
        }

        // Color range checks
        if preset.color.exposure < -5.0 || preset.color.exposure > 5.0 {
            result.warnings.push("Exposure is outside recommended range (-5 to 5)".to_string());
        }
        if preset.color.contrast < 0.5 || preset.color.contrast > 2.0 {
            result.warnings.push("Contrast is outside recommended range (0.5 to 2.0)".to_string());
        }
        if preset.color.saturation < 0.0 || preset.color.saturation > 2.0 {
            result.warnings.push("Saturation is outside recommended range (0 to 2.0)".to_string());
        }

        // Post-process checks
        if preset.post_process.ssao_samples > 128 {
            result.warnings.push("SSAO samples very high, may impact performance".to_string());
        }
        if preset.post_process.bloom_intensity > 2.0 {
            result.warnings.push("Bloom intensity very high, may cause visual artifacts".to_string());
        }

        // Performance checks
        if preset.performance.resolution_scale < 0.25 {
            result.warnings.push("Resolution scale very low, image quality will be poor".to_string());
        }
        if preset.performance.target_fps > 360 {
            result.warnings.push("Target FPS unrealistically high".to_string());
        }

        // Accessibility checks
        if preset.accessibility.ui_scale < 0.5 || preset.accessibility.ui_scale > 3.0 {
            result.warnings.push("UI scale outside typical range".to_string());
        }

        result
    }

    pub fn fix_issues(preset: &mut NovaPreset) {
        // Clamp values to safe ranges
        preset.color.exposure = preset.color.exposure.clamp(-5.0, 5.0);
        preset.color.contrast = preset.color.contrast.clamp(0.1, 3.0);
        preset.color.saturation = preset.color.saturation.clamp(0.0, 3.0);
        preset.color.temperature = preset.color.temperature.clamp(-100.0, 100.0);
        preset.color.tint = preset.color.tint.clamp(-100.0, 100.0);

        preset.post_process.ssao_samples = preset.post_process.ssao_samples.min(128);
        preset.post_process.bloom_intensity = preset.post_process.bloom_intensity.clamp(0.0, 3.0);
        preset.post_process.vignette_intensity = preset.post_process.vignette_intensity.clamp(0.0, 1.0);

        preset.performance.resolution_scale = preset.performance.resolution_scale.clamp(0.25, 2.0);
        preset.performance.target_fps = preset.performance.target_fps.clamp(15, 360);

        preset.accessibility.ui_scale = preset.accessibility.ui_scale.clamp(0.5, 3.0);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REAL-TIME PREVIEW
// ═══════════════════════════════════════════════════════════════════════════════

/// Real-time preset preview system
pub struct PresetPreview {
    pub current_preset: NovaPreset,
    pub preview_preset: Option<NovaPreset>,
    pub preview_opacity: f32,
    pub transition_time: f32,
    pub transition_progress: f32,
    pub transition_curve: TransitionCurve,
}

#[derive(Debug, Clone, Copy)]
pub enum TransitionCurve {
    Linear,
    EaseIn,
    EaseOut,
    EaseInOut,
    Bounce,
}

impl PresetPreview {
    pub fn new(initial: NovaPreset) -> Self {
        PresetPreview {
            current_preset: initial,
            preview_preset: None,
            preview_opacity: 0.0,
            transition_time: 0.5,
            transition_progress: 0.0,
            transition_curve: TransitionCurve::EaseInOut,
        }
    }

    pub fn start_preview(&mut self, preset: NovaPreset) {
        self.preview_preset = Some(preset);
        self.preview_opacity = 0.0;
        self.transition_progress = 0.0;
    }

    pub fn apply_preview(&mut self) {
        if let Some(preview) = self.preview_preset.take() {
            self.current_preset = preview;
            self.preview_opacity = 0.0;
        }
    }

    pub fn cancel_preview(&mut self) {
        self.preview_preset = None;
        self.preview_opacity = 0.0;
        self.transition_progress = 0.0;
    }

    pub fn update(&mut self, delta_time: f32) {
        if self.preview_preset.is_some() {
            self.transition_progress += delta_time / self.transition_time;
            self.transition_progress = self.transition_progress.min(1.0);
            self.preview_opacity = self.apply_curve(self.transition_progress);
        }
    }

    fn apply_curve(&self, t: f32) -> f32 {
        match self.transition_curve {
            TransitionCurve::Linear => t,
            TransitionCurve::EaseIn => t * t,
            TransitionCurve::EaseOut => 1.0 - (1.0 - t) * (1.0 - t),
            TransitionCurve::EaseInOut => {
                if t < 0.5 {
                    2.0 * t * t
                } else {
                    1.0 - (-2.0 * t + 2.0).powi(2) / 2.0
                }
            }
            TransitionCurve::Bounce => {
                let n1 = 7.5625;
                let d1 = 2.75;
                let mut t = t;

                if t < 1.0 / d1 {
                    n1 * t * t
                } else if t < 2.0 / d1 {
                    t -= 1.5 / d1;
                    n1 * t * t + 0.75
                } else if t < 2.5 / d1 {
                    t -= 2.25 / d1;
                    n1 * t * t + 0.9375
                } else {
                    t -= 2.625 / d1;
                    n1 * t * t + 0.984375
                }
            }
        }
    }

    pub fn get_blended_preset(&self) -> NovaPreset {
        match &self.preview_preset {
            Some(preview) => blend_presets(&self.current_preset, preview, self.preview_opacity),
            None => self.current_preset.clone(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET ANALYTICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Preset usage analytics
pub struct PresetAnalytics {
    pub usage_counts: HashMap<String, u64>,
    pub usage_durations: HashMap<String, f64>,
    pub transitions: Vec<PresetTransition>,
    pub favorites: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct PresetTransition {
    pub from_preset: String,
    pub to_preset: String,
    pub timestamp: u64,
    pub duration: f32,
}

impl PresetAnalytics {
    pub fn new() -> Self {
        PresetAnalytics {
            usage_counts: HashMap::new(),
            usage_durations: HashMap::new(),
            transitions: Vec::new(),
            favorites: Vec::new(),
        }
    }

    pub fn record_usage(&mut self, preset_id: &str, duration: f64) {
        *self.usage_counts.entry(preset_id.to_string()).or_insert(0) += 1;
        *self.usage_durations.entry(preset_id.to_string()).or_insert(0.0) += duration;
    }

    pub fn record_transition(&mut self, from: &str, to: &str, timestamp: u64) {
        self.transitions.push(PresetTransition {
            from_preset: from.to_string(),
            to_preset: to.to_string(),
            timestamp,
            duration: 0.0,
        });
    }

    pub fn add_favorite(&mut self, preset_id: &str) {
        if !self.favorites.contains(&preset_id.to_string()) {
            self.favorites.push(preset_id.to_string());
        }
    }

    pub fn remove_favorite(&mut self, preset_id: &str) {
        self.favorites.retain(|id| id != preset_id);
    }

    pub fn most_used(&self, limit: usize) -> Vec<(&String, &u64)> {
        let mut sorted: Vec<_> = self.usage_counts.iter().collect();
        sorted.sort_by(|a, b| b.1.cmp(a.1));
        sorted.into_iter().take(limit).collect()
    }

    pub fn average_session_duration(&self, preset_id: &str) -> f64 {
        let count = self.usage_counts.get(preset_id).copied().unwrap_or(1) as f64;
        let total = self.usage_durations.get(preset_id).copied().unwrap_or(0.0);
        total / count
    }

    pub fn common_transitions(&self, from_preset: &str) -> Vec<(String, usize)> {
        let mut counts: HashMap<String, usize> = HashMap::new();

        for trans in &self.transitions {
            if trans.from_preset == from_preset {
                *counts.entry(trans.to_preset.clone()).or_insert(0) += 1;
            }
        }

        let mut sorted: Vec<_> = counts.into_iter().collect();
        sorted.sort_by(|a, b| b.1.cmp(&a.1));
        sorted
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VERSIONING & MIGRATION
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct PresetVersion {
    pub major: u32,
    pub minor: u32,
    pub patch: u32,
    pub created_at: u64,
    pub changelog: String,
}

impl PresetVersion {
    pub fn new(major: u32, minor: u32, patch: u32) -> Self {
        PresetVersion { major, minor, patch, created_at: 0, changelog: String::new() }
    }

    pub fn is_compatible(&self, other: &PresetVersion) -> bool {
        self.major == other.major
    }

    pub fn to_string(&self) -> String {
        format!("{}.{}.{}", self.major, self.minor, self.patch)
    }
}

#[derive(Debug, Clone)]
pub struct VersionedPreset {
    pub preset: NovaPreset,
    pub version: PresetVersion,
    pub history: Vec<PresetVersion>,
    pub migration_path: Vec<Migration>,
}

#[derive(Debug, Clone)]
pub struct Migration {
    pub from_version: PresetVersion,
    pub to_version: PresetVersion,
    pub transformations: Vec<MigrationTransform>,
}

#[derive(Debug, Clone)]
pub enum MigrationTransform {
    RenameField { old_name: String, new_name: String },
    AddField { name: String, default_value: f32 },
    RemoveField { name: String },
    ScaleValue { field: String, factor: f32 },
    MapValue { field: String, old_val: f32, new_val: f32 },
    ConvertColorSpace { from: String, to: String },
}

pub struct PresetMigrator {
    migrations: Vec<Migration>,
}

impl PresetMigrator {
    pub fn new() -> Self {
        PresetMigrator { migrations: Vec::new() }
    }

    pub fn register_migration(&mut self, migration: Migration) {
        self.migrations.push(migration);
    }

    pub fn migrate(&self, preset: &mut VersionedPreset, target: &PresetVersion) -> Result<(), String> {
        let mut current = preset.version.clone();

        while !current.is_compatible(target) || current.minor < target.minor {
            let migration = self.find_migration(&current)?;
            self.apply_migration(preset, &migration)?;
            current = migration.to_version.clone();
        }

        preset.version = target.clone();
        Ok(())
    }

    fn find_migration(&self, from: &PresetVersion) -> Result<&Migration, String> {
        self.migrations.iter()
            .find(|m| m.from_version.major == from.major && m.from_version.minor == from.minor)
            .ok_or_else(|| format!("No migration from version {}", from.to_string()))
    }

    fn apply_migration(&self, preset: &mut VersionedPreset, migration: &Migration) -> Result<(), String> {
        for transform in &migration.transformations {
            self.apply_transform(preset, transform)?;
        }
        preset.history.push(migration.from_version.clone());
        Ok(())
    }

    fn apply_transform(&self, preset: &mut VersionedPreset, transform: &MigrationTransform) -> Result<(), String> {
        match transform {
            MigrationTransform::ScaleValue { field, factor } => {
                match field.as_str() {
                    "exposure" => preset.preset.color.exposure *= factor,
                    "contrast" => preset.preset.color.contrast *= factor,
                    "saturation" => preset.preset.color.saturation *= factor,
                    "bloom_intensity" => preset.preset.effects.bloom_intensity *= factor,
                    _ => {}
                }
            }
            MigrationTransform::AddField { name, default_value } => {
                // Fields added with defaults - no-op for existing struct
            }
            _ => {}
        }
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CLOUD SYNC
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub enum SyncStatus {
    Synced,
    LocalOnly,
    CloudOnly,
    Conflict,
    Syncing,
    Error(String),
}

#[derive(Debug, Clone)]
pub struct CloudPreset {
    pub preset: NovaPreset,
    pub cloud_id: String,
    pub owner_id: String,
    pub is_public: bool,
    pub download_count: u64,
    pub rating: f32,
    pub tags: Vec<String>,
    pub sync_status: SyncStatus,
    pub last_synced: u64,
    pub local_modified: u64,
    pub cloud_modified: u64,
}

pub struct CloudSync {
    pub endpoint: String,
    pub api_key: String,
    pub user_id: String,
    pub local_cache: HashMap<String, CloudPreset>,
    pub sync_queue: Vec<String>,
    pub conflict_resolution: ConflictResolution,
}

#[derive(Debug, Clone, Copy)]
pub enum ConflictResolution {
    LocalWins,
    CloudWins,
    AskUser,
    MergeIfPossible,
}

impl CloudSync {
    pub fn new(endpoint: &str, api_key: &str, user_id: &str) -> Self {
        CloudSync {
            endpoint: endpoint.to_string(),
            api_key: api_key.to_string(),
            user_id: user_id.to_string(),
            local_cache: HashMap::new(),
            sync_queue: Vec::new(),
            conflict_resolution: ConflictResolution::AskUser,
        }
    }

    pub fn queue_upload(&mut self, preset_id: &str) {
        if !self.sync_queue.contains(&preset_id.to_string()) {
            self.sync_queue.push(preset_id.to_string());
        }
    }

    pub fn check_conflicts(&self, preset: &CloudPreset) -> Option<SyncStatus> {
        if preset.local_modified > preset.last_synced && preset.cloud_modified > preset.last_synced {
            Some(SyncStatus::Conflict)
        } else {
            None
        }
    }

    pub fn resolve_conflict(&self, local: &NovaPreset, cloud: &NovaPreset) -> NovaPreset {
        match self.conflict_resolution {
            ConflictResolution::LocalWins => local.clone(),
            ConflictResolution::CloudWins => cloud.clone(),
            ConflictResolution::MergeIfPossible => blend_presets(local, cloud, 0.5),
            ConflictResolution::AskUser => local.clone(), // Default to local
        }
    }

    pub fn generate_diff(&self, local: &NovaPreset, cloud: &NovaPreset) -> PresetDiff {
        PresetDiff {
            exposure_diff: local.color.exposure - cloud.color.exposure,
            contrast_diff: local.color.contrast - cloud.color.contrast,
            saturation_diff: local.color.saturation - cloud.color.saturation,
            temperature_diff: local.color.temperature - cloud.color.temperature,
            bloom_diff: local.effects.bloom_intensity - cloud.effects.bloom_intensity,
            has_significant_diff: (local.color.exposure - cloud.color.exposure).abs() > 0.1,
        }
    }
}

#[derive(Debug, Clone)]
pub struct PresetDiff {
    pub exposure_diff: f32,
    pub contrast_diff: f32,
    pub saturation_diff: f32,
    pub temperature_diff: f32,
    pub bloom_diff: f32,
    pub has_significant_diff: bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET RECOMMENDATIONS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct ContentProfile {
    pub game_genre: GameGenre,
    pub avg_brightness: f32,
    pub color_temperature: f32,
    pub contrast_ratio: f32,
    pub is_hdr: bool,
    pub is_indoor: bool,
    pub time_of_day: TimeOfDay,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum GameGenre {
    FPS,
    RPG,
    Racing,
    Horror,
    Strategy,
    Sports,
    Platformer,
    Simulation,
    Adventure,
    Puzzle,
    Unknown,
}

#[derive(Debug, Clone, Copy)]
pub enum TimeOfDay {
    Dawn,
    Day,
    Dusk,
    Night,
    Mixed,
}

pub struct PresetRecommender {
    pub genre_presets: HashMap<GameGenre, Vec<String>>,
    pub user_preferences: UserPreferences,
    pub usage_history: Vec<(String, ContentProfile)>,
}

#[derive(Debug, Clone)]
pub struct UserPreferences {
    pub prefers_warm: bool,
    pub prefers_high_contrast: bool,
    pub prefers_saturated: bool,
    pub sensitivity_to_bloom: f32,
    pub eye_comfort_priority: bool,
}

impl PresetRecommender {
    pub fn new() -> Self {
        let mut genre_presets = HashMap::new();
        genre_presets.insert(GameGenre::FPS, vec!["fps_competitive".to_string()]);
        genre_presets.insert(GameGenre::RPG, vec!["rpg_immersive".to_string()]);
        genre_presets.insert(GameGenre::Horror, vec!["horror_atmospheric".to_string()]);
        genre_presets.insert(GameGenre::Racing, vec!["racing_dynamic".to_string()]);

        PresetRecommender {
            genre_presets,
            user_preferences: UserPreferences {
                prefers_warm: false,
                prefers_high_contrast: false,
                prefers_saturated: false,
                sensitivity_to_bloom: 0.5,
                eye_comfort_priority: false,
            },
            usage_history: Vec::new(),
        }
    }

    pub fn recommend(&self, profile: &ContentProfile, library: &NovaLibrary) -> Vec<&NovaPreset> {
        let mut scored: Vec<(&NovaPreset, f32)> = library.presets.iter()
            .map(|p| (p, self.score_preset(p, profile)))
            .collect();

        scored.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap_or(std::cmp::Ordering::Equal));
        scored.into_iter().take(5).map(|(p, _)| p).collect()
    }

    fn score_preset(&self, preset: &NovaPreset, profile: &ContentProfile) -> f32 {
        let mut score = 0.0;

        // Genre matching
        if let Some(genre_presets) = self.genre_presets.get(&profile.game_genre) {
            if genre_presets.contains(&preset.metadata.id) {
                score += 10.0;
            }
        }

        // HDR matching
        if profile.is_hdr && preset.color.exposure < 1.0 {
            score += 2.0;
        }

        // Time of day matching
        match profile.time_of_day {
            TimeOfDay::Night => {
                if preset.color.exposure > 0.0 { score += 1.0; }
            }
            TimeOfDay::Day => {
                if preset.color.exposure < 0.3 { score += 1.0; }
            }
            _ => {}
        }

        // User preferences
        if self.user_preferences.prefers_warm && preset.color.temperature > 0.0 {
            score += 1.5;
        }
        if self.user_preferences.prefers_high_contrast && preset.color.contrast > 1.1 {
            score += 1.5;
        }
        if self.user_preferences.eye_comfort_priority && preset.effects.bloom_intensity < 0.3 {
            score += 2.0;
        }

        score
    }

    pub fn learn_from_usage(&mut self, preset_id: &str, profile: ContentProfile) {
        self.usage_history.push((preset_id.to_string(), profile));
        // Update preferences based on patterns
        if self.usage_history.len() > 10 {
            self.update_preferences();
        }
    }

    fn update_preferences(&mut self) {
        // Analyze patterns and update user preferences
        let warm_count = self.usage_history.iter()
            .filter(|(_, p)| p.color_temperature > 0.0)
            .count();
        self.user_preferences.prefers_warm = warm_count > self.usage_history.len() / 2;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LUT GENERATION & COLOR GRADING CURVES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct ColorCurve {
    pub control_points: Vec<(f32, f32)>, // Input, Output pairs
    pub interpolation: CurveInterpolation,
}

#[derive(Debug, Clone, Copy)]
pub enum CurveInterpolation {
    Linear,
    CatmullRom,
    Bezier,
    BSpline,
}

impl ColorCurve {
    pub fn new() -> Self {
        ColorCurve {
            control_points: vec![(0.0, 0.0), (1.0, 1.0)],
            interpolation: CurveInterpolation::CatmullRom,
        }
    }

    pub fn add_point(&mut self, x: f32, y: f32) {
        self.control_points.push((x.clamp(0.0, 1.0), y.clamp(0.0, 1.0)));
        self.control_points.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap());
    }

    pub fn evaluate(&self, x: f32) -> f32 {
        if self.control_points.len() < 2 { return x; }

        let x = x.clamp(0.0, 1.0);

        // Find surrounding points
        let mut i = 0;
        for (idx, &(px, _)) in self.control_points.iter().enumerate() {
            if px > x { break; }
            i = idx;
        }

        let j = (i + 1).min(self.control_points.len() - 1);
        let (x0, y0) = self.control_points[i];
        let (x1, y1) = self.control_points[j];

        if x1 == x0 { return y0; }

        let t = (x - x0) / (x1 - x0);

        match self.interpolation {
            CurveInterpolation::Linear => y0 + t * (y1 - y0),
            CurveInterpolation::CatmullRom => self.catmull_rom_interp(i, t),
            CurveInterpolation::Bezier => self.bezier_interp(i, t),
            CurveInterpolation::BSpline => self.bspline_interp(i, t),
        }
    }

    fn catmull_rom_interp(&self, i: usize, t: f32) -> f32 {
        let n = self.control_points.len();
        let p0 = self.control_points[i.saturating_sub(1)].1;
        let p1 = self.control_points[i].1;
        let p2 = self.control_points[(i + 1).min(n - 1)].1;
        let p3 = self.control_points[(i + 2).min(n - 1)].1;

        let t2 = t * t;
        let t3 = t2 * t;

        0.5 * ((2.0 * p1) +
               (-p0 + p2) * t +
               (2.0 * p0 - 5.0 * p1 + 4.0 * p2 - p3) * t2 +
               (-p0 + 3.0 * p1 - 3.0 * p2 + p3) * t3)
    }

    fn bezier_interp(&self, i: usize, t: f32) -> f32 {
        let p0 = self.control_points[i].1;
        let p1 = self.control_points[(i + 1).min(self.control_points.len() - 1)].1;
        (1.0 - t) * p0 + t * p1
    }

    fn bspline_interp(&self, i: usize, t: f32) -> f32 {
        // Simplified B-spline (same as Catmull-Rom for this implementation)
        self.catmull_rom_interp(i, t)
    }
}

#[derive(Debug, Clone)]
pub struct RGBCurves {
    pub master: ColorCurve,
    pub red: ColorCurve,
    pub green: ColorCurve,
    pub blue: ColorCurve,
}

impl RGBCurves {
    pub fn new() -> Self {
        RGBCurves {
            master: ColorCurve::new(),
            red: ColorCurve::new(),
            green: ColorCurve::new(),
            blue: ColorCurve::new(),
        }
    }

    pub fn apply(&self, r: f32, g: f32, b: f32) -> (f32, f32, f32) {
        let r_out = self.master.evaluate(self.red.evaluate(r));
        let g_out = self.master.evaluate(self.green.evaluate(g));
        let b_out = self.master.evaluate(self.blue.evaluate(b));
        (r_out.clamp(0.0, 1.0), g_out.clamp(0.0, 1.0), b_out.clamp(0.0, 1.0))
    }
}

#[derive(Debug, Clone)]
pub struct LUT3D {
    pub size: usize,
    pub data: Vec<(f32, f32, f32)>,
    pub title: String,
}

impl LUT3D {
    pub fn new(size: usize) -> Self {
        let total = size * size * size;
        LUT3D {
            size,
            data: vec![(0.0, 0.0, 0.0); total],
            title: String::new(),
        }
    }

    pub fn from_preset(preset: &NovaPreset, size: usize) -> Self {
        let mut lut = LUT3D::new(size);
        lut.title = preset.metadata.name.clone();

        let step = 1.0 / (size - 1) as f32;

        for b in 0..size {
            for g in 0..size {
                for r in 0..size {
                    let idx = r + g * size + b * size * size;
                    let (ri, gi, bi) = (r as f32 * step, g as f32 * step, b as f32 * step);
                    lut.data[idx] = lut.apply_preset_color(preset, ri, gi, bi);
                }
            }
        }

        lut
    }

    fn apply_preset_color(&self, preset: &NovaPreset, r: f32, g: f32, b: f32) -> (f32, f32, f32) {
        // Apply exposure
        let exp_factor = (2.0_f32).powf(preset.color.exposure);
        let (mut r, mut g, mut b) = (r * exp_factor, g * exp_factor, b * exp_factor);

        // Apply contrast
        let mid = 0.5;
        r = mid + (r - mid) * preset.color.contrast;
        g = mid + (g - mid) * preset.color.contrast;
        b = mid + (b - mid) * preset.color.contrast;

        // Apply saturation
        let lum = 0.2126 * r + 0.7152 * g + 0.0722 * b;
        r = lum + (r - lum) * preset.color.saturation;
        g = lum + (g - lum) * preset.color.saturation;
        b = lum + (b - lum) * preset.color.saturation;

        // Apply temperature shift
        if preset.color.temperature != 0.0 {
            let temp_shift = preset.color.temperature * 0.1;
            r += temp_shift;
            b -= temp_shift;
        }

        (r.clamp(0.0, 1.0), g.clamp(0.0, 1.0), b.clamp(0.0, 1.0))
    }

    pub fn lookup(&self, r: f32, g: f32, b: f32) -> (f32, f32, f32) {
        let size = self.size as f32;
        let r_idx = (r * (size - 1.0)).clamp(0.0, size - 1.0);
        let g_idx = (g * (size - 1.0)).clamp(0.0, size - 1.0);
        let b_idx = (b * (size - 1.0)).clamp(0.0, size - 1.0);

        // Trilinear interpolation
        let r0 = r_idx.floor() as usize;
        let g0 = g_idx.floor() as usize;
        let b0 = b_idx.floor() as usize;
        let r1 = (r0 + 1).min(self.size - 1);
        let g1 = (g0 + 1).min(self.size - 1);
        let b1 = (b0 + 1).min(self.size - 1);

        let rf = r_idx.fract();
        let gf = g_idx.fract();
        let bf = b_idx.fract();

        let get = |r: usize, g: usize, b: usize| -> (f32, f32, f32) {
            self.data[r + g * self.size + b * self.size * self.size]
        };

        let c000 = get(r0, g0, b0);
        let c100 = get(r1, g0, b0);
        let c010 = get(r0, g1, b0);
        let c110 = get(r1, g1, b0);
        let c001 = get(r0, g0, b1);
        let c101 = get(r1, g0, b1);
        let c011 = get(r0, g1, b1);
        let c111 = get(r1, g1, b1);

        let lerp3 = |a: (f32, f32, f32), b: (f32, f32, f32), t: f32| -> (f32, f32, f32) {
            (a.0 + (b.0 - a.0) * t, a.1 + (b.1 - a.1) * t, a.2 + (b.2 - a.2) * t)
        };

        let c00 = lerp3(c000, c100, rf);
        let c01 = lerp3(c001, c101, rf);
        let c10 = lerp3(c010, c110, rf);
        let c11 = lerp3(c011, c111, rf);
        let c0 = lerp3(c00, c10, gf);
        let c1 = lerp3(c01, c11, gf);

        lerp3(c0, c1, bf)
    }

    pub fn export_cube(&self) -> String {
        let mut output = String::new();
        output.push_str(&format!("TITLE \"{}\"\n", self.title));
        output.push_str(&format!("LUT_3D_SIZE {}\n", self.size));
        output.push_str("\n");

        for b in 0..self.size {
            for g in 0..self.size {
                for r in 0..self.size {
                    let idx = r + g * self.size + b * self.size * self.size;
                    let (rv, gv, bv) = self.data[idx];
                    output.push_str(&format!("{:.6} {:.6} {:.6}\n", rv, gv, bv));
                }
            }
        }

        output
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE IMPACT ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct PerformanceProfile {
    pub preset_id: String,
    pub estimated_fps_impact: f32,
    pub gpu_cost: GPUCost,
    pub memory_usage_mb: f32,
    pub shader_passes: u32,
    pub texture_samples: u32,
}

#[derive(Debug, Clone, Copy)]
pub enum GPUCost {
    Minimal,    // < 1% GPU
    Low,        // 1-3% GPU
    Medium,     // 3-8% GPU
    High,       // 8-15% GPU
    VeryHigh,   // > 15% GPU
}

pub struct PerformanceAnalyzer {
    pub baseline_fps: f32,
    pub gpu_headroom: f32,
    pub benchmarks: HashMap<String, PerformanceProfile>,
}

impl PerformanceAnalyzer {
    pub fn new(baseline_fps: f32) -> Self {
        PerformanceAnalyzer {
            baseline_fps,
            gpu_headroom: 1.0,
            benchmarks: HashMap::new(),
        }
    }

    pub fn analyze_preset(&self, preset: &NovaPreset) -> PerformanceProfile {
        let mut passes = 1; // Base pass
        let mut samples = 0;
        let mut cost_score = 0.0;

        // Bloom cost
        if preset.effects.bloom_intensity > 0.0 {
            passes += 2; // Downsample + upsample
            samples += 8;
            cost_score += preset.effects.bloom_intensity * 3.0;
        }

        // Vignette (cheap)
        if preset.effects.vignette_intensity > 0.0 {
            cost_score += 0.1;
        }

        // Sharpening
        if preset.effects.sharpening > 0.0 {
            passes += 1;
            samples += 4;
            cost_score += preset.effects.sharpening * 0.5;
        }

        // Color grading (moderate)
        cost_score += 0.5; // LUT lookup

        let fps_impact = cost_score * 2.0;
        let gpu_cost = match cost_score {
            x if x < 0.5 => GPUCost::Minimal,
            x if x < 1.5 => GPUCost::Low,
            x if x < 3.0 => GPUCost::Medium,
            x if x < 5.0 => GPUCost::High,
            _ => GPUCost::VeryHigh,
        };

        PerformanceProfile {
            preset_id: preset.metadata.id.clone(),
            estimated_fps_impact: fps_impact,
            gpu_cost,
            memory_usage_mb: (passes * 4) as f32, // Rough estimate
            shader_passes: passes,
            texture_samples: samples,
        }
    }

    pub fn compare_presets(&self, a: &NovaPreset, b: &NovaPreset) -> String {
        let prof_a = self.analyze_preset(a);
        let prof_b = self.analyze_preset(b);

        let fps_diff = prof_b.estimated_fps_impact - prof_a.estimated_fps_impact;
        let pass_diff = prof_b.shader_passes as i32 - prof_a.shader_passes as i32;

        format!(
            "{} vs {}: FPS impact diff: {:.1}, Pass diff: {}",
            a.metadata.name, b.metadata.name, fps_diff, pass_diff
        )
    }

    pub fn suggest_optimizations(&self, preset: &NovaPreset) -> Vec<String> {
        let mut suggestions = Vec::new();

        if preset.effects.bloom_intensity > 0.5 {
            suggestions.push("Reduce bloom intensity to improve performance".to_string());
        }
        if preset.effects.sharpening > 0.8 {
            suggestions.push("High sharpening adds overhead - consider reducing".to_string());
        }
        if preset.color.saturation > 1.5 || preset.color.saturation < 0.5 {
            suggestions.push("Extreme saturation values may cause banding".to_string());
        }

        suggestions
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCREENSHOT COMPARISON
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct Screenshot {
    pub width: u32,
    pub height: u32,
    pub data: Vec<u8>, // RGBA
    pub preset_id: Option<String>,
    pub timestamp: u64,
    pub metadata: ScreenshotMetadata,
}

#[derive(Debug, Clone)]
pub struct ScreenshotMetadata {
    pub game_name: String,
    pub scene_description: String,
    pub capture_settings: CaptureSettings,
}

#[derive(Debug, Clone)]
pub struct CaptureSettings {
    pub format: ImageFormat,
    pub quality: u8,
    pub include_ui: bool,
    pub auto_name: bool,
}

#[derive(Debug, Clone, Copy)]
pub enum ImageFormat {
    PNG,
    JPEG,
    WebP,
    BMP,
    TGA,
}

pub struct ScreenshotComparer {
    pub reference: Option<Screenshot>,
    pub comparison_mode: ComparisonMode,
    pub difference_threshold: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum ComparisonMode {
    SideBySide,
    Overlay,
    Difference,
    SplitScreen,
    Toggle,
}

impl ScreenshotComparer {
    pub fn new() -> Self {
        ScreenshotComparer {
            reference: None,
            comparison_mode: ComparisonMode::SideBySide,
            difference_threshold: 0.01,
        }
    }

    pub fn set_reference(&mut self, screenshot: Screenshot) {
        self.reference = Some(screenshot);
    }

    pub fn compute_difference(&self, a: &Screenshot, b: &Screenshot) -> DifferenceResult {
        if a.width != b.width || a.height != b.height {
            return DifferenceResult {
                mean_difference: 1.0,
                max_difference: 1.0,
                psnr: 0.0,
                ssim: 0.0,
                histogram_diff: 1.0,
            };
        }

        let pixel_count = (a.width * a.height) as f32;
        let mut total_diff = 0.0;
        let mut max_diff: f32 = 0.0;
        let mut mse = 0.0;

        for i in 0..a.data.len() {
            let diff = (a.data[i] as f32 - b.data[i] as f32).abs() / 255.0;
            total_diff += diff;
            max_diff = max_diff.max(diff);
            mse += diff * diff;
        }

        let channels = a.data.len() as f32 / pixel_count;
        mse /= pixel_count * channels;

        let psnr = if mse > 0.0 { 10.0 * (1.0 / mse).log10() } else { 100.0 };

        DifferenceResult {
            mean_difference: total_diff / (pixel_count * channels),
            max_difference: max_diff,
            psnr,
            ssim: 1.0 - (total_diff / (pixel_count * channels)), // Simplified SSIM
            histogram_diff: 0.0, // TODO: Implement histogram comparison
        }
    }

    pub fn generate_diff_image(&self, a: &Screenshot, b: &Screenshot) -> Screenshot {
        let mut diff = Screenshot {
            width: a.width,
            height: a.height,
            data: vec![0; a.data.len()],
            preset_id: None,
            timestamp: 0,
            metadata: ScreenshotMetadata {
                game_name: String::new(),
                scene_description: "Difference image".to_string(),
                capture_settings: CaptureSettings {
                    format: ImageFormat::PNG,
                    quality: 100,
                    include_ui: false,
                    auto_name: true,
                },
            },
        };

        for i in 0..a.data.len() {
            let d = ((a.data[i] as i32 - b.data[i] as i32).abs() * 4).min(255) as u8;
            diff.data[i] = if i % 4 == 3 { 255 } else { d };
        }

        diff
    }
}

#[derive(Debug, Clone)]
pub struct DifferenceResult {
    pub mean_difference: f32,
    pub max_difference: f32,
    pub psnr: f32,
    pub ssim: f32,
    pub histogram_diff: f32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTO-TUNING WITH ML
// ═══════════════════════════════════════════════════════════════════════════════

pub struct AutoTuner {
    pub target_style: VisualStyle,
    pub learning_rate: f32,
    pub history: Vec<TuningStep>,
    pub constraints: TuningConstraints,
}

#[derive(Debug, Clone, Copy)]
pub enum VisualStyle {
    Cinematic,
    Vibrant,
    Natural,
    Moody,
    Vintage,
    Custom,
}

#[derive(Debug, Clone)]
pub struct TuningStep {
    pub preset: NovaPreset,
    pub score: f32,
    pub user_feedback: Option<f32>,
}

#[derive(Debug, Clone)]
pub struct TuningConstraints {
    pub min_exposure: f32,
    pub max_exposure: f32,
    pub min_contrast: f32,
    pub max_contrast: f32,
    pub preserve_highlights: bool,
    pub preserve_shadows: bool,
}

impl AutoTuner {
    pub fn new(style: VisualStyle) -> Self {
        AutoTuner {
            target_style: style,
            learning_rate: 0.1,
            history: Vec::new(),
            constraints: TuningConstraints {
                min_exposure: -2.0,
                max_exposure: 2.0,
                min_contrast: 0.5,
                max_contrast: 2.0,
                preserve_highlights: true,
                preserve_shadows: true,
            },
        }
    }

    pub fn auto_adjust(&self, preset: &NovaPreset, image_stats: &ImageStatistics) -> NovaPreset {
        let mut adjusted = preset.clone();

        // Adjust exposure based on image brightness
        if image_stats.mean_luminance < 0.3 {
            adjusted.color.exposure += 0.3;
        } else if image_stats.mean_luminance > 0.7 {
            adjusted.color.exposure -= 0.2;
        }

        // Adjust contrast based on image dynamic range
        if image_stats.dynamic_range < 0.5 {
            adjusted.color.contrast *= 1.1;
        }

        // Adjust saturation based on color variance
        if image_stats.color_variance < 0.1 {
            adjusted.color.saturation *= 1.15;
        }

        // Apply style-specific adjustments
        match self.target_style {
            VisualStyle::Cinematic => {
                adjusted.color.contrast *= 1.1;
                adjusted.effects.vignette_intensity = 0.3;
            }
            VisualStyle::Vibrant => {
                adjusted.color.saturation *= 1.2;
                adjusted.effects.bloom_intensity *= 1.1;
            }
            VisualStyle::Natural => {
                // Keep adjustments minimal
            }
            VisualStyle::Moody => {
                adjusted.color.exposure -= 0.2;
                adjusted.color.contrast *= 1.15;
            }
            VisualStyle::Vintage => {
                adjusted.color.saturation *= 0.85;
                adjusted.color.temperature += 0.15;
            }
            VisualStyle::Custom => {}
        }

        self.apply_constraints(&mut adjusted);
        adjusted
    }

    fn apply_constraints(&self, preset: &mut NovaPreset) {
        preset.color.exposure = preset.color.exposure
            .clamp(self.constraints.min_exposure, self.constraints.max_exposure);
        preset.color.contrast = preset.color.contrast
            .clamp(self.constraints.min_contrast, self.constraints.max_contrast);
    }

    pub fn optimize(&mut self, preset: &NovaPreset, target: &ImageStatistics, iterations: usize) -> NovaPreset {
        let mut best = preset.clone();
        let mut best_score = 0.0;

        for _ in 0..iterations {
            let candidate = self.mutate(&best);
            let score = self.evaluate(&candidate, target);

            if score > best_score {
                best = candidate;
                best_score = score;
            }

            self.history.push(TuningStep {
                preset: best.clone(),
                score: best_score,
                user_feedback: None,
            });
        }

        best
    }

    fn mutate(&self, preset: &NovaPreset) -> NovaPreset {
        let mut mutated = preset.clone();

        // Random small mutations
        let mutation = (rand_f32() - 0.5) * self.learning_rate;

        match (rand_f32() * 5.0) as u32 {
            0 => mutated.color.exposure += mutation,
            1 => mutated.color.contrast += mutation * 0.2,
            2 => mutated.color.saturation += mutation * 0.3,
            3 => mutated.color.temperature += mutation * 0.5,
            _ => mutated.effects.bloom_intensity += mutation.abs() * 0.1,
        }

        self.apply_constraints(&mut mutated);
        mutated
    }

    fn evaluate(&self, preset: &NovaPreset, target: &ImageStatistics) -> f32 {
        // Score based on how well preset matches target statistics
        let exposure_score = 1.0 - (preset.color.exposure - target.ideal_exposure).abs();
        let contrast_score = 1.0 - (preset.color.contrast - target.ideal_contrast).abs() * 0.5;

        (exposure_score + contrast_score) / 2.0
    }
}

#[derive(Debug, Clone)]
pub struct ImageStatistics {
    pub mean_luminance: f32,
    pub dynamic_range: f32,
    pub color_variance: f32,
    pub highlight_percentage: f32,
    pub shadow_percentage: f32,
    pub ideal_exposure: f32,
    pub ideal_contrast: f32,
}

fn rand_f32() -> f32 {
    // Simplified random - in real implementation would use proper RNG
    use std::time::{SystemTime, UNIX_EPOCH};
    let nanos = SystemTime::now().duration_since(UNIX_EPOCH)
        .unwrap_or_default().subsec_nanos();
    (nanos % 1000) as f32 / 1000.0
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCENE DETECTION & AUTO-SWITCHING
// ═══════════════════════════════════════════════════════════════════════════════

/// Scene type classification
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum SceneType {
    Outdoor,
    Indoor,
    Night,
    Sunset,
    Underwater,
    Space,
    Forest,
    Urban,
    Desert,
    Snow,
    Fog,
    Rain,
    Action,
    Dialogue,
    Cutscene,
    Menu,
}

/// Scene detection using frame analysis
pub struct SceneDetector {
    history: Vec<SceneType>,
    history_size: usize,
    confidence_threshold: f32,
    scene_presets: HashMap<SceneType, String>,
}

impl SceneDetector {
    pub fn new() -> Self {
        let mut scene_presets = HashMap::new();
        scene_presets.insert(SceneType::Night, "cinematic_noir".to_string());
        scene_presets.insert(SceneType::Sunset, "cinematic_golden_hour".to_string());
        scene_presets.insert(SceneType::Underwater, "cinematic_teal".to_string());
        scene_presets.insert(SceneType::Snow, "cinematic_cool".to_string());
        scene_presets.insert(SceneType::Forest, "cinematic_natural".to_string());

        Self {
            history: Vec::new(),
            history_size: 30,
            confidence_threshold: 0.7,
            scene_presets,
        }
    }

    /// Analyze frame and detect scene type
    pub fn analyze_frame(&mut self, stats: &FrameStatistics) -> SceneClassification {
        let mut scores: HashMap<SceneType, f32> = HashMap::new();

        // Luminance-based detection
        if stats.mean_luminance < 0.15 {
            *scores.entry(SceneType::Night).or_insert(0.0) += 0.8;
        } else if stats.mean_luminance > 0.7 {
            *scores.entry(SceneType::Outdoor).or_insert(0.0) += 0.5;
        }

        // Color temperature detection
        if stats.color_temperature > 5500.0 {
            *scores.entry(SceneType::Snow).or_insert(0.0) += 0.4;
            *scores.entry(SceneType::Indoor).or_insert(0.0) += 0.3;
        } else if stats.color_temperature < 4000.0 {
            *scores.entry(SceneType::Sunset).or_insert(0.0) += 0.6;
        }

        // Dominant hue detection
        match stats.dominant_hue {
            0..=30 | 330..=360 => *scores.entry(SceneType::Sunset).or_insert(0.0) += 0.4,
            90..=150 => *scores.entry(SceneType::Forest).or_insert(0.0) += 0.5,
            180..=220 => *scores.entry(SceneType::Underwater).or_insert(0.0) += 0.3,
            _ => {}
        }

        // Motion detection
        if stats.motion_vectors > 100.0 {
            *scores.entry(SceneType::Action).or_insert(0.0) += 0.6;
        } else if stats.motion_vectors < 5.0 {
            *scores.entry(SceneType::Dialogue).or_insert(0.0) += 0.4;
        }

        // Fog/haze detection
        if stats.contrast < 0.3 && stats.saturation < 0.3 {
            *scores.entry(SceneType::Fog).or_insert(0.0) += 0.7;
        }

        let (scene_type, confidence) = scores.iter()
            .max_by(|a, b| a.1.partial_cmp(b.1).unwrap())
            .map(|(&t, &c)| (t, c))
            .unwrap_or((SceneType::Outdoor, 0.0));

        self.history.push(scene_type);
        if self.history.len() > self.history_size {
            self.history.remove(0);
        }

        SceneClassification {
            scene_type,
            confidence,
            recommended_preset: self.scene_presets.get(&scene_type).cloned(),
        }
    }

    /// Get smoothed scene type from history
    pub fn get_stable_scene(&self) -> Option<SceneType> {
        if self.history.len() < 10 {
            return None;
        }

        let mut counts: HashMap<SceneType, usize> = HashMap::new();
        for scene in &self.history[self.history.len()-10..] {
            *counts.entry(*scene).or_insert(0) += 1;
        }

        counts.into_iter()
            .max_by_key(|(_, count)| *count)
            .filter(|(_, count)| *count >= 7)
            .map(|(scene, _)| scene)
    }
}

#[derive(Debug, Clone)]
pub struct FrameStatistics {
    pub mean_luminance: f32,
    pub contrast: f32,
    pub saturation: f32,
    pub color_temperature: f32,
    pub dominant_hue: u16,
    pub motion_vectors: f32,
    pub depth_complexity: f32,
}

#[derive(Debug, Clone)]
pub struct SceneClassification {
    pub scene_type: SceneType,
    pub confidence: f32,
    pub recommended_preset: Option<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET RECOMMENDATION ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

/// ML-based preset recommendation
pub struct EnginePresetRecommender {
    user_preferences: UserPreferenceModel,
    content_analyzer: ContentAnalyzer,
    collaborative_filter: CollaborativeFilter,
}

#[derive(Debug, Clone)]
pub struct UserPreferenceModel {
    favorite_categories: HashMap<PresetCategory, f32>,
    color_preferences: ColorPreferences,
    usage_history: Vec<PresetUsage>,
    time_of_day_preferences: HashMap<u8, String>,
}

#[derive(Debug, Clone)]
pub struct ColorPreferences {
    preferred_temperature: f32,
    preferred_saturation: f32,
    preferred_contrast: f32,
    warm_bias: f32,
}

#[derive(Debug, Clone)]
pub struct PresetUsage {
    preset_name: String,
    duration_seconds: u64,
    rating: Option<u8>,
    scene_context: Option<SceneType>,
    timestamp: u64,
}

#[derive(Debug, Clone)]
pub struct ContentAnalyzer {
    scene_history: Vec<SceneType>,
    genre_weights: HashMap<String, f32>,
}

#[derive(Debug, Clone)]
pub struct CollaborativeFilter {
    user_similarities: HashMap<String, f32>,
    preset_ratings: HashMap<String, Vec<(String, f32)>>,
}

impl EnginePresetRecommender {
    pub fn new() -> Self {
        Self {
            user_preferences: UserPreferenceModel {
                favorite_categories: HashMap::new(),
                color_preferences: ColorPreferences {
                    preferred_temperature: 0.0,
                    preferred_saturation: 1.0,
                    preferred_contrast: 1.0,
                    warm_bias: 0.0,
                },
                usage_history: Vec::new(),
                time_of_day_preferences: HashMap::new(),
            },
            content_analyzer: ContentAnalyzer {
                scene_history: Vec::new(),
                genre_weights: HashMap::new(),
            },
            collaborative_filter: CollaborativeFilter {
                user_similarities: HashMap::new(),
                preset_ratings: HashMap::new(),
            },
        }
    }

    /// Record preset usage for learning
    pub fn record_usage(&mut self, preset: &str, duration: u64, rating: Option<u8>, scene: Option<SceneType>) {
        self.user_preferences.usage_history.push(PresetUsage {
            preset_name: preset.to_string(),
            duration_seconds: duration,
            rating,
            scene_context: scene,
            timestamp: std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap_or_default()
                .as_secs(),
        });

        // Update category preferences
        if duration > 60 {
            // Long usage indicates preference
            if let Some(category) = self.get_preset_category(preset) {
                *self.user_preferences.favorite_categories.entry(category).or_insert(0.0) += 0.1;
            }
        }
    }

    fn get_preset_category(&self, _preset: &str) -> Option<PresetCategory> {
        Some(PresetCategory::Cinematic)
    }

    /// Get personalized recommendations
    pub fn recommend(&self, context: &RecommendationContext) -> Vec<PresetRecommendation> {
        let mut recommendations = Vec::new();

        // Content-based recommendations
        let content_recs = self.content_based_recommend(context);
        recommendations.extend(content_recs);

        // Collaborative filtering recommendations
        let collab_recs = self.collaborative_recommend();
        recommendations.extend(collab_recs);

        // Time-based recommendations
        if let Some(time_preset) = self.user_preferences.time_of_day_preferences.get(&context.hour_of_day) {
            recommendations.push(PresetRecommendation {
                preset_name: time_preset.clone(),
                confidence: 0.6,
                reason: RecommendationReason::TimeOfDay,
            });
        }

        // Sort by confidence and deduplicate
        recommendations.sort_by(|a, b| b.confidence.partial_cmp(&a.confidence).unwrap());
        recommendations.dedup_by(|a, b| a.preset_name == b.preset_name);

        recommendations.into_iter().take(5).collect()
    }

    fn content_based_recommend(&self, context: &RecommendationContext) -> Vec<PresetRecommendation> {
        let mut recs = Vec::new();

        // Recommend based on scene type
        if let Some(scene) = context.current_scene {
            let preset_name = match scene {
                SceneType::Night => "cinematic_noir",
                SceneType::Sunset => "cinematic_golden_hour",
                SceneType::Snow => "cinematic_cool",
                SceneType::Forest => "cinematic_natural",
                SceneType::Action => "cinematic_blockbuster",
                _ => "cinematic_balanced",
            };

            recs.push(PresetRecommendation {
                preset_name: preset_name.to_string(),
                confidence: 0.8,
                reason: RecommendationReason::SceneMatch,
            });
        }

        recs
    }

    fn collaborative_recommend(&self) -> Vec<PresetRecommendation> {
        // Find similar users and recommend their favorites
        let mut recs = Vec::new();

        for (user, similarity) in &self.collaborative_filter.user_similarities {
            if *similarity > 0.7 {
                if let Some(ratings) = self.collaborative_filter.preset_ratings.get(user) {
                    for (preset, rating) in ratings {
                        if *rating > 4.0 {
                            recs.push(PresetRecommendation {
                                preset_name: preset.clone(),
                                confidence: similarity * rating / 5.0,
                                reason: RecommendationReason::SimilarUsers,
                            });
                        }
                    }
                }
            }
        }

        recs
    }
}

#[derive(Debug, Clone)]
pub struct RecommendationContext {
    pub current_scene: Option<SceneType>,
    pub game_genre: Option<String>,
    pub hour_of_day: u8,
    pub display_type: DisplayType,
    pub performance_tier: PerformanceTier,
}

#[derive(Debug, Clone)]
pub struct PresetRecommendation {
    pub preset_name: String,
    pub confidence: f32,
    pub reason: RecommendationReason,
}

#[derive(Debug, Clone, Copy)]
pub enum RecommendationReason {
    SceneMatch,
    UserHistory,
    SimilarUsers,
    TimeOfDay,
    GenreMatch,
    PopularChoice,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VERSION CONTROL
// ═══════════════════════════════════════════════════════════════════════════════

/// Version control for preset modifications
pub struct PresetVersionControl {
    presets: HashMap<String, VersionedPreset>,
    branches: HashMap<String, String>,
    current_branch: String,
}

#[derive(Debug, Clone)]
pub struct VCSVersionedPreset {
    name: String,
    versions: Vec<PresetVersion>,
    current_version: usize,
}

#[derive(Debug, Clone)]
pub struct VCSPresetVersion {
    version_id: u64,
    preset: NovaPreset,
    message: String,
    timestamp: u64,
    parent_version: Option<u64>,
    tags: Vec<String>,
}

impl VCSPresetVersionControl {
    pub fn new() -> Self {
        Self {
            presets: HashMap::new(),
            branches: HashMap::new(),
            current_branch: "main".to_string(),
        }
    }

    /// Create initial version of preset
    pub fn init(&mut self, name: &str, preset: NovaPreset) {
        let version = VCSPresetVersion {
            version_id: 1,
            preset,
            message: "Initial version".to_string(),
            timestamp: Self::now(),
            parent_version: None,
            tags: Vec::new(),
        };

        self.presets.insert(name.to_string(), VersionedPreset {
            name: name.to_string(),
            versions: vec![version],
            current_version: 0,
        });
    }

    /// Commit changes to preset
    pub fn commit(&mut self, name: &str, preset: NovaPreset, message: &str) -> Result<u64, String> {
        let versioned = self.presets.get_mut(name)
            .ok_or_else(|| "Preset not found".to_string())?;

        let version_id = versioned.versions.len() as u64 + 1;
        let parent = versioned.versions.last().map(|v| v.version_id);

        versioned.versions.push(VCSPresetVersion {
            version_id,
            preset,
            message: message.to_string(),
            timestamp: Self::now(),
            parent_version: parent,
            tags: Vec::new(),
        });

        versioned.current_version = versioned.versions.len() - 1;
        Ok(version_id)
    }

    /// Checkout specific version
    pub fn checkout(&mut self, name: &str, version_id: u64) -> Result<&NovaPreset, String> {
        let versioned = self.presets.get_mut(name)
            .ok_or_else(|| "Preset not found".to_string())?;

        let idx = versioned.versions.iter()
            .position(|v| v.version_id == version_id)
            .ok_or_else(|| "Version not found".to_string())?;

        versioned.current_version = idx;
        Ok(&versioned.versions[idx].preset)
    }

    /// Get version history
    pub fn log(&self, name: &str) -> Option<Vec<&VCSPresetVersion>> {
        self.presets.get(name)
            .map(|v| v.versions.iter().rev().collect())
    }

    /// Tag a version
    pub fn tag(&mut self, name: &str, version_id: u64, tag: &str) -> Result<(), String> {
        let versioned = self.presets.get_mut(name)
            .ok_or_else(|| "Preset not found".to_string())?;

        let version = versioned.versions.iter_mut()
            .find(|v| v.version_id == version_id)
            .ok_or_else(|| "Version not found".to_string())?;

        version.tags.push(tag.to_string());
        Ok(())
    }

    /// Diff two versions
    pub fn diff(&self, name: &str, v1: u64, v2: u64) -> Option<PresetDiff> {
        let versioned = self.presets.get(name)?;

        let preset1 = versioned.versions.iter().find(|v| v.version_id == v1)?;
        let preset2 = versioned.versions.iter().find(|v| v.version_id == v2)?;

        Some(PresetDiff {
            exposure_delta: preset2.preset.color.exposure - preset1.preset.color.exposure,
            contrast_delta: preset2.preset.color.contrast - preset1.preset.color.contrast,
            saturation_delta: preset2.preset.color.saturation - preset1.preset.color.saturation,
            temperature_delta: preset2.preset.color.temperature - preset1.preset.color.temperature,
        })
    }

    /// Revert to previous version
    pub fn revert(&mut self, name: &str) -> Result<u64, String> {
        let versioned = self.presets.get_mut(name)
            .ok_or_else(|| "Preset not found".to_string())?;

        if versioned.current_version == 0 {
            return Err("Already at initial version".to_string());
        }

        versioned.current_version -= 1;
        Ok(versioned.versions[versioned.current_version].version_id)
    }

    fn now() -> u64 {
        std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap_or_default()
            .as_secs()
    }
}

#[derive(Debug, Clone)]
pub struct VCSPresetDiff {
    pub exposure_delta: f32,
    pub contrast_delta: f32,
    pub saturation_delta: f32,
    pub temperature_delta: f32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET EXPORT/IMPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Cross-platform preset serialization
pub struct PresetSerializer {
    format: SerializationFormat,
    compression: CompressionType,
}

#[derive(Debug, Clone, Copy)]
pub enum SerializationFormat {
    NovaJson,
    NovaBinary,
    LUT3D,
    Cube,
    ICC,
    ACES,
}

#[derive(Debug, Clone, Copy)]
pub enum CompressionType {
    None,
    Zstd,
    Lz4,
    Gzip,
}

impl PresetSerializer {
    pub fn new(format: SerializationFormat) -> Self {
        Self {
            format,
            compression: CompressionType::Zstd,
        }
    }

    /// Export preset to bytes
    pub fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
        let data = match self.format {
            SerializationFormat::NovaJson => self.to_json(preset)?,
            SerializationFormat::NovaBinary => self.to_binary(preset)?,
            SerializationFormat::LUT3D => self.to_lut3d(preset)?,
            SerializationFormat::Cube => self.to_cube(preset)?,
            SerializationFormat::ICC => self.to_icc(preset)?,
            SerializationFormat::ACES => self.to_aces(preset)?,
        };

        self.compress(&data)
    }

    /// Import preset from bytes
    pub fn import(&self, data: &[u8]) -> Result<NovaPreset, String> {
        let decompressed = self.decompress(data)?;

        match self.format {
            SerializationFormat::NovaJson => self.from_json(&decompressed),
            SerializationFormat::NovaBinary => self.from_binary(&decompressed),
            SerializationFormat::LUT3D => self.from_lut3d(&decompressed),
            SerializationFormat::Cube => self.from_cube(&decompressed),
            SerializationFormat::ICC => self.from_icc(&decompressed),
            SerializationFormat::ACES => self.from_aces(&decompressed),
        }
    }

    fn to_json(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
        let mut json = String::new();
        json.push_str("{\n");
        json.push_str(&format!("  \"name\": \"{}\",\n", preset.metadata.name));
        json.push_str(&format!("  \"version\": \"{}\",\n", preset.metadata.version));
        json.push_str("  \"color\": {\n");
        json.push_str(&format!("    \"exposure\": {},\n", preset.color.exposure));
        json.push_str(&format!("    \"contrast\": {},\n", preset.color.contrast));
        json.push_str(&format!("    \"saturation\": {},\n", preset.color.saturation));
        json.push_str(&format!("    \"temperature\": {}\n", preset.color.temperature));
        json.push_str("  }\n");
        json.push_str("}\n");
        Ok(json.into_bytes())
    }

    fn from_json(&self, _data: &[u8]) -> Result<NovaPreset, String> {
        // Parse JSON and construct preset
        Err("JSON parsing not implemented".to_string())
    }

    fn to_binary(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
        let mut bytes = Vec::new();

        // Magic bytes
        bytes.extend_from_slice(b"NOVA");

        // Version
        bytes.push(1);

        // Color settings (f32 each)
        bytes.extend_from_slice(&preset.color.exposure.to_le_bytes());
        bytes.extend_from_slice(&preset.color.contrast.to_le_bytes());
        bytes.extend_from_slice(&preset.color.saturation.to_le_bytes());
        bytes.extend_from_slice(&preset.color.temperature.to_le_bytes());

        Ok(bytes)
    }

    fn from_binary(&self, data: &[u8]) -> Result<NovaPreset, String> {
        if data.len() < 21 || &data[0..4] != b"NOVA" {
            return Err("Invalid Nova binary format".to_string());
        }

        let mut preset = NovaPreset::default();
        preset.color.exposure = f32::from_le_bytes([data[5], data[6], data[7], data[8]]);
        preset.color.contrast = f32::from_le_bytes([data[9], data[10], data[11], data[12]]);
        preset.color.saturation = f32::from_le_bytes([data[13], data[14], data[15], data[16]]);
        preset.color.temperature = f32::from_le_bytes([data[17], data[18], data[19], data[20]]);

        Ok(preset)
    }

    fn to_lut3d(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
        // Generate 3D LUT from preset color settings
        let size: usize = 33;
        let mut lut = Vec::with_capacity(size * size * size * 3);

        for b in 0..size {
            for g in 0..size {
                for r in 0..size {
                    let rf = r as f32 / (size - 1) as f32;
                    let gf = g as f32 / (size - 1) as f32;
                    let bf = b as f32 / (size - 1) as f32;

                    let (ro, go, bo) = self.apply_color_transform(rf, gf, bf, preset);

                    lut.push((ro * 255.0) as u8);
                    lut.push((go * 255.0) as u8);
                    lut.push((bo * 255.0) as u8);
                }
            }
        }

        Ok(lut)
    }

    fn from_lut3d(&self, _data: &[u8]) -> Result<NovaPreset, String> {
        Err("LUT3D import not implemented".to_string())
    }

    fn to_cube(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
        let mut cube = String::new();
        cube.push_str("# Nova Preset Export\n");
        cube.push_str(&format!("TITLE \"{}\"\n", preset.metadata.name));
        cube.push_str("LUT_3D_SIZE 33\n");
        cube.push_str("DOMAIN_MIN 0.0 0.0 0.0\n");
        cube.push_str("DOMAIN_MAX 1.0 1.0 1.0\n\n");

        let size: usize = 33;
        for b in 0..size {
            for g in 0..size {
                for r in 0..size {
                    let rf = r as f32 / (size - 1) as f32;
                    let gf = g as f32 / (size - 1) as f32;
                    let bf = b as f32 / (size - 1) as f32;

                    let (ro, go, bo) = self.apply_color_transform(rf, gf, bf, preset);
                    cube.push_str(&format!("{:.6} {:.6} {:.6}\n", ro, go, bo));
                }
            }
        }

        Ok(cube.into_bytes())
    }

    fn from_cube(&self, _data: &[u8]) -> Result<NovaPreset, String> {
        Err("CUBE import not implemented".to_string())
    }

    fn to_icc(&self, _preset: &NovaPreset) -> Result<Vec<u8>, String> {
        // ICC profile generation
        let mut icc = Vec::new();

        // ICC header (128 bytes)
        icc.resize(128, 0);

        // Profile size (placeholder)
        icc[0..4].copy_from_slice(&(128u32 + 100).to_be_bytes());

        // CMM Type
        icc[4..8].copy_from_slice(b"NOVA");

        // Profile version (4.3)
        icc[8] = 4;
        icc[9] = 0x30;

        // Profile class (display)
        icc[12..16].copy_from_slice(b"mntr");

        // Color space (RGB)
        icc[16..20].copy_from_slice(b"RGB ");

        // PCS (XYZ)
        icc[20..24].copy_from_slice(b"XYZ ");

        Ok(icc)
    }

    fn from_icc(&self, _data: &[u8]) -> Result<NovaPreset, String> {
        Err("ICC import not implemented".to_string())
    }

    fn to_aces(&self, _preset: &NovaPreset) -> Result<Vec<u8>, String> {
        // ACES CTL generation
        let ctl = r#"
// ACES Color Transform Language
// Generated by Nova

import "ACESlib.Utilities";
import "ACESlib.Transform_Common";

void main
(
    input varying float rIn,
    input varying float gIn,
    input varying float bIn,
    output varying float rOut,
    output varying float gOut,
    output varying float bOut
)
{
    rOut = rIn;
    gOut = gIn;
    bOut = bIn;
}
"#;
        Ok(ctl.as_bytes().to_vec())
    }

    fn from_aces(&self, _data: &[u8]) -> Result<NovaPreset, String> {
        Err("ACES import not implemented".to_string())
    }

    fn apply_color_transform(&self, r: f32, g: f32, b: f32, preset: &NovaPreset) -> (f32, f32, f32) {
        // Apply exposure
        let exposure_mult = 2.0_f32.powf(preset.color.exposure);
        let r = r * exposure_mult;
        let g = g * exposure_mult;
        let b = b * exposure_mult;

        // Apply contrast
        let r = ((r - 0.5) * preset.color.contrast + 0.5).max(0.0).min(1.0);
        let g = ((g - 0.5) * preset.color.contrast + 0.5).max(0.0).min(1.0);
        let b = ((b - 0.5) * preset.color.contrast + 0.5).max(0.0).min(1.0);

        // Apply saturation
        let luma = 0.2126 * r + 0.7152 * g + 0.0722 * b;
        let r = luma + (r - luma) * preset.color.saturation;
        let g = luma + (g - luma) * preset.color.saturation;
        let b = luma + (b - luma) * preset.color.saturation;

        (r.max(0.0).min(1.0), g.max(0.0).min(1.0), b.max(0.0).min(1.0))
    }

    fn compress(&self, data: &[u8]) -> Result<Vec<u8>, String> {
        match self.compression {
            CompressionType::None => Ok(data.to_vec()),
            CompressionType::Zstd => {
                // Simplified Zstd-like compression header
                let mut compressed = Vec::new();
                compressed.extend_from_slice(&[0x28, 0xB5, 0x2F, 0xFD]); // Zstd magic
                compressed.extend_from_slice(&(data.len() as u32).to_le_bytes());
                compressed.extend_from_slice(data);
                Ok(compressed)
            },
            CompressionType::Lz4 => {
                let mut compressed = Vec::new();
                compressed.extend_from_slice(&[0x04, 0x22, 0x4D, 0x18]); // LZ4 magic
                compressed.extend_from_slice(data);
                Ok(compressed)
            },
            CompressionType::Gzip => {
                let mut compressed = Vec::new();
                compressed.extend_from_slice(&[0x1F, 0x8B]); // Gzip magic
                compressed.extend_from_slice(data);
                Ok(compressed)
            },
        }
    }

    fn decompress(&self, data: &[u8]) -> Result<Vec<u8>, String> {
        if data.len() < 4 {
            return Err("Data too short".to_string());
        }

        // Detect format by magic bytes
        match &data[0..4] {
            [0x28, 0xB5, 0x2F, 0xFD] => {
                // Zstd
                let len = u32::from_le_bytes([data[4], data[5], data[6], data[7]]) as usize;
                Ok(data[8..8+len].to_vec())
            },
            [0x04, 0x22, 0x4D, 0x18] => {
                // LZ4
                Ok(data[4..].to_vec())
            },
            [0x1F, 0x8B, ..] => {
                // Gzip
                Ok(data[2..].to_vec())
            },
            _ => Ok(data.to_vec()),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET SHARING NETWORK
// ═══════════════════════════════════════════════════════════════════════════════

/// Community preset sharing
pub struct PresetCloud {
    local_cache: HashMap<String, CachedPreset>,
    pending_uploads: Vec<PendingUpload>,
    subscriptions: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct CachedPreset {
    preset: NovaPreset,
    author: String,
    downloads: u64,
    rating: f32,
    tags: Vec<String>,
    last_updated: u64,
}

#[derive(Debug, Clone)]
pub struct PendingUpload {
    preset: NovaPreset,
    description: String,
    tags: Vec<String>,
}

impl PresetCloud {
    pub fn new() -> Self {
        Self {
            local_cache: HashMap::new(),
            pending_uploads: Vec::new(),
            subscriptions: Vec::new(),
        }
    }

    /// Search for presets
    pub fn search(&self, query: &SearchQuery) -> Vec<&CachedPreset> {
        self.local_cache.values()
            .filter(|p| {
                if let Some(ref cat) = query.category {
                    if p.preset.metadata.category != *cat {
                        return false;
                    }
                }
                if let Some(ref author) = query.author {
                    if !p.author.contains(author) {
                        return false;
                    }
                }
                if let Some(min_rating) = query.min_rating {
                    if p.rating < min_rating {
                        return false;
                    }
                }
                for tag in &query.tags {
                    if !p.tags.contains(tag) {
                        return false;
                    }
                }
                true
            })
            .collect()
    }

    /// Queue preset for upload
    pub fn queue_upload(&mut self, preset: NovaPreset, description: &str, tags: Vec<String>) {
        self.pending_uploads.push(PendingUpload {
            preset,
            description: description.to_string(),
            tags,
        });
    }

    /// Subscribe to creator
    pub fn subscribe(&mut self, creator_id: &str) {
        if !self.subscriptions.contains(&creator_id.to_string()) {
            self.subscriptions.push(creator_id.to_string());
        }
    }

    /// Download preset by ID
    pub fn download(&mut self, preset_id: &str) -> Option<&NovaPreset> {
        self.local_cache.get(preset_id).map(|c| &c.preset)
    }

    /// Get trending presets
    pub fn trending(&self, limit: usize) -> Vec<&CachedPreset> {
        let mut presets: Vec<_> = self.local_cache.values().collect();
        presets.sort_by(|a, b| b.downloads.cmp(&a.downloads));
        presets.into_iter().take(limit).collect()
    }
}

#[derive(Debug, Clone, Default)]
pub struct SearchQuery {
    pub text: Option<String>,
    pub category: Option<PresetCategory>,
    pub author: Option<String>,
    pub min_rating: Option<f32>,
    pub tags: Vec<String>,
    pub sort_by: SortOrder,
}

#[derive(Debug, Clone, Copy, Default)]
pub enum SortOrder {
    #[default]
    Relevance,
    Downloads,
    Rating,
    Recent,
    Alphabetical,
}

// ═══════════════════════════════════════════════════════════════════════════════
// REAL-TIME PRESET PREVIEW
// ═══════════════════════════════════════════════════════════════════════════════

/// Real-time A/B comparison and preview
pub struct PresetPreviewer {
    active_preset: Option<NovaPreset>,
    comparison_preset: Option<NovaPreset>,
    split_position: f32,
    split_mode: SplitMode,
    animation: Option<PreviewAnimation>,
}

#[derive(Debug, Clone, Copy)]
pub enum SplitMode {
    Horizontal,
    Vertical,
    Circle,
    Diagonal,
    None,
}

#[derive(Debug, Clone)]
pub struct PreviewAnimation {
    from_preset: NovaPreset,
    to_preset: NovaPreset,
    progress: f32,
    duration_ms: u32,
    easing: EasingFunction,
}

#[derive(Debug, Clone, Copy)]
pub enum EasingFunction {
    Linear,
    EaseIn,
    EaseOut,
    EaseInOut,
    Bounce,
}

impl PresetPreviewer {
    pub fn new() -> Self {
        Self {
            active_preset: None,
            comparison_preset: None,
            split_position: 0.5,
            split_mode: SplitMode::Vertical,
            animation: None,
        }
    }

    /// Set active preset
    pub fn set_active(&mut self, preset: NovaPreset) {
        self.active_preset = Some(preset);
    }

    /// Set comparison preset for A/B testing
    pub fn set_comparison(&mut self, preset: NovaPreset) {
        self.comparison_preset = Some(preset);
    }

    /// Start animated transition between presets
    pub fn animate_to(&mut self, to_preset: NovaPreset, duration_ms: u32, easing: EasingFunction) {
        if let Some(from) = &self.active_preset {
            self.animation = Some(PreviewAnimation {
                from_preset: from.clone(),
                to_preset: to_preset.clone(),
                progress: 0.0,
                duration_ms,
                easing,
            });
        } else {
            self.active_preset = Some(to_preset);
        }
    }

    /// Update animation
    pub fn update(&mut self, delta_ms: u32) {
        if let Some(ref mut anim) = self.animation {
            anim.progress += delta_ms as f32 / anim.duration_ms as f32;

            if anim.progress >= 1.0 {
                self.active_preset = Some(anim.to_preset.clone());
                self.animation = None;
            } else {
                let t = Self::apply_easing(anim.progress, anim.easing);
                self.active_preset = Some(blend_presets(&anim.from_preset, &anim.to_preset, t));
            }
        }
    }

    fn apply_easing(t: f32, easing: EasingFunction) -> f32 {
        match easing {
            EasingFunction::Linear => t,
            EasingFunction::EaseIn => t * t,
            EasingFunction::EaseOut => t * (2.0 - t),
            EasingFunction::EaseInOut => {
                if t < 0.5 {
                    2.0 * t * t
                } else {
                    -1.0 + (4.0 - 2.0 * t) * t
                }
            },
            EasingFunction::Bounce => {
                let n1 = 7.5625;
                let d1 = 2.75;
                let t = t;
                if t < 1.0 / d1 {
                    n1 * t * t
                } else if t < 2.0 / d1 {
                    let t = t - 1.5 / d1;
                    n1 * t * t + 0.75
                } else if t < 2.5 / d1 {
                    let t = t - 2.25 / d1;
                    n1 * t * t + 0.9375
                } else {
                    let t = t - 2.625 / d1;
                    n1 * t * t + 0.984375
                }
            },
        }
    }

    /// Get current interpolated preset
    pub fn current_preset(&self) -> Option<&NovaPreset> {
        self.active_preset.as_ref()
    }

    /// Render split comparison
    pub fn get_split_mask(&self, width: u32, height: u32) -> Vec<bool> {
        let mut mask = vec![false; (width * height) as usize];

        for y in 0..height {
            for x in 0..width {
                let idx = (y * width + x) as usize;
                let nx = x as f32 / width as f32;
                let ny = y as f32 / height as f32;

                mask[idx] = match self.split_mode {
                    SplitMode::Horizontal => ny < self.split_position,
                    SplitMode::Vertical => nx < self.split_position,
                    SplitMode::Diagonal => nx + ny < self.split_position * 2.0,
                    SplitMode::Circle => {
                        let dx = nx - 0.5;
                        let dy = ny - 0.5;
                        (dx * dx + dy * dy).sqrt() < self.split_position
                    },
                    SplitMode::None => true,
                };
            }
        }

        mask
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET INTERPOLATION ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

pub enum InterpolationCurve {
    Linear,
    EaseIn,
    EaseOut,
    EaseInOut,
    Cubic,
    Exponential,
    Bounce,
    Elastic,
    Spring { stiffness: f32, damping: f32 },
    Bezier { p1: Vec2, p2: Vec2 },
    Custom { samples: Vec<f32> },
}

impl InterpolationCurve {
    pub fn evaluate(&self, t: f32) -> f32 {
        let t = t.clamp(0.0, 1.0);
        match self {
            Self::Linear => t,
            Self::EaseIn => t * t,
            Self::EaseOut => 1.0 - (1.0 - t) * (1.0 - t),
            Self::EaseInOut => if t < 0.5 { 2.0 * t * t } else { 1.0 - (-2.0 * t + 2.0).powi(2) / 2.0 },
            Self::Cubic => t * t * t,
            Self::Exponential => if t == 0.0 { 0.0 } else { 2.0_f32.powf(10.0 * t - 10.0) },
            Self::Bounce => {
                let n1 = 7.5625; let d1 = 2.75;
                let mut tt = 1.0 - t;
                if tt < 1.0 / d1 { 1.0 - n1 * tt * tt }
                else if tt < 2.0 / d1 { tt -= 1.5 / d1; 1.0 - n1 * tt * tt - 0.75 }
                else if tt < 2.5 / d1 { tt -= 2.25 / d1; 1.0 - n1 * tt * tt - 0.9375 }
                else { tt -= 2.625 / d1; 1.0 - n1 * tt * tt - 0.984375 }
            },
            Self::Elastic => {
                if t == 0.0 || t == 1.0 { t }
                else { 2.0_f32.powf(-10.0 * t) * ((t * 10.0 - 0.75) * std::f32::consts::TAU / 3.0).sin() + 1.0 }
            },
            Self::Spring { stiffness, damping } => {
                let omega = stiffness.sqrt();
                let zeta = *damping / (2.0 * omega);
                if zeta < 1.0 {
                    let omega_d = omega * (1.0 - zeta * zeta).sqrt();
                    1.0 - (-zeta * omega * t).exp() * ((zeta * omega * t / omega_d).sin() * zeta + (omega_d * t).cos())
                } else { 1.0 - (1.0 + omega * t) * (-omega * t).exp() }
            },
            Self::Bezier { p1, p2 } => { Self::cubic_bezier(t, p1.x, p1.y, p2.x, p2.y) },
            Self::Custom { samples } => {
                if samples.is_empty() { return t; }
                let pos = t * (samples.len() - 1) as f32;
                let idx = pos.floor() as usize;
                if idx >= samples.len() - 1 { samples[samples.len() - 1] }
                else { let frac = pos - idx as f32; samples[idx] * (1.0 - frac) + samples[idx + 1] * frac }
            },
        }
    }

    fn cubic_bezier(t: f32, x1: f32, y1: f32, x2: f32, y2: f32) -> f32 {
        let mut lo = 0.0; let mut hi = 1.0;
        for _ in 0..20 {
            let mid = (lo + hi) / 2.0;
            let x = 3.0 * (1.0 - mid).powi(2) * mid * x1 + 3.0 * (1.0 - mid) * mid * mid * x2 + mid * mid * mid;
            if x < t { lo = mid; } else { hi = mid; }
        }
        let tt = (lo + hi) / 2.0;
        3.0 * (1.0 - tt).powi(2) * tt * y1 + 3.0 * (1.0 - tt) * tt * tt * y2 + tt * tt * tt
    }
}

pub struct InterpolatedValue<T> { pub start: T, pub end: T, pub curve: InterpolationCurve }

impl InterpolatedValue<f32> {
    pub fn at(&self, t: f32) -> f32 { self.start + (self.end - self.start) * self.curve.evaluate(t) }
}

impl InterpolatedValue<Vec3> {
    pub fn at(&self, t: f32) -> Vec3 {
        let e = self.curve.evaluate(t);
        Vec3::new(
            self.start.x + (self.end.x - self.start.x) * e,
            self.start.y + (self.end.y - self.start.y) * e,
            self.start.z + (self.end.z - self.start.z) * e,
        )
    }
}

pub struct PresetInterpolator {
    pub source_values: HashMap<String, f32>,
    pub target_values: HashMap<String, f32>,
    pub curves: HashMap<String, InterpolationCurve>,
    pub default_curve: InterpolationCurve,
    pub progress: f32,
}

impl PresetInterpolator {
    pub fn new(source: &NovaPreset, target: &NovaPreset) -> Self {
        Self {
            source_values: source.values.clone(),
            target_values: target.values.clone(),
            curves: HashMap::new(),
            default_curve: InterpolationCurve::EaseInOut,
            progress: 0.0,
        }
    }

    pub fn set_curve(&mut self, param: &str, curve: InterpolationCurve) { self.curves.insert(param.to_string(), curve); }

    pub fn interpolate(&self, t: f32) -> HashMap<String, f32> {
        let mut result = HashMap::new();
        for (key, &start) in &self.source_values {
            let end = self.target_values.get(key).copied().unwrap_or(start);
            let curve = self.curves.get(key).unwrap_or(&self.default_curve);
            result.insert(key.clone(), start + (end - start) * curve.evaluate(t));
        }
        for (key, &end) in &self.target_values {
            if !result.contains_key(key) {
                let curve = self.curves.get(key).unwrap_or(&self.default_curve);
                result.insert(key.clone(), end * curve.evaluate(t));
            }
        }
        result
    }

    pub fn step(&mut self, delta: f32) -> bool { self.progress = (self.progress + delta).min(1.0); self.progress >= 1.0 }
    pub fn current(&self) -> HashMap<String, f32> { self.interpolate(self.progress) }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET MORPHING SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub struct MorphKeyframe { pub time: f32, pub preset_id: String, pub curve: InterpolationCurve }

pub struct PresetMorph {
    pub name: String,
    pub keyframes: Vec<MorphKeyframe>,
    pub duration: f32,
    pub loop_mode: LoopMode,
    pub current_time: f32,
    pub speed: f32,
}

pub enum LoopMode { Once, Loop, PingPong, Hold }

impl PresetMorph {
    pub fn new(name: &str) -> Self {
        Self { name: name.to_string(), keyframes: Vec::new(), duration: 0.0, loop_mode: LoopMode::Once, current_time: 0.0, speed: 1.0 }
    }

    pub fn add_keyframe(&mut self, time: f32, preset_id: &str, curve: InterpolationCurve) {
        self.keyframes.push(MorphKeyframe { time, preset_id: preset_id.to_string(), curve });
        self.keyframes.sort_by(|a, b| a.time.partial_cmp(&b.time).unwrap());
        self.duration = self.keyframes.last().map(|k| k.time).unwrap_or(0.0);
    }

    pub fn update(&mut self, delta: f32) {
        self.current_time += delta * self.speed;
        match self.loop_mode {
            LoopMode::Once => self.current_time = self.current_time.min(self.duration),
            LoopMode::Loop => if self.current_time > self.duration { self.current_time %= self.duration; },
            LoopMode::PingPong => {
                let cycle = (self.current_time / self.duration).floor() as i32;
                if cycle % 2 == 1 { self.current_time = self.duration - (self.current_time % self.duration); }
                else { self.current_time %= self.duration; }
            },
            LoopMode::Hold => {},
        }
    }

    pub fn get_blend_info(&self) -> Option<(usize, usize, f32)> {
        if self.keyframes.len() < 2 { return None; }
        for i in 0..self.keyframes.len() - 1 {
            if self.current_time >= self.keyframes[i].time && self.current_time <= self.keyframes[i + 1].time {
                let local_t = (self.current_time - self.keyframes[i].time) / (self.keyframes[i + 1].time - self.keyframes[i].time);
                return Some((i, i + 1, self.keyframes[i].curve.evaluate(local_t)));
            }
        }
        Some((self.keyframes.len() - 2, self.keyframes.len() - 1, 1.0))
    }

    pub fn is_complete(&self) -> bool { matches!(self.loop_mode, LoopMode::Once) && self.current_time >= self.duration }
}

pub struct MorphPlayer {
    pub morphs: HashMap<String, PresetMorph>,
    pub active_morph: Option<String>,
    pub presets: HashMap<String, NovaPreset>,
    pub crossfade_duration: f32,
    pub crossfade_progress: f32,
    pub previous_values: HashMap<String, f32>,
}

impl MorphPlayer {
    pub fn new() -> Self {
        Self { morphs: HashMap::new(), active_morph: None, presets: HashMap::new(), crossfade_duration: 0.5, crossfade_progress: 1.0, previous_values: HashMap::new() }
    }

    pub fn register_preset(&mut self, preset: NovaPreset) { self.presets.insert(preset.name.clone(), preset); }
    pub fn register_morph(&mut self, morph: PresetMorph) { self.morphs.insert(morph.name.clone(), morph); }

    pub fn play(&mut self, morph_name: &str) {
        if self.active_morph.is_some() { self.crossfade_progress = 0.0; }
        self.active_morph = Some(morph_name.to_string());
        if let Some(morph) = self.morphs.get_mut(morph_name) { morph.current_time = 0.0; }
    }

    pub fn update(&mut self, delta: f32) -> HashMap<String, f32> {
        if self.crossfade_progress < 1.0 { self.crossfade_progress = (self.crossfade_progress + delta / self.crossfade_duration).min(1.0); }
        let Some(morph_name) = &self.active_morph else { return HashMap::new(); };
        let Some(morph) = self.morphs.get_mut(morph_name) else { return HashMap::new(); };
        morph.update(delta);
        let Some((idx_a, idx_b, t)) = morph.get_blend_info() else { return HashMap::new(); };
        let preset_a = self.presets.get(&morph.keyframes[idx_a].preset_id);
        let preset_b = self.presets.get(&morph.keyframes[idx_b].preset_id);
        let mut result = HashMap::new();
        if let (Some(a), Some(b)) = (preset_a, preset_b) {
            for (k, &va) in &a.values {
                let vb = b.values.get(k).copied().unwrap_or(va);
                result.insert(k.clone(), va + (vb - va) * t);
            }
        }
        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCENE DETECTION & AUTO-PRESET
// ═══════════════════════════════════════════════════════════════════════════════

pub enum DetectedSceneType { Day, Night, Indoor, Outdoor, Forest, Urban, Water, Snow, Desert, Sunset, Storm, Fog }

pub struct SceneFeatures {
    pub avg_luminance: f32,
    pub luminance_variance: f32,
    pub dominant_hue: f32,
    pub saturation: f32,
    pub color_temperature: f32,
    pub edge_density: f32,
    pub sky_ratio: f32,
    pub green_ratio: f32,
    pub blue_ratio: f32,
    pub contrast: f32,
}

pub struct SceneAnalyzer {
    pub history: VecDeque<SceneFeatures>,
    pub history_size: usize,
    pub smoothing: f32,
}

impl SceneAnalyzer {
    pub fn new() -> Self { Self { history: VecDeque::new(), history_size: 30, smoothing: 0.8 } }

    pub fn analyze_frame(&mut self, pixels: &[u8], width: u32, height: u32) -> SceneFeatures {
        let step = ((width * height) / 10000).max(1) as usize;
        let mut lum_sum = 0.0; let mut lum_sq_sum = 0.0;
        let mut hue_sin = 0.0; let mut hue_cos = 0.0;
        let mut sat_sum = 0.0; let mut green_count = 0; let mut blue_count = 0; let mut sky_count = 0;
        let mut samples = 0;
        for i in (0..pixels.len()).step_by(step * 4) {
            if i + 2 >= pixels.len() { break; }
            let (r, g, b) = (pixels[i] as f32 / 255.0, pixels[i + 1] as f32 / 255.0, pixels[i + 2] as f32 / 255.0);
            let lum = 0.299 * r + 0.587 * g + 0.114 * b;
            lum_sum += lum; lum_sq_sum += lum * lum;
            let max_c = r.max(g).max(b); let min_c = r.min(g).min(b); let delta = max_c - min_c;
            let sat = if max_c > 0.0 { delta / max_c } else { 0.0 }; sat_sum += sat;
            let hue = if delta < 0.001 { 0.0 } else if max_c == r { 60.0 * (((g - b) / delta) % 6.0) }
                      else if max_c == g { 60.0 * ((b - r) / delta + 2.0) } else { 60.0 * ((r - g) / delta + 4.0) };
            hue_sin += (hue * std::f32::consts::PI / 180.0).sin();
            hue_cos += (hue * std::f32::consts::PI / 180.0).cos();
            if g > r * 1.2 && g > b * 1.2 { green_count += 1; }
            if b > r * 1.1 && b > g * 0.9 { blue_count += 1; }
            let y_pos = (i / 4) as u32 / width;
            if y_pos < height / 3 && b > 0.4 && lum > 0.5 { sky_count += 1; }
            samples += 1;
        }
        let n = samples as f32;
        let avg_lum = lum_sum / n; let var_lum = (lum_sq_sum / n - avg_lum * avg_lum).max(0.0);
        let avg_hue = hue_cos.atan2(hue_sin) * 180.0 / std::f32::consts::PI;
        SceneFeatures {
            avg_luminance: avg_lum, luminance_variance: var_lum, dominant_hue: if avg_hue < 0.0 { avg_hue + 360.0 } else { avg_hue },
            saturation: sat_sum / n, color_temperature: 6500.0 - (avg_hue - 30.0) * 50.0,
            edge_density: 0.0, sky_ratio: sky_count as f32 / n, green_ratio: green_count as f32 / n, blue_ratio: blue_count as f32 / n,
            contrast: var_lum.sqrt() * 4.0,
        }
    }

    pub fn classify(&self, features: &SceneFeatures) -> DetectedSceneType {
        if features.avg_luminance < 0.15 { return DetectedSceneType::Night; }
        if features.luminance_variance < 0.01 && features.avg_luminance > 0.7 { return DetectedSceneType::Fog; }
        if features.green_ratio > 0.3 { return DetectedSceneType::Forest; }
        if features.sky_ratio > 0.4 && features.blue_ratio > 0.3 { return DetectedSceneType::Outdoor; }
        if features.dominant_hue > 15.0 && features.dominant_hue < 45.0 && features.saturation > 0.5 { return DetectedSceneType::Sunset; }
        if features.avg_luminance > 0.8 && features.saturation < 0.2 { return DetectedSceneType::Snow; }
        if features.blue_ratio > 0.4 && features.sky_ratio < 0.2 { return DetectedSceneType::Water; }
        if features.saturation < 0.3 && features.contrast > 0.5 { return DetectedSceneType::Urban; }
        if features.dominant_hue > 30.0 && features.dominant_hue < 60.0 && features.saturation > 0.4 { return DetectedSceneType::Desert; }
        if features.sky_ratio < 0.1 { return DetectedSceneType::Indoor; }
        DetectedSceneType::Day
    }
}

pub struct AutoPresetSelector {
    pub analyzer: SceneAnalyzer,
    pub scene_presets: HashMap<DetectedSceneType, String>,
    pub current_scene: DetectedSceneType,
    pub transition_speed: f32,
    pub hysteresis_frames: u32,
    pub scene_counter: HashMap<DetectedSceneType, u32>,
    pub min_confidence: u32,
}

impl AutoPresetSelector {
    pub fn new() -> Self {
        Self {
            analyzer: SceneAnalyzer::new(), scene_presets: HashMap::new(), current_scene: DetectedSceneType::Day,
            transition_speed: 0.02, hysteresis_frames: 15, scene_counter: HashMap::new(), min_confidence: 10,
        }
    }

    pub fn map_scene(&mut self, scene: DetectedSceneType, preset_name: &str) {
        self.scene_presets.insert(scene, preset_name.to_string());
    }

    pub fn process_frame(&mut self, pixels: &[u8], width: u32, height: u32) -> Option<String> {
        let features = self.analyzer.analyze_frame(pixels, width, height);
        let detected = self.analyzer.classify(&features);
        *self.scene_counter.entry(detected).or_insert(0) += 1;
        for (scene, count) in self.scene_counter.iter_mut() { if *scene != detected { *count = count.saturating_sub(1); } }
        let best = self.scene_counter.iter().max_by_key(|(_, c)| *c);
        if let Some((scene, count)) = best {
            if *count >= self.min_confidence && *scene != self.current_scene {
                self.current_scene = *scene;
                return self.scene_presets.get(scene).cloned();
            }
        }
        None
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VERSIONING SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub struct HistoryPresetVersion { pub version: u32, pub timestamp: u64, pub values: HashMap<String, f32>, pub message: String, pub author: String }

pub struct PresetHistory {
    pub preset_id: String,
    pub versions: Vec<HistoryPresetVersion>,
    pub current_version: u32,
    pub max_versions: usize,
}

impl PresetHistory {
    pub fn new(preset_id: &str) -> Self { Self { preset_id: preset_id.to_string(), versions: Vec::new(), current_version: 0, max_versions: 100 } }

    pub fn commit(&mut self, values: HashMap<String, f32>, message: &str, author: &str) -> u32 {
        self.current_version += 1;
        let version = HistoryPresetVersion {
            version: self.current_version, timestamp: std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs(),
            values, message: message.to_string(), author: author.to_string(),
        };
        self.versions.push(version);
        while self.versions.len() > self.max_versions { self.versions.remove(0); }
        self.current_version
    }

    pub fn checkout(&self, version: u32) -> Option<&HistoryPresetVersion> { self.versions.iter().find(|v| v.version == version) }
    pub fn latest(&self) -> Option<&HistoryPresetVersion> { self.versions.last() }

    pub fn diff(&self, v1: u32, v2: u32) -> Vec<(String, Option<f32>, Option<f32>)> {
        let pv1 = self.checkout(v1); let pv2 = self.checkout(v2);
        let mut changes = Vec::new();
        let (vals1, vals2) = match (pv1, pv2) { (Some(a), Some(b)) => (&a.values, &b.values), _ => return changes };
        for (k, &v1) in vals1 {
            let v2_opt = vals2.get(k).copied();
            if v2_opt != Some(v1) { changes.push((k.clone(), Some(v1), v2_opt)); }
        }
        for (k, &v2) in vals2 { if !vals1.contains_key(k) { changes.push((k.clone(), None, Some(v2))); } }
        changes
    }

    pub fn revert(&mut self, version: u32) -> Option<HashMap<String, f32>> {
        let v = self.checkout(version)?;
        let values = v.values.clone();
        self.commit(values.clone(), &format!("Revert to version {}", version), "system");
        Some(values)
    }
}

pub struct PresetRepository {
    pub histories: HashMap<String, PresetHistory>,
    pub tags: HashMap<String, (String, u32)>,
}

impl PresetRepository {
    pub fn new() -> Self { Self { histories: HashMap::new(), tags: HashMap::new() } }

    pub fn init(&mut self, preset_id: &str) { self.histories.insert(preset_id.to_string(), PresetHistory::new(preset_id)); }

    pub fn commit(&mut self, preset_id: &str, values: HashMap<String, f32>, msg: &str, author: &str) -> Option<u32> {
        self.histories.get_mut(preset_id).map(|h| h.commit(values, msg, author))
    }

    pub fn tag(&mut self, tag_name: &str, preset_id: &str, version: u32) { self.tags.insert(tag_name.to_string(), (preset_id.to_string(), version)); }
    pub fn get_tag(&self, tag_name: &str) -> Option<&(String, u32)> { self.tags.get(tag_name) }

    pub fn log(&self, preset_id: &str, limit: usize) -> Vec<&HistoryPresetVersion> {
        self.histories.get(preset_id).map(|h| h.versions.iter().rev().take(limit).collect()).unwrap_or_default()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VALIDATION & SCHEMA
// ═══════════════════════════════════════════════════════════════════════════════

pub enum ValidationRule { Required, Range { min: f32, max: f32 }, OneOf(Vec<f32>), Regex(String), Custom(fn(f32) -> bool) }

pub struct ParameterSchema { pub name: String, pub default: f32, pub rules: Vec<ValidationRule>, pub description: String, pub category: String }

pub struct PresetSchema { pub name: String, pub version: String, pub parameters: Vec<ParameterSchema>, pub required_params: HashSet<String> }

impl PresetSchema {
    pub fn new(name: &str, version: &str) -> Self {
        Self { name: name.to_string(), version: version.to_string(), parameters: Vec::new(), required_params: HashSet::new() }
    }

    pub fn add_param(&mut self, param: ParameterSchema) {
        for rule in &param.rules { if matches!(rule, ValidationRule::Required) { self.required_params.insert(param.name.clone()); } }
        self.parameters.push(param);
    }

    pub fn validate(&self, values: &HashMap<String, f32>) -> Vec<String> {
        let mut errors = Vec::new();
        for req in &self.required_params { if !values.contains_key(req) { errors.push(format!("Missing required parameter: {}", req)); } }
        for param in &self.parameters {
            if let Some(&value) = values.get(&param.name) {
                for rule in &param.rules {
                    match rule {
                        ValidationRule::Range { min, max } => { if value < *min || value > *max { errors.push(format!("{}: {} not in range [{}, {}]", param.name, value, min, max)); } }
                        ValidationRule::OneOf(opts) => { if !opts.contains(&value) { errors.push(format!("{}: {} not in allowed values", param.name, value)); } }
                        ValidationRule::Custom(f) => { if !f(value) { errors.push(format!("{}: custom validation failed", param.name)); } }
                        _ => {}
                    }
                }
            }
        }
        errors
    }

    pub fn apply_defaults(&self, values: &mut HashMap<String, f32>) {
        for param in &self.parameters { values.entry(param.name.clone()).or_insert(param.default); }
    }
}

pub struct SchemaRegistry { pub schemas: HashMap<String, PresetSchema> }

impl SchemaRegistry {
    pub fn new() -> Self { Self { schemas: HashMap::new() } }
    pub fn register(&mut self, schema: PresetSchema) { self.schemas.insert(schema.name.clone(), schema); }
    pub fn get(&self, name: &str) -> Option<&PresetSchema> { self.schemas.get(name) }
    pub fn validate(&self, schema_name: &str, values: &HashMap<String, f32>) -> Vec<String> {
        self.schemas.get(schema_name).map(|s| s.validate(values)).unwrap_or_else(|| vec!["Schema not found".to_string()])
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET CLOUD SYNC
// ═══════════════════════════════════════════════════════════════════════════════

pub enum CloudSyncStatus { Synced, LocalOnly, RemoteOnly, Conflict, Syncing }

pub struct SyncCloudPreset {
    pub id: String,
    pub name: String,
    pub values: HashMap<String, f32>,
    pub remote_version: u64,
    pub local_version: u64,
    pub status: CloudSyncStatus,
    pub last_sync: u64,
    pub checksum: String,
}

impl SyncCloudPreset {
    pub fn compute_checksum(values: &HashMap<String, f32>) -> String {
        let mut sorted: Vec<_> = values.iter().collect();
        sorted.sort_by_key(|(k, _)| *k);
        let data: String = sorted.iter().map(|(k, v)| format!("{}:{:.6}", k, v)).collect::<Vec<_>>().join("|");
        format!("{:x}", md5_hash(&data))
    }
}

fn md5_hash(data: &str) -> u128 {
    let bytes = data.as_bytes();
    let mut h: u128 = 0;
    for (i, &b) in bytes.iter().enumerate() { h = h.wrapping_add((b as u128) << ((i % 16) * 8)); h = h.rotate_left(5); }
    h
}

pub struct PresetCloudSync {
    pub endpoint: String,
    pub api_key: String,
    pub user_id: String,
    pub local_presets: HashMap<String, SyncCloudPreset>,
    pub sync_interval: u64,
    pub last_full_sync: u64,
    pub pending_uploads: VecDeque<String>,
    pub pending_downloads: VecDeque<String>,
    pub conflict_resolver: CloudConflictResolution,
}

pub enum CloudConflictResolution { KeepLocal, KeepRemote, KeepNewer, Manual }

impl PresetCloudSync {
    pub fn new(endpoint: &str, api_key: &str, user_id: &str) -> Self {
        Self {
            endpoint: endpoint.to_string(), api_key: api_key.to_string(), user_id: user_id.to_string(),
            local_presets: HashMap::new(), sync_interval: 300, last_full_sync: 0,
            pending_uploads: VecDeque::new(), pending_downloads: VecDeque::new(), conflict_resolver: CloudConflictResolution::KeepNewer,
        }
    }

    pub fn add_local(&mut self, name: &str, values: HashMap<String, f32>) {
        let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
        let checksum = SyncCloudPreset::compute_checksum(&values);
        self.local_presets.insert(name.to_string(), SyncCloudPreset {
            id: format!("{}-{}", self.user_id, name), name: name.to_string(), values, remote_version: 0, local_version: now, status: CloudSyncStatus::LocalOnly, last_sync: 0, checksum,
        });
        self.pending_uploads.push_back(name.to_string());
    }

    pub fn mark_dirty(&mut self, name: &str) {
        if let Some(preset) = self.local_presets.get_mut(name) {
            preset.local_version = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
            preset.checksum = SyncCloudPreset::compute_checksum(&preset.values);
            if !self.pending_uploads.contains(&name.to_string()) { self.pending_uploads.push_back(name.to_string()); }
        }
    }

    pub fn resolve_conflict(&self, local: &SyncCloudPreset, remote_version: u64) -> CloudSyncStatus {
        match self.conflict_resolver {
            CloudConflictResolution::KeepLocal => CloudSyncStatus::LocalOnly,
            CloudConflictResolution::KeepRemote => CloudSyncStatus::RemoteOnly,
            CloudConflictResolution::KeepNewer => if local.local_version > remote_version { CloudSyncStatus::LocalOnly } else { CloudSyncStatus::RemoteOnly },
            CloudConflictResolution::Manual => CloudSyncStatus::Conflict,
        }
    }

    pub fn get_sync_stats(&self) -> (usize, usize, usize) {
        let synced = self.local_presets.values().filter(|p| matches!(p.status, CloudSyncStatus::Synced)).count();
        let pending = self.pending_uploads.len() + self.pending_downloads.len();
        let conflicts = self.local_presets.values().filter(|p| matches!(p.status, CloudSyncStatus::Conflict)).count();
        (synced, pending, conflicts)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET EXPORT FORMATS
// ═══════════════════════════════════════════════════════════════════════════════

pub enum PresetExportFormat { Json, Xml, Ini, Binary, Lua, ReShade, ENB }

pub struct PresetExporter;

impl PresetExporter {
    pub fn export(preset: &NovaPreset, format: PresetExportFormat) -> String {
        match format {
            PresetExportFormat::Json => Self::to_json(preset),
            PresetExportFormat::Xml => Self::to_xml(preset),
            PresetExportFormat::Ini => Self::to_ini(preset),
            PresetExportFormat::Lua => Self::to_lua(preset),
            PresetExportFormat::ReShade => Self::to_reshade(preset),
            PresetExportFormat::ENB => Self::to_enb(preset),
            PresetExportFormat::Binary => "[BINARY DATA]".to_string(),
        }
    }

    fn to_json(p: &NovaPreset) -> String {
        let mut s = format!("{{\n  \"name\": \"{}\",\n  \"category\": \"{}\",\n  \"values\": {{\n", p.name, p.category);
        for (i, (k, v)) in p.values.iter().enumerate() {
            s.push_str(&format!("    \"{}\": {:.4}{}\n", k, v, if i < p.values.len() - 1 { "," } else { "" }));
        }
        s.push_str("  }\n}"); s
    }

    fn to_xml(p: &NovaPreset) -> String {
        let mut s = format!("<preset name=\"{}\" category=\"{}\">\n", p.name, p.category);
        for (k, v) in &p.values { s.push_str(&format!("  <param name=\"{}\" value=\"{:.4}\"/>\n", k, v)); }
        s.push_str("</preset>"); s
    }

    fn to_ini(p: &NovaPreset) -> String {
        let mut s = format!("[{}]\n", p.name);
        for (k, v) in &p.values { s.push_str(&format!("{}={:.4}\n", k, v)); }
        s
    }

    fn to_lua(p: &NovaPreset) -> String {
        let mut s = format!("local {} = {{\n", p.name.replace(" ", "_"));
        for (k, v) in &p.values { s.push_str(&format!("  {} = {:.4},\n", k, v)); }
        s.push_str("}\n"); s
    }

    fn to_reshade(p: &NovaPreset) -> String {
        let mut s = format!("; Nova Preset: {}\n; Category: {}\n\n", p.name, p.category);
        for (k, v) in &p.values { s.push_str(&format!("{}={:.4}\n", k, v)); }
        s
    }

    fn to_enb(p: &NovaPreset) -> String {
        let mut s = format!("[NOVA:{}]\n", p.name);
        for (k, v) in &p.values { s.push_str(&format!("{}={:.4}\n", k, v)); }
        s
    }
}

pub struct PresetImporter;

impl PresetImporter {
    pub fn import_json(json: &str) -> Option<NovaPreset> {
        let name_start = json.find("\"name\":")?;
        let name_val_start = json[name_start..].find('"')? + name_start + 1;
        let name_quote = json[name_val_start + 1..].find('"')? + name_val_start + 1;
        let name_end = json[name_quote + 1..].find('"')? + name_quote + 1;
        let name = json[name_quote + 1..name_end].to_string();
        let mut preset = NovaPreset { name, category: "Imported".to_string(), values: HashMap::new(), thumbnail: None };
        let values_start = json.find("\"values\":")?;
        let values_section = &json[values_start..];
        for line in values_section.lines() {
            if let Some(colon) = line.find(':') {
                let key_part = line[..colon].trim().trim_matches('"').trim_matches('{').trim();
                if key_part.is_empty() || key_part == "values" { continue; }
                let val_part = line[colon + 1..].trim().trim_matches(',').trim_matches('}');
                if let Ok(v) = val_part.parse::<f32>() { preset.values.insert(key_part.to_string(), v); }
            }
        }
        Some(preset)
    }

    pub fn import_ini(ini: &str) -> Option<NovaPreset> {
        let mut preset = NovaPreset { name: "Imported".to_string(), category: "Imported".to_string(), values: HashMap::new(), thumbnail: None };
        for line in ini.lines() {
            let line = line.trim();
            if line.starts_with('[') && line.ends_with(']') { preset.name = line[1..line.len()-1].to_string(); }
            else if let Some(eq) = line.find('=') {
                let key = line[..eq].trim();
                if let Ok(v) = line[eq + 1..].trim().parse::<f32>() { preset.values.insert(key.to_string(), v); }
            }
        }
        Some(preset)
    }
}

