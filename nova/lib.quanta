                    chromatic_aberration: 0.005,
                    shadow_crush: 0.1,
                    highlight_bloom: 0.2,
                },
                Genre::Cyberpunk => GenreStyle {
                    contrast: 1.35,
                    desaturation: -0.05,
                    vignette_intensity: 0.3,
                    grain_amount: 0.06,
                    chromatic_aberration: 0.04,
                    shadow_crush: 0.25,
