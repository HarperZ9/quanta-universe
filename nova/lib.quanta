    /// Genre-specific visual style parameters
    #[derive(Debug, Clone)]
    pub struct GenreStyle {
        pub contrast: f32,
        pub desaturation: f32,
        pub vignette_intensity: f32,
        pub grain_amount: f32,
        pub chromatic_aberration: f32,
        pub shadow_crush: f32,
        pub highlight_bloom: f32,
    }

    /// Preset generator that combines mood, time, and genre
    pub struct PresetGenerator {
        pub base_preset: NovaPreset,
        pub mood_weight: f32,
        pub time_weight: f32,
        pub genre_weight: f32,
    }

    impl PresetGenerator {
        pub fn new() -> Self {
            Self {
                base_preset: NovaPreset::default(),
                mood_weight: 1.0,
                time_weight: 1.0,
                genre_weight: 1.0,
            }
        }

        /// Generate a preset from mood, time, and genre
        pub fn generate(&self, mood: Mood, time: MoodTimeOfDay, genre: Genre) -> NovaPreset {
            let mut preset = self.base_preset.clone();

            // Apply mood-based color adjustments
            let mood_profile = mood.color_profile();
            preset.color.temperature += mood_profile.warmth_bias * self.mood_weight;
            preset.color.saturation += mood_profile.saturation_bias * self.mood_weight;
            preset.color.contrast *= 1.0 + (mood_profile.contrast_multiplier - 1.0) * self.mood_weight;
            preset.color.exposure += mood_profile.luminance_bias * self.mood_weight;

            // Apply time of day lighting
            let (sun_alt, color_temp, intensity) = time.lighting_params();
            let temp_adjustment = (color_temp - 5500.0) / 100.0;
            preset.color.temperature += temp_adjustment * self.time_weight;
            preset.color.exposure *= intensity.powf(self.time_weight);
            preset.lighting.sun_altitude = sun_alt;
            preset.lighting.sun_intensity *= intensity;

            let sky = time.sky_color();
            preset.lighting.ambient_color = RGB::new(
                lerp(preset.lighting.ambient_color.r, sky.r, self.time_weight * 0.5),
                lerp(preset.lighting.ambient_color.g, sky.g, self.time_weight * 0.5),
                lerp(preset.lighting.ambient_color.b, sky.b, self.time_weight * 0.5),
            );

            // Apply genre styling
            let genre_style = genre.visual_style();
            preset.color.contrast *= 1.0 + (genre_style.contrast - 1.0) * self.genre_weight;
            preset.color.saturation -= genre_style.desaturation * self.genre_weight;
            preset.effects.vignette_intensity = lerp(
                preset.effects.vignette_intensity,
                genre_style.vignette_intensity,
                self.genre_weight,
            );
            preset.effects.film_grain = lerp(
                preset.effects.film_grain,
                genre_style.grain_amount,
                self.genre_weight,
            );
            preset.effects.chromatic_aberration = lerp(
                preset.effects.chromatic_aberration,
                genre_style.chromatic_aberration,
                self.genre_weight,
            );
            preset.post_process.bloom_intensity = lerp(
                preset.post_process.bloom_intensity,
                genre_style.highlight_bloom,
                self.genre_weight,
            );

            // Generate metadata
            preset.metadata.name = format!("{:?} {:?} {:?}", mood, time, genre);
            preset.metadata.category = PresetCategory::Cinematic;
            preset.metadata.tags = vec![
                format!("{:?}", mood).to_lowercase(),
                format!("{:?}", time).to_lowercase(),
                format!("{:?}", genre).to_lowercase(),
                "generated".to_string(),
            ];

            preset
        }

        /// Generate presets for all times of day with given mood and genre
        pub fn generate_day_cycle(&self, mood: Mood, genre: Genre) -> Vec<NovaPreset> {
            let times = [
                MoodTimeOfDay::Dawn,
                MoodTimeOfDay::GoldenHourMorning,
                MoodTimeOfDay::Morning,
                MoodTimeOfDay::Midday,
                MoodTimeOfDay::Afternoon,
                MoodTimeOfDay::GoldenHourEvening,
                MoodTimeOfDay::Dusk,
                MoodTimeOfDay::BlueHour,
                MoodTimeOfDay::Night,
                MoodTimeOfDay::Midnight,
            ];
            times.iter().map(|&time| self.generate(mood, time, genre)).collect()
        }

        /// Generate a random preset with weighted randomization
        pub fn generate_random(&self, rng: &mut impl Rng) -> NovaPreset {
            let moods = [
                Mood::Joyful, Mood::Melancholic, Mood::Tense, Mood::Peaceful,
                Mood::Dramatic, Mood::Mysterious, Mood::Nostalgic, Mood::Energetic,
                Mood::Romantic, Mood::Ominous, Mood::Ethereal, Mood::Gritty,
            ];
            let times = [
                MoodTimeOfDay::Dawn, MoodTimeOfDay::GoldenHourMorning, MoodTimeOfDay::Morning,
                MoodTimeOfDay::Midday, MoodTimeOfDay::Afternoon, MoodTimeOfDay::GoldenHourEvening,
                MoodTimeOfDay::Dusk, MoodTimeOfDay::BlueHour, MoodTimeOfDay::Night, MoodTimeOfDay::Midnight,
            ];
            let genres = [
                Genre::Horror, Genre::SciFi, Genre::Fantasy, Genre::Noir,
                Genre::Western, Genre::Documentary, Genre::ActionBlockbuster,
                Genre::IndieDrama, Genre::Animation, Genre::HistoricalPeriod,
                Genre::Cyberpunk, Genre::PostApocalyptic,
            ];

            let mood = moods[rng.gen_range(0..moods.len())];
            let time = times[rng.gen_range(0..times.len())];
            let genre = genres[rng.gen_range(0..genres.len())];

            self.generate(mood, time, genre)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET ANIMATION SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Animated preset transitions and keyframe system
pub mod animation {
    use super::*;

    /// Easing functions for smooth transitions
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum AnimEasingFunction {
        Linear,
        EaseIn,
        EaseOut,
        EaseInOut,
        EaseInQuad,
        EaseOutQuad,
        EaseInOutQuad,
        EaseInCubic,
        EaseOutCubic,
        EaseInOutCubic,
        EaseInQuart,
        EaseOutQuart,
        EaseInOutQuart,
        EaseInExpo,
        EaseOutExpo,
        EaseInOutExpo,
        EaseInCirc,
        EaseOutCirc,
        EaseInOutCirc,
        EaseInBack,
        EaseOutBack,
        EaseInOutBack,
        EaseInElastic,
        EaseOutElastic,
        EaseInOutElastic,
        EaseInBounce,
        EaseOutBounce,
        EaseInOutBounce,
    }

    impl AnimEasingFunction {
        /// Evaluate the easing function at time t (0.0 to 1.0)
        pub fn evaluate(&self, t: f32) -> f32 {
            let t = t.clamp(0.0, 1.0);
            match self {
                AnimEasingFunction::Linear => t,
                AnimEasingFunction::EaseIn => t * t,
                AnimEasingFunction::EaseOut => t * (2.0 - t),
                AnimEasingFunction::EaseInOut => {
                    if t < 0.5 { 2.0 * t * t } else { -1.0 + (4.0 - 2.0 * t) * t }
                },
                AnimEasingFunction::EaseInQuad => t * t,
                AnimEasingFunction::EaseOutQuad => t * (2.0 - t),
                AnimEasingFunction::EaseInOutQuad => {
                    if t < 0.5 { 2.0 * t * t } else { -1.0 + (4.0 - 2.0 * t) * t }
                },
                AnimEasingFunction::EaseInCubic => t * t * t,
                AnimEasingFunction::EaseOutCubic => {
                    let t1 = t - 1.0;
                    t1 * t1 * t1 + 1.0
                },
                AnimEasingFunction::EaseInOutCubic => {
                    if t < 0.5 { 4.0 * t * t * t }
                    else {
                        let t1 = 2.0 * t - 2.0;
                        0.5 * t1 * t1 * t1 + 1.0
                    }
                },
                AnimEasingFunction::EaseInQuart => t * t * t * t,
                AnimEasingFunction::EaseOutQuart => {
                    let t1 = t - 1.0;
                    1.0 - t1 * t1 * t1 * t1
                },
                AnimEasingFunction::EaseInOutQuart => {
                    if t < 0.5 { 8.0 * t * t * t * t }
                    else {
                        let t1 = t - 1.0;
                        1.0 - 8.0 * t1 * t1 * t1 * t1
                    }
                },
                AnimEasingFunction::EaseInExpo => {
                    if t == 0.0 { 0.0 } else { 2.0_f32.powf(10.0 * (t - 1.0)) }
                },
                AnimEasingFunction::EaseOutExpo => {
                    if t == 1.0 { 1.0 } else { 1.0 - 2.0_f32.powf(-10.0 * t) }
                },
                AnimEasingFunction::EaseInOutExpo => {
                    if t == 0.0 { return 0.0; }
                    if t == 1.0 { return 1.0; }
                    if t < 0.5 { 0.5 * 2.0_f32.powf(20.0 * t - 10.0) }
                    else { 1.0 - 0.5 * 2.0_f32.powf(-20.0 * t + 10.0) }
                },
                AnimEasingFunction::EaseInCirc => 1.0 - (1.0 - t * t).sqrt(),
                AnimEasingFunction::EaseOutCirc => (1.0 - (t - 1.0).powi(2)).sqrt(),
                AnimEasingFunction::EaseInOutCirc => {
                    if t < 0.5 { (1.0 - (1.0 - 4.0 * t * t).sqrt()) / 2.0 }
                    else { ((1.0 - (-2.0 * t + 2.0).powi(2)).sqrt() + 1.0) / 2.0 }
                },
                AnimEasingFunction::EaseInBack => {
                    let c1 = 1.70158;
                    let c3 = c1 + 1.0;
                    c3 * t * t * t - c1 * t * t
                },
                AnimEasingFunction::EaseOutBack => {
                    let c1 = 1.70158;
                    let c3 = c1 + 1.0;
                    1.0 + c3 * (t - 1.0).powi(3) + c1 * (t - 1.0).powi(2)
                },
                AnimEasingFunction::EaseInOutBack => {
                    let c1 = 1.70158;
                    let c2 = c1 * 1.525;
                    if t < 0.5 {
                        ((2.0 * t).powi(2) * ((c2 + 1.0) * 2.0 * t - c2)) / 2.0
                    } else {
                        ((2.0 * t - 2.0).powi(2) * ((c2 + 1.0) * (t * 2.0 - 2.0) + c2) + 2.0) / 2.0
                    }
                },
                AnimEasingFunction::EaseInElastic => {
                    if t == 0.0 { return 0.0; }
                    if t == 1.0 { return 1.0; }
                    let c4 = (2.0 * std::f32::consts::PI) / 3.0;
                    -2.0_f32.powf(10.0 * t - 10.0) * ((t * 10.0 - 10.75) * c4).sin()
                },
                AnimEasingFunction::EaseOutElastic => {
                    if t == 0.0 { return 0.0; }
                    if t == 1.0 { return 1.0; }
                    let c4 = (2.0 * std::f32::consts::PI) / 3.0;
                    2.0_f32.powf(-10.0 * t) * ((t * 10.0 - 0.75) * c4).sin() + 1.0
                },
                AnimEasingFunction::EaseInOutElastic => {
                    if t == 0.0 { return 0.0; }
                    if t == 1.0 { return 1.0; }
                    let c5 = (2.0 * std::f32::consts::PI) / 4.5;
                    if t < 0.5 {
                        -(2.0_f32.powf(20.0 * t - 10.0) * ((20.0 * t - 11.125) * c5).sin()) / 2.0
                    } else {
                        (2.0_f32.powf(-20.0 * t + 10.0) * ((20.0 * t - 11.125) * c5).sin()) / 2.0 + 1.0
                    }
                },
                AnimEasingFunction::EaseInBounce => 1.0 - Self::EaseOutBounce.evaluate(1.0 - t),
                AnimEasingFunction::EaseOutBounce => {
                    let n1 = 7.5625;
                    let d1 = 2.75;
                    if t < 1.0 / d1 {
                        n1 * t * t
                    } else if t < 2.0 / d1 {
                        let t = t - 1.5 / d1;
                        n1 * t * t + 0.75
                    } else if t < 2.5 / d1 {
                        let t = t - 2.25 / d1;
                        n1 * t * t + 0.9375
                    } else {
                        let t = t - 2.625 / d1;
                        n1 * t * t + 0.984375
                    }
                },
                AnimEasingFunction::EaseInOutBounce => {
                    if t < 0.5 {
                        (1.0 - Self::EaseOutBounce.evaluate(1.0 - 2.0 * t)) / 2.0
                    } else {
                        (1.0 + Self::EaseOutBounce.evaluate(2.0 * t - 1.0)) / 2.0
                    }
                },
            }
        }
    }

    /// A keyframe in a preset animation
    #[derive(Debug, Clone)]
    pub struct Keyframe {
        pub time: f32,
        pub preset: NovaPreset,
        pub easing: AnimEasingFunction,
    }

    /// Animated preset timeline
    #[derive(Debug, Clone)]
    pub struct PresetTimeline {
        pub keyframes: Vec<Keyframe>,
        pub duration: f32,
        pub loop_mode: AnimLoopMode,
        pub current_time: f32,
        pub playback_speed: f32,
    }

    /// Loop mode for timeline playback
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum AnimLoopMode {
        Once,
        Loop,
        PingPong,
        Hold,
    }

    impl PresetTimeline {
        pub fn new(duration: f32) -> Self {
            Self {
                keyframes: Vec::new(),
                duration,
                loop_mode: AnimLoopMode::Once,
                current_time: 0.0,
                playback_speed: 1.0,
            }
        }

        /// Add a keyframe at the specified time
        pub fn add_keyframe(&mut self, time: f32, preset: NovaPreset, easing: AnimEasingFunction) {
            self.keyframes.push(Keyframe { time, preset, easing });
            self.keyframes.sort_by(|a, b| a.time.partial_cmp(&b.time).unwrap());
        }

        /// Advance the timeline by delta time
        pub fn advance(&mut self, delta_time: f32) {
            self.current_time += delta_time * self.playback_speed;

            match self.loop_mode {
                AnimLoopMode::Once => {
                    self.current_time = self.current_time.clamp(0.0, self.duration);
                },
                AnimLoopMode::Loop => {
                    while self.current_time >= self.duration {
                        self.current_time -= self.duration;
                    }
                    while self.current_time < 0.0 {
                        self.current_time += self.duration;
                    }
                },
                AnimLoopMode::PingPong => {
                    let cycle = (self.current_time / self.duration).floor() as i32;
                    let phase = self.current_time % self.duration;
                    self.current_time = if cycle % 2 == 0 { phase } else { self.duration - phase };
                },
                AnimLoopMode::Hold => {
                    // Just clamp to ends
                    self.current_time = self.current_time.clamp(0.0, self.duration);
                },
            }
        }

        /// Get the interpolated preset at the current time
        pub fn evaluate(&self) -> Option<NovaPreset> {
            if self.keyframes.is_empty() {
                return None;
            }
            if self.keyframes.len() == 1 {
                return Some(self.keyframes[0].preset.clone());
            }

            // Find surrounding keyframes
            let mut prev_idx = 0;
            let mut next_idx = 0;

            for (i, kf) in self.keyframes.iter().enumerate() {
                if kf.time <= self.current_time {
                    prev_idx = i;
                }
                if kf.time >= self.current_time && next_idx == 0 {
                    next_idx = i;
                }
            }

            if prev_idx == next_idx || self.keyframes[prev_idx].time == self.keyframes[next_idx].time {
                return Some(self.keyframes[prev_idx].preset.clone());
            }

            let prev = &self.keyframes[prev_idx];
            let next = &self.keyframes[next_idx];

            let segment_duration = next.time - prev.time;
            let segment_progress = (self.current_time - prev.time) / segment_duration;
            let eased_progress = next.easing.evaluate(segment_progress);

            Some(blend_presets(&prev.preset, &next.preset, eased_progress))
        }

        /// Reset timeline to beginning
        pub fn reset(&mut self) {
            self.current_time = 0.0;
        }

        /// Check if timeline has finished (only for non-looping modes)
        pub fn is_finished(&self) -> bool {
            match self.loop_mode {
                AnimLoopMode::Once | AnimLoopMode::Hold => self.current_time >= self.duration,
                _ => false,
            }
        }
    }

    /// Transition between two presets with configurable easing
    pub struct AnimPresetTransition {
        pub from: NovaPreset,
        pub to: NovaPreset,
        pub duration: f32,
        pub easing: AnimEasingFunction,
        pub elapsed: f32,
    }

    impl AnimPresetTransition {
        pub fn new(from: NovaPreset, to: NovaPreset, duration: f32, easing: AnimEasingFunction) -> Self {
            Self { from, to, duration, easing, elapsed: 0.0 }
        }

        /// Advance the transition
        pub fn advance(&mut self, delta_time: f32) {
            self.elapsed = (self.elapsed + delta_time).min(self.duration);
        }

        /// Get the current interpolated preset
        pub fn current(&self) -> NovaPreset {
            let progress = self.elapsed / self.duration;
            let eased = self.easing.evaluate(progress);
            blend_presets(&self.from, &self.to, eased)
        }

        /// Check if transition is complete
        pub fn is_complete(&self) -> bool {
            self.elapsed >= self.duration
        }
    }

    /// Sequence of preset transitions
    pub struct PresetSequence {
        pub presets: Vec<NovaPreset>,
        pub transition_duration: f32,
        pub hold_duration: f32,
        pub easing: AnimEasingFunction,
        current_index: usize,
        state: SequenceState,
        state_elapsed: f32,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    enum SequenceState {
        Holding,
        Transitioning,
    }

    impl PresetSequence {
        pub fn new(presets: Vec<NovaPreset>, transition_duration: f32, hold_duration: f32) -> Self {
            Self {
                presets,
                transition_duration,
                hold_duration,
                easing: AnimEasingFunction::EaseInOutCubic,
                current_index: 0,
                state: SequenceState::Holding,
                state_elapsed: 0.0,
            }
        }

        /// Advance the sequence
        pub fn advance(&mut self, delta_time: f32) {
            self.state_elapsed += delta_time;

            match self.state {
                SequenceState::Holding => {
                    if self.state_elapsed >= self.hold_duration {
                        self.state = SequenceState::Transitioning;
                        self.state_elapsed = 0.0;
                    }
                },
                SequenceState::Transitioning => {
                    if self.state_elapsed >= self.transition_duration {
                        self.current_index = (self.current_index + 1) % self.presets.len();
                        self.state = SequenceState::Holding;
                        self.state_elapsed = 0.0;
                    }
                },
            }
        }

        /// Get the current interpolated preset
        pub fn current(&self) -> NovaPreset {
            match self.state {
                SequenceState::Holding => self.presets[self.current_index].clone(),
                SequenceState::Transitioning => {
                    let next_index = (self.current_index + 1) % self.presets.len();
                    let progress = self.state_elapsed / self.transition_duration;
                    let eased = self.easing.evaluate(progress);
                    blend_presets(&self.presets[self.current_index], &self.presets[next_index], eased)
                },
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCENE ANALYSIS FOR PRESET ADAPTATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Scene analysis for intelligent preset suggestions
pub mod scene_analysis {
    use super::*;

    /// Analyzed scene characteristics
    #[derive(Debug, Clone)]
    pub struct SceneCharacteristics {
        pub average_luminance: f32,
        pub luminance_histogram: [f32; 256],
        pub dominant_colors: Vec<(RGB, f32)>,
        pub color_temperature: f32,
        pub contrast_ratio: f32,
        pub saturation_level: f32,
        pub edge_density: f32,
        pub motion_intensity: f32,
        pub depth_complexity: f32,
        pub sky_coverage: f32,
        pub shadow_coverage: f32,
        pub highlight_coverage: f32,
    }

    /// Scene type classification
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum AnalysisSceneType {
        Interior,
        ExteriorDay,
        ExteriorNight,
        Sunset,
        Overcast,
        Underwater,
        Space,
        Forest,
        Desert,
        Snow,
        Urban,
        Industrial,
    }

    /// Scene analyzer for automatic preset adaptation
    pub struct AdaptiveSceneAnalyzer {
        pub history_size: usize,
        pub luminance_history: Vec<f32>,
        pub adaptation_speed: f32,
    }

    impl AdaptiveSceneAnalyzer {
        pub fn new() -> Self {
            Self {
                history_size: 60,
                luminance_history: Vec::new(),
                adaptation_speed: 0.1,
            }
        }

        /// Analyze a frame and extract scene characteristics
        pub fn analyze_frame(&mut self, pixels: &[u8], width: u32, height: u32) -> SceneCharacteristics {
            let mut luminance_sum = 0.0;
            let mut histogram = [0.0_f32; 256];
            let mut color_buckets: HashMap<(u8, u8, u8), f32> = HashMap::new();
            let mut saturation_sum = 0.0;
            let pixel_count = (width * height) as f32;

            // Analyze pixels
            for y in 0..height {
                for x in 0..width {
                    let idx = ((y * width + x) * 4) as usize;
                    let r = pixels[idx] as f32 / 255.0;
                    let g = pixels[idx + 1] as f32 / 255.0;
                    let b = pixels[idx + 2] as f32 / 255.0;

                    // Luminance (Rec. 709)
                    let lum = 0.2126 * r + 0.7152 * g + 0.0722 * b;
                    luminance_sum += lum;
                    histogram[(lum * 255.0) as usize] += 1.0;

                    // Color quantization for dominant colors
                    let bucket = ((r * 7.0) as u8, (g * 7.0) as u8, (b * 7.0) as u8);
                    *color_buckets.entry(bucket).or_insert(0.0) += 1.0;

                    // Saturation
                    let max_c = r.max(g).max(b);
                    let min_c = r.min(g).min(b);
                    let sat = if max_c > 0.0 { (max_c - min_c) / max_c } else { 0.0 };
                    saturation_sum += sat;
                }
            }

            // Normalize histogram
            for h in &mut histogram {
                *h /= pixel_count;
            }

            // Extract dominant colors
            let mut sorted_colors: Vec<_> = color_buckets.into_iter().collect();
            sorted_colors.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
            let dominant_colors: Vec<(RGB, f32)> = sorted_colors.into_iter()
                .take(5)
                .map(|((r, g, b), count)| {
                    (RGB::new(r as f32 / 7.0, g as f32 / 7.0, b as f32 / 7.0), count / pixel_count)
                })
                .collect();

            // Calculate average luminance
            let avg_luminance = luminance_sum / pixel_count;

            // Update history
            self.luminance_history.push(avg_luminance);
            if self.luminance_history.len() > self.history_size {
                self.luminance_history.remove(0);
            }

            // Calculate contrast ratio (95th percentile / 5th percentile)
            let mut cumsum = 0.0;
            let mut p5 = 0;
            let mut p95 = 255;
            for (i, &h) in histogram.iter().enumerate() {
                cumsum += h;
                if cumsum < 0.05 { p5 = i; }
                if cumsum < 0.95 { p95 = i; }
            }
            let contrast_ratio = if p5 > 0 { p95 as f32 / p5 as f32 } else { p95 as f32 };

            // Estimate color temperature from dominant colors
            let color_temp = self.estimate_color_temperature(&dominant_colors);

            // Calculate shadow/highlight coverage
            let shadow_coverage = histogram[0..50].iter().sum();
            let highlight_coverage = histogram[200..256].iter().sum();

            SceneCharacteristics {
                average_luminance: avg_luminance,
                luminance_histogram: histogram,
                dominant_colors,
                color_temperature: color_temp,
                contrast_ratio,
                saturation_level: saturation_sum / pixel_count,
                edge_density: 0.0,  // Would require edge detection
                motion_intensity: 0.0,  // Would require motion vectors
                depth_complexity: 0.0,  // Would require depth buffer
                sky_coverage: 0.0,  // Would require semantic segmentation
                shadow_coverage,
                highlight_coverage,
            }
        }

        /// Estimate color temperature from dominant colors
        fn estimate_color_temperature(&self, colors: &[(RGB, f32)]) -> f32 {
            if colors.is_empty() { return 6500.0; }

            let mut weighted_temp = 0.0;
            let mut total_weight = 0.0;

            for (color, weight) in colors {
                // McCamy's formula approximation
                let n = (color.r - 0.3320) / (color.g - 0.1858);
                let cct = -449.0 * n * n * n + 3525.0 * n * n - 6823.3 * n + 5520.33;
                weighted_temp += cct * weight;
                total_weight += weight;
            }

            (weighted_temp / total_weight).clamp(1000.0, 40000.0)
        }

        /// Classify the scene type based on characteristics
        pub fn classify_scene(&self, chars: &SceneCharacteristics) -> AnalysisSceneType {
            // Simple heuristic classification
            if chars.average_luminance < 0.1 {
                if chars.saturation_level < 0.1 {
                    return AnalysisSceneType::Space;
                }
                return AnalysisSceneType::ExteriorNight;
            }

            if chars.color_temperature < 3500.0 && chars.highlight_coverage > 0.1 {
                return AnalysisSceneType::Sunset;
            }

            if chars.saturation_level < 0.15 && chars.color_temperature > 7000.0 {
                return AnalysisSceneType::Overcast;
            }

            if chars.dominant_colors.len() > 0 {
                let (primary, _) = &chars.dominant_colors[0];
                if primary.b > primary.r * 1.5 && primary.b > primary.g {
                    return AnalysisSceneType::Underwater;
                }
                if primary.g > primary.r * 1.3 && primary.g > primary.b {
                    return AnalysisSceneType::Forest;
                }
                if primary.r > 0.7 && primary.g > 0.6 && primary.b < 0.4 {
                    return AnalysisSceneType::Desert;
                }
            }

            if chars.average_luminance > 0.7 && chars.saturation_level < 0.2 {
                return AnalysisSceneType::Snow;
            }

            if chars.contrast_ratio > 10.0 {
                return AnalysisSceneType::Urban;
            }

            AnalysisSceneType::ExteriorDay
        }

        /// Suggest preset adjustments based on scene analysis
        pub fn suggest_adjustments(&self, chars: &SceneCharacteristics) -> PresetAdjustments {
            let scene_type = self.classify_scene(chars);

            let mut adjustments = PresetAdjustments::default();

            // Exposure compensation
            adjustments.exposure_offset = (0.5 - chars.average_luminance) * 2.0;

            // Contrast adjustment
            if chars.contrast_ratio < 5.0 {
                adjustments.contrast_multiplier = 1.2;
            } else if chars.contrast_ratio > 20.0 {
                adjustments.contrast_multiplier = 0.85;
            }

            // Color temperature correction
            if chars.color_temperature < 4000.0 {
                adjustments.temperature_offset = (5500.0 - chars.color_temperature) / 100.0;
            } else if chars.color_temperature > 8000.0 {
                adjustments.temperature_offset = (5500.0 - chars.color_temperature) / 100.0;
            }

            // Saturation adjustment
            if chars.saturation_level < 0.2 {
                adjustments.saturation_offset = 0.1;
            } else if chars.saturation_level > 0.6 {
                adjustments.saturation_offset = -0.1;
            }

            // Scene-specific adjustments
            match scene_type {
                AnalysisSceneType::ExteriorNight => {
                    adjustments.exposure_offset += 0.5;
                    adjustments.shadow_lift = 0.1;
                },
                AnalysisSceneType::Sunset => {
                    adjustments.vibrance_offset = 0.15;
                    adjustments.highlight_recovery = 0.2;
                },
                AnalysisSceneType::Snow => {
                    adjustments.highlight_recovery = 0.3;
                    adjustments.exposure_offset -= 0.3;
                },
                AnalysisSceneType::Underwater => {
                    adjustments.temperature_offset = 30.0;
                    adjustments.tint_offset = -10.0;
                },
                _ => {},
            }

            adjustments
        }

        /// Get temporal luminance adaptation target
        pub fn get_adaptation_target(&self) -> f32 {
            if self.luminance_history.is_empty() {
                return 0.5;
            }
            let sum: f32 = self.luminance_history.iter().sum();
            sum / self.luminance_history.len() as f32
        }
    }

    /// Suggested preset adjustments from scene analysis
    #[derive(Debug, Clone, Default)]
    pub struct PresetAdjustments {
        pub exposure_offset: f32,
        pub contrast_multiplier: f32,
        pub saturation_offset: f32,
        pub vibrance_offset: f32,
        pub temperature_offset: f32,
        pub tint_offset: f32,
        pub shadow_lift: f32,
        pub highlight_recovery: f32,
    }

    impl PresetAdjustments {
        /// Apply adjustments to a preset
        pub fn apply_to(&self, preset: &mut NovaPreset) {
            preset.color.exposure += self.exposure_offset;
            preset.color.contrast *= self.contrast_multiplier.max(0.5).min(2.0);
            preset.color.saturation += self.saturation_offset;
            preset.color.vibrance += self.vibrance_offset;
            preset.color.temperature += self.temperature_offset;
            preset.color.tint += self.tint_offset;
            preset.color.shadows_lift.r += self.shadow_lift;
            preset.color.shadows_lift.g += self.shadow_lift;
            preset.color.shadows_lift.b += self.shadow_lift;
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEATHER INTEGRATION SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Weather-aware preset adaptation
pub mod weather {
    use super::*;

    /// Weather condition types
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum WeatherCondition {
        Clear,
        PartlyCloudy,
        Overcast,
        LightRain,
        HeavyRain,
        Thunderstorm,
        LightSnow,
        HeavySnow,
        Blizzard,
        Fog,
        Mist,
        Haze,
        Sandstorm,
        Windy,
    }

    /// Complete weather state
    #[derive(Debug, Clone)]
    pub struct WeatherState {
        pub condition: WeatherCondition,
        pub cloud_coverage: f32,        // 0.0 - 1.0
        pub precipitation_intensity: f32,
        pub fog_density: f32,           // 0.0 - 1.0
        pub wind_speed: f32,            // m/s
        pub wind_direction: f32,        // degrees
        pub temperature: f32,           // Celsius
        pub humidity: f32,              // 0.0 - 1.0
        pub visibility: f32,            // meters
        pub sun_position: (f32, f32),   // (altitude, azimuth)
    }

    impl WeatherState {
        pub fn clear_day() -> Self {
            Self {
                condition: WeatherCondition::Clear,
                cloud_coverage: 0.1,
                precipitation_intensity: 0.0,
                fog_density: 0.0,
                wind_speed: 5.0,
                wind_direction: 180.0,
                temperature: 22.0,
                humidity: 0.4,
                visibility: 50000.0,
                sun_position: (60.0, 180.0),
            }
        }

        pub fn overcast() -> Self {
            Self {
                condition: WeatherCondition::Overcast,
                cloud_coverage: 0.95,
                precipitation_intensity: 0.0,
                fog_density: 0.1,
                wind_speed: 8.0,
                wind_direction: 270.0,
                temperature: 15.0,
                humidity: 0.7,
                visibility: 10000.0,
                sun_position: (45.0, 180.0),
            }
        }

        pub fn rainy() -> Self {
            Self {
                condition: WeatherCondition::HeavyRain,
                cloud_coverage: 1.0,
                precipitation_intensity: 0.8,
                fog_density: 0.2,
                wind_speed: 15.0,
                wind_direction: 225.0,
                temperature: 12.0,
                humidity: 0.95,
                visibility: 3000.0,
                sun_position: (30.0, 180.0),
            }
        }

        pub fn foggy() -> Self {
            Self {
                condition: WeatherCondition::Fog,
                cloud_coverage: 0.5,
                precipitation_intensity: 0.0,
                fog_density: 0.8,
                wind_speed: 2.0,
                wind_direction: 0.0,
                temperature: 8.0,
                humidity: 0.98,
                visibility: 200.0,
                sun_position: (25.0, 90.0),
            }
        }

        pub fn snowy() -> Self {
            Self {
                condition: WeatherCondition::HeavySnow,
                cloud_coverage: 0.9,
                precipitation_intensity: 0.6,
                fog_density: 0.3,
                wind_speed: 10.0,
                wind_direction: 315.0,
                temperature: -5.0,
                humidity: 0.85,
                visibility: 1000.0,
                sun_position: (20.0, 180.0),
            }
        }
    }

    /// Weather preset adapter
    pub struct WeatherAdapter {
        pub current_weather: WeatherState,
        pub transition_speed: f32,
        cached_adjustments: WeatherPresetAdjustments,
    }

    impl WeatherAdapter {
        pub fn new() -> Self {
            Self {
                current_weather: WeatherState::clear_day(),
                transition_speed: 0.1,
                cached_adjustments: WeatherPresetAdjustments::default(),
            }
        }

        /// Update the current weather state
        pub fn set_weather(&mut self, weather: WeatherState) {
            self.current_weather = weather;
            self.cached_adjustments = self.calculate_adjustments();
        }

        /// Calculate preset adjustments for current weather
        fn calculate_adjustments(&self) -> WeatherPresetAdjustments {
            let w = &self.current_weather;
            let mut adj = WeatherPresetAdjustments::default();

            // Cloud coverage reduces contrast and saturation
            adj.contrast_reduction = w.cloud_coverage * 0.2;
            adj.saturation_reduction = w.cloud_coverage * 0.15;

            // Fog affects visibility and adds desaturation
            adj.fog_intensity = w.fog_density;
            adj.fog_color = RGB::new(0.7, 0.75, 0.8);
            adj.saturation_reduction += w.fog_density * 0.3;

            // Rain adds wetness effects
            if w.precipitation_intensity > 0.0 {
                adj.wetness = w.precipitation_intensity;
                adj.specular_boost = w.precipitation_intensity * 0.5;
                adj.ripple_intensity = w.precipitation_intensity * 0.8;
            }

            // Snow increases brightness and reduces color temperature
            if matches!(w.condition, WeatherCondition::LightSnow | WeatherCondition::HeavySnow | WeatherCondition::Blizzard) {
                adj.brightness_boost = 0.2 * w.precipitation_intensity;
                adj.temperature_shift = -15.0;
                adj.snow_coverage = w.precipitation_intensity;
            }

            // Sandstorm adds warm color cast
            if w.condition == WeatherCondition::Sandstorm {
                adj.color_overlay = Some(RGB::new(0.9, 0.7, 0.4));
                adj.overlay_intensity = 0.3;
                adj.visibility_reduction = 0.7;
            }

            // Sun position affects lighting
            let sun_alt = w.sun_position.0;
            if sun_alt < 15.0 && sun_alt > -10.0 {
                // Golden hour
                adj.temperature_shift += 25.0;
                adj.saturation_reduction -= 0.1;
            } else if sun_alt <= -10.0 {
                // Night
                adj.brightness_reduction = 0.8;
                adj.temperature_shift -= 20.0;
            }

            adj
        }

        /// Apply weather adjustments to a preset
        pub fn apply_to_preset(&self, preset: &mut NovaPreset) {
            let adj = &self.cached_adjustments;

            preset.color.contrast *= 1.0 - adj.contrast_reduction;
            preset.color.saturation -= adj.saturation_reduction;
            preset.color.temperature += adj.temperature_shift;
            preset.color.exposure += adj.brightness_boost - adj.brightness_reduction;

            // Weather effects
            preset.effects.fog_enabled = adj.fog_intensity > 0.01;
            preset.effects.fog_density = adj.fog_intensity;
            preset.effects.fog_color = adj.fog_color;

            preset.effects.wetness = adj.wetness;
            preset.effects.rain_ripples = adj.ripple_intensity;

            if let Some(overlay) = adj.color_overlay {
                preset.color.highlights_tint = RGB::new(
                    lerp(preset.color.highlights_tint.r, overlay.r, adj.overlay_intensity),
                    lerp(preset.color.highlights_tint.g, overlay.g, adj.overlay_intensity),
                    lerp(preset.color.highlights_tint.b, overlay.b, adj.overlay_intensity),
                );
            }
        }

        /// Get particle effects parameters based on weather
        pub fn get_particle_params(&self) -> WeatherParticles {
            let w = &self.current_weather;

            match w.condition {
                WeatherCondition::LightRain => WeatherParticles {
                    particle_type: ParticleType::Rain,
                    density: 500.0,
                    size: 0.02,
                    velocity: (0.0, -10.0, 0.0),
                    wind_influence: 0.3,
                    splash_enabled: true,
                },
                WeatherCondition::HeavyRain | WeatherCondition::Thunderstorm => WeatherParticles {
                    particle_type: ParticleType::Rain,
                    density: 2000.0,
                    size: 0.03,
                    velocity: (0.0, -15.0, 0.0),
                    wind_influence: 0.5,
                    splash_enabled: true,
                },
                WeatherCondition::LightSnow => WeatherParticles {
                    particle_type: ParticleType::Snow,
                    density: 300.0,
                    size: 0.015,
                    velocity: (0.0, -1.5, 0.0),
                    wind_influence: 0.8,
                    splash_enabled: false,
                },
                WeatherCondition::HeavySnow | WeatherCondition::Blizzard => WeatherParticles {
                    particle_type: ParticleType::Snow,
                    density: 1500.0,
                    size: 0.02,
                    velocity: (0.0, -3.0, 0.0),
                    wind_influence: 1.0,
                    splash_enabled: false,
                },
                WeatherCondition::Sandstorm => WeatherParticles {
                    particle_type: ParticleType::Dust,
                    density: 3000.0,
                    size: 0.005,
                    velocity: (5.0, -0.5, 0.0),
                    wind_influence: 1.0,
                    splash_enabled: false,
                },
                _ => WeatherParticles::none(),
            }
        }
    }

    /// Weather-based preset adjustments
    #[derive(Debug, Clone, Default)]
    pub struct WeatherPresetAdjustments {
        pub contrast_reduction: f32,
        pub saturation_reduction: f32,
        pub brightness_boost: f32,
        pub brightness_reduction: f32,
        pub temperature_shift: f32,
        pub fog_intensity: f32,
        pub fog_color: RGB,
        pub wetness: f32,
        pub specular_boost: f32,
        pub ripple_intensity: f32,
        pub snow_coverage: f32,
        pub color_overlay: Option<RGB>,
        pub overlay_intensity: f32,
        pub visibility_reduction: f32,
    }

    /// Weather particle parameters
    #[derive(Debug, Clone)]
    pub struct WeatherParticles {
        pub particle_type: ParticleType,
        pub density: f32,
        pub size: f32,
        pub velocity: (f32, f32, f32),
        pub wind_influence: f32,
        pub splash_enabled: bool,
    }

    impl WeatherParticles {
        pub fn none() -> Self {
            Self {
                particle_type: ParticleType::None,
                density: 0.0,
                size: 0.0,
                velocity: (0.0, 0.0, 0.0),
                wind_influence: 0.0,
                splash_enabled: false,
            }
        }
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum ParticleType {
        None,
        Rain,
        Snow,
        Dust,
        Leaves,
        Pollen,
        Ash,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VERSIONING AND HISTORY
// ═══════════════════════════════════════════════════════════════════════════════

/// Version control for presets
pub mod versioning {
    use super::*;

    /// A version of a preset in history
    #[derive(Debug, Clone)]
    pub struct VersioningPresetVersion {
        pub version_id: u64,
        pub preset: NovaPreset,
        pub timestamp: u64,
        pub message: String,
        pub author: String,
        pub parent_version: Option<u64>,
        pub tags: Vec<String>,
    }

    /// Diff between two preset versions
    #[derive(Debug, Clone)]
    pub struct VersioningPresetDiff {
        pub changes: Vec<PresetChange>,
    }

    /// A single change in a preset
    #[derive(Debug, Clone)]
    pub struct PresetChange {
        pub field_path: String,
        pub old_value: String,
        pub new_value: String,
        pub change_type: ChangeType,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum ChangeType {
        Modified,
        Added,
        Removed,
    }

    /// Preset history manager
    pub struct VersioningPresetHistory {
        versions: Vec<PresetVersion>,
        current_version: u64,
        next_version_id: u64,
        max_versions: usize,
    }

    impl VersioningPresetHistory {
        pub fn new(initial_preset: NovaPreset, max_versions: usize) -> Self {
            let initial_version = PresetVersion {
                version_id: 0,
                preset: initial_preset,
                timestamp: Self::current_timestamp(),
                message: "Initial version".to_string(),
                author: "system".to_string(),
                parent_version: None,
                tags: vec!["initial".to_string()],
            };

            Self {
                versions: vec![initial_version],
                current_version: 0,
                next_version_id: 1,
                max_versions,
            }
        }

        fn current_timestamp() -> u64 {
            // In real implementation, would use system time
            0
        }

        /// Commit a new version
        pub fn commit(&mut self, preset: NovaPreset, message: &str, author: &str) -> u64 {
            let version = PresetVersion {
                version_id: self.next_version_id,
                preset,
                timestamp: Self::current_timestamp(),
                message: message.to_string(),
                author: author.to_string(),
                parent_version: Some(self.current_version),
                tags: Vec::new(),
            };

            self.versions.push(version);
            self.current_version = self.next_version_id;
            self.next_version_id += 1;

            // Prune old versions if exceeding max
            while self.versions.len() > self.max_versions {
                self.versions.remove(0);
            }

            self.current_version
        }

        /// Get a specific version
        pub fn get_version(&self, version_id: u64) -> Option<&PresetVersion> {
            self.versions.iter().find(|v| v.version_id == version_id)
        }

        /// Get the current version
        pub fn current(&self) -> Option<&PresetVersion> {
            self.get_version(self.current_version)
        }

        /// Checkout a specific version
        pub fn checkout(&mut self, version_id: u64) -> Option<&NovaPreset> {
            if self.versions.iter().any(|v| v.version_id == version_id) {
                self.current_version = version_id;
                self.get_version(version_id).map(|v| &v.preset)
            } else {
                None
            }
        }

        /// Revert to a previous version (creates new commit)
        pub fn revert(&mut self, version_id: u64, author: &str) -> Option<u64> {
            let version = self.get_version(version_id)?.clone();
            let message = format!("Revert to version {}", version_id);
            Some(self.commit(version.preset, &message, author))
        }

        /// Compare two versions
        pub fn diff(&self, from_version: u64, to_version: u64) -> Option<PresetDiff> {
            let from = self.get_version(from_version)?;
            let to = self.get_version(to_version)?;
            Some(Self::compute_diff(&from.preset, &to.preset))
        }

        /// Compute diff between two presets
        fn compute_diff(from: &NovaPreset, to: &NovaPreset) -> PresetDiff {
            let mut changes = Vec::new();

            // Compare color settings
            if from.color.exposure != to.color.exposure {
                changes.push(PresetChange {
                    field_path: "color.exposure".to_string(),
                    old_value: from.color.exposure.to_string(),
                    new_value: to.color.exposure.to_string(),
                    change_type: ChangeType::Modified,
                });
            }
            if from.color.contrast != to.color.contrast {
                changes.push(PresetChange {
                    field_path: "color.contrast".to_string(),
                    old_value: from.color.contrast.to_string(),
                    new_value: to.color.contrast.to_string(),
                    change_type: ChangeType::Modified,
                });
            }
            if from.color.saturation != to.color.saturation {
                changes.push(PresetChange {
                    field_path: "color.saturation".to_string(),
                    old_value: from.color.saturation.to_string(),
                    new_value: to.color.saturation.to_string(),
                    change_type: ChangeType::Modified,
                });
            }
            if from.color.temperature != to.color.temperature {
                changes.push(PresetChange {
                    field_path: "color.temperature".to_string(),
                    old_value: from.color.temperature.to_string(),
                    new_value: to.color.temperature.to_string(),
                    change_type: ChangeType::Modified,
                });
            }

            // Compare post-process settings
            if from.post_process.bloom_intensity != to.post_process.bloom_intensity {
                changes.push(PresetChange {
                    field_path: "post_process.bloom_intensity".to_string(),
                    old_value: from.post_process.bloom_intensity.to_string(),
                    new_value: to.post_process.bloom_intensity.to_string(),
                    change_type: ChangeType::Modified,
                });
            }

            // Compare effects
            if from.effects.vignette_intensity != to.effects.vignette_intensity {
                changes.push(PresetChange {
                    field_path: "effects.vignette_intensity".to_string(),
                    old_value: from.effects.vignette_intensity.to_string(),
                    new_value: to.effects.vignette_intensity.to_string(),
                    change_type: ChangeType::Modified,
                });
            }

            PresetDiff { changes }
        }

        /// Get version history
        pub fn history(&self) -> &[PresetVersion] {
            &self.versions
        }

        /// Tag a version
        pub fn tag_version(&mut self, version_id: u64, tag: &str) {
            if let Some(version) = self.versions.iter_mut().find(|v| v.version_id == version_id) {
                if !version.tags.contains(&tag.to_string()) {
                    version.tags.push(tag.to_string());
                }
            }
        }

        /// Find versions by tag
        pub fn find_by_tag(&self, tag: &str) -> Vec<&PresetVersion> {
            self.versions.iter()
                .filter(|v| v.tags.contains(&tag.to_string()))
                .collect()
        }
    }

    /// Branch for parallel preset development
    #[derive(Debug, Clone)]
    pub struct PresetBranch {
        pub name: String,
        pub base_version: u64,
        pub history: VersioningPresetHistory,
    }

    /// Preset repository with branches
    pub struct VersioningPresetRepository {
        branches: HashMap<String, PresetBranch>,
        current_branch: String,
    }

    impl VersioningPresetRepository {
        pub fn new(initial_preset: NovaPreset) -> Self {
            let main_branch = PresetBranch {
                name: "main".to_string(),
                base_version: 0,
                history: PresetHistory::new(initial_preset, 100),
            };

            let mut branches = HashMap::new();
            branches.insert("main".to_string(), main_branch);

            Self {
                branches,
                current_branch: "main".to_string(),
            }
        }

        /// Create a new branch from current
        pub fn create_branch(&mut self, name: &str) -> bool {
            if self.branches.contains_key(name) {
                return false;
            }

            let current = self.branches.get(&self.current_branch).unwrap();
            let current_preset = current.history.current().unwrap().preset.clone();

            let new_branch = PresetBranch {
                name: name.to_string(),
                base_version: current.history.current_version,
                history: PresetHistory::new(current_preset, 100),
            };

            self.branches.insert(name.to_string(), new_branch);
            true
        }

        /// Switch to a branch
        pub fn checkout_branch(&mut self, name: &str) -> bool {
            if self.branches.contains_key(name) {
                self.current_branch = name.to_string();
                true
            } else {
                false
            }
        }

        /// Get current branch
        pub fn current_branch(&self) -> &PresetBranch {
            self.branches.get(&self.current_branch).unwrap()
        }

        /// Get current branch mutably
        pub fn current_branch_mut(&mut self) -> &mut PresetBranch {
            self.branches.get_mut(&self.current_branch).unwrap()
        }

        /// List all branches
        pub fn list_branches(&self) -> Vec<&str> {
            self.branches.keys().map(|s| s.as_str()).collect()
        }

        /// Delete a branch
        pub fn delete_branch(&mut self, name: &str) -> bool {
            if name == "main" || name == &self.current_branch {
                return false;
            }
            self.branches.remove(name).is_some()
        }

        /// Merge a branch into current
        pub fn merge(&mut self, from_branch: &str, author: &str) -> Result<u64, String> {
            if from_branch == self.current_branch {
                return Err("Cannot merge branch into itself".to_string());
            }

            let from = self.branches.get(from_branch)
                .ok_or("Source branch not found")?;
            let from_preset = from.history.current()
                .ok_or("Source branch has no commits")?
                .preset.clone();

            let message = format!("Merge branch '{}' into '{}'", from_branch, self.current_branch);
            let current = self.branches.get_mut(&self.current_branch).unwrap();

            Ok(current.history.commit(from_preset, &message, author))
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPORT/IMPORT FORMATS
// ═══════════════════════════════════════════════════════════════════════════════

/// Format converters for external preset formats
pub mod formats {
    use super::*;

    /// Supported export formats
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum FormatExportFormat {
        NovaJson,
        NovaBinary,
        ReShade,
        ENBSeries,
        UnrealEngine,
        Unity,
        DaVinciResolve,
        AdobePremiere,
        Photoshop,
        Lightroom,
    }

    /// Format converter trait
    pub trait FormatConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String>;
        fn import(&self, data: &[u8]) -> Result<NovaPreset, String>;
        fn format(&self) -> FormatExportFormat;
        fn file_extension(&self) -> &str;
    }

    /// JSON format converter
    pub struct JsonConverter {
        pub pretty_print: bool,
    }

    impl JsonConverter {
        pub fn new(pretty_print: bool) -> Self {
            Self { pretty_print }
        }

        fn preset_to_json(&self, preset: &NovaPreset) -> String {
            let mut json = String::new();
            json.push_str("{\n");
            json.push_str(&format!("  \"metadata\": {{\n"));
            json.push_str(&format!("    \"id\": \"{}\",\n", preset.metadata.id));
            json.push_str(&format!("    \"name\": \"{}\",\n", preset.metadata.name));
            json.push_str(&format!("    \"description\": \"{}\",\n", preset.metadata.description));
            json.push_str(&format!("    \"author\": \"{}\",\n", preset.metadata.author));
            json.push_str(&format!("    \"version\": \"{}\"\n", preset.metadata.version));
            json.push_str("  },\n");
            json.push_str("  \"color\": {\n");
            json.push_str(&format!("    \"exposure\": {},\n", preset.color.exposure));
            json.push_str(&format!("    \"contrast\": {},\n", preset.color.contrast));
            json.push_str(&format!("    \"saturation\": {},\n", preset.color.saturation));
            json.push_str(&format!("    \"vibrance\": {},\n", preset.color.vibrance));
            json.push_str(&format!("    \"temperature\": {},\n", preset.color.temperature));
            json.push_str(&format!("    \"tint\": {}\n", preset.color.tint));
            json.push_str("  },\n");
            json.push_str("  \"post_process\": {\n");
            json.push_str(&format!("    \"bloom_intensity\": {},\n", preset.post_process.bloom_intensity));
            json.push_str(&format!("    \"bloom_threshold\": {},\n", preset.post_process.bloom_threshold));
            json.push_str(&format!("    \"dof_enabled\": {},\n", preset.post_process.dof_enabled));
            json.push_str(&format!("    \"motion_blur_enabled\": {}\n", preset.post_process.motion_blur_enabled));
            json.push_str("  },\n");
            json.push_str("  \"effects\": {\n");
            json.push_str(&format!("    \"vignette_intensity\": {},\n", preset.effects.vignette_intensity));
            json.push_str(&format!("    \"film_grain\": {},\n", preset.effects.film_grain));
            json.push_str(&format!("    \"chromatic_aberration\": {}\n", preset.effects.chromatic_aberration));
            json.push_str("  }\n");
            json.push_str("}\n");
            json
        }
    }

    impl FormatConverter for JsonConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
            let json = self.preset_to_json(preset);
            Ok(json.into_bytes())
        }

        fn import(&self, data: &[u8]) -> Result<NovaPreset, String> {
            let text = String::from_utf8(data.to_vec())
                .map_err(|e| format!("Invalid UTF-8: {}", e))?;

            // Simple JSON parser for preset
            let mut preset = NovaPreset::default();

            // Parse name
            if let Some(start) = text.find("\"name\":") {
                let rest = &text[start + 8..];
                if let Some(end) = rest.find("\"") {
                    let start_quote = rest.find("\"").unwrap_or(0) + 1;
                    if let Some(end_quote) = rest[start_quote..].find("\"") {
                        preset.metadata.name = rest[start_quote..start_quote + end_quote].to_string();
                    }
                }
            }

            // Parse numeric values
            preset.color.exposure = Self::parse_field(&text, "exposure").unwrap_or(0.0);
            preset.color.contrast = Self::parse_field(&text, "contrast").unwrap_or(1.0);
            preset.color.saturation = Self::parse_field(&text, "saturation").unwrap_or(1.0);
            preset.color.temperature = Self::parse_field(&text, "temperature").unwrap_or(0.0);
            preset.post_process.bloom_intensity = Self::parse_field(&text, "bloom_intensity").unwrap_or(0.5);
            preset.effects.vignette_intensity = Self::parse_field(&text, "vignette_intensity").unwrap_or(0.0);

            Ok(preset)
        }

        fn format(&self) -> FormatExportFormat {
            FormatExportFormat::NovaJson
        }

        fn file_extension(&self) -> &str {
            ".nova.json"
        }
    }

    impl JsonConverter {
        fn parse_field(text: &str, field: &str) -> Option<f32> {
            let pattern = format!("\"{}\":", field);
            if let Some(start) = text.find(&pattern) {
                let rest = &text[start + pattern.len()..];
                let rest = rest.trim_start();
                let end = rest.find(|c: char| !c.is_numeric() && c != '.' && c != '-')
                    .unwrap_or(rest.len());
                rest[..end].parse().ok()
            } else {
                None
            }
        }
    }

    /// ReShade preset format converter
    pub struct ReShadeConverter;

    impl ReShadeConverter {
        pub fn new() -> Self { Self }

        fn map_tonemapper(tonemapper: &ToneMapperType) -> &'static str {
            match tonemapper {
                ToneMapperType::Reinhard => "Reinhard",
                ToneMapperType::ACES => "ACES",
                ToneMapperType::Filmic => "Filmic",
                _ => "None",
            }
        }
    }

    impl FormatConverter for ReShadeConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
            let mut ini = String::new();

            // Header
            ini.push_str("; ReShade Preset exported from Nova\n");
            ini.push_str(&format!("; Name: {}\n", preset.metadata.name));
            ini.push_str(&format!("; Author: {}\n\n", preset.metadata.author));

            // Tonemap.fx
            ini.push_str("[Tonemap.fx]\n");
            ini.push_str(&format!("Exposure={}\n", preset.color.exposure));
            ini.push_str(&format!("Contrast={}\n", preset.color.contrast));
            ini.push_str(&format!("Saturation={}\n", preset.color.saturation));
            ini.push_str(&format!("Tonemapper={}\n\n", Self::map_tonemapper(&preset.color.tonemapper)));

            // Bloom.fx
            ini.push_str("[Bloom.fx]\n");
            ini.push_str(&format!("BloomIntensity={}\n", preset.post_process.bloom_intensity));
            ini.push_str(&format!("BloomThreshold={}\n\n", preset.post_process.bloom_threshold));

            // Vignette.fx
            ini.push_str("[Vignette.fx]\n");
            ini.push_str(&format!("VignetteIntensity={}\n", preset.effects.vignette_intensity));
            ini.push_str(&format!("VignetteRatio=1.0\n\n"));

            // FilmGrain.fx
            ini.push_str("[FilmGrain.fx]\n");
            ini.push_str(&format!("GrainIntensity={}\n", preset.effects.film_grain));
            ini.push_str("GrainSize=1.6\n\n");

            // ChromaticAberration.fx
            ini.push_str("[ChromaticAberration.fx]\n");
            ini.push_str(&format!("ChromaticAberration={}\n", preset.effects.chromatic_aberration * 100.0));

            Ok(ini.into_bytes())
        }

        fn import(&self, data: &[u8]) -> Result<NovaPreset, String> {
            let text = String::from_utf8(data.to_vec())
                .map_err(|e| format!("Invalid UTF-8: {}", e))?;

            let mut preset = NovaPreset::default();
            preset.metadata.name = "Imported ReShade Preset".to_string();

            for line in text.lines() {
                let line = line.trim();
                if let Some(eq_pos) = line.find('=') {
                    let key = line[..eq_pos].trim();
                    let value = line[eq_pos + 1..].trim();

                    match key {
                        "Exposure" => preset.color.exposure = value.parse().unwrap_or(0.0),
                        "Contrast" => preset.color.contrast = value.parse().unwrap_or(1.0),
                        "Saturation" => preset.color.saturation = value.parse().unwrap_or(1.0),
                        "BloomIntensity" => preset.post_process.bloom_intensity = value.parse().unwrap_or(0.5),
                        "BloomThreshold" => preset.post_process.bloom_threshold = value.parse().unwrap_or(0.8),
                        "VignetteIntensity" => preset.effects.vignette_intensity = value.parse().unwrap_or(0.0),
                        "GrainIntensity" => preset.effects.film_grain = value.parse().unwrap_or(0.0),
                        "ChromaticAberration" => {
                            let val: f32 = value.parse().unwrap_or(0.0);
                            preset.effects.chromatic_aberration = val / 100.0;
                        },
                        _ => {},
                    }
                }
            }

            Ok(preset)
        }

        fn format(&self) -> FormatExportFormat {
            FormatExportFormat::ReShade
        }

        fn file_extension(&self) -> &str {
            ".ini"
        }
    }

    /// ENBSeries preset format converter
    pub struct ENBConverter;

    impl ENBConverter {
        pub fn new() -> Self { Self }
    }

    impl FormatConverter for ENBConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
            let mut ini = String::new();

            ini.push_str("; ENBSeries Preset exported from Nova\n\n");

            // [EFFECT]
            ini.push_str("[EFFECT]\n");
            ini.push_str("EnableBloom=true\n");
            ini.push_str("EnableLens=true\n");
            ini.push_str("EnableAdaptation=true\n\n");

            // [BLOOM]
            ini.push_str("[BLOOM]\n");
            ini.push_str(&format!("BloomAmount={:.4}\n", preset.post_process.bloom_intensity));
            ini.push_str(&format!("BloomCurve={:.4}\n", preset.post_process.bloom_threshold * 2.0));
            ini.push_str("BloomQuality=1\n\n");

            // [COLORCORRECTION]
            ini.push_str("[COLORCORRECTION]\n");
            ini.push_str(&format!("Brightness={:.4}\n", 1.0 + preset.color.exposure * 0.1));
            ini.push_str(&format!("Contrast={:.4}\n", preset.color.contrast));
            ini.push_str(&format!("Saturation={:.4}\n", preset.color.saturation));
            ini.push_str(&format!("ColorTemperature={:.4}\n", preset.color.temperature / 100.0 + 0.5));
            ini.push_str(&format!("Vibrance={:.4}\n\n", preset.color.vibrance));

            // [VIGNETTE]
            ini.push_str("[VIGNETTE]\n");
            ini.push_str(&format!("VignetteAmount={:.4}\n", preset.effects.vignette_intensity));
            ini.push_str("VignetteRadius=1.5\n\n");

            // [FILMGRAIN]
            ini.push_str("[FILMGRAIN]\n");
            ini.push_str(&format!("GrainAmount={:.4}\n", preset.effects.film_grain));
            ini.push_str("GrainSize=1.0\n");

            Ok(ini.into_bytes())
        }

        fn import(&self, data: &[u8]) -> Result<NovaPreset, String> {
            let text = String::from_utf8(data.to_vec())
                .map_err(|e| format!("Invalid UTF-8: {}", e))?;

            let mut preset = NovaPreset::default();
            preset.metadata.name = "Imported ENB Preset".to_string();

            for line in text.lines() {
                let line = line.trim();
                if let Some(eq_pos) = line.find('=') {
                    let key = line[..eq_pos].trim();
                    let value = line[eq_pos + 1..].trim();

                    match key {
                        "BloomAmount" => preset.post_process.bloom_intensity = value.parse().unwrap_or(0.5),
                        "Brightness" => {
                            let val: f32 = value.parse().unwrap_or(1.0);
                            preset.color.exposure = (val - 1.0) * 10.0;
                        },
                        "Contrast" => preset.color.contrast = value.parse().unwrap_or(1.0),
                        "Saturation" => preset.color.saturation = value.parse().unwrap_or(1.0),
                        "Vibrance" => preset.color.vibrance = value.parse().unwrap_or(0.0),
                        "VignetteAmount" => preset.effects.vignette_intensity = value.parse().unwrap_or(0.0),
                        "GrainAmount" => preset.effects.film_grain = value.parse().unwrap_or(0.0),
                        _ => {},
                    }
                }
            }

            Ok(preset)
        }

        fn format(&self) -> FormatExportFormat {
            FormatExportFormat::ENBSeries
        }

        fn file_extension(&self) -> &str {
            ".ini"
        }
    }

    /// Unreal Engine post-process volume exporter
    pub struct UnrealConverter;

    impl UnrealConverter {
        pub fn new() -> Self { Self }
    }

    impl FormatConverter for UnrealConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
            let mut text = String::new();

            text.push_str("// Unreal Engine Post Process Settings exported from Nova\n\n");
            text.push_str("// Add these settings to your Post Process Volume Blueprint:\n\n");

            // Color grading
            text.push_str("// --- Color Grading ---\n");
            text.push_str(&format!("Settings.WhiteTemp = {:.2}f;\n", 6500.0 + preset.color.temperature * 10.0));
            text.push_str(&format!("Settings.ColorContrast = FVector4({:.3}f, {:.3}f, {:.3}f, 1.0f);\n",
                preset.color.contrast, preset.color.contrast, preset.color.contrast));
            text.push_str(&format!("Settings.ColorSaturation = FVector4({:.3}f, {:.3}f, {:.3}f, 1.0f);\n",
                preset.color.saturation, preset.color.saturation, preset.color.saturation));
            text.push_str(&format!("Settings.AutoExposureBias = {:.3}f;\n\n", preset.color.exposure));

            // Bloom
            text.push_str("// --- Bloom ---\n");
            text.push_str(&format!("Settings.BloomIntensity = {:.3}f;\n", preset.post_process.bloom_intensity * 5.0));
            text.push_str(&format!("Settings.BloomThreshold = {:.3}f;\n\n", preset.post_process.bloom_threshold));

            // Vignette
            text.push_str("// --- Vignette ---\n");
            text.push_str(&format!("Settings.VignetteIntensity = {:.3}f;\n\n", preset.effects.vignette_intensity));

            // Film
            text.push_str("// --- Film ---\n");
            text.push_str(&format!("Settings.FilmGrainIntensity = {:.3}f;\n", preset.effects.film_grain));

            Ok(text.into_bytes())
        }

        fn import(&self, _data: &[u8]) -> Result<NovaPreset, String> {
            Err("Unreal Engine import not supported".to_string())
        }

        fn format(&self) -> FormatExportFormat {
            FormatExportFormat::UnrealEngine
        }

        fn file_extension(&self) -> &str {
            ".ue.txt"
        }
    }

    /// DaVinci Resolve grade exporter
    pub struct DaVinciConverter;

    impl DaVinciConverter {
        pub fn new() -> Self { Self }
    }

    impl FormatConverter for DaVinciConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
            let mut drx = String::new();

            // DaVinci Resolve XML grade format
            drx.push_str("<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n");
            drx.push_str("<ColorGrade version=\"1.0\">\n");
            drx.push_str(&format!("  <Name>{}</Name>\n", preset.metadata.name));
            drx.push_str("  <Primaries>\n");
            drx.push_str(&format!("    <Contrast>{:.3}</Contrast>\n", preset.color.contrast));
            drx.push_str(&format!("    <Saturation>{:.3}</Saturation>\n", preset.color.saturation));
            drx.push_str(&format!("    <Exposure>{:.3}</Exposure>\n", preset.color.exposure));
            drx.push_str(&format!("    <Temperature>{:.3}</Temperature>\n", preset.color.temperature));
            drx.push_str(&format!("    <Tint>{:.3}</Tint>\n", preset.color.tint));
            drx.push_str("  </Primaries>\n");
            drx.push_str("  <Wheels>\n");
            drx.push_str(&format!("    <Lift r=\"{:.3}\" g=\"{:.3}\" b=\"{:.3}\"/>\n",
                preset.color.shadows_lift.r, preset.color.shadows_lift.g, preset.color.shadows_lift.b));
            drx.push_str(&format!("    <Gamma r=\"{:.3}\" g=\"{:.3}\" b=\"{:.3}\"/>\n",
                preset.color.midtones_gamma.r, preset.color.midtones_gamma.g, preset.color.midtones_gamma.b));
            drx.push_str(&format!("    <Gain r=\"{:.3}\" g=\"{:.3}\" b=\"{:.3}\"/>\n",
                preset.color.highlights_gain.r, preset.color.highlights_gain.g, preset.color.highlights_gain.b));
            drx.push_str("  </Wheels>\n");
            drx.push_str("</ColorGrade>\n");

            Ok(drx.into_bytes())
        }

        fn import(&self, _data: &[u8]) -> Result<NovaPreset, String> {
            Err("DaVinci Resolve import not yet implemented".to_string())
        }

        fn format(&self) -> FormatExportFormat {
            FormatExportFormat::DaVinciResolve
        }

        fn file_extension(&self) -> &str {
            ".drx"
        }
    }

    /// Photoshop/Lightroom adjustment exporter
    pub struct AdobeConverter;

    impl AdobeConverter {
        pub fn new() -> Self { Self }
    }

    impl FormatConverter for AdobeConverter {
        fn export(&self, preset: &NovaPreset) -> Result<Vec<u8>, String> {
            let mut xmp = String::new();

            xmp.push_str("<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n");
            xmp.push_str("<x:xmpmeta xmlns:x=\"adobe:ns:meta/\" x:xmptk=\"Nova Preset Export\">\n");
            xmp.push_str("  <rdf:RDF xmlns:rdf=\"http://www.w3.org/1999/02/22-rdf-syntax-ns#\">\n");
            xmp.push_str("    <rdf:Description rdf:about=\"\"\n");
            xmp.push_str("      xmlns:crs=\"http://ns.adobe.com/camera-raw-settings/1.0/\">\n");
            xmp.push_str(&format!("      <crs:Exposure2012>{:.2}</crs:Exposure2012>\n", preset.color.exposure));
            xmp.push_str(&format!("      <crs:Contrast2012>{}</crs:Contrast2012>\n", ((preset.color.contrast - 1.0) * 100.0) as i32));
            xmp.push_str(&format!("      <crs:Saturation>{}</crs:Saturation>\n", ((preset.color.saturation - 1.0) * 100.0) as i32));
            xmp.push_str(&format!("      <crs:Vibrance>{}</crs:Vibrance>\n", (preset.color.vibrance * 100.0) as i32));
            xmp.push_str(&format!("      <crs:Temperature>{}</crs:Temperature>\n", (6500.0 + preset.color.temperature * 100.0) as i32));
            xmp.push_str(&format!("      <crs:Tint>{}</crs:Tint>\n", preset.color.tint as i32));
            xmp.push_str(&format!("      <crs:PostCropVignetteAmount>{}</crs:PostCropVignetteAmount>\n",
                (preset.effects.vignette_intensity * -100.0) as i32));
            xmp.push_str(&format!("      <crs:GrainAmount>{}</crs:GrainAmount>\n", (preset.effects.film_grain * 100.0) as i32));
            xmp.push_str("    </rdf:Description>\n");
            xmp.push_str("  </rdf:RDF>\n");
            xmp.push_str("</x:xmpmeta>\n");

            Ok(xmp.into_bytes())
        }

        fn import(&self, _data: &[u8]) -> Result<NovaPreset, String> {
            Err("Adobe import not yet implemented".to_string())
        }

        fn format(&self) -> FormatExportFormat {
            FormatExportFormat::Lightroom
        }

        fn file_extension(&self) -> &str {
            ".xmp"
        }
    }

    /// Format converter factory
    pub fn get_converter(format: FormatExportFormat) -> Box<dyn FormatConverter> {
        match format {
            FormatExportFormat::NovaJson => Box::new(JsonConverter::new(true)),
            FormatExportFormat::ReShade => Box::new(ReShadeConverter::new()),
            FormatExportFormat::ENBSeries => Box::new(ENBConverter::new()),
            FormatExportFormat::UnrealEngine => Box::new(UnrealConverter::new()),
            FormatExportFormat::DaVinciResolve => Box::new(DaVinciConverter::new()),
            FormatExportFormat::Lightroom | FormatExportFormat::Photoshop | FormatExportFormat::AdobePremiere => {
                Box::new(AdobeConverter::new())
            },
            _ => Box::new(JsonConverter::new(true)),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED BLENDING MODES
// ═══════════════════════════════════════════════════════════════════════════════

/// Advanced preset blending beyond linear interpolation
pub mod blending {
    use super::*;

    /// Blending modes for presets
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum BlendMode {
        Linear,
        Smooth,         // Smoothstep
        SmoothStep,     // Ken Perlin's smootherstep
        Bezier,         // Cubic bezier
        Spring,         // Physics-based spring
        Additive,       // Add values
        Multiplicative, // Multiply values
        Screen,         // Screen blending
        Overlay,        // Overlay blending
        SoftLight,      // Soft light
        Maximum,        // Take max of each value
        Minimum,        // Take min of each value
        Difference,     // Absolute difference
        Average,        // Weighted average (same as linear)
        Geometric,      // Geometric mean
        Harmonic,       // Harmonic mean
    }

    impl BlendMode {
        /// Blend two f32 values using this mode
        pub fn blend_f32(&self, a: f32, b: f32, t: f32) -> f32 {
            match self {
                BlendMode::Linear | BlendMode::Average => lerp(a, b, t),
                BlendMode::Smooth => {
                    let t = t * t * (3.0 - 2.0 * t);
                    lerp(a, b, t)
                },
                BlendMode::SmoothStep => {
                    let t = t * t * t * (t * (t * 6.0 - 15.0) + 10.0);
                    lerp(a, b, t)
                },
                BlendMode::Bezier => {
                    // Simple ease-in-out bezier
                    let t2 = t * t;
                    let t3 = t2 * t;
                    let blend = 3.0 * t2 - 2.0 * t3;
                    lerp(a, b, blend)
                },
                BlendMode::Spring => {
                    // Damped spring oscillation
                    let omega = 10.0;
                    let zeta = 0.5;
                    let decay = (-zeta * omega * t).exp();
                    let oscillation = (omega * (1.0 - zeta * zeta).sqrt() * t).cos();
                    let spring_t = 1.0 - decay * oscillation;
                    lerp(a, b, spring_t)
                },
                BlendMode::Additive => a + b * t,
                BlendMode::Multiplicative => a * (1.0 + (b / a.max(0.001) - 1.0) * t),
                BlendMode::Screen => {
                    let screened = 1.0 - (1.0 - a) * (1.0 - b);
                    lerp(a, screened, t)
                },
                BlendMode::Overlay => {
                    let result = if a < 0.5 {
                        2.0 * a * b
                    } else {
                        1.0 - 2.0 * (1.0 - a) * (1.0 - b)
                    };
                    lerp(a, result, t)
                },
                BlendMode::SoftLight => {
                    let result = if b < 0.5 {
                        a - (1.0 - 2.0 * b) * a * (1.0 - a)
                    } else {
                        let d = if a < 0.25 {
                            ((16.0 * a - 12.0) * a + 4.0) * a
                        } else {
                            a.sqrt()
                        };
                        a + (2.0 * b - 1.0) * (d - a)
                    };
                    lerp(a, result, t)
                },
                BlendMode::Maximum => a.max(lerp(a, b, t)),
                BlendMode::Minimum => a.min(lerp(a, b, t)),
                BlendMode::Difference => lerp(a, (a - b).abs(), t),
                BlendMode::Geometric => {
                    if a > 0.0 && b > 0.0 {
                        (a.powf(1.0 - t) * b.powf(t))
                    } else {
                        lerp(a, b, t)
                    }
                },
                BlendMode::Harmonic => {
                    if a.abs() > 0.001 && b.abs() > 0.001 {
                        let ha = 1.0 / a;
                        let hb = 1.0 / b;
                        1.0 / lerp(ha, hb, t)
                    } else {
                        lerp(a, b, t)
                    }
                },
            }
        }

        /// Blend two RGB colors using this mode
        pub fn blend_rgb(&self, a: &RGB, b: &RGB, t: f32) -> RGB {
            RGB::new(
                self.blend_f32(a.r, b.r, t),
                self.blend_f32(a.g, b.g, t),
                self.blend_f32(a.b, b.b, t),
            )
        }
    }

    /// Advanced preset blender with per-parameter blend modes
    pub struct PresetBlender {
        pub color_blend: BlendMode,
        pub post_process_blend: BlendMode,
        pub effects_blend: BlendMode,
        pub lighting_blend: BlendMode,
    }

    impl Default for PresetBlender {
        fn default() -> Self {
            Self {
                color_blend: BlendMode::Smooth,
                post_process_blend: BlendMode::Linear,
                effects_blend: BlendMode::Linear,
                lighting_blend: BlendMode::Linear,
            }
        }
    }

    impl PresetBlender {
        /// Blend two presets with custom per-section blend modes
        pub fn blend(&self, a: &NovaPreset, b: &NovaPreset, t: f32) -> NovaPreset {
            let mut result = a.clone();

            // Color section
            result.color.exposure = self.color_blend.blend_f32(a.color.exposure, b.color.exposure, t);
            result.color.contrast = self.color_blend.blend_f32(a.color.contrast, b.color.contrast, t);
            result.color.saturation = self.color_blend.blend_f32(a.color.saturation, b.color.saturation, t);
            result.color.vibrance = self.color_blend.blend_f32(a.color.vibrance, b.color.vibrance, t);
            result.color.temperature = self.color_blend.blend_f32(a.color.temperature, b.color.temperature, t);
            result.color.tint = self.color_blend.blend_f32(a.color.tint, b.color.tint, t);
            result.color.shadows_lift = self.color_blend.blend_rgb(&a.color.shadows_lift, &b.color.shadows_lift, t);
            result.color.midtones_gamma = self.color_blend.blend_rgb(&a.color.midtones_gamma, &b.color.midtones_gamma, t);
            result.color.highlights_gain = self.color_blend.blend_rgb(&a.color.highlights_gain, &b.color.highlights_gain, t);

            // Post-process section
            result.post_process.bloom_intensity = self.post_process_blend.blend_f32(
                a.post_process.bloom_intensity, b.post_process.bloom_intensity, t);
            result.post_process.bloom_threshold = self.post_process_blend.blend_f32(
                a.post_process.bloom_threshold, b.post_process.bloom_threshold, t);

            // Effects section
            result.effects.vignette_intensity = self.effects_blend.blend_f32(
                a.effects.vignette_intensity, b.effects.vignette_intensity, t);
            result.effects.film_grain = self.effects_blend.blend_f32(
                a.effects.film_grain, b.effects.film_grain, t);
            result.effects.chromatic_aberration = self.effects_blend.blend_f32(
                a.effects.chromatic_aberration, b.effects.chromatic_aberration, t);

            // Lighting section
            result.lighting.sun_intensity = self.lighting_blend.blend_f32(
                a.lighting.sun_intensity, b.lighting.sun_intensity, t);
            result.lighting.ambient_intensity = self.lighting_blend.blend_f32(
                a.lighting.ambient_intensity, b.lighting.ambient_intensity, t);
            result.lighting.ambient_color = self.lighting_blend.blend_rgb(
                &a.lighting.ambient_color, &b.lighting.ambient_color, t);

            result
        }
    }

    /// Multi-preset blender for complex mixing
    pub struct MultiPresetBlender {
        presets: Vec<(NovaPreset, f32)>,  // (preset, weight)
        blend_mode: BlendMode,
        normalize_weights: bool,
    }

    impl MultiPresetBlender {
        pub fn new() -> Self {
            Self {
                presets: Vec::new(),
                blend_mode: BlendMode::Linear,
                normalize_weights: true,
            }
        }

        /// Add a preset with a weight
        pub fn add(&mut self, preset: NovaPreset, weight: f32) {
            self.presets.push((preset, weight));
        }

        /// Clear all presets
        pub fn clear(&mut self) {
            self.presets.clear();
        }

        /// Blend all presets together
        pub fn blend(&self) -> Option<NovaPreset> {
            if self.presets.is_empty() {
                return None;
            }
            if self.presets.len() == 1 {
                return Some(self.presets[0].0.clone());
            }

            // Calculate total weight
            let total_weight: f32 = if self.normalize_weights {
                self.presets.iter().map(|(_, w)| w).sum()
            } else {
                1.0
            };

            if total_weight <= 0.0 {
                return Some(self.presets[0].0.clone());
            }

            // Initialize result with first preset
            let mut result = self.presets[0].0.clone();
            let mut accumulated_weight = self.presets[0].1 / total_weight;

            // Blend in remaining presets
            for (preset, weight) in self.presets.iter().skip(1) {
                let normalized_weight = weight / total_weight;
                let blend_t = normalized_weight / (accumulated_weight + normalized_weight);

                result = blend_presets(&result, preset, blend_t);
                accumulated_weight += normalized_weight;
            }

            Some(result)
        }

        /// Get preset at index
        pub fn get(&self, index: usize) -> Option<&(NovaPreset, f32)> {
            self.presets.get(index)
        }

        /// Set weight for preset at index
        pub fn set_weight(&mut self, index: usize, weight: f32) {
            if let Some((_, w)) = self.presets.get_mut(index) {
                *w = weight;
            }
        }
    }

    /// Preset mask for selective blending
    #[derive(Debug, Clone)]
    pub struct PresetMask {
        pub color_enabled: bool,
        pub color_mask: ColorMask,
        pub post_process_enabled: bool,
        pub effects_enabled: bool,
        pub lighting_enabled: bool,
    }

    #[derive(Debug, Clone)]
    pub struct ColorMask {
        pub exposure: bool,
        pub contrast: bool,
        pub saturation: bool,
        pub vibrance: bool,
        pub temperature: bool,
        pub tint: bool,
        pub lift_gamma_gain: bool,
        pub split_toning: bool,
    }

    impl Default for PresetMask {
        fn default() -> Self {
            Self {
                color_enabled: true,
                color_mask: ColorMask::all(),
                post_process_enabled: true,
                effects_enabled: true,
                lighting_enabled: true,
            }
        }
    }

    impl ColorMask {
        pub fn all() -> Self {
            Self {
                exposure: true,
                contrast: true,
                saturation: true,
                vibrance: true,
                temperature: true,
                tint: true,
                lift_gamma_gain: true,
                split_toning: true,
            }
        }

        pub fn none() -> Self {
            Self {
                exposure: false,
                contrast: false,
                saturation: false,
                vibrance: false,
                temperature: false,
                tint: false,
                lift_gamma_gain: false,
                split_toning: false,
            }
        }
    }

    /// Masked preset blender
    pub fn blend_masked(base: &NovaPreset, overlay: &NovaPreset, t: f32, mask: &PresetMask) -> NovaPreset {
        let mut result = base.clone();

        if mask.color_enabled {
            if mask.color_mask.exposure {
                result.color.exposure = lerp(base.color.exposure, overlay.color.exposure, t);
            }
            if mask.color_mask.contrast {
                result.color.contrast = lerp(base.color.contrast, overlay.color.contrast, t);
            }
            if mask.color_mask.saturation {
                result.color.saturation = lerp(base.color.saturation, overlay.color.saturation, t);
            }
            if mask.color_mask.vibrance {
                result.color.vibrance = lerp(base.color.vibrance, overlay.color.vibrance, t);
            }
            if mask.color_mask.temperature {
                result.color.temperature = lerp(base.color.temperature, overlay.color.temperature, t);
            }
            if mask.color_mask.tint {
                result.color.tint = lerp(base.color.tint, overlay.color.tint, t);
            }
        }

        if mask.post_process_enabled {
            result.post_process.bloom_intensity = lerp(
                base.post_process.bloom_intensity, overlay.post_process.bloom_intensity, t);
            result.post_process.bloom_threshold = lerp(
                base.post_process.bloom_threshold, overlay.post_process.bloom_threshold, t);
        }

        if mask.effects_enabled {
            result.effects.vignette_intensity = lerp(
                base.effects.vignette_intensity, overlay.effects.vignette_intensity, t);
            result.effects.film_grain = lerp(
                base.effects.film_grain, overlay.effects.film_grain, t);
            result.effects.chromatic_aberration = lerp(
                base.effects.chromatic_aberration, overlay.effects.chromatic_aberration, t);
        }

        if mask.lighting_enabled {
            result.lighting.sun_intensity = lerp(
                base.lighting.sun_intensity, overlay.lighting.sun_intensity, t);
            result.lighting.ambient_intensity = lerp(
                base.lighting.ambient_intensity, overlay.lighting.ambient_intensity, t);
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET VALIDATION AND COMPATIBILITY
// ═══════════════════════════════════════════════════════════════════════════════

/// Preset validation and compatibility checking
pub mod validation {
    use super::*;

    /// Validation severity levels
    #[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
    pub enum ValidationSeverity {
        Info,
        Warning,
        Error,
    }

    /// A single validation issue
    #[derive(Debug, Clone)]
    pub struct ValidationIssue {
        pub severity: ValidationSeverity,
        pub field: String,
        pub message: String,
        pub suggestion: Option<String>,
    }

    /// Validation result
    #[derive(Debug, Clone)]
    pub struct CompatValidationResult {
        pub is_valid: bool,
        pub issues: Vec<ValidationIssue>,
    }

    impl CompatValidationResult {
        pub fn new() -> Self {
            Self { is_valid: true, issues: Vec::new() }
        }

        pub fn add_issue(&mut self, issue: ValidationIssue) {
            if issue.severity == ValidationSeverity::Error {
                self.is_valid = false;
            }
            self.issues.push(issue);
        }

        pub fn errors(&self) -> Vec<&ValidationIssue> {
            self.issues.iter()
                .filter(|i| i.severity == ValidationSeverity::Error)
                .collect()
        }

        pub fn warnings(&self) -> Vec<&ValidationIssue> {
            self.issues.iter()
                .filter(|i| i.severity == ValidationSeverity::Warning)
                .collect()
        }
    }

    /// Preset validator
    pub struct PresetValidator {
        pub strict_mode: bool,
        pub check_performance: bool,
        pub target_tier: PerformanceTier,
    }

    impl PresetValidator {
        pub fn new() -> Self {
            Self {
                strict_mode: false,
                check_performance: true,
                target_tier: PerformanceTier::Medium,
            }
        }

        /// Validate a preset
        pub fn validate(&self, preset: &NovaPreset) -> CompatValidationResult {
            let mut result = CompatValidationResult::new();

            // Metadata validation
            if preset.metadata.name.is_empty() {
                result.add_issue(ValidationIssue {
                    severity: ValidationSeverity::Error,
                    field: "metadata.name".to_string(),
                    message: "Preset name is required".to_string(),
                    suggestion: Some("Provide a descriptive name for the preset".to_string()),
                });
            }

            if preset.metadata.name.len() > 64 {
                result.add_issue(ValidationIssue {
                    severity: ValidationSeverity::Warning,
                    field: "metadata.name".to_string(),
                    message: "Preset name is very long".to_string(),
                    suggestion: Some("Consider shortening to under 64 characters".to_string()),
                });
            }

            // Color settings validation
            self.validate_range(&mut result, "color.exposure", preset.color.exposure, -10.0, 10.0);
            self.validate_range(&mut result, "color.contrast", preset.color.contrast, 0.0, 5.0);
            self.validate_range(&mut result, "color.saturation", preset.color.saturation, 0.0, 3.0);
            self.validate_range(&mut result, "color.vibrance", preset.color.vibrance, -1.0, 1.0);
            self.validate_range(&mut result, "color.temperature", preset.color.temperature, -100.0, 100.0);
            self.validate_range(&mut result, "color.tint", preset.color.tint, -100.0, 100.0);

            // Post-process validation
            self.validate_range(&mut result, "post_process.bloom_intensity",
                preset.post_process.bloom_intensity, 0.0, 2.0);
            self.validate_range(&mut result, "post_process.bloom_threshold",
                preset.post_process.bloom_threshold, 0.0, 1.0);

            // Effects validation
            self.validate_range(&mut result, "effects.vignette_intensity",
                preset.effects.vignette_intensity, 0.0, 1.0);
            self.validate_range(&mut result, "effects.film_grain",
                preset.effects.film_grain, 0.0, 1.0);
            self.validate_range(&mut result, "effects.chromatic_aberration",
                preset.effects.chromatic_aberration, 0.0, 0.1);

            // Performance check
            if self.check_performance {
                let perf_issues = self.check_performance_impact(preset);
                for issue in perf_issues {
                    result.add_issue(issue);
                }
            }

            // Strict mode checks
            if self.strict_mode {
                if preset.metadata.author.is_empty() {
                    result.add_issue(ValidationIssue {
                        severity: ValidationSeverity::Error,
                        field: "metadata.author".to_string(),
                        message: "Author is required in strict mode".to_string(),
                        suggestion: None,
                    });
                }

                if preset.metadata.description.is_empty() {
                    result.add_issue(ValidationIssue {
                        severity: ValidationSeverity::Warning,
                        field: "metadata.description".to_string(),
                        message: "Description is recommended".to_string(),
                        suggestion: Some("Add a brief description of the preset's visual style".to_string()),
                    });
                }
            }

            result
        }

        fn validate_range(&self, result: &mut CompatValidationResult, field: &str, value: f32, min: f32, max: f32) {
            if value < min || value > max {
                result.add_issue(ValidationIssue {
                    severity: if self.strict_mode { ValidationSeverity::Error } else { ValidationSeverity::Warning },
                    field: field.to_string(),
                    message: format!("Value {} is outside recommended range [{}, {}]", value, min, max),
                    suggestion: Some(format!("Consider using a value between {} and {}", min, max)),
                });
            }
        }

        fn check_performance_impact(&self, preset: &NovaPreset) -> Vec<ValidationIssue> {
            let mut issues = Vec::new();

            // Check for expensive features
            if preset.post_process.dof_enabled && self.target_tier < PerformanceTier::High {
                issues.push(ValidationIssue {
                    severity: ValidationSeverity::Warning,
                    field: "post_process.dof_enabled".to_string(),
                    message: "Depth of Field may impact performance on lower-end systems".to_string(),
                    suggestion: Some("Consider disabling for performance tier below High".to_string()),
                });
            }

            if preset.post_process.motion_blur_enabled && self.target_tier < PerformanceTier::Medium {
                issues.push(ValidationIssue {
                    severity: ValidationSeverity::Warning,
                    field: "post_process.motion_blur_enabled".to_string(),
                    message: "Motion blur may cause stuttering on low-end systems".to_string(),
                    suggestion: Some("Consider disabling for Low performance tier".to_string()),
                });
            }

            if preset.post_process.bloom_intensity > 1.0 && self.target_tier < PerformanceTier::Medium {
                issues.push(ValidationIssue {
                    severity: ValidationSeverity::Info,
                    field: "post_process.bloom_intensity".to_string(),
                    message: "High bloom intensity may slightly impact performance".to_string(),
                    suggestion: None,
                });
            }

            issues
        }

        /// Auto-fix validation issues where possible
        pub fn auto_fix(&self, preset: &mut NovaPreset) -> Vec<String> {
            let mut fixes = Vec::new();

            // Clamp values to valid ranges
            if preset.color.exposure < -10.0 || preset.color.exposure > 10.0 {
                preset.color.exposure = preset.color.exposure.clamp(-10.0, 10.0);
                fixes.push("Clamped exposure to [-10, 10]".to_string());
            }

            if preset.color.contrast < 0.0 || preset.color.contrast > 5.0 {
                preset.color.contrast = preset.color.contrast.clamp(0.0, 5.0);
                fixes.push("Clamped contrast to [0, 5]".to_string());
            }

            if preset.color.saturation < 0.0 || preset.color.saturation > 3.0 {
                preset.color.saturation = preset.color.saturation.clamp(0.0, 3.0);
                fixes.push("Clamped saturation to [0, 3]".to_string());
            }

            if preset.post_process.bloom_intensity < 0.0 {
                preset.post_process.bloom_intensity = 0.0;
                fixes.push("Set negative bloom intensity to 0".to_string());
            }

            if preset.effects.vignette_intensity < 0.0 || preset.effects.vignette_intensity > 1.0 {
                preset.effects.vignette_intensity = preset.effects.vignette_intensity.clamp(0.0, 1.0);
                fixes.push("Clamped vignette intensity to [0, 1]".to_string());
            }

            if preset.effects.film_grain < 0.0 || preset.effects.film_grain > 1.0 {
                preset.effects.film_grain = preset.effects.film_grain.clamp(0.0, 1.0);
                fixes.push("Clamped film grain to [0, 1]".to_string());
            }

            fixes
        }
    }

    /// Hardware capability checker
    #[derive(Debug, Clone)]
    pub struct HardwareCapabilities {
        pub gpu_tier: PerformanceTier,
        pub vram_mb: u32,
        pub max_texture_size: u32,
        pub supports_hdr: bool,
        pub supports_compute: bool,
        pub supports_raytracing: bool,
    }

    impl HardwareCapabilities {
        pub fn detect() -> Self {
            // In real implementation, would query GPU
            Self {
                gpu_tier: PerformanceTier::Medium,
                vram_mb: 4096,
                max_texture_size: 8192,
                supports_hdr: true,
                supports_compute: true,
                supports_raytracing: false,
            }
        }

        /// Check if preset is compatible with this hardware
        pub fn is_compatible(&self, preset: &NovaPreset) -> bool {
            preset.metadata.min_performance_tier <= self.gpu_tier
        }

        /// Get compatible display types
        pub fn compatible_display_types(&self) -> Vec<DisplayType> {
            let mut types = vec![DisplayType::SDR];
            if self.supports_hdr {
                types.push(DisplayType::HDR10);
                types.push(DisplayType::HDR10Plus);
            }
            types
        }

        /// Adapt preset to hardware capabilities
        pub fn adapt_preset(&self, preset: &NovaPreset) -> NovaPreset {
            let mut adapted = preset.clone();

            // Reduce quality for lower-tier hardware
            if self.gpu_tier < PerformanceTier::High {
                adapted.post_process.dof_enabled = false;
                adapted.effects.chromatic_aberration = 0.0;
            }

            if self.gpu_tier < PerformanceTier::Medium {
                adapted.post_process.motion_blur_enabled = false;
                adapted.post_process.bloom_intensity = (adapted.post_process.bloom_intensity * 0.5).min(0.5);
            }

            if self.gpu_tier == PerformanceTier::Potato {
                adapted.post_process.bloom_intensity = 0.0;
                adapted.effects.film_grain = 0.0;
            }

            // Adjust for VRAM constraints
            if self.vram_mb < 2048 {
                adapted.color.lut_enabled = false;
            }

            adapted
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_library_creation() {
        let library = NovaLibrary::new();
        assert!(!library.presets.is_empty());
    }
    
    #[test]
    fn test_preset_categories() {
        let library = NovaLibrary::new();
        let cinematic = library.by_category(PresetCategory::Cinematic);
        assert!(!cinematic.is_empty());
    }
    
    #[test]
    fn test_preset_blend() {
        let a = presets::cinematic_warm();
        let b = presets::cinematic_cool();
        let blended = blend_presets(&a, &b, 0.5);
        assert!(blended.color.temperature.abs() < 1.0); // Should be near zero
    }
    
    #[test]
    fn test_accessibility_presets() {
        let library = NovaLibrary::new();
        let accessible = library.by_category(PresetCategory::Accessibility);
        assert!(accessible.len() >= 6);
    }
}
