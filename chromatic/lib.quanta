// ═══════════════════════════════════════════════════════════════════════════════
// OKLAB/OKLCH COLOR SPACE
// ═══════════════════════════════════════════════════════════════════════════════

/// Oklab - Modern perceptually uniform color space by Björn Ottosson
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Oklab {
    /// Lightness (0-1)
    pub L: f64,
    /// Green-red opponent channel
    pub a: f64,
    /// Blue-yellow opponent channel
    pub b: f64,
}

/// Oklch - Cylindrical form of Oklab
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Oklch {
    /// Lightness (0-1)
    pub L: f64,
    /// Chroma (saturation)
    pub C: f64,
    /// Hue angle (0-360 degrees)
    pub h: f64,
}

impl Oklab {
    pub fn new(L: f64, a: f64, b: f64) -> Self {
        Oklab { L, a, b }
    }

    pub fn black() -> Self {
        Oklab { L: 0.0, a: 0.0, b: 0.0 }
    }

    pub fn white() -> Self {
        Oklab { L: 1.0, a: 0.0, b: 0.0 }
    }

    /// Convert from linear sRGB to Oklab
    pub fn from_linear_rgb(rgb: LinearRGB) -> Self {
        // LMS intermediate
        let l = 0.4122214708 * rgb.r + 0.5363325363 * rgb.g + 0.0514459929 * rgb.b;
        let m = 0.2119034982 * rgb.r + 0.6806995451 * rgb.g + 0.1073969566 * rgb.b;
        let s = 0.0883024619 * rgb.r + 0.2817188376 * rgb.g + 0.6299787005 * rgb.b;

        // Cube root (perceptual compression)
        let l_ = cbrt(l);
        let m_ = cbrt(m);
        let s_ = cbrt(s);

        Oklab {
            L: 0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_,
            a: 1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_,
            b: 0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_,
        }
    }

    /// Convert from Oklab to linear sRGB
    pub fn to_linear_rgb(&self) -> LinearRGB {
        let l_ = self.L + 0.3963377774 * self.a + 0.2158037573 * self.b;
        let m_ = self.L - 0.1055613458 * self.a - 0.0638541728 * self.b;
        let s_ = self.L - 0.0894841775 * self.a - 1.2914855480 * self.b;

        let l = l_ * l_ * l_;
        let m = m_ * m_ * m_;
        let s = s_ * s_ * s_;

        LinearRGB {
            r: 4.0767416621 * l - 3.3077115913 * m + 0.2309699292 * s,
            g: -1.2684380046 * l + 2.6097574011 * m - 0.3413193965 * s,
            b: -0.0041960863 * l - 0.7034186147 * m + 1.7076147010 * s,
        }
    }

    /// Convert to cylindrical Oklch
    pub fn to_oklch(&self) -> Oklch {
        let C = sqrt(self.a * self.a + self.b * self.b);
        let h = atan2(self.b, self.a) * 180.0 / PI;
        let h = if h < 0.0 { h + 360.0 } else { h };

        Oklch { L: self.L, C, h }
    }

    /// Convert from cylindrical Oklch
    pub fn from_oklch(lch: Oklch) -> Self {
        let h_rad = lch.h * PI / 180.0;
        Oklab {
            L: lch.L,
            a: lch.C * cos(h_rad),
            b: lch.C * sin(h_rad),
        }
    }

    /// Perceptual color difference
    pub fn delta_e(&self, other: &Oklab) -> f64 {
        let dL = self.L - other.L;
        let da = self.a - other.a;
        let db = self.b - other.b;
        sqrt(dL * dL + da * da + db * db)
    }

    /// Linear interpolation in Oklab space
    pub fn lerp(&self, other: &Oklab, t: f64) -> Oklab {
        Oklab {
            L: self.L + (other.L - self.L) * t,
            a: self.a + (other.a - self.a) * t,
            b: self.b + (other.b - self.b) * t,
        }
    }

    /// Check if in sRGB gamut
    pub fn in_srgb_gamut(&self) -> bool {
        let rgb = self.to_linear_rgb();
        rgb.r >= -0.0001 && rgb.r <= 1.0001 &&
        rgb.g >= -0.0001 && rgb.g <= 1.0001 &&
        rgb.b >= -0.0001 && rgb.b <= 1.0001
    }

    /// Gamut map to sRGB (preserve lightness and hue)
    pub fn gamut_map_srgb(&self) -> Oklab {
        if self.in_srgb_gamut() {
            return *self;
        }

        let lch = self.to_oklch();

        // Binary search for maximum chroma
        let mut low = 0.0;
        let mut high = lch.C;

        for _ in 0..20 {
            let mid = (low + high) / 2.0;
            let test = Oklab::from_oklch(Oklch { L: lch.L, C: mid, h: lch.h });

            if test.in_srgb_gamut() {
                low = mid;
            } else {
                high = mid;
            }
        }

        Oklab::from_oklch(Oklch { L: lch.L, C: low, h: lch.h })
    }
}

impl Oklch {
    pub fn new(L: f64, C: f64, h: f64) -> Self {
        Oklch { L, C, h }
    }

    /// Saturate/desaturate
    pub fn scale_chroma(&self, factor: f64) -> Self {
        Oklch { L: self.L, C: (self.C * factor).max(0.0), h: self.h }
    }

    /// Adjust lightness
    pub fn adjust_lightness(&self, delta: f64) -> Self {
        Oklch { L: (self.L + delta).clamp(0.0, 1.0), C: self.C, h: self.h }
    }

    /// Rotate hue
    pub fn rotate_hue(&self, degrees: f64) -> Self {
        Oklch { L: self.L, C: self.C, h: (self.h + degrees + 360.0) % 360.0 }
    }
}

fn cbrt(x: f64) -> f64 {
    if x >= 0.0 { pow(x, 1.0/3.0) } else { -pow(-x, 1.0/3.0) }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR HARMONY ALGORITHMS
// ═══════════════════════════════════════════════════════════════════════════════

/// Color harmony schemes
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum HarmonyScheme {
    Complementary,
    SplitComplementary,
    Triadic,
    Tetradic,
    Analogous,
    Square,
    Monochromatic,
}

/// Generate color harmonies in Oklch space
pub struct ColorHarmony;

impl ColorHarmony {
    /// Generate harmony colors from a base color
    pub fn generate(base: Oklch, scheme: HarmonyScheme) -> Vec<Oklch> {
        match scheme {
            HarmonyScheme::Complementary => {
                vec![base, base.rotate_hue(180.0)]
            }
            HarmonyScheme::SplitComplementary => {
                vec![
                    base,
                    base.rotate_hue(150.0),
                    base.rotate_hue(210.0),
                ]
            }
            HarmonyScheme::Triadic => {
                vec![
                    base,
                    base.rotate_hue(120.0),
                    base.rotate_hue(240.0),
                ]
            }
            HarmonyScheme::Tetradic => {
                vec![
                    base,
                    base.rotate_hue(60.0),
                    base.rotate_hue(180.0),
                    base.rotate_hue(240.0),
                ]
            }
            HarmonyScheme::Analogous => {
                vec![
                    base.rotate_hue(-30.0),
                    base.rotate_hue(-15.0),
                    base,
                    base.rotate_hue(15.0),
                    base.rotate_hue(30.0),
                ]
            }
            HarmonyScheme::Square => {
                vec![
                    base,
                    base.rotate_hue(90.0),
                    base.rotate_hue(180.0),
                    base.rotate_hue(270.0),
                ]
            }
            HarmonyScheme::Monochromatic => {
                vec![
                    Oklch { L: 0.2, C: base.C * 0.5, h: base.h },
                    Oklch { L: 0.4, C: base.C * 0.7, h: base.h },
                    base,
                    Oklch { L: 0.7, C: base.C * 0.8, h: base.h },
                    Oklch { L: 0.9, C: base.C * 0.3, h: base.h },
                ]
            }
        }
    }

    /// Generate a color palette with consistent perceived lightness
    pub fn equal_lightness_palette(base_hue: f64, count: usize, lightness: f64, chroma: f64) -> Vec<Oklch> {
        (0..count)
            .map(|i| Oklch {
                L: lightness,
                C: chroma,
                h: (base_hue + 360.0 * i as f64 / count as f64) % 360.0,
            })
            .collect()
    }

    /// Generate sequential palette (for data visualization)
    pub fn sequential_palette(base: Oklch, steps: usize) -> Vec<Oklch> {
        (0..steps)
            .map(|i| {
                let t = i as f64 / (steps - 1) as f64;
                Oklch {
                    L: 0.2 + t * 0.7,  // Light to dark
                    C: base.C * (0.3 + t * 0.7),  // Increase saturation
                    h: base.h,
                }
            })
            .collect()
    }

    /// Generate diverging palette (for data visualization)
    pub fn diverging_palette(start: Oklch, end: Oklch, steps: usize) -> Vec<Oklch> {
        let mid = steps / 2;
        let mut palette = Vec::with_capacity(steps);

        // First half: start to neutral
        for i in 0..mid {
            let t = i as f64 / mid as f64;
            palette.push(Oklch {
                L: start.L + (0.95 - start.L) * t,
                C: start.C * (1.0 - t),
                h: start.h,
            });
        }

        // Middle: neutral
        palette.push(Oklch { L: 0.95, C: 0.0, h: 0.0 });

        // Second half: neutral to end
        for i in 1..=(steps - mid - 1) {
            let t = i as f64 / (steps - mid - 1) as f64;
            palette.push(Oklch {
                L: 0.95 + (end.L - 0.95) * t,
                C: end.C * t,
                h: end.h,
            });
        }

        palette
    }

    /// Generate qualitative palette (for categorical data)
    pub fn qualitative_palette(count: usize) -> Vec<Oklch> {
        let golden_ratio = (1.0 + sqrt(5.0)) / 2.0;
        let mut hue = 0.0;

        (0..count)
            .map(|_| {
                let color = Oklch { L: 0.65, C: 0.15, h: hue };
                hue = (hue + 360.0 / golden_ratio) % 360.0;
                color
            })
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED GAMUT MAPPING
// ═══════════════════════════════════════════════════════════════════════════════

/// Cusp-based gamut mapping for high quality color conversion
pub struct CuspGamutMapper {
    target_gamut: GamutPrimaries,
    cusp_table: Vec<CuspPoint>,
}

#[derive(Clone, Copy)]
pub struct GamutPrimaries {
    pub red: (f64, f64),
    pub green: (f64, f64),
    pub blue: (f64, f64),
    pub white: (f64, f64),
}

impl GamutPrimaries {
    pub fn srgb() -> Self {
        GamutPrimaries {
            red: (0.64, 0.33),
            green: (0.30, 0.60),
            blue: (0.15, 0.06),
            white: (0.3127, 0.3290),
        }
    }

    pub fn display_p3() -> Self {
        GamutPrimaries {
            red: (0.680, 0.320),
            green: (0.265, 0.690),
            blue: (0.150, 0.060),
            white: (0.3127, 0.3290),
        }
    }

    pub fn rec2020() -> Self {
        GamutPrimaries {
            red: (0.708, 0.292),
            green: (0.170, 0.797),
            blue: (0.131, 0.046),
            white: (0.3127, 0.3290),
        }
    }

    pub fn adobe_rgb() -> Self {
        GamutPrimaries {
            red: (0.64, 0.33),
            green: (0.21, 0.71),
            blue: (0.15, 0.06),
            white: (0.3127, 0.3290),
        }
    }
}

#[derive(Clone, Copy)]
pub struct CuspPoint {
    pub hue: f64,
    pub max_chroma: f64,
    pub lightness_at_cusp: f64,
}

impl CuspGamutMapper {
    pub fn new(target: GamutPrimaries) -> Self {
        let mut mapper = CuspGamutMapper {
            target_gamut: target,
            cusp_table: Vec::with_capacity(360),
        };
        mapper.build_cusp_table();
        mapper
    }

    fn build_cusp_table(&mut self) {
        // Pre-compute cusp points for each degree of hue
        for hue_deg in 0..360 {
            let hue = hue_deg as f64;
            let cusp = self.find_cusp_at_hue(hue);
            self.cusp_table.push(cusp);
        }
    }

    fn find_cusp_at_hue(&self, hue: f64) -> CuspPoint {
        // Binary search for maximum chroma at each lightness
        let mut max_chroma = 0.0;
        let mut lightness_at_max = 0.5;

        for l_step in 0..100 {
            let L = l_step as f64 / 100.0;

            // Find max chroma at this L
            let mut low = 0.0;
            let mut high = 0.5;  // Max theoretical chroma in Oklab

            for _ in 0..20 {
                let mid = (low + high) / 2.0;
                let test = Oklab::from_oklch(Oklch { L, C: mid, h: hue });

                if test.in_srgb_gamut() {
                    low = mid;
                } else {
                    high = mid;
                }
            }

            if low > max_chroma {
                max_chroma = low;
                lightness_at_max = L;
            }
        }

        CuspPoint {
            hue,
            max_chroma,
            lightness_at_cusp: lightness_at_max,
        }
    }

    /// Map out-of-gamut color while preserving hue
    pub fn map(&self, color: Oklch) -> Oklch {
        let hue_idx = (color.h.floor() as usize) % 360;
        let cusp = &self.cusp_table[hue_idx];

        if color.C <= self.max_chroma_at(color.L, cusp) {
            return color;  // Already in gamut
        }

        // Map toward the cusp
        let max_c = self.max_chroma_at(color.L, cusp);
        Oklch { L: color.L, C: max_c * 0.99, h: color.h }
    }

    fn max_chroma_at(&self, L: f64, cusp: &CuspPoint) -> f64 {
        // Interpolate max chroma based on lightness relative to cusp
        if L <= cusp.lightness_at_cusp {
            // Below cusp: linear from black to cusp
            cusp.max_chroma * (L / cusp.lightness_at_cusp)
        } else {
            // Above cusp: linear from cusp to white
            cusp.max_chroma * (1.0 - L) / (1.0 - cusp.lightness_at_cusp)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR DIFFERENCE FORMULAS
// ═══════════════════════════════════════════════════════════════════════════════

/// Color difference calculation methods
pub mod delta_e {
    use super::*;

    /// CIE76 Delta E (Euclidean distance in L*a*b*)
    pub fn cie76(lab1: &Lab, lab2: &Lab) -> f64 {
        let dL = lab1.L - lab2.L;
        let da = lab1.a - lab2.a;
        let db = lab1.b - lab2.b;
        sqrt(dL * dL + da * da + db * db)
    }

    /// CIE94 Delta E (improved, accounts for human perception)
    pub fn cie94(lab1: &Lab, lab2: &Lab, textile: bool) -> f64 {
        let dL = lab1.L - lab2.L;
        let da = lab1.a - lab2.a;
        let db = lab1.b - lab2.b;

        let C1 = sqrt(lab1.a * lab1.a + lab1.b * lab1.b);
        let C2 = sqrt(lab2.a * lab2.a + lab2.b * lab2.b);
        let dC = C1 - C2;

        let dH_sq = da * da + db * db - dC * dC;
        let dH = if dH_sq > 0.0 { sqrt(dH_sq) } else { 0.0 };

        // Weighting factors
        let (kL, K1, K2) = if textile {
            (2.0, 0.048, 0.014)
        } else {
            (1.0, 0.045, 0.015)
        };

        let SL = 1.0;
        let SC = 1.0 + K1 * C1;
        let SH = 1.0 + K2 * C1;

        let term1 = dL / (kL * SL);
        let term2 = dC / SC;
        let term3 = dH / SH;

        sqrt(term1 * term1 + term2 * term2 + term3 * term3)
    }

    /// CIEDE2000 Delta E (most accurate, industry standard)
    pub fn ciede2000(lab1: &Lab, lab2: &Lab) -> f64 {
        let L1 = lab1.L;
        let a1 = lab1.a;
        let b1 = lab1.b;
        let L2 = lab2.L;
        let a2 = lab2.a;
        let b2 = lab2.b;

        // Weighting factors
        let kL = 1.0;
        let kC = 1.0;
        let kH = 1.0;

        // Calculate C and h
        let C1 = sqrt(a1 * a1 + b1 * b1);
        let C2 = sqrt(a2 * a2 + b2 * b2);
        let C_avg = (C1 + C2) / 2.0;

        let G = 0.5 * (1.0 - sqrt(pow(C_avg, 7.0) / (pow(C_avg, 7.0) + pow(25.0, 7.0))));

        let a1_prime = a1 * (1.0 + G);
        let a2_prime = a2 * (1.0 + G);

        let C1_prime = sqrt(a1_prime * a1_prime + b1 * b1);
        let C2_prime = sqrt(a2_prime * a2_prime + b2 * b2);

        let h1_prime = if a1_prime == 0.0 && b1 == 0.0 {
            0.0
        } else {
            let h = atan2(b1, a1_prime) * 180.0 / PI;
            if h < 0.0 { h + 360.0 } else { h }
        };

        let h2_prime = if a2_prime == 0.0 && b2 == 0.0 {
            0.0
        } else {
            let h = atan2(b2, a2_prime) * 180.0 / PI;
            if h < 0.0 { h + 360.0 } else { h }
        };

        // Calculate differences
        let dL_prime = L2 - L1;
        let dC_prime = C2_prime - C1_prime;

        let dh_prime = if C1_prime * C2_prime == 0.0 {
            0.0
        } else if abs(h2_prime - h1_prime) <= 180.0 {
            h2_prime - h1_prime
        } else if h2_prime - h1_prime > 180.0 {
            h2_prime - h1_prime - 360.0
        } else {
            h2_prime - h1_prime + 360.0
        };

        let dH_prime = 2.0 * sqrt(C1_prime * C2_prime) * sin(dh_prime * PI / 360.0);

        // Calculate averages
        let L_avg = (L1 + L2) / 2.0;
        let C_prime_avg = (C1_prime + C2_prime) / 2.0;

        let h_prime_avg = if C1_prime * C2_prime == 0.0 {
            h1_prime + h2_prime
        } else if abs(h1_prime - h2_prime) <= 180.0 {
            (h1_prime + h2_prime) / 2.0
        } else if h1_prime + h2_prime < 360.0 {
            (h1_prime + h2_prime + 360.0) / 2.0
        } else {
            (h1_prime + h2_prime - 360.0) / 2.0
        };

        // T factor
        let T = 1.0 - 0.17 * cos((h_prime_avg - 30.0) * PI / 180.0)
              + 0.24 * cos(2.0 * h_prime_avg * PI / 180.0)
              + 0.32 * cos((3.0 * h_prime_avg + 6.0) * PI / 180.0)
              - 0.20 * cos((4.0 * h_prime_avg - 63.0) * PI / 180.0);

        // SL, SC, SH
        let SL = 1.0 + (0.015 * pow(L_avg - 50.0, 2.0)) / sqrt(20.0 + pow(L_avg - 50.0, 2.0));
        let SC = 1.0 + 0.045 * C_prime_avg;
        let SH = 1.0 + 0.015 * C_prime_avg * T;

        // RT
        let dTheta = 30.0 * exp(-pow((h_prime_avg - 275.0) / 25.0, 2.0));
        let RC = 2.0 * sqrt(pow(C_prime_avg, 7.0) / (pow(C_prime_avg, 7.0) + pow(25.0, 7.0)));
        let RT = -RC * sin(2.0 * dTheta * PI / 180.0);

        // Final calculation
        let term1 = dL_prime / (kL * SL);
        let term2 = dC_prime / (kC * SC);
        let term3 = dH_prime / (kH * SH);

        sqrt(term1 * term1 + term2 * term2 + term3 * term3 + RT * term2 * term3)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CAM16 COLOR APPEARANCE MODEL
// ═══════════════════════════════════════════════════════════════════════════════

/// CAM16 viewing conditions
#[derive(Clone, Copy)]
pub struct CAM16ViewingConditions {
    /// Adapting luminance (cd/m²)
    pub L_A: f64,
    /// Background relative luminance (Y_b / Y_w)
    pub Y_b: f64,
    /// Surround factor (dim: 0.9, dark: 0.8, average: 1.0)
    pub surround: f64,
    /// Whether chromatic adaptation is complete
    pub discounting: bool,
}

impl Default for CAM16ViewingConditions {
    fn default() -> Self {
        CAM16ViewingConditions {
            L_A: 64.0,
            Y_b: 0.20,
            surround: 1.0,
            discounting: false,
        }
    }
}

/// CAM16 color appearance correlates
#[derive(Clone, Copy)]
pub struct CAM16 {
    /// Lightness
    pub J: f64,
    /// Chroma
    pub C: f64,
    /// Hue angle (degrees)
    pub h: f64,
    /// Brightness
    pub Q: f64,
    /// Colorfulness
    pub M: f64,
    /// Saturation
    pub s: f64,
}

impl CAM16 {
    /// Convert XYZ to CAM16
    pub fn from_xyz(xyz: XYZ, white: XYZ, conditions: CAM16ViewingConditions) -> Self {
        // This is a simplified implementation
        // Full CAM16 involves complex calculations

        let L_A = conditions.L_A;
        let Y_b = conditions.Y_b;
        let c = conditions.surround;

        // Chromatic adaptation
        let D = if conditions.discounting {
            1.0
        } else {
            0.4 * (1.0 - (1.0/3.6) * exp((-L_A - 42.0) / 92.0)) * c
        };
        let D = D.clamp(0.0, 1.0);

        // More CAM16 calculations would go here...
        // Returning placeholder values
        CAM16 {
            J: xyz.y * 100.0,
            C: 50.0,
            h: 0.0,
            Q: sqrt(xyz.y * 100.0),
            M: 50.0,
            s: 50.0,
        }
    }

    /// Convert CAM16 to XYZ
    pub fn to_xyz(&self, white: XYZ, conditions: CAM16ViewingConditions) -> XYZ {
        // Inverse CAM16 transformation
        XYZ { x: 0.95047 * self.J / 100.0, y: self.J / 100.0, z: 1.08883 * self.J / 100.0 }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HDR COLOR HANDLING
// ═══════════════════════════════════════════════════════════════════════════════

/// HDR color with absolute luminance
#[derive(Debug, Clone, Copy)]
pub struct HDRColor {
    pub r: f64,
    pub g: f64,
    pub b: f64,
    /// Peak luminance (cd/m² or nits)
    pub max_luminance: f64,
}

impl HDRColor {
    pub fn new(r: f64, g: f64, b: f64, max_lum: f64) -> Self {
        HDRColor { r, g, b, max_luminance: max_lum }
    }

    /// Apply PQ (Perceptual Quantizer) EOTF (ST.2084)
    pub fn to_pq(&self) -> (f64, f64, f64) {
        (pq_oetf(self.r), pq_oetf(self.g), pq_oetf(self.b))
    }

    /// Apply inverse PQ
    pub fn from_pq(r: f64, g: f64, b: f64, max_lum: f64) -> Self {
        HDRColor {
            r: pq_eotf(r),
            g: pq_eotf(g),
            b: pq_eotf(b),
            max_luminance: max_lum,
        }
    }

    /// Apply HLG (Hybrid Log-Gamma) OETF
    pub fn to_hlg(&self) -> (f64, f64, f64) {
        (hlg_oetf(self.r), hlg_oetf(self.g), hlg_oetf(self.b))
    }

    /// Apply inverse HLG
    pub fn from_hlg(r: f64, g: f64, b: f64, max_lum: f64) -> Self {
        HDRColor {
            r: hlg_eotf(r),
            g: hlg_eotf(g),
            b: hlg_eotf(b),
            max_luminance: max_lum,
        }
    }

    /// Tone map to SDR
    pub fn tonemap_to_sdr(&self, method: TonemapMethod) -> LinearRGB {
        let max_l = self.max_luminance / 10000.0;  // Normalize to 10000 nits

        let (r, g, b) = match method {
            TonemapMethod::Reinhard => (
                self.r / (1.0 + self.r),
                self.g / (1.0 + self.g),
                self.b / (1.0 + self.b),
            ),
            TonemapMethod::ReinhardExtended => {
                let white = max_l;
                (
                    self.r * (1.0 + self.r / (white * white)) / (1.0 + self.r),
                    self.g * (1.0 + self.g / (white * white)) / (1.0 + self.g),
                    self.b * (1.0 + self.b / (white * white)) / (1.0 + self.b),
                )
            }
            TonemapMethod::ACES => {
                // Simplified ACES filmic
                let a = 2.51;
                let b = 0.03;
                let c = 2.43;
                let d = 0.59;
                let e = 0.14;
                (
                    ((self.r * (a * self.r + b)) / (self.r * (c * self.r + d) + e)).clamp(0.0, 1.0),
                    ((self.g * (a * self.g + b)) / (self.g * (c * self.g + d) + e)).clamp(0.0, 1.0),
                    ((self.b * (a * self.b + b)) / (self.b * (c * self.b + d) + e)).clamp(0.0, 1.0),
                )
            }
            TonemapMethod::Hable => {
                // Uncharted 2 tonemap
                fn hable(x: f64) -> f64 {
                    let A = 0.15;
                    let B = 0.50;
                    let C = 0.10;
                    let D = 0.20;
                    let E = 0.02;
                    let F = 0.30;
                    ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F
                }
                let white_scale = 1.0 / hable(max_l);
                (
                    hable(self.r) * white_scale,
                    hable(self.g) * white_scale,
                    hable(self.b) * white_scale,
                )
            }
        };

        LinearRGB { r, g, b }
    }
}

#[derive(Clone, Copy)]
pub enum TonemapMethod {
    Reinhard,
    ReinhardExtended,
    ACES,
    Hable,
}

/// PQ (Perceptual Quantizer) OETF for encoding
fn pq_oetf(L: f64) -> f64 {
    let Y = L / 10000.0;  // Normalize to 10000 nits
    let m1 = 0.1593017578125;
    let m2 = 78.84375;
    let c1 = 0.8359375;
    let c2 = 18.8515625;
    let c3 = 18.6875;

    let Ym1 = pow(Y.max(0.0), m1);
    pow((c1 + c2 * Ym1) / (1.0 + c3 * Ym1), m2)
}

/// PQ EOTF for decoding
fn pq_eotf(E: f64) -> f64 {
    let m1 = 0.1593017578125;
    let m2 = 78.84375;
    let c1 = 0.8359375;
    let c2 = 18.8515625;
    let c3 = 18.6875;

    let E1m2 = pow(E.max(0.0), 1.0 / m2);
    let numerator = (E1m2 - c1).max(0.0);
    let denominator = c2 - c3 * E1m2;

    10000.0 * pow(numerator / denominator, 1.0 / m1)
}

/// HLG OETF
fn hlg_oetf(L: f64) -> f64 {
    let a = 0.17883277;
    let b = 0.28466892;
    let c = 0.55991073;

    if L <= 1.0 / 12.0 {
        sqrt(3.0 * L)
    } else {
        a * log(12.0 * L - b) + c
    }
}

/// HLG EOTF
fn hlg_eotf(E: f64) -> f64 {
    let a = 0.17883277;
    let b = 0.28466892;
    let c = 0.55991073;

    if E <= 0.5 {
        E * E / 3.0
    } else {
        (exp((E - c) / a) + b) / 12.0
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPECTRAL COLOR SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Spectral power distribution
#[derive(Clone)]
pub struct SpectralData {
    /// Wavelengths in nm (typically 380-780)
    pub wavelengths: Vec<f64>,
    /// Power/reflectance values at each wavelength
    pub values: Vec<f64>,
}

impl SpectralData {
    pub fn new(wavelengths: Vec<f64>, values: Vec<f64>) -> Self {
        SpectralData { wavelengths, values }
    }

    /// Sample at a specific wavelength (with interpolation)
    pub fn sample(&self, wavelength: f64) -> f64 {
        if wavelength <= self.wavelengths[0] {
            return self.values[0];
        }
        if wavelength >= *self.wavelengths.last().unwrap() {
            return *self.values.last().unwrap();
        }

        // Linear interpolation
        for i in 0..self.wavelengths.len() - 1 {
            if wavelength >= self.wavelengths[i] && wavelength < self.wavelengths[i + 1] {
                let t = (wavelength - self.wavelengths[i]) / (self.wavelengths[i + 1] - self.wavelengths[i]);
                return self.values[i] + t * (self.values[i + 1] - self.values[i]);
            }
        }

        0.0
    }

    /// Convert to XYZ using CIE color matching functions
    pub fn to_xyz(&self, illuminant: &SpectralData) -> XYZ {
        let mut X = 0.0;
        let mut Y = 0.0;
        let mut Z = 0.0;

        for i in 0..self.wavelengths.len() {
            let wl = self.wavelengths[i];
            let (x_bar, y_bar, z_bar) = cie_color_matching(wl);
            let spd = self.values[i] * illuminant.sample(wl);

            X += spd * x_bar;
            Y += spd * y_bar;
            Z += spd * z_bar;
        }

        // Normalize
        let k = 1.0 / Y;
        XYZ { x: X * k, y: Y * k, z: Z * k }
    }

    /// D65 illuminant
    pub fn d65() -> Self {
        let wavelengths: Vec<f64> = (380..=780).step_by(5).map(|w| w as f64).collect();
        let values = vec![
            49.98, 52.31, 54.65, 68.70, 82.75, 87.12, 91.49, 92.46, 93.43, 90.06,
            86.68, 95.77, 104.86, 110.94, 117.01, 117.41, 117.81, 116.34, 114.86, 115.39,
            115.92, 112.37, 108.81, 109.08, 109.35, 108.58, 107.80, 106.30, 104.79, 106.24,
            107.69, 106.05, 104.41, 104.23, 104.05, 102.02, 100.00, 98.17, 96.33, 96.06,
            95.79, 92.24, 88.69, 89.35, 90.01, 89.80, 89.60, 88.65, 87.70, 85.49,
            83.29, 83.49, 83.70, 81.86, 80.03, 80.12, 80.21, 81.25, 82.28, 80.28,
            78.28, 74.00, 69.72, 70.67, 71.61, 72.98, 74.35, 67.98, 61.60, 65.74,
            69.89, 72.49, 75.09, 69.34, 63.59, 55.01, 46.42, 56.61, 66.81, 65.09,
            63.38,
        ];
        SpectralData { wavelengths, values }
    }

    /// Multiply spectra (for reflectance * illuminant)
    pub fn multiply(&self, other: &SpectralData) -> SpectralData {
        let values: Vec<f64> = self.wavelengths.iter()
            .enumerate()
            .map(|(i, &wl)| self.values[i] * other.sample(wl))
            .collect();

        SpectralData {
            wavelengths: self.wavelengths.clone(),
            values,
        }
    }
}

/// CIE 1931 2° color matching functions (simplified lookup)
fn cie_color_matching(wavelength: f64) -> (f64, f64, f64) {
    // Gaussian approximation
    let wl = wavelength;

    let x = 1.056 * gaussian(wl, 599.8, 37.9, 31.0)
          + 0.362 * gaussian(wl, 442.0, 16.0, 26.7)
          - 0.065 * gaussian(wl, 501.1, 20.4, 26.2);

    let y = 0.821 * gaussian(wl, 568.8, 46.9, 40.5)
          + 0.286 * gaussian(wl, 530.9, 16.3, 31.1);

    let z = 1.217 * gaussian(wl, 437.0, 11.8, 36.0)
          + 0.681 * gaussian(wl, 459.0, 26.0, 13.8);

    (x.max(0.0), y.max(0.0), z.max(0.0))
}

fn gaussian(x: f64, mean: f64, sigma1: f64, sigma2: f64) -> f64 {
    let sigma = if x < mean { sigma1 } else { sigma2 };
    exp(-0.5 * pow((x - mean) / sigma, 2.0))
}

// ═══════════════════════════════════════════════════════════════════════════════
// ICC PROFILE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

enum ICCProfileClass {
    Input,
    Display,
    Output,
    DeviceLink,
    ColorSpace,
    Abstract,
    NamedColor
}

enum RenderingIntent {
    Perceptual,
    RelativeColorimetric,
    Saturation,
    AbsoluteColorimetric
}

struct ICCProfile {
    class: ICCProfileClass,
    color_space: str,
    pcs: str,  // Profile Connection Space
    version: (u8, u8, u8),
    white_point: (f64, f64, f64),
    red_primary: (f64, f64, f64),
    green_primary: (f64, f64, f64),
    blue_primary: (f64, f64, f64),
    trc_red: ToneCurve,
    trc_green: ToneCurve,
    trc_blue: ToneCurve,
    a2b_tables: Map<RenderingIntent, CLUT>,
    b2a_tables: Map<RenderingIntent, CLUT>,
    chromatic_adaptation: Matrix3x3,
    description: str,
    copyright: str
}

struct ToneCurve {
    gamma: f64?,
    curve_points: [f64]?,
    parametric: ParametricCurve?
}

struct ParametricCurve {
    function_type: u16,
    params: [f64]
}

struct CLUT {
    grid_points: [u8],
    input_curves: [[f64]],
    clut_data: [f64],
    output_curves: [[f64]]
}

impl ICCProfile {
    fn load(path: Path) -> Result<ICCProfile, ICCError> {
        let data = fs::read(path)?;
        Self::parse_icc_data(data)
    }

    fn parse_icc_data(data: [u8]) -> Result<ICCProfile, ICCError> {
        if data.len() < 128 { return Err(ICCError::InvalidHeader); }
        let profile_size = u32::from_be_bytes(data[0..4]);
        let version = (data[8], data[9], data[10]);
        let class = Self::parse_profile_class(data[12..16])?;
        // Parse tag table and extract profile data
        Self::parse_tags(data, class, version)
    }

    fn transform_color(self, color: (f64, f64, f64), intent: RenderingIntent) -> (f64, f64, f64) {
        let linearized = self.apply_input_trc(color);
        let pcs_color = self.to_pcs(linearized, intent);
        pcs_color
    }

    fn apply_input_trc(self, color: (f64, f64, f64)) -> (f64, f64, f64) {
        (
            self.trc_red.evaluate(color.0),
            self.trc_green.evaluate(color.1),
            self.trc_blue.evaluate(color.2)
        )
    }

    fn to_pcs(self, linear: (f64, f64, f64), intent: RenderingIntent) -> (f64, f64, f64) {
        match self.a2b_tables.get(intent) {
            Some(clut) => clut.interpolate(linear),
            None => self.matrix_transform(linear)
        }
    }

    fn matrix_transform(self, rgb: (f64, f64, f64)) -> (f64, f64, f64) {
        let x = self.red_primary.0 * rgb.0 + self.green_primary.0 * rgb.1 + self.blue_primary.0 * rgb.2;
        let y = self.red_primary.1 * rgb.0 + self.green_primary.1 * rgb.1 + self.blue_primary.1 * rgb.2;
        let z = self.red_primary.2 * rgb.0 + self.green_primary.2 * rgb.1 + self.blue_primary.2 * rgb.2;
        (x, y, z)
    }
}

impl ToneCurve {
    fn evaluate(self, v: f64) -> f64 {
        match self.gamma {
            Some(g) => pow(v.clamp(0.0, 1.0), g),
            None => match self.curve_points {
                Some(pts) => Self::interpolate_curve(pts, v),
                None => match self.parametric {
                    Some(p) => p.evaluate(v),
                    None => v
                }
            }
        }
    }

    fn interpolate_curve(points: [f64], v: f64) -> f64 {
        let idx = v * (points.len() - 1) as f64;
        let lo = idx.floor() as usize;
        let hi = (lo + 1).min(points.len() - 1);
        let t = idx - lo as f64;
        points[lo] * (1.0 - t) + points[hi] * t
    }
}

struct ColorTransform {
    source_profile: ICCProfile,
    dest_profile: ICCProfile,
    intent: RenderingIntent,
    black_point_compensation: bool,
    gamut_warning_color: (f64, f64, f64)?
}

impl ColorTransform {
    fn new(src: ICCProfile, dst: ICCProfile, intent: RenderingIntent) -> ColorTransform {
        ColorTransform {
            source_profile: src,
            dest_profile: dst,
            intent: intent,
            black_point_compensation: false,
            gamut_warning_color: None
        }
    }

    fn transform(self, color: (f64, f64, f64)) -> (f64, f64, f64) {
        let pcs = self.source_profile.transform_color(color, self.intent);
        let adapted = self.chromatic_adapt(pcs);
        self.dest_profile.from_pcs(adapted, self.intent)
    }

    fn chromatic_adapt(self, xyz: (f64, f64, f64)) -> (f64, f64, f64) {
        let src_wp = self.source_profile.white_point;
        let dst_wp = self.dest_profile.white_point;
        bradford_adapt(xyz, src_wp, dst_wp)
    }

    fn is_in_gamut(self, pcs_color: (f64, f64, f64)) -> bool {
        let rgb = self.dest_profile.from_pcs(pcs_color, self.intent);
        rgb.0 >= 0.0 && rgb.0 <= 1.0 &&
        rgb.1 >= 0.0 && rgb.1 <= 1.0 &&
        rgb.2 >= 0.0 && rgb.2 <= 1.0
    }
}

fn bradford_adapt(xyz: (f64, f64, f64), src_wp: (f64, f64, f64), dst_wp: (f64, f64, f64)) -> (f64, f64, f64) {
    let ma = [
        [0.8951, 0.2664, -0.1614],
        [-0.7502, 1.7135, 0.0367],
        [0.0389, -0.0685, 1.0296]
    ];
    let src_lms = matrix_mult_3(ma, xyz);
    let dst_lms = matrix_mult_3(ma, dst_wp);
    let src_wp_lms = matrix_mult_3(ma, src_wp);
    let scaled = (
        src_lms.0 * dst_lms.0 / src_wp_lms.0,
        src_lms.1 * dst_lms.1 / src_wp_lms.1,
        src_lms.2 * dst_lms.2 / src_wp_lms.2
    );
    matrix_mult_3(invert_3x3(ma), scaled)
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR BLINDNESS SIMULATION
// ═══════════════════════════════════════════════════════════════════════════════

enum ColorBlindnessType {
    Protanopia,      // No red cones
    Deuteranopia,    // No green cones
    Tritanopia,      // No blue cones
    Protanomaly,     // Weak red cones
    Deuteranomaly,   // Weak green cones
    Tritanomaly,     // Weak blue cones
    Achromatopsia,   // Complete color blindness
    BlueConeMonochromacy
}

struct ColorBlindnessSimulator {
    cvd_type: ColorBlindnessType,
    severity: f64,  // 0.0-1.0 for anomalous trichromacy
    simulation_matrix: Matrix3x3
}

impl ColorBlindnessSimulator {
    fn new(cvd_type: ColorBlindnessType) -> ColorBlindnessSimulator {
        let matrix = Self::get_simulation_matrix(cvd_type, 1.0);
        ColorBlindnessSimulator {
            cvd_type: cvd_type,
            severity: 1.0,
            simulation_matrix: matrix
        }
    }

    fn with_severity(cvd_type: ColorBlindnessType, severity: f64) -> ColorBlindnessSimulator {
        let matrix = Self::get_simulation_matrix(cvd_type, severity);
        ColorBlindnessSimulator {
            cvd_type: cvd_type,
            severity: severity.clamp(0.0, 1.0),
            simulation_matrix: matrix
        }
    }

    fn get_simulation_matrix(cvd_type: ColorBlindnessType, severity: f64) -> Matrix3x3 {
        let base = match cvd_type {
            Protanopia => Matrix3x3::new([
                [0.567, 0.433, 0.0],
                [0.558, 0.442, 0.0],
                [0.0, 0.242, 0.758]
            ]),
            Deuteranopia => Matrix3x3::new([
                [0.625, 0.375, 0.0],
                [0.7, 0.3, 0.0],
                [0.0, 0.3, 0.7]
            ]),
            Tritanopia => Matrix3x3::new([
                [0.95, 0.05, 0.0],
                [0.0, 0.433, 0.567],
                [0.0, 0.475, 0.525]
            ]),
            Achromatopsia => Matrix3x3::new([
                [0.299, 0.587, 0.114],
                [0.299, 0.587, 0.114],
                [0.299, 0.587, 0.114]
            ]),
            _ => Self::interpolate_anomaly(cvd_type, severity)
        };
        Matrix3x3::lerp(Matrix3x3::identity(), base, severity)
    }

    fn simulate(self, rgb: LinearRGB) -> LinearRGB {
        let vec = [rgb.r, rgb.g, rgb.b];
        let result = self.simulation_matrix.multiply_vec(vec);
        LinearRGB { r: result[0], g: result[1], b: result[2] }
    }

    fn daltonize(self, rgb: LinearRGB) -> LinearRGB {
        // Shift colors to improve visibility for color blind users
        let simulated = self.simulate(rgb);
        let error = (
            rgb.r - simulated.r,
            rgb.g - simulated.g,
            rgb.b - simulated.b
        );
        LinearRGB {
            r: rgb.r + error.1 * 0.7 + error.2 * 0.7,
            g: rgb.g + error.0 * 0.7 + error.2 * 0.7,
            b: rgb.b + error.0 * 0.7 + error.1 * 0.7
        }.clamp()
    }
}

struct AccessibilityChecker {
    min_contrast_ratio: f64,
    cvd_types: [ColorBlindnessType]
}

impl AccessibilityChecker {
    fn wcag_aa() -> AccessibilityChecker {
        AccessibilityChecker {
            min_contrast_ratio: 4.5,
            cvd_types: [Protanopia, Deuteranopia, Tritanopia]
        }
    }

    fn wcag_aaa() -> AccessibilityChecker {
        AccessibilityChecker {
            min_contrast_ratio: 7.0,
            cvd_types: [Protanopia, Deuteranopia, Tritanopia]
        }
    }

    fn check_contrast(self, fg: LinearRGB, bg: LinearRGB) -> ContrastResult {
        let fg_lum = relative_luminance(fg);
        let bg_lum = relative_luminance(bg);
        let ratio = (fg_lum.max(bg_lum) + 0.05) / (fg_lum.min(bg_lum) + 0.05);
        ContrastResult {
            ratio: ratio,
            passes_normal: ratio >= self.min_contrast_ratio,
            passes_large: ratio >= self.min_contrast_ratio / 1.5
        }
    }

    fn check_cvd_distinguishability(self, colors: [LinearRGB]) -> [CVDResult] {
        self.cvd_types.iter().map(|cvd| {
            let sim = ColorBlindnessSimulator::new(*cvd);
            let simulated: [LinearRGB] = colors.iter().map(|c| sim.simulate(*c)).collect();
            let min_diff = Self::min_color_difference(simulated);
            CVDResult {
                cvd_type: *cvd,
                min_difference: min_diff,
                distinguishable: min_diff > 0.05
            }
        }).collect()
    }
}

fn relative_luminance(rgb: LinearRGB) -> f64 {
    0.2126 * rgb.r + 0.7152 * rgb.g + 0.0722 * rgb.b
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED COLOR DIFFERENCE METRICS
// ═══════════════════════════════════════════════════════════════════════════════

struct ColorDifferenceMetrics;

impl ColorDifferenceMetrics {
    fn delta_e_76(lab1: LabColor, lab2: LabColor) -> f64 {
        let dl = lab1.l - lab2.l;
        let da = lab1.a - lab2.a;
        let db = lab1.b - lab2.b;
        sqrt(dl*dl + da*da + db*db)
    }

    fn delta_e_94(lab1: LabColor, lab2: LabColor, textile: bool) -> f64 {
        let (kl, k1, k2) = if textile { (2.0, 0.048, 0.014) } else { (1.0, 0.045, 0.015) };
        let dl = lab1.l - lab2.l;
        let c1 = sqrt(lab1.a*lab1.a + lab1.b*lab1.b);
        let c2 = sqrt(lab2.a*lab2.a + lab2.b*lab2.b);
        let dc = c1 - c2;
        let da = lab1.a - lab2.a;
        let db = lab1.b - lab2.b;
        let dh_sq = da*da + db*db - dc*dc;
        let dh = if dh_sq > 0.0 { sqrt(dh_sq) } else { 0.0 };
        let sc = 1.0 + k1 * c1;
        let sh = 1.0 + k2 * c1;
        sqrt(pow(dl/kl, 2.0) + pow(dc/sc, 2.0) + pow(dh/sh, 2.0))
    }

    fn delta_e_2000(lab1: LabColor, lab2: LabColor) -> f64 {
        let kl = 1.0; let kc = 1.0; let kh = 1.0;
        let c1 = sqrt(lab1.a*lab1.a + lab1.b*lab1.b);
        let c2 = sqrt(lab2.a*lab2.a + lab2.b*lab2.b);
        let c_avg = (c1 + c2) / 2.0;
        let g = 0.5 * (1.0 - sqrt(pow(c_avg, 7.0) / (pow(c_avg, 7.0) + pow(25.0, 7.0))));
        let a1_prime = lab1.a * (1.0 + g);
        let a2_prime = lab2.a * (1.0 + g);
        let c1_prime = sqrt(a1_prime*a1_prime + lab1.b*lab1.b);
        let c2_prime = sqrt(a2_prime*a2_prime + lab2.b*lab2.b);
        let h1_prime = atan2(lab1.b, a1_prime).to_degrees();
        let h2_prime = atan2(lab2.b, a2_prime).to_degrees();
        let h1_norm = if h1_prime < 0.0 { h1_prime + 360.0 } else { h1_prime };
        let h2_norm = if h2_prime < 0.0 { h2_prime + 360.0 } else { h2_prime };
        let dl_prime = lab2.l - lab1.l;
        let dc_prime = c2_prime - c1_prime;
        let dh_prime = Self::compute_dh_prime(h1_norm, h2_norm, c1_prime, c2_prime);
        let dh_big = 2.0 * sqrt(c1_prime * c2_prime) * sin(dh_prime.to_radians() / 2.0);
        let l_avg = (lab1.l + lab2.l) / 2.0;
        let c_avg_prime = (c1_prime + c2_prime) / 2.0;
        let h_avg_prime = Self::compute_h_avg(h1_norm, h2_norm, c1_prime, c2_prime);
        let t = 1.0 - 0.17*cos((h_avg_prime - 30.0).to_radians())
              + 0.24*cos((2.0*h_avg_prime).to_radians())
              + 0.32*cos((3.0*h_avg_prime + 6.0).to_radians())
              - 0.20*cos((4.0*h_avg_prime - 63.0).to_radians());
        let sl = 1.0 + (0.015 * pow(l_avg - 50.0, 2.0)) / sqrt(20.0 + pow(l_avg - 50.0, 2.0));
        let sc = 1.0 + 0.045 * c_avg_prime;
        let sh = 1.0 + 0.015 * c_avg_prime * t;
        let rc = 2.0 * sqrt(pow(c_avg_prime, 7.0) / (pow(c_avg_prime, 7.0) + pow(25.0, 7.0)));
        let dt = 30.0 * exp(-pow((h_avg_prime - 275.0) / 25.0, 2.0));
        let rt = -rc * sin((2.0 * dt).to_radians());
        sqrt(pow(dl_prime/(kl*sl), 2.0) + pow(dc_prime/(kc*sc), 2.0) +
             pow(dh_big/(kh*sh), 2.0) + rt*(dc_prime/(kc*sc))*(dh_big/(kh*sh)))
    }

    fn delta_e_cmc(lab1: LabColor, lab2: LabColor, l: f64, c: f64) -> f64 {
        let c1 = sqrt(lab1.a*lab1.a + lab1.b*lab1.b);
        let c2 = sqrt(lab2.a*lab2.a + lab2.b*lab2.b);
        let h1 = atan2(lab1.b, lab1.a).to_degrees();
        let h1_norm = if h1 < 0.0 { h1 + 360.0 } else { h1 };
        let dl = lab1.l - lab2.l;
        let dc = c1 - c2;
        let da = lab1.a - lab2.a;
        let db = lab1.b - lab2.b;
        let dh = sqrt((da*da + db*db - dc*dc).max(0.0));
        let f = sqrt(pow(c1, 4.0) / (pow(c1, 4.0) + 1900.0));
        let t = if h1_norm >= 164.0 && h1_norm <= 345.0 {
            0.56 + (0.2 * cos((h1_norm + 168.0).to_radians())).abs()
        } else {
            0.36 + (0.4 * cos((h1_norm + 35.0).to_radians())).abs()
        };
        let sl = if lab1.l < 16.0 { 0.511 } else { 0.040975 * lab1.l / (1.0 + 0.01765 * lab1.l) };
        let sc = 0.0638 * c1 / (1.0 + 0.0131 * c1) + 0.638;
        let sh = sc * (f * t + 1.0 - f);
        sqrt(pow(dl/(l*sl), 2.0) + pow(dc/(c*sc), 2.0) + pow(dh/sh, 2.0))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// METAMERISM DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

struct Illuminant {
    name: str,
    spd: [f64; 81],  // 380-780nm at 5nm intervals
    white_point: (f64, f64, f64)
}

impl Illuminant {
    fn d50() -> Illuminant {
        Illuminant {
            name: "D50",
            spd: Self::cie_d_series(5000.0),
            white_point: (0.9642, 1.0, 0.8251)
        }
    }

    fn d65() -> Illuminant {
        Illuminant {
            name: "D65",
            spd: Self::cie_d_series(6500.0),
            white_point: (0.95047, 1.0, 1.08883)
        }
    }

    fn a() -> Illuminant {
        let spd = (0..81).map(|i| {
            let wl = 380.0 + i as f64 * 5.0;
            Self::planckian(wl, 2856.0)
        }).collect();
        Illuminant { name: "A", spd: spd, white_point: (1.0985, 1.0, 0.3558) }
    }

    fn f11() -> Illuminant {
        Illuminant {
            name: "F11",
            spd: Self::fluorescent_f11_spd(),
            white_point: (1.00962, 1.0, 0.64350)
        }
    }
}

struct MetamerismIndex {
    illuminant_pair: (Illuminant, Illuminant),
    reference_observer: str
}

impl MetamerismIndex {
    fn compute(self, spectral1: SpectralReflectance, spectral2: SpectralReflectance) -> f64 {
        let xyz1_ill1 = spectral1.to_xyz(self.illuminant_pair.0);
        let xyz2_ill1 = spectral2.to_xyz(self.illuminant_pair.0);
        let xyz1_ill2 = spectral1.to_xyz(self.illuminant_pair.1);
        let xyz2_ill2 = spectral2.to_xyz(self.illuminant_pair.1);
        let lab1_ill1 = xyz_to_lab(xyz1_ill1, self.illuminant_pair.0.white_point);
        let lab2_ill1 = xyz_to_lab(xyz2_ill1, self.illuminant_pair.0.white_point);
        let lab1_ill2 = xyz_to_lab(xyz1_ill2, self.illuminant_pair.1.white_point);
        let lab2_ill2 = xyz_to_lab(xyz2_ill2, self.illuminant_pair.1.white_point);
        let de_ill1 = ColorDifferenceMetrics::delta_e_2000(lab1_ill1, lab2_ill1);
        let de_ill2 = ColorDifferenceMetrics::delta_e_2000(lab1_ill2, lab2_ill2);
        (de_ill2 - de_ill1).abs()
    }

    fn special_metamerism_index(spectral: SpectralReflectance, illuminants: [Illuminant]) -> [f64] {
        let reference = illuminants[0];
        let ref_xyz = spectral.to_xyz(reference);
        illuminants[1..].iter().map(|ill| {
            let test_xyz = spectral.to_xyz(*ill);
            let ref_lab = xyz_to_lab(ref_xyz, reference.white_point);
            let test_lab = xyz_to_lab(test_xyz, ill.white_point);
            ColorDifferenceMetrics::delta_e_2000(ref_lab, test_lab)
        }).collect()
    }
}

struct SpectralReflectance {
    wavelengths: [f64],
    reflectance: [f64]
}

impl SpectralReflectance {
    fn to_xyz(self, illuminant: Illuminant) -> (f64, f64, f64) {
        let mut x = 0.0; let mut y = 0.0; let mut z = 0.0;
        let mut k = 0.0;
        for i in 0..self.wavelengths.len() {
            let wl = self.wavelengths[i];
            let r = self.reflectance[i];
            let s = illuminant.sample_spd(wl);
            let (xbar, ybar, zbar) = cie_1931_observer(wl);
            x += s * r * xbar;
            y += s * r * ybar;
            z += s * r * zbar;
            k += s * ybar;
        }
        (x / k, y / k, z / k)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR ADAPTATION MODELS
// ═══════════════════════════════════════════════════════════════════════════════

enum ChromaticAdaptationMethod {
    VonKries,
    Bradford,
    CAT02,
    CAT16,
    Sharp
}

struct ChromaticAdaptation {
    method: ChromaticAdaptationMethod,
    source_white: (f64, f64, f64),
    dest_white: (f64, f64, f64),
    degree: f64
}

impl ChromaticAdaptation {
    fn new(method: ChromaticAdaptationMethod, src: (f64, f64, f64), dst: (f64, f64, f64)) -> ChromaticAdaptation {
        ChromaticAdaptation {
            method: method,
            source_white: src,
            dest_white: dst,
            degree: 1.0
        }
    }

    fn get_transform_matrix(self) -> Matrix3x3 {
        let ma = self.cone_response_matrix();
        let ma_inv = ma.invert();
        let src_lms = ma.multiply_vec([self.source_white.0, self.source_white.1, self.source_white.2]);
        let dst_lms = ma.multiply_vec([self.dest_white.0, self.dest_white.1, self.dest_white.2]);
        let scale = Matrix3x3::diagonal([
            Self::adapt_component(dst_lms[0] / src_lms[0], self.degree),
            Self::adapt_component(dst_lms[1] / src_lms[1], self.degree),
            Self::adapt_component(dst_lms[2] / src_lms[2], self.degree)
        ]);
        ma_inv.multiply(scale).multiply(ma)
    }

    fn cone_response_matrix(self) -> Matrix3x3 {
        match self.method {
            VonKries => Matrix3x3::new([
                [0.40024, 0.70760, -0.08081],
                [-0.22630, 1.16532, 0.04570],
                [0.0, 0.0, 0.91822]
            ]),
            Bradford => Matrix3x3::new([
                [0.8951, 0.2664, -0.1614],
                [-0.7502, 1.7135, 0.0367],
                [0.0389, -0.0685, 1.0296]
            ]),
            CAT02 => Matrix3x3::new([
                [0.7328, 0.4296, -0.1624],
                [-0.7036, 1.6975, 0.0061],
                [0.0030, 0.0136, 0.9834]
            ]),
            CAT16 => Matrix3x3::new([
                [0.401288, 0.650173, -0.051461],
                [-0.250268, 1.204414, 0.045854],
                [-0.002079, 0.048952, 0.953127]
            ]),
            Sharp => Matrix3x3::new([
                [1.2694, -0.0988, -0.1706],
                [-0.8364, 1.8006, 0.0357],
                [0.0297, -0.0315, 1.0018]
            ])
        }
    }

    fn adapt(self, xyz: (f64, f64, f64)) -> (f64, f64, f64) {
        let mat = self.get_transform_matrix();
        let result = mat.multiply_vec([xyz.0, xyz.1, xyz.2]);
        (result[0], result[1], result[2])
    }
}

// CIECAM02 Appearance Model
struct CIECAM02 {
    white_point: (f64, f64, f64),
    adapting_luminance: f64,
    background_luminance: f64,
    surround: Surround,
    discounting: bool
}

enum Surround {
    Average,
    Dim,
    Dark
}

struct CIECAM02Color {
    j: f64,   // Lightness
    c: f64,   // Chroma
    h: f64,   // Hue angle
    q: f64,   // Brightness
    m: f64,   // Colorfulness
    s: f64,   // Saturation
    hc: str   // Hue composition
}

impl CIECAM02 {
    fn new(white: (f64, f64, f64), la: f64, yb: f64, surround: Surround) -> CIECAM02 {
        CIECAM02 {
            white_point: white,
            adapting_luminance: la,
            background_luminance: yb,
            surround: surround,
            discounting: false
        }
    }

    fn forward(self, xyz: (f64, f64, f64)) -> CIECAM02Color {
        let (c, nc, f) = self.surround_params();
        let fl = self.luminance_adaptation();
        let n = self.background_luminance / self.white_point.1;
        let z = 1.48 + sqrt(n);
        let nbb = 0.725 * pow(1.0 / n, 0.2);
        let rgb_c = self.chromatic_adapt(xyz);
        let rgb_a = self.post_adapt(rgb_c, fl);
        let a = rgb_a[0] - 12.0 * rgb_a[1] / 11.0 + rgb_a[2] / 11.0;
        let b = (rgb_a[0] + rgb_a[1] - 2.0 * rgb_a[2]) / 9.0;
        let h = atan2(b, a).to_degrees();
        let h_norm = if h < 0.0 { h + 360.0 } else { h };
        let et = 0.25 * (cos(h_norm.to_radians() + 2.0) + 3.8);
        let t = (50000.0/13.0 * nc * nbb * et * sqrt(a*a + b*b)) /
                (rgb_a[0] + rgb_a[1] + 21.0 * rgb_a[2] / 20.0);
        let aw = self.achromatic_response(self.white_point);
        let j = 100.0 * pow(self.achromatic_response(xyz) / aw, c * z);
        let q = (4.0 / c) * sqrt(j / 100.0) * (aw + 4.0) * pow(fl, 0.25);
        let cc = pow(t, 0.9) * sqrt(j / 100.0) * pow(1.64 - pow(0.29, n), 0.73);
        let m = cc * pow(fl, 0.25);
        let s = 100.0 * sqrt(m / q);
        CIECAM02Color { j: j, c: cc, h: h_norm, q: q, m: m, s: s, hc: self.hue_composition(h_norm) }
    }

    fn inverse(self, cam: CIECAM02Color) -> (f64, f64, f64) {
        // Inverse transform from CIECAM02 to XYZ
        let (c, nc, f) = self.surround_params();
        let fl = self.luminance_adaptation();
        let n = self.background_luminance / self.white_point.1;
        let z = 1.48 + sqrt(n);
        let nbb = 0.725 * pow(1.0 / n, 0.2);
        let aw = self.achromatic_response(self.white_point);
        let aa = aw * pow(cam.j / 100.0, 1.0 / (c * z));
        let et = 0.25 * (cos(cam.h.to_radians() + 2.0) + 3.8);
        let t = pow(cam.c / (sqrt(cam.j / 100.0) * pow(1.64 - pow(0.29, n), 0.73)), 1.0 / 0.9);
        let p2 = aa / nbb + 0.305;
        let hr = cam.h.to_radians();
        let (sin_h, cos_h) = (sin(hr), cos(hr));
        self.solve_rgb_to_xyz(p2, t, et, sin_h, cos_h, nc, nbb, fl)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPECTRAL LOCUS & GAMUT MAPPING
// ═══════════════════════════════════════════════════════════════════════════════

/// CIE 1931 spectral locus data points
pub struct SpectralLocus {
    wavelengths: Vec<f64>,
    xy_coords: Vec<(f64, f64)>,
}

impl SpectralLocus {
    pub fn cie1931() -> Self {
        Self {
            wavelengths: (380..=700).step_by(5).map(|w| w as f64).collect(),
            xy_coords: vec![
                (0.1741, 0.0050), (0.1740, 0.0050), (0.1738, 0.0049), (0.1736, 0.0049),
                (0.1733, 0.0048), (0.1730, 0.0048), (0.1726, 0.0048), (0.1721, 0.0048),
                (0.1714, 0.0051), (0.1703, 0.0058), (0.1689, 0.0069), (0.1669, 0.0086),
                (0.1644, 0.0109), (0.1611, 0.0138), (0.1566, 0.0177), (0.1510, 0.0227),
                (0.1440, 0.0297), (0.1355, 0.0399), (0.1241, 0.0578), (0.1096, 0.0868),
                (0.0913, 0.1327), (0.0687, 0.2007), (0.0454, 0.2950), (0.0235, 0.4127),
                (0.0082, 0.5384), (0.0039, 0.6548), (0.0139, 0.7502), (0.0389, 0.8120),
                (0.0743, 0.8338), (0.1142, 0.8262), (0.1547, 0.8059), (0.1929, 0.7816),
                (0.2296, 0.7543), (0.2658, 0.7243), (0.3016, 0.6923), (0.3373, 0.6589),
                (0.3731, 0.6245), (0.4087, 0.5896), (0.4441, 0.5547), (0.4788, 0.5202),
                (0.5125, 0.4866), (0.5448, 0.4544), (0.5752, 0.4242), (0.6029, 0.3965),
                (0.6270, 0.3725), (0.6482, 0.3514), (0.6658, 0.3340), (0.6801, 0.3197),
                (0.6915, 0.3083), (0.7006, 0.2993), (0.7079, 0.2920), (0.7140, 0.2859),
                (0.7190, 0.2809), (0.7230, 0.2770), (0.7260, 0.2740), (0.7283, 0.2717),
                (0.7300, 0.2700), (0.7311, 0.2689), (0.7320, 0.2680), (0.7327, 0.2673),
                (0.7334, 0.2666), (0.7340, 0.2660), (0.7344, 0.2656), (0.7346, 0.2654),
                (0.7347, 0.2653),
            ],
        }
    }

    pub fn is_inside_gamut(&self, x: f64, y: f64) -> bool {
        let n = self.xy_coords.len();
        let mut inside = false;

        for i in 0..n {
            let j = (i + 1) % n;
            let (xi, yi) = self.xy_coords[i];
            let (xj, yj) = self.xy_coords[j];

            if ((yi > y) != (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi) {
                inside = !inside;
            }
        }

        inside
    }

    pub fn closest_point_on_locus(&self, x: f64, y: f64) -> (f64, f64) {
        let mut min_dist = f64::MAX;
        let mut closest = (0.0, 0.0);

        for i in 0..self.xy_coords.len() - 1 {
            let p1 = self.xy_coords[i];
            let p2 = self.xy_coords[i + 1];
            let point = self.project_to_segment(x, y, p1, p2);
            let dist = (point.0 - x).powi(2) + (point.1 - y).powi(2);

            if dist < min_dist {
                min_dist = dist;
                closest = point;
            }
        }

        closest
    }

    fn project_to_segment(&self, x: f64, y: f64, p1: (f64, f64), p2: (f64, f64)) -> (f64, f64) {
        let dx = p2.0 - p1.0;
        let dy = p2.1 - p1.1;
        let t = ((x - p1.0) * dx + (y - p1.1) * dy) / (dx * dx + dy * dy);
        let t = t.clamp(0.0, 1.0);
        (p1.0 + t * dx, p1.1 + t * dy)
    }
}

/// Gamut mapping strategies
#[derive(Debug, Clone, Copy)]
pub enum GamutMappingMethod {
    Clip,
    Compress,
    ProjectToLocus,
    DesaturateToWhite,
    HuePreserving,
}

/// Gamut mapper for color space conversions
pub struct GamutMapper {
    pub method: GamutMappingMethod,
    pub source_gamut: ColorGamut,
    pub target_gamut: ColorGamut,
    pub compression_factor: f64,
}

#[derive(Debug, Clone)]
pub struct ColorGamut {
    pub red: (f64, f64),
    pub green: (f64, f64),
    pub blue: (f64, f64),
    pub white: (f64, f64),
}

impl ColorGamut {
    pub fn srgb() -> Self {
        Self {
            red: (0.64, 0.33),
            green: (0.30, 0.60),
            blue: (0.15, 0.06),
            white: (0.3127, 0.3290),
        }
    }

    pub fn bt2020() -> Self {
        Self {
            red: (0.708, 0.292),
            green: (0.170, 0.797),
            blue: (0.131, 0.046),
            white: (0.3127, 0.3290),
        }
    }

    pub fn dci_p3() -> Self {
        Self {
            red: (0.680, 0.320),
            green: (0.265, 0.690),
            blue: (0.150, 0.060),
            white: (0.314, 0.351),
        }
    }

    pub fn adobe_rgb() -> Self {
        Self {
            red: (0.64, 0.33),
            green: (0.21, 0.71),
            blue: (0.15, 0.06),
            white: (0.3127, 0.3290),
        }
    }

    pub fn contains(&self, x: f64, y: f64) -> bool {
        let v0 = (self.blue.0 - self.red.0, self.blue.1 - self.red.1);
        let v1 = (self.green.0 - self.red.0, self.green.1 - self.red.1);
        let v2 = (x - self.red.0, y - self.red.1);

        let dot00 = v0.0 * v0.0 + v0.1 * v0.1;
        let dot01 = v0.0 * v1.0 + v0.1 * v1.1;
        let dot02 = v0.0 * v2.0 + v0.1 * v2.1;
        let dot11 = v1.0 * v1.0 + v1.1 * v1.1;
        let dot12 = v1.0 * v2.0 + v1.1 * v2.1;

        let inv_denom = 1.0 / (dot00 * dot11 - dot01 * dot01);
        let u = (dot11 * dot02 - dot01 * dot12) * inv_denom;
        let v = (dot00 * dot12 - dot01 * dot02) * inv_denom;

        u >= 0.0 && v >= 0.0 && u + v <= 1.0
    }
}

impl GamutMapper {
    pub fn new(source: ColorGamut, target: ColorGamut, method: GamutMappingMethod) -> Self {
        Self {
            method,
            source_gamut: source,
            target_gamut: target,
            compression_factor: 0.5,
        }
    }

    pub fn map(&self, x: f64, y: f64, luminance: f64) -> (f64, f64, f64) {
        if self.target_gamut.contains(x, y) {
            return (x, y, luminance);
        }

        match self.method {
            GamutMappingMethod::Clip => self.clip(x, y, luminance),
            GamutMappingMethod::Compress => self.compress(x, y, luminance),
            GamutMappingMethod::ProjectToLocus => self.project_to_boundary(x, y, luminance),
            GamutMappingMethod::DesaturateToWhite => self.desaturate_to_white(x, y, luminance),
            GamutMappingMethod::HuePreserving => self.hue_preserving(x, y, luminance),
        }
    }

    fn clip(&self, x: f64, y: f64, luminance: f64) -> (f64, f64, f64) {
        let white = self.target_gamut.white;
        let dx = x - white.0;
        let dy = y - white.1;
        let mut t = 1.0;

        let edges = [
            (self.target_gamut.red, self.target_gamut.green),
            (self.target_gamut.green, self.target_gamut.blue),
            (self.target_gamut.blue, self.target_gamut.red),
        ];

        for (p1, p2) in edges {
            if let Some(ti) = self.line_intersect(white, (x, y), p1, p2) {
                if ti > 0.0 && ti < t {
                    t = ti;
                }
            }
        }

        (white.0 + dx * t, white.1 + dy * t, luminance)
    }

    fn compress(&self, x: f64, y: f64, luminance: f64) -> (f64, f64, f64) {
        let white = self.target_gamut.white;
        let dx = x - white.0;
        let dy = y - white.1;
        let sat = (dx * dx + dy * dy).sqrt();
        let compressed_sat = sat * self.compression_factor;
        let scale = if sat > 0.0 { compressed_sat / sat } else { 0.0 };
        (white.0 + dx * scale, white.1 + dy * scale, luminance)
    }

    fn project_to_boundary(&self, x: f64, y: f64, luminance: f64) -> (f64, f64, f64) {
        let clipped = self.clip(x, y, luminance);
        (clipped.0, clipped.1, luminance)
    }

    fn desaturate_to_white(&self, x: f64, y: f64, luminance: f64) -> (f64, f64, f64) {
        let white = self.target_gamut.white;
        let mut low = 0.0;
        let mut high = 1.0;

        for _ in 0..20 {
            let mid = (low + high) / 2.0;
            let test_x = x + (white.0 - x) * mid;
            let test_y = y + (white.1 - y) * mid;

            if self.target_gamut.contains(test_x, test_y) {
                high = mid;
            } else {
                low = mid;
            }
        }

        let t = high;
        (x + (white.0 - x) * t, y + (white.1 - y) * t, luminance)
    }

    fn hue_preserving(&self, x: f64, y: f64, luminance: f64) -> (f64, f64, f64) {
        self.clip(x, y, luminance)
    }

    fn line_intersect(&self, p1: (f64, f64), p2: (f64, f64), p3: (f64, f64), p4: (f64, f64)) -> Option<f64> {
        let d = (p1.0 - p2.0) * (p3.1 - p4.1) - (p1.1 - p2.1) * (p3.0 - p4.0);
        if d.abs() < 1e-10 { return None; }
        let t = ((p1.0 - p3.0) * (p3.1 - p4.1) - (p1.1 - p3.1) * (p3.0 - p4.0)) / d;
        let u = -((p1.0 - p2.0) * (p1.1 - p3.1) - (p1.1 - p2.1) * (p1.0 - p3.0)) / d;
        if t >= 0.0 && t <= 1.0 && u >= 0.0 && u <= 1.0 { Some(t) } else { None }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPECTRAL RENDERING
// ═══════════════════════════════════════════════════════════════════════════════

/// Spectral power distribution
pub struct SPD {
    wavelength_start: f64,
    wavelength_end: f64,
    values: Vec<f64>,
}

impl SPD {
    pub fn new(start: f64, end: f64, values: Vec<f64>) -> Self {
        Self { wavelength_start: start, wavelength_end: end, values }
    }

    pub fn sample(&self, wavelength: f64) -> f64 {
        if wavelength < self.wavelength_start || wavelength > self.wavelength_end {
            return 0.0;
        }

        let t = (wavelength - self.wavelength_start) / (self.wavelength_end - self.wavelength_start);
        let idx = t * (self.values.len() - 1) as f64;
        let i = idx.floor() as usize;
        let frac = idx.fract();

        if i >= self.values.len() - 1 {
            self.values[self.values.len() - 1]
        } else {
            self.values[i] * (1.0 - frac) + self.values[i + 1] * frac
        }
    }

    pub fn to_xyz(&self, cmf: &ColorMatchingFunction) -> (f64, f64, f64) {
        let mut x = 0.0;
        let mut y = 0.0;
        let mut z = 0.0;

        for wavelength in (380..=700).step_by(5) {
            let wl = wavelength as f64;
            let spd = self.sample(wl);
            let (cx, cy, cz) = cmf.sample(wl);
            x += spd * cx;
            y += spd * cy;
            z += spd * cz;
        }

        let scale = 5.0 / y.max(0.001);
        (x * scale, 1.0, z * scale)
    }
}

/// CIE color matching functions
pub struct ColorMatchingFunction {
    x_bar: Vec<f64>,
    y_bar: Vec<f64>,
    z_bar: Vec<f64>,
}

