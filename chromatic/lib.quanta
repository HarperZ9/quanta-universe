// ═══════════════════════════════════════════════════════════════════════════════
// PERCEPTUAL COLOR MODELS
// ═══════════════════════════════════════════════════════════════════════════════

/// CAM16 color appearance model
pub struct CAM16 {
    pub white_point: (f64, f64, f64),
    pub adapting_luminance: f64,
    pub background_luminance: f64,
    pub surround_type: CAM16Surround,
    pub discounting: bool,
}

#[derive(Debug, Clone, Copy)]
pub enum CAM16Surround {
    Average,
    Dim,
    Dark,
}

#[derive(Debug, Clone)]
pub struct CAM16Color {
    pub j: f64,
    pub c: f64,
    pub h: f64,
    pub q: f64,
    pub m: f64,
    pub s: f64,
}

impl CAM16 {
    pub fn default_viewing_conditions() -> Self {
        Self {
            white_point: (95.047, 100.0, 108.883),
            adapting_luminance: 64.0,
            background_luminance: 20.0,
            surround_type: CAM16Surround::Average,
            discounting: false,
        }
    }

    pub fn get_surround_params(&self) -> (f64, f64, f64) {
        match self.surround_type {
            CAM16Surround::Average => (1.0, 0.69, 1.0),
            CAM16Surround::Dim => (0.9, 0.59, 0.9),
            CAM16Surround::Dark => (0.8, 0.525, 0.8),
        }
    }

    pub fn forward(&self, xyz: (f64, f64, f64)) -> CAM16Color {
        let (c, nc, f) = self.get_surround_params();
        let k = 1.0 / (5.0 * self.adapting_luminance + 1.0);
        let k4 = k.powi(4);
        let fl = k4 * self.adapting_luminance + 0.1 * (1.0 - k4).powi(2) * (5.0 * self.adapting_luminance).powf(1.0 / 3.0);
        let n = self.background_luminance / self.white_point.1;
        let z = 1.48 + n.sqrt();
        let nbb = 0.725 / n.powf(0.2);
        let ncb = nbb;

        let m16 = [
            [0.401288, 0.650173, -0.051461],
            [-0.250268, 1.204414, 0.045854],
            [-0.002079, 0.048952, 0.953127],
        ];

        let rgb_c = self.transform_xyz(xyz, &m16);
        let rgb_w = self.transform_xyz(self.white_point, &m16);

        let d = if self.discounting { 1.0 } else { f * (1.0 - (1.0 / 3.6) * ((-self.adapting_luminance - 42.0) / 92.0).exp()) };
        let d = d.clamp(0.0, 1.0);

        let rgb_c_adapted = (
            (d * self.white_point.1 / rgb_w.0 + 1.0 - d) * rgb_c.0,
            (d * self.white_point.1 / rgb_w.1 + 1.0 - d) * rgb_c.1,
            (d * self.white_point.1 / rgb_w.2 + 1.0 - d) * rgb_c.2,
        );

        let rgb_a = self.post_adaptation(rgb_c_adapted, fl);
        let a = rgb_a.0 - 12.0 * rgb_a.1 / 11.0 + rgb_a.2 / 11.0;
        let b = (rgb_a.0 + rgb_a.1 - 2.0 * rgb_a.2) / 9.0;

        let h_rad = b.atan2(a);
        let h = h_rad.to_degrees();
        let h = if h < 0.0 { h + 360.0 } else { h };

        let et = 0.25 * ((h_rad + 2.0).cos() + 3.8);
        let aa = rgb_a.0 + rgb_a.1 + 21.0 * rgb_a.2 / 20.0;
        let t = 50000.0 / 13.0 * nc * ncb * et * (a * a + b * b).sqrt() / aa;

        let aw_rgb = self.transform_xyz(self.white_point, &m16);
        let aw_adapted = (
            (d * self.white_point.1 / rgb_w.0 + 1.0 - d) * aw_rgb.0,
            (d * self.white_point.1 / rgb_w.1 + 1.0 - d) * aw_rgb.1,
            (d * self.white_point.1 / rgb_w.2 + 1.0 - d) * aw_rgb.2,
        );
        let aw_a = self.post_adaptation(aw_adapted, fl);
        let aw = (2.0 * aw_a.0 + aw_a.1 + aw_a.2 / 20.0 - 0.305) * nbb;
        let a_sample = (2.0 * rgb_a.0 + rgb_a.1 + rgb_a.2 / 20.0 - 0.305) * nbb;

        let j = 100.0 * (a_sample / aw).powf(c * z);
        let q = (4.0 / c) * (j / 100.0).sqrt() * (aw + 4.0) * fl.powf(0.25);
        let cc = t.powf(0.9) * (j / 100.0).sqrt() * (1.64 - 0.29_f64.powf(n)).powf(0.73);
        let m = cc * fl.powf(0.25);
        let s = 100.0 * (m / q).sqrt();

        CAM16Color { j, c: cc, h, q, m, s }
    }

    fn transform_xyz(&self, xyz: (f64, f64, f64), m: &[[f64; 3]; 3]) -> (f64, f64, f64) {
        (
            m[0][0] * xyz.0 + m[0][1] * xyz.1 + m[0][2] * xyz.2,
            m[1][0] * xyz.0 + m[1][1] * xyz.1 + m[1][2] * xyz.2,
            m[2][0] * xyz.0 + m[2][1] * xyz.1 + m[2][2] * xyz.2,
        )
    }

    fn post_adaptation(&self, rgb: (f64, f64, f64), fl: f64) -> (f64, f64, f64) {
        let adapt = |c: f64| -> f64 {
            let c_abs = c.abs();
            let sign = if c >= 0.0 { 1.0 } else { -1.0 };
            sign * 400.0 * (fl * c_abs / 100.0).powf(0.42) / ((fl * c_abs / 100.0).powf(0.42) + 27.13)
        };
        (adapt(rgb.0), adapt(rgb.1), adapt(rgb.2))
    }
}

/// Oklab perceptual color space
pub struct Oklab;

impl Oklab {
    pub fn from_linear_srgb(r: f64, g: f64, b: f64) -> (f64, f64, f64) {
        let l = 0.4122214708 * r + 0.5363325363 * g + 0.0514459929 * b;
        let m = 0.2119034982 * r + 0.6806995451 * g + 0.1073969566 * b;
        let s = 0.0883024619 * r + 0.2817188376 * g + 0.6299787005 * b;

        let l_ = l.cbrt();
        let m_ = m.cbrt();
        let s_ = s.cbrt();

        let lab_l = 0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_;
        let lab_a = 1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_;
        let lab_b = 0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_;

        (lab_l, lab_a, lab_b)
    }

    pub fn to_linear_srgb(l: f64, a: f64, b: f64) -> (f64, f64, f64) {
        let l_ = l + 0.3963377774 * a + 0.2158037573 * b;
        let m_ = l - 0.1055613458 * a - 0.0638541728 * b;
        let s_ = l - 0.0894841775 * a - 1.2914855480 * b;

        let l_cubed = l_ * l_ * l_;
        let m_cubed = m_ * m_ * m_;
        let s_cubed = s_ * s_ * s_;

        let r = 4.0767416621 * l_cubed - 3.3077115913 * m_cubed + 0.2309699292 * s_cubed;
        let g = -1.2684380046 * l_cubed + 2.6097574011 * m_cubed - 0.3413193965 * s_cubed;
        let b_out = -0.0041960863 * l_cubed - 0.7034186147 * m_cubed + 1.7076147010 * s_cubed;

        (r, g, b_out)
    }

    pub fn to_oklch(l: f64, a: f64, b: f64) -> (f64, f64, f64) {
        let c = (a * a + b * b).sqrt();
        let h = b.atan2(a).to_degrees();
        let h = if h < 0.0 { h + 360.0 } else { h };
        (l, c, h)
    }

    pub fn from_oklch(l: f64, c: f64, h: f64) -> (f64, f64, f64) {
        let h_rad = h.to_radians();
        let a = c * h_rad.cos();
        let b = c * h_rad.sin();
        (l, a, b)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR PALETTE GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

enum HarmonyType { Complementary, SplitComplementary, Triadic, Tetradic, Analogous, Monochromatic }

struct ColorHarmony {
    base_hue: f64,
    saturation: f64,
    lightness: f64,
    harmony_type: HarmonyType
}

impl ColorHarmony {
    fn new(h: f64, s: f64, l: f64, harmony: HarmonyType) -> ColorHarmony {
        ColorHarmony { base_hue: h, saturation: s, lightness: l, harmony_type: harmony }
    }

    fn generate_palette(self) -> [(f64, f64, f64)] {
        let h = self.base_hue;
        match self.harmony_type {
            HarmonyType::Complementary => {
                vec![(h, self.saturation, self.lightness),
                     ((h + 180.0) % 360.0, self.saturation, self.lightness)]
            }
            HarmonyType::SplitComplementary => {
                vec![(h, self.saturation, self.lightness),
                     ((h + 150.0) % 360.0, self.saturation, self.lightness),
                     ((h + 210.0) % 360.0, self.saturation, self.lightness)]
            }
            HarmonyType::Triadic => {
                vec![(h, self.saturation, self.lightness),
                     ((h + 120.0) % 360.0, self.saturation, self.lightness),
                     ((h + 240.0) % 360.0, self.saturation, self.lightness)]
            }
            HarmonyType::Tetradic => {
                vec![(h, self.saturation, self.lightness),
                     ((h + 90.0) % 360.0, self.saturation, self.lightness),
                     ((h + 180.0) % 360.0, self.saturation, self.lightness),
                     ((h + 270.0) % 360.0, self.saturation, self.lightness)]
            }
            HarmonyType::Analogous => {
                vec![(h, self.saturation, self.lightness),
                     ((h + 30.0) % 360.0, self.saturation, self.lightness),
                     ((h + 330.0) % 360.0, self.saturation, self.lightness)]
            }
            HarmonyType::Monochromatic => {
                vec![(h, self.saturation, self.lightness * 0.5),
                     (h, self.saturation, self.lightness * 0.75),
                     (h, self.saturation, self.lightness),
                     (h, self.saturation, self.lightness.min(1.0) * 1.25)]
            }
        }
    }

    fn adjust_for_accessibility(self, colors: [(f64, f64, f64)], min_contrast: f64) -> [(f64, f64, f64)] {
        let mut adjusted = vec![];
        for (h, s, l) in colors.iter() {
            let contrast = self.calculate_contrast(*l, 0.0);
            if contrast < min_contrast {
                let new_l = if *l > 0.5 { l * 0.7 } else { l * 1.3 };
                adjusted.push((*h, *s, new_l.clamp(0.0, 1.0)));
            } else {
                adjusted.push((*h, *s, *l));
            }
        }
        adjusted
    }

    fn calculate_contrast(self, l1: f64, l2: f64) -> f64 {
        let lighter = l1.max(l2) + 0.05;
        let darker = l1.min(l2) + 0.05;
        lighter / darker
    }
}

struct PaletteGenerator {
    seed_colors: [(f64, f64, f64)],
    num_colors: usize,
    color_space: String
}

impl PaletteGenerator {
    fn new(num: usize) -> PaletteGenerator {
        PaletteGenerator { seed_colors: vec![], num_colors: num, color_space: "oklab".to_string() }
    }

    fn generate_gradient(self, start: (f64, f64, f64), end: (f64, f64, f64)) -> [(f64, f64, f64)] {
        (0..self.num_colors).map(|i| {
            let t = i as f64 / (self.num_colors - 1) as f64;
            (start.0 * (1.0 - t) + end.0 * t,
             start.1 * (1.0 - t) + end.1 * t,
             start.2 * (1.0 - t) + end.2 * t)
        }).collect()
    }

    fn generate_random_palette(self, seed: u64) -> [(f64, f64, f64)] {
        let golden_ratio = 0.618033988749895;
        let mut h = (seed as f64 * golden_ratio) % 1.0 * 360.0;
        (0..self.num_colors).map(|_| {
            let color = (h, 0.65, 0.55);
            h = (h + golden_ratio * 360.0) % 360.0;
            color
        }).collect()
    }

    fn extract_palette_from_image(self, image: &[(f64, f64, f64)], k: usize) -> [(f64, f64, f64)] {
        let mut centroids: Vec<(f64, f64, f64)> = image.iter().take(k).cloned().collect();
        for _ in 0..20 {
            let mut clusters: Vec<Vec<(f64, f64, f64)>> = vec![vec![]; k];
            for pixel in image.iter() {
                let mut min_dist = f64::MAX;
                let mut nearest = 0;
                for (i, centroid) in centroids.iter().enumerate() {
                    let d = (pixel.0 - centroid.0).powi(2) +
                           (pixel.1 - centroid.1).powi(2) +
                           (pixel.2 - centroid.2).powi(2);
                    if d < min_dist { min_dist = d; nearest = i; }
                }
                clusters[nearest].push(*pixel);
            }
            for (i, cluster) in clusters.iter().enumerate() {
                if cluster.is_empty() { continue; }
                let sum: (f64, f64, f64) = cluster.iter().fold((0.0, 0.0, 0.0), |acc, p| {
                    (acc.0 + p.0, acc.1 + p.1, acc.2 + p.2)
                });
                let n = cluster.len() as f64;
                centroids[i] = (sum.0 / n, sum.1 / n, sum.2 / n);
            }
        }
        centroids
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GAMUT BOUNDARY DESCRIPTOR
// ═══════════════════════════════════════════════════════════════════════════════

struct GamutBoundary {
    segments: [GamutSegment],
    color_space: String,
    resolution: usize
}

struct GamutSegment {
    lightness: f64,
    hue_min: f64,
    hue_max: f64,
    chroma_max: f64
}

impl GamutBoundary {
    fn new(color_space: &str, resolution: usize) -> GamutBoundary {
        GamutBoundary {
            segments: vec![], color_space: color_space.to_string(), resolution: resolution
        }
    }

    fn compute_srgb_boundary(mut self) -> GamutBoundary {
        let mut segments = vec![];
        for l_step in 0..self.resolution {
            let l = l_step as f64 / (self.resolution - 1) as f64;
            for h_step in 0..360 {
                let h = h_step as f64;
                let max_c = self.find_max_chroma(l, h);
                segments.push(GamutSegment {
                    lightness: l, hue_min: h, hue_max: h + 1.0, chroma_max: max_c
                });
            }
        }
        self.segments = segments;
        self
    }

    fn find_max_chroma(self, l: f64, h: f64) -> f64 {
        let mut low = 0.0;
        let mut high = 0.4;
        for _ in 0..20 {
            let mid = (low + high) / 2.0;
            let (a, b) = Oklab::from_oklch(l, mid, h);
            let (r, g, b_rgb) = Oklab::to_linear_srgb(l, a, b);
            if r >= 0.0 && r <= 1.0 && g >= 0.0 && g <= 1.0 && b_rgb >= 0.0 && b_rgb <= 1.0 {
                low = mid;
            } else {
                high = mid;
            }
        }
        low
    }

    fn is_in_gamut(self, l: f64, c: f64, h: f64) -> bool {
        for seg in self.segments.iter() {
            if (seg.lightness - l).abs() < 0.05 && h >= seg.hue_min && h < seg.hue_max {
                return c <= seg.chroma_max;
            }
        }
        false
    }

    fn clamp_to_gamut(self, l: f64, c: f64, h: f64) -> (f64, f64, f64) {
        for seg in self.segments.iter() {
            if (seg.lightness - l).abs() < 0.05 && h >= seg.hue_min && h < seg.hue_max {
                return (l, c.min(seg.chroma_max), h);
            }
        }
        (l, c, h)
    }
}

struct GamutMapping {
    method: GamutMappingMethod,
    preserve_hue: bool,
    cusp_l: f64
}

enum GamutMappingMethod { Clip, Compress, ProjectToL, ProjectToC, MINDE }

impl GamutMapping {
    fn new(method: GamutMappingMethod) -> GamutMapping {
        GamutMapping { method: method, preserve_hue: true, cusp_l: 0.5 }
    }

    fn map(self, l: f64, c: f64, h: f64, boundary: &GamutBoundary) -> (f64, f64, f64) {
        if boundary.is_in_gamut(l, c, h) { return (l, c, h); }
        match self.method {
            GamutMappingMethod::Clip => boundary.clamp_to_gamut(l, c, h),
            GamutMappingMethod::Compress => {
                let (_, max_c, _) = boundary.clamp_to_gamut(l, 1.0, h);
                let compressed_c = c * max_c / (c + max_c - max_c * c / c.max(0.001));
                (l, compressed_c, h)
            }
            GamutMappingMethod::ProjectToL => {
                let max_c = boundary.find_max_chroma(l, h);
                if c > max_c {
                    let new_l = if l > self.cusp_l { l - (c - max_c) * 0.5 } else { l + (c - max_c) * 0.5 };
                    (new_l.clamp(0.0, 1.0), max_c, h)
                } else { (l, c, h) }
            }
            _ => boundary.clamp_to_gamut(l, c, h)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// JZAZBZ PERCEPTUAL COLOR SPACE
// ═══════════════════════════════════════════════════════════════════════════════

struct Jzazbz {
    b: f64,
    c1: f64,
    c2: f64,
    c3: f64,
    n: f64,
    p: f64,
    d: f64,
    d0: f64
}

impl Jzazbz {
    fn new() -> Jzazbz {
        Jzazbz {
            b: 1.15, c1: 0.8359375, c2: 18.8515625, c3: 18.6875,
            n: 0.15930175781, p: 134.034375, d: -0.56, d0: 1.6295499532821566e-11
        }
    }

    fn from_xyz(self, x: f64, y: f64, z: f64) -> (f64, f64, f64) {
        let xp = self.b * x - (self.b - 1.0) * z;
        let yp = self.b * y - (self.b - 1.0) * x;
        let lp = 0.41478972 * xp + 0.579999 * yp + 0.0146480 * z;
        let mp = -0.2015100 * xp + 1.120649 * yp + 0.0531008 * z;
        let sp = -0.0166008 * xp + 0.264800 * yp + 0.6684799 * z;
        let lp_pq = self.pq_transfer(lp / 10000.0);
        let mp_pq = self.pq_transfer(mp / 10000.0);
        let sp_pq = self.pq_transfer(sp / 10000.0);
        let iz = 0.5 * (lp_pq + mp_pq);
        let az = 3.524000 * lp_pq - 4.066708 * mp_pq + 0.542708 * sp_pq;
        let bz = 0.199076 * lp_pq + 1.096799 * mp_pq - 1.295875 * sp_pq;
        let jz = ((1.0 + self.d) * iz) / (1.0 + self.d * iz) - self.d0;
        (jz, az, bz)
    }

    fn pq_transfer(self, x: f64) -> f64 {
        let xp = (x.max(0.0) / 10000.0).powf(self.n);
        ((self.c1 + self.c2 * xp) / (1.0 + self.c3 * xp)).powf(self.p)
    }

    fn pq_inverse(self, x: f64) -> f64 {
        let xp = x.powf(1.0 / self.p);
        (10000.0 * ((self.c1 - xp) / (self.c3 * xp - self.c2)).max(0.0).powf(1.0 / self.n))
    }

    fn to_jzczhz(self, jz: f64, az: f64, bz: f64) -> (f64, f64, f64) {
        let cz = (az * az + bz * bz).sqrt();
        let hz = bz.atan2(az).to_degrees();
        let hz = if hz < 0.0 { hz + 360.0 } else { hz };
        (jz, cz, hz)
    }

    fn delta_e(self, jz1: f64, az1: f64, bz1: f64, jz2: f64, az2: f64, bz2: f64) -> f64 {
        let dj = jz2 - jz1;
        let da = az2 - az1;
        let db = bz2 - bz1;
        (dj * dj + da * da + db * db).sqrt()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ICTCP COLOR SPACE (HDR)
// ═══════════════════════════════════════════════════════════════════════════════

struct ICtCp {
    l_hdr: f64
}

impl ICtCp {
    fn new(l_hdr: f64) -> ICtCp {
        ICtCp { l_hdr: l_hdr }
    }

    fn from_rgb(self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
        let l = 0.412109 * r + 0.523925 * g + 0.063965 * b;
        let m = 0.166748 * r + 0.720459 * g + 0.112793 * b;
        let s = 0.024170 * r + 0.075440 * g + 0.900394 * b;
        let lp = self.pq_oetf(l);
        let mp = self.pq_oetf(m);
        let sp = self.pq_oetf(s);
        let i = 0.5 * lp + 0.5 * mp;
        let ct = 1.61370 * lp - 3.32340 * mp + 1.70970 * sp;
        let cp = 4.37800 * lp - 4.24530 * mp - 0.13270 * sp;
        (i, ct, cp)
    }

    fn to_rgb(self, i: f64, ct: f64, cp: f64) -> (f64, f64, f64) {
        let lp = i + 0.00860904 * ct + 0.11103 * cp;
        let mp = i - 0.00860904 * ct - 0.11103 * cp;
        let sp = i + 0.56003 * ct - 0.32068 * cp;
        let l = self.pq_eotf(lp);
        let m = self.pq_eotf(mp);
        let s = self.pq_eotf(sp);
        let r = 3.43661 * l - 2.50645 * m + 0.06984 * s;
        let g = -0.79133 * l + 1.98360 * m - 0.19227 * s;
        let b_out = -0.02590 * l - 0.09893 * m + 1.12483 * s;
        (r, g, b_out)
    }

    fn pq_oetf(self, y: f64) -> f64 {
        let m1 = 2610.0 / 16384.0;
        let m2 = 2523.0 / 4096.0 * 128.0;
        let c1 = 3424.0 / 4096.0;
        let c2 = 2413.0 / 4096.0 * 32.0;
        let c3 = 2392.0 / 4096.0 * 32.0;
        let yp = (y / self.l_hdr).max(0.0).powf(m1);
        ((c1 + c2 * yp) / (1.0 + c3 * yp)).powf(m2)
    }

    fn pq_eotf(self, e: f64) -> f64 {
        let m1 = 2610.0 / 16384.0;
        let m2 = 2523.0 / 4096.0 * 128.0;
        let c1 = 3424.0 / 4096.0;
        let c2 = 2413.0 / 4096.0 * 32.0;
        let c3 = 2392.0 / 4096.0 * 32.0;
        let ep = e.powf(1.0 / m2);
        self.l_hdr * ((ep - c1).max(0.0) / (c2 - c3 * ep)).powf(1.0 / m1)
    }

    fn delta_e_itp(self, i1: f64, t1: f64, p1: f64, i2: f64, t2: f64, p2: f64) -> f64 {
        let di = 720.0 * (i2 - i1);
        let dt = 360.0 * (t2 - t1);
        let dp = 360.0 * (p2 - p1);
        (di * di + dt * dt + dp * dp).sqrt()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR TEMPERATURE
// ═══════════════════════════════════════════════════════════════════════════════

struct ColorTemperature {
    min_k: f64,
    max_k: f64
}

impl ColorTemperature {
    fn new() -> ColorTemperature {
        ColorTemperature { min_k: 1000.0, max_k: 40000.0 }
    }

    fn kelvin_to_xy(self, k: f64) -> (f64, f64) {
        let x = if k < 4000.0 {
            -0.2661239e9 / (k*k*k) - 0.2343589e6 / (k*k) + 0.8776956e3 / k + 0.179910
        } else {
            -3.0258469e9 / (k*k*k) + 2.1070379e6 / (k*k) + 0.2226347e3 / k + 0.24039
        };
        let y = if k < 2222.0 {
            -1.1063814 * x*x*x - 1.34811020 * x*x + 2.18555832 * x - 0.20219683
        } else if k < 4000.0 {
            -0.9549476 * x*x*x - 1.37418593 * x*x + 2.09137015 * x - 0.16748867
        } else {
            3.0817580 * x*x*x - 5.87338670 * x*x + 3.75112997 * x - 0.37001483
        };
        (x, y)
    }

    fn xy_to_kelvin(self, x: f64, y: f64) -> f64 {
        let n = (x - 0.3320) / (0.1858 - y);
        437.0 * n * n * n + 3601.0 * n * n + 6861.0 * n + 5517.0
    }

    fn kelvin_to_rgb(self, k: f64) -> (f64, f64, f64) {
        let temp = k / 100.0;
        let r = if temp <= 66.0 { 1.0 }
                else { (329.698727446 * (temp - 60.0).powf(-0.1332047592) / 255.0).clamp(0.0, 1.0) };
        let g = if temp <= 66.0 {
            (99.4708025861 * temp.ln() - 161.1195681661) / 255.0
        } else {
            288.1221695283 * (temp - 60.0).powf(-0.0755148492) / 255.0
        }.clamp(0.0, 1.0);
        let b = if temp >= 66.0 { 1.0 }
                else if temp <= 19.0 { 0.0 }
                else { (138.5177312231 * (temp - 10.0).ln() - 305.0447927307) / 255.0 }.clamp(0.0, 1.0);
        (r, g, b)
    }

    fn correlated_color_temp(self, x: f64, y: f64) -> f64 {
        let n = (x - 0.3320) / (y - 0.1858);
        -449.0 * n * n * n + 3525.0 * n * n - 6823.3 * n + 5520.33
    }

    fn duv(self, x: f64, y: f64) -> f64 {
        let u = 4.0 * x / (-2.0 * x + 12.0 * y + 3.0);
        let v = 6.0 * y / (-2.0 * x + 12.0 * y + 3.0);
        let lfp = (u - 0.292).powi(2) + (v - 0.24).powi(2);
        let k = self.correlated_color_temp(x, y);
        let (x_bb, y_bb) = self.kelvin_to_xy(k);
        let u_bb = 4.0 * x_bb / (-2.0 * x_bb + 12.0 * y_bb + 3.0);
        let v_bb = 6.0 * y_bb / (-2.0 * x_bb + 12.0 * y_bb + 3.0);
        let dist = ((u - u_bb).powi(2) + (v - v_bb).powi(2)).sqrt();
        if v < v_bb { -dist } else { dist }
    }
}

struct WhiteBalance {
    source_temp: f64,
    target_temp: f64,
    tint: f64
}

impl WhiteBalance {
    fn new(source: f64, target: f64) -> WhiteBalance {
        WhiteBalance { source_temp: source, target_temp: target, tint: 0.0 }
    }

    fn compute_multipliers(self) -> (f64, f64, f64) {
        let ct = ColorTemperature::new();
        let (sr, sg, sb) = ct.kelvin_to_rgb(self.source_temp);
        let (tr, tg, tb) = ct.kelvin_to_rgb(self.target_temp);
        let r_mult = tr / sr.max(0.001);
        let g_mult = tg / sg.max(0.001) * (1.0 + self.tint * 0.1);
        let b_mult = tb / sb.max(0.001);
        (r_mult, g_mult, b_mult)
    }

    fn apply(self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
        let (rm, gm, bm) = self.compute_multipliers();
        (r * rm, g * gm, b * bm)
    }

    fn auto_white_balance(image: &[(f64, f64, f64)]) -> WhiteBalance {
        let sum: (f64, f64, f64) = image.iter().fold((0.0, 0.0, 0.0), |acc, p| {
            (acc.0 + p.0, acc.1 + p.1, acc.2 + p.2)
        });
        let n = image.len() as f64;
        let avg = (sum.0 / n, sum.1 / n, sum.2 / n);
        let gray = (avg.0 + avg.1 + avg.2) / 3.0;
        let r_mult = gray / avg.0.max(0.001);
        let b_mult = gray / avg.2.max(0.001);
        let estimated_temp = 6500.0 * (r_mult / b_mult).powf(0.5);
        WhiteBalance::new(estimated_temp, 6500.0)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR VISION MODELS
// ═══════════════════════════════════════════════════════════════════════════════

struct HuntModel {
    adapting_luminance: f64,
    background_luminance: f64,
    surround: HuntSurround,
    discount_illuminant: bool
}

enum HuntSurround { Average, Dim, Dark }

impl HuntModel {
    fn new(la: f64, yb: f64, surround: HuntSurround) -> HuntModel {
        HuntModel {
            adapting_luminance: la, background_luminance: yb,
            surround: surround, discount_illuminant: false
        }
    }

    fn compute_appearance(self, x: f64, y: f64, z: f64) -> HuntAppearance {
        let k = 1.0 / (5.0 * self.adapting_luminance + 1.0);
        let fl = 0.2 * k.powi(4) * (5.0 * self.adapting_luminance) +
                 0.1 * (1.0 - k.powi(4)).powi(2) * (5.0 * self.adapting_luminance).powf(1.0/3.0);
        let n = self.background_luminance / 100.0;
        let nbb = 0.725 * n.powf(-0.2);
        let l = 0.38971 * x + 0.68898 * y - 0.07868 * z;
        let m = -0.22981 * x + 1.18340 * y + 0.04641 * z;
        let s = z;
        let (c, f) = match self.surround {
            HuntSurround::Average => (0.69, 1.0),
            HuntSurround::Dim => (0.59, 0.9),
            HuntSurround::Dark => (0.525, 0.8),
        };
        let j = 100.0 * (y / 100.0).powf(c * nbb);
        let q = (4.0 / c) * (j / 100.0).sqrt() * (self.adapting_luminance + 4.0) * fl.powf(0.25);
        HuntAppearance { j: j, q: q, c: 0.0, m: 0.0, s_val: 0.0, h: 0.0 }
    }
}

struct HuntAppearance {
    j: f64,
    q: f64,
    c: f64,
    m: f64,
    s_val: f64,
    h: f64
}

struct NayataniModel {
    eo: f64,
    e: f64,
    y_o: f64
}

impl NayataniModel {
    fn new(eo: f64, e: f64) -> NayataniModel {
        NayataniModel { eo: eo, e: e, y_o: 20.0 }
    }

    fn compute_lightness(self, y: f64) -> f64 {
        let beta = (self.eo + 0.000001).log10() - 1.5;
        let alpha = 2.26 * beta - 0.54;
        100.0 * (y / self.y_o).powf(alpha)
    }

    fn compute_hue_angle(self, a: f64, b: f64) -> f64 {
        b.atan2(a).to_degrees()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPECTRAL OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

struct SpectralReflectance {
    wavelengths: [f64],
    values: [f64],
    min_nm: f64,
    max_nm: f64
}

impl SpectralReflectance {
    fn new(wavelengths: [f64], values: [f64]) -> SpectralReflectance {
        let min = *wavelengths.first().unwrap_or(&380.0);
        let max = *wavelengths.last().unwrap_or(&780.0);
        SpectralReflectance { wavelengths: wavelengths, values: values, min_nm: min, max_nm: max }
    }

    fn sample(self, nm: f64) -> f64 {
        if nm < self.min_nm || nm > self.max_nm { return 0.0; }
        for i in 0..self.wavelengths.len() - 1 {
            if nm >= self.wavelengths[i] && nm <= self.wavelengths[i + 1] {
                let t = (nm - self.wavelengths[i]) / (self.wavelengths[i + 1] - self.wavelengths[i]);
                return self.values[i] * (1.0 - t) + self.values[i + 1] * t;
            }
        }
        0.0
    }

    fn multiply(self, other: &SpectralReflectance) -> SpectralReflectance {
        let new_values: Vec<f64> = self.wavelengths.iter().enumerate().map(|(i, nm)| {
            self.values[i] * other.sample(*nm)
        }).collect();
        SpectralReflectance::new(self.wavelengths.clone(), new_values)
    }

    fn add(self, other: &SpectralReflectance) -> SpectralReflectance {
        let new_values: Vec<f64> = self.wavelengths.iter().enumerate().map(|(i, nm)| {
            self.values[i] + other.sample(*nm)
        }).collect();
        SpectralReflectance::new(self.wavelengths.clone(), new_values)
    }

    fn integrate(self) -> f64 {
        let mut sum = 0.0;
        for i in 0..self.wavelengths.len() - 1 {
            let delta = self.wavelengths[i + 1] - self.wavelengths[i];
            sum += (self.values[i] + self.values[i + 1]) * 0.5 * delta;
        }
        sum
    }
}

struct SpectralUpsampling;

impl SpectralUpsampling {
    fn rgb_to_spectral(r: f64, g: f64, b: f64) -> SpectralReflectance {
        let wavelengths: Vec<f64> = (380..=780).step_by(5).map(|w| w as f64).collect();
        let values: Vec<f64> = wavelengths.iter().map(|nm| {
            let r_weight = Self::rgb_basis_r(*nm);
            let g_weight = Self::rgb_basis_g(*nm);
            let b_weight = Self::rgb_basis_b(*nm);
            (r * r_weight + g * g_weight + b * b_weight).clamp(0.0, 1.0)
        }).collect();
        SpectralReflectance::new(wavelengths, values)
    }

    fn rgb_basis_r(nm: f64) -> f64 {
        if nm >= 580.0 && nm <= 700.0 { ((nm - 580.0) / 40.0).min(1.0) }
        else if nm > 700.0 { 1.0 - ((nm - 700.0) / 80.0).min(1.0) }
        else { 0.0 }
    }

    fn rgb_basis_g(nm: f64) -> f64 {
        if nm >= 480.0 && nm <= 560.0 { ((nm - 480.0) / 40.0).min(1.0) }
        else if nm > 560.0 && nm <= 600.0 { 1.0 - ((nm - 560.0) / 40.0) }
        else { 0.0 }
    }

    fn rgb_basis_b(nm: f64) -> f64 {
        if nm >= 380.0 && nm <= 480.0 { ((nm - 380.0) / 50.0).min(1.0) }
        else if nm > 480.0 && nm <= 530.0 { 1.0 - ((nm - 480.0) / 50.0) }
        else { 0.0 }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR APPEARANCE MODELS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod color_appearance {
    use super::*;

    /// CIECAM02 viewing conditions
    #[derive(Debug, Clone, Copy)]
    pub struct ViewingConditions {
        pub white_point: XYZ,
        pub adapting_luminance: f64,
        pub background_luminance: f64,
        pub surround: Surround,
        pub discount_illuminant: bool,
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum Surround {
        Average,
        Dim,
        Dark,
    }

    impl ViewingConditions {
        pub fn new(white_point: XYZ, la: f64, yb: f64, surround: Surround) -> Self {
            Self {
                white_point,
                adapting_luminance: la,
                background_luminance: yb,
                surround,
                discount_illuminant: false,
            }
        }

        pub fn srgb_standard() -> Self {
            Self::new(
                XYZ { x: 0.95047, y: 1.0, z: 1.08883 },
                64.0,
                20.0,
                Surround::Average,
            )
        }

        pub fn dim_viewing() -> Self {
            Self::new(
                XYZ { x: 0.95047, y: 1.0, z: 1.08883 },
                16.0,
                20.0,
                Surround::Dim,
            )
        }

        fn surround_params(&self) -> (f64, f64, f64) {
            match self.surround {
                Surround::Average => (1.0, 0.69, 1.0),
                Surround::Dim => (0.9, 0.59, 0.9),
                Surround::Dark => (0.8, 0.525, 0.8),
            }
        }
    }

    /// CIECAM02 correlates - perceptual color attributes
    #[derive(Debug, Clone, Copy)]
    pub struct CIECAM02 {
        pub j: f64,         // Lightness
        pub c: f64,         // Chroma
        pub h: f64,         // Hue angle (degrees)
        pub s: f64,         // Saturation
        pub q: f64,         // Brightness
        pub m: f64,         // Colorfulness
        pub h_c: HueQuadrature, // Hue quadrature
    }

    #[derive(Debug, Clone, Copy)]
    pub struct HueQuadrature {
        pub h: f64,
        pub h_prime: f64,
        pub eccentricity: f64,
    }

    impl CIECAM02 {
        const M_CAT02: [[f64; 3]; 3] = [
            [0.7328, 0.4296, -0.1624],
            [-0.7036, 1.6975, 0.0061],
            [0.0030, 0.0136, 0.9834],
        ];

        const M_CAT02_INV: [[f64; 3]; 3] = [
            [1.096124, -0.278869, 0.182745],
            [0.454369, 0.473533, 0.072098],
            [-0.009628, -0.005698, 1.015326],
        ];

        const M_HPE: [[f64; 3]; 3] = [
            [0.38971, 0.68898, -0.07868],
            [-0.22981, 1.18340, 0.04641],
            [0.00000, 0.00000, 1.00000],
        ];

        pub fn from_xyz(xyz: XYZ, vc: &ViewingConditions) -> Self {
            let (c, nc, f) = vc.surround_params();
            let n = vc.background_luminance / vc.white_point.y;
            let z = 1.48 + n.sqrt();
            let nbb = 0.725 * n.powf(-0.2);
            let ncb = nbb;

            let k = 1.0 / (5.0 * vc.adapting_luminance + 1.0);
            let fl = 0.2 * k.powi(4) * 5.0 * vc.adapting_luminance
                + 0.1 * (1.0 - k.powi(4)).powi(2) * (5.0 * vc.adapting_luminance).powf(1.0 / 3.0);

            let rgb_w = Self::xyz_to_cat02(vc.white_point);
            let d = if vc.discount_illuminant {
                1.0
            } else {
                f * (1.0 - (1.0 / 3.6) * (-((vc.adapting_luminance + 42.0) / 92.0)).exp())
            };
            let d = d.clamp(0.0, 1.0);

            let rgb_c = Self::xyz_to_cat02(xyz);
            let rgb_c_adapted = [
                rgb_c[0] * (d * vc.white_point.y / rgb_w[0] + 1.0 - d),
                rgb_c[1] * (d * vc.white_point.y / rgb_w[1] + 1.0 - d),
                rgb_c[2] * (d * vc.white_point.y / rgb_w[2] + 1.0 - d),
            ];

            let rgb_w_adapted = [
                rgb_w[0] * (d * vc.white_point.y / rgb_w[0] + 1.0 - d),
                rgb_w[1] * (d * vc.white_point.y / rgb_w[1] + 1.0 - d),
                rgb_w[2] * (d * vc.white_point.y / rgb_w[2] + 1.0 - d),
            ];

            let rgb_prime = Self::cat02_to_hpe(rgb_c_adapted);
            let rgb_a = Self::nonlinear_adaptation(rgb_prime, fl);
            let rgb_w_prime = Self::cat02_to_hpe(rgb_w_adapted);
            let rgb_aw = Self::nonlinear_adaptation(rgb_w_prime, fl);

            let a = rgb_a[0] + (-12.0 * rgb_a[1] + rgb_a[2]) / 11.0;
            let b = (rgb_a[0] + rgb_a[1] - 2.0 * rgb_a[2]) / 9.0;

            let h_rad = b.atan2(a);
            let h = h_rad.to_degrees();
            let h = if h < 0.0 { h + 360.0 } else { h };

            let h_prime = if h < 20.14 { h + 360.0 } else { h };
            let eccentricity = 0.25 * (h_prime.to_radians().cos() + 3.8);

            let a_w = (2.0 * rgb_aw[0] + rgb_aw[1] + rgb_aw[2] / 20.0 - 0.305) * nbb;
            let a_sample = (2.0 * rgb_a[0] + rgb_a[1] + rgb_a[2] / 20.0 - 0.305) * nbb;

            let j = 100.0 * (a_sample / a_w).powf(c * z);
            let t = (50000.0 / 13.0 * nc * ncb * eccentricity * (a * a + b * b).sqrt())
                / (rgb_a[0] + rgb_a[1] + 21.0 * rgb_a[2] / 20.0);
            let chroma = t.powf(0.9) * (j / 100.0).powf(0.5) * (1.64 - 0.29f64.powf(n)).powf(0.73);
            let m = chroma * fl.powf(0.25);
            let s = 100.0 * (m / (rgb_a[0] + rgb_a[1] + 21.0 * rgb_a[2] / 20.0)).sqrt();
            let q = (4.0 / c) * (j / 100.0).sqrt() * (a_w + 4.0) * fl.powf(0.25);

            Self {
                j,
                c: chroma,
                h,
                s,
                q,
                m,
                h_c: HueQuadrature { h, h_prime, eccentricity },
            }
        }

        pub fn to_xyz(&self, vc: &ViewingConditions) -> XYZ {
            let (c, nc, f) = vc.surround_params();
            let n = vc.background_luminance / vc.white_point.y;
            let z = 1.48 + n.sqrt();
            let nbb = 0.725 * n.powf(-0.2);
            let ncb = nbb;

            let k = 1.0 / (5.0 * vc.adapting_luminance + 1.0);
            let fl = 0.2 * k.powi(4) * 5.0 * vc.adapting_luminance
                + 0.1 * (1.0 - k.powi(4)).powi(2) * (5.0 * vc.adapting_luminance).powf(1.0 / 3.0);

            let rgb_w = Self::xyz_to_cat02(vc.white_point);
            let d = if vc.discount_illuminant {
                1.0
            } else {
                f * (1.0 - (1.0 / 3.6) * (-((vc.adapting_luminance + 42.0) / 92.0)).exp())
            };

            let rgb_w_adapted = [
                rgb_w[0] * (d * vc.white_point.y / rgb_w[0] + 1.0 - d),
                rgb_w[1] * (d * vc.white_point.y / rgb_w[1] + 1.0 - d),
                rgb_w[2] * (d * vc.white_point.y / rgb_w[2] + 1.0 - d),
            ];

            let rgb_w_prime = Self::cat02_to_hpe(rgb_w_adapted);
            let rgb_aw = Self::nonlinear_adaptation(rgb_w_prime, fl);
            let a_w = (2.0 * rgb_aw[0] + rgb_aw[1] + rgb_aw[2] / 20.0 - 0.305) * nbb;

            let t = (self.c / ((self.j / 100.0).powf(0.5) * (1.64 - 0.29f64.powf(n)).powf(0.73))).powf(1.0 / 0.9);

            let h_rad = self.h.to_radians();
            let h_prime = if self.h < 20.14 { self.h + 360.0 } else { self.h };
            let et = 0.25 * (h_prime.to_radians().cos() + 3.8);

            let a_sample = a_w * (self.j / 100.0).powf(1.0 / (c * z));
            let p1 = (50000.0 / 13.0) * nc * ncb * et / t;
            let p2 = a_sample / nbb + 0.305;

            let sin_h = h_rad.sin();
            let cos_h = h_rad.cos();

            let (a, b) = if t.abs() < 1e-10 {
                (0.0, 0.0)
            } else {
                let num = p2 * (2.0 + 21.0 / 20.0) * 460.0 / 1403.0;
                let denom = p1 / sin_h
                    + (2.0 + 21.0 / 20.0) * (220.0 / 1403.0) * cos_h / sin_h
                    - 27.0 / 1403.0
                    + 21.0 / 20.0 * 6300.0 / 1403.0;
                let b_val = num / denom;
                let a_val = b_val * cos_h / sin_h;
                (a_val, b_val)
            };

            let rgb_a = [
                (460.0 * p2 + 451.0 * a + 288.0 * b) / 1403.0,
                (460.0 * p2 - 891.0 * a - 261.0 * b) / 1403.0,
                (460.0 * p2 - 220.0 * a - 6300.0 * b) / 1403.0,
            ];

            let rgb_prime = Self::inverse_nonlinear_adaptation(rgb_a, fl);
            let rgb_c_adapted = Self::hpe_to_cat02(rgb_prime);

            let rgb_c = [
                rgb_c_adapted[0] / (d * vc.white_point.y / rgb_w[0] + 1.0 - d),
                rgb_c_adapted[1] / (d * vc.white_point.y / rgb_w[1] + 1.0 - d),
                rgb_c_adapted[2] / (d * vc.white_point.y / rgb_w[2] + 1.0 - d),
            ];

            Self::cat02_to_xyz(rgb_c)
        }

        fn xyz_to_cat02(xyz: XYZ) -> [f64; 3] {
            [
                Self::M_CAT02[0][0] * xyz.x + Self::M_CAT02[0][1] * xyz.y + Self::M_CAT02[0][2] * xyz.z,
                Self::M_CAT02[1][0] * xyz.x + Self::M_CAT02[1][1] * xyz.y + Self::M_CAT02[1][2] * xyz.z,
                Self::M_CAT02[2][0] * xyz.x + Self::M_CAT02[2][1] * xyz.y + Self::M_CAT02[2][2] * xyz.z,
            ]
        }

        fn cat02_to_xyz(rgb: [f64; 3]) -> XYZ {
            XYZ {
                x: Self::M_CAT02_INV[0][0] * rgb[0] + Self::M_CAT02_INV[0][1] * rgb[1] + Self::M_CAT02_INV[0][2] * rgb[2],
                y: Self::M_CAT02_INV[1][0] * rgb[0] + Self::M_CAT02_INV[1][1] * rgb[1] + Self::M_CAT02_INV[1][2] * rgb[2],
                z: Self::M_CAT02_INV[2][0] * rgb[0] + Self::M_CAT02_INV[2][1] * rgb[1] + Self::M_CAT02_INV[2][2] * rgb[2],
            }
        }

        fn cat02_to_hpe(rgb: [f64; 3]) -> [f64; 3] {
            let xyz = Self::cat02_to_xyz(rgb);
            [
                Self::M_HPE[0][0] * xyz.x + Self::M_HPE[0][1] * xyz.y + Self::M_HPE[0][2] * xyz.z,
                Self::M_HPE[1][0] * xyz.x + Self::M_HPE[1][1] * xyz.y + Self::M_HPE[1][2] * xyz.z,
                Self::M_HPE[2][0] * xyz.x + Self::M_HPE[2][1] * xyz.y + Self::M_HPE[2][2] * xyz.z,
            ]
        }

        fn hpe_to_cat02(rgb: [f64; 3]) -> [f64; 3] {
            let m_hpe_inv = [
                [1.910197, -1.112124, 0.201908],
                [0.370950, 0.629054, -0.000008],
                [0.000000, 0.000000, 1.000000],
            ];
            let xyz = XYZ {
                x: m_hpe_inv[0][0] * rgb[0] + m_hpe_inv[0][1] * rgb[1] + m_hpe_inv[0][2] * rgb[2],
                y: m_hpe_inv[1][0] * rgb[0] + m_hpe_inv[1][1] * rgb[1] + m_hpe_inv[1][2] * rgb[2],
                z: m_hpe_inv[2][0] * rgb[0] + m_hpe_inv[2][1] * rgb[1] + m_hpe_inv[2][2] * rgb[2],
            };
            Self::xyz_to_cat02(xyz)
        }

        fn nonlinear_adaptation(rgb: [f64; 3], fl: f64) -> [f64; 3] {
            rgb.map(|c| {
                let c_abs = c.abs();
                let fl_c = (fl * c_abs / 100.0).powf(0.42);
                let sign = if c >= 0.0 { 1.0 } else { -1.0 };
                sign * 400.0 * fl_c / (fl_c + 27.13) + 0.1
            })
        }

        fn inverse_nonlinear_adaptation(rgb_a: [f64; 3], fl: f64) -> [f64; 3] {
            rgb_a.map(|c| {
                let c_shifted = c - 0.1;
                let sign = if c_shifted >= 0.0 { 1.0 } else { -1.0 };
                let c_abs = c_shifted.abs();
                let val = (27.13 * c_abs) / (400.0 - c_abs);
                sign * 100.0 / fl * val.powf(1.0 / 0.42)
            })
        }
    }

    /// CAM16 - Updated color appearance model
    #[derive(Debug, Clone, Copy)]
    pub struct CAM16 {
        pub j: f64,
        pub c: f64,
        pub h: f64,
        pub s: f64,
        pub q: f64,
        pub m: f64,
    }

    impl CAM16 {
        const M16: [[f64; 3]; 3] = [
            [0.401288, 0.650173, -0.051461],
            [-0.250268, 1.204414, 0.045854],
            [-0.002079, 0.048952, 0.953127],
        ];

        const M16_INV: [[f64; 3]; 3] = [
            [1.862068, -1.011255, 0.149187],
            [0.387527, 0.621447, -0.008974],
            [-0.015841, -0.034123, 1.049964],
        ];

        pub fn from_xyz(xyz: XYZ, vc: &ViewingConditions) -> Self {
            let (c, nc, f) = vc.surround_params();
            let n = vc.background_luminance / vc.white_point.y;
            let z = 1.48 + n.sqrt();
            let nbb = 0.725 * n.powf(-0.2);
            let ncb = nbb;

            let k = 1.0 / (5.0 * vc.adapting_luminance + 1.0);
            let k4 = k.powi(4);
            let fl = k4 * 0.2 * 5.0 * vc.adapting_luminance
                + 0.1 * (1.0 - k4).powi(2) * (5.0 * vc.adapting_luminance).powf(1.0 / 3.0);

            let rgb_w = Self::xyz_to_m16(vc.white_point);
            let d = if vc.discount_illuminant {
                1.0
            } else {
                f * (1.0 - (1.0 / 3.6) * (-(vc.adapting_luminance - 42.0) / 92.0).exp())
            };
            let d = d.clamp(0.0, 1.0);

            let d_rgb = [
                d * vc.white_point.y / rgb_w[0] + 1.0 - d,
                d * vc.white_point.y / rgb_w[1] + 1.0 - d,
                d * vc.white_point.y / rgb_w[2] + 1.0 - d,
            ];

            let rgb = Self::xyz_to_m16(xyz);
            let rgb_c = [rgb[0] * d_rgb[0], rgb[1] * d_rgb[1], rgb[2] * d_rgb[2]];
            let rgb_a = Self::adapt(rgb_c, fl);

            let rgb_wc = [rgb_w[0] * d_rgb[0], rgb_w[1] * d_rgb[1], rgb_w[2] * d_rgb[2]];
            let rgb_aw = Self::adapt(rgb_wc, fl);
            let a_w = (2.0 * rgb_aw[0] + rgb_aw[1] + rgb_aw[2] / 20.0 - 0.305) * nbb;

            let a = rgb_a[0] - 12.0 * rgb_a[1] / 11.0 + rgb_a[2] / 11.0;
            let b = (rgb_a[0] + rgb_a[1] - 2.0 * rgb_a[2]) / 9.0;

            let h_rad = b.atan2(a);
            let h = h_rad.to_degrees();
            let h = if h < 0.0 { h + 360.0 } else { h };

            let h_prime = if h < 20.14 { h + 360.0 } else { h };
            let e_t = 0.25 * (h_prime.to_radians().cos() + 3.8);

            let p1 = 50000.0 / 13.0 * nc * ncb * e_t;
            let p2 = a * a + b * b;
            let a_sample = (2.0 * rgb_a[0] + rgb_a[1] + rgb_a[2] / 20.0 - 0.305) * nbb;

            let j = 100.0 * (a_sample / a_w).powf(c * z);

            let t = p1 * p2.sqrt() / (rgb_a[0] + rgb_a[1] + 21.0 * rgb_a[2] / 20.0 + 0.305);
            let chroma = t.powf(0.9) * (j / 100.0).sqrt() * (1.64 - 0.29f64.powf(n)).powf(0.73);
            let m = chroma * fl.powf(0.25);
            let s = 50.0 * (c * m / (rgb_a[0] + rgb_a[1] + 21.0 * rgb_a[2] / 20.0)).sqrt();
            let q = 4.0 / c * (j / 100.0).sqrt() * (a_w + 4.0) * fl.powf(0.25);

            Self { j, c: chroma, h, s, q, m }
        }

        pub fn to_xyz(&self, vc: &ViewingConditions) -> XYZ {
            let (c, nc, f) = vc.surround_params();
            let n = vc.background_luminance / vc.white_point.y;
            let z = 1.48 + n.sqrt();
            let nbb = 0.725 * n.powf(-0.2);
            let ncb = nbb;

            let k = 1.0 / (5.0 * vc.adapting_luminance + 1.0);
            let k4 = k.powi(4);
            let fl = k4 * 0.2 * 5.0 * vc.adapting_luminance
                + 0.1 * (1.0 - k4).powi(2) * (5.0 * vc.adapting_luminance).powf(1.0 / 3.0);

            let rgb_w = Self::xyz_to_m16(vc.white_point);
            let d = if vc.discount_illuminant {
                1.0
            } else {
                f * (1.0 - (1.0 / 3.6) * (-(vc.adapting_luminance - 42.0) / 92.0).exp())
            };
            let d = d.clamp(0.0, 1.0);

            let d_rgb = [
                d * vc.white_point.y / rgb_w[0] + 1.0 - d,
                d * vc.white_point.y / rgb_w[1] + 1.0 - d,
                d * vc.white_point.y / rgb_w[2] + 1.0 - d,
            ];

            let rgb_wc = [rgb_w[0] * d_rgb[0], rgb_w[1] * d_rgb[1], rgb_w[2] * d_rgb[2]];
            let rgb_aw = Self::adapt(rgb_wc, fl);
            let a_w = (2.0 * rgb_aw[0] + rgb_aw[1] + rgb_aw[2] / 20.0 - 0.305) * nbb;

            let t = (self.c / ((self.j / 100.0).sqrt() * (1.64 - 0.29f64.powf(n)).powf(0.73))).powf(1.0 / 0.9);
            let h_rad = self.h.to_radians();
            let h_prime = if self.h < 20.14 { self.h + 360.0 } else { self.h };
            let e_t = 0.25 * (h_prime.to_radians().cos() + 3.8);

            let a_sample = a_w * (self.j / 100.0).powf(1.0 / (c * z));
            let p1 = 50000.0 / 13.0 * nc * ncb * e_t / t;
            let p2 = a_sample / nbb + 0.305;

            let (sin_h, cos_h) = (h_rad.sin(), h_rad.cos());

            let gamma = 23.0 * (p2 - 0.305) * (p1 + 23.0 * cos_h + 108.0 * sin_h / 11.0);
            let gamma = gamma / (23.0 * p1 + 23.0 * 23.0 * cos_h + 108.0 * sin_h);

            let a = gamma * cos_h;
            let b = gamma * sin_h;

            let rgb_a = [
                (460.0 * p2 + 451.0 * a + 288.0 * b) / 1403.0,
                (460.0 * p2 - 891.0 * a - 261.0 * b) / 1403.0,
                (460.0 * p2 - 220.0 * a - 6300.0 * b) / 1403.0,
            ];

            let rgb_c = Self::unadapt(rgb_a, fl);
            let rgb = [rgb_c[0] / d_rgb[0], rgb_c[1] / d_rgb[1], rgb_c[2] / d_rgb[2]];
            Self::m16_to_xyz(rgb)
        }

        fn xyz_to_m16(xyz: XYZ) -> [f64; 3] {
            [
                Self::M16[0][0] * xyz.x + Self::M16[0][1] * xyz.y + Self::M16[0][2] * xyz.z,
                Self::M16[1][0] * xyz.x + Self::M16[1][1] * xyz.y + Self::M16[1][2] * xyz.z,
                Self::M16[2][0] * xyz.x + Self::M16[2][1] * xyz.y + Self::M16[2][2] * xyz.z,
            ]
        }

        fn m16_to_xyz(rgb: [f64; 3]) -> XYZ {
            XYZ {
                x: Self::M16_INV[0][0] * rgb[0] + Self::M16_INV[0][1] * rgb[1] + Self::M16_INV[0][2] * rgb[2],
                y: Self::M16_INV[1][0] * rgb[0] + Self::M16_INV[1][1] * rgb[1] + Self::M16_INV[1][2] * rgb[2],
                z: Self::M16_INV[2][0] * rgb[0] + Self::M16_INV[2][1] * rgb[1] + Self::M16_INV[2][2] * rgb[2],
            }
        }

        fn adapt(rgb: [f64; 3], fl: f64) -> [f64; 3] {
            rgb.map(|c| {
                let c_abs = c.abs();
                let adapted = (fl * c_abs / 100.0).powf(0.42);
                let sign = if c >= 0.0 { 1.0 } else { -1.0 };
                sign * 400.0 * adapted / (adapted + 27.13) + 0.1
            })
        }

        fn unadapt(rgb_a: [f64; 3], fl: f64) -> [f64; 3] {
            rgb_a.map(|c| {
                let c_shifted = c - 0.1;
                let sign = if c_shifted >= 0.0 { 1.0 } else { -1.0 };
                let c_abs = c_shifted.abs();
                let val = 27.13 * c_abs / (400.0 - c_abs);
                sign * 100.0 / fl * val.powf(1.0 / 0.42)
            })
        }
    }

    /// Uniform Color Scales (UCS) from CAM16
    #[derive(Debug, Clone, Copy)]
    pub struct CAM16UCS {
        pub j_prime: f64,
        pub a_prime: f64,
        pub b_prime: f64,
    }

    impl CAM16UCS {
        const C1: f64 = 0.007;
        const C2: f64 = 0.0228;

        pub fn from_cam16(cam: &CAM16) -> Self {
            let m_prime = (1.0 / Self::C2) * (1.0 + Self::C2 * cam.m).ln();
            let j_prime = (1.0 + 100.0 * Self::C1) * cam.j / (1.0 + Self::C1 * cam.j);
            let h_rad = cam.h.to_radians();
            Self {
                j_prime,
                a_prime: m_prime * h_rad.cos(),
                b_prime: m_prime * h_rad.sin(),
            }
        }

        pub fn to_cam16(&self, vc: &ViewingConditions) -> CAM16 {
            let m_prime = (self.a_prime * self.a_prime + self.b_prime * self.b_prime).sqrt();
            let m = ((Self::C2 * m_prime).exp() - 1.0) / Self::C2;
            let h = self.b_prime.atan2(self.a_prime).to_degrees();
            let h = if h < 0.0 { h + 360.0 } else { h };
            let j = self.j_prime / (1.0 + 100.0 * Self::C1 - Self::C1 * self.j_prime);

            let (c_coef, _, _) = vc.surround_params();
            let n = vc.background_luminance / vc.white_point.y;
            let k = 1.0 / (5.0 * vc.adapting_luminance + 1.0);
            let k4 = k.powi(4);
            let fl = k4 * 0.2 * 5.0 * vc.adapting_luminance
                + 0.1 * (1.0 - k4).powi(2) * (5.0 * vc.adapting_luminance).powf(1.0 / 3.0);

            let chroma = m / fl.powf(0.25);
            let s = 50.0 * (c_coef * m).sqrt();
            let rgb_w = CAM16::xyz_to_m16(vc.white_point);
            let d = 1.0;
            let d_rgb = [
                d * vc.white_point.y / rgb_w[0] + 1.0 - d,
                d * vc.white_point.y / rgb_w[1] + 1.0 - d,
                d * vc.white_point.y / rgb_w[2] + 1.0 - d,
            ];
            let rgb_wc = [rgb_w[0] * d_rgb[0], rgb_w[1] * d_rgb[1], rgb_w[2] * d_rgb[2]];
            let rgb_aw = CAM16::adapt(rgb_wc, fl);
            let nbb = 0.725 * n.powf(-0.2);
            let a_w = (2.0 * rgb_aw[0] + rgb_aw[1] + rgb_aw[2] / 20.0 - 0.305) * nbb;
            let q = 4.0 / c_coef * (j / 100.0).sqrt() * (a_w + 4.0) * fl.powf(0.25);

            CAM16 { j, c: chroma, h, s, q, m }
        }

        pub fn delta_e(&self, other: &CAM16UCS) -> f64 {
            let dj = self.j_prime - other.j_prime;
            let da = self.a_prime - other.a_prime;
            let db = self.b_prime - other.b_prime;
            (dj * dj + da * da + db * db).sqrt()
        }
    }

    /// HCT - Hue, Chroma, Tone color space (Material Design 3)
    #[derive(Debug, Clone, Copy)]
    pub struct HCT {
        pub hue: f64,
        pub chroma: f64,
        pub tone: f64,
    }

    impl HCT {
        pub fn new(hue: f64, chroma: f64, tone: f64) -> Self {
            Self {
                hue: hue % 360.0,
                chroma: chroma.max(0.0),
                tone: tone.clamp(0.0, 100.0),
            }
        }

        pub fn from_argb(argb: u32) -> Self {
            let r = ((argb >> 16) & 0xFF) as f64 / 255.0;
            let g = ((argb >> 8) & 0xFF) as f64 / 255.0;
            let b = (argb & 0xFF) as f64 / 255.0;

            let xyz = Self::linear_rgb_to_xyz(
                Self::srgb_to_linear(r),
                Self::srgb_to_linear(g),
                Self::srgb_to_linear(b),
            );
            let vc = ViewingConditions::srgb_standard();
            let cam = CAM16::from_xyz(xyz, &vc);
            let tone = Self::y_to_lstar(xyz.y);

            Self::new(cam.h, cam.c, tone)
        }

        pub fn to_argb(&self) -> u32 {
            let mut low = 0.0;
            let mut high = 100.0;

            for _ in 0..100 {
                let mid = (low + high) / 2.0;
                let result = self.find_argb_with_chroma(mid);
                if let Some(argb) = result {
                    let found = Self::from_argb(argb);
                    if (found.chroma - self.chroma).abs() < 0.5 {
                        return argb;
                    }
                    if found.chroma < self.chroma {
                        high = mid;
                    } else {
                        low = mid;
                    }
                } else {
                    high = mid;
                }
            }

            self.find_argb_with_chroma(low).unwrap_or(0xFF000000)
        }

        fn find_argb_with_chroma(&self, chroma: f64) -> Option<u32> {
            let y = Self::lstar_to_y(self.tone);
            let vc = ViewingConditions::srgb_standard();

            let cam = CAM16 {
                j: self.tone,
                c: chroma,
                h: self.hue,
                s: 0.0,
                q: 0.0,
                m: 0.0,
            };
            let xyz = cam.to_xyz(&vc);

            let scaled_y = if xyz.y > 0.0 { y / xyz.y } else { 1.0 };
            let xyz_scaled = XYZ {
                x: xyz.x * scaled_y,
                y,
                z: xyz.z * scaled_y,
            };

            let (r, g, b) = Self::xyz_to_linear_rgb(xyz_scaled);
            if r < -0.001 || r > 1.001 || g < -0.001 || g > 1.001 || b < -0.001 || b > 1.001 {
                return None;
            }

            let r8 = (Self::linear_to_srgb(r.clamp(0.0, 1.0)) * 255.0).round() as u32;
            let g8 = (Self::linear_to_srgb(g.clamp(0.0, 1.0)) * 255.0).round() as u32;
            let b8 = (Self::linear_to_srgb(b.clamp(0.0, 1.0)) * 255.0).round() as u32;

            Some(0xFF000000 | (r8 << 16) | (g8 << 8) | b8)
        }

        fn srgb_to_linear(c: f64) -> f64 {
            if c <= 0.04045 { c / 12.92 } else { ((c + 0.055) / 1.055).powf(2.4) }
        }

        fn linear_to_srgb(c: f64) -> f64 {
            if c <= 0.0031308 { c * 12.92 } else { 1.055 * c.powf(1.0 / 2.4) - 0.055 }
        }

        fn linear_rgb_to_xyz(r: f64, g: f64, b: f64) -> XYZ {
            XYZ {
                x: 0.4124564 * r + 0.3575761 * g + 0.1804375 * b,
                y: 0.2126729 * r + 0.7151522 * g + 0.0721750 * b,
                z: 0.0193339 * r + 0.1191920 * g + 0.9503041 * b,
            }
        }

        fn xyz_to_linear_rgb(xyz: XYZ) -> (f64, f64, f64) {
            (
                3.2404542 * xyz.x - 1.5371385 * xyz.y - 0.4985314 * xyz.z,
                -0.9692660 * xyz.x + 1.8760108 * xyz.y + 0.0415560 * xyz.z,
                0.0556434 * xyz.x - 0.2040259 * xyz.y + 1.0572252 * xyz.z,
            )
        }

        fn y_to_lstar(y: f64) -> f64 {
            let fy = if y > 0.008856 {
                y.powf(1.0 / 3.0)
            } else {
                (903.3 * y + 16.0) / 116.0
            };
            116.0 * fy - 16.0
        }

        fn lstar_to_y(lstar: f64) -> f64 {
            let fy = (lstar + 16.0) / 116.0;
            if fy > 0.206893 {
                fy.powi(3)
            } else {
                (116.0 * fy - 16.0) / 903.3
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HDR COLOR SPACES
// ═══════════════════════════════════════════════════════════════════════════════

pub mod hdr_color {
    use super::*;

    /// ICtCp color space - ITU-R BT.2100
    #[derive(Debug, Clone, Copy)]
    pub struct ICtCp {
        pub i: f64,   // Intensity
        pub ct: f64,  // Chroma tritan
        pub cp: f64,  // Chroma protan
    }

    impl ICtCp {
        const M1: [[f64; 3]; 3] = [
            [0.412109, 0.523926, 0.063965],
            [0.166748, 0.720459, 0.112793],
            [0.024170, 0.075440, 0.900390],
        ];

        const M2: [[f64; 3]; 3] = [
            [2048.0 / 4096.0, 2048.0 / 4096.0, 0.0],
            [6610.0 / 4096.0, -13613.0 / 4096.0, 7003.0 / 4096.0],
            [17933.0 / 4096.0, -17390.0 / 4096.0, -543.0 / 4096.0],
        ];

        const M2_INV: [[f64; 3]; 3] = [
            [1.0, 0.008609, 0.111030],
            [1.0, -0.008609, -0.111030],
            [1.0, 0.560032, -0.320627],
        ];

        const M1_INV: [[f64; 3]; 3] = [
            [3.436607, -2.506201, 0.069594],
            [-0.791329, 1.983600, -0.192271],
            [-0.025950, -0.099003, 1.124954],
        ];

        pub fn from_xyz(xyz: XYZ) -> Self {
            let lms = [
                Self::M1[0][0] * xyz.x + Self::M1[0][1] * xyz.y + Self::M1[0][2] * xyz.z,
                Self::M1[1][0] * xyz.x + Self::M1[1][1] * xyz.y + Self::M1[1][2] * xyz.z,
                Self::M1[2][0] * xyz.x + Self::M1[2][1] * xyz.y + Self::M1[2][2] * xyz.z,
            ];

            let lms_prime = lms.map(Self::pq_eotf);

            Self {
                i: Self::M2[0][0] * lms_prime[0] + Self::M2[0][1] * lms_prime[1] + Self::M2[0][2] * lms_prime[2],
                ct: Self::M2[1][0] * lms_prime[0] + Self::M2[1][1] * lms_prime[1] + Self::M2[1][2] * lms_prime[2],
                cp: Self::M2[2][0] * lms_prime[0] + Self::M2[2][1] * lms_prime[1] + Self::M2[2][2] * lms_prime[2],
            }
        }

        pub fn to_xyz(&self) -> XYZ {
            let lms_prime = [
                Self::M2_INV[0][0] * self.i + Self::M2_INV[0][1] * self.ct + Self::M2_INV[0][2] * self.cp,
                Self::M2_INV[1][0] * self.i + Self::M2_INV[1][1] * self.ct + Self::M2_INV[1][2] * self.cp,
                Self::M2_INV[2][0] * self.i + Self::M2_INV[2][1] * self.ct + Self::M2_INV[2][2] * self.cp,
            ];

            let lms = lms_prime.map(Self::pq_oetf);

            XYZ {
                x: Self::M1_INV[0][0] * lms[0] + Self::M1_INV[0][1] * lms[1] + Self::M1_INV[0][2] * lms[2],
                y: Self::M1_INV[1][0] * lms[0] + Self::M1_INV[1][1] * lms[1] + Self::M1_INV[1][2] * lms[2],
                z: Self::M1_INV[2][0] * lms[0] + Self::M1_INV[2][1] * lms[1] + Self::M1_INV[2][2] * lms[2],
            }
        }

        fn pq_eotf(v: f64) -> f64 {
            let m1 = 2610.0 / 16384.0;
            let m2 = 2523.0 / 4096.0 * 128.0;
            let c1 = 3424.0 / 4096.0;
            let c2 = 2413.0 / 4096.0 * 32.0;
            let c3 = 2392.0 / 4096.0 * 32.0;

            let y_abs = v.abs().max(0.0);
            let y_m1 = y_abs.powf(m1);
            let num = (c1 + c2 * y_m1).max(0.0);
            let den = (1.0 + c3 * y_m1).max(1e-10);
            (num / den).powf(m2)
        }

        fn pq_oetf(l: f64) -> f64 {
            let m1 = 2610.0 / 16384.0;
            let m2 = 2523.0 / 4096.0 * 128.0;
            let c1 = 3424.0 / 4096.0;
            let c2 = 2413.0 / 4096.0 * 32.0;
            let c3 = 2392.0 / 4096.0 * 32.0;

            let l_abs = l.abs().max(0.0);
            let l_m2_inv = l_abs.powf(1.0 / m2);
            let num = (l_m2_inv - c1).max(0.0);
            let den = (c2 - c3 * l_m2_inv).max(1e-10);
            (num / den).powf(1.0 / m1)
        }

        pub fn delta_e(&self, other: &ICtCp) -> f64 {
            let di = 720.0 * (self.i - other.i);
            let dct = 360.0 * (self.ct - other.ct);
            let dcp = 360.0 * (self.cp - other.cp);
            (di * di + dct * dct + dcp * dcp).sqrt()
        }
    }

    /// Jzazbz color space - perceptually uniform HDR
    #[derive(Debug, Clone, Copy)]
    pub struct Jzazbz {
        pub jz: f64,
        pub az: f64,
        pub bz: f64,
    }

    impl Jzazbz {
        const B: f64 = 1.15;
        const G: f64 = 0.66;
        const C1: f64 = 0.8359375;
        const C2: f64 = 18.8515625;
        const C3: f64 = 18.6875;
        const N: f64 = 0.15930175781;
        const P: f64 = 134.034375;
        const D: f64 = -0.56;
        const D0: f64 = 1.6295499532821566e-11;

        const M1: [[f64; 3]; 3] = [
            [0.41478972, 0.579999, 0.0146480],
            [-0.2015100, 1.120649, 0.0531008],
            [-0.0166008, 0.264800, 0.6684799],
        ];

        const M2: [[f64; 3]; 3] = [
            [0.5, 0.5, 0.0],
            [3.524000, -4.066708, 0.542708],
            [0.199076, 1.096799, -1.295875],
        ];

        const M1_INV: [[f64; 3]; 3] = [
            [1.9242264358, -1.0047923126, 0.0376514040],
            [0.3503167621, 0.7264811939, -0.0653844229],
            [-0.0909828110, -0.3127282905, 1.5227665613],
        ];

        const M2_INV: [[f64; 3]; 3] = [
            [1.0, 0.1386050433, 0.0580473162],
            [1.0, -0.1386050433, -0.0580473162],
            [1.0, -0.0960192421, -0.8118918960],
        ];

        pub fn from_xyz(xyz: XYZ) -> Self {
            let x_prime = Self::B * xyz.x - (Self::B - 1.0) * xyz.z;
            let y_prime = Self::G * xyz.y - (Self::G - 1.0) * xyz.x;

            let lms = [
                Self::M1[0][0] * x_prime + Self::M1[0][1] * y_prime + Self::M1[0][2] * xyz.z,
                Self::M1[1][0] * x_prime + Self::M1[1][1] * y_prime + Self::M1[1][2] * xyz.z,
                Self::M1[2][0] * x_prime + Self::M1[2][1] * y_prime + Self::M1[2][2] * xyz.z,
            ];

            let lms_prime = lms.map(|v| {
                let v_abs = v.abs();
                let v_n = (v_abs / 10000.0).powf(Self::N);
                let num = Self::C1 + Self::C2 * v_n;
                let den = 1.0 + Self::C3 * v_n;
                (num / den).powf(Self::P) * v.signum()
            });

            let iz = Self::M2[0][0] * lms_prime[0] + Self::M2[0][1] * lms_prime[1] + Self::M2[0][2] * lms_prime[2];
            let az = Self::M2[1][0] * lms_prime[0] + Self::M2[1][1] * lms_prime[1] + Self::M2[1][2] * lms_prime[2];
            let bz = Self::M2[2][0] * lms_prime[0] + Self::M2[2][1] * lms_prime[1] + Self::M2[2][2] * lms_prime[2];

            let jz = ((1.0 + Self::D) * iz) / (1.0 + Self::D * iz) - Self::D0;

            Self { jz, az, bz }
        }

        pub fn to_xyz(&self) -> XYZ {
            let iz = (self.jz + Self::D0) / (1.0 + Self::D - Self::D * (self.jz + Self::D0));

            let lms_prime = [
                Self::M2_INV[0][0] * iz + Self::M2_INV[0][1] * self.az + Self::M2_INV[0][2] * self.bz,
                Self::M2_INV[1][0] * iz + Self::M2_INV[1][1] * self.az + Self::M2_INV[1][2] * self.bz,
                Self::M2_INV[2][0] * iz + Self::M2_INV[2][1] * self.az + Self::M2_INV[2][2] * self.bz,
            ];

            let lms = lms_prime.map(|v| {
                let v_abs = v.abs();
                let v_p = v_abs.powf(1.0 / Self::P);
                let num = Self::C1 - v_p;
                let den = Self::C3 * v_p - Self::C2;
                10000.0 * (num / den).powf(1.0 / Self::N) * v.signum()
            });

            let x_prime = Self::M1_INV[0][0] * lms[0] + Self::M1_INV[0][1] * lms[1] + Self::M1_INV[0][2] * lms[2];
            let y_prime = Self::M1_INV[1][0] * lms[0] + Self::M1_INV[1][1] * lms[1] + Self::M1_INV[1][2] * lms[2];
            let z = Self::M1_INV[2][0] * lms[0] + Self::M1_INV[2][1] * lms[1] + Self::M1_INV[2][2] * lms[2];

            let x = (x_prime + (Self::B - 1.0) * z) / Self::B;
            let y = (y_prime + (Self::G - 1.0) * x) / Self::G;

            XYZ { x, y, z }
        }

        pub fn delta_e(&self, other: &Jzazbz) -> f64 {
            let djz = self.jz - other.jz;
            let daz = self.az - other.az;
            let dbz = self.bz - other.bz;
            (djz * djz + daz * daz + dbz * dbz).sqrt()
        }

        pub fn to_jzczhz(&self) -> JzCzhz {
            let cz = (self.az * self.az + self.bz * self.bz).sqrt();
            let hz = self.bz.atan2(self.az).to_degrees();
            let hz = if hz < 0.0 { hz + 360.0 } else { hz };
            JzCzhz { jz: self.jz, cz, hz }
        }
    }

    /// Cylindrical form of Jzazbz
    #[derive(Debug, Clone, Copy)]
    pub struct JzCzhz {
        pub jz: f64,
        pub cz: f64,
        pub hz: f64,
    }

    impl JzCzhz {
        pub fn to_jzazbz(&self) -> Jzazbz {
            let h_rad = self.hz.to_radians();
            Jzazbz {
                jz: self.jz,
                az: self.cz * h_rad.cos(),
                bz: self.cz * h_rad.sin(),
            }
        }
    }

    /// ACEScg color space - ACES working space
    #[derive(Debug, Clone, Copy)]
    pub struct ACEScg {
        pub r: f64,
        pub g: f64,
        pub b: f64,
    }

    impl ACEScg {
        const XYZ_TO_AP1: [[f64; 3]; 3] = [
            [1.6410234, -0.3248033, -0.2364247],
            [-0.6636629, 1.6153316, 0.0167563],
            [0.0117219, -0.0082844, 0.9883948],
        ];

        const AP1_TO_XYZ: [[f64; 3]; 3] = [
            [0.6624542, 0.1340042, 0.1561877],
            [0.2722287, 0.6740818, 0.0536895],
            [-0.0055746, 0.0040607, 1.0103391],
        ];

        pub fn from_xyz(xyz: XYZ) -> Self {
            Self {
                r: Self::XYZ_TO_AP1[0][0] * xyz.x + Self::XYZ_TO_AP1[0][1] * xyz.y + Self::XYZ_TO_AP1[0][2] * xyz.z,
                g: Self::XYZ_TO_AP1[1][0] * xyz.x + Self::XYZ_TO_AP1[1][1] * xyz.y + Self::XYZ_TO_AP1[1][2] * xyz.z,
                b: Self::XYZ_TO_AP1[2][0] * xyz.x + Self::XYZ_TO_AP1[2][1] * xyz.y + Self::XYZ_TO_AP1[2][2] * xyz.z,
            }
        }

        pub fn to_xyz(&self) -> XYZ {
            XYZ {
                x: Self::AP1_TO_XYZ[0][0] * self.r + Self::AP1_TO_XYZ[0][1] * self.g + Self::AP1_TO_XYZ[0][2] * self.b,
                y: Self::AP1_TO_XYZ[1][0] * self.r + Self::AP1_TO_XYZ[1][1] * self.g + Self::AP1_TO_XYZ[1][2] * self.b,
                z: Self::AP1_TO_XYZ[2][0] * self.r + Self::AP1_TO_XYZ[2][1] * self.g + Self::AP1_TO_XYZ[2][2] * self.b,
            }
        }

        pub fn is_in_gamut(&self) -> bool {
            self.r >= 0.0 && self.g >= 0.0 && self.b >= 0.0
        }

        pub fn clamp(&self) -> Self {
            Self {
                r: self.r.max(0.0),
                g: self.g.max(0.0),
                b: self.b.max(0.0),
            }
        }
    }

    /// ACES2065-1 (AP0) color space
    #[derive(Debug, Clone, Copy)]
    pub struct ACES2065 {
        pub r: f64,
        pub g: f64,
        pub b: f64,
    }

    impl ACES2065 {
        const XYZ_TO_AP0: [[f64; 3]; 3] = [
            [1.0498110, 0.0000000, -0.0000974],
            [-0.4959030, 1.3733130, 0.0982400],
            [0.0000000, 0.0000000, 0.9912520],
        ];

        const AP0_TO_XYZ: [[f64; 3]; 3] = [
            [0.9525524, 0.0000000, 0.0000937],
            [0.3439664, 0.7281661, -0.0721325],
            [0.0000000, 0.0000000, 1.0088251],
        ];

        pub fn from_xyz(xyz: XYZ) -> Self {
            Self {
                r: Self::XYZ_TO_AP0[0][0] * xyz.x + Self::XYZ_TO_AP0[0][1] * xyz.y + Self::XYZ_TO_AP0[0][2] * xyz.z,
                g: Self::XYZ_TO_AP0[1][0] * xyz.x + Self::XYZ_TO_AP0[1][1] * xyz.y + Self::XYZ_TO_AP0[1][2] * xyz.z,
                b: Self::XYZ_TO_AP0[2][0] * xyz.x + Self::XYZ_TO_AP0[2][1] * xyz.y + Self::XYZ_TO_AP0[2][2] * xyz.z,
            }
        }

        pub fn to_xyz(&self) -> XYZ {
            XYZ {
                x: Self::AP0_TO_XYZ[0][0] * self.r + Self::AP0_TO_XYZ[0][1] * self.g + Self::AP0_TO_XYZ[0][2] * self.b,
                y: Self::AP0_TO_XYZ[1][0] * self.r + Self::AP0_TO_XYZ[1][1] * self.g + Self::AP0_TO_XYZ[1][2] * self.b,
                z: Self::AP0_TO_XYZ[2][0] * self.r + Self::AP0_TO_XYZ[2][1] * self.g + Self::AP0_TO_XYZ[2][2] * self.b,
            }
        }

        pub fn to_acescg(&self) -> ACEScg {
            let xyz = self.to_xyz();
            ACEScg::from_xyz(xyz)
        }
    }

    /// Oklab color space - perceptually uniform
    #[derive(Debug, Clone, Copy)]
    pub struct Oklab {
        pub l: f64,
        pub a: f64,
        pub b: f64,
    }

    impl Oklab {
        const M1: [[f64; 3]; 3] = [
            [0.8189330101, 0.3618667424, -0.1288597137],
            [0.0329845436, 0.9293118715, 0.0361456387],
            [0.0482003018, 0.2643662691, 0.6338517070],
        ];

        const M2: [[f64; 3]; 3] = [
            [0.2104542553, 0.7936177850, -0.0040720468],
            [1.9779984951, -2.4285922050, 0.4505937099],
            [0.0259040371, 0.7827717662, -0.8086757660],
        ];

        const M1_INV: [[f64; 3]; 3] = [
            [1.2270138511, -0.5577999807, 0.2812561490],
            [-0.0405801784, 1.1122568696, -0.0716766787],
            [-0.0763812845, -0.4214819784, 1.5861632204],
        ];

        const M2_INV: [[f64; 3]; 3] = [
            [1.0, 0.3963377774, 0.2158037573],
            [1.0, -0.1055613458, -0.0638541728],
            [1.0, -0.0894841775, -1.2914855480],
        ];

        pub fn from_linear_rgb(r: f64, g: f64, b: f64) -> Self {
            let l = Self::M1[0][0] * r + Self::M1[0][1] * g + Self::M1[0][2] * b;
            let m = Self::M1[1][0] * r + Self::M1[1][1] * g + Self::M1[1][2] * b;
            let s = Self::M1[2][0] * r + Self::M1[2][1] * g + Self::M1[2][2] * b;

            let l_prime = l.cbrt();
            let m_prime = m.cbrt();
            let s_prime = s.cbrt();

            Self {
                l: Self::M2[0][0] * l_prime + Self::M2[0][1] * m_prime + Self::M2[0][2] * s_prime,
                a: Self::M2[1][0] * l_prime + Self::M2[1][1] * m_prime + Self::M2[1][2] * s_prime,
                b: Self::M2[2][0] * l_prime + Self::M2[2][1] * m_prime + Self::M2[2][2] * s_prime,
            }
        }

        pub fn to_linear_rgb(&self) -> (f64, f64, f64) {
            let l_prime = Self::M2_INV[0][0] * self.l + Self::M2_INV[0][1] * self.a + Self::M2_INV[0][2] * self.b;
            let m_prime = Self::M2_INV[1][0] * self.l + Self::M2_INV[1][1] * self.a + Self::M2_INV[1][2] * self.b;
            let s_prime = Self::M2_INV[2][0] * self.l + Self::M2_INV[2][1] * self.a + Self::M2_INV[2][2] * self.b;

            let l = l_prime.powi(3);
            let m = m_prime.powi(3);
            let s = s_prime.powi(3);

            (
                Self::M1_INV[0][0] * l + Self::M1_INV[0][1] * m + Self::M1_INV[0][2] * s,
                Self::M1_INV[1][0] * l + Self::M1_INV[1][1] * m + Self::M1_INV[1][2] * s,
                Self::M1_INV[2][0] * l + Self::M1_INV[2][1] * m + Self::M1_INV[2][2] * s,
            )
        }

        pub fn to_oklch(&self) -> Oklch {
            let c = (self.a * self.a + self.b * self.b).sqrt();
            let h = self.b.atan2(self.a).to_degrees();
            let h = if h < 0.0 { h + 360.0 } else { h };
            Oklch { l: self.l, c, h }
        }

        pub fn delta_e(&self, other: &Oklab) -> f64 {
            let dl = self.l - other.l;
            let da = self.a - other.a;
            let db = self.b - other.b;
            (dl * dl + da * da + db * db).sqrt()
        }
    }

    /// Oklch - cylindrical form of Oklab
    #[derive(Debug, Clone, Copy)]
    pub struct Oklch {
        pub l: f64,
        pub c: f64,
        pub h: f64,
    }

    impl Oklch {
        pub fn to_oklab(&self) -> Oklab {
            let h_rad = self.h.to_radians();
            Oklab {
                l: self.l,
                a: self.c * h_rad.cos(),
                b: self.c * h_rad.sin(),
            }
        }

        pub fn lerp(&self, other: &Oklch, t: f64) -> Oklch {
            let h1 = self.h;
            let h2 = other.h;
            let delta = h2 - h1;
            let delta = if delta > 180.0 {
                delta - 360.0
            } else if delta < -180.0 {
                delta + 360.0
            } else {
                delta
            };
            let h = (h1 + delta * t + 360.0) % 360.0;

            Oklch {
                l: self.l + (other.l - self.l) * t,
                c: self.c + (other.c - self.c) * t,
                h,
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR BLINDNESS SIMULATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod color_blindness {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum DeficiencyType {
        Protanopia,     // No red cones
        Deuteranopia,   // No green cones
        Tritanopia,     // No blue cones
        Protanomaly,    // Weak red cones
        Deuteranomaly,  // Weak green cones
        Tritanomaly,    // Weak blue cones
        Achromatopsia,  // Complete color blindness
    }

    /// Color blindness simulator using Brettel model
    pub struct ColorBlindnessSimulator {
        deficiency: DeficiencyType,
        severity: f64,
    }

    impl ColorBlindnessSimulator {
        pub fn new(deficiency: DeficiencyType, severity: f64) -> Self {
            Self {
                deficiency,
                severity: severity.clamp(0.0, 1.0),
            }
        }

        pub fn simulate_rgb(&self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
            let (sim_r, sim_g, sim_b) = match self.deficiency {
                DeficiencyType::Protanopia => self.simulate_protan(r, g, b),
                DeficiencyType::Deuteranopia => self.simulate_deutan(r, g, b),
                DeficiencyType::Tritanopia => self.simulate_tritan(r, g, b),
                DeficiencyType::Protanomaly => {
                    let (sr, sg, sb) = self.simulate_protan(r, g, b);
                    self.blend(r, g, b, sr, sg, sb)
                }
                DeficiencyType::Deuteranomaly => {
                    let (sr, sg, sb) = self.simulate_deutan(r, g, b);
                    self.blend(r, g, b, sr, sg, sb)
                }
                DeficiencyType::Tritanomaly => {
                    let (sr, sg, sb) = self.simulate_tritan(r, g, b);
                    self.blend(r, g, b, sr, sg, sb)
                }
                DeficiencyType::Achromatopsia => {
                    let y = 0.299 * r + 0.587 * g + 0.114 * b;
                    self.blend(r, g, b, y, y, y)
                }
            };
            (sim_r.clamp(0.0, 1.0), sim_g.clamp(0.0, 1.0), sim_b.clamp(0.0, 1.0))
        }

        fn simulate_protan(&self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
            let m = [
                [0.567, 0.433, 0.0],
                [0.558, 0.442, 0.0],
                [0.0, 0.242, 0.758],
            ];
            (
                m[0][0] * r + m[0][1] * g + m[0][2] * b,
                m[1][0] * r + m[1][1] * g + m[1][2] * b,
                m[2][0] * r + m[2][1] * g + m[2][2] * b,
            )
        }

        fn simulate_deutan(&self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
            let m = [
                [0.625, 0.375, 0.0],
                [0.7, 0.3, 0.0],
                [0.0, 0.3, 0.7],
            ];
            (
                m[0][0] * r + m[0][1] * g + m[0][2] * b,
                m[1][0] * r + m[1][1] * g + m[1][2] * b,
                m[2][0] * r + m[2][1] * g + m[2][2] * b,
            )
        }

        fn simulate_tritan(&self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
            let m = [
                [0.95, 0.05, 0.0],
                [0.0, 0.433, 0.567],
                [0.0, 0.475, 0.525],
            ];
            (
                m[0][0] * r + m[0][1] * g + m[0][2] * b,
                m[1][0] * r + m[1][1] * g + m[1][2] * b,
                m[2][0] * r + m[2][1] * g + m[2][2] * b,
            )
        }

        fn blend(&self, r: f64, g: f64, b: f64, sr: f64, sg: f64, sb: f64) -> (f64, f64, f64) {
            let t = self.severity;
            (
                r + t * (sr - r),
                g + t * (sg - g),
                b + t * (sb - b),
            )
        }
    }

    /// Daltonization - color correction for color blind viewers
    pub struct Daltonizer {
        deficiency: DeficiencyType,
    }

    impl Daltonizer {
        pub fn new(deficiency: DeficiencyType) -> Self {
            Self { deficiency }
        }

        pub fn correct_rgb(&self, r: f64, g: f64, b: f64) -> (f64, f64, f64) {
            let sim = ColorBlindnessSimulator::new(self.deficiency, 1.0);
            let (sr, sg, sb) = sim.simulate_rgb(r, g, b);

            let err_r = r - sr;
            let err_g = g - sg;
            let err_b = b - sb;

            let (shift_r, shift_g, shift_b) = match self.deficiency {
                DeficiencyType::Protanopia | DeficiencyType::Protanomaly => {
                    (0.0, 0.7 * err_r + 1.0 * err_g, 0.7 * err_r)
                }
                DeficiencyType::Deuteranopia | DeficiencyType::Deuteranomaly => {
                    (0.7 * err_g + 1.0 * err_r, 0.0, 0.7 * err_g)
                }
                DeficiencyType::Tritanopia | DeficiencyType::Tritanomaly => {
                    (0.7 * err_b, 0.7 * err_b + 1.0 * err_g, 0.0)
                }
                DeficiencyType::Achromatopsia => (0.0, 0.0, 0.0),
            };

            (
                (r + shift_r).clamp(0.0, 1.0),
                (g + shift_g).clamp(0.0, 1.0),
                (b + shift_b).clamp(0.0, 1.0),
            )
        }
    }

    /// Color pair contrast checker for accessibility
    pub struct ContrastChecker;

    impl ContrastChecker {
        pub fn relative_luminance(r: f64, g: f64, b: f64) -> f64 {
            let to_linear = |c: f64| {
                if c <= 0.03928 { c / 12.92 } else { ((c + 0.055) / 1.055).powf(2.4) }
            };
            0.2126 * to_linear(r) + 0.7152 * to_linear(g) + 0.0722 * to_linear(b)
        }

        pub fn contrast_ratio(l1: f64, l2: f64) -> f64 {
            let lighter = l1.max(l2);
            let darker = l1.min(l2);
            (lighter + 0.05) / (darker + 0.05)
        }

        pub fn wcag_aa_normal(ratio: f64) -> bool {
            ratio >= 4.5
        }

        pub fn wcag_aa_large(ratio: f64) -> bool {
            ratio >= 3.0
        }

        pub fn wcag_aaa_normal(ratio: f64) -> bool {
            ratio >= 7.0
        }

        pub fn wcag_aaa_large(ratio: f64) -> bool {
            ratio >= 4.5
        }

        pub fn check_pair(&self, fg: (f64, f64, f64), bg: (f64, f64, f64)) -> ContrastResult {
            let l1 = Self::relative_luminance(fg.0, fg.1, fg.2);
            let l2 = Self::relative_luminance(bg.0, bg.1, bg.2);
            let ratio = Self::contrast_ratio(l1, l2);

            ContrastResult {
                ratio,
                aa_normal: Self::wcag_aa_normal(ratio),
                aa_large: Self::wcag_aa_large(ratio),
                aaa_normal: Self::wcag_aaa_normal(ratio),
                aaa_large: Self::wcag_aaa_large(ratio),
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct ContrastResult {
        pub ratio: f64,
        pub aa_normal: bool,
        pub aa_large: bool,
        pub aaa_normal: bool,
        pub aaa_large: bool,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR HARMONY AND PALETTE GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod color_harmony {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum HarmonyType {
        Complementary,
        Analogous,
        Triadic,
        SplitComplementary,
        Tetradic,
        Square,
        Monochromatic,
    }

    /// Generate harmonious color palettes
    pub struct PaletteGenerator;

    impl PaletteGenerator {
        pub fn generate(base_hsl: HSL, harmony: HarmonyType) -> Vec<HSL> {
            match harmony {
                HarmonyType::Complementary => vec![
                    base_hsl,
                    HSL { h: (base_hsl.h + 180.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                ],
                HarmonyType::Analogous => vec![
                    HSL { h: (base_hsl.h + 330.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    base_hsl,
                    HSL { h: (base_hsl.h + 30.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                ],
                HarmonyType::Triadic => vec![
                    base_hsl,
                    HSL { h: (base_hsl.h + 120.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    HSL { h: (base_hsl.h + 240.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                ],
                HarmonyType::SplitComplementary => vec![
                    base_hsl,
                    HSL { h: (base_hsl.h + 150.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    HSL { h: (base_hsl.h + 210.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                ],
                HarmonyType::Tetradic => vec![
                    base_hsl,
                    HSL { h: (base_hsl.h + 60.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    HSL { h: (base_hsl.h + 180.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    HSL { h: (base_hsl.h + 240.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                ],
                HarmonyType::Square => vec![
                    base_hsl,
                    HSL { h: (base_hsl.h + 90.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    HSL { h: (base_hsl.h + 180.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                    HSL { h: (base_hsl.h + 270.0) % 360.0, s: base_hsl.s, l: base_hsl.l },
                ],
                HarmonyType::Monochromatic => vec![
                    HSL { h: base_hsl.h, s: base_hsl.s, l: (base_hsl.l * 0.5).max(0.0) },
                    HSL { h: base_hsl.h, s: base_hsl.s, l: (base_hsl.l * 0.75).max(0.0) },
                    base_hsl,
                    HSL { h: base_hsl.h, s: base_hsl.s, l: (base_hsl.l * 1.25).min(1.0) },
                    HSL { h: base_hsl.h, s: base_hsl.s, l: (base_hsl.l * 1.5).min(1.0) },
                ],
            }
        }

        pub fn generate_shades(base_hsl: HSL, count: usize) -> Vec<HSL> {
            (0..count)
                .map(|i| {
                    let t = i as f64 / (count - 1).max(1) as f64;
                    HSL {
                        h: base_hsl.h,
                        s: base_hsl.s,
                        l: 0.1 + 0.8 * (1.0 - t),
                    }
                })
                .collect()
        }

        pub fn generate_tints(base_hsl: HSL, count: usize) -> Vec<HSL> {
            (0..count)
                .map(|i| {
                    let t = i as f64 / (count - 1).max(1) as f64;
                    HSL {
                        h: base_hsl.h,
                        s: base_hsl.s * (1.0 - t * 0.5),
                        l: base_hsl.l + (1.0 - base_hsl.l) * t,
                    }
                })
                .collect()
        }

        pub fn generate_tones(base_hsl: HSL, count: usize) -> Vec<HSL> {
            (0..count)
                .map(|i| {
                    let t = i as f64 / (count - 1).max(1) as f64;
                    HSL {
                        h: base_hsl.h,
                        s: base_hsl.s * (1.0 - t * 0.8),
                        l: base_hsl.l,
                    }
                })
                .collect()
        }
    }

    /// Color temperature and mood analysis
    pub struct ColorTemperature;

    impl ColorTemperature {
        pub fn classify(hsl: HSL) -> Temperature {
            if hsl.s < 0.1 {
                return Temperature::Neutral;
            }

            let h = hsl.h;
            if (h >= 0.0 && h < 60.0) || (h >= 300.0 && h <= 360.0) {
                Temperature::Warm
            } else if h >= 180.0 && h < 300.0 {
                Temperature::Cool
            } else {
                Temperature::Neutral
            }
        }

        pub fn warmth_score(hsl: HSL) -> f64 {
            let h = if hsl.h > 180.0 { hsl.h - 360.0 } else { hsl.h };
            let warm_center = 30.0;
            let distance = (h - warm_center).abs();
            let normalized = 1.0 - (distance / 180.0).min(1.0);
            normalized * hsl.s
        }
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum Temperature {
        Warm,
        Cool,
        Neutral,
    }

    /// Material Design palette generator
    pub struct MaterialPalette;

    impl MaterialPalette {
        pub fn generate(base_hsl: HSL) -> MaterialColors {
            let base_l = base_hsl.l;

            MaterialColors {
                p50: HSL { h: base_hsl.h, s: base_hsl.s * 0.4, l: 0.95 },
                p100: HSL { h: base_hsl.h, s: base_hsl.s * 0.6, l: 0.90 },
                p200: HSL { h: base_hsl.h, s: base_hsl.s * 0.7, l: 0.80 },
                p300: HSL { h: base_hsl.h, s: base_hsl.s * 0.8, l: 0.70 },
                p400: HSL { h: base_hsl.h, s: base_hsl.s * 0.9, l: 0.60 },
                p500: base_hsl,
                p600: HSL { h: base_hsl.h, s: base_hsl.s, l: base_l * 0.87 },
                p700: HSL { h: base_hsl.h, s: base_hsl.s, l: base_l * 0.74 },
                p800: HSL { h: base_hsl.h, s: base_hsl.s, l: base_l * 0.61 },
                p900: HSL { h: base_hsl.h, s: base_hsl.s, l: base_l * 0.48 },
                a100: HSL { h: base_hsl.h, s: 1.0, l: 0.82 },
                a200: HSL { h: base_hsl.h, s: 1.0, l: 0.65 },
                a400: HSL { h: base_hsl.h, s: 1.0, l: 0.50 },
                a700: HSL { h: base_hsl.h, s: 1.0, l: 0.40 },
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct MaterialColors {
        pub p50: HSL,
        pub p100: HSL,
        pub p200: HSL,
        pub p300: HSL,
        pub p400: HSL,
        pub p500: HSL,
        pub p600: HSL,
        pub p700: HSL,
        pub p800: HSL,
        pub p900: HSL,
        pub a100: HSL,
        pub a200: HSL,
        pub a400: HSL,
        pub a700: HSL,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRINT COLOR MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod print_color {
    use super::*;

    /// CMYK color model for print
    #[derive(Debug, Clone, Copy)]
    pub struct CMYK {
        pub c: f64,
        pub m: f64,
        pub y: f64,
        pub k: f64,
    }

    impl CMYK {
        pub fn new(c: f64, m: f64, y: f64, k: f64) -> Self {
            Self {
                c: c.clamp(0.0, 1.0),
                m: m.clamp(0.0, 1.0),
                y: y.clamp(0.0, 1.0),
                k: k.clamp(0.0, 1.0),
            }
        }

        pub fn from_rgb(r: f64, g: f64, b: f64) -> Self {
            let k = 1.0 - r.max(g).max(b);
            if k >= 1.0 {
                return Self::new(0.0, 0.0, 0.0, 1.0);
            }
            Self::new(
                (1.0 - r - k) / (1.0 - k),
                (1.0 - g - k) / (1.0 - k),
                (1.0 - b - k) / (1.0 - k),
                k,
            )
        }

        pub fn to_rgb(&self) -> (f64, f64, f64) {
            let r = (1.0 - self.c) * (1.0 - self.k);
            let g = (1.0 - self.m) * (1.0 - self.k);
            let b = (1.0 - self.y) * (1.0 - self.k);
            (r, g, b)
        }

        pub fn total_ink_coverage(&self) -> f64 {
            self.c + self.m + self.y + self.k
        }

        pub fn limit_ink(&self, max_tac: f64) -> Self {
            let tac = self.total_ink_coverage();
            if tac <= max_tac {
                return *self;
            }

            let scale = max_tac / tac;
            Self::new(
                self.c * scale,
                self.m * scale,
                self.y * scale,
                self.k * scale,
            )
        }
    }

    /// Spot color definition
    #[derive(Debug, Clone)]
    pub struct SpotColor {
        pub name: String,
        pub lab: Lab,
        pub cmyk_fallback: CMYK,
        pub rgb_preview: (f64, f64, f64),
    }

    impl SpotColor {
        pub fn new(name: &str, lab: Lab) -> Self {
            let xyz = lab.to_xyz();
            let (r, g, b) = Self::xyz_to_rgb(xyz);
            let cmyk = CMYK::from_rgb(r, g, b);

            Self {
                name: name.to_string(),
                lab,
                cmyk_fallback: cmyk,
                rgb_preview: (r, g, b),
            }
        }

        fn xyz_to_rgb(xyz: XYZ) -> (f64, f64, f64) {
            let r = 3.2404542 * xyz.x - 1.5371385 * xyz.y - 0.4985314 * xyz.z;
            let g = -0.9692660 * xyz.x + 1.8760108 * xyz.y + 0.0415560 * xyz.z;
            let b = 0.0556434 * xyz.x - 0.2040259 * xyz.y + 1.0572252 * xyz.z;

            let gamma = |c: f64| {
                let c = c.clamp(0.0, 1.0);
                if c <= 0.0031308 { c * 12.92 } else { 1.055 * c.powf(1.0 / 2.4) - 0.055 }
            };

            (gamma(r), gamma(g), gamma(b))
        }
    }

    /// Pantone-like spot color library
    pub struct SpotColorLibrary {
        colors: Vec<SpotColor>,
    }

    impl SpotColorLibrary {
        pub fn new() -> Self {
            Self { colors: Vec::new() }
        }

        pub fn add(&mut self, color: SpotColor) {
            self.colors.push(color);
        }

        pub fn find_by_name(&self, name: &str) -> Option<&SpotColor> {
            self.colors.iter().find(|c| c.name == name)
        }

        pub fn find_closest(&self, lab: &Lab) -> Option<(&SpotColor, f64)> {
            self.colors
                .iter()
                .map(|c| {
                    let de = Self::delta_e_2000(&c.lab, lab);
                    (c, de)
                })
                .min_by(|a, b| a.1.partial_cmp(&b.1).unwrap())
        }

        fn delta_e_2000(lab1: &Lab, lab2: &Lab) -> f64 {
            let l_bar = (lab1.L + lab2.L) / 2.0;
            let c1 = (lab1.a * lab1.a + lab1.b * lab1.b).sqrt();
            let c2 = (lab2.a * lab2.a + lab2.b * lab2.b).sqrt();
            let c_bar = (c1 + c2) / 2.0;

            let g = 0.5 * (1.0 - (c_bar.powi(7) / (c_bar.powi(7) + 25.0f64.powi(7))).sqrt());
            let a1_prime = lab1.a * (1.0 + g);
            let a2_prime = lab2.a * (1.0 + g);

            let c1_prime = (a1_prime * a1_prime + lab1.b * lab1.b).sqrt();
            let c2_prime = (a2_prime * a2_prime + lab2.b * lab2.b).sqrt();
            let c_bar_prime = (c1_prime + c2_prime) / 2.0;

            let h1_prime = lab1.b.atan2(a1_prime).to_degrees();
            let h1_prime = if h1_prime < 0.0 { h1_prime + 360.0 } else { h1_prime };
            let h2_prime = lab2.b.atan2(a2_prime).to_degrees();
            let h2_prime = if h2_prime < 0.0 { h2_prime + 360.0 } else { h2_prime };

            let h_bar_prime = if (h1_prime - h2_prime).abs() > 180.0 {
                (h1_prime + h2_prime + 360.0) / 2.0
            } else {
                (h1_prime + h2_prime) / 2.0
            };

            let t = 1.0 - 0.17 * (h_bar_prime - 30.0).to_radians().cos()
                + 0.24 * (2.0 * h_bar_prime).to_radians().cos()
                + 0.32 * (3.0 * h_bar_prime + 6.0).to_radians().cos()
                - 0.20 * (4.0 * h_bar_prime - 63.0).to_radians().cos();

            let delta_h_prime = if (h2_prime - h1_prime).abs() <= 180.0 {
                h2_prime - h1_prime
            } else if h2_prime <= h1_prime {
                h2_prime - h1_prime + 360.0
            } else {
                h2_prime - h1_prime - 360.0
            };

            let delta_l_prime = lab2.L - lab1.L;
            let delta_c_prime = c2_prime - c1_prime;
            let delta_h_prime_rad = 2.0 * (c1_prime * c2_prime).sqrt() * (delta_h_prime / 2.0).to_radians().sin();

            let s_l = 1.0 + (0.015 * (l_bar - 50.0).powi(2)) / (20.0 + (l_bar - 50.0).powi(2)).sqrt();
            let s_c = 1.0 + 0.045 * c_bar_prime;
            let s_h = 1.0 + 0.015 * c_bar_prime * t;

            let delta_theta = 30.0 * (-((h_bar_prime - 275.0) / 25.0).powi(2)).exp();
            let r_c = 2.0 * (c_bar_prime.powi(7) / (c_bar_prime.powi(7) + 25.0f64.powi(7))).sqrt();
            let r_t = -r_c * (2.0 * delta_theta).to_radians().sin();

            let kl = 1.0;
            let kc = 1.0;
            let kh = 1.0;

            ((delta_l_prime / (kl * s_l)).powi(2)
                + (delta_c_prime / (kc * s_c)).powi(2)
                + (delta_h_prime_rad / (kh * s_h)).powi(2)
                + r_t * (delta_c_prime / (kc * s_c)) * (delta_h_prime_rad / (kh * s_h)))
                .sqrt()
        }

        pub fn standard_library() -> Self {
            let mut lib = Self::new();
            lib.add(SpotColor::new("Process Black", Lab { L: 0.0, a: 0.0, b: 0.0 }));
            lib.add(SpotColor::new("Reflex Blue", Lab { L: 20.0, a: 35.0, b: -80.0 }));
            lib.add(SpotColor::new("Rhodamine Red", Lab { L: 50.0, a: 75.0, b: -5.0 }));
            lib.add(SpotColor::new("Yellow 012", Lab { L: 90.0, a: -5.0, b: 90.0 }));
            lib.add(SpotColor::new("Orange 021", Lab { L: 65.0, a: 55.0, b: 70.0 }));
            lib.add(SpotColor::new("Green", Lab { L: 55.0, a: -60.0, b: 35.0 }));
            lib.add(SpotColor::new("Process Cyan", Lab { L: 55.0, a: -40.0, b: -50.0 }));
            lib.add(SpotColor::new("Purple", Lab { L: 30.0, a: 55.0, b: -50.0 }));
            lib.add(SpotColor::new("Warm Red", Lab { L: 55.0, a: 65.0, b: 50.0 }));
            lib.add(SpotColor::new("Rubine Red", Lab { L: 45.0, a: 70.0, b: 15.0 }));
            lib
        }
    }

    /// UCR/GCR color separation
    pub struct ColorSeparation {
        gcr_percent: f64,
        ucr_percent: f64,
        max_black: f64,
        black_start: f64,
    }

    impl ColorSeparation {
        pub fn new() -> Self {
            Self {
                gcr_percent: 0.5,
                ucr_percent: 1.0,
                max_black: 1.0,
                black_start: 0.0,
            }
        }

        pub fn with_gcr(mut self, percent: f64) -> Self {
            self.gcr_percent = percent.clamp(0.0, 1.0);
            self
        }

        pub fn with_ucr(mut self, percent: f64) -> Self {
            self.ucr_percent = percent.clamp(0.0, 1.0);
            self
        }

        pub fn with_max_black(mut self, max: f64) -> Self {
            self.max_black = max.clamp(0.0, 1.0);
            self
        }

        pub fn with_black_start(mut self, start: f64) -> Self {
            self.black_start = start.clamp(0.0, 1.0);
            self
        }

        pub fn separate(&self, r: f64, g: f64, b: f64) -> CMYK {
            let c = 1.0 - r;
            let m = 1.0 - g;
            let y = 1.0 - b;

            let k_max = c.min(m).min(y);
            let k = if k_max > self.black_start {
                ((k_max - self.black_start) / (1.0 - self.black_start)) * self.gcr_percent * self.max_black
            } else {
                0.0
            };

            let ucr = k * self.ucr_percent;

            CMYK::new(
                (c - ucr).max(0.0),
                (m - ucr).max(0.0),
                (y - ucr).max(0.0),
                k,
            )
        }
    }

    /// Overprint simulation
    pub struct OverprintSimulator;

    impl OverprintSimulator {
        pub fn multiply_cmyk(bottom: CMYK, top: CMYK) -> CMYK {
            CMYK::new(
                bottom.c + top.c - bottom.c * top.c,
                bottom.m + top.m - bottom.m * top.m,
                bottom.y + top.y - bottom.y * top.y,
                bottom.k + top.k - bottom.k * top.k,
            )
        }

        pub fn simulate_overprint(colors: &[CMYK]) -> CMYK {
            colors
                .iter()
                .cloned()
                .reduce(Self::multiply_cmyk)
                .unwrap_or(CMYK::new(0.0, 0.0, 0.0, 0.0))
        }
    }

    /// Ink trapping calculation
    pub struct TrapCalculator {
        trap_width: f64,
    }

    impl TrapCalculator {
        pub fn new(trap_width: f64) -> Self {
            Self { trap_width }
        }

        pub fn calculate_trap_direction(&self, color1: CMYK, color2: CMYK) -> TrapDirection {
            let density1 = self.apparent_density(color1);
            let density2 = self.apparent_density(color2);

            if (density1 - density2).abs() < 0.1 {
                TrapDirection::Centerline
            } else if density1 > density2 {
                TrapDirection::Into(1)
            } else {
                TrapDirection::Into(2)
            }
        }

        fn apparent_density(&self, cmyk: CMYK) -> f64 {
            0.3 * cmyk.c + 0.59 * cmyk.m + 0.11 * cmyk.y + cmyk.k
        }

        pub fn trap_width(&self) -> f64 {
            self.trap_width
        }
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum TrapDirection {
        Into(u8),
        Centerline,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// METAMERISM AND COLOR CONSTANCY
// ═══════════════════════════════════════════════════════════════════════════════

pub mod metamerism {
    use super::*;

    /// Metamerism index calculation
    pub struct MetamerismAnalyzer;

    impl MetamerismAnalyzer {
        pub fn special_metamerism_index(
            sample1: &SpectralData,
            sample2: &SpectralData,
            illuminant_test: &SpectralData,
            illuminant_ref: &SpectralData,
        ) -> f64 {
            let xyz1_ref = sample1.to_xyz(illuminant_ref);
            let xyz2_ref = sample2.to_xyz(illuminant_ref);
            let xyz1_test = sample1.to_xyz(illuminant_test);
            let xyz2_test = sample2.to_xyz(illuminant_test);

            let lab1_ref = Lab::from_xyz(xyz1_ref);
            let lab2_ref = Lab::from_xyz(xyz2_ref);
            let lab1_test = Lab::from_xyz(xyz1_test);
            let lab2_test = Lab::from_xyz(xyz2_test);

            let de_ref = Self::delta_e(&lab1_ref, &lab2_ref);
            let de_test = Self::delta_e(&lab1_test, &lab2_test);

            (de_test - de_ref).abs()
        }

        fn delta_e(lab1: &Lab, lab2: &Lab) -> f64 {
            let dl = lab1.L - lab2.L;
            let da = lab1.a - lab2.a;
            let db = lab1.b - lab2.b;
            (dl * dl + da * da + db * db).sqrt()
        }

        pub fn is_metameric_pair(
            sample1: &SpectralData,
            sample2: &SpectralData,
            illuminant: &SpectralData,
            threshold: f64,
        ) -> bool {
            let xyz1 = sample1.to_xyz(illuminant);
            let xyz2 = sample2.to_xyz(illuminant);

            let lab1 = Lab::from_xyz(xyz1);
            let lab2 = Lab::from_xyz(xyz2);

            Self::delta_e(&lab1, &lab2) < threshold
        }
    }

    /// Color constancy algorithms
    pub struct ColorConstancy;

    impl ColorConstancy {
        pub fn gray_world(image_rgb: &[(f64, f64, f64)]) -> (f64, f64, f64) {
            let n = image_rgb.len() as f64;
            let (sum_r, sum_g, sum_b) = image_rgb
                .iter()
                .fold((0.0, 0.0, 0.0), |(r, g, b), (pr, pg, pb)| {
                    (r + pr, g + pg, b + pb)
                });

            let avg_r = sum_r / n;
            let avg_g = sum_g / n;
            let avg_b = sum_b / n;
            let avg_gray = (avg_r + avg_g + avg_b) / 3.0;

            (avg_gray / avg_r, avg_gray / avg_g, avg_gray / avg_b)
        }

        pub fn white_patch(image_rgb: &[(f64, f64, f64)]) -> (f64, f64, f64) {
            let (max_r, max_g, max_b) = image_rgb
                .iter()
                .fold((0.0f64, 0.0f64, 0.0f64), |(mr, mg, mb), (r, g, b)| {
                    (mr.max(*r), mg.max(*g), mb.max(*b))
                });

            (1.0 / max_r, 1.0 / max_g, 1.0 / max_b)
        }

        pub fn shades_of_gray(image_rgb: &[(f64, f64, f64)], p: f64) -> (f64, f64, f64) {
            let n = image_rgb.len() as f64;

            let (sum_r, sum_g, sum_b) = image_rgb
                .iter()
                .fold((0.0, 0.0, 0.0), |(sr, sg, sb), (r, g, b)| {
                    (sr + r.powf(p), sg + g.powf(p), sb + b.powf(p))
                });

            let norm_r = (sum_r / n).powf(1.0 / p);
            let norm_g = (sum_g / n).powf(1.0 / p);
            let norm_b = (sum_b / n).powf(1.0 / p);

            let gray_est = (norm_r + norm_g + norm_b) / 3.0;

            (gray_est / norm_r, gray_est / norm_g, gray_est / norm_b)
        }

        pub fn apply_correction(
            image_rgb: &[(f64, f64, f64)],
            gains: (f64, f64, f64),
        ) -> Vec<(f64, f64, f64)> {
            image_rgb
                .iter()
                .map(|(r, g, b)| {
                    (
                        (r * gains.0).clamp(0.0, 1.0),
                        (g * gains.1).clamp(0.0, 1.0),
                        (b * gains.2).clamp(0.0, 1.0),
                    )
                })
                .collect()
        }
    }

    /// Chromatic adaptation transforms
    pub struct ChromaticAdaptation;

    impl ChromaticAdaptation {
        const BRADFORD: [[f64; 3]; 3] = [
            [0.8951, 0.2664, -0.1614],
            [-0.7502, 1.7135, 0.0367],
            [0.0389, -0.0685, 1.0296],
        ];

        const BRADFORD_INV: [[f64; 3]; 3] = [
            [0.9869929, -0.1470543, 0.1599627],
            [0.4323053, 0.5183603, 0.0492912],
            [-0.0085287, 0.0400428, 0.9684867],
        ];

        pub fn bradford_transform(xyz: XYZ, src_white: XYZ, dst_white: XYZ) -> XYZ {
            let src_lms = Self::xyz_to_lms(src_white);
            let dst_lms = Self::xyz_to_lms(dst_white);
            let sample_lms = Self::xyz_to_lms(xyz);

            let adapted_lms = [
                sample_lms[0] * dst_lms[0] / src_lms[0],
                sample_lms[1] * dst_lms[1] / src_lms[1],
                sample_lms[2] * dst_lms[2] / src_lms[2],
            ];

            Self::lms_to_xyz(adapted_lms)
        }

        fn xyz_to_lms(xyz: XYZ) -> [f64; 3] {
            [
                Self::BRADFORD[0][0] * xyz.x + Self::BRADFORD[0][1] * xyz.y + Self::BRADFORD[0][2] * xyz.z,
                Self::BRADFORD[1][0] * xyz.x + Self::BRADFORD[1][1] * xyz.y + Self::BRADFORD[1][2] * xyz.z,
                Self::BRADFORD[2][0] * xyz.x + Self::BRADFORD[2][1] * xyz.y + Self::BRADFORD[2][2] * xyz.z,
            ]
        }

        fn lms_to_xyz(lms: [f64; 3]) -> XYZ {
            XYZ {
                x: Self::BRADFORD_INV[0][0] * lms[0] + Self::BRADFORD_INV[0][1] * lms[1] + Self::BRADFORD_INV[0][2] * lms[2],
                y: Self::BRADFORD_INV[1][0] * lms[0] + Self::BRADFORD_INV[1][1] * lms[1] + Self::BRADFORD_INV[1][2] * lms[2],
                z: Self::BRADFORD_INV[2][0] * lms[0] + Self::BRADFORD_INV[2][1] * lms[1] + Self::BRADFORD_INV[2][2] * lms[2],
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_roundtrip() {
        let original = LinearRGB { r: 0.5, g: 0.3, b: 0.8 };
        let genesis = GenesisSymmetric::from_linear_rgb(original);
        let recovered = genesis.to_linear_rgb();

        assert!((original.r - recovered.r).abs() < 0.01);
        assert!((original.g - recovered.g).abs() < 0.01);
        assert!((original.b - recovered.b).abs() < 0.01);
    }

    #[test]
    fn test_lightness_symmetry() {
        // Mid-gray should be at L=50
        let mid_gray = LinearRGB { r: 0.18, g: 0.18, b: 0.18 };
        let genesis = GenesisSymmetric::from_linear_rgb(mid_gray);
        assert!((genesis.L - 50.0).abs() < 5.0);
    }

    #[test]
    fn test_delta_e() {
        let white = GenesisSymmetric::white();
        let black = GenesisSymmetric::black();
        let delta = white.delta_e(&black);
        assert!(delta > 95.0 && delta < 105.0);
    }

    #[test]
    fn test_gamut_mapping() {
        // Out of gamut color
        let out_of_gamut = GenesisSymmetric::new(50.0, 200.0, 0.0);
        let mapped = out_of_gamut.gamut_map_srgb();
        assert!(mapped.in_srgb_gamut());
    }

    #[test]
    fn test_contrast_ratio() {
        let white = GenesisSymmetric::white();
        let black = GenesisSymmetric::black();
        let ratio = contrast_ratio(white, black);
        assert!(ratio > 20.0);
    }

    #[test]
    fn test_oklab_roundtrip() {
        let original = LinearRGB { r: 0.4, g: 0.6, b: 0.2 };
        let oklab = Oklab::from_linear_rgb(original);
        let recovered = oklab.to_linear_rgb();

        assert!((original.r - recovered.r).abs() < 0.001);
        assert!((original.g - recovered.g).abs() < 0.001);
        assert!((original.b - recovered.b).abs() < 0.001);
    }

    #[test]
    fn test_oklab_gamut_mapping() {
        let out_of_gamut = Oklab::from_oklch(Oklch { L: 0.7, C: 0.5, h: 120.0 });
        let mapped = out_of_gamut.gamut_map_srgb();
        assert!(mapped.in_srgb_gamut());
    }

    #[test]
    fn test_color_harmony() {
        let base = Oklch::new(0.6, 0.15, 180.0);
        let triadic = ColorHarmony::generate(base, HarmonyScheme::Triadic);
        assert_eq!(triadic.len(), 3);
        assert!((triadic[1].h - 300.0).abs() < 0.1);
    }

    #[test]
    fn test_ciede2000() {
        let lab1 = Lab { L: 50.0, a: 2.6772, b: -79.7751 };
        let lab2 = Lab { L: 50.0, a: 0.0, b: -82.7485 };
        let de = delta_e::ciede2000(&lab1, &lab2);
        // Reference value from CIE
        assert!((de - 2.0425).abs() < 0.01);
    }

    #[test]
    fn test_pq_roundtrip() {
        let luminance = 100.0;  // 100 nits
        let encoded = pq_oetf(luminance);
        let decoded = pq_eotf(encoded);
        assert!((luminance - decoded).abs() < 0.01);
    }

    #[test]
    fn test_hlg_roundtrip() {
        let signal = 0.5;
        let encoded = hlg_oetf(signal);
        let decoded = hlg_eotf(encoded);
        assert!((signal - decoded).abs() < 0.001);
    }

    #[test]
    fn test_spectral_to_xyz() {
        let d65 = SpectralData::d65();
        let xyz = d65.to_xyz(&d65);
        // D65 illuminant should give approximately D65 white point
        assert!((xyz.y - 1.0).abs() < 0.1);
    }
}
