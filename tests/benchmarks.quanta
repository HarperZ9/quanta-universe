pub fn bench_matrix_multiply_small() -> BenchmarkResult {
    let a = Matrix::random(10, 10);
    let b = Matrix::random(10, 10);

    benchmark("Matrix multiply 10x10", 100, 10000, || {
        let _ = a.mul(&b);
    })
}

pub fn bench_matrix_multiply_medium() -> BenchmarkResult {
    let a = Matrix::random(100, 100);
    let b = Matrix::random(100, 100);

    benchmark("Matrix multiply 100x100", 10, 100, || {
        let _ = a.mul(&b);
    })
}

pub fn bench_matrix_multiply_large() -> BenchmarkResult {
    let a = Matrix::random(500, 500);
    let b = Matrix::random(500, 500);

    benchmark("Matrix multiply 500x500", 3, 10, || {
        let _ = a.mul(&b);
    })
}

pub fn bench_matrix_inverse_small() -> BenchmarkResult {
    let m = Matrix::random(10, 10);

    benchmark("Matrix inverse 10x10", 100, 1000, || {
        let _ = m.inverse();
    })
}

pub fn bench_matrix_inverse_medium() -> BenchmarkResult {
    let m = Matrix::random(50, 50);

    benchmark("Matrix inverse 50x50", 10, 100, || {
        let _ = m.inverse();
    })
}

pub fn bench_matrix_cholesky() -> BenchmarkResult {
    // Create positive definite matrix
    let r = Matrix::random(50, 50);
    let m = r.transpose().mul(&r);

    benchmark("Cholesky decomposition 50x50", 10, 100, || {
        let _ = m.cholesky();
    })
}

pub fn bench_matrix_svd() -> BenchmarkResult {
    let m = Matrix::random(50, 50);

    benchmark("SVD 50x50", 5, 20, || {
        let _ = m.svd();
    })
}

// ═══════════════════════════════════════════════════════════════════════════════
// PORTFOLIO OPTIMIZATION BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn bench_portfolio_mean_variance() -> BenchmarkResult {
    let n = 50;
    let returns: Vec<f64> = (0..n).map(|i| 0.05 + 0.01 * (i as f64) / n as f64).collect();
    let cov = Matrix::random_positive_definite(n);
    let optimizer = PortfolioOptimizer::new(returns, cov);

    benchmark("Mean-variance optimization (50 assets)", 10, 100, || {
        let _ = optimizer.mean_variance(3.0);
    })
}

pub fn bench_portfolio_risk_parity() -> BenchmarkResult {
    let n = 50;
    let returns: Vec<f64> = (0..n).map(|i| 0.05 + 0.01 * (i as f64) / n as f64).collect();
    let cov = Matrix::random_positive_definite(n);
    let optimizer = PortfolioOptimizer::new(returns, cov);

    benchmark("Risk parity optimization (50 assets)", 5, 50, || {
        let _ = optimizer.risk_parity(100);
    })
}

pub fn bench_portfolio_max_sharpe() -> BenchmarkResult {
    let n = 30;
    let returns: Vec<f64> = (0..n).map(|i| 0.05 + 0.01 * (i as f64) / n as f64).collect();
    let cov = Matrix::random_positive_definite(n);
    let optimizer = PortfolioOptimizer::new(returns, cov);

    benchmark("Maximum Sharpe optimization (30 assets)", 5, 50, || {
        let _ = optimizer.maximum_sharpe(0.02);
    })
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL NETWORK BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn bench_nn_forward_small() -> BenchmarkResult {
    let nn = NeuralNetwork::new()
        .add(Dense::new(10, 32))
        .add(Activation::ReLU)
        .add(Dense::new(32, 10))
        .build();

    let input: Vec<f64> = (0..10).map(|i| i as f64 * 0.1).collect();

    benchmark("NN forward small (10->32->10)", 100, 10000, || {
        let _ = nn.forward(&input);
    })
}

pub fn bench_nn_forward_medium() -> BenchmarkResult {
    let nn = NeuralNetwork::new()
        .add(Dense::new(100, 256))
        .add(Activation::ReLU)
        .add(Dense::new(256, 128))
        .add(Activation::ReLU)
        .add(Dense::new(128, 64))
        .add(Activation::ReLU)
        .add(Dense::new(64, 10))
        .build();

    let input: Vec<f64> = (0..100).map(|i| i as f64 * 0.01).collect();

    benchmark("NN forward medium (100->256->128->64->10)", 50, 1000, || {
        let _ = nn.forward(&input);
    })
}

pub fn bench_nn_forward_large() -> BenchmarkResult {
    let nn = NeuralNetwork::new()
        .add(Dense::new(1000, 512))
        .add(Activation::ReLU)
        .add(Dense::new(512, 256))
        .add(Activation::ReLU)
        .add(Dense::new(256, 128))
        .add(Activation::ReLU)
        .add(Dense::new(128, 64))
        .add(Activation::ReLU)
        .add(Dense::new(64, 10))
        .build();

    let input: Vec<f64> = (0..1000).map(|i| i as f64 * 0.001).collect();

    benchmark("NN forward large (1000->512->256->128->64->10)", 10, 100, || {
        let _ = nn.forward(&input);
    })
}

pub fn bench_lstm_forward() -> BenchmarkResult {
    let lstm = LSTM::new(10, 64, 2);
    let sequence: Vec<Vec<f64>> = (0..20)
        .map(|t| (0..10).map(|f| (t * f) as f64 * 0.01).collect())
        .collect();

    benchmark("LSTM forward (seq=20, in=10, hidden=64)", 10, 100, || {
        let _ = lstm.forward(&sequence);
    })
}

