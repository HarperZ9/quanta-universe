pub fn bench_aes_encrypt_1kb() -> BenchmarkResult {
    let data = vec![0u8; 1024];
    let key = crypto::generate_key(crypto::Algorithm::AES256);

    benchmark("AES-256 encrypt 1KB", 100, 10000, || {
        let _ = crypto::encrypt(&data, &key, crypto::Algorithm::AES256).unwrap();
    })
}

pub fn bench_aes_encrypt_1mb() -> BenchmarkResult {
    let data = vec![0u8; 1_000_000];
    let key = crypto::generate_key(crypto::Algorithm::AES256);

    benchmark("AES-256 encrypt 1MB", 10, 100, || {
        let _ = crypto::encrypt(&data, &key, crypto::Algorithm::AES256).unwrap();
    })
}

pub fn bench_sha256_1kb() -> BenchmarkResult {
    let data = vec![0u8; 1024];

    benchmark("SHA-256 hash 1KB", 100, 10000, || {
        let _ = crypto::hash(&data, crypto::HashAlgorithm::SHA256);
    })
}

pub fn bench_sha256_1mb() -> BenchmarkResult {
    let data = vec![0u8; 1_000_000];

    benchmark("SHA-256 hash 1MB", 10, 100, || {
        let _ = crypto::hash(&data, crypto::HashAlgorithm::SHA256);
    })
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLLECTION BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn bench_hashmap_insert() -> BenchmarkResult {
    benchmark("HashMap insert 10k entries", 5, 100, || {
        let mut map = HashMap::with_capacity(10000);
        for i in 0..10000 {
            map.insert(format!("key_{}", i), i);
        }
    })
}

pub fn bench_hashmap_lookup() -> BenchmarkResult {
    let mut map = HashMap::new();
    for i in 0..10000 {
        map.insert(format!("key_{}", i), i);
    }

    benchmark("HashMap lookup 10k entries", 10, 1000, || {
        for i in 0..10000 {
            let _ = map.get(&format!("key_{}", i));
        }
    })
}

pub fn bench_vec_sort() -> BenchmarkResult {
    let original: Vec<i64> = (0..100_000).rev().collect();

    benchmark("Vec sort 100k elements", 5, 50, || {
        let mut v = original.clone();
        v.sort_unstable();
    })
}

pub fn bench_vec_binary_search() -> BenchmarkResult {
    let v: Vec<i64> = (0..100_000).collect();

    benchmark("Vec binary search 100k", 10, 1000, || {
        for i in (0..100_000).step_by(100) {
            let _ = v.binary_search(&i);
        }
    })
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPER TYPES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Serialize, Deserialize)]
struct TestMessage {
    id: i32,
    name: String,
    values: Vec<i32>,
    nested: Option<NestedMessage>,
}

#[derive(Serialize, Deserialize)]
struct NestedMessage {
    value: i32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK RUNNER
// ═══════════════════════════════════════════════════════════════════════════════

/// Run all benchmarks
pub fn run_all_benchmarks() -> Vec<BenchmarkResult> {
    let mut results = Vec::new();

    println!("\n{}", "═".repeat(70));
    println!("QUANTA-UNIVERSE Benchmark Suite");
    println!("{}", "═".repeat(70));

    // Serialization
    println!("\n[Serialization]");
    for bench in [
        bench_json_small,
        bench_json_medium,
        bench_json_large,
        bench_msgpack_small,
        bench_msgpack_large,
        bench_protobuf_encode,
        bench_protobuf_decode,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    // Tensor operations
    println!("\n[Tensor Operations]");
    for bench in [
        bench_tensor_create,
        bench_tensor_fill,
        bench_tensor_covariance,
        bench_tensor_ewm_covariance,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    // Matrix operations
    println!("\n[Matrix Operations]");
    for bench in [
        bench_matrix_multiply_small,
        bench_matrix_multiply_medium,
        bench_matrix_multiply_large,
        bench_matrix_inverse_small,
        bench_matrix_inverse_medium,
        bench_matrix_cholesky,
        bench_matrix_svd,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    // Portfolio optimization
    println!("\n[Portfolio Optimization]");
    for bench in [
        bench_portfolio_mean_variance,
        bench_portfolio_risk_parity,
        bench_portfolio_max_sharpe,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    // Neural networks
    println!("\n[Neural Networks]");
    for bench in [
        bench_nn_forward_small,
        bench_nn_forward_medium,
        bench_nn_forward_large,
        bench_lstm_forward,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    // Cryptography
    println!("\n[Cryptography]");
    for bench in [
        bench_aes_encrypt_1kb,
        bench_aes_encrypt_1mb,
        bench_sha256_1kb,
        bench_sha256_1mb,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    // Collections
    println!("\n[Collections]");
    for bench in [
        bench_hashmap_insert,
        bench_hashmap_lookup,
        bench_vec_sort,
        bench_vec_binary_search,
    ] {
        let result = bench();
        result.print();
        results.push(result);
    }

    println!("\n{}", "═".repeat(70));
    println!("Completed {} benchmarks", results.len());
    println!("{}", "═".repeat(70));

    results
}

/// Main entry point
pub fn main() -> i32 {
    let _ = run_all_benchmarks();
    0
}
