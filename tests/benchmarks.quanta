module benchmarks

use std::time::{Duration, Instant}
use std::collections::HashMap

use foundation::*
use field_tensor::{MarketTensor4D, Matrix, PortfolioOptimizer}
use axiom::{NeuralNetwork, Dense, Activation, LSTM}
use oracle::{TimeSeriesPredictor, ProphetModel}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK INFRASTRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// Benchmark result
pub struct BenchmarkResult {
    pub name: String,
    pub iterations: usize,
    pub total_time: Duration,
    pub mean_time: Duration,
    pub min_time: Duration,
    pub max_time: Duration,
    pub std_dev: Duration,
    pub throughput: Option<f64>,
}

impl BenchmarkResult {
    pub fn print(&self) {
        println!("  {}: {:.2?} ± {:.2?} (min: {:.2?}, max: {:.2?})",
            self.name, self.mean_time, self.std_dev, self.min_time, self.max_time);
        if let Some(tp) = self.throughput {
            println!("    Throughput: {:.2} ops/sec", tp);
        }
    }
}

/// Run a benchmark with warmup and multiple iterations
pub fn benchmark<F: FnMut()>(name: &str, warmup: usize, iterations: usize, mut f: F) -> BenchmarkResult {
    // Warmup
    for _ in 0..warmup {
        f();
    }

    // Actual benchmark
    let mut times = Vec::with_capacity(iterations);
    let total_start = Instant::now();

    for _ in 0..iterations {
        let start = Instant::now();
        f();
        times.push(start.elapsed());
    }

    let total_time = total_start.elapsed();

    // Compute statistics
    let total_nanos: u128 = times.iter().map(|d| d.as_nanos()).sum();
    let mean_nanos = total_nanos / iterations as u128;
    let mean_time = Duration::from_nanos(mean_nanos as u64);

    let min_time = times.iter().min().copied().unwrap_or(Duration::ZERO);
    let max_time = times.iter().max().copied().unwrap_or(Duration::ZERO);

    let variance: f64 = times.iter()
        .map(|d| {
            let diff = d.as_nanos() as f64 - mean_nanos as f64;
            diff * diff
        })
        .sum::<f64>() / iterations as f64;
    let std_dev = Duration::from_nanos(variance.sqrt() as u64);

    let throughput = Some(iterations as f64 / total_time.as_secs_f64());

    BenchmarkResult {
        name: name.to_string(),
        iterations,
        total_time,
        mean_time,
        min_time,
        max_time,
        std_dev,
        throughput,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SERIALIZATION BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn bench_json_small() -> BenchmarkResult {
    let data = HashMap::from([
        ("name", "test"),
        ("value", "12345"),
        ("active", "true"),
    ]);

    benchmark("JSON small object", 100, 10000, || {
        let json = serialization::json::to_string(&data).unwrap();
        let _: HashMap<&str, &str> = serialization::json::from_str(&json).unwrap();
    })
}

pub fn bench_json_medium() -> BenchmarkResult {
    let data: Vec<HashMap<String, i32>> = (0..100)
        .map(|i| {
            let mut map = HashMap::new();
            for j in 0..10 {
                map.insert(format!("key_{}", j), i * 10 + j);
            }
            map
        })
        .collect();

    benchmark("JSON medium array", 10, 1000, || {
        let json = serialization::json::to_string(&data).unwrap();
        let _: Vec<HashMap<String, i32>> = serialization::json::from_str(&json).unwrap();
    })
}

pub fn bench_json_large() -> BenchmarkResult {
    let data: Vec<i64> = (0..100_000).collect();

    benchmark("JSON large array (100k)", 5, 100, || {
        let json = serialization::json::to_string(&data).unwrap();
        let _: Vec<i64> = serialization::json::from_str(&json).unwrap();
    })
}

pub fn bench_msgpack_small() -> BenchmarkResult {
    let data = (42i32, "hello", true, 3.14f64);

    benchmark("MessagePack small tuple", 100, 10000, || {
        let bytes = serialization::msgpack::to_vec(&data).unwrap();
        let _: (i32, String, bool, f64) = serialization::msgpack::from_slice(&bytes).unwrap();
    })
}

pub fn bench_msgpack_large() -> BenchmarkResult {
    let data: Vec<i64> = (0..100_000).collect();

    benchmark("MessagePack large array (100k)", 5, 100, || {
        let bytes = serialization::msgpack::to_vec(&data).unwrap();
        let _: Vec<i64> = serialization::msgpack::from_slice(&bytes).unwrap();
    })
}

pub fn bench_protobuf_encode() -> BenchmarkResult {
    let msg = TestMessage {
        id: 12345,
        name: "Benchmark Test Message".to_string(),
        values: (0..100).collect(),
        nested: Some(NestedMessage { value: 42 }),
    };

    benchmark("Protobuf encode", 100, 10000, || {
        let _ = serialization::protobuf::encode(&msg).unwrap();
    })
}

pub fn bench_protobuf_decode() -> BenchmarkResult {
    let msg = TestMessage {
        id: 12345,
        name: "Benchmark Test Message".to_string(),
        values: (0..100).collect(),
        nested: Some(NestedMessage { value: 42 }),
    };
    let bytes = serialization::protobuf::encode(&msg).unwrap();

    benchmark("Protobuf decode", 100, 10000, || {
        let _: TestMessage = serialization::protobuf::decode(&bytes).unwrap();
    })
}

// ═══════════════════════════════════════════════════════════════════════════════
// TENSOR BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn bench_tensor_create() -> BenchmarkResult {
    benchmark("Tensor create (252x100x16x4)", 5, 100, || {
        let _ = MarketTensor4D::new(252, 100, 16, 4);
    })
}

pub fn bench_tensor_fill() -> BenchmarkResult {
    let mut tensor = MarketTensor4D::new(252, 50, 16, 4);

    benchmark("Tensor fill (252x50x16x4)", 5, 50, || {
        for t in 0..252 {
            for a in 0..50 {
                for f in 0..16 {
                    for d in 0..4 {
                        tensor.set(t, a, f, d, (t * a + f * d) as f64 * 0.001);
                    }
                }
            }
        }
    })
}

pub fn bench_tensor_covariance() -> BenchmarkResult {
    let mut tensor = MarketTensor4D::new(252, 50, 16, 4);
    for t in 0..252 {
        for a in 0..50 {
            tensor.set(t, a, 0, 0, ((t * a) as f64).sin() * 0.02);
        }
    }

    benchmark("Tensor covariance (50 assets)", 5, 50, || {
        let _ = tensor.asset_covariance();
    })
}

pub fn bench_tensor_ewm_covariance() -> BenchmarkResult {
    let mut tensor = MarketTensor4D::new(252, 30, 16, 4);
    for t in 0..252 {
        for a in 0..30 {
            tensor.set(t, a, 0, 0, ((t * a) as f64).sin() * 0.02);
        }
    }

    benchmark("Tensor EWM covariance (30 assets, span=60)", 5, 50, || {
        let _ = tensor.ewm_covariance(60.0);
    })
}

