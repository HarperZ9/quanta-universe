/// Test serialization with large data structures
#[test]
fn stress_large_json_serialization() -> TestResult {
    let start = Instant::now();

    // Create large nested structure
    let mut data = HashMap::new();
    for i in 0..1000 {
        let key = format!("key_{}", i);
        let mut inner = Vec::new();
        for j in 0..1000 {
            inner.push(HashMap::from([
                ("id".to_string(), serde_json::Value::Number(j.into())),
                ("name".to_string(), serde_json::Value::String(format!("item_{}_{}", i, j))),
                ("value".to_string(), serde_json::Value::Number(((i * j) as f64 * 0.001).into())),
                ("nested".to_string(), serde_json::Value::Object(HashMap::from([
                    ("a".to_string(), serde_json::Value::Number(i.into())),
                    ("b".to_string(), serde_json::Value::Number(j.into())),
                ]))),
            ]));
        }
        data.insert(key, inner);
    }

    // Serialize
    let json = serialization::json::to_string(&data)?;
    assert!(json.len() > 100_000_000); // Should be > 100MB

    // Deserialize
    let restored: HashMap<String, Vec<HashMap<String, serde_json::Value>>> =
        serialization::json::from_str(&json)?;

    assert_eq!(restored.len(), 1000);
    assert_eq!(restored.get("key_500").unwrap().len(), 1000);

    println!("Large JSON test: {} bytes in {:?}", json.len(), start.elapsed());

    TestResult::pass()
}

/// Test MessagePack with large binary data
#[test]
fn stress_large_msgpack_binary() -> TestResult {
    let start = Instant::now();

    // Create large binary payload
    let large_binary: Vec<u8> = (0..10_000_000).map(|i| (i % 256) as u8).collect();

    // Serialize
    let msgpack = serialization::msgpack::to_vec(&large_binary)?;

    // Deserialize
    let restored: Vec<u8> = serialization::msgpack::from_slice(&msgpack)?;

    assert_eq!(restored.len(), 10_000_000);
    assert_eq!(restored[0], 0);
    assert_eq!(restored[255], 255);
    assert_eq!(restored[256], 0);

    println!("Large MessagePack binary: {} bytes in {:?}", msgpack.len(), start.elapsed());

    TestResult::pass()
}

/// Test Protocol Buffers with deeply nested messages
#[test]
fn stress_deep_protobuf_nesting() -> TestResult {
    let start = Instant::now();

    // Create deeply nested structure (100 levels deep)
    fn create_nested(depth: usize, max_depth: usize) -> NestedMessage {
        if depth >= max_depth {
            NestedMessage {
                value: depth as i32,
                name: format!("leaf_{}", depth),
                child: None,
            }
        } else {
            NestedMessage {
                value: depth as i32,
                name: format!("node_{}", depth),
                child: Some(Box::new(create_nested(depth + 1, max_depth))),
            }
        }
    }

    let nested = create_nested(0, 100);

    // Serialize
    let bytes = serialization::protobuf::encode(&nested)?;

    // Deserialize
    let restored: NestedMessage = serialization::protobuf::decode(&bytes)?;

    // Verify depth
    let mut current = &restored;
    let mut depth = 0;
    while let Some(ref child) = current.child {
        depth += 1;
        current = child;
    }
    assert_eq!(depth, 99);

    println!("Deep protobuf nesting (100 levels): {:?}", start.elapsed());

    TestResult::pass()
}

/// Test large market tensor operations
#[test]
fn stress_large_tensor_operations() -> TestResult {
    let start = Instant::now();

    // Create large tensor: 5000 time steps, 500 assets, 32 features, 8 derivatives
    let mut tensor = MarketTensor4D::new(5000, 500, 32, 8);

    // Fill with data
    for t in 0..5000 {
        for a in 0..500 {
            for f in 0..32 {
                for d in 0..8 {
                    let value = (t * a + f * d) as f64 * 0.0001;
                    tensor.set(t, a, f, d, value);
                }
            }
        }
    }

    println!("Tensor creation: {:?}", start.elapsed());
    let creation_time = start.elapsed();

    // Compute covariance matrix (500x500)
    let cov_start = Instant::now();
    let cov = tensor.asset_covariance();
    println!("Covariance computation: {:?}", cov_start.elapsed());

    assert_eq!(cov.rows(), 500);
    assert_eq!(cov.cols(), 500);

    // Verify symmetry
    for i in 0..500 {
        for j in i..500 {
            assert_approx(cov.get(i, j), cov.get(j, i), 1e-10);
        }
    }

    // Rolling window computation
    let rolling_start = Instant::now();
    for window_end in 100..5000 {
        let window_start = window_end - 100;
        let slice = tensor.slice_time(window_start, window_end);
        let _ = slice.asset_covariance();
    }
    println!("Rolling 100-window covariance (4900 iterations): {:?}", rolling_start.elapsed());

    TestResult::pass()
}

/// Test collection operations at scale
#[test]
fn stress_large_collections() -> TestResult {
    let start = Instant::now();

    // Test HashMap with 10M entries
    let mut hashmap = HashMap::with_capacity(10_000_000);
    for i in 0..10_000_000 {
        hashmap.insert(format!("key_{}", i), i);
    }
    println!("HashMap 10M insertions: {:?}", start.elapsed());

    let lookup_start = Instant::now();
    for i in 0..1_000_000 {
        let key = format!("key_{}", i * 10);
        assert_eq!(hashmap.get(&key), Some(&(i * 10)));
    }
    println!("HashMap 1M lookups: {:?}", lookup_start.elapsed());

    // Test BTreeMap with 1M entries (more expensive operations)
    let btree_start = Instant::now();
    let mut btreemap = BTreeMap::new();
    for i in 0..1_000_000 {
        btreemap.insert(i, format!("value_{}", i));
    }
    println!("BTreeMap 1M insertions: {:?}", btree_start.elapsed());

    // Range queries
    let range_start = Instant::now();
    for base in (0..1_000_000).step_by(10000) {
        let count = btreemap.range(base..base+1000).count();
        assert_eq!(count, 1000);
    }
    println!("BTreeMap 100 range queries: {:?}", range_start.elapsed());

    // Test Vec operations
    let vec_start = Instant::now();
    let mut vec: Vec<i64> = (0..50_000_000).collect();
    println!("Vec 50M creation: {:?}", vec_start.elapsed());

    let sort_start = Instant::now();
    vec.sort_unstable();
    println!("Vec 50M sort: {:?}", sort_start.elapsed());

    TestResult::pass()
}

