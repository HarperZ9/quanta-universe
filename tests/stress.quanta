// PERFORMANCE BOUNDARY TESTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Test serialization performance bounds
#[test]
fn stress_serialization_performance() -> TestResult {
    let sizes = vec![1_000, 10_000, 100_000, 1_000_000];

    for size in sizes {
        let data: Vec<i64> = (0..size).collect();

        // JSON
        let json_start = Instant::now();
        let json = serialization::json::to_string(&data)?;
        let json_serialize_time = json_start.elapsed();

        let json_deser_start = Instant::now();
        let _: Vec<i64> = serialization::json::from_str(&json)?;
        let json_deserialize_time = json_deser_start.elapsed();

        // MessagePack
        let msgpack_start = Instant::now();
        let msgpack = serialization::msgpack::to_vec(&data)?;
        let msgpack_serialize_time = msgpack_start.elapsed();

        let msgpack_deser_start = Instant::now();
        let _: Vec<i64> = serialization::msgpack::from_slice(&msgpack)?;
        let msgpack_deserialize_time = msgpack_deser_start.elapsed();

        // MessagePack should be faster than JSON for large data
        if size >= 100_000 {
            assert!(msgpack_serialize_time < json_serialize_time * 2);
            assert!(msgpack_deserialize_time < json_deserialize_time * 2);
        }

        // MessagePack should produce smaller output
        assert!(msgpack.len() < json.len());

        println!("Size {}: JSON {}ms/{}ms ({}B), MsgPack {}ms/{}ms ({}B)",
            size,
            json_serialize_time.as_millis(), json_deserialize_time.as_millis(), json.len(),
            msgpack_serialize_time.as_millis(), msgpack_deserialize_time.as_millis(), msgpack.len()
        );
    }

    TestResult::pass()
}

/// Test matrix operation performance scaling
#[test]
fn stress_matrix_performance_scaling() -> TestResult {
    let sizes = vec![10, 50, 100, 200, 500];

    for size in sizes {
        let mut a = Matrix::new(size, size);
        let mut b = Matrix::new(size, size);

        // Fill with random-ish data
        for i in 0..size {
            for j in 0..size {
                a.set(i, j, ((i * j + i + j) as f64).sin());
                b.set(i, j, ((i * j * 2 + i - j) as f64).cos());
            }
        }

        // Matrix multiplication
        let mul_start = Instant::now();
        let c = a.mul(&b);
        let mul_time = mul_start.elapsed();

        // Inversion (for smaller matrices)
        if size <= 200 {
            let inv_start = Instant::now();
            let _ = a.inverse();
            let inv_time = inv_start.elapsed();
            println!("Matrix {}x{}: mul {:?}, inv {:?}", size, size, mul_time, inv_time);
        } else {
            println!("Matrix {}x{}: mul {:?}", size, size, mul_time);
        }

        // Verify result dimensions
        assert_eq!(c.rows(), size);
        assert_eq!(c.cols(), size);
    }

    TestResult::pass()
}

/// Test neural network inference throughput
#[test]
fn stress_neural_network_throughput() -> TestResult {
    use axiom::{Dense, Activation};

    // Create network
    let mut nn = NeuralNetwork::new()
        .add(Dense::new(100, 256))
        .add(Activation::ReLU)
        .add(Dense::new(256, 128))
        .add(Activation::ReLU)
        .add(Dense::new(128, 64))
        .add(Activation::ReLU)
        .add(Dense::new(64, 10))
        .add(Activation::Softmax)
        .build();

    // Generate batch of inputs
    let batch_sizes = vec![1, 10, 100, 1000];

    for batch_size in batch_sizes {
        let inputs: Vec<Vec<f64>> = (0..batch_size)
            .map(|i| (0..100).map(|j| ((i * j) as f64 * 0.01).sin()).collect())
            .collect();

        let start = Instant::now();
        for input in &inputs {
            let _ = nn.forward(input);
        }
        let elapsed = start.elapsed();

        let throughput = batch_size as f64 / elapsed.as_secs_f64();
        println!("NN batch {}: {:?} ({:.0} samples/sec)", batch_size, elapsed, throughput);

        // Should maintain reasonable throughput
        assert!(throughput > 100.0); // At least 100 samples/sec
    }

    TestResult::pass()
}

/// Test encryption/decryption throughput
#[test]
fn stress_crypto_throughput() -> TestResult {
    let data_sizes = vec![1_000, 10_000, 100_000, 1_000_000];

    for size in data_sizes {
        let data: Vec<u8> = (0..size).map(|i| (i % 256) as u8).collect();
        let key = crypto::generate_key(crypto::Algorithm::AES256);

        // Encryption
        let encrypt_start = Instant::now();
        let encrypted = crypto::encrypt(&data, &key, crypto::Algorithm::AES256)?;
        let encrypt_time = encrypt_start.elapsed();

        // Decryption
        let decrypt_start = Instant::now();
        let decrypted = crypto::decrypt(&encrypted, &key, crypto::Algorithm::AES256)?;
        let decrypt_time = decrypt_start.elapsed();

        assert_eq!(decrypted, data);

        let encrypt_throughput = size as f64 / encrypt_time.as_secs_f64() / 1_000_000.0;
        let decrypt_throughput = size as f64 / decrypt_time.as_secs_f64() / 1_000_000.0;

        println!("Crypto {}B: encrypt {:.1} MB/s, decrypt {:.1} MB/s",
            size, encrypt_throughput, decrypt_throughput);

        // Should achieve reasonable throughput
        if size >= 100_000 {
            assert!(encrypt_throughput > 10.0); // At least 10 MB/s
            assert!(decrypt_throughput > 10.0);
        }
    }

    TestResult::pass()
}

