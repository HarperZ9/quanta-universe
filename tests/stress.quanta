/// Test extreme floating point values
#[test]
fn stress_floating_point_edge_cases() -> TestResult {
    let edge_values = vec![
        0.0,
        -0.0,
        f64::MIN,
        f64::MAX,
        f64::MIN_POSITIVE,
        f64::EPSILON,
        f64::INFINITY,
        f64::NEG_INFINITY,
        1e308,
        1e-308,
        2.2250738585072014e-308, // Smallest normal
    ];

    for &val in &edge_values {
        // JSON roundtrip
        if val.is_finite() {
            let json = serialization::json::to_string(&val)?;
            let restored: f64 = serialization::json::from_str(&json)?;

            if val == 0.0 {
                assert!(restored == 0.0);
            } else {
                assert!((restored - val).abs() / val.abs() < 1e-10);
            }
        }

        // MessagePack roundtrip
        if val.is_finite() {
            let msgpack = serialization::msgpack::to_vec(&val)?;
            let restored: f64 = serialization::msgpack::from_slice(&msgpack)?;

            if val == 0.0 {
                assert!(restored == 0.0);
            } else {
                assert!((restored - val).abs() / val.abs() < 1e-10);
            }
        }
    }

    // Test NaN handling
    let nan = f64::NAN;
    let msgpack = serialization::msgpack::to_vec(&nan)?;
    let restored: f64 = serialization::msgpack::from_slice(&msgpack)?;
    assert!(restored.is_nan());

    TestResult::pass()
}

/// Test empty and near-empty structures
#[test]
fn stress_empty_structures() -> TestResult {
    // Empty collections
    let empty_vec: Vec<i32> = Vec::new();
    let empty_map: HashMap<String, i32> = HashMap::new();
    let empty_string = String::new();

    // Serialize all
    let json = serialization::json::to_string(&(empty_vec.clone(), empty_map.clone(), empty_string.clone()))?;

    // Deserialize
    let restored: (Vec<i32>, HashMap<String, i32>, String) = serialization::json::from_str(&json)?;

    assert!(restored.0.is_empty());
    assert!(restored.1.is_empty());
    assert!(restored.2.is_empty());

    // Empty tensor
    let tensor = MarketTensor4D::new(0, 0, 0, 0);
    assert_eq!(tensor.shape[0], 0);

    // Single element collections
    let single_vec = vec![42];
    let mut single_map = HashMap::new();
    single_map.insert("key".to_string(), 1);

    let json = serialization::json::to_string(&(single_vec.clone(), single_map.clone()))?;
    let restored: (Vec<i32>, HashMap<String, i32>) = serialization::json::from_str(&json)?;

    assert_eq!(restored.0.len(), 1);
    assert_eq!(restored.1.len(), 1);

    TestResult::pass()
}

/// Test Unicode edge cases
#[test]
fn stress_unicode_edge_cases() -> TestResult {
    let unicode_strings = vec![
        "",
        " ",
        "Hello, World!",
        "日本語テスト",
        "العربية",
        "🎉🚀💻🔥",
        "Mixed: Hello 世界 🌍",
        "\u{0000}",  // Null
        "\u{FFFF}",  // Max BMP
        "🏴󠁧󠁢󠁥󠁮󠁧󠁿",  // Flag emoji with ZWJ
        "\u{200B}", // Zero-width space
        "Z̤͔ͧ̑̓ä͖̭̈́l̥̻̗̳̿g̲͈͋͒o̫̕",  // Zalgo text
        "a\u{0308}",  // Decomposed ä
        "ä",  // Precomposed ä
        "\u{1F469}\u{200D}\u{1F4BB}",  // Woman technologist
    ];

    for s in &unicode_strings {
        // JSON roundtrip
        let json = serialization::json::to_string(s)?;
        let restored: String = serialization::json::from_str(&json)?;
        assert_eq!(&restored, *s);

        // MessagePack roundtrip
        let msgpack = serialization::msgpack::to_vec(s)?;
        let restored: String = serialization::msgpack::from_slice(&msgpack)?;
        assert_eq!(&restored, *s);
    }

    // Very long Unicode string
    let long_unicode: String = "日本語".repeat(100_000);
    let json = serialization::json::to_string(&long_unicode)?;
    let restored: String = serialization::json::from_str(&json)?;
    assert_eq!(restored.len(), long_unicode.len());

    TestResult::pass()
}

/// Test matrix edge cases
#[test]
fn stress_matrix_edge_cases() -> TestResult {
    // 1x1 matrix
    let tiny = Matrix::new(1, 1);
    assert_eq!(tiny.rows(), 1);
    assert_eq!(tiny.cols(), 1);

    // Very wide matrix
    let wide = Matrix::new(1, 10000);
    assert_eq!(wide.rows(), 1);
    assert_eq!(wide.cols(), 10000);

    // Very tall matrix
    let tall = Matrix::new(10000, 1);
    assert_eq!(tall.rows(), 10000);
    assert_eq!(tall.cols(), 1);

    // Matrix with all zeros
    let zeros = Matrix::zeros(100, 100);
    let det = zeros.determinant();
    assert_eq!(det, 0.0);

    // Identity matrix
    let identity = Matrix::identity(100);
    let det = identity.determinant();
    assert_approx(det, 1.0, 1e-10);

    // Matrix inverse of identity
    let inv = identity.inverse()?;
    for i in 0..100 {
        for j in 0..100 {
            let expected = if i == j { 1.0 } else { 0.0 };
            assert_approx(inv.get(i, j), expected, 1e-10);
        }
    }

    TestResult::pass()
}

