/// Test memory allocation patterns
#[test]
fn stress_memory_allocation_churn() -> TestResult {
    let iterations = 1000;
    let mut peak_memory = 0usize;

    for iter in 0..iterations {
        // Allocate varying sizes
        let size = ((iter % 100) + 1) * 10000;
        let mut vec: Vec<u8> = vec![0u8; size];

        // Touch memory to ensure allocation
        for i in 0..size {
            vec[i] = (i % 256) as u8;
        }

        peak_memory = peak_memory.max(size);

        // Let it go out of scope for deallocation
    }

    // Allocate a final large block to verify heap isn't fragmented
    let final_alloc: Vec<u64> = vec![0; 1_000_000];
    assert_eq!(final_alloc.len(), 1_000_000);

    TestResult::pass()
}

/// Test string interning under pressure
#[test]
fn stress_string_interning() -> TestResult {
    let mut strings = HashSet::new();

    // Insert many unique strings
    for i in 0..1_000_000 {
        strings.insert(format!("string_number_{}_with_suffix_{}", i, i % 100));
    }

    assert_eq!(strings.len(), 1_000_000);

    // Insert duplicates (should not increase size)
    for i in 0..100_000 {
        strings.insert(format!("string_number_{}_with_suffix_{}", i, i % 100));
    }

    assert_eq!(strings.len(), 1_000_000);

    // Lookup performance
    let start = Instant::now();
    for i in 0..100_000 {
        let key = format!("string_number_{}_with_suffix_{}", i * 10, (i * 10) % 100);
        assert!(strings.contains(&key));
    }
    println!("100k string lookups: {:?}", start.elapsed());

    TestResult::pass()
}

/// Test arena allocation patterns
#[test]
fn stress_arena_allocation() -> TestResult {
    // Simulate arena-like allocation with VecDeque
    let mut arena = VecDeque::with_capacity(10_000_000);

    // Allocate in chunks
    for chunk in 0..1000 {
        let chunk_data: Vec<u64> = (0..10000).map(|i| (chunk * 10000 + i) as u64).collect();
        arena.extend(chunk_data);
    }

    assert_eq!(arena.len(), 10_000_000);

    // Random access
    for i in (0..10_000_000).step_by(10000) {
        assert_eq!(arena[i], i as u64);
    }

    // Pop from front (arena cleanup simulation)
    let pop_start = Instant::now();
    while arena.len() > 1_000_000 {
        arena.pop_front();
    }
    println!("Arena cleanup (9M pops): {:?}", pop_start.elapsed());

    TestResult::pass()
}

