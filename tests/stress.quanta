/// Test concurrent HashMap access
#[test]
fn stress_concurrent_hashmap() -> TestResult {
    let map = Arc::new(RwLock::new(HashMap::new()));
    let counter = Arc::new(AtomicU64::new(0));

    let num_threads = 16;
    let ops_per_thread = 100_000;

    let mut handles = Vec::new();

    for thread_id in 0..num_threads {
        let map = Arc::clone(&map);
        let counter = Arc::clone(&counter);

        let handle = thread::spawn(move || {
            for i in 0..ops_per_thread {
                let key = format!("thread_{}_key_{}", thread_id, i);
                let value = thread_id * ops_per_thread + i;

                // Write operation
                {
                    let mut w = map.write().unwrap();
                    w.insert(key.clone(), value);
                }

                // Read operation
                {
                    let r = map.read().unwrap();
                    if let Some(&v) = r.get(&key) {
                        counter.fetch_add(1, Ordering::Relaxed);
                    }
                }
            }
        });

        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    let final_count = counter.load(Ordering::Relaxed);
    assert!(final_count >= (num_threads * ops_per_thread) as u64 * 8 / 10); // At least 80% success

    let map = map.read().unwrap();
    assert_eq!(map.len(), (num_threads * ops_per_thread) as usize);

    TestResult::pass()
}

/// Test concurrent tensor writes
#[test]
fn stress_concurrent_tensor_writes() -> TestResult {
    let tensor = Arc::new(Mutex::new(MarketTensor4D::new(1000, 100, 16, 4)));

    let num_threads = 8;
    let mut handles = Vec::new();

    for thread_id in 0..num_threads {
        let tensor = Arc::clone(&tensor);
        let asset_range_start = thread_id * (100 / num_threads);
        let asset_range_end = (thread_id + 1) * (100 / num_threads);

        let handle = thread::spawn(move || {
            for t in 0..1000 {
                for a in asset_range_start..asset_range_end {
                    let value = (thread_id * 1000 + t * 100 + a) as f64 * 0.001;
                    let mut tensor = tensor.lock().unwrap();
                    tensor.set(t, a, 0, 0, value);
                }
            }
        });

        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    // Verify data integrity
    let tensor = tensor.lock().unwrap();
    for a in 0..100 {
        let value = tensor.get(500, a, 0, 0);
        assert!(value > 0.0);
    }

    TestResult::pass()
}

/// Test parallel trading engine execution
#[test]
fn stress_parallel_trading_engines() -> TestResult {
    let num_engines = 100;
    let mut handles = Vec::new();

    let results = Arc::new(Mutex::new(Vec::new()));

    for engine_id in 0..num_engines {
        let results = Arc::clone(&results);

        let handle = thread::spawn(move || {
            let mut engine = TradingEngine::new()
                .with_capital(100_000.0)
                .with_commission(0.001);

            // Simulate 252 trading days
            for day in 0..252 {
                let price = 100.0 + (day as f64).sin() * 10.0 + engine_id as f64 * 0.1;

                engine.update_prices(&HashMap::from([
                    ("ASSET".to_string(), price),
                ]));

                // Generate signals
                if day % 10 == 0 {
                    engine.signal("ASSET", if day % 20 == 0 { Signal::Buy } else { Signal::Sell }, 0.5);
                }

                engine.execute().ok();
            }

            let equity = engine.equity();
            results.lock().unwrap().push((engine_id, equity));
        });

        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    let results = results.lock().unwrap();
    assert_eq!(results.len(), num_engines);

    // All engines should have positive equity
    for (_, equity) in results.iter() {
        assert!(*equity > 0.0);
    }

    TestResult::pass()
}

/// Test async task spawning under load
#[test]
fn stress_async_task_spawning() -> TestResult {
    use foundation::sync::{spawn, channel};

    let num_tasks = 10_000;
    let (tx, rx) = channel::<u64>();

    let start = Instant::now();

    for i in 0..num_tasks {
        let tx = tx.clone();
        spawn(async move {
            // Simulate some work
            let result = (0..1000).fold(0u64, |acc, x| acc.wrapping_add(x * i as u64));
            tx.send(result).ok();
        });
    }

    drop(tx); // Close sender

    // Collect all results
    let mut count = 0;
    while let Ok(_) = rx.recv() {
        count += 1;
    }

    assert_eq!(count, num_tasks);
    println!("Spawned and completed {} async tasks in {:?}", num_tasks, start.elapsed());

    TestResult::pass()
}

