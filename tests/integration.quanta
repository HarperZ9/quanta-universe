/// Test field-tensor and quantum-finance integration
fn test_tensor_finance_integration() -> TestResult {
    // Build market tensor from sample data
    let mut builder = MarketTensorBuilder::new();
    builder.add_symbol("AAPL");
    builder.add_symbol("GOOGL");
    builder.add_symbol("MSFT");

    // Add 100 days of simulated data
    for day in 0..100 {
        let base_price = 100.0 + (day as f64) * 0.5;
        for (i, symbol) in ["AAPL", "GOOGL", "MSFT"].iter().enumerate() {
            let multiplier = 1.0 + (i as f64) * 0.5;
            let price = base_price * multiplier;
            let volume = 1_000_000.0 + (day as f64) * 10_000.0;

            builder.add_ohlcv(
                symbol,
                day as u64,
                price * 0.99,  // open
                price * 1.02,  // high
                price * 0.98,  // low
                price,         // close
                volume,
            );
        }
    }

    let tensor = builder.build(50);

    // Use tensor for portfolio optimization
    let cov = tensor.asset_covariance();
    let returns = vec![0.12, 0.15, 0.10]; // Expected returns

    let optimizer = PortfolioOptimizer::new(returns, cov);
    let weights = optimizer.mean_variance(2.0);

    // Verify weights sum to 1
    let sum: f64 = weights.iter().sum();
    assert_approx(sum, 1.0, 1e-10);

    // Verify all weights are non-negative
    for w in &weights {
        assert!(*w >= 0.0);
    }

    // Use weights in trading engine
    let mut engine = TradingEngine::new();
    engine.set_portfolio_weights(&["AAPL", "GOOGL", "MSFT"], &weights);

    // Generate signals from tensor
    for t in 0..tensor.shape[0] {
        let rsi_aapl = tensor.get(t, 0, features::RSI, derivatives::VALUE);
        if rsi_aapl < 30.0 {
            engine.signal("AAPL", Signal::Buy, 0.8);
        } else if rsi_aapl > 70.0 {
            engine.signal("AAPL", Signal::Sell, 0.8);
        }
    }

    TestResult::pass()
}

/// Test oracle and trading integration
fn test_oracle_trading_integration() -> TestResult {
    use oracle::{TimeSeriesPredictor, ProphetModel, TemporalFusion};

    // Create historical price data
    let prices: Vec<f64> = (0..200).map(|i| {
        100.0 + (i as f64).sin() * 10.0 + (i as f64) * 0.1
    }).collect();

    // Train predictor
    let mut predictor = TimeSeriesPredictor::new(ProphetModel::default());
    predictor.fit(&prices, 20)?;

    // Generate forecasts
    let forecasts = predictor.predict(10)?;
    assert_eq!(forecasts.len(), 10);

    // Use forecasts in trading decisions
    let current_price = prices.last().unwrap();
    let predicted_price = forecasts[0];

    let decision = if predicted_price > current_price * 1.02 {
        TradingDecision::Buy
    } else if predicted_price < current_price * 0.98 {
        TradingDecision::Sell
    } else {
        TradingDecision::Hold
    };

    // Verify prediction is reasonable
    assert!((predicted_price - current_price).abs() < current_price * 0.2);

    TestResult::pass()
}

/// Test end-to-end portfolio optimization
fn test_portfolio_optimization_e2e() -> TestResult {
    // Load or generate market data
    let mut tensor = MarketTensor4D::new(252, 10, 16, 4);

    // Populate with realistic market simulation
    let symbols = vec!["AAPL", "GOOGL", "MSFT", "AMZN", "META",
                       "NVDA", "TSLA", "JPM", "V", "UNH"];

    for t in 0..252 {
        for (a, _) in symbols.iter().enumerate() {
            // Simulate returns
            let ret = 0.0002 + 0.02 * ((t * a) as f64).sin();
            tensor.set(t, a, features::PRICE, derivatives::FIRST, ret);
        }
    }

    // Compute various portfolio strategies
    let cov = tensor.asset_covariance();
    let returns: Vec<f64> = (0..10).map(|i| 0.08 + 0.02 * (i as f64) / 10.0).collect();
    let optimizer = PortfolioOptimizer::new(returns.clone(), cov.clone());

    // Mean-variance portfolio
    let mv_weights = optimizer.mean_variance(3.0);

    // Minimum variance portfolio
    let min_var_weights = optimizer.minimum_variance();

    // Maximum Sharpe portfolio
    let max_sharpe_weights = optimizer.maximum_sharpe(0.02);

    // Risk parity portfolio
    let risk_parity_weights = optimizer.risk_parity(100);

    // Verify all portfolios are valid
    for weights in [&mv_weights, &min_var_weights, &max_sharpe_weights, &risk_parity_weights] {
        let sum: f64 = weights.iter().sum();
        assert_approx(sum, 1.0, 1e-6);
        assert!(weights.iter().all(|&w| w >= 0.0));
    }

    // Compare portfolio risks
    fn portfolio_variance(weights: &[f64], cov: &Matrix) -> f64 {
        let mut var = 0.0;
        for i in 0..weights.len() {
            for j in 0..weights.len() {
                var += weights[i] * weights[j] * cov.get(i, j);
            }
        }
        var
    }

    let min_var_risk = portfolio_variance(&min_var_weights, &cov);
    let mv_risk = portfolio_variance(&mv_weights, &cov);

    // Minimum variance should have lower risk
    assert!(min_var_risk <= mv_risk + 1e-10);

    TestResult::pass()
}

/// Test backtesting pipeline
fn test_backtest_pipeline() -> TestResult {
    use quantum_finance::{Backtester, BacktestConfig, Strategy};

    // Create strategy
    let strategy = MomentumStrategy::new(20, 0.02);

    // Configure backtest
    let config = BacktestConfig::new()
        .with_initial_capital(100_000.0)
        .with_commission(0.001)
        .with_slippage(0.0005)
        .with_start_date("2020-01-01")
        .with_end_date("2023-12-31");

    // Generate sample market data
    let mut market_data = Vec::new();
    for day in 0..1000 {
        market_data.push(MarketBar {
            timestamp: day as u64 * 86400,
            open: 100.0 + (day as f64).sin() * 5.0,
            high: 102.0 + (day as f64).sin() * 5.0,
            low: 98.0 + (day as f64).sin() * 5.0,
            close: 100.5 + (day as f64).sin() * 5.0 + day as f64 * 0.01,
            volume: 1_000_000.0,
        });
    }

    // Run backtest
    let mut backtester = Backtester::new(config);
    let results = backtester.run(&strategy, &market_data)?;

    // Verify results
    assert!(results.total_trades > 0);
    assert!(results.sharpe_ratio.is_finite());
    assert!(results.max_drawdown <= 1.0);
    assert!(results.final_equity > 0.0);

    // Verify trade log
    for trade in &results.trades {
        assert!(trade.entry_price > 0.0);
        assert!(trade.exit_price > 0.0);
        assert!(trade.quantity > 0.0);
    }

    TestResult::pass()
}

