// HELPER TYPES FOR TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Serialize, Deserialize)]
struct User {
    id: u32,
    name: String,
    score: f64,
}

#[derive(Serialize, Deserialize)]
struct Credentials {
    api_key: String,
    secret: String,
}

enum Signal {
    Buy,
    Sell,
    Hold,
}

enum TradingDecision {
    Buy,
    Sell,
    Hold,
}

struct MomentumStrategy {
    lookback: usize,
    threshold: f64,
}

impl MomentumStrategy {
    fn new(lookback: usize, threshold: f64) -> Self {
        MomentumStrategy { lookback, threshold }
    }
}

impl Strategy for MomentumStrategy {
    fn generate_signal(&self, data: &[MarketBar]) -> Signal {
        if data.len() < self.lookback {
            return Signal::Hold;
        }

        let momentum = (data.last().unwrap().close - data[data.len() - self.lookback].close)
            / data[data.len() - self.lookback].close;

        if momentum > self.threshold {
            Signal::Buy
        } else if momentum < -self.threshold {
            Signal::Sell
        } else {
            Signal::Hold
        }
    }
}

struct MarketBar {
    timestamp: u64,
    open: f64,
    high: f64,
    low: f64,
    close: f64,
    volume: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST RUNNER
// ═══════════════════════════════════════════════════════════════════════════════

/// Main entry point for running integration tests
pub fn main() -> i32 {
    let config = IntegrationTestConfig::default();
    let suite = run_all_integration_tests(&config);

    let results = suite.run();

    println!("\n{}", "═".repeat(70));
    println!("QUANTA-UNIVERSE Integration Test Results");
    println!("{}", "═".repeat(70));
    println!("Total:   {}", results.total);
    println!("Passed:  {} ({}%)", results.passed, results.passed * 100 / results.total.max(1));
    println!("Failed:  {}", results.failed);
    println!("Skipped: {}", results.skipped);
    println!("{}", "═".repeat(70));

    if results.failed > 0 {
        println!("\nFailed tests:");
        for failure in &results.failures {
            println!("  - {}: {}", failure.name, failure.message);
        }
        1
    } else {
        println!("\nAll integration tests passed!");
        0
    }
}
