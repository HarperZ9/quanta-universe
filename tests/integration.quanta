/// Test full trading system with all components
fn test_full_trading_system() -> TestResult {
    // 1. Load/generate market data
    let mut tensor_builder = MarketTensorBuilder::new();
    let symbols = vec!["SPY", "QQQ", "IWM", "DIA", "VTI"];

    for symbol in &symbols {
        tensor_builder.add_symbol(symbol);
    }

    // Simulate 2 years of daily data
    for day in 0..504 {
        for (i, symbol) in symbols.iter().enumerate() {
            let base = 100.0 + i as f64 * 50.0;
            let trend = day as f64 * 0.02;
            let noise = ((day * (i + 1)) as f64).sin() * 3.0;
            let price = base + trend + noise;

            tensor_builder.add_ohlcv(
                symbol,
                day as u64 * 86400,
                price * 0.995,
                price * 1.01,
                price * 0.99,
                price,
                1_000_000.0 + (day as f64 * 1000.0),
            );
        }
    }

    let tensor = tensor_builder.build(252);

    // 2. Compute covariance and optimize portfolio
    let cov = tensor.ewm_covariance(60.0);
    let returns: Vec<f64> = symbols.iter().enumerate().map(|(i, _)| {
        0.08 + 0.02 * i as f64 / symbols.len() as f64
    }).collect();

    let optimizer = PortfolioOptimizer::new(returns, cov);
    let weights = optimizer.risk_parity(100);

    // 3. Train prediction model
    let mut predictor = TimeSeriesPredictor::new(LSTMModel::new(16, 64, 2));
    let price_history: Vec<f64> = (0..252).map(|t| {
        tensor.get(t, 0, features::PRICE, derivatives::VALUE)
    }).collect();
    predictor.fit(&price_history, 20)?;

    // 4. Create trading engine
    let mut engine = TradingEngine::new()
        .with_capital(1_000_000.0)
        .with_commission(0.001)
        .with_slippage(0.0005);

    engine.set_portfolio_weights(&symbols, &weights);

    // 5. Run simulation
    let mut equity_curve = Vec::new();
    equity_curve.push(engine.equity());

    for t in 252..504 {
        // Get current prices
        let prices: HashMap<String, f64> = symbols.iter().enumerate().map(|(i, s)| {
            (s.to_string(), tensor.get(t % 252, i, features::PRICE, derivatives::VALUE))
        }).collect();

        // Update engine with prices
        engine.update_prices(&prices);

        // Generate signals based on indicators
        for (i, symbol) in symbols.iter().enumerate() {
            let rsi = tensor.get(t % 252, i, features::RSI, derivatives::VALUE);
            let macd = tensor.get(t % 252, i, features::MACD, derivatives::VALUE);

            if rsi < 30.0 && macd > 0.0 {
                engine.signal(symbol, Signal::Buy, weights[i]);
            } else if rsi > 70.0 && macd < 0.0 {
                engine.signal(symbol, Signal::Sell, weights[i]);
            }
        }

        // Execute
        engine.execute()?;
        equity_curve.push(engine.equity());
    }

    // 6. Compute performance metrics
    let returns: Vec<f64> = (1..equity_curve.len()).map(|i| {
        (equity_curve[i] / equity_curve[i - 1]) - 1.0
    }).collect();

    let mean_return = returns.iter().sum::<f64>() / returns.len() as f64;
    let variance = returns.iter().map(|r| (r - mean_return).powi(2)).sum::<f64>() / returns.len() as f64;
    let volatility = variance.sqrt() * (252.0_f64).sqrt();
    let sharpe = mean_return * 252.0 / volatility;

    // Verify reasonable performance
    assert!(sharpe.is_finite());
    assert!(engine.equity() > 0.0);

    TestResult::pass()
}

/// Test AI-enhanced trading
fn test_ai_enhanced_trading() -> TestResult {
    use axiom::{NeuralNetwork, Dense, Dropout, LSTM};
    use oracle::{EnsemblePredictor, BayesianRegression};

    // Create feature tensor
    let mut tensor = MarketTensor4D::new(500, 3, 16, 4);

    // Populate with market simulation
    for t in 0..500 {
        for a in 0..3 {
            let ret = 0.001 * ((t * a) as f64).sin() + 0.0001 * ((t + a) as f64);
            let vol = 0.15 + 0.05 * ((t * 2) as f64).cos();
            let rsi = 50.0 + 30.0 * ((t * 3) as f64).sin();

            tensor.set(t, a, features::PRICE, derivatives::FIRST, ret);
            tensor.set(t, a, features::VOLATILITY, derivatives::VALUE, vol);
            tensor.set(t, a, features::RSI, derivatives::VALUE, rsi);
        }
    }

    // Extract features for ML
    let features: Vec<Vec<f64>> = (0..400).map(|t| {
        let mut feat = Vec::new();
        for a in 0..3 {
            feat.push(tensor.get(t, a, features::PRICE, derivatives::FIRST));
            feat.push(tensor.get(t, a, features::VOLATILITY, derivatives::VALUE));
            feat.push(tensor.get(t, a, features::RSI, derivatives::VALUE));
        }
        feat
    }).collect();

    // Labels: next period return
    let labels: Vec<f64> = (0..400).map(|t| {
        tensor.get(t + 1, 0, features::PRICE, derivatives::FIRST)
    }).collect();

    // Train neural network
    let mut nn = NeuralNetwork::new()
        .add(Dense::new(9, 32))
        .add(Activation::ReLU)
        .add(Dropout::new(0.2))
        .add(Dense::new(32, 16))
        .add(Activation::ReLU)
        .add(Dense::new(16, 1))
        .build();

    nn.train_regression(&features[..300], &labels[..300], 50, 0.001)?;

    // Train Bayesian regression
    let mut bayesian = BayesianRegression::new();
    bayesian.fit(&features[..300], &labels[..300])?;

    // Create ensemble
    let mut ensemble = EnsemblePredictor::new();
    ensemble.add_model("nn", Box::new(nn), 0.6);
    ensemble.add_model("bayesian", Box::new(bayesian), 0.4);

    // Test predictions
    let mut correct_direction = 0;
    for t in 300..400 {
        let prediction = ensemble.predict(&features[t])?;
        let actual = labels[t];

        if prediction.signum() == actual.signum() {
            correct_direction += 1;
        }
    }

    // Should predict direction better than random
    let accuracy = correct_direction as f64 / 100.0;
    assert!(accuracy >= 0.45); // At least close to random

    TestResult::pass()
}

/// Test full render pipeline
fn test_full_render_pipeline() -> TestResult {
    use photon::{Renderer, Scene, Mesh, Material, Light};
    use spectrum::{Color, HDRImage};
    use lumina::{PostProcessor, Bloom, ToneMapping, FXAA};

    // Create scene
    let mut scene = Scene::new();

    // Add mesh
    let cube = Mesh::cube(1.0);
    let material = Material::pbr()
        .albedo(Color::from_rgb(0.8, 0.2, 0.2))
        .metallic(0.0)
        .roughness(0.5);

    scene.add_object(cube, material, Transform::identity());

    // Add lights
    scene.add_light(Light::directional(
        Vec3::new(-1.0, -1.0, -1.0).normalize(),
        Color::white(),
        10.0
    ));

    scene.add_light(Light::ambient(Color::from_rgb(0.1, 0.1, 0.15)));

    // Create renderer
    let mut renderer = Renderer::new(1920, 1080);

    // Render scene
    let hdr_image = renderer.render(&scene)?;

    // Verify HDR output
    assert_eq!(hdr_image.width(), 1920);
    assert_eq!(hdr_image.height(), 1080);

    // Apply post-processing
    let mut post = PostProcessor::new();
    post.add(Bloom::new(0.8, 5));
    post.add(ToneMapping::ACES);
    post.add(FXAA::new());

    let final_image = post.process(&hdr_image)?;

    // Verify LDR output
    for pixel in final_image.pixels() {
        assert!(pixel.r >= 0.0 && pixel.r <= 1.0);
        assert!(pixel.g >= 0.0 && pixel.g <= 1.0);
        assert!(pixel.b >= 0.0 && pixel.b <= 1.0);
    }

    TestResult::pass()
}

