/// Test forge project lifecycle
fn test_forge_project_lifecycle() -> TestResult {
    use forge::{ProjectGenerator, ProjectTemplate, BuildSystem, TestRunner};

    // Create temp project directory
    let project_dir = temp_dir().join("test_project");

    // Generate new project
    let generator = ProjectGenerator::new(ProjectTemplate::Library);
    generator.create(&project_dir, "test_lib")?;

    // Verify project structure
    assert!(project_dir.join("lib.quanta").exists());
    assert!(project_dir.join("Quark.toml").exists());
    assert!(project_dir.join("tests").is_dir());

    // Add source file
    let src = r#"
        pub fn add(a: i32, b: i32) -> i32 {
            a + b
        }

        #[test]
        fn test_add() {
            assert_eq!(add(2, 3), 5);
        }
    "#;
    fs::write(project_dir.join("lib.quanta"), src)?;

    // Build project
    let build = BuildSystem::new(&project_dir);
    let build_result = build.compile()?;
    assert!(build_result.success);
    assert!(build_result.artifacts.len() > 0);

    // Run tests
    let test_runner = TestRunner::new(&project_dir);
    let test_result = test_runner.run_all()?;
    assert!(test_result.passed > 0);
    assert_eq!(test_result.failed, 0);

    // Cleanup
    fs::remove_dir_all(&project_dir)?;

    TestResult::pass()
}

/// Test LSP completion integration
fn test_lsp_completion_integration() -> TestResult {
    use lsp::{LanguageServer, CompletionRequest, TextDocument};

    // Create language server
    let mut server = LanguageServer::new();

    // Open document
    let doc = TextDocument::new(
        "file:///test.quanta",
        r#"
            use std::collections::HashMap

            fn main() {
                let mut map = HashMap::new();
                map.
            }
        "#
    );

    server.open_document(doc)?;

    // Request completion at cursor position
    let completions = server.completion(CompletionRequest {
        uri: "file:///test.quanta".to_string(),
        line: 5,
        character: 20,
    })?;

    // Verify HashMap methods are suggested
    let method_names: Vec<&str> = completions.iter()
        .map(|c| c.label.as_str())
        .collect();

    assert!(method_names.contains(&"insert"));
    assert!(method_names.contains(&"get"));
    assert!(method_names.contains(&"remove"));
    assert!(method_names.contains(&"len"));

    TestResult::pass()
}

/// Test formatter parse roundtrip
fn test_fmt_parse_roundtrip() -> TestResult {
    use fmt::{Formatter, FormatConfig};
    use quantalang::parser::Parser;

    let original = r#"
fn fibonacci(n:i32)->i32{
if n<=1{return n;}
return fibonacci(n-1)+fibonacci(n-2);
}
"#;

    // Parse original
    let ast = Parser::parse(original)?;

    // Format
    let config = FormatConfig::default();
    let formatter = Formatter::new(config);
    let formatted = formatter.format(original)?;

    // Parse formatted
    let formatted_ast = Parser::parse(&formatted)?;

    // ASTs should be equivalent
    assert_eq!(ast, formatted_ast);

    // Formatting should be idempotent
    let reformatted = formatter.format(&formatted)?;
    assert_eq!(formatted, reformatted);

    TestResult::pass()
}

