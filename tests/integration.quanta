/// Test photon and spectrum integration
fn test_photon_spectrum_integration() -> TestResult {
    use photon::{RenderTarget, ShaderProgram, Uniform};
    use spectrum::{Color, ColorSpace, ToneMapper};

    // Create HDR color
    let hdr_color = Color::from_xyz(0.5, 0.4, 0.3);

    // Convert to different color spaces
    let srgb = hdr_color.to_srgb();
    let display_p3 = hdr_color.to_color_space(ColorSpace::DisplayP3);
    let rec2020 = hdr_color.to_color_space(ColorSpace::Rec2020);

    // Verify color space conversions are reversible
    let back_to_xyz = srgb.to_xyz();
    assert_approx(back_to_xyz.x, hdr_color.x, 1e-6);
    assert_approx(back_to_xyz.y, hdr_color.y, 1e-6);
    assert_approx(back_to_xyz.z, hdr_color.z, 1e-6);

    // Apply tone mapping
    let tone_mapper = ToneMapper::ACES;
    let tonemapped = tone_mapper.apply(&hdr_color);

    // Verify tonemapped values are in display range
    assert!(tonemapped.r >= 0.0 && tonemapped.r <= 1.0);
    assert!(tonemapped.g >= 0.0 && tonemapped.g <= 1.0);
    assert!(tonemapped.b >= 0.0 && tonemapped.b <= 1.0);

    // Create shader with color uniform
    let shader = ShaderProgram::new()
        .add_uniform(Uniform::Vec3("u_color", tonemapped.to_vec3()))
        .add_uniform(Uniform::Float("u_exposure", 1.0))
        .compile()?;

    assert!(shader.is_valid());

    TestResult::pass()
}

/// Test shader compilation pipeline
fn test_shader_compilation_pipeline() -> TestResult {
    use photon::{ShaderCompiler, ShaderStage, ShaderFormat};

    let vertex_source = r#"
        #version 450
        layout(location = 0) in vec3 a_position;
        layout(location = 1) in vec2 a_texcoord;
        layout(location = 0) out vec2 v_texcoord;

        void main() {
            gl_Position = vec4(a_position, 1.0);
            v_texcoord = a_texcoord;
        }
    "#;

    let fragment_source = r#"
        #version 450
        layout(location = 0) in vec2 v_texcoord;
        layout(location = 0) out vec4 fragColor;
        layout(binding = 0) uniform sampler2D u_texture;

        void main() {
            fragColor = texture(u_texture, v_texcoord);
        }
    "#;

    // Compile shaders
    let compiler = ShaderCompiler::new();

    let vertex_spirv = compiler.compile(
        vertex_source,
        ShaderStage::Vertex,
        ShaderFormat::SPIRV
    )?;

    let fragment_spirv = compiler.compile(
        fragment_source,
        ShaderStage::Fragment,
        ShaderFormat::SPIRV
    )?;

    // Verify SPIR-V is valid
    assert!(vertex_spirv.len() > 0);
    assert!(fragment_spirv.len() > 0);

    // Validate SPIR-V
    assert!(compiler.validate(&vertex_spirv)?);
    assert!(compiler.validate(&fragment_spirv)?);

    // Reflect shader to get uniforms and inputs
    let reflection = compiler.reflect(&fragment_spirv)?;
    assert!(reflection.uniforms.contains_key("u_texture"));

    TestResult::pass()
}

/// Test color processing pipeline
fn test_color_processing_pipeline() -> TestResult {
    use spectrum::{ColorGrader, LUT3D, WhiteBalance};
    use chromatic::{CAM16, ColorAppearance};

    // Create HDR image data (simplified as array of colors)
    let mut pixels: Vec<Color> = (0..100).map(|i| {
        Color::from_rgb(
            (i as f64 / 100.0) * 2.0,  // HDR range
            (50.0 - (i as f64 - 50.0).abs()) / 50.0 * 1.5,
            ((100 - i) as f64 / 100.0) * 1.8
        )
    }).collect();

    // Apply white balance
    let wb = WhiteBalance::new(6500.0); // Daylight
    for pixel in &mut pixels {
        *pixel = wb.apply(pixel);
    }

    // Apply color grading
    let grader = ColorGrader::new()
        .lift(Color::from_rgb(0.02, 0.0, 0.04))
        .gamma(Color::from_rgb(1.0, 0.98, 1.02))
        .gain(Color::from_rgb(1.0, 1.0, 0.95))
        .saturation(1.1);

    for pixel in &mut pixels {
        *pixel = grader.apply(pixel);
    }

    // Compute color appearance
    let viewing_conditions = ViewingConditions::default();
    for pixel in &pixels {
        let appearance = CAM16::from_xyz(pixel.to_xyz(), &viewing_conditions);
        assert!(appearance.lightness >= 0.0);
        assert!(appearance.chroma >= 0.0);
    }

    TestResult::pass()
}

