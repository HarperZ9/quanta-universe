/// Test collections and I/O work together
fn test_collections_io_integration() -> TestResult {
    // Create a complex data structure
    let mut data = HashMap::new();
    data.insert("users", vec![
        User { id: 1, name: "Alice".to_string(), score: 95.5 },
        User { id: 2, name: "Bob".to_string(), score: 87.3 },
        User { id: 3, name: "Charlie".to_string(), score: 92.1 },
    ]);

    // Serialize to JSON
    let json = serialization::to_json(&data)?;

    // Write to temp file
    let path = temp_dir().join("test_data.json");
    fs::write(&path, &json)?;

    // Read back
    let read_json = fs::read_to_string(&path)?;

    // Deserialize
    let restored: HashMap<String, Vec<User>> = serialization::from_json(&read_json)?;

    // Verify
    assert_eq!(restored.get("users").unwrap().len(), 3);
    assert_eq!(restored.get("users").unwrap()[0].name, "Alice");

    // Cleanup
    fs::remove_file(&path)?;

    TestResult::pass()
}

/// Test crypto and serialization integration
fn test_crypto_serialization_integration() -> TestResult {
    // Create sensitive data
    let credentials = Credentials {
        api_key: "sk_live_abc123".to_string(),
        secret: "supersecret".to_string(),
    };

    // Serialize
    let serialized = serialization::to_msgpack(&credentials)?;

    // Encrypt
    let key = crypto::generate_key(crypto::Algorithm::AES256);
    let encrypted = crypto::encrypt(&serialized, &key, crypto::Algorithm::AES256)?;

    // Decrypt
    let decrypted = crypto::decrypt(&encrypted, &key, crypto::Algorithm::AES256)?;

    // Deserialize
    let restored: Credentials = serialization::from_msgpack(&decrypted)?;

    assert_eq!(restored.api_key, credentials.api_key);
    assert_eq!(restored.secret, credentials.secret);

    TestResult::pass()
}

/// Test network and async integration
fn test_network_async_integration() -> TestResult {
    use foundation::net::{TcpListener, TcpStream};
    use foundation::sync::{spawn, channel};

    let (tx, rx) = channel::<String>();

    // Spawn server
    let server_handle = spawn(async {
        let listener = TcpListener::bind("127.0.0.1:0").await?;
        let port = listener.local_addr()?.port();
        tx.send(format!("{}", port))?;

        let (stream, _) = listener.accept().await?;
        let mut buf = [0u8; 1024];
        let n = stream.read(&mut buf).await?;
        let msg = String::from_utf8_lossy(&buf[..n]);

        assert_eq!(msg, "Hello, Server!");
        stream.write_all(b"Hello, Client!").await?;

        Ok::<(), Error>(())
    });

    // Get port from server
    let port: u16 = rx.recv()?.parse()?;

    // Connect client
    let client_handle = spawn(async move {
        let mut stream = TcpStream::connect(format!("127.0.0.1:{}", port)).await?;
        stream.write_all(b"Hello, Server!").await?;

        let mut buf = [0u8; 1024];
        let n = stream.read(&mut buf).await?;
        let msg = String::from_utf8_lossy(&buf[..n]);

        assert_eq!(msg, "Hello, Client!");

        Ok::<(), Error>(())
    });

    // Wait for both
    server_handle.join()?;
    client_handle.join()?;

    TestResult::pass()
}

/// Test error and logging integration
fn test_error_logging_integration() -> TestResult {
    use foundation::error::{Error, ErrorKind, Context};
    use foundation::logging::{Logger, Level};

    // Setup logger
    let logger = Logger::new()
        .with_level(Level::Debug)
        .with_format("{level} [{target}] {message}")
        .build();

    // Create error chain
    let inner_error = Error::io(IoErrorKind::NotFound, "config.toml not found");
    let outer_error = Error::new(ErrorKind::ConfigError, "Failed to load configuration")
        .caused_by(inner_error)
        .with_context("path", "/etc/app/config.toml");

    // Log the error
    logger.error(&format!("{}", outer_error));

    // Verify error chain
    let mut chain_length = 0;
    for _ in outer_error.chain() {
        chain_length += 1;
    }
    assert_eq!(chain_length, 2);

    TestResult::pass()
}

