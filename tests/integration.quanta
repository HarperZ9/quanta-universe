/// Test axiom and oracle integration
fn test_axiom_oracle_integration() -> TestResult {
    use axiom::{NeuralNetwork, Dense, Activation, Adam};
    use oracle::{AnomalyDetector, IsolationForest};

    // Create neural network for feature extraction
    let mut nn = NeuralNetwork::new()
        .add(Dense::new(10, 64))
        .add(Activation::ReLU)
        .add(Dense::new(64, 32))
        .add(Activation::ReLU)
        .add(Dense::new(32, 8))
        .build();

    // Generate sample data
    let data: Vec<Vec<f64>> = (0..100).map(|i| {
        (0..10).map(|j| (i * j) as f64 * 0.01 + ((i + j) as f64).sin()).collect()
    }).collect();

    // Extract features using neural network
    let features: Vec<Vec<f64>> = data.iter().map(|x| {
        nn.forward(x)
    }).collect();

    // Use oracle for anomaly detection on features
    let mut detector = IsolationForest::new(100, 256);
    detector.fit(&features)?;

    // Score each sample
    let scores: Vec<f64> = features.iter().map(|f| detector.score(f)).collect();

    // Verify scores are in valid range
    for score in &scores {
        assert!(*score >= 0.0 && *score <= 1.0);
    }

    // Find anomalies
    let threshold = 0.7;
    let anomalies: Vec<usize> = scores.iter()
        .enumerate()
        .filter(|(_, &s)| s > threshold)
        .map(|(i, _)| i)
        .collect();

    // Should have some anomalies
    assert!(anomalies.len() < scores.len());

    TestResult::pass()
}

/// Test neural prediction pipeline
fn test_neural_prediction_pipeline() -> TestResult {
    use axiom::{LSTM, Transformer, Attention};

    // Create LSTM for sequence prediction
    let mut lstm = LSTM::new(10, 64, 2);

    // Generate sequence data
    let sequences: Vec<Vec<Vec<f64>>> = (0..50).map(|i| {
        (0..20).map(|t| {
            (0..10).map(|f| ((i + t + f) as f64).sin()).collect()
        }).collect()
    }).collect();

    let targets: Vec<f64> = (0..50).map(|i| (i as f64 * 0.1).sin()).collect();

    // Train LSTM
    lstm.train(&sequences, &targets, 10, 0.001)?;

    // Predict
    let test_seq: Vec<Vec<f64>> = (0..20).map(|t| {
        (0..10).map(|f| ((50 + t + f) as f64).sin()).collect()
    }).collect();

    let prediction = lstm.predict(&test_seq)?;
    assert!(prediction.is_finite());

    TestResult::pass()
}

/// Test model persistence
fn test_model_persistence() -> TestResult {
    use axiom::{NeuralNetwork, Dense, Activation, ModelIO};

    // Create and train a model
    let mut model = NeuralNetwork::new()
        .add(Dense::new(5, 10))
        .add(Activation::ReLU)
        .add(Dense::new(10, 3))
        .add(Activation::Softmax)
        .build();

    // Generate training data
    let x: Vec<Vec<f64>> = (0..100).map(|i| {
        (0..5).map(|j| (i * j) as f64 * 0.01).collect()
    }).collect();
    let y: Vec<usize> = (0..100).map(|i| i % 3).collect();

    model.train_classification(&x, &y, 10)?;

    // Save model
    let path = temp_dir().join("test_model.qnn");
    ModelIO::save(&model, &path)?;

    // Load model
    let loaded_model: NeuralNetwork = ModelIO::load(&path)?;

    // Verify predictions match
    for sample in &x[..10] {
        let orig_pred = model.predict(sample);
        let loaded_pred = loaded_model.predict(sample);

        for i in 0..3 {
            assert_approx(orig_pred[i], loaded_pred[i], 1e-10);
        }
    }

    // Cleanup
    fs::remove_file(&path)?;

    TestResult::pass()
}

