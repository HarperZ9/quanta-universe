/// Integration test configuration
pub struct IntegrationTestConfig {
    pub verbose: bool,
    pub timeout: Duration,
    pub temp_dir: PathBuf,
    pub parallel: bool,
    pub fail_fast: bool,
}

impl IntegrationTestConfig {
    pub fn default() -> Self {
        IntegrationTestConfig {
            verbose: false,
            timeout: Duration::from_secs(300),
            temp_dir: temp_dir().join("quanta_integration_tests"),
            parallel: true,
            fail_fast: false,
        }
    }
}

/// Run all integration tests
pub fn run_all_integration_tests(config: &IntegrationTestConfig) -> TestSuite {
    let mut suite = TestSuite::new("QUANTA-UNIVERSE Integration Tests");

    // Foundation Layer Tests
    suite.add_group("Foundation", vec![
        ("collections_io_integration", test_collections_io_integration),
        ("crypto_serialization_integration", test_crypto_serialization_integration),
        ("network_async_integration", test_network_async_integration),
        ("error_logging_integration", test_error_logging_integration),
    ]);

    // Trading Layer Tests
    suite.add_group("Trading", vec![
        ("tensor_finance_integration", test_tensor_finance_integration),
        ("oracle_trading_integration", test_oracle_trading_integration),
        ("portfolio_optimization_e2e", test_portfolio_optimization_e2e),
        ("backtest_pipeline", test_backtest_pipeline),
    ]);

    // AI Layer Tests
    suite.add_group("AI", vec![
        ("axiom_oracle_integration", test_axiom_oracle_integration),
        ("neural_prediction_pipeline", test_neural_prediction_pipeline),
        ("model_persistence", test_model_persistence),
    ]);

    // Rendering Layer Tests
    suite.add_group("Rendering", vec![
        ("photon_spectrum_integration", test_photon_spectrum_integration),
        ("shader_compilation_pipeline", test_shader_compilation_pipeline),
        ("color_processing_pipeline", test_color_processing_pipeline),
    ]);

    // Tools Layer Tests
    suite.add_group("Tools", vec![
        ("forge_project_lifecycle", test_forge_project_lifecycle),
        ("lsp_completion_integration", test_lsp_completion_integration),
        ("fmt_parse_roundtrip", test_fmt_parse_roundtrip),
    ]);

    // Cross-Layer Tests
    suite.add_group("Cross-Layer", vec![
        ("full_trading_system", test_full_trading_system),
        ("ai_enhanced_trading", test_ai_enhanced_trading),
        ("full_render_pipeline", test_full_render_pipeline),
    ]);

    suite
}

