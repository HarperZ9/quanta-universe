// PROTOBUF FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Fuzz Protobuf varint decoding
#[test]
fn fuzz_protobuf_varint() -> TestResult {
    let mut rng = Rng::new(303);
    let iterations = 1000;

    for _ in 0..iterations {
        // Generate random varint bytes (up to 10 bytes)
        let len = rng.range(1, 11);
        let mut bytes: Vec<u8> = (0..len-1).map(|_| rng.next_u8() | 0x80).collect();
        bytes.push(rng.next_u8() & 0x7F); // Last byte without continuation

        // Should not panic
        let _ = std::panic::catch_unwind(|| {
            let mut decoder = serialization::protobuf::Decoder::new(&bytes);
            let _ = decoder.read_varint();
        });
    }

    // Malformed varints (all continuation bits set)
    let malformed = vec![0x80u8; 20];
    let result = std::panic::catch_unwind(|| {
        let mut decoder = serialization::protobuf::Decoder::new(&malformed);
        let _ = decoder.read_varint();
    });
    assert!(result.is_ok(), "Varint decoder panicked on overflow");

    TestResult::pass()
}

/// Fuzz Protobuf with random wire types
#[test]
fn fuzz_protobuf_wire_types() -> TestResult {
    let mut rng = Rng::new(404);

    for _ in 0..100 {
        // Build random protobuf-like bytes
        let mut bytes = Vec::new();

        for _ in 0..rng.range(1, 10) {
            // Random field tag with random wire type
            let field_num = rng.range(1, 100);
            let wire_type = rng.range(0, 8);
            let tag = (field_num << 3) | wire_type;

            // Encode tag as varint
            let mut t = tag;
            while t >= 0x80 {
                bytes.push((t & 0x7F) as u8 | 0x80);
                t >>= 7;
            }
            bytes.push(t as u8);

            // Add random payload
            let payload_len = rng.range(0, 20);
            bytes.extend(rng.next_bytes(payload_len));
        }

        // Should not panic
        let _ = std::panic::catch_unwind(|| {
            let _ = serialization::protobuf::decode_raw(&bytes);
        });
    }

    TestResult::pass()
}

// ═══════════════════════════════════════════════════════════════════════════════
// CRYPTO FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Fuzz encryption with random keys and data
#[test]
fn fuzz_crypto_aes() -> TestResult {
    let mut rng = Rng::new(505);

    for _ in 0..100 {
        // Random key (32 bytes for AES-256)
        let key = crypto::Key::from_bytes(&rng.next_bytes(32));

        // Random plaintext
        let len = rng.range(0, 1000);
        let plaintext = rng.next_bytes(len);

        // Encrypt
        let ciphertext = crypto::encrypt(&plaintext, &key, crypto::Algorithm::AES256)?;

        // Decrypt
        let decrypted = crypto::decrypt(&ciphertext, &key, crypto::Algorithm::AES256)?;

        assert_eq!(plaintext, decrypted);
    }

    TestResult::pass()
}

/// Fuzz decryption with invalid ciphertext
#[test]
fn fuzz_crypto_invalid_ciphertext() -> TestResult {
    let mut rng = Rng::new(606);
    let key = crypto::generate_key(crypto::Algorithm::AES256);

    for _ in 0..100 {
        // Random bytes (not valid ciphertext)
        let len = rng.range(0, 100);
        let garbage = rng.next_bytes(len);

        // Should return error, not panic
        let result = crypto::decrypt(&garbage, &key, crypto::Algorithm::AES256);
        assert!(result.is_err());
    }

    // Tampered ciphertext
    let plaintext = b"test message";
    let ciphertext = crypto::encrypt(plaintext, &key, crypto::Algorithm::AES256)?;

    for _ in 0..100 {
        let mut tampered = ciphertext.clone();
        let idx = rng.range(0, tampered.len());
        tampered[idx] ^= rng.next_u8();

        // Should fail authentication
        let result = crypto::decrypt(&tampered, &key, crypto::Algorithm::AES256);
        // May succeed if tampering happened in padding area, but shouldn't panic
    }

    TestResult::pass()
}

/// Fuzz hashing with random data
#[test]
fn fuzz_crypto_hash() -> TestResult {
    let mut rng = Rng::new(707);

    for _ in 0..100 {
        let len = rng.range(0, 10000);
        let data = rng.next_bytes(len);

        // Compute hashes - should never panic
        let sha256 = crypto::hash(&data, crypto::HashAlgorithm::SHA256);
        let sha512 = crypto::hash(&data, crypto::HashAlgorithm::SHA512);
        let blake3 = crypto::hash(&data, crypto::HashAlgorithm::Blake3);

        // Verify hash lengths
        assert_eq!(sha256.len(), 32);
        assert_eq!(sha512.len(), 64);
        assert_eq!(blake3.len(), 32);

        // Same input should produce same output
        let sha256_2 = crypto::hash(&data, crypto::HashAlgorithm::SHA256);
        assert_eq!(sha256, sha256_2);
    }

    TestResult::pass()
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLLECTIONS FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Fuzz HashMap operations
#[test]
fn fuzz_hashmap_operations() -> TestResult {
    let mut rng = Rng::new(808);
    let mut map = HashMap::new();

    for _ in 0..10000 {
        let op = rng.range(0, 4);
        let key = format!("key_{}", rng.range(0, 100));

        match op {
            0 => { map.insert(key, rng.next_u64()); }
            1 => { map.remove(&key); }
            2 => { let _ = map.get(&key); }
            _ => { let _ = map.contains_key(&key); }
        }
    }

    // Verify invariants
    for (k, v) in &map {
        assert!(k.starts_with("key_"));
        assert!(map.get(k) == Some(v));
    }

    TestResult::pass()
}

/// Fuzz Vec operations
#[test]
fn fuzz_vec_operations() -> TestResult {
    let mut rng = Rng::new(909);
    let mut vec: Vec<i64> = Vec::new();

    for _ in 0..10000 {
        let op = rng.range(0, 5);

        match op {
            0 => { vec.push(rng.next_u64() as i64); }
            1 => { vec.pop(); }
            2 if !vec.is_empty() => {
                let idx = rng.range(0, vec.len());
                let _ = vec.get(idx);
            }
            3 if !vec.is_empty() => {
                let idx = rng.range(0, vec.len());
                vec.remove(idx);
            }
            4 if !vec.is_empty() => {
                let idx = rng.range(0, vec.len());
                vec.insert(idx, rng.next_u64() as i64);
            }
            _ => {}
        }
    }

    TestResult::pass()
}

