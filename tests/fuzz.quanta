// ═══════════════════════════════════════════════════════════════════════════════
// RANDOM DATA GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Simple PRNG for reproducible fuzzing
struct Rng {
    state: u64,
}

impl Rng {
    pub fn new(seed: u64) -> Self {
        Rng { state: seed }
    }

    pub fn next_u64(&mut self) -> u64 {
        // xorshift64
        self.state ^= self.state << 13;
        self.state ^= self.state >> 7;
        self.state ^= self.state << 17;
        self.state
    }

    pub fn next_u32(&mut self) -> u32 {
        (self.next_u64() >> 32) as u32
    }

    pub fn next_u8(&mut self) -> u8 {
        (self.next_u64() & 0xFF) as u8
    }

    pub fn next_bool(&mut self) -> bool {
        self.next_u64() & 1 == 1
    }

    pub fn next_f64(&mut self) -> f64 {
        self.next_u64() as f64 / u64::MAX as f64
    }

    pub fn next_bytes(&mut self, len: usize) -> Vec<u8> {
        (0..len).map(|_| self.next_u8()).collect()
    }

    pub fn choice<T: Clone>(&mut self, items: &[T]) -> T {
        let idx = (self.next_u64() as usize) % items.len();
        items[idx].clone()
    }

    pub fn range(&mut self, min: usize, max: usize) -> usize {
        min + (self.next_u64() as usize) % (max - min)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// JSON FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Generate random JSON-like values
fn generate_random_json(rng: &mut Rng, depth: usize) -> String {
    if depth > 5 {
        // Terminate recursion with primitive
        return match rng.range(0, 4) {
            0 => format!("{}", rng.next_u64() as i64),
            1 => format!("{:.6}", rng.next_f64()),
            2 => if rng.next_bool() { "true".to_string() } else { "false".to_string() },
            _ => "null".to_string(),
        };
    }

    match rng.range(0, 7) {
        0 => format!("{}", rng.next_u64() as i64),
        1 => format!("{:.10}", rng.next_f64() * 1e10 - 5e9),
        2 => if rng.next_bool() { "true".to_string() } else { "false".to_string() },
        3 => "null".to_string(),
        4 => {
            // Random string
            let len = rng.range(0, 50);
            let chars: String = (0..len).map(|_| {
                let c = rng.range(32, 127) as u8 as char;
                if c == '"' || c == '\\' { ' ' } else { c }
            }).collect();
            format!("\"{}\"", chars)
        }
        5 => {
            // Array
            let len = rng.range(0, 5);
            let items: Vec<String> = (0..len)
                .map(|_| generate_random_json(rng, depth + 1))
                .collect();
            format!("[{}]", items.join(","))
        }
        _ => {
            // Object
            let len = rng.range(0, 5);
            let items: Vec<String> = (0..len).map(|i| {
                format!("\"key_{}\":{}", i, generate_random_json(rng, depth + 1))
            }).collect();
            format!("{{{}}}", items.join(","))
        }
    }
}

/// Fuzz JSON parser with valid inputs
#[test]
fn fuzz_json_valid() -> TestResult {
    let mut rng = Rng::new(42);
    let iterations = 1000;
    let mut parse_failures = 0;

    for _ in 0..iterations {
        let json = generate_random_json(&mut rng, 0);

        match serialization::json::parse(&json) {
            Ok(_) => {}
            Err(e) => {
                // This shouldn't happen for valid JSON we generated
                parse_failures += 1;
                if parse_failures < 5 {
                    println!("Parse failure: {} -> {}", json, e);
                }
            }
        }
    }

    // Allow small number of edge case failures
    assert!(parse_failures < iterations / 20);

    TestResult::pass()
}

/// Fuzz JSON parser with malformed inputs
#[test]
fn fuzz_json_malformed() -> TestResult {
    let mut rng = Rng::new(123);
    let iterations = 1000;
    let mut panics = 0;

    let malformed_samples = vec![
        // Truncated
        "{\"key\":",
        "[1, 2,",
        "\"incomplete string",
        // Invalid characters
        "{key: value}",
        "{'key': 'value'}",
        // Numeric edge cases
        "1e999999",
        "-1e-999999",
        "0.0.0",
        "1.2.3",
        // Structure errors
        "[[]]]",
        "{{{",
        "}}",
        "[,]",
        "{:}",
        // Unicode edge cases
        "\"\u{0000}\"",
        "\"\u{FFFF}\"",
        // Random bytes
        "",
    ];

    for sample in &malformed_samples {
        // Should not panic
        let _ = std::panic::catch_unwind(|| {
            let _ = serialization::json::parse(sample);
        });
    }

    // Random malformed inputs
    for _ in 0..iterations {
        let len = rng.range(0, 100);
        let bytes = rng.next_bytes(len);
        let input = String::from_utf8_lossy(&bytes).to_string();

        match std::panic::catch_unwind(|| {
            let _ = serialization::json::parse(&input);
        }) {
            Ok(_) => {}
            Err(_) => panics += 1,
        }
    }

    assert_eq!(panics, 0, "Parser panicked on malformed input");

    TestResult::pass()
}

/// Fuzz JSON roundtrip
#[test]
fn fuzz_json_roundtrip() -> TestResult {
    let mut rng = Rng::new(456);

    // Generate random structured data
    for _ in 0..100 {
        let data = generate_fuzz_data(&mut rng);

        let json = serialization::json::to_string(&data).unwrap();
        let restored: FuzzData = serialization::json::from_str(&json).unwrap();

        assert_eq!(data.number, restored.number);
        assert_eq!(data.text, restored.text);
        assert_eq!(data.flag, restored.flag);
        assert_eq!(data.items, restored.items);
    }

    TestResult::pass()
}

// ═══════════════════════════════════════════════════════════════════════════════
// MESSAGEPACK FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Fuzz MessagePack with random byte sequences
#[test]
fn fuzz_msgpack_random_bytes() -> TestResult {
    let mut rng = Rng::new(789);
    let iterations = 1000;
    let mut panics = 0;

    for _ in 0..iterations {
        let len = rng.range(0, 200);
        let bytes = rng.next_bytes(len);

        match std::panic::catch_unwind(|| {
            // Try to decode as various types
            let _ = serialization::msgpack::from_slice::<i64>(&bytes);
            let _ = serialization::msgpack::from_slice::<String>(&bytes);
            let _ = serialization::msgpack::from_slice::<Vec<u8>>(&bytes);
            let _ = serialization::msgpack::from_slice::<HashMap<String, i32>>(&bytes);
        }) {
            Ok(_) => {}
            Err(_) => panics += 1,
        }
    }

    assert_eq!(panics, 0, "MessagePack decoder panicked on random bytes");

    TestResult::pass()
}

/// Fuzz MessagePack format markers
#[test]
fn fuzz_msgpack_format_markers() -> TestResult {
    // All possible format marker bytes
    for marker in 0u8..=255u8 {
        let input = vec![marker];

        // Should not panic
        let _ = std::panic::catch_unwind(|| {
            let _ = serialization::msgpack::from_slice::<i64>(&input);
        });
    }

    // Format marker followed by random data
    let mut rng = Rng::new(101);
    for marker in 0u8..=255u8 {
        let mut input = vec![marker];
        input.extend(rng.next_bytes(20));

        let _ = std::panic::catch_unwind(|| {
            let _ = serialization::msgpack::from_slice::<Vec<u8>>(&input);
        });
    }

    TestResult::pass()
}

/// Fuzz MessagePack roundtrip
#[test]
fn fuzz_msgpack_roundtrip() -> TestResult {
    let mut rng = Rng::new(202);

    for _ in 0..100 {
        let data = generate_fuzz_data(&mut rng);

        let bytes = serialization::msgpack::to_vec(&data).unwrap();
        let restored: FuzzData = serialization::msgpack::from_slice(&bytes).unwrap();

        assert_eq!(data.number, restored.number);
        assert_eq!(data.text, restored.text);
        assert_eq!(data.flag, restored.flag);
        assert_eq!(data.items, restored.items);
    }

    TestResult::pass()
}

