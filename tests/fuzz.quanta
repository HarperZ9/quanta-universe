// STRING FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Fuzz string parsing operations
#[test]
fn fuzz_string_parsing() -> TestResult {
    let mut rng = Rng::new(111);

    for _ in 0..1000 {
        let len = rng.range(0, 100);
        let bytes = rng.next_bytes(len);

        // UTF-8 validation - should not panic
        let _ = String::from_utf8(bytes.clone());
        let _ = String::from_utf8_lossy(&bytes);

        // Generate valid-ish strings
        let s = String::from_utf8_lossy(&bytes).to_string();

        // Various parsing operations - should not panic
        let _ = s.parse::<i64>();
        let _ = s.parse::<f64>();
        let _ = s.parse::<bool>();
        let _ = s.split(',').collect::<Vec<_>>();
        let _ = s.trim();
        let _ = s.to_uppercase();
        let _ = s.to_lowercase();
    }

    TestResult::pass()
}

/// Fuzz regex-like patterns (simplified pattern matching)
#[test]
fn fuzz_pattern_matching() -> TestResult {
    let mut rng = Rng::new(222);

    let patterns = vec!["*", "?", ".*", ".+", "[a-z]", "[0-9]+", "\\d+", "\\w+"];

    for _ in 0..100 {
        let len = rng.range(0, 50);
        let input: String = (0..len).map(|_| {
            (rng.range(32, 127) as u8) as char
        }).collect();

        for pattern in &patterns {
            // Simplified glob matching - should not panic
            let _ = glob_match(pattern, &input);
        }
    }

    TestResult::pass()
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPER TYPES AND FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, PartialEq, Serialize, Deserialize)]
struct FuzzData {
    number: i64,
    text: String,
    flag: bool,
    items: Vec<i32>,
}

fn generate_fuzz_data(rng: &mut Rng) -> FuzzData {
    let text_len = rng.range(0, 50);
    let text: String = (0..text_len).map(|_| {
        let c = rng.range(65, 91) as u8 as char;
        c
    }).collect();

    let items_len = rng.range(0, 20);
    let items: Vec<i32> = (0..items_len).map(|_| rng.next_u32() as i32).collect();

    FuzzData {
        number: rng.next_u64() as i64,
        text,
        flag: rng.next_bool(),
        items,
    }
}

fn glob_match(pattern: &str, input: &str) -> bool {
    // Simplified glob matching
    if pattern == "*" {
        return true;
    }
    if pattern == input {
        return true;
    }
    if pattern.contains('*') {
        let parts: Vec<&str> = pattern.split('*').collect();
        if parts.len() == 2 {
            return input.starts_with(parts[0]) && input.ends_with(parts[1]);
        }
    }
    false
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST RUNNER
// ═══════════════════════════════════════════════════════════════════════════════

/// Run all fuzz tests
pub fn run_all_fuzz_tests() -> TestSuite {
    let mut suite = TestSuite::new("QUANTA-UNIVERSE Fuzz Tests");

    suite.add_group("JSON Fuzzing", vec![
        ("json_valid", fuzz_json_valid),
        ("json_malformed", fuzz_json_malformed),
        ("json_roundtrip", fuzz_json_roundtrip),
    ]);

    suite.add_group("MessagePack Fuzzing", vec![
        ("msgpack_random_bytes", fuzz_msgpack_random_bytes),
        ("msgpack_format_markers", fuzz_msgpack_format_markers),
        ("msgpack_roundtrip", fuzz_msgpack_roundtrip),
    ]);

    suite.add_group("Protobuf Fuzzing", vec![
        ("protobuf_varint", fuzz_protobuf_varint),
        ("protobuf_wire_types", fuzz_protobuf_wire_types),
    ]);

    suite.add_group("Crypto Fuzzing", vec![
        ("crypto_aes", fuzz_crypto_aes),
        ("crypto_invalid_ciphertext", fuzz_crypto_invalid_ciphertext),
        ("crypto_hash", fuzz_crypto_hash),
    ]);

    suite.add_group("Collections Fuzzing", vec![
        ("hashmap_operations", fuzz_hashmap_operations),
        ("vec_operations", fuzz_vec_operations),
    ]);

    suite.add_group("String Fuzzing", vec![
        ("string_parsing", fuzz_string_parsing),
        ("pattern_matching", fuzz_pattern_matching),
    ]);

    suite
}

/// Main entry point
pub fn main() -> i32 {
    let suite = run_all_fuzz_tests();
    let results = suite.run();

    println!("\n{}", "═".repeat(70));
    println!("QUANTA-UNIVERSE Fuzz Test Results");
    println!("{}", "═".repeat(70));
    println!("Total:   {}", results.total);
    println!("Passed:  {}", results.passed);
    println!("Failed:  {}", results.failed);
    println!("{}", "═".repeat(70));

    if results.failed > 0 {
        println!("\nFailed tests:");
        for failure in &results.failures {
            println!("  - {}: {}", failure.name, failure.message);
        }
        1
    } else {
        println!("\nAll fuzz tests passed!");
        0
    }
}
