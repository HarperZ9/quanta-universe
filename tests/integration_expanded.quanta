/// Oracle predictions drive Quantum-Finance trading signals
fn test_oracle_to_finance_forecast_signals() {
    // Create a synthetic time series with upward trend
    let n: usize = 60;
    let mut prices: Vec<f64> = Vec::new();
    for i in 0..n {
        let t = i as f64;
        let trend = 100.0 + 0.5 * t;
        let cycle = 3.0 * sin(2.0 * PI * t / 20.0);
        prices.push(trend + cycle);
    }

    // Oracle: compute moving averages (exponential smoothing)
    let alpha: f64 = 0.3;
    let mut ema: Vec<f64> = Vec::new();
    ema.push(prices[0]);
    for i in 1..n {
        let prev = ema[i - 1];
        ema.push(alpha * prices[i] + (1.0 - alpha) * prev);
    }

    // Oracle: simple forecast = extrapolate EMA trend
    let ema_slope = (ema[n - 1] - ema[n - 5]) / 4.0;
    let forecast_1 = ema[n - 1] + ema_slope;
    let forecast_5 = ema[n - 1] + 5.0 * ema_slope;

    // Quantum-Finance: generate trading signal from oracle forecast
    let current_price = prices[n - 1];
    let pct_change_1 = (forecast_1 - current_price) / current_price;
    let pct_change_5 = (forecast_5 - current_price) / current_price;

    // Determine signal strength: higher expected return = stronger signal
    let signal_strength = clamp(pct_change_5 * 10.0, -1.0, 1.0) as f64;

    // Since our series has an upward trend, signal should be positive
    assert_true(signal_strength > 0.0, "Uptrend series should produce buy signal");
    assert_in_range(signal_strength, -1.0, 1.0);

    // Verify the forecast is reasonable
    assert_true(abs(pct_change_1) < 0.1,
        "1-step forecast should not deviate more than 10%");

    println("  oracle -> quantum-finance forecast signals: OK");
}

/// Oracle anomaly detection feeds Quantum-Finance risk management
fn test_oracle_to_finance_anomaly_risk() {
    // Create a time series with a volatility spike (anomaly)
    let n: usize = 80;
    let mut returns: Vec<f64> = Vec::new();
    for i in 0..n {
        if i >= 30 && i <= 35 {
            // Anomalous period: 5x normal volatility
            returns.push(0.05 * sin((i as f64) * 3.0));
        } else {
            returns.push(0.01 * sin((i as f64) * 3.0));
        }
    }

    // Oracle: compute rolling standard deviation (window = 10)
    let window: usize = 10;
    let mut rolling_vol: Vec<f64> = Vec::new();
    for i in window..n {
        let window_slice = &returns[(i - window)..i];
        let mean: f64 = window_slice.iter().sum::<f64>() / (window as f64);
        let var: f64 = window_slice.iter()
            .map(|r| (r - mean) * (r - mean))
            .sum::<f64>() / (window as f64);
        rolling_vol.push(sqrt(var));
    }

    // Oracle: detect anomalies (vol > 2 * median vol)
    let mut sorted_vol = rolling_vol.clone();
    // Simple insertion sort for median (small n)
    for i in 1..sorted_vol.len() {
        let val = sorted_vol[i];
        let mut j = i;
        while j > 0 && sorted_vol[j - 1] > val {
            sorted_vol[j] = sorted_vol[j - 1];
            j = j - 1;
        }
        sorted_vol[j] = val;
    }
    let median_vol = sorted_vol[sorted_vol.len() / 2];
    let threshold = 2.0 * median_vol;

    let anomaly_count = rolling_vol.iter().filter(|v| **v > threshold).count();

    // Quantum-Finance: adjust position size based on anomaly signal
    let base_position = 100000.0;  // $100k position
    let max_vol = rolling_vol.iter().cloned().fold(0.0_f64, f64::max);
    let vol_ratio = median_vol / max_vol.max(0.0001);
    let adjusted_position = base_position * vol_ratio;

    // During high vol, position should be reduced
    assert_true(adjusted_position < base_position,
        "Position should be reduced during volatility anomaly");
    assert_true(adjusted_position > 0.0,
        "Position should remain positive");
    assert_true(anomaly_count > 0,
        "Should detect at least one anomalous period");

    println("  oracle -> quantum-finance anomaly risk: OK");
}

// =============================================================================
// 5. FOUNDATION -> FIELD-TENSOR
//    Math operations in tensor computations
// =============================================================================

/// Foundation math ops populate and transform market tensors
fn test_foundation_to_field_tensor_populate() {
    // Create a market tensor for 20 time steps, 3 assets, 4 features, 2 derivatives
    let tensor = MarketTensor4D::new(20, 3, 4, 2);

    // Use foundation math to compute features
    // Feature 0 = price, Feature 1 = log return, Feature 2 = volatility, Feature 3 = momentum
    let mut populated = tensor;
    for t in 0..20 {
        for a in 0..3 {
            // Price: sinusoidal with asset-specific phase
            let price = 100.0 + 10.0 * sin(2.0 * PI * (t as f64) / 20.0 + (a as f64) * PI / 3.0);
            populated.set(t, a, 0, 0, price);  // price value
            populated.set(t, a, 0, 1, cos(2.0 * PI * (t as f64) / 20.0 + (a as f64) * PI / 3.0));  // price derivative

            // Log return
            if t > 0 {
                let prev_price = populated.get(t - 1, a, 0, 0);
                if prev_price > 0.0 {
                    let log_ret = log(price / prev_price);
                    populated.set(t, a, 1, 0, log_ret);
                }
            }

            // Volatility: rolling absolute return
            let abs_ret = if t > 0 {
                abs(populated.get(t, a, 1, 0))
            } else {
                0.0
            };
            populated.set(t, a, 2, 0, abs_ret);

            // Momentum: cumulative return over 5 periods
            if t >= 5 {
                let p_now = populated.get(t, a, 0, 0);
                let p_5ago = populated.get(t - 5, a, 0, 0);
                if p_5ago > 0.0 {
                    populated.set(t, a, 3, 0, (p_now - p_5ago) / p_5ago);
                }
            }
        }
    }

    // Verify data integrity
    let mid_price = populated.get(10, 0, 0, 0);
    assert_true(mid_price > 0.0, "Price should be positive");

    // Extract time series for asset 0, price feature
    let price_series = populated.time_series(0, 0, 0);
    assert_true(price_series.len() == 20, "Time series should have 20 points");

    // Prices should oscillate around 100
    let price_mean: f64 = price_series.iter().sum::<f64>() / (price_series.len() as f64);
    assert_approx(price_mean, 100.0, 5.0);

    println("  foundation -> field-tensor populate: OK");
}

/// Foundation linear algebra operations on field-tensor cross-sections
fn test_foundation_to_field_tensor_covariance() {
    // Create tensor and populate with correlated asset returns
    let n_time: usize = 50;
    let n_assets: usize = 3;
    let tensor = MarketTensor4D::new(n_time, n_assets, 1, 1);
    let mut populated = tensor;

    // Asset 0: independent, Asset 1: correlated with 0, Asset 2: anti-correlated
    for t in 0..n_time {
        let base = sin((t as f64) * 0.5);
        populated.set(t, 0, 0, 0, base * 0.02);                // Asset 0
        populated.set(t, 1, 0, 0, base * 0.015 + 0.005 * cos((t as f64) * 1.1));  // Correlated
        populated.set(t, 2, 0, 0, -base * 0.01 + 0.003 * sin((t as f64) * 2.3));  // Anti-correlated
    }

    // Compute means
    let mut means: Vec<f64> = Vec::new();
    for a in 0..n_assets {
        let series = populated.time_series(a, 0, 0);
        let mean: f64 = series.iter().sum::<f64>() / (n_time as f64);
        means.push(mean);
    }

    // Compute covariance matrix using foundation math
    let mut cov = vec![vec![0.0; n_assets]; n_assets];
    for i in 0..n_assets {
        for j in 0..n_assets {
            let mut sum = 0.0;
            for t in 0..n_time {
                let ri = populated.get(t, i, 0, 0) - means[i];
                let rj = populated.get(t, j, 0, 0) - means[j];
                sum = sum + ri * rj;
            }
            cov[i][j] = sum / (n_time as f64);
        }
    }

    // Diagonal elements (variances) should be positive
    for i in 0..n_assets {
        assert_true(cov[i][i] > 0.0, "Variance should be positive");
    }

    // Asset 0 and 1 should be positively correlated
    assert_true(cov[0][1] > 0.0, "Asset 0-1 covariance should be positive");

    // Asset 0 and 2 should be negatively correlated
    assert_true(cov[0][2] < 0.0, "Asset 0-2 covariance should be negative");

    // Covariance matrix should be symmetric
    for i in 0..n_assets {
        for j in 0..n_assets {
            assert_approx(cov[i][j], cov[j][i], 1e-12);
        }
    }

    println("  foundation -> field-tensor covariance: OK");
}

// =============================================================================
// 6. PHOTON -> SPECTRUM
//    Rendering pipeline using color science
// =============================================================================

/// Photon's rendering pipeline consumes Spectrum color types and transforms
fn test_photon_to_spectrum_color_pipeline() {
    // Photon renders a scene with linear RGB values (pre-tonemapping)
    // These are high dynamic range pixel values from the rendering engine
    let scene_pixels: Vec<RGB> = vec![
        RGB::new(0.1, 0.2, 0.15),   // Dark shadow
        RGB::new(0.5, 0.5, 0.5),    // Mid-gray
        RGB::new(1.0, 0.8, 0.6),    // Skin tone
        RGB::new(2.5, 2.0, 1.8),    // Bright highlight (HDR)
        RGB::new(0.0, 0.0, 0.0),    // Pure black
        RGB::new(1.0, 1.0, 1.0),    // Pure white
    ];

    // Step 1: Convert from linear scene-referred to XYZ via Spectrum matrices
    let mut xyz_pixels: Vec<XYZ> = Vec::new();
    for pixel in &scene_pixels {
        let linear_vec = Vec3::new(pixel.r, pixel.g, pixel.b);
        let xyz_vec = SRGB_TO_XYZ.mul_vec3(&linear_vec);
        xyz_pixels.push(XYZ::new(xyz_vec.x, xyz_vec.y, xyz_vec.z));
    }

    // Step 2: Spectrum tonemapping (Reinhard on luminance)
    let mut display_pixels: Vec<RGB> = Vec::new();
    for (i, pixel) in scene_pixels.iter().enumerate() {
        let luminance = pixel.luminance();
        if luminance > 0.0 {
            let mapped_lum = luminance / (1.0 + luminance);
            let scale = mapped_lum / luminance;
            display_pixels.push(RGB::new(
                pixel.r * scale,
                pixel.g * scale,
                pixel.b * scale,
            ));
        } else {
            display_pixels.push(RGB::new(0.0, 0.0, 0.0));
        }
    }

    // Step 3: Apply sRGB gamma encode via Spectrum transfer functions
    let mut gamma_pixels: Vec<RGB> = Vec::new();
    for pixel in &display_pixels {
        gamma_pixels.push(RGB::new(
            srgb_oetf(clamp(pixel.r, 0.0, 1.0) as f32),
            srgb_oetf(clamp(pixel.g, 0.0, 1.0) as f32),
            srgb_oetf(clamp(pixel.b, 0.0, 1.0) as f32),
        ));
    }

    // Verify: all output pixels should be in [0, 1] (display-ready)
    for pixel in &gamma_pixels {
        assert_in_range(pixel.r as f64, 0.0, 1.0);
        assert_in_range(pixel.g as f64, 0.0, 1.0);
        assert_in_range(pixel.b as f64, 0.0, 1.0);
    }

    // Verify: pure black stays black
    assert_approx(gamma_pixels[4].r as f64, 0.0, 0.001);

    // Verify: HDR highlight (2.5, 2.0, 1.8) is compressed to < 1.0
    assert_true((gamma_pixels[3].r as f64) < 1.0,
        "HDR highlight should be compressed below 1.0");

    // Verify: luminance ordering is preserved after tonemapping
    let lum_shadow = gamma_pixels[0].luminance();
    let lum_mid = gamma_pixels[1].luminance();
    let lum_skin = gamma_pixels[2].luminance();
    assert_true(lum_shadow < lum_mid, "Shadow should be darker than mid-gray");
    assert_true(lum_mid < lum_skin, "Mid-gray should be darker than skin tone");

    println("  photon -> spectrum color pipeline: OK");
}

/// Photon uses Spectrum's OKLab for perceptual color manipulation
fn test_photon_to_spectrum_oklab() {
    // Photon wants to shift hue of rendered pixels perceptually
    // Use Spectrum's OKLab conversion matrices

    // Start with a known sRGB color (linear)
    let input = RGB::new(0.8, 0.2, 0.1);  // Reddish

    // Convert to OKLab via Spectrum's M1 and M2 matrices
    // Step 1: Linear sRGB -> intermediate (via M1)
    let linear_vec = Vec3::new(input.r, input.g, input.b);
    let lms = OKLAB_M1.mul_vec3(&linear_vec);

    // Step 2: Cube root (foundation math)
    let lms_g = Vec3::new(
        pow(abs(lms.x) as f64, 1.0 / 3.0) as f32,
        pow(abs(lms.y) as f64, 1.0 / 3.0) as f32,
        pow(abs(lms.z) as f64, 1.0 / 3.0) as f32,
    );

    // Step 3: M2 transform -> OKLab
    let oklab_vec = OKLAB_M2.mul_vec3(&lms_g);
    let oklab = OKLab::new(oklab_vec.x, oklab_vec.y, oklab_vec.z);

    // Verify OKLab lightness is in [0, 1]
    assert_in_range(oklab.l as f64, 0.0, 1.0);

    // Red color should have positive a (red-green axis)
    assert_true(oklab.a > 0.0, "Red color should have positive OKLab 'a'");

    // Compute chroma using Spectrum's OKLab method
    let chroma = oklab.chroma();
    assert_true(chroma > 0.0, "Saturated color should have positive chroma");

    // Compute hue angle using foundation atan2
    let hue = atan2(oklab.b as f64, oklab.a as f64);
    assert_in_range(hue, -PI, PI);

    println("  photon -> spectrum OKLab: OK");
}

// =============================================================================
// 7. ORACLE -> FIELD-TENSOR
//    Predictions informing tensor analysis
// =============================================================================

/// Oracle's tensor operations produce forecasts stored in field-tensor format
fn test_oracle_to_field_tensor_forecast_embedding() {
    // Oracle produces forecast vectors using its Tensor type
    let n_assets: usize = 3;
    let horizon: usize = 5;

    // Generate Oracle-style forecast tensors (one per asset)
    let mut forecasts: Vec<Tensor> = Vec::new();
    for a in 0..n_assets {
        let mut data: Vec<f64> = Vec::new();
        for h in 0..horizon {
            // Forecast: base + trend + mean-reverting component
            let base = 100.0 + (a as f64) * 50.0;
            let trend = 0.1 * (h as f64);
            let mean_rev = -0.05 * (a as f64) * exp(-0.5 * (h as f64));
            data.push(base + trend + mean_rev);
        }
        forecasts.push(Tensor::from_vec(data, vec![horizon]));
    }

    // Embed Oracle forecasts into a Field-Tensor MarketTensor4D
    // Shape: [horizon, n_assets, 1 feature (forecast), 1 derivative (value)]
    let mut market_tensor = MarketTensor4D::new(horizon, n_assets, 1, 1);
    for a in 0..n_assets {
        for h in 0..horizon {
            let forecast_val = forecasts[a].data[h];
            market_tensor.set(h, a, 0, 0, forecast_val);
        }
    }

    // Extract cross-section at horizon=0 (immediate forecast)
    let immediate_forecast = market_tensor.cross_section(0);

    // Verify forecasts are embedded correctly
    for a in 0..n_assets {
        let embedded = market_tensor.get(0, a, 0, 0);
        let original = forecasts[a].data[0];
        assert_approx(embedded, original, 1e-12);
    }

    // Compute portfolio weights from forecast returns using tensor contraction
    let time_weights: Vec<f64> = (0..horizon).map(|h| {
        exp(-0.5 * (h as f64))  // Exponential decay weighting
    }).collect();
    let weighted_tensor = market_tensor.contract(0, &time_weights);

    // Weighted aggregation should produce a single time slice
    assert_true(weighted_tensor.shape[0] == 1,
        "Contracted tensor should have 1 time step");

    println("  oracle -> field-tensor forecast embedding: OK");
}

// =============================================================================
// 8. FULL CHAIN: FOUNDATION -> ORACLE -> QUANTUM-FINANCE
//    End-to-end prediction-to-trade pipeline
// =============================================================================

/// Full chain: math generates data, oracle predicts, finance trades
fn test_full_chain_predict_and_trade() {
    // Stage 1: Foundation generates synthetic market data
    let n: usize = 100;
    let mut prices: Vec<f64> = Vec::new();
    for i in 0..n {
        let t = i as f64;
        let drift = exp(0.0003 * t);   // ~8% annual drift
        let cycle = sin(2.0 * PI * t / 25.0) * 5.0;
        let micro = cos(t * 1.7) * 0.5;
        prices.push(100.0 * drift + cycle + micro);
    }

    // Stage 2: Oracle computes features
    let price_tensor = Tensor::from_slice(&prices);
    let price_mean = price_tensor.mean();

    // Compute returns
    let mut returns: Vec<f64> = Vec::new();
    for i in 1..n {
        returns.push(log(prices[i] / prices[i - 1]));
    }
    let return_tensor = Tensor::from_slice(&returns);
    let vol = return_tensor.std();

    // Simple EMA forecast
    let alpha: f64 = 0.2;
    let mut ema_val = returns[0];
    for i in 1..returns.len() {
        ema_val = alpha * returns[i] + (1.0 - alpha) * ema_val;
    }
    let forecast_return = ema_val;

    // Stage 3: Quantum-Finance position sizing
    let current_price = prices[n - 1];
    let forecast_price = current_price * exp(forecast_return);
    let expected_pnl = forecast_price - current_price;

    // Kelly criterion: f = expected_return / variance
    let kelly_fraction = if vol > 0.0 {
        clamp(forecast_return / (vol * vol), -0.5, 0.5) as f64
    } else {
        0.0
    };

    let capital = 100000.0;
    let position_size = capital * abs(kelly_fraction);

    // Verify the full pipeline produced reasonable results
    assert_true(current_price > 0.0, "Current price should be positive");
    assert_true(vol > 0.0, "Volatility should be positive");
    assert_in_range(abs(kelly_fraction), 0.0, 0.5);
    assert_true(position_size >= 0.0, "Position size should be non-negative");
    assert_true(position_size <= capital * 0.5, "Position size should not exceed 50% of capital");

    println("  foundation -> oracle -> quantum-finance full chain: OK");
}

// =============================================================================
// 9. FULL CHAIN: SPECTRUM -> PHOTON -> CALIBRATE
//    End-to-end color pipeline from scene to display
// =============================================================================

/// Full chain: spectrum defines colors, photon renders, calibrate corrects
fn test_full_chain_color_to_display() {
    // Stage 1: Spectrum defines scene colors in linear sRGB
    let scene_color = RGB::new(0.6, 0.3, 0.1);  // Warm orange, linear

    // Stage 2: Photon applies HDR rendering (boost by exposure)
    let exposure = 1.5;
    let exposed = RGB::new(
        scene_color.r * exposure as f32,
        scene_color.g * exposure as f32,
        scene_color.b * exposure as f32,
    );

    // Stage 3: Spectrum tonemaps via Reinhard
    let lum = exposed.luminance();
    let mapped_lum = lum / (1.0 + lum);
    let scale = if lum > 0.0 { mapped_lum / lum } else { 0.0 };
    let tonemapped = RGB::new(
        exposed.r * scale,
        exposed.g * scale,
        exposed.b * scale,
    );

    // Stage 4: Spectrum applies sRGB gamma for standard display
    let srgb_output = RGB::new(
        srgb_oetf(tonemapped.r),
        srgb_oetf(tonemapped.g),
        srgb_oetf(tonemapped.b),
    );

    // Stage 5: Calibrate applies display-specific correction
    // Simulate a display that is slightly too warm (boost blue, reduce red)
    let cal_matrix = Mat3::new([
        [0.98, 0.00, 0.00],  // Reduce red by 2%
        [0.00, 1.00, 0.00],  // Green unchanged
        [0.00, 0.00, 1.03],  // Boost blue by 3%
    ]);
    let srgb_vec = Vec3::new(srgb_output.r, srgb_output.g, srgb_output.b);
    let corrected_vec = cal_matrix.mul_vec3(&srgb_vec);
    let calibrated = RGB::new(
        clamp(corrected_vec.x, 0.0, 1.0) as f32,
        clamp(corrected_vec.y, 0.0, 1.0) as f32,
        clamp(corrected_vec.z, 0.0, 1.0) as f32,
    );

    // Verify: calibrated output is in display range
    assert_in_range(calibrated.r as f64, 0.0, 1.0);
    assert_in_range(calibrated.g as f64, 0.0, 1.0);
    assert_in_range(calibrated.b as f64, 0.0, 1.0);

    // Verify: warm scene color is still predominantly red/green
    assert_true(calibrated.r > calibrated.b,
        "Warm orange should have more red than blue even after cal");

    // Verify: calibration correction is subtle (< 5% per channel)
    assert_true(abs((calibrated.r - srgb_output.r) as f64) < 0.05,
        "Calibration correction should be subtle");

    println("  spectrum -> photon -> calibrate full chain: OK");
}

// =============================================================================
// 10. FULL CHAIN: FIELD-TENSOR -> QUANTUM-FINANCE -> ORACLE
//     Trading feedback loop with performance analysis
// =============================================================================

/// Full chain: tensor data drives trades, oracle analyzes performance
fn test_full_chain_trading_feedback() {
    // Stage 1: Field-Tensor contains market state
    let n_time: usize = 40;
    let n_assets: usize = 2;
    let mut tensor = MarketTensor4D::new(n_time, n_assets, 2, 1);

    // Populate: feature 0 = price, feature 1 = volume
    for t in 0..n_time {
        for a in 0..n_assets {
            let price = 100.0 + (a as f64) * 20.0
                + 5.0 * sin(2.0 * PI * (t as f64) / 15.0 + (a as f64));
            let volume = 1000000.0 + 500000.0 * cos((t as f64) * 0.3);
            tensor.set(t, a, 0, 0, price);
            tensor.set(t, a, 1, 0, volume);
        }
    }

    // Stage 2: Quantum-Finance generates trades from tensor
    let mut trades: Vec<(usize, f64)> = Vec::new();  // (time, pnl)
    for t in 5..n_time {
        // Simple momentum: buy if 5-period return is positive
        let price_now = tensor.get(t, 0, 0, 0);
        let price_5ago = tensor.get(t - 5, 0, 0, 0);
        let momentum = (price_now - price_5ago) / price_5ago;

        if t < n_time - 1 {
            let next_price = tensor.get(t + 1, 0, 0, 0);
            let trade_return = (next_price - price_now) / price_now;
            if momentum > 0.0 {
                trades.push((t, trade_return * 10000.0));  // Long
            } else {
                trades.push((t, -trade_return * 10000.0)); // Short
            }
        }
    }

    // Stage 3: Oracle analyzes trade performance
    let pnl_values: Vec<f64> = trades.iter().map(|(_, pnl)| *pnl).collect();
    let pnl_tensor = Tensor::from_slice(&pnl_values);

    let total_pnl = pnl_tensor.sum();
    let avg_pnl = pnl_tensor.mean();
    let pnl_vol = pnl_tensor.std();

    // Compute Sharpe ratio (using Oracle tensor stats)
    let sharpe = if pnl_vol > 0.0 { avg_pnl / pnl_vol } else { 0.0 };

    // Compute win rate
    let wins = pnl_values.iter().filter(|p| **p > 0.0).count();
    let win_rate = (wins as f64) / (pnl_values.len() as f64);

    // Verify: we got trades
    assert_true(trades.len() > 0, "Should generate at least one trade");

    // Verify: PnL statistics are finite
    assert_true(total_pnl.is_finite(), "Total PnL should be finite");
    assert_true(sharpe.is_finite(), "Sharpe ratio should be finite");
    assert_in_range(win_rate, 0.0, 1.0);

    // Verify: Oracle can compute cumulative PnL curve
    let mut cum_pnl: Vec<f64> = Vec::new();
    let mut running = 0.0;
    for pnl in &pnl_values {
        running = running + pnl;
        cum_pnl.push(running);
    }
    let cum_tensor = Tensor::from_slice(&cum_pnl);
    assert_true(cum_tensor.numel() == pnl_values.len(),
        "Cumulative PnL should have same length as trades");

    println("  field-tensor -> quantum-finance -> oracle feedback: OK");
}

