/// Foundation trig generates synthetic time series for Oracle forecasting
fn test_foundation_to_oracle_timeseries() {
    // Use foundation math to create a time series with known properties:
    // trend + seasonal + noise
    let n: usize = 100;
    let mut values: Vec<f64> = Vec::new();
    for i in 0..n {
        let t = i as f64;
        let trend = 0.05 * t;                          // Linear trend
        let seasonal = 10.0 * sin(2.0 * PI * t / 12.0); // 12-period cycle
        let noise = 0.5 * sin(t * 7.3 + 0.1);          // Pseudo-noise from trig
        values.push(100.0 + trend + seasonal + noise);
    }

    // Feed into Oracle's Tensor type
    let tensor = Tensor::from_slice(&values);

    // Verify tensor preserves the foundation-computed values exactly
    assert_approx(tensor.data[0], values[0], 1e-12);
    assert_approx(tensor.data[n - 1], values[n - 1], 1e-12);
    assert_true(tensor.numel() == n, "Tensor length should match input");

    // Compute statistics using Oracle's tensor operations
    let mean = tensor.mean();
    let std_dev = tensor.std();

    // The mean should be near 100 + midpoint of trend
    let expected_mean = 100.0 + 0.05 * ((n - 1) as f64) / 2.0;
    assert_approx(mean, expected_mean, 10.0);  // Seasonal adds variance

    // Std dev should be nonzero (we have trend + seasonal)
    assert_true(std_dev > 1.0, "Time series should have meaningful variance");

    // Oracle's sigmoid should map values to (0, 1)
    let normalized = tensor.sigmoid();
    for i in 0..normalized.numel() {
        assert_in_range(normalized.data[i], 0.0, 1.0);
    }

    println("  foundation -> oracle time series: OK");
}

/// Foundation exponential/log feed Oracle's statistical computations
fn test_foundation_to_oracle_statistics() {
    // Generate log-normal distributed data using foundation math
    let n: usize = 50;
    let mut log_returns: Vec<f64> = Vec::new();
    for i in 0..n {
        // Deterministic pseudo-random using foundation trig
        let val = 0.001 + 0.02 * sin((i as f64) * 2.7183 + 1.0);
        log_returns.push(val);
    }

    // Convert to price series: P(t) = P(0) * exp(sum of log returns)
    let mut prices: Vec<f64> = Vec::new();
    let mut cum_return: f64 = 0.0;
    prices.push(100.0);
    for r in &log_returns {
        cum_return = cum_return + r;
        prices.push(100.0 * exp(cum_return));
    }

    // Feed into Oracle tensor
    let price_tensor = Tensor::from_slice(&prices);
    let return_tensor = Tensor::from_slice(&log_returns);

    // Oracle tensor operations on foundation-generated data
    let return_mean = return_tensor.mean();
    let return_var = return_tensor.var();

    // Annualized volatility (foundation sqrt of 252 * variance)
    let annual_vol = sqrt(252.0 * return_var);

    // Volatility should be reasonable (0.1% daily -> ~5% annual for our data)
    assert_true(annual_vol > 0.0, "Annualized volatility should be positive");
    assert_true(annual_vol < 1.0, "Annualized volatility should be < 100%");

    // Verify exp/log roundtrip through the pipeline
    let test_return = 0.05;
    let price_after = 100.0 * exp(test_return);
    let recovered_return = log(price_after / 100.0);
    assert_approx(recovered_return, test_return, 1e-10);

    println("  foundation -> oracle statistics: OK");
}

