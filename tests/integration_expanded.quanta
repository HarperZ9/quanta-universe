// 1. FOUNDATION -> SPECTRUM
//    Math operations flowing into color space conversions
// =============================================================================

/// Foundation math generates tristimulus values; Spectrum converts them
/// through the full sRGB <-> XYZ <-> Lab <-> OKLab roundtrip.
fn test_foundation_to_spectrum_xyz_roundtrip() {
    // Use foundation trig to generate a set of spectral-like energy values
    let wavelengths: Vec<f64> = (0..8).map(|i| 380.0 + (i as f64) * 50.0).collect();
    let energies: Vec<f64> = wavelengths.iter()
        .map(|w| exp(-pow((w - 550.0) / 80.0, 2.0)))  // Gaussian peak at 550nm (green)
        .collect();

    // Approximate CIE XYZ from spectral energy using foundation math
    // Simplified: X ~ energy * x_bar, Y ~ energy * y_bar
    let mut x_sum: f64 = 0.0;
    let mut y_sum: f64 = 0.0;
    let mut z_sum: f64 = 0.0;
    for i in 0..energies.len() {
        let t = (wavelengths[i] - 380.0) / (780.0 - 380.0);
        // Simplified color matching approximation
        x_sum = x_sum + energies[i] * exp(-pow((t - 0.45) / 0.15, 2.0));
        y_sum = y_sum + energies[i] * exp(-pow((t - 0.55) / 0.20, 2.0));
        z_sum = z_sum + energies[i] * exp(-pow((t - 0.30) / 0.10, 2.0));
    }

    // Normalize to [0, 1] range
    let scale = 1.0 / y_sum.max(0.001);
    let xyz = XYZ::new(
        (x_sum * scale) as f32,
        (y_sum * scale) as f32,
        (z_sum * scale) as f32,
    );

    // Convert XYZ -> sRGB using spectrum matrices
    let xyz_vec = Vec3::new(xyz.x, xyz.y, xyz.z);
    let rgb_vec = XYZ_TO_SRGB.mul_vec3(&xyz_vec);
    let rgb = RGB::new(
        clamp(rgb_vec.x, 0.0, 1.0) as f32,
        clamp(rgb_vec.y, 0.0, 1.0) as f32,
        clamp(rgb_vec.z, 0.0, 1.0) as f32,
    );

    // Convert back: sRGB -> XYZ
    let linear_vec = Vec3::new(
        srgb_eotf(rgb.r),
        srgb_eotf(rgb.g),
        srgb_eotf(rgb.b),
    );
    let roundtrip_xyz = SRGB_TO_XYZ.mul_vec3(&linear_vec);

    // Apply sRGB OETF then EOTF to verify transfer function roundtrip
    let test_val: f32 = 0.73;
    let encoded = srgb_oetf(test_val);
    let decoded = srgb_eotf(encoded);

    assert_approx(decoded as f64, test_val as f64, 0.001);

    // Y channel should be preserved through the pipeline (luminance)
    assert_true(rgb.luminance() > 0.0, "Luminance should be positive for visible light");

    println("  foundation -> spectrum XYZ roundtrip: OK");
}

/// Foundation pow/exp feeding spectrum tonemapping
fn test_foundation_to_spectrum_tonemapping() {
    // Generate HDR scene values using foundation exponentials
    let hdr_values: Vec<f64> = (0..10).map(|i| {
        exp((i as f64) * 0.5) * 0.1  // Exponentially increasing brightness
    }).collect();

    // Apply reinhard tonemap (uses foundation division)
    let tonemapped: Vec<f64> = hdr_values.iter()
        .map(|x| x / (1.0 + x))  // Reinhard: x / (1 + x)
        .collect();

    // All tonemapped values must be in [0, 1)
    for (i, val) in tonemapped.iter().enumerate() {
        assert_in_range(*val, 0.0, 1.0);
        // Reinhard is monotonically increasing
        if i > 0 {
            assert_true(*val > tonemapped[i - 1],
                "Reinhard tonemapping must be monotonically increasing");
        }
    }

    // Verify reinhard approaches but never reaches 1.0
    let extreme = 10000.0;
    let result = extreme / (1.0 + extreme);
    assert_true(result < 1.0, "Reinhard(10000) should be < 1.0");
    assert_true(result > 0.999, "Reinhard(10000) should be > 0.999");

    // ACES filmic tonemap (uses foundation polynomial math)
    let aces_a: f64 = 2.51;
    let aces_b: f64 = 0.03;
    let aces_c: f64 = 2.43;
    let aces_d: f64 = 0.59;
    let aces_e: f64 = 0.14;
    let aces_mapped: Vec<f64> = hdr_values.iter().map(|x| {
        let num = x * (aces_a * x + aces_b);
        let den = x * (aces_c * x + aces_d) + aces_e;
        clamp(num / den, 0.0, 1.0) as f64
    }).collect();

    // ACES(0) should be ~0 (slightly positive due to b/e ratio)
    assert_true(aces_mapped[0] < 0.1, "ACES(~0.1) should be small");

    println("  foundation -> spectrum tonemapping: OK");
}

/// Foundation linear algebra feeds spectrum color matrix transforms
fn test_foundation_to_spectrum_matrix_chain() {
    // Use foundation math to build a chromatic adaptation matrix (Bradford)
    // This demonstrates math -> color science integration
    let src_white = XYZ::d65_white();
    let dst_white = XYZ::d50_white();

    // Bradford cone response matrix
    let bradford = Mat3::new([
        [ 0.8951,  0.2664, -0.1614],
        [-0.7502,  1.7135,  0.0367],
        [ 0.0389, -0.0685,  1.0296],
    ]);

    // Transform white points to cone space using matrix * vector
    let src_cone = bradford.mul_vec3(&Vec3::new(src_white.x, src_white.y, src_white.z));
    let dst_cone = bradford.mul_vec3(&Vec3::new(dst_white.x, dst_white.y, dst_white.z));

    // Cone ratios (diagonal scaling)
    let scale_l = dst_cone.x / src_cone.x;
    let scale_m = dst_cone.y / src_cone.y;
    let scale_s = dst_cone.z / src_cone.z;

    // All scale factors should be near 1.0 for similar illuminants
    assert_in_range(scale_l as f64, 0.5, 1.5);
    assert_in_range(scale_m as f64, 0.5, 1.5);
    assert_in_range(scale_s as f64, 0.5, 1.5);

    // Verify identity: adapting from D65 to D65 should give scale = 1.0
    let self_cone = bradford.mul_vec3(&Vec3::new(src_white.x, src_white.y, src_white.z));
    let self_scale_l = self_cone.x / src_cone.x;
    assert_approx(self_scale_l as f64, 1.0, 0.0001);

    println("  foundation -> spectrum matrix chain: OK");
}

