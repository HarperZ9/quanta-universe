// =============================================================================
// HELPER: Approximate equality for floating-point comparisons
// =============================================================================

const EPSILON: f64 = 1e-6;

fn approx_eq(a: f64, b: f64, tol: f64) -> bool {
    abs(a - b) < tol
}

fn assert_approx(a: f64, b: f64, tol: f64) {
    if !approx_eq(a, b, tol) {
        println!("  FAIL: expected {} ~= {} (tol={}), diff={}", a, b, tol, abs(a - b));
    }
}

fn assert_in_range(val: f64, lo: f64, hi: f64) {
    if val < lo || val > hi {
        println!("  FAIL: {} not in [{}, {}]", val, lo, hi);
    }
}

fn assert_true(cond: bool, msg: &str) {
    if !cond {
        println!("  FAIL: {}", msg);
    }
}

