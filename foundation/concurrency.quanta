//! # Concurrency Module
//!
//! Comprehensive concurrency primitives for the Foundation Standard Library:
//! - Synchronization primitives (Mutex, RwLock, Condvar, Barrier)
//! - Channels (bounded, unbounded, oneshot)
//! - Thread pool with work-stealing
//! - Async runtime integration
//! - Atomic operations and memory ordering
//!
//! ## Design Philosophy
//!
//! This module prioritizes safety and correctness while providing high performance
//! through careful attention to memory ordering and cache-friendly data structures.

// =============================================================================
// Atomic Types
// =============================================================================

/// Memory ordering for atomic operations
pub enum Ordering {
    /// No ordering constraints
    Relaxed,
    /// Acquire ordering (loads)
    Acquire,
    /// Release ordering (stores)
    Release,
    /// Acquire-Release ordering
    AcqRel,
    /// Sequentially consistent ordering
    SeqCst,
}

/// Atomic boolean
pub struct AtomicBool {
    value: intrinsic::AtomicBoolInner,
}

impl AtomicBool {
    /// Create a new atomic bool
    pub const fn new(value: bool) -> Self {
        Self {
            value: intrinsic::atomic_bool_new(value),
        }
    }

    /// Load the value
    pub fn load(self: &Self, ordering: Ordering) -> bool {
        intrinsic::atomic_bool_load(&self.value, ordering)
    }

    /// Store a value
    pub fn store(self: &Self, value: bool, ordering: Ordering) {
        intrinsic::atomic_bool_store(&self.value, value, ordering)
    }

    /// Swap values, returning old value
    pub fn swap(self: &Self, value: bool, ordering: Ordering) -> bool {
        intrinsic::atomic_bool_swap(&self.value, value, ordering)
    }

    /// Compare and swap
    pub fn compare_exchange(
        self: &Self,
        current: bool,
        new: bool,
        success: Ordering,
        failure: Ordering,
    ) -> Result<bool, bool> {
        intrinsic::atomic_bool_compare_exchange(&self.value, current, new, success, failure)
    }

    /// Weak compare and swap (may spuriously fail)
    pub fn compare_exchange_weak(
        self: &Self,
        current: bool,
        new: bool,
        success: Ordering,
        failure: Ordering,
    ) -> Result<bool, bool> {
        intrinsic::atomic_bool_compare_exchange_weak(&self.value, current, new, success, failure)
    }

    /// Fetch and logical AND
    pub fn fetch_and(self: &Self, value: bool, ordering: Ordering) -> bool {
        intrinsic::atomic_bool_fetch_and(&self.value, value, ordering)
    }

    /// Fetch and logical OR
    pub fn fetch_or(self: &Self, value: bool, ordering: Ordering) -> bool {
        intrinsic::atomic_bool_fetch_or(&self.value, value, ordering)
    }

    /// Fetch and logical XOR
    pub fn fetch_xor(self: &Self, value: bool, ordering: Ordering) -> bool {
        intrinsic::atomic_bool_fetch_xor(&self.value, value, ordering)
    }

    /// Fetch and logical NAND
    pub fn fetch_nand(self: &Self, value: bool, ordering: Ordering) -> bool {
        intrinsic::atomic_bool_fetch_nand(&self.value, value, ordering)
    }
}

/// Atomic usize
pub struct AtomicUsize {
    value: intrinsic::AtomicUsizeInner,
}

impl AtomicUsize {
    /// Create a new atomic usize
    pub const fn new(value: usize) -> Self {
        Self {
            value: intrinsic::atomic_usize_new(value),
        }
    }

    /// Load the value
    pub fn load(self: &Self, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_load(&self.value, ordering)
    }

    /// Store a value
    pub fn store(self: &Self, value: usize, ordering: Ordering) {
        intrinsic::atomic_usize_store(&self.value, value, ordering)
    }

    /// Swap values, returning old value
    pub fn swap(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_swap(&self.value, value, ordering)
    }

    /// Compare and swap
    pub fn compare_exchange(
        self: &Self,
        current: usize,
        new: usize,
        success: Ordering,
        failure: Ordering,
    ) -> Result<usize, usize> {
        intrinsic::atomic_usize_compare_exchange(&self.value, current, new, success, failure)
    }

    /// Weak compare and swap
    pub fn compare_exchange_weak(
        self: &Self,
        current: usize,
        new: usize,
        success: Ordering,
        failure: Ordering,
    ) -> Result<usize, usize> {
        intrinsic::atomic_usize_compare_exchange_weak(&self.value, current, new, success, failure)
    }

    /// Fetch and add
    pub fn fetch_add(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_add(&self.value, value, ordering)
    }

    /// Fetch and subtract
    pub fn fetch_sub(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_sub(&self.value, value, ordering)
    }

    /// Fetch and bitwise AND
    pub fn fetch_and(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_and(&self.value, value, ordering)
    }

    /// Fetch and bitwise OR
    pub fn fetch_or(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_or(&self.value, value, ordering)
    }

    /// Fetch and bitwise XOR
    pub fn fetch_xor(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_xor(&self.value, value, ordering)
    }

    /// Fetch max
    pub fn fetch_max(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_max(&self.value, value, ordering)
    }

    /// Fetch min
    pub fn fetch_min(self: &Self, value: usize, ordering: Ordering) -> usize {
        intrinsic::atomic_usize_fetch_min(&self.value, value, ordering)
    }
}

