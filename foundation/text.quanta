//! Text processing utilities.
//!
//! This module provides string algorithms, Unicode utilities, text formatting,
//! and natural language processing primitives.

use foundation::collections::{Vec, HashMap, HashSet};

// ============================================================================
// String Extensions
// ============================================================================

/// Extended string operations.
pub trait StringExt {
    /// Check if string is empty or whitespace only.
    fn is_blank(self: &Self) -> bool;

    /// Truncate to max length, adding ellipsis if needed.
    fn truncate(self: &Self, max_len: usize) -> String;

    /// Pad left to width.
    fn pad_left(self: &Self, width: usize, c: char) -> String;

    /// Pad right to width.
    fn pad_right(self: &Self, width: usize, c: char) -> String;

    /// Center in width.
    fn center(self: &Self, width: usize, c: char) -> String;

    /// Remove prefix if present.
    fn strip_prefix_str(self: &Self, prefix: &str) -> String;

    /// Remove suffix if present.
    fn strip_suffix_str(self: &Self, suffix: &str) -> String;

    /// Repeat string n times.
    fn repeat(self: &Self, n: usize) -> String;

    /// Reverse string (grapheme-aware).
    fn reverse_graphemes(self: &Self) -> String;

    /// Count occurrences of substring.
    fn count_occurrences(self: &Self, pattern: &str) -> usize;

    /// Word count.
    fn word_count(self: &Self) -> usize;

    /// Line count.
    fn line_count(self: &Self) -> usize;

    /// Get all words.
    fn words(self: &Self) -> Vec<&str>;

    /// Get all lines.
    fn lines_vec(self: &Self) -> Vec<&str>;
}

impl StringExt for str {
    fn is_blank(self: &Self) -> bool {
        self.chars().all(|c| c.is_whitespace())
    }

    fn truncate(self: &Self, max_len: usize) -> String {
        if self.len() <= max_len {
            self.to_string()
        } else if max_len <= 3 {
            self.chars().take(max_len).collect()
        } else {
            let mut result: String = self.chars().take(max_len - 3).collect();
            result.push_str("...");
            result
        }
    }

    fn pad_left(self: &Self, width: usize, c: char) -> String {
        if self.len() >= width {
            self.to_string()
        } else {
            let padding: String = std::iter::repeat(c).take(width - self.len()).collect();
            format!("{}{}", padding, self)
        }
    }

    fn pad_right(self: &Self, width: usize, c: char) -> String {
        if self.len() >= width {
            self.to_string()
        } else {
            let padding: String = std::iter::repeat(c).take(width - self.len()).collect();
            format!("{}{}", self, padding)
        }
    }

    fn center(self: &Self, width: usize, c: char) -> String {
        if self.len() >= width {
            self.to_string()
        } else {
            let total_pad = width - self.len();
            let left_pad = total_pad / 2;
            let right_pad = total_pad - left_pad;
            let left: String = std::iter::repeat(c).take(left_pad).collect();
            let right: String = std::iter::repeat(c).take(right_pad).collect();
            format!("{}{}{}", left, self, right)
        }
    }

    fn strip_prefix_str(self: &Self, prefix: &str) -> String {
        self.strip_prefix(prefix).unwrap_or(self).to_string()
    }

    fn strip_suffix_str(self: &Self, suffix: &str) -> String {
        self.strip_suffix(suffix).unwrap_or(self).to_string()
    }

    fn repeat(self: &Self, n: usize) -> String {
        self.repeat(n)
    }

    fn reverse_graphemes(self: &Self) -> String {
        // Simple char-based reverse (proper grapheme handling would use unicode-segmentation)
        self.chars().rev().collect()
    }

    fn count_occurrences(self: &Self, pattern: &str) -> usize {
        if pattern.is_empty() {
            return 0;
        }
        self.matches(pattern).count()
    }

    fn word_count(self: &Self) -> usize {
        self.split_whitespace().count()
    }

    fn line_count(self: &Self) -> usize {
        if self.is_empty() {
            0
        } else {
            self.lines().count()
        }
    }

    fn words(self: &Self) -> Vec<&str> {
        self.split_whitespace().collect()
    }

    fn lines_vec(self: &Self) -> Vec<&str> {
        self.lines().collect()
    }
}

// ============================================================================
// Case Conversion
// ============================================================================

/// Case conversion utilities.
pub mod case {
    /// Convert to snake_case.
    pub fn to_snake_case(s: &str) -> String {
        let mut result = String::new();
        let mut prev_lower = false;

        for c in s.chars() {
            if c.is_uppercase() {
                if prev_lower && !result.is_empty() {
                    result.push('_');
                }
                result.push(c.to_lowercase().next().unwrap());
                prev_lower = false;
            } else if c == '-' || c == ' ' {
                if !result.is_empty() && !result.ends_with('_') {
                    result.push('_');
                }
                prev_lower = false;
            } else {
                result.push(c);
                prev_lower = c.is_lowercase();
            }
        }

        result
    }

    /// Convert to camelCase.
    pub fn to_camel_case(s: &str) -> String {
        let mut result = String::new();
        let mut capitalize_next = false;

        for c in s.chars() {
            if c == '_' || c == '-' || c == ' ' {
                capitalize_next = true;
            } else if capitalize_next {
                result.push(c.to_uppercase().next().unwrap());
                capitalize_next = false;
            } else {
                result.push(c.to_lowercase().next().unwrap());
            }
        }

        result
    }

    /// Convert to PascalCase.
    pub fn to_pascal_case(s: &str) -> String {
        let camel = to_camel_case(s);
        let mut chars = camel.chars();
        match chars.next() {
            Some(c) => c.to_uppercase().collect::<String>() + chars.as_str(),
            None => String::new(),
        }
    }

    /// Convert to SCREAMING_SNAKE_CASE.
    pub fn to_screaming_snake_case(s: &str) -> String {
        to_snake_case(s).to_uppercase()
    }

    /// Convert to kebab-case.
    pub fn to_kebab_case(s: &str) -> String {
        to_snake_case(s).replace('_', "-")
    }

    /// Convert to Title Case.
    pub fn to_title_case(s: &str) -> String {
        s.split_whitespace()
            .map(|word| {
                let mut chars = word.chars();
                match chars.next() {
                    Some(c) => c.to_uppercase().collect::<String>() + &chars.as_str().to_lowercase(),
                    None => String::new(),
                }
            })
            .collect::<Vec<_>>()
            .join(" ")
    }

    /// Convert to Sentence case.
    pub fn to_sentence_case(s: &str) -> String {
        let lower = s.to_lowercase();
        let mut chars = lower.chars();
        match chars.next() {
            Some(c) => c.to_uppercase().collect::<String>() + chars.as_str(),
            None => String::new(),
        }
    }

    /// Swap case of all characters.
    pub fn swap_case(s: &str) -> String {
        s.chars()
            .map(|c| {
                if c.is_uppercase() {
                    c.to_lowercase().next().unwrap()
                } else {
                    c.to_uppercase().next().unwrap()
                }
            })
            .collect()
    }
}

// ============================================================================
// Text Similarity
// ============================================================================

/// Text similarity and distance algorithms.
pub mod similarity {
    /// Levenshtein edit distance.
    pub fn levenshtein(a: &str, b: &str) -> usize {
        let a_chars: Vec<char> = a.chars().collect();
        let b_chars: Vec<char> = b.chars().collect();
        let m = a_chars.len();
        let n = b_chars.len();

        if m == 0 { return n; }
        if n == 0 { return m; }

        let mut prev = vec![0usize; n + 1];
        let mut curr = vec![0usize; n + 1];

        for j in 0..=n {
            prev[j] = j;
        }

        for i in 1..=m {
            curr[0] = i;
            for j in 1..=n {
                let cost = if a_chars[i - 1] == b_chars[j - 1] { 0 } else { 1 };
                curr[j] = (prev[j] + 1)
                    .min(curr[j - 1] + 1)
                    .min(prev[j - 1] + cost);
            }
            std::mem::swap(&mut prev, &mut curr);
        }

        prev[n]
    }

    /// Damerau-Levenshtein distance (allows transpositions).
    pub fn damerau_levenshtein(a: &str, b: &str) -> usize {
        let a_chars: Vec<char> = a.chars().collect();
        let b_chars: Vec<char> = b.chars().collect();
        let m = a_chars.len();
        let n = b_chars.len();

        if m == 0 { return n; }
        if n == 0 { return m; }

        let mut d = vec![vec![0usize; n + 1]; m + 1];

        for i in 0..=m { d[i][0] = i; }
        for j in 0..=n { d[0][j] = j; }

        for i in 1..=m {
            for j in 1..=n {
                let cost = if a_chars[i - 1] == b_chars[j - 1] { 0 } else { 1 };
                d[i][j] = (d[i - 1][j] + 1)
                    .min(d[i][j - 1] + 1)
                    .min(d[i - 1][j - 1] + cost);

                if i > 1 && j > 1
                    && a_chars[i - 1] == b_chars[j - 2]
                    && a_chars[i - 2] == b_chars[j - 1]
                {
                    d[i][j] = d[i][j].min(d[i - 2][j - 2] + cost);
                }
            }
        }

        d[m][n]
    }

    /// Jaro similarity (0.0 to 1.0).
    pub fn jaro(a: &str, b: &str) -> f64 {
        if a == b { return 1.0; }
        if a.is_empty() || b.is_empty() { return 0.0; }

        let a_chars: Vec<char> = a.chars().collect();
        let b_chars: Vec<char> = b.chars().collect();
        let m = a_chars.len();
        let n = b_chars.len();

        let match_distance = (m.max(n) / 2).saturating_sub(1);

        let mut a_matched = vec![false; m];
        let mut b_matched = vec![false; n];

        let mut matches = 0usize;
        let mut transpositions = 0usize;

        for i in 0..m {
            let start = i.saturating_sub(match_distance);
            let end = (i + match_distance + 1).min(n);

            for j in start..end {
                if b_matched[j] || a_chars[i] != b_chars[j] {
                    continue;
                }
                a_matched[i] = true;
                b_matched[j] = true;
                matches += 1;
                break;
            }
        }

        if matches == 0 { return 0.0; }

        let mut k = 0;
        for i in 0..m {
            if !a_matched[i] { continue; }
            while !b_matched[k] { k += 1; }
            if a_chars[i] != b_chars[k] {
                transpositions += 1;
            }
            k += 1;
        }

        let matches = matches as f64;
        (matches / m as f64 + matches / n as f64 + (matches - transpositions as f64 / 2.0) / matches) / 3.0
    }

    /// Jaro-Winkler similarity (0.0 to 1.0).
    pub fn jaro_winkler(a: &str, b: &str) -> f64 {
        let jaro_sim = jaro(a, b);

        // Common prefix length (up to 4)
        let a_chars: Vec<char> = a.chars().collect();
        let b_chars: Vec<char> = b.chars().collect();
        let prefix_len = a_chars.iter()
            .zip(b_chars.iter())
            .take(4)
            .take_while(|(a, b)| a == b)
            .count();

        jaro_sim + prefix_len as f64 * 0.1 * (1.0 - jaro_sim)
    }

    /// Hamming distance (for equal-length strings).
    pub fn hamming(a: &str, b: &str) -> Option<usize> {
        if a.len() != b.len() {
            return None;
        }
        Some(a.chars().zip(b.chars()).filter(|(a, b)| a != b).count())
    }

    /// Longest common subsequence length.
    pub fn lcs_length(a: &str, b: &str) -> usize {
        let a_chars: Vec<char> = a.chars().collect();
        let b_chars: Vec<char> = b.chars().collect();
        let m = a_chars.len();
        let n = b_chars.len();

        let mut dp = vec![vec![0usize; n + 1]; m + 1];

        for i in 1..=m {
            for j in 1..=n {
                if a_chars[i - 1] == b_chars[j - 1] {
                    dp[i][j] = dp[i - 1][j - 1] + 1;
                } else {
                    dp[i][j] = dp[i - 1][j].max(dp[i][j - 1]);
                }
            }
        }

        dp[m][n]
    }

    /// Longest common subsequence string.
    pub fn lcs(a: &str, b: &str) -> String {
        let a_chars: Vec<char> = a.chars().collect();
        let b_chars: Vec<char> = b.chars().collect();
        let m = a_chars.len();
        let n = b_chars.len();

        let mut dp = vec![vec![0usize; n + 1]; m + 1];

        for i in 1..=m {
            for j in 1..=n {
                if a_chars[i - 1] == b_chars[j - 1] {
                    dp[i][j] = dp[i - 1][j - 1] + 1;
                } else {
                    dp[i][j] = dp[i - 1][j].max(dp[i][j - 1]);
                }
            }
        }

        // Backtrack to find LCS
        let mut result = Vec::new();
        let mut i = m;
        let mut j = n;

        while i > 0 && j > 0 {
            if a_chars[i - 1] == b_chars[j - 1] {
                result.push(a_chars[i - 1]);
                i -= 1;
                j -= 1;
            } else if dp[i - 1][j] > dp[i][j - 1] {
                i -= 1;
            } else {
                j -= 1;
            }
        }

        result.reverse();
        result.into_iter().collect()
    }

    /// Normalized similarity (0.0 to 1.0) based on Levenshtein.
    pub fn normalized_similarity(a: &str, b: &str) -> f64 {
        let max_len = a.len().max(b.len());
        if max_len == 0 { return 1.0; }
        1.0 - (levenshtein(a, b) as f64 / max_len as f64)
    }

    /// Cosine similarity of character n-grams.
    pub fn cosine_ngram(a: &str, b: &str, n: usize) -> f64 {
        let a_ngrams = ngrams(a, n);
        let b_ngrams = ngrams(b, n);

        let mut a_counts: std::collections::HashMap<&str, usize> = std::collections::HashMap::new();
        let mut b_counts: std::collections::HashMap<&str, usize> = std::collections::HashMap::new();

        for ng in &a_ngrams {
            *a_counts.entry(ng).or_insert(0) += 1;
        }
        for ng in &b_ngrams {
            *b_counts.entry(ng).or_insert(0) += 1;
        }

        let mut dot = 0.0;
        let mut a_norm = 0.0;
        let mut b_norm = 0.0;

        for (ng, &count) in &a_counts {
            let a_val = count as f64;
            let b_val = b_counts.get(ng).copied().unwrap_or(0) as f64;
            dot += a_val * b_val;
            a_norm += a_val * a_val;
        }

        for &count in b_counts.values() {
            b_norm += (count as f64) * (count as f64);
        }

        if a_norm == 0.0 || b_norm == 0.0 {
            0.0
        } else {
            dot / (a_norm.sqrt() * b_norm.sqrt())
        }
    }

    /// Generate character n-grams.
    fn ngrams(s: &str, n: usize) -> Vec<&str> {
        if n == 0 || s.len() < n {
            return Vec::new();
        }
        (0..=s.len() - n).map(|i| &s[i..i + n]).collect()
    }
}

// ============================================================================
// Text Search
// ============================================================================

/// Text search algorithms.
pub mod search {
    use super::*;

    /// Boyer-Moore-Horspool search.
    pub fn boyer_moore_horspool(text: &str, pattern: &str) -> Vec<usize> {
        if pattern.is_empty() || pattern.len() > text.len() {
            return Vec::new();
        }

        let text_bytes = text.as_bytes();
        let pattern_bytes = pattern.as_bytes();
        let m = pattern_bytes.len();
        let n = text_bytes.len();

        // Build bad character table
        let mut bad_char = [m; 256];
        for i in 0..m - 1 {
            bad_char[pattern_bytes[i] as usize] = m - 1 - i;
        }

        let mut matches = Vec::new();
        let mut i = 0;

        while i <= n - m {
            let mut j = m - 1;
            while pattern_bytes[j] == text_bytes[i + j] {
                if j == 0 {
                    matches.push(i);
                    break;
                }
                j -= 1;
            }
            i += bad_char[text_bytes[i + m - 1] as usize];
        }

        matches
    }

    /// Knuth-Morris-Pratt search.
    pub fn kmp(text: &str, pattern: &str) -> Vec<usize> {
        if pattern.is_empty() {
            return Vec::new();
        }

        let text_bytes = text.as_bytes();
        let pattern_bytes = pattern.as_bytes();
        let m = pattern_bytes.len();
        let n = text_bytes.len();

        // Build failure function
        let mut failure = vec![0usize; m];
        let mut k = 0;
        for i in 1..m {
            while k > 0 && pattern_bytes[k] != pattern_bytes[i] {
                k = failure[k - 1];
            }
            if pattern_bytes[k] == pattern_bytes[i] {
                k += 1;
            }
            failure[i] = k;
        }

        // Search
        let mut matches = Vec::new();
        let mut j = 0;

        for i in 0..n {
            while j > 0 && pattern_bytes[j] != text_bytes[i] {
                j = failure[j - 1];
            }
            if pattern_bytes[j] == text_bytes[i] {
                j += 1;
            }
            if j == m {
                matches.push(i + 1 - m);
                j = failure[j - 1];
            }
        }

        matches
    }

    /// Rabin-Karp search with rolling hash.
    pub fn rabin_karp(text: &str, pattern: &str) -> Vec<usize> {
        if pattern.is_empty() || pattern.len() > text.len() {
            return Vec::new();
        }

        const BASE: u64 = 256;
        const MOD: u64 = 1_000_000_007;

        let text_bytes = text.as_bytes();
        let pattern_bytes = pattern.as_bytes();
        let m = pattern_bytes.len();
        let n = text_bytes.len();

        // Compute pattern hash and h = BASE^(m-1)
        let mut pattern_hash: u64 = 0;
        let mut text_hash: u64 = 0;
        let mut h: u64 = 1;

        for _ in 0..m - 1 {
            h = (h * BASE) % MOD;
        }

        for i in 0..m {
            pattern_hash = (BASE * pattern_hash + pattern_bytes[i] as u64) % MOD;
            text_hash = (BASE * text_hash + text_bytes[i] as u64) % MOD;
        }

        let mut matches = Vec::new();

        for i in 0..=n - m {
            if pattern_hash == text_hash {
                if &text_bytes[i..i + m] == pattern_bytes {
                    matches.push(i);
                }
            }

            if i < n - m {
                text_hash = (BASE * (text_hash + MOD - (text_bytes[i] as u64 * h) % MOD) % MOD
                    + text_bytes[i + m] as u64) % MOD;
            }
        }

        matches
    }

    /// Fuzzy search with max edit distance.
    pub fn fuzzy_find(text: &str, pattern: &str, max_distance: usize) -> Vec<(usize, usize)> {
        let words: Vec<&str> = text.split_whitespace().collect();
        let mut results = Vec::new();

        for (i, word) in words.iter().enumerate() {
            let dist = super::similarity::levenshtein(word, pattern);
            if dist <= max_distance {
                results.push((i, dist));
            }
        }

        results.sort_by_key(|&(_, d)| d);
        results
    }
}

// ============================================================================
// Text Formatting
// ============================================================================

/// Text formatting utilities.
pub mod format {
    /// Word wrap text to specified width.
    pub fn word_wrap(text: &str, width: usize) -> String {
        let mut result = String::new();
        let mut line_len = 0;

        for word in text.split_whitespace() {
            if line_len + word.len() > width {
                if line_len > 0 {
                    result.push('\n');
                    line_len = 0;
                }
            } else if line_len > 0 {
                result.push(' ');
                line_len += 1;
            }
            result.push_str(word);
            line_len += word.len();
        }

        result
    }

    /// Justify text to width (left and right aligned).
    pub fn justify(text: &str, width: usize) -> String {
        let words: Vec<&str> = text.split_whitespace().collect();
        if words.is_empty() {
            return String::new();
        }

        let total_word_len: usize = words.iter().map(|w| w.len()).sum();
        let gaps = words.len() - 1;

        if gaps == 0 || total_word_len >= width {
            return words.join(" ");
        }

        let total_spaces = width - total_word_len;
        let base_spaces = total_spaces / gaps;
        let extra_spaces = total_spaces % gaps;

        let mut result = String::new();
        for (i, word) in words.iter().enumerate() {
            if i > 0 {
                let spaces = base_spaces + if i <= extra_spaces { 1 } else { 0 };
                result.extend(std::iter::repeat(' ').take(spaces));
            }
            result.push_str(word);
        }

        result
    }

    /// Indent text by specified amount.
    pub fn indent(text: &str, indent: &str) -> String {
        text.lines()
            .map(|line| format!("{}{}", indent, line))
            .collect::<Vec<_>>()
            .join("\n")
    }

    /// Dedent text (remove common leading whitespace).
    pub fn dedent(text: &str) -> String {
        let lines: Vec<&str> = text.lines().collect();
        let non_empty: Vec<&&str> = lines.iter().filter(|l| !l.trim().is_empty()).collect();

        if non_empty.is_empty() {
            return text.to_string();
        }

        // Find minimum indentation
        let min_indent = non_empty.iter()
            .map(|l| l.len() - l.trim_start().len())
            .min()
            .unwrap_or(0);

        lines.iter()
            .map(|line| {
                if line.trim().is_empty() {
                    ""
                } else {
                    &line[min_indent.min(line.len())..]
                }
            })
            .collect::<Vec<_>>()
            .join("\n")
    }

    /// Create table from rows.
    pub fn table(headers: &[&str], rows: &[Vec<&str>], padding: usize) -> String {
        // Calculate column widths
        let mut widths = headers.iter().map(|h| h.len()).collect::<Vec<_>>();
        for row in rows {
            for (i, cell) in row.iter().enumerate() {
                if i < widths.len() {
                    widths[i] = widths[i].max(cell.len());
                }
            }
        }

        let pad = " ".repeat(padding);
        let separator = widths.iter()
            .map(|&w| "-".repeat(w + padding * 2))
            .collect::<Vec<_>>()
            .join("+");

        let mut result = String::new();

        // Header row
        result.push_str(&format_row(headers, &widths, &pad));
        result.push('\n');
        result.push_str(&separator);
        result.push('\n');

        // Data rows
        for row in rows {
            let cells: Vec<&str> = row.iter().map(|s| *s).collect();
            result.push_str(&format_row(&cells, &widths, &pad));
            result.push('\n');
        }

        result
    }

    fn format_row(cells: &[&str], widths: &[usize], pad: &str) -> String {
        cells.iter()
            .zip(widths.iter())
            .map(|(cell, &width)| format!("{}{:width$}{}", pad, cell, pad, width = width))
            .collect::<Vec<_>>()
            .join("|")
    }

    /// Slugify text (URL-friendly).
    pub fn slugify(text: &str) -> String {
        text.chars()
            .map(|c| {
                if c.is_alphanumeric() {
                    c.to_lowercase().next().unwrap()
                } else {
                    '-'
                }
            })
            .collect::<String>()
            .split('-')
            .filter(|s| !s.is_empty())
            .collect::<Vec<_>>()
            .join("-")
    }

    /// Ordinalize number (1st, 2nd, 3rd, etc.).
    pub fn ordinalize(n: i64) -> String {
        let suffix = match n.abs() % 100 {
            11 | 12 | 13 => "th",
            _ => match n.abs() % 10 {
                1 => "st",
                2 => "nd",
                3 => "rd",
                _ => "th",
            },
        };
        format!("{}{}", n, suffix)
    }

    /// Pluralize word based on count.
    pub fn pluralize(word: &str, count: i64) -> String {
        if count == 1 || count == -1 {
            word.to_string()
        } else {
            // Simple English pluralization
            if word.ends_with('s') || word.ends_with('x') || word.ends_with("ch") || word.ends_with("sh") {
                format!("{}es", word)
            } else if word.ends_with('y') && !word.ends_with("ay") && !word.ends_with("ey") && !word.ends_with("oy") && !word.ends_with("uy") {
                format!("{}ies", &word[..word.len() - 1])
            } else {
                format!("{}s", word)
            }
        }
    }
}

// ============================================================================
// Unicode Utilities
// ============================================================================

/// Unicode-aware text utilities.
pub mod unicode {
    /// Check if string is ASCII only.
    pub fn is_ascii(s: &str) -> bool {
        s.bytes().all(|b| b.is_ascii())
    }

    /// Count Unicode scalar values.
    pub fn char_count(s: &str) -> usize {
        s.chars().count()
    }

    /// Get Unicode width (for terminal display).
    pub fn display_width(s: &str) -> usize {
        s.chars().map(char_width).sum()
    }

    /// Get width of single character.
    pub fn char_width(c: char) -> usize {
        // Simplified width calculation
        if c.is_ascii() {
            if c.is_control() { 0 } else { 1 }
        } else if is_wide(c) {
            2
        } else if is_zero_width(c) {
            0
        } else {
            1
        }
    }

    /// Check if character is wide (CJK, etc.).
    fn is_wide(c: char) -> bool {
        let cp = c as u32;
        // Simplified: CJK ranges
        (0x1100..=0x115F).contains(&cp)  // Hangul Jamo
            || (0x2E80..=0x9FFF).contains(&cp)  // CJK
            || (0xAC00..=0xD7A3).contains(&cp)  // Hangul Syllables
            || (0xF900..=0xFAFF).contains(&cp)  // CJK Compat
            || (0xFE10..=0xFE1F).contains(&cp)  // Vertical forms
            || (0xFF00..=0xFF60).contains(&cp)  // Fullwidth
    }

    /// Check if character is zero-width.
    fn is_zero_width(c: char) -> bool {
        let cp = c as u32;
        (0x200B..=0x200F).contains(&cp)  // Zero-width chars
            || (0x2028..=0x202F).contains(&cp)  // Line/paragraph separators
            || (0xFE00..=0xFE0F).contains(&cp)  // Variation selectors
            || (0xFEFF..=0xFEFF).contains(&cp)  // BOM
    }

    /// Normalize to NFC form.
    pub fn normalize_nfc(s: &str) -> String {
        // Simplified: would use unicode-normalization crate
        s.to_string()
    }

    /// Normalize to NFD form.
    pub fn normalize_nfd(s: &str) -> String {
        s.to_string()
    }

    /// Remove diacritics/accents.
    pub fn remove_diacritics(s: &str) -> String {
        s.chars()
            .map(|c| {
                // Simplified mapping
                match c {
                    'á' | 'à' | 'â' | 'ä' | 'ã' | 'å' => 'a',
                    'é' | 'è' | 'ê' | 'ë' => 'e',
                    'í' | 'ì' | 'î' | 'ï' => 'i',
                    'ó' | 'ò' | 'ô' | 'ö' | 'õ' => 'o',
                    'ú' | 'ù' | 'û' | 'ü' => 'u',
                    'ñ' => 'n',
                    'ç' => 'c',
                    _ => c,
                }
            })
            .collect()
    }

    /// Transliterate to ASCII.
    pub fn to_ascii_transliterate(s: &str) -> String {
        remove_diacritics(s)
            .chars()
            .filter(|c| c.is_ascii())
            .collect()
    }
}

// ============================================================================
// Tokenization
// ============================================================================

/// Text tokenization utilities.
pub mod tokenize {
    use super::*;

    /// Token types.
    #[derive(Clone, Debug, PartialEq)]
    pub enum TokenKind {
        Word,
        Number,
        Punctuation,
        Whitespace,
        Unknown,
    }

    /// A token with position info.
    #[derive(Clone, Debug)]
    pub struct Token<'a> {
        pub text: &'a str,
        pub kind: TokenKind,
        pub start: usize,
        pub end: usize,
    }

    /// Simple word tokenizer.
    pub fn tokenize_words(text: &str) -> Vec<&str> {
        text.split(|c: char| !c.is_alphanumeric())
            .filter(|s| !s.is_empty())
            .collect()
    }

    /// Tokenize with position info.
    pub fn tokenize_with_positions(text: &str) -> Vec<Token> {
        let mut tokens = Vec::new();
        let mut start = 0;

        for (i, c) in text.char_indices() {
            let kind = classify_char(c);
            let prev_kind = if i > 0 {
                tokens.last().map(|t: &Token| t.kind.clone())
            } else {
                None
            };

            match prev_kind {
                Some(pk) if pk == kind => {
                    // Continue current token
                }
                _ => {
                    if i > start {
                        tokens.push(Token {
                            text: &text[start..i],
                            kind: prev_kind.unwrap_or(TokenKind::Unknown),
                            start,
                            end: i,
                        });
                    }
                    start = i;
                }
            }
        }

        // Final token
        if start < text.len() {
            tokens.push(Token {
                text: &text[start..],
                kind: classify_char(text.chars().last().unwrap()),
                start,
                end: text.len(),
            });
        }

        tokens
    }

    fn classify_char(c: char) -> TokenKind {
        if c.is_alphabetic() {
            TokenKind::Word
        } else if c.is_numeric() {
            TokenKind::Number
        } else if c.is_whitespace() {
            TokenKind::Whitespace
        } else if c.is_ascii_punctuation() {
            TokenKind::Punctuation
        } else {
            TokenKind::Unknown
        }
    }

    /// Sentence tokenizer (simple).
    pub fn tokenize_sentences(text: &str) -> Vec<&str> {
        let mut sentences = Vec::new();
        let mut start = 0;

        for (i, c) in text.char_indices() {
            if c == '.' || c == '!' || c == '?' {
                let end = i + c.len_utf8();
                let sentence = text[start..end].trim();
                if !sentence.is_empty() {
                    sentences.push(sentence);
                }
                start = end;
            }
        }

        // Remaining text
        let remaining = text[start..].trim();
        if !remaining.is_empty() {
            sentences.push(remaining);
        }

        sentences
    }

    /// N-gram generation.
    pub fn ngrams(tokens: &[&str], n: usize) -> Vec<Vec<&str>> {
        if n == 0 || n > tokens.len() {
            return Vec::new();
        }
        (0..=tokens.len() - n)
            .map(|i| tokens[i..i + n].to_vec())
            .collect()
    }
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_string_ext() {
        assert!("   ".is_blank());
        assert!(!"hello".is_blank());
        assert_eq!("hello world".truncate(8), "hello...");
        assert_eq!("42".pad_left(5, '0'), "00042");
        assert_eq!("hi".center(6, '-'), "--hi--");
    }

    #[test]
    fn test_case_conversion() {
        assert_eq!(case::to_snake_case("HelloWorld"), "hello_world");
        assert_eq!(case::to_camel_case("hello_world"), "helloWorld");
        assert_eq!(case::to_pascal_case("hello_world"), "HelloWorld");
        assert_eq!(case::to_kebab_case("HelloWorld"), "hello-world");
    }

    #[test]
    fn test_levenshtein() {
        assert_eq!(similarity::levenshtein("kitten", "sitting"), 3);
        assert_eq!(similarity::levenshtein("", "abc"), 3);
        assert_eq!(similarity::levenshtein("abc", "abc"), 0);
    }

    #[test]
    fn test_jaro_winkler() {
        let sim = similarity::jaro_winkler("MARTHA", "MARHTA");
        assert!(sim > 0.9);
    }

    #[test]
    fn test_kmp_search() {
        let matches = search::kmp("abcabcabc", "abc");
        assert_eq!(matches, vec![0, 3, 6]);
    }

    #[test]
    fn test_word_wrap() {
        let text = "The quick brown fox jumps over the lazy dog";
        let wrapped = format::word_wrap(text, 20);
        assert!(wrapped.lines().all(|l| l.len() <= 20));
    }

    #[test]
    fn test_slugify() {
        assert_eq!(format::slugify("Hello World!"), "hello-world");
        assert_eq!(format::slugify("Café & Thé"), "caf-th");
    }

    #[test]
    fn test_ordinalize() {
        assert_eq!(format::ordinalize(1), "1st");
        assert_eq!(format::ordinalize(2), "2nd");
        assert_eq!(format::ordinalize(3), "3rd");
        assert_eq!(format::ordinalize(11), "11th");
        assert_eq!(format::ordinalize(21), "21st");
    }

    #[test]
    fn test_tokenize() {
        let tokens = tokenize::tokenize_words("Hello, world! How are you?");
        assert_eq!(tokens, vec!["Hello", "world", "How", "are", "you"]);
    }
}
