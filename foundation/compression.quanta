// Checksum Functions
// ============================================================================

/// Calculate CRC32 checksum (ISO 3309).
pub fn crc32(data: &[u8]) -> u32 {
    const TABLE: [u32; 256] = [
        0x00000000, 0x77073096, 0xee0e612c, 0x990951ba, 0x076dc419, 0x706af48f,
        0xe963a535, 0x9e6495a3, 0x0edb8832, 0x79dcb8a4, 0xe0d5e91e, 0x97d2d988,
        0x09b64c2b, 0x7eb17cbd, 0xe7b82d07, 0x90bf1d91, 0x1db71064, 0x6ab020f2,
        0xf3b97148, 0x84be41de, 0x1adad47d, 0x6ddde4eb, 0xf4d4b551, 0x83d385c7,
        0x136c9856, 0x646ba8c0, 0xfd62f97a, 0x8a65c9ec, 0x14015c4f, 0x63066cd9,
        0xfa0f3d63, 0x8d080df5, 0x3b6e20c8, 0x4c69105e, 0xd56041e4, 0xa2677172,
        0x3c03e4d1, 0x4b04d447, 0xd20d85fd, 0xa50ab56b, 0x35b5a8fa, 0x42b2986c,
        0xdbbbc9d6, 0xacbcf940, 0x32d86ce3, 0x45df5c75, 0xdcd60dcf, 0xabd13d59,
        0x26d930ac, 0x51de003a, 0xc8d75180, 0xbfd06116, 0x21b4f4b5, 0x56b3c423,
        0xcfba9599, 0xb8bda50f, 0x2802b89e, 0x5f058808, 0xc60cd9b2, 0xb10be924,
        0x2f6f7c87, 0x58684c11, 0xc1611dab, 0xb6662d3d, 0x76dc4190, 0x01db7106,
        0x98d220bc, 0xefd5102a, 0x71b18589, 0x06b6b51f, 0x9fbfe4a5, 0xe8b8d433,
        0x7807c9a2, 0x0f00f934, 0x9609a88e, 0xe10e9818, 0x7f6a0dbb, 0x086d3d2d,
        0x91646c97, 0xe6635c01, 0x6b6b51f4, 0x1c6c6162, 0x856530d8, 0xf262004e,
        0x6c0695ed, 0x1b01a57b, 0x8208f4c1, 0xf50fc457, 0x65b0d9c6, 0x12b7e950,
        0x8bbeb8ea, 0xfcb9887c, 0x62dd1ddf, 0x15da2d49, 0x8cd37cf3, 0xfbd44c65,
        0x4db26158, 0x3ab551ce, 0xa3bc0074, 0xd4bb30e2, 0x4adfa541, 0x3dd895d7,
        0xa4d1c46d, 0xd3d6f4fb, 0x4369e96a, 0x346ed9fc, 0xad678846, 0xda60b8d0,
        0x44042d73, 0x33031de5, 0xaa0a4c5f, 0xdd0d7a9b, 0x5005713c, 0x270241aa,
        0xbe0b1010, 0xc90c2086, 0x5768b525, 0x206f85b3, 0xb966d409, 0xce61e49f,
        0x5edef90e, 0x29d9c998, 0xb0d09822, 0xc7d7a8b4, 0x59b33d17, 0x2eb40d81,
        0xb7bd5c3b, 0xc0ba6cad, 0xedb88320, 0x9abfb3b6, 0x03b6e20c, 0x74b1d29a,
        0xead54739, 0x9dd277af, 0x04db2615, 0x73dc1683, 0xe3630b12, 0x94643b84,
        0x0d6d6a3e, 0x7a6a5aa8, 0xe40ecf0b, 0x9309ff9d, 0x0a00ae27, 0x7d079eb1,
        0xf00f9344, 0x8708a3d2, 0x1e01f268, 0x6906c2fe, 0xf762575d, 0x806567cb,
        0x196c3671, 0x6e6b06e7, 0xfed41b76, 0x89d32be0, 0x10da7a5a, 0x67dd4acc,
        0xf9b9df6f, 0x8ebeeff9, 0x17b7be43, 0x60b08ed5, 0xd6d6a3e8, 0xa1d1937e,
        0x38d8c2c4, 0x4fdff252, 0xd1bb67f1, 0xa6bc5767, 0x3fb506dd, 0x48b2364b,
        0xd80d2bda, 0xaf0a1b4c, 0x36034af6, 0x41047a60, 0xdf60efc3, 0xa867df55,
        0x316e8eef, 0x4669be79, 0xcb61b38c, 0xbc66831a, 0x256fd2a0, 0x5268e236,
        0xcc0c7795, 0xbb0b4703, 0x220216b9, 0x5505262f, 0xc5ba3bbe, 0xb2bd0b28,
        0x2bb45a92, 0x5cb36a04, 0xc2d7ffa7, 0xb5d0cf31, 0x2cd99e8b, 0x5bdeae1d,
        0x9b64c2b0, 0xec63f226, 0x756aa39c, 0x026d930a, 0x9c0906a9, 0xeb0e363f,
        0x72076785, 0x05005713, 0x95bf4a82, 0xe2b87a14, 0x7bb12bae, 0x0cb61b38,
        0x92d28e9b, 0xe5d5be0d, 0x7cdcefb7, 0x0bdbdf21, 0x86d3d2d4, 0xf1d4e242,
        0x68ddb3f8, 0x1fda836e, 0x81be16cd, 0xf6b9265b, 0x6fb077e1, 0x18b74777,
        0x88085ae6, 0xff0f6a70, 0x66063bca, 0x11010b5c, 0x8f659eff, 0xf862ae69,
        0x616bffd3, 0x166ccf45, 0xa00ae278, 0xd70dd2ee, 0x4e048354, 0x3903b3c2,
        0xa7672661, 0xd06016f7, 0x4969474d, 0x3e6e77db, 0xaed16a4a, 0xd9d65adc,
        0x40df0b66, 0x37d83bf0, 0xa9bcae53, 0xdebb9ec5, 0x47b2cf7f, 0x30b5ffe9,
        0xbdbdf21c, 0xcabac28a, 0x53b39330, 0x24b4a3a6, 0xbad03605, 0xcdd706b3,
        0x54de5729, 0x23d967bf, 0xb3667a2e, 0xc4614ab8, 0x5d681b02, 0x2a6f2b94,
        0xb40bbe37, 0xc30c8ea1, 0x5a05df1b, 0x2d02ef8d,
    ];

    let mut crc = !0u32;
    for byte in data {
        crc = TABLE[((crc ^ (*byte as u32)) & 0xFF) as usize] ^ (crc >> 8);
    }
    !crc
}

/// Calculate Adler-32 checksum.
pub fn adler32(data: &[u8]) -> u32 {
    const MOD_ADLER: u32 = 65521;

    let mut a = 1u32;
    let mut b = 0u32;

    for byte in data {
        a = (a + *byte as u32) % MOD_ADLER;
        b = (b + a) % MOD_ADLER;
    }

    (b << 16) | a
}

/// Calculate xxHash32.
pub fn xxhash32(data: &[u8], seed: u32) -> u32 {
    const PRIME1: u32 = 0x9E3779B1;
    const PRIME2: u32 = 0x85EBCA77;
    const PRIME3: u32 = 0xC2B2AE3D;
    const PRIME4: u32 = 0x27D4EB2F;
    const PRIME5: u32 = 0x165667B1;

    let len = data.len();
    let mut h32: u32;
    let mut pos = 0;

    if len >= 16 {
        let mut v1 = seed.wrapping_add(PRIME1).wrapping_add(PRIME2);
        let mut v2 = seed.wrapping_add(PRIME2);
        let mut v3 = seed;
        let mut v4 = seed.wrapping_sub(PRIME1);

        while pos + 16 <= len {
            let k1 = u32::from_le_bytes([data[pos], data[pos+1], data[pos+2], data[pos+3]]);
            v1 = v1.wrapping_add(k1.wrapping_mul(PRIME2)).rotate_left(13).wrapping_mul(PRIME1);
            pos += 4;

            let k2 = u32::from_le_bytes([data[pos], data[pos+1], data[pos+2], data[pos+3]]);
            v2 = v2.wrapping_add(k2.wrapping_mul(PRIME2)).rotate_left(13).wrapping_mul(PRIME1);
            pos += 4;

            let k3 = u32::from_le_bytes([data[pos], data[pos+1], data[pos+2], data[pos+3]]);
            v3 = v3.wrapping_add(k3.wrapping_mul(PRIME2)).rotate_left(13).wrapping_mul(PRIME1);
            pos += 4;

            let k4 = u32::from_le_bytes([data[pos], data[pos+1], data[pos+2], data[pos+3]]);
            v4 = v4.wrapping_add(k4.wrapping_mul(PRIME2)).rotate_left(13).wrapping_mul(PRIME1);
            pos += 4;
        }

        h32 = v1.rotate_left(1)
            .wrapping_add(v2.rotate_left(7))
            .wrapping_add(v3.rotate_left(12))
            .wrapping_add(v4.rotate_left(18));
    } else {
        h32 = seed.wrapping_add(PRIME5);
    }

    h32 = h32.wrapping_add(len as u32);

    while pos + 4 <= len {
        let k = u32::from_le_bytes([data[pos], data[pos+1], data[pos+2], data[pos+3]]);
        h32 = h32.wrapping_add(k.wrapping_mul(PRIME3)).rotate_left(17).wrapping_mul(PRIME4);
        pos += 4;
    }

    while pos < len {
        h32 = h32.wrapping_add((data[pos] as u32).wrapping_mul(PRIME5)).rotate_left(11).wrapping_mul(PRIME1);
        pos += 1;
    }

    h32 ^= h32 >> 15;
    h32 = h32.wrapping_mul(PRIME2);
    h32 ^= h32 >> 13;
    h32 = h32.wrapping_mul(PRIME3);
    h32 ^= h32 >> 16;

    h32
}

// ============================================================================
// Streaming Compression
// ============================================================================

/// Streaming deflate encoder.
pub struct DeflateEncoder<W: Write> {
    writer: W,
    level: CompressionLevel,
    buffer: Vec<u8>,
    finished: bool,
}

impl<W: Write> DeflateEncoder<W> {
    pub fn new(writer: W, level: CompressionLevel) -> Self {
        Self {
            writer,
            level,
            buffer: Vec::new(),
            finished: false,
        }
    }

    /// Write data to be compressed.
    pub fn write(self: &mut Self, data: &[u8]) -> Result<usize, CompressionError> {
        self.buffer.extend_from_slice(data);
        Ok(data.len())
    }

    /// Flush buffered data.
    pub fn flush(self: &mut Self) -> Result<(), CompressionError> {
        if self.buffer.is_empty() {
            return Ok(());
        }

        let compressed = deflate::compress(&self.buffer, self.level.clone())?;
        self.writer.write_all(&compressed).map_err(|e| CompressionError::IoError(e.to_string()))?;
        self.buffer.clear();
        Ok(())
    }

    /// Finish compression and return writer.
    pub fn finish(mut self: Self) -> Result<W, CompressionError> {
        self.flush()?;
        self.finished = true;
        Ok(self.writer)
    }
}

/// Streaming gzip encoder.
pub struct GzipEncoder<W: Write> {
    writer: W,
    level: CompressionLevel,
    buffer: Vec<u8>,
    header_written: bool,
    crc: u32,
    size: u32,
}

impl<W: Write> GzipEncoder<W> {
    pub fn new(writer: W, level: CompressionLevel) -> Self {
        Self {
            writer,
            level,
            buffer: Vec::new(),
            header_written: false,
            crc: 0,
            size: 0,
        }
    }

    fn write_header(self: &mut Self) -> Result<(), CompressionError> {
        if self.header_written {
            return Ok(());
        }

        let header = [
            0x1f, 0x8b,  // Magic
            0x08,        // Compression method (deflate)
            0x00,        // Flags
            0, 0, 0, 0,  // Modification time
            0x00,        // Extra flags
            0xff,        // OS (unknown)
        ];

        self.writer.write_all(&header).map_err(|e| CompressionError::IoError(e.to_string()))?;
        self.header_written = true;
        Ok(())
    }

    pub fn write(self: &mut Self, data: &[u8]) -> Result<usize, CompressionError> {
        self.write_header()?;
        self.buffer.extend_from_slice(data);

        // Update running CRC and size
        for byte in data {
            self.crc = crc32_update(self.crc, *byte);
            self.size = self.size.wrapping_add(1);
        }

        Ok(data.len())
    }

    pub fn finish(mut self: Self) -> Result<W, CompressionError> {
        self.write_header()?;

        // Compress buffered data
        let compressed = deflate::compress(&self.buffer, self.level)?;
        self.writer.write_all(&compressed).map_err(|e| CompressionError::IoError(e.to_string()))?;

        // Write trailer
        let crc = crc32(&self.buffer);
        self.writer.write_all(&crc.to_le_bytes()).map_err(|e| CompressionError::IoError(e.to_string()))?;
        self.writer.write_all(&self.size.to_le_bytes()).map_err(|e| CompressionError::IoError(e.to_string()))?;

        Ok(self.writer)
    }
}

fn crc32_update(crc: u32, byte: u8) -> u32 {
    // Simplified incremental CRC32 update
    let table_idx = ((crc ^ (byte as u32)) & 0xFF) as usize;
    // Would use TABLE from crc32 function
    crc >> 8  // Placeholder - full implementation uses lookup table
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_deflate_roundtrip() {
        let original = b"Hello, World! This is a test of deflate compression.";
        let compressed = deflate::compress(original, CompressionLevel::Default).unwrap();
        let decompressed = deflate::decompress(&compressed).unwrap();
        assert_eq!(original.as_slice(), decompressed.as_slice());
    }

    #[test]
    fn test_gzip_roundtrip() {
        let original = b"Gzip compression test data with some repetition: AAAAAABBBBBBCCCCCC";
        let compressed = gzip::compress(original, CompressionLevel::Default).unwrap();
        let decompressed = gzip::decompress(&compressed).unwrap();
        assert_eq!(original.as_slice(), decompressed.as_slice());
    }

    #[test]
    fn test_zlib_roundtrip() {
        let original = b"Zlib format test with various bytes: 0123456789ABCDEF";
        let compressed = zlib::compress(original, CompressionLevel::Default).unwrap();
        let decompressed = zlib::decompress(&compressed).unwrap();
        assert_eq!(original.as_slice(), decompressed.as_slice());
    }

    #[test]
    fn test_lz4_roundtrip() {
        let original = b"LZ4 is a fast compression algorithm. Fast! Fast! Fast!";
        let compressed = lz4::compress(original).unwrap();
        let decompressed = lz4::decompress(&compressed, original.len() * 2).unwrap();
        assert_eq!(original.as_slice(), decompressed.as_slice());
    }

    #[test]
    fn test_crc32() {
        let data = b"123456789";
        let crc = crc32(data);
        assert_eq!(crc, 0xCBF43926);
    }

    #[test]
    fn test_adler32() {
        let data = b"Wikipedia";
        let checksum = adler32(data);
        assert_eq!(checksum, 0x11E60398);
    }

    #[test]
    fn test_compression_levels() {
        let data = b"Test data for compression level comparison. ".repeat(100);

        let fast = deflate::compress(&data, CompressionLevel::Fast).unwrap();
        let default = deflate::compress(&data, CompressionLevel::Default).unwrap();
        let best = deflate::compress(&data, CompressionLevel::Best).unwrap();

        // Best should generally produce smallest output
        assert!(best.len() <= default.len());
        // All should decompress correctly
        assert_eq!(deflate::decompress(&fast).unwrap(), data);
        assert_eq!(deflate::decompress(&default).unwrap(), data);
        assert_eq!(deflate::decompress(&best).unwrap(), data);
    }

    #[test]
    fn test_empty_data() {
        let empty: &[u8] = &[];

        let compressed = deflate::compress(empty, CompressionLevel::Default).unwrap();
        let decompressed = deflate::decompress(&compressed).unwrap();
        assert!(decompressed.is_empty());
    }

    #[test]
    fn test_gzip_header() {
        let data = b"Test with filename";
        let mut header = gzip::GzipHeader::new();
        header.filename = Some("test.txt".to_string());
        header.mtime = 1234567890;

        let compressed = gzip::compress_with_header(data, CompressionLevel::Default, header).unwrap();
        let (parsed_header, decompressed) = gzip::decompress_with_header(&compressed).unwrap();

        assert_eq!(parsed_header.filename, Some("test.txt".to_string()));
        assert_eq!(parsed_header.mtime, 1234567890);
        assert_eq!(decompressed, data);
    }
}
