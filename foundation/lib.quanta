// ═══════════════════════════════════════════════════════════════════════════════
// STATE MACHINE MODULE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod state_machine {
    use std::collections::HashMap;
    use std::hash::Hash;

    /// Finite State Machine
    pub struct StateMachine<S: Eq + Hash + Clone, E: Eq + Hash + Clone> {
        current_state: S,
        transitions: HashMap<(S, E), S>,
        on_enter: HashMap<S, Vec<Box<dyn Fn(&S)>>>,
        on_exit: HashMap<S, Vec<Box<dyn Fn(&S)>>>,
        history: Vec<S>,
        max_history: usize,
    }

    impl<S: Eq + Hash + Clone, E: Eq + Hash + Clone> StateMachine<S, E> {
        pub fn new(initial: S) -> Self {
            Self {
                current_state: initial.clone(),
                transitions: HashMap::new(),
                on_enter: HashMap::new(),
                on_exit: HashMap::new(),
                history: vec![initial],
                max_history: 100,
            }
        }

        pub fn add_transition(&mut self, from: S, event: E, to: S) -> &mut Self {
            self.transitions.insert((from, event), to);
            self
        }

        pub fn on_enter<F: Fn(&S) + 'static>(&mut self, state: S, callback: F) -> &mut Self {
            self.on_enter.entry(state).or_insert_with(Vec::new).push(Box::new(callback));
            self
        }

        pub fn on_exit<F: Fn(&S) + 'static>(&mut self, state: S, callback: F) -> &mut Self {
            self.on_exit.entry(state).or_insert_with(Vec::new).push(Box::new(callback));
            self
        }

        pub fn process(&mut self, event: &E) -> bool {
            let key = (self.current_state.clone(), event.clone());
            if let Some(next_state) = self.transitions.get(&key).cloned() {
                // Exit callbacks
                if let Some(callbacks) = self.on_exit.get(&self.current_state) {
                    for cb in callbacks { cb(&self.current_state); }
                }
                self.current_state = next_state.clone();
                self.history.push(next_state.clone());
                if self.history.len() > self.max_history { self.history.remove(0); }
                // Enter callbacks
                if let Some(callbacks) = self.on_enter.get(&self.current_state) {
                    for cb in callbacks { cb(&self.current_state); }
                }
                true
            } else {
                false
            }
        }

        pub fn state(&self) -> &S { &self.current_state }
        pub fn history(&self) -> &[S] { &self.history }
        pub fn can_process(&self, event: &E) -> bool {
            self.transitions.contains_key(&(self.current_state.clone(), event.clone()))
        }
    }

    /// Hierarchical State Machine
    pub struct HierarchicalStateMachine<S: Eq + Hash + Clone, E: Eq + Hash + Clone> {
        current_state: S,
        parent_states: HashMap<S, S>,
        transitions: HashMap<(S, E), S>,
    }

    impl<S: Eq + Hash + Clone, E: Eq + Hash + Clone> HierarchicalStateMachine<S, E> {
        pub fn new(initial: S) -> Self {
            Self { current_state: initial, parent_states: HashMap::new(), transitions: HashMap::new() }
        }

        pub fn add_child_state(&mut self, child: S, parent: S) -> &mut Self {
            self.parent_states.insert(child, parent);
            self
        }

        pub fn add_transition(&mut self, from: S, event: E, to: S) -> &mut Self {
            self.transitions.insert((from, event), to);
            self
        }

        pub fn process(&mut self, event: &E) -> bool {
            let mut current = self.current_state.clone();
            loop {
                if let Some(next) = self.transitions.get(&(current.clone(), event.clone())).cloned() {
                    self.current_state = next;
                    return true;
                }
                if let Some(parent) = self.parent_states.get(&current).cloned() {
                    current = parent;
                } else {
                    return false;
                }
            }
        }

        pub fn state(&self) -> &S { &self.current_state }
        pub fn ancestors(&self, state: &S) -> Vec<S> {
            let mut result = Vec::new();
            let mut current = state.clone();
            while let Some(parent) = self.parent_states.get(&current).cloned() {
                result.push(parent.clone());
                current = parent;
            }
            result
        }
    }
}
pub use state_machine::*;

// ═══════════════════════════════════════════════════════════════════════════════
// GRAPH MODULE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod graph {
    use std::collections::{HashMap, HashSet, BinaryHeap, VecDeque};
    use std::cmp::Ordering;
    use std::hash::Hash;

    /// Directed graph with weighted edges
    pub struct DiGraph<N: Eq + Hash + Clone, W: Clone> {
        nodes: HashSet<N>,
        edges: HashMap<N, Vec<(N, W)>>,
    }

    impl<N: Eq + Hash + Clone, W: Clone> DiGraph<N, W> {
        pub fn new() -> Self { Self { nodes: HashSet::new(), edges: HashMap::new() } }

        pub fn add_node(&mut self, node: N) { self.nodes.insert(node); }
        pub fn add_edge(&mut self, from: N, to: N, weight: W) {
            self.nodes.insert(from.clone());
            self.nodes.insert(to.clone());
            self.edges.entry(from).or_insert_with(Vec::new).push((to, weight));
        }

        pub fn neighbors(&self, node: &N) -> Vec<&N> {
            self.edges.get(node).map(|e| e.iter().map(|(n, _)| n).collect()).unwrap_or_default()
        }

        pub fn edges_from(&self, node: &N) -> &[(N, W)] {
            self.edges.get(node).map(|e| e.as_slice()).unwrap_or(&[])
        }

        pub fn nodes(&self) -> impl Iterator<Item = &N> { self.nodes.iter() }
        pub fn node_count(&self) -> usize { self.nodes.len() }
        pub fn edge_count(&self) -> usize { self.edges.values().map(|e| e.len()).sum() }
    }

    impl<N: Eq + Hash + Clone> DiGraph<N, f64> {
        /// Dijkstra's shortest path
        pub fn dijkstra(&self, start: &N, end: &N) -> Option<(f64, Vec<N>)> {
            let mut dist: HashMap<N, f64> = HashMap::new();
            let mut prev: HashMap<N, N> = HashMap::new();
            let mut heap = BinaryHeap::new();

            dist.insert(start.clone(), 0.0);
            heap.push(DijkstraState { cost: 0.0, node: start.clone() });

            while let Some(DijkstraState { cost, node }) = heap.pop() {
                if &node == end {
                    let mut path = vec![node.clone()];
                    let mut curr = node;
                    while let Some(p) = prev.get(&curr) {
                        path.push(p.clone());
                        curr = p.clone();
                    }
                    path.reverse();
                    return Some((cost, path));
                }
                if cost > *dist.get(&node).unwrap_or(&f64::INFINITY) { continue; }
                for (neighbor, weight) in self.edges_from(&node) {
                    let next_cost = cost + weight;
                    if next_cost < *dist.get(neighbor).unwrap_or(&f64::INFINITY) {
                        dist.insert(neighbor.clone(), next_cost);
                        prev.insert(neighbor.clone(), node.clone());
                        heap.push(DijkstraState { cost: next_cost, node: neighbor.clone() });
                    }
                }
            }
            None
        }

        /// Bellman-Ford (handles negative weights)
        pub fn bellman_ford(&self, start: &N) -> Option<HashMap<N, f64>> {
            let mut dist: HashMap<N, f64> = self.nodes.iter().map(|n| (n.clone(), f64::INFINITY)).collect();
            dist.insert(start.clone(), 0.0);

            let n = self.nodes.len();
            for _ in 0..n-1 {
                for (from, edges) in &self.edges {
                    if let Some(&d) = dist.get(from) {
                        if d < f64::INFINITY {
                            for (to, weight) in edges {
                                let new_dist = d + weight;
                                if new_dist < *dist.get(to).unwrap_or(&f64::INFINITY) {
                                    dist.insert(to.clone(), new_dist);
                                }
                            }
                        }
                    }
                }
            }

            // Check for negative cycles
            for (from, edges) in &self.edges {
                if let Some(&d) = dist.get(from) {
                    for (to, weight) in edges {
                        if d + weight < *dist.get(to).unwrap_or(&f64::INFINITY) {
                            return None; // Negative cycle detected
                        }
                    }
                }
            }
            Some(dist)
        }
    }

    #[derive(Clone)]
    struct DijkstraState<N> { cost: f64, node: N }

    impl<N: Eq> PartialEq for DijkstraState<N> {
        fn eq(&self, other: &Self) -> bool { self.cost == other.cost }
    }
    impl<N: Eq> Eq for DijkstraState<N> {}
    impl<N: Eq> PartialOrd for DijkstraState<N> {
        fn partial_cmp(&self, other: &Self) -> Option<Ordering> { Some(self.cmp(other)) }
    }
    impl<N: Eq> Ord for DijkstraState<N> {
        fn cmp(&self, other: &Self) -> Ordering { other.cost.partial_cmp(&self.cost).unwrap_or(Ordering::Equal) }
    }

    impl<N: Eq + Hash + Clone, W: Clone> DiGraph<N, W> {
        /// Breadth-first search
        pub fn bfs(&self, start: &N) -> Vec<N> {
            let mut visited = HashSet::new();
            let mut queue = VecDeque::new();
            let mut result = Vec::new();

            visited.insert(start.clone());
            queue.push_back(start.clone());

            while let Some(node) = queue.pop_front() {
                result.push(node.clone());
                for neighbor in self.neighbors(&node) {
                    if !visited.contains(neighbor) {
                        visited.insert(neighbor.clone());
                        queue.push_back(neighbor.clone());
                    }
                }
            }
            result
        }

        /// Depth-first search
        pub fn dfs(&self, start: &N) -> Vec<N> {
            let mut visited = HashSet::new();
            let mut stack = vec![start.clone()];
            let mut result = Vec::new();

            while let Some(node) = stack.pop() {
                if visited.contains(&node) { continue; }
                visited.insert(node.clone());
                result.push(node.clone());
                for neighbor in self.neighbors(&node) {
                    if !visited.contains(neighbor) {
                        stack.push(neighbor.clone());
                    }
                }
            }
            result
        }

        /// Topological sort (returns None if cycle exists)
        pub fn topological_sort(&self) -> Option<Vec<N>> {
            let mut in_degree: HashMap<N, usize> = self.nodes.iter().map(|n| (n.clone(), 0)).collect();
            for edges in self.edges.values() {
                for (to, _) in edges { *in_degree.entry(to.clone()).or_insert(0) += 1; }
            }

            let mut queue: VecDeque<N> = in_degree.iter().filter(|(_, &d)| d == 0).map(|(n, _)| n.clone()).collect();
            let mut result = Vec::new();

            while let Some(node) = queue.pop_front() {
                result.push(node.clone());
                for neighbor in self.neighbors(&node) {
                    if let Some(d) = in_degree.get_mut(neighbor) {
                        *d -= 1;
                        if *d == 0 { queue.push_back(neighbor.clone()); }
                    }
                }
            }

            if result.len() == self.nodes.len() { Some(result) } else { None }
        }

        /// Find strongly connected components (Tarjan's algorithm)
        pub fn strongly_connected_components(&self) -> Vec<Vec<N>> where N: Ord {
            struct TarjanState<N> { index: usize, low_link: HashMap<N, usize>, on_stack: HashSet<N>, stack: Vec<N>, sccs: Vec<Vec<N>>, counter: usize }

            fn strongconnect<N: Eq + Hash + Clone + Ord, W: Clone>(
                graph: &DiGraph<N, W>, node: &N, state: &mut TarjanState<N>
            ) {
                state.low_link.insert(node.clone(), state.counter);
                let node_index = state.counter;
                state.counter += 1;
                state.stack.push(node.clone());
                state.on_stack.insert(node.clone());

                for neighbor in graph.neighbors(node) {
                    if !state.low_link.contains_key(neighbor) {
                        strongconnect(graph, neighbor, state);
                        let neighbor_low = *state.low_link.get(neighbor).unwrap();
                        let node_low = state.low_link.get_mut(node).unwrap();
                        *node_low = (*node_low).min(neighbor_low);
                    } else if state.on_stack.contains(neighbor) {
                        let neighbor_idx = *state.low_link.get(neighbor).unwrap();
                        let node_low = state.low_link.get_mut(node).unwrap();
                        *node_low = (*node_low).min(neighbor_idx);
                    }
                }

                if *state.low_link.get(node).unwrap() == node_index {
                    let mut scc = Vec::new();
                    while let Some(w) = state.stack.pop() {
                        state.on_stack.remove(&w);
                        scc.push(w.clone());
                        if &w == node { break; }
                    }
                    state.sccs.push(scc);
                }
            }

            let mut state = TarjanState { index: 0, low_link: HashMap::new(), on_stack: HashSet::new(), stack: Vec::new(), sccs: Vec::new(), counter: 0 };
            let mut nodes: Vec<_> = self.nodes.iter().cloned().collect();
            nodes.sort();
            for node in &nodes {
                if !state.low_link.contains_key(node) {
                    strongconnect(self, node, &mut state);
                }
            }
            state.sccs
        }
    }

    /// Undirected graph
    pub struct Graph<N: Eq + Hash + Clone, W: Clone> {
        inner: DiGraph<N, W>,
    }

    impl<N: Eq + Hash + Clone, W: Clone> Graph<N, W> {
        pub fn new() -> Self { Self { inner: DiGraph::new() } }
        pub fn add_node(&mut self, node: N) { self.inner.add_node(node); }
        pub fn add_edge(&mut self, a: N, b: N, weight: W) {
            self.inner.add_edge(a.clone(), b.clone(), weight.clone());
            self.inner.add_edge(b, a, weight);
        }
        pub fn neighbors(&self, node: &N) -> Vec<&N> { self.inner.neighbors(node) }
        pub fn bfs(&self, start: &N) -> Vec<N> { self.inner.bfs(start) }
        pub fn dfs(&self, start: &N) -> Vec<N> { self.inner.dfs(start) }
    }

    impl<N: Eq + Hash + Clone> Graph<N, f64> {
        pub fn dijkstra(&self, start: &N, end: &N) -> Option<(f64, Vec<N>)> { self.inner.dijkstra(start, end) }

        /// Minimum spanning tree (Prim's algorithm)
        pub fn minimum_spanning_tree(&self) -> Vec<(N, N, f64)> {
            if self.inner.nodes.is_empty() { return Vec::new(); }

            let mut mst = Vec::new();
            let mut visited = HashSet::new();
            let mut heap = BinaryHeap::new();

            let start = self.inner.nodes.iter().next().unwrap().clone();
            visited.insert(start.clone());
            for (neighbor, weight) in self.inner.edges_from(&start) {
                heap.push(MstEdge { from: start.clone(), to: neighbor.clone(), weight: *weight });
            }

            while let Some(MstEdge { from, to, weight }) = heap.pop() {
                if visited.contains(&to) { continue; }
                visited.insert(to.clone());
                mst.push((from.clone(), to.clone(), weight));
                for (neighbor, w) in self.inner.edges_from(&to) {
                    if !visited.contains(neighbor) {
                        heap.push(MstEdge { from: to.clone(), to: neighbor.clone(), weight: *w });
                    }
                }
            }
            mst
        }
    }

    #[derive(Clone)]
    struct MstEdge<N> { from: N, to: N, weight: f64 }
    impl<N: Eq> PartialEq for MstEdge<N> { fn eq(&self, other: &Self) -> bool { self.weight == other.weight } }
    impl<N: Eq> Eq for MstEdge<N> {}
    impl<N: Eq> PartialOrd for MstEdge<N> { fn partial_cmp(&self, other: &Self) -> Option<Ordering> { Some(self.cmp(other)) } }
    impl<N: Eq> Ord for MstEdge<N> { fn cmp(&self, other: &Self) -> Ordering { other.weight.partial_cmp(&self.weight).unwrap_or(Ordering::Equal) } }
}
pub use graph::*;

// ═══════════════════════════════════════════════════════════════════════════════
// PARSER COMBINATORS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod parser {
    /// Parse result
    pub type ParseResult<'a, T> = Result<(T, &'a str), ParseError>;

    #[derive(Debug, Clone)]
    pub struct ParseError { pub message: String, pub position: usize }

    /// Parser trait
    pub trait Parser<T>: Sized {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, T>;

        fn map<U, F: Fn(T) -> U>(self, f: F) -> Map<Self, F, T> { Map { parser: self, f, _phantom: std::marker::PhantomData } }
        fn and_then<U, P: Parser<U>, F: Fn(T) -> P>(self, f: F) -> AndThen<Self, F, T> { AndThen { parser: self, f, _phantom: std::marker::PhantomData } }
        fn or<P: Parser<T>>(self, other: P) -> Or<Self, P> { Or { first: self, second: other } }
        fn many(self) -> Many<Self> { Many { parser: self } }
        fn many1(self) -> Many1<Self> { Many1 { parser: self } }
        fn optional(self) -> Optional<Self> { Optional { parser: self } }
    }

    pub struct Map<P, F, T> { parser: P, f: F, _phantom: std::marker::PhantomData<T> }
    impl<T, U, P: Parser<T>, F: Fn(T) -> U> Parser<U> for Map<P, F, T> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, U> {
            self.parser.parse(input).map(|(val, rest)| ((self.f)(val), rest))
        }
    }

    pub struct AndThen<P, F, T> { parser: P, f: F, _phantom: std::marker::PhantomData<T> }
    impl<T, U, P: Parser<T>, P2: Parser<U>, F: Fn(T) -> P2> Parser<U> for AndThen<P, F, T> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, U> {
            let (val, rest) = self.parser.parse(input)?;
            (self.f)(val).parse(rest)
        }
    }

    pub struct Or<P1, P2> { first: P1, second: P2 }
    impl<T, P1: Parser<T>, P2: Parser<T>> Parser<T> for Or<P1, P2> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, T> {
            self.first.parse(input).or_else(|_| self.second.parse(input))
        }
    }

    pub struct Many<P> { parser: P }
    impl<T, P: Parser<T>> Parser<Vec<T>> for Many<P> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, Vec<T>> {
            let mut result = Vec::new();
            let mut remaining = input;
            while let Ok((val, rest)) = self.parser.parse(remaining) {
                result.push(val);
                remaining = rest;
            }
            Ok((result, remaining))
        }
    }

    pub struct Many1<P> { parser: P }
    impl<T, P: Parser<T>> Parser<Vec<T>> for Many1<P> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, Vec<T>> {
            let (first, rest) = self.parser.parse(input)?;
            let (mut result, remaining) = Many { parser: &self.parser }.parse(rest)?;
            result.insert(0, first);
            Ok((result, remaining))
        }
    }

    pub struct Optional<P> { parser: P }
    impl<T, P: Parser<T>> Parser<Option<T>> for Optional<P> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, Option<T>> {
            match self.parser.parse(input) {
                Ok((val, rest)) => Ok((Some(val), rest)),
                Err(_) => Ok((None, input)),
            }
        }
    }

    // Basic parsers
    pub struct Char(pub char);
    impl Parser<char> for Char {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, char> {
            input.chars().next().filter(|&c| c == self.0).map(|c| (c, &input[c.len_utf8()..]))
                .ok_or(ParseError { message: format!("expected '{}'", self.0), position: 0 })
        }
    }

    pub struct Satisfy<F>(pub F);
    impl<F: Fn(char) -> bool> Parser<char> for Satisfy<F> {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, char> {
            input.chars().next().filter(|c| (self.0)(*c)).map(|c| (c, &input[c.len_utf8()..]))
                .ok_or(ParseError { message: "predicate not satisfied".into(), position: 0 })
        }
    }

    pub struct Literal(pub &'static str);
    impl Parser<&'static str> for Literal {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, &'static str> {
            if input.starts_with(self.0) { Ok((self.0, &input[self.0.len()..])) }
            else { Err(ParseError { message: format!("expected '{}'", self.0), position: 0 }) }
        }
    }

    pub fn digit() -> Satisfy<fn(char) -> bool> { Satisfy(|c: char| c.is_ascii_digit()) }
    pub fn letter() -> Satisfy<fn(char) -> bool> { Satisfy(|c: char| c.is_alphabetic()) }
    pub fn whitespace() -> Satisfy<fn(char) -> bool> { Satisfy(|c: char| c.is_whitespace()) }
    pub fn alphanumeric() -> Satisfy<fn(char) -> bool> { Satisfy(|c: char| c.is_alphanumeric()) }

    pub struct Integer;
    impl Parser<i64> for Integer {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, i64> {
            let (neg, rest) = Char('-').optional().parse(input)?;
            let (digits, remaining): (Vec<char>, &str) = digit().many1().parse(rest)?;
            let num: i64 = digits.into_iter().collect::<String>().parse().map_err(|_| ParseError { message: "invalid integer".into(), position: 0 })?;
            Ok((if neg.is_some() { -num } else { num }, remaining))
        }
    }

    pub struct Float;
    impl Parser<f64> for Float {
        fn parse<'a>(&self, input: &'a str) -> ParseResult<'a, f64> {
            let (neg, rest) = Char('-').optional().parse(input)?;
            let (int_part, rest): (Vec<char>, &str) = digit().many1().parse(rest)?;
            let (frac, remaining) = Char('.').and_then(|_| digit().many1()).optional().parse(rest)?;
            let mut s: String = int_part.into_iter().collect();
            if let Some(frac_digits) = frac { s.push('.'); s.extend(frac_digits); }
            let num: f64 = s.parse().map_err(|_| ParseError { message: "invalid float".into(), position: 0 })?;
            Ok((if neg.is_some() { -num } else { num }, remaining))
        }
    }
}
pub use parser::*;

// ═══════════════════════════════════════════════════════════════════════════════
// EVENT SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub mod events {
    use std::collections::HashMap;
    use std::any::{Any, TypeId};
    use std::sync::{Arc, RwLock};

    /// Event bus for publish/subscribe pattern
    pub struct EventBus {
        handlers: RwLock<HashMap<TypeId, Vec<Box<dyn Fn(&dyn Any) + Send + Sync>>>>,
    }

    impl EventBus {
        pub fn new() -> Self { Self { handlers: RwLock::new(HashMap::new()) } }

        pub fn subscribe<E: 'static, F: Fn(&E) + Send + Sync + 'static>(&self, handler: F) {
            let type_id = TypeId::of::<E>();
            let wrapped = move |event: &dyn Any| {
                if let Some(e) = event.downcast_ref::<E>() { handler(e); }
            };
            self.handlers.write().unwrap().entry(type_id).or_insert_with(Vec::new).push(Box::new(wrapped));
        }

        pub fn publish<E: 'static>(&self, event: &E) {
            let type_id = TypeId::of::<E>();
            if let Some(handlers) = self.handlers.read().unwrap().get(&type_id) {
                for handler in handlers { handler(event); }
            }
        }
    }

    /// Typed event channel
    pub struct EventChannel<E> {
        buffer: Arc<RwLock<Vec<E>>>,
        readers: Arc<RwLock<Vec<usize>>>,
    }

    impl<E: Clone> EventChannel<E> {
        pub fn new() -> Self { Self { buffer: Arc::new(RwLock::new(Vec::new())), readers: Arc::new(RwLock::new(Vec::new())) } }

        pub fn send(&self, event: E) { self.buffer.write().unwrap().push(event); }

        pub fn reader(&self) -> EventReader<E> {
            let id = {
                let mut readers = self.readers.write().unwrap();
                let id = readers.len();
                readers.push(self.buffer.read().unwrap().len());
                id
            };
            EventReader { channel: self.clone(), id }
        }
    }

    impl<E> Clone for EventChannel<E> {
        fn clone(&self) -> Self { Self { buffer: self.buffer.clone(), readers: self.readers.clone() } }
    }

    pub struct EventReader<E> { channel: EventChannel<E>, id: usize }

    impl<E: Clone> EventReader<E> {
        pub fn read(&self) -> Vec<E> {
            let buffer = self.channel.buffer.read().unwrap();
            let mut readers = self.channel.readers.write().unwrap();
            let start = readers[self.id];
            let events: Vec<E> = buffer[start..].to_vec();
            readers[self.id] = buffer.len();
            events
        }
    }

    /// Simple event emitter
    pub struct EventEmitter<E> {
        listeners: Vec<Box<dyn Fn(&E) + Send + Sync>>,
    }

    impl<E> EventEmitter<E> {
        pub fn new() -> Self { Self { listeners: Vec::new() } }
        pub fn on<F: Fn(&E) + Send + Sync + 'static>(&mut self, listener: F) { self.listeners.push(Box::new(listener)); }
        pub fn emit(&self, event: &E) { for listener in &self.listeners { listener(event); } }
        pub fn off_all(&mut self) { self.listeners.clear(); }
    }
}
pub use events::*;

// ═══════════════════════════════════════════════════════════════════════════════
// RESULT EXTENSIONS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod result_ext {
    /// Extension trait for Result
    pub trait ResultExt<T, E> {
        fn ok_or_log(self, msg: &str) -> Option<T> where E: std::fmt::Debug;
        fn map_err_ctx<C: std::fmt::Display>(self, context: C) -> Result<T, String> where E: std::fmt::Display;
        fn tap<F: FnOnce(&T)>(self, f: F) -> Self;
        fn tap_err<F: FnOnce(&E)>(self, f: F) -> Self;
    }

    impl<T, E> ResultExt<T, E> for Result<T, E> {
        fn ok_or_log(self, msg: &str) -> Option<T> where E: std::fmt::Debug {
            match self {
                Ok(v) => Some(v),
                Err(e) => { eprintln!("{}: {:?}", msg, e); None }
            }
        }

        fn map_err_ctx<C: std::fmt::Display>(self, context: C) -> Result<T, String> where E: std::fmt::Display {
            self.map_err(|e| format!("{}: {}", context, e))
        }

        fn tap<F: FnOnce(&T)>(self, f: F) -> Self {
            if let Ok(ref v) = self { f(v); }
            self
        }

        fn tap_err<F: FnOnce(&E)>(self, f: F) -> Self {
            if let Err(ref e) = self { f(e); }
            self
        }
    }

    /// Extension trait for Option
    pub trait OptionExt<T> {
        fn ok_or_log(self, msg: &str) -> Option<T>;
        fn tap<F: FnOnce(&T)>(self, f: F) -> Self;
    }

    impl<T> OptionExt<T> for Option<T> {
        fn ok_or_log(self, msg: &str) -> Option<T> {
            if self.is_none() { eprintln!("{}", msg); }
            self
        }

        fn tap<F: FnOnce(&T)>(self, f: F) -> Self {
            if let Some(ref v) = self { f(v); }
            self
        }
    }

    /// Try macro for early returns with context
    #[macro_export]
    macro_rules! try_ctx {
        ($expr:expr, $ctx:expr) => {
            match $expr {
                Ok(val) => val,
                Err(e) => return Err(format!("{}: {}", $ctx, e)),
            }
        };
    }

    /// Ensure macro for assertions that return errors
    #[macro_export]
    macro_rules! ensure {
        ($cond:expr, $msg:expr) => {
            if !$cond { return Err($msg.into()); }
        };
    }
}
pub use result_ext::*;

// ═══════════════════════════════════════════════════════════════════════════════
// ASYNC RUNTIME MODULE - Production Async Execution System
// ═══════════════════════════════════════════════════════════════════════════════

pub mod async_runtime {
    use std::sync::{Arc, Mutex, Condvar, atomic::{AtomicBool, AtomicUsize, Ordering}};
    use std::collections::{VecDeque, HashMap, BinaryHeap};
    use std::time::{Duration, Instant};

    /// Task priority levels
    #[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
    pub enum TaskPriority {
        Low = 0,
        Normal = 1,
        High = 2,
        Critical = 3,
    }

    /// Task state in the runtime
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum TaskState {
        Pending,
        Running,
        Blocked,
        Completed,
        Cancelled,
        Failed,
    }

    /// Async task handle
    pub struct TaskHandle<T> {
        pub id: u64,
        pub priority: TaskPriority,
        pub state: Arc<Mutex<TaskState>>,
        pub result: Arc<Mutex<Option<Result<T, String>>>>,
        pub waker: Arc<Condvar>,
    }

    impl<T> TaskHandle<T> {
        pub fn new(id: u64, priority: TaskPriority) -> Self {
            Self {
                id,
                priority,
                state: Arc::new(Mutex::new(TaskState::Pending)),
                result: Arc::new(Mutex::new(None)),
                waker: Arc::new(Condvar::new()),
            }
        }

        pub fn is_complete(&self) -> bool {
            let state = self.state.lock().unwrap();
            matches!(*state, TaskState::Completed | TaskState::Failed | TaskState::Cancelled)
        }

        pub fn await_result(&self, timeout: Option<Duration>) -> Option<Result<T, String>> {
            let mut state = self.state.lock().unwrap();
            let deadline = timeout.map(|t| Instant::now() + t);
            while !self.is_complete() {
                if let Some(dl) = deadline {
                    if Instant::now() >= dl { return None; }
                    let remaining = dl.saturating_duration_since(Instant::now());
                    state = self.waker.wait_timeout(state, remaining).unwrap().0;
                } else {
                    state = self.waker.wait(state).unwrap();
                }
            }
            self.result.lock().unwrap().take()
        }

        pub fn cancel(&self) -> bool {
            let mut state = self.state.lock().unwrap();
            if *state == TaskState::Pending {
                *state = TaskState::Cancelled;
                self.waker.notify_all();
                true
            } else { false }
        }
    }

    /// Work-stealing task queue
    pub struct WorkStealingQueue<T> {
        local_queue: Mutex<VecDeque<T>>,
        steal_half: bool,
    }

    impl<T> WorkStealingQueue<T> {
        pub fn new() -> Self {
            Self { local_queue: Mutex::new(VecDeque::new()), steal_half: true }
        }

        pub fn push(&self, task: T) {
            self.local_queue.lock().unwrap().push_back(task);
        }

        pub fn pop(&self) -> Option<T> {
            self.local_queue.lock().unwrap().pop_front()
        }

        pub fn steal(&self) -> Vec<T> {
            let mut queue = self.local_queue.lock().unwrap();
            if self.steal_half {
                let half = queue.len() / 2;
                queue.drain(..half).collect()
            } else {
                queue.pop_front().map(|t| vec![t]).unwrap_or_default()
            }
        }

        pub fn len(&self) -> usize {
            self.local_queue.lock().unwrap().len()
        }
    }

    /// Timer entry for delayed tasks
    #[derive(Debug)]
    pub struct TimerEntry {
        pub deadline: Instant,
        pub task_id: u64,
    }

    impl PartialEq for TimerEntry {
        fn eq(&self, other: &Self) -> bool { self.deadline == other.deadline }
    }
    impl Eq for TimerEntry {}
    impl PartialOrd for TimerEntry {
        fn partial_cmp(&self, other: &Self) -> Option<std::cmp::Ordering> {
            Some(self.cmp(other))
        }
    }
    impl Ord for TimerEntry {
        fn cmp(&self, other: &Self) -> std::cmp::Ordering {
            other.deadline.cmp(&self.deadline) // Min-heap
        }
    }

    /// Timer wheel for efficient timer management
    pub struct TimerWheel {
        wheel: Vec<Vec<TimerEntry>>,
        wheel_size: usize,
        current_tick: usize,
        tick_duration: Duration,
        overflow: BinaryHeap<TimerEntry>,
    }

    impl TimerWheel {
        pub fn new(wheel_size: usize, tick_duration: Duration) -> Self {
            Self {
                wheel: (0..wheel_size).map(|_| Vec::new()).collect(),
                wheel_size,
                current_tick: 0,
                tick_duration,
                overflow: BinaryHeap::new(),
            }
        }

        pub fn insert(&mut self, deadline: Instant, task_id: u64) {
            let now = Instant::now();
            if deadline <= now {
                self.wheel[self.current_tick].push(TimerEntry { deadline, task_id });
                return;
            }
            let ticks_away = (deadline.duration_since(now).as_nanos() /
                              self.tick_duration.as_nanos()) as usize;
            if ticks_away < self.wheel_size {
                let slot = (self.current_tick + ticks_away) % self.wheel_size;
                self.wheel[slot].push(TimerEntry { deadline, task_id });
            } else {
                self.overflow.push(TimerEntry { deadline, task_id });
            }
        }

        pub fn advance(&mut self) -> Vec<u64> {
            self.current_tick = (self.current_tick + 1) % self.wheel_size;
            let expired: Vec<u64> = self.wheel[self.current_tick].drain(..)
                .map(|e| e.task_id).collect();
            // Check overflow
            let now = Instant::now();
            while let Some(entry) = self.overflow.peek() {
                if entry.deadline <= now + self.tick_duration * self.wheel_size as u32 {
                    let entry = self.overflow.pop().unwrap();
                    self.insert(entry.deadline, entry.task_id);
                } else { break; }
            }
            expired
        }
    }

    /// Async runtime configuration
    pub struct RuntimeConfig {
        pub num_workers: usize,
        pub worker_stack_size: usize,
        pub max_blocking_threads: usize,
        pub enable_io: bool,
        pub enable_time: bool,
        pub thread_name_prefix: String,
    }

    impl Default for RuntimeConfig {
        fn default() -> Self {
            Self {
                num_workers: num_cpus::get(),
                worker_stack_size: 2 * 1024 * 1024,
                max_blocking_threads: 512,
                enable_io: true,
                enable_time: true,
                thread_name_prefix: "quanta-worker".into(),
            }
        }
    }

    /// Multi-threaded async runtime
    pub struct Runtime {
        config: RuntimeConfig,
        shutdown: AtomicBool,
        task_counter: AtomicUsize,
        global_queue: Arc<WorkStealingQueue<Box<dyn FnOnce() + Send>>>,
        worker_queues: Vec<Arc<WorkStealingQueue<Box<dyn FnOnce() + Send>>>>,
        timer_wheel: Mutex<TimerWheel>,
        pending_tasks: Mutex<HashMap<u64, TaskState>>,
    }

    impl Runtime {
        pub fn new(config: RuntimeConfig) -> Self {
            let num_workers = config.num_workers.max(1);
            let worker_queues = (0..num_workers)
                .map(|_| Arc::new(WorkStealingQueue::new()))
                .collect();
            Self {
                config,
                shutdown: AtomicBool::new(false),
                task_counter: AtomicUsize::new(0),
                global_queue: Arc::new(WorkStealingQueue::new()),
                worker_queues,
                timer_wheel: Mutex::new(TimerWheel::new(4096, Duration::from_millis(1))),
                pending_tasks: Mutex::new(HashMap::new()),
            }
        }

        pub fn spawn<F, T>(&self, f: F) -> TaskHandle<T>
        where F: FnOnce() -> T + Send + 'static, T: Send + 'static {
            let id = self.task_counter.fetch_add(1, Ordering::SeqCst) as u64;
            let handle = TaskHandle::new(id, TaskPriority::Normal);
            let state = handle.state.clone();
            let result = handle.result.clone();
            let waker = handle.waker.clone();
            self.global_queue.push(Box::new(move || {
                *state.lock().unwrap() = TaskState::Running;
                let res = std::panic::catch_unwind(std::panic::AssertUnwindSafe(f));
                match res {
                    Ok(val) => {
                        *result.lock().unwrap() = Some(Ok(val));
                        *state.lock().unwrap() = TaskState::Completed;
                    }
                    Err(_) => {
                        *result.lock().unwrap() = Some(Err("Task panicked".into()));
                        *state.lock().unwrap() = TaskState::Failed;
                    }
                }
                waker.notify_all();
            }));
            self.pending_tasks.lock().unwrap().insert(id, TaskState::Pending);
            handle
        }

        pub fn spawn_delayed<F, T>(&self, delay: Duration, f: F) -> TaskHandle<T>
        where F: FnOnce() -> T + Send + 'static, T: Send + 'static {
            let id = self.task_counter.fetch_add(1, Ordering::SeqCst) as u64;
            let deadline = Instant::now() + delay;
            self.timer_wheel.lock().unwrap().insert(deadline, id);
            TaskHandle::new(id, TaskPriority::Normal)
        }

        pub fn block_on<F, T>(&self, f: F) -> T where F: FnOnce() -> T {
            f()
        }

        pub fn shutdown(&self) {
            self.shutdown.store(true, Ordering::SeqCst);
        }

        pub fn pending_count(&self) -> usize {
            self.pending_tasks.lock().unwrap().len()
        }
    }

    /// Oneshot channel for single value communication
    pub struct OneshotSender<T> {
        value: Arc<Mutex<Option<T>>>,
        signaled: Arc<AtomicBool>,
        waker: Arc<Condvar>,
    }

    pub struct OneshotReceiver<T> {
        value: Arc<Mutex<Option<T>>>,
        signaled: Arc<AtomicBool>,
        waker: Arc<Condvar>,
    }

    pub fn oneshot<T>() -> (OneshotSender<T>, OneshotReceiver<T>) {
        let value = Arc::new(Mutex::new(None));
        let signaled = Arc::new(AtomicBool::new(false));
        let waker = Arc::new(Condvar::new());
        (
            OneshotSender { value: value.clone(), signaled: signaled.clone(), waker: waker.clone() },
            OneshotReceiver { value, signaled, waker },
        )
    }

    impl<T> OneshotSender<T> {
        pub fn send(self, val: T) -> Result<(), T> {
            if self.signaled.load(Ordering::Acquire) {
                return Err(val);
            }
            *self.value.lock().unwrap() = Some(val);
            self.signaled.store(true, Ordering::Release);
            self.waker.notify_all();
            Ok(())
        }
    }

    impl<T> OneshotReceiver<T> {
        pub fn recv(self) -> Result<T, ()> {
            let mut guard = self.value.lock().unwrap();
            while !self.signaled.load(Ordering::Acquire) {
                guard = self.waker.wait(guard).unwrap();
            }
            guard.take().ok_or(())
        }

        pub fn try_recv(&self) -> Option<T> {
            if self.signaled.load(Ordering::Acquire) {
                self.value.lock().unwrap().take()
            } else { None }
        }
    }

    /// Broadcast channel for multiple receivers
    pub struct BroadcastSender<T: Clone> {
        receivers: Arc<Mutex<Vec<Arc<Mutex<VecDeque<T>>>>>>,
        capacity: usize,
    }

    pub struct BroadcastReceiver<T: Clone> {
        queue: Arc<Mutex<VecDeque<T>>>,
    }

    impl<T: Clone> BroadcastSender<T> {
        pub fn new(capacity: usize) -> Self {
            Self { receivers: Arc::new(Mutex::new(Vec::new())), capacity }
        }

        pub fn subscribe(&self) -> BroadcastReceiver<T> {
            let queue = Arc::new(Mutex::new(VecDeque::with_capacity(self.capacity)));
            self.receivers.lock().unwrap().push(queue.clone());
            BroadcastReceiver { queue }
        }

        pub fn send(&self, value: T) {
            let receivers = self.receivers.lock().unwrap();
            for rx in receivers.iter() {
                let mut q = rx.lock().unwrap();
                if q.len() >= self.capacity { q.pop_front(); }
                q.push_back(value.clone());
            }
        }
    }

    impl<T: Clone> BroadcastReceiver<T> {
        pub fn recv(&self) -> Option<T> {
            self.queue.lock().unwrap().pop_front()
        }
    }

    /// Watch channel for latest value observation
    pub struct WatchSender<T: Clone> {
        value: Arc<Mutex<T>>,
        version: Arc<AtomicUsize>,
    }

    pub struct WatchReceiver<T: Clone> {
        value: Arc<Mutex<T>>,
        version: Arc<AtomicUsize>,
        last_seen: usize,
    }

    impl<T: Clone> WatchSender<T> {
        pub fn new(initial: T) -> (Self, WatchReceiver<T>) {
            let value = Arc::new(Mutex::new(initial));
            let version = Arc::new(AtomicUsize::new(0));
            let rx = WatchReceiver {
                value: value.clone(),
                version: version.clone(),
                last_seen: 0
            };
            (Self { value, version }, rx)
        }

        pub fn send(&self, val: T) {
            *self.value.lock().unwrap() = val;
            self.version.fetch_add(1, Ordering::SeqCst);
        }
    }

    impl<T: Clone> WatchReceiver<T> {
        pub fn borrow(&self) -> T {
            self.value.lock().unwrap().clone()
        }

        pub fn has_changed(&self) -> bool {
            self.version.load(Ordering::Acquire) > self.last_seen
        }

        pub fn changed(&mut self) -> Option<T> {
            let current = self.version.load(Ordering::Acquire);
            if current > self.last_seen {
                self.last_seen = current;
                Some(self.value.lock().unwrap().clone())
            } else { None }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEMORY POOL MODULE - High-Performance Object Pooling
// ═══════════════════════════════════════════════════════════════════════════════

pub mod memory_pool {
    use std::sync::{Arc, Mutex, atomic::{AtomicUsize, Ordering}};
    use std::collections::VecDeque;

    /// Object pool statistics
    #[derive(Debug, Clone, Default)]
    pub struct PoolStats {
        pub created: usize,
        pub reused: usize,
        pub returned: usize,
        pub current_size: usize,
        pub peak_size: usize,
    }

    /// Generic object pool with creation callback
    pub struct ObjectPool<T> {
        pool: Mutex<VecDeque<T>>,
        creator: Box<dyn Fn() -> T + Send + Sync>,
        resetter: Option<Box<dyn Fn(&mut T) + Send + Sync>>,
        max_size: usize,
        stats: Mutex<PoolStats>,
    }

    impl<T> ObjectPool<T> {
        pub fn new<F>(max_size: usize, creator: F) -> Self
        where F: Fn() -> T + Send + Sync + 'static {
            Self {
                pool: Mutex::new(VecDeque::with_capacity(max_size)),
                creator: Box::new(creator),
                resetter: None,
                max_size,
                stats: Mutex::new(PoolStats::default()),
            }
        }

        pub fn with_resetter<F, R>(mut self, resetter: R) -> Self
        where R: Fn(&mut T) + Send + Sync + 'static {
            self.resetter = Some(Box::new(resetter));
            self
        }

        pub fn acquire(&self) -> T {
            let mut stats = self.stats.lock().unwrap();
            if let Some(obj) = self.pool.lock().unwrap().pop_front() {
                stats.reused += 1;
                stats.current_size -= 1;
                obj
            } else {
                stats.created += 1;
                (self.creator)()
            }
        }

        pub fn release(&self, mut obj: T) {
            let mut pool = self.pool.lock().unwrap();
            let mut stats = self.stats.lock().unwrap();
            if pool.len() < self.max_size {
                if let Some(ref resetter) = self.resetter {
                    resetter(&mut obj);
                }
                pool.push_back(obj);
                stats.returned += 1;
                stats.current_size += 1;
                stats.peak_size = stats.peak_size.max(stats.current_size);
            }
        }

        pub fn stats(&self) -> PoolStats {
            self.stats.lock().unwrap().clone()
        }

        pub fn clear(&self) {
            self.pool.lock().unwrap().clear();
            self.stats.lock().unwrap().current_size = 0;
        }

        pub fn prewarm(&self, count: usize) {
            let mut pool = self.pool.lock().unwrap();
            let mut stats = self.stats.lock().unwrap();
            let to_create = count.min(self.max_size).saturating_sub(pool.len());
            for _ in 0..to_create {
                pool.push_back((self.creator)());
                stats.created += 1;
                stats.current_size += 1;
            }
            stats.peak_size = stats.peak_size.max(stats.current_size);
        }
    }

    /// RAII guard for pooled objects
    pub struct PooledObject<'a, T> {
        pool: &'a ObjectPool<T>,
        object: Option<T>,
    }

    impl<'a, T> PooledObject<'a, T> {
        pub fn new(pool: &'a ObjectPool<T>) -> Self {
            Self { pool, object: Some(pool.acquire()) }
        }
    }

    impl<T> std::ops::Deref for PooledObject<'_, T> {
        type Target = T;
        fn deref(&self) -> &T { self.object.as_ref().unwrap() }
    }

    impl<T> std::ops::DerefMut for PooledObject<'_, T> {
        fn deref_mut(&mut self) -> &mut T { self.object.as_mut().unwrap() }
    }

    impl<T> Drop for PooledObject<'_, T> {
        fn drop(&mut self) {
            if let Some(obj) = self.object.take() {
                self.pool.release(obj);
            }
        }
    }

    /// Slab allocator for fixed-size blocks
    pub struct SlabAllocator<T> {
        slabs: Mutex<Vec<Box<[Option<T>]>>>,
        free_list: Mutex<Vec<usize>>,
        slab_size: usize,
        total_allocated: AtomicUsize,
    }

    impl<T: Default + Clone> SlabAllocator<T> {
        pub fn new(slab_size: usize) -> Self {
            Self {
                slabs: Mutex::new(Vec::new()),
                free_list: Mutex::new(Vec::new()),
                slab_size,
                total_allocated: AtomicUsize::new(0),
            }
        }

        pub fn allocate(&self) -> usize {
            let mut free = self.free_list.lock().unwrap();
            if let Some(idx) = free.pop() {
                return idx;
            }
            drop(free);
            let mut slabs = self.slabs.lock().unwrap();
            let slab_idx = slabs.len();
            let new_slab: Box<[Option<T>]> = (0..self.slab_size)
                .map(|_| None)
                .collect::<Vec<_>>()
                .into_boxed_slice();
            slabs.push(new_slab);
            let base = slab_idx * self.slab_size;
            let mut free = self.free_list.lock().unwrap();
            for i in (1..self.slab_size).rev() {
                free.push(base + i);
            }
            self.total_allocated.fetch_add(1, Ordering::SeqCst);
            base
        }

        pub fn deallocate(&self, index: usize) {
            let slab_idx = index / self.slab_size;
            let slot = index % self.slab_size;
            let mut slabs = self.slabs.lock().unwrap();
            if let Some(slab) = slabs.get_mut(slab_idx) {
                slab[slot] = None;
            }
            self.free_list.lock().unwrap().push(index);
        }

        pub fn get(&self, index: usize) -> Option<T> where T: Clone {
            let slab_idx = index / self.slab_size;
            let slot = index % self.slab_size;
            let slabs = self.slabs.lock().unwrap();
            slabs.get(slab_idx).and_then(|s| s[slot].clone())
        }

        pub fn set(&self, index: usize, value: T) {
            let slab_idx = index / self.slab_size;
            let slot = index % self.slab_size;
            let mut slabs = self.slabs.lock().unwrap();
            if let Some(slab) = slabs.get_mut(slab_idx) {
                slab[slot] = Some(value);
            }
        }

        pub fn allocated_count(&self) -> usize {
            self.total_allocated.load(Ordering::Acquire)
        }
    }

    /// Arena allocator for batch allocations
    pub struct Arena {
        chunks: Mutex<Vec<Vec<u8>>>,
        chunk_size: usize,
        current_offset: AtomicUsize,
    }

    impl Arena {
        pub fn new(chunk_size: usize) -> Self {
            Self {
                chunks: Mutex::new(vec![vec![0u8; chunk_size]]),
                chunk_size,
                current_offset: AtomicUsize::new(0),
            }
        }

        pub fn alloc(&self, size: usize, align: usize) -> *mut u8 {
            let mut offset = self.current_offset.load(Ordering::Acquire);
            let aligned = (offset + align - 1) & !(align - 1);
            if aligned + size > self.chunk_size {
                let mut chunks = self.chunks.lock().unwrap();
                chunks.push(vec![0u8; self.chunk_size.max(size)]);
                self.current_offset.store(size, Ordering::Release);
                return chunks.last_mut().unwrap().as_mut_ptr();
            }
            self.current_offset.store(aligned + size, Ordering::Release);
            let chunks = self.chunks.lock().unwrap();
            unsafe { chunks.last().unwrap().as_ptr().add(aligned) as *mut u8 }
        }

        pub fn reset(&self) {
            let mut chunks = self.chunks.lock().unwrap();
            chunks.truncate(1);
            if let Some(first) = chunks.first_mut() {
                first.fill(0);
            }
            self.current_offset.store(0, Ordering::Release);
        }

        pub fn allocated_bytes(&self) -> usize {
            let chunks = self.chunks.lock().unwrap();
            (chunks.len() - 1) * self.chunk_size + self.current_offset.load(Ordering::Acquire)
        }
    }

    /// Bump allocator for linear allocation
    pub struct BumpAllocator {
        buffer: Vec<u8>,
        offset: usize,
    }

    impl BumpAllocator {
        pub fn new(capacity: usize) -> Self {
            Self { buffer: vec![0u8; capacity], offset: 0 }
        }

        pub fn alloc<T: Default>(&mut self) -> Option<&mut T> {
            let size = std::mem::size_of::<T>();
            let align = std::mem::align_of::<T>();
            let aligned = (self.offset + align - 1) & !(align - 1);
            if aligned + size > self.buffer.len() { return None; }
            self.offset = aligned + size;
            let ptr = self.buffer[aligned..].as_mut_ptr() as *mut T;
            unsafe {
                ptr.write(T::default());
                Some(&mut *ptr)
            }
        }

        pub fn reset(&mut self) {
            self.offset = 0;
            self.buffer.fill(0);
        }

        pub fn remaining(&self) -> usize {
            self.buffer.len() - self.offset
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VALIDATION MODULE - Data Validation Framework
// ═══════════════════════════════════════════════════════════════════════════════

pub mod validation {
    use std::collections::HashMap;

    /// Validation error with field path
    #[derive(Debug, Clone)]
    pub struct ValidationError {
        pub field: String,
        pub message: String,
        pub code: String,
    }

    impl ValidationError {
        pub fn new(field: &str, message: &str, code: &str) -> Self {
            Self { field: field.into(), message: message.into(), code: code.into() }
        }
    }

    /// Validation result
    pub type ValidationResult = Result<(), Vec<ValidationError>>;

    /// Validatable trait
    pub trait Validate {
        fn validate(&self) -> ValidationResult;
    }

    /// Validation rule builder
    pub struct Validator<T> {
        rules: Vec<Box<dyn Fn(&T) -> Option<ValidationError>>>,
    }

    impl<T> Validator<T> {
        pub fn new() -> Self {
            Self { rules: Vec::new() }
        }

        pub fn rule<F>(mut self, f: F) -> Self
        where F: Fn(&T) -> Option<ValidationError> + 'static {
            self.rules.push(Box::new(f));
            self
        }

        pub fn validate(&self, value: &T) -> ValidationResult {
            let errors: Vec<_> = self.rules.iter()
                .filter_map(|rule| rule(value))
                .collect();
            if errors.is_empty() { Ok(()) } else { Err(errors) }
        }
    }

    /// String validation rules
    pub struct StringValidator {
        field: String,
        min_len: Option<usize>,
        max_len: Option<usize>,
        pattern: Option<String>,
        not_empty: bool,
        trim: bool,
    }

    impl StringValidator {
        pub fn new(field: &str) -> Self {
            Self {
                field: field.into(),
                min_len: None,
                max_len: None,
                pattern: None,
                not_empty: false,
                trim: false,
            }
        }

        pub fn min_length(mut self, len: usize) -> Self {
            self.min_len = Some(len);
            self
        }

        pub fn max_length(mut self, len: usize) -> Self {
            self.max_len = Some(len);
            self
        }

        pub fn not_empty(mut self) -> Self {
            self.not_empty = true;
            self
        }

        pub fn pattern(mut self, regex: &str) -> Self {
            self.pattern = Some(regex.into());
            self
        }

        pub fn validate(&self, value: &str) -> Vec<ValidationError> {
            let mut errors = Vec::new();
            let val = if self.trim { value.trim() } else { value };
            if self.not_empty && val.is_empty() {
                errors.push(ValidationError::new(&self.field, "must not be empty", "NOT_EMPTY"));
            }
            if let Some(min) = self.min_len {
                if val.len() < min {
                    errors.push(ValidationError::new(&self.field,
                        &format!("must be at least {} characters", min), "MIN_LENGTH"));
                }
            }
            if let Some(max) = self.max_len {
                if val.len() > max {
                    errors.push(ValidationError::new(&self.field,
                        &format!("must be at most {} characters", max), "MAX_LENGTH"));
                }
            }
            errors
        }
    }

    /// Numeric validation rules
    pub struct NumberValidator<T> {
        field: String,
        min: Option<T>,
        max: Option<T>,
        positive: bool,
        non_zero: bool,
    }

    impl<T: PartialOrd + Default + Copy + std::fmt::Display> NumberValidator<T> {
        pub fn new(field: &str) -> Self {
            Self { field: field.into(), min: None, max: None, positive: false, non_zero: false }
        }

        pub fn min(mut self, val: T) -> Self { self.min = Some(val); self }
        pub fn max(mut self, val: T) -> Self { self.max = Some(val); self }
        pub fn positive(mut self) -> Self { self.positive = true; self }
        pub fn non_zero(mut self) -> Self { self.non_zero = true; self }

        pub fn validate(&self, value: T) -> Vec<ValidationError> {
            let mut errors = Vec::new();
            if let Some(min) = self.min {
                if value < min {
                    errors.push(ValidationError::new(&self.field,
                        &format!("must be at least {}", min), "MIN_VALUE"));
                }
            }
            if let Some(max) = self.max {
                if value > max {
                    errors.push(ValidationError::new(&self.field,
                        &format!("must be at most {}", max), "MAX_VALUE"));
                }
            }
            if self.positive && value < T::default() {
                errors.push(ValidationError::new(&self.field, "must be positive", "POSITIVE"));
            }
            if self.non_zero && value == T::default() {
                errors.push(ValidationError::new(&self.field, "must not be zero", "NON_ZERO"));
            }
            errors
        }
    }

    /// Email validator
    pub fn validate_email(field: &str, email: &str) -> Option<ValidationError> {
        if email.is_empty() {
            return Some(ValidationError::new(field, "email is required", "REQUIRED"));
        }
        if !email.contains('@') || !email.contains('.') {
            return Some(ValidationError::new(field, "invalid email format", "INVALID_EMAIL"));
        }
        let parts: Vec<&str> = email.split('@').collect();
        if parts.len() != 2 || parts[0].is_empty() || parts[1].is_empty() {
            return Some(ValidationError::new(field, "invalid email format", "INVALID_EMAIL"));
        }
        None
    }

    /// URL validator
    pub fn validate_url(field: &str, url: &str) -> Option<ValidationError> {
        if url.is_empty() {
            return Some(ValidationError::new(field, "URL is required", "REQUIRED"));
        }
        if !url.starts_with("http://") && !url.starts_with("https://") {
            return Some(ValidationError::new(field, "URL must start with http:// or https://", "INVALID_URL"));
        }
        None
    }

    /// Schema-based validator
    pub struct Schema {
        fields: HashMap<String, FieldSchema>,
    }

    pub struct FieldSchema {
        pub required: bool,
        pub field_type: FieldType,
        pub rules: Vec<Box<dyn Fn(&str) -> Option<ValidationError>>>,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum FieldType {
        String,
        Integer,
        Float,
        Boolean,
        Email,
        Url,
        Date,
        Array,
        Object,
    }

    impl Schema {
        pub fn new() -> Self {
            Self { fields: HashMap::new() }
        }

        pub fn field(mut self, name: &str, schema: FieldSchema) -> Self {
            self.fields.insert(name.into(), schema);
            self
        }

        pub fn validate(&self, data: &HashMap<String, String>) -> ValidationResult {
            let mut errors = Vec::new();
            for (name, schema) in &self.fields {
                if let Some(value) = data.get(name) {
                    for rule in &schema.rules {
                        if let Some(err) = rule(value) {
                            errors.push(err);
                        }
                    }
                } else if schema.required {
                    errors.push(ValidationError::new(name, "field is required", "REQUIRED"));
                }
            }
            if errors.is_empty() { Ok(()) } else { Err(errors) }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// RETRY MODULE - Fault Tolerance and Retry Policies
// ═══════════════════════════════════════════════════════════════════════════════

pub mod retry {
    use std::time::{Duration, Instant};
    use std::thread;

    /// Retry policy configuration
    #[derive(Debug, Clone)]
    pub struct RetryPolicy {
        pub max_attempts: usize,
        pub initial_delay: Duration,
        pub max_delay: Duration,
        pub backoff: BackoffStrategy,
        pub jitter: bool,
    }

    impl Default for RetryPolicy {
        fn default() -> Self {
            Self {
                max_attempts: 3,
                initial_delay: Duration::from_millis(100),
                max_delay: Duration::from_secs(30),
                backoff: BackoffStrategy::Exponential(2.0),
                jitter: true,
            }
        }
    }

    /// Backoff strategy
    #[derive(Debug, Clone, Copy)]
    pub enum BackoffStrategy {
        Constant,
        Linear(f64),
        Exponential(f64),
        Fibonacci,
    }

    impl BackoffStrategy {
        pub fn delay(&self, attempt: usize, initial: Duration) -> Duration {
            let millis = initial.as_millis() as f64;
            let delay = match self {
                BackoffStrategy::Constant => millis,
                BackoffStrategy::Linear(factor) => millis * (1.0 + *factor * attempt as f64),
                BackoffStrategy::Exponential(base) => millis * base.powi(attempt as i32),
                BackoffStrategy::Fibonacci => {
                    let fib = Self::fibonacci(attempt);
                    millis * fib as f64
                }
            };
            Duration::from_millis(delay as u64)
        }

        fn fibonacci(n: usize) -> usize {
            if n <= 1 { return n; }
            let mut a = 0; let mut b = 1;
            for _ in 2..=n {
                let c = a + b;
                a = b; b = c;
            }
            b
        }
    }

    /// Retry result
    #[derive(Debug)]
    pub struct RetryResult<T, E> {
        pub result: Result<T, E>,
        pub attempts: usize,
        pub total_time: Duration,
    }

    /// Execute with retry
    pub fn retry<T, E, F>(policy: &RetryPolicy, mut f: F) -> RetryResult<T, E>
    where F: FnMut() -> Result<T, E> {
        let start = Instant::now();
        let mut attempts = 0;
        loop {
            attempts += 1;
            match f() {
                Ok(val) => return RetryResult {
                    result: Ok(val),
                    attempts,
                    total_time: start.elapsed(),
                },
                Err(e) if attempts >= policy.max_attempts => {
                    return RetryResult {
                        result: Err(e),
                        attempts,
                        total_time: start.elapsed(),
                    };
                }
                Err(_) => {
                    let mut delay = policy.backoff.delay(attempts - 1, policy.initial_delay);
                    if delay > policy.max_delay { delay = policy.max_delay; }
                    if policy.jitter {
                        let jitter = (rand::random::<f64>() - 0.5) * 0.2;
                        delay = Duration::from_millis(
                            (delay.as_millis() as f64 * (1.0 + jitter)) as u64
                        );
                    }
                    thread::sleep(delay);
                }
            }
        }
    }

    /// Circuit breaker states
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum CircuitState {
        Closed,
        Open,
        HalfOpen,
    }

    /// Circuit breaker for fault tolerance
    pub struct CircuitBreaker {
        state: std::sync::Mutex<CircuitState>,
        failure_count: std::sync::atomic::AtomicUsize,
        success_count: std::sync::atomic::AtomicUsize,
        last_failure: std::sync::Mutex<Option<Instant>>,
        config: CircuitBreakerConfig,
    }

    #[derive(Debug, Clone)]
    pub struct CircuitBreakerConfig {
        pub failure_threshold: usize,
        pub success_threshold: usize,
        pub timeout: Duration,
    }

    impl Default for CircuitBreakerConfig {
        fn default() -> Self {
            Self {
                failure_threshold: 5,
                success_threshold: 3,
                timeout: Duration::from_secs(30),
            }
        }
    }

    impl CircuitBreaker {
        pub fn new(config: CircuitBreakerConfig) -> Self {
            Self {
                state: std::sync::Mutex::new(CircuitState::Closed),
                failure_count: std::sync::atomic::AtomicUsize::new(0),
                success_count: std::sync::atomic::AtomicUsize::new(0),
                last_failure: std::sync::Mutex::new(None),
                config,
            }
        }

        pub fn state(&self) -> CircuitState {
            *self.state.lock().unwrap()
        }

        pub fn call<T, E, F>(&self, f: F) -> Result<T, CircuitBreakerError<E>>
        where F: FnOnce() -> Result<T, E> {
            use std::sync::atomic::Ordering;
            let mut state = self.state.lock().unwrap();
            match *state {
                CircuitState::Open => {
                    let last = self.last_failure.lock().unwrap();
                    if let Some(t) = *last {
                        if t.elapsed() >= self.config.timeout {
                            *state = CircuitState::HalfOpen;
                            self.success_count.store(0, Ordering::SeqCst);
                        } else {
                            return Err(CircuitBreakerError::Open);
                        }
                    }
                }
                _ => {}
            }
            drop(state);
            match f() {
                Ok(val) => {
                    self.on_success();
                    Ok(val)
                }
                Err(e) => {
                    self.on_failure();
                    Err(CircuitBreakerError::Inner(e))
                }
            }
        }

        fn on_success(&self) {
            use std::sync::atomic::Ordering;
            let mut state = self.state.lock().unwrap();
            self.failure_count.store(0, Ordering::SeqCst);
            if *state == CircuitState::HalfOpen {
                let count = self.success_count.fetch_add(1, Ordering::SeqCst) + 1;
                if count >= self.config.success_threshold {
                    *state = CircuitState::Closed;
                }
            }
        }

        fn on_failure(&self) {
            use std::sync::atomic::Ordering;
            let mut state = self.state.lock().unwrap();
            let count = self.failure_count.fetch_add(1, Ordering::SeqCst) + 1;
            *self.last_failure.lock().unwrap() = Some(Instant::now());
            if *state == CircuitState::HalfOpen || count >= self.config.failure_threshold {
                *state = CircuitState::Open;
            }
        }

        pub fn reset(&self) {
            use std::sync::atomic::Ordering;
            *self.state.lock().unwrap() = CircuitState::Closed;
            self.failure_count.store(0, Ordering::SeqCst);
            self.success_count.store(0, Ordering::SeqCst);
            *self.last_failure.lock().unwrap() = None;
        }
    }

    #[derive(Debug)]
    pub enum CircuitBreakerError<E> {
        Open,
        Inner(E),
    }

    /// Rate limiter using token bucket
    pub struct RateLimiter {
        tokens: std::sync::atomic::AtomicUsize,
        max_tokens: usize,
        refill_rate: f64,
        last_refill: std::sync::Mutex<Instant>,
    }

    impl RateLimiter {
        pub fn new(max_tokens: usize, refill_rate: f64) -> Self {
            Self {
                tokens: std::sync::atomic::AtomicUsize::new(max_tokens),
                max_tokens,
                refill_rate,
                last_refill: std::sync::Mutex::new(Instant::now()),
            }
        }

        pub fn try_acquire(&self) -> bool {
            self.refill();
            use std::sync::atomic::Ordering;
            let mut current = self.tokens.load(Ordering::Acquire);
            loop {
                if current == 0 { return false; }
                match self.tokens.compare_exchange_weak(
                    current, current - 1, Ordering::SeqCst, Ordering::Acquire
                ) {
                    Ok(_) => return true,
                    Err(c) => current = c,
                }
            }
        }

        pub fn acquire(&self) {
            while !self.try_acquire() {
                thread::sleep(Duration::from_millis(10));
            }
        }

        fn refill(&self) {
            use std::sync::atomic::Ordering;
            let mut last = self.last_refill.lock().unwrap();
            let elapsed = last.elapsed();
            let tokens_to_add = (elapsed.as_secs_f64() * self.refill_rate) as usize;
            if tokens_to_add > 0 {
                let current = self.tokens.load(Ordering::Acquire);
                let new = (current + tokens_to_add).min(self.max_tokens);
                self.tokens.store(new, Ordering::Release);
                *last = Instant::now();
            }
        }

        pub fn available(&self) -> usize {
            self.refill();
            self.tokens.load(std::sync::atomic::Ordering::Acquire)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// METRICS MODULE - Application Metrics Collection
// ═══════════════════════════════════════════════════════════════════════════════

pub mod metrics {
    use std::collections::HashMap;
    use std::sync::{Arc, Mutex, RwLock, atomic::{AtomicU64, AtomicI64, Ordering}};
    use std::time::{Duration, Instant};

    /// Counter metric (monotonically increasing)
    pub struct Counter {
        value: AtomicU64,
        labels: HashMap<String, String>,
    }

    impl Counter {
        pub fn new() -> Self {
            Self { value: AtomicU64::new(0), labels: HashMap::new() }
        }

        pub fn with_labels(labels: HashMap<String, String>) -> Self {
            Self { value: AtomicU64::new(0), labels }
        }

        pub fn inc(&self) { self.value.fetch_add(1, Ordering::Relaxed); }
        pub fn add(&self, n: u64) { self.value.fetch_add(n, Ordering::Relaxed); }
        pub fn get(&self) -> u64 { self.value.load(Ordering::Relaxed) }
    }

    /// Gauge metric (can go up and down)
    pub struct Gauge {
        value: AtomicI64,
        labels: HashMap<String, String>,
    }

    impl Gauge {
        pub fn new() -> Self {
            Self { value: AtomicI64::new(0), labels: HashMap::new() }
        }

        pub fn set(&self, val: i64) { self.value.store(val, Ordering::Relaxed); }
        pub fn inc(&self) { self.value.fetch_add(1, Ordering::Relaxed); }
        pub fn dec(&self) { self.value.fetch_sub(1, Ordering::Relaxed); }
        pub fn add(&self, n: i64) { self.value.fetch_add(n, Ordering::Relaxed); }
        pub fn get(&self) -> i64 { self.value.load(Ordering::Relaxed) }
    }

    /// Histogram for distribution tracking
    pub struct Histogram {
        buckets: Vec<(f64, AtomicU64)>,
        sum: Mutex<f64>,
        count: AtomicU64,
    }

    impl Histogram {
        pub fn new(bucket_bounds: Vec<f64>) -> Self {
            let mut buckets: Vec<_> = bucket_bounds.into_iter()
                .map(|b| (b, AtomicU64::new(0))).collect();
            buckets.push((f64::INFINITY, AtomicU64::new(0)));
            Self { buckets, sum: Mutex::new(0.0), count: AtomicU64::new(0) }
        }

        pub fn default_buckets() -> Self {
            Self::new(vec![0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1.0, 2.5, 5.0, 10.0])
        }

        pub fn observe(&self, value: f64) {
            for (bound, count) in &self.buckets {
                if value <= *bound {
                    count.fetch_add(1, Ordering::Relaxed);
                }
            }
            *self.sum.lock().unwrap() += value;
            self.count.fetch_add(1, Ordering::Relaxed);
        }

        pub fn sum(&self) -> f64 { *self.sum.lock().unwrap() }
        pub fn count(&self) -> u64 { self.count.load(Ordering::Relaxed) }
        pub fn mean(&self) -> f64 {
            let c = self.count();
            if c == 0 { 0.0 } else { self.sum() / c as f64 }
        }
    }

    /// Summary for quantile tracking
    pub struct Summary {
        values: Mutex<Vec<f64>>,
        quantiles: Vec<f64>,
        max_samples: usize,
    }

    impl Summary {
        pub fn new(quantiles: Vec<f64>, max_samples: usize) -> Self {
            Self { values: Mutex::new(Vec::new()), quantiles, max_samples }
        }

        pub fn observe(&self, value: f64) {
            let mut values = self.values.lock().unwrap();
            if values.len() >= self.max_samples {
                values.remove(0);
            }
            values.push(value);
        }

        pub fn quantile(&self, q: f64) -> f64 {
            let mut values = self.values.lock().unwrap().clone();
            if values.is_empty() { return 0.0; }
            values.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let idx = (q * (values.len() - 1) as f64) as usize;
            values[idx.min(values.len() - 1)]
        }
    }

    /// Timer for measuring durations
    pub struct Timer {
        histogram: Arc<Histogram>,
        start: Instant,
    }

    impl Timer {
        pub fn new(histogram: Arc<Histogram>) -> Self {
            Self { histogram, start: Instant::now() }
        }

        pub fn observe_duration(self) -> Duration {
            let elapsed = self.start.elapsed();
            self.histogram.observe(elapsed.as_secs_f64());
            elapsed
        }
    }

    impl Drop for Timer {
        fn drop(&mut self) {
            self.histogram.observe(self.start.elapsed().as_secs_f64());
        }
    }

    /// Metrics registry
    pub struct Registry {
        counters: RwLock<HashMap<String, Arc<Counter>>>,
        gauges: RwLock<HashMap<String, Arc<Gauge>>>,
        histograms: RwLock<HashMap<String, Arc<Histogram>>>,
        summaries: RwLock<HashMap<String, Arc<Summary>>>,
    }

    impl Registry {
        pub fn new() -> Self {
            Self {
                counters: RwLock::new(HashMap::new()),
                gauges: RwLock::new(HashMap::new()),
                histograms: RwLock::new(HashMap::new()),
                summaries: RwLock::new(HashMap::new()),
            }
        }

        pub fn counter(&self, name: &str) -> Arc<Counter> {
            let mut counters = self.counters.write().unwrap();
            counters.entry(name.into())
                .or_insert_with(|| Arc::new(Counter::new()))
                .clone()
        }

        pub fn gauge(&self, name: &str) -> Arc<Gauge> {
            let mut gauges = self.gauges.write().unwrap();
            gauges.entry(name.into())
                .or_insert_with(|| Arc::new(Gauge::new()))
                .clone()
        }

        pub fn histogram(&self, name: &str) -> Arc<Histogram> {
            let mut histograms = self.histograms.write().unwrap();
            histograms.entry(name.into())
                .or_insert_with(|| Arc::new(Histogram::default_buckets()))
                .clone()
        }

        pub fn export_prometheus(&self) -> String {
            let mut output = String::new();
            for (name, counter) in self.counters.read().unwrap().iter() {
                output.push_str(&format!("# TYPE {} counter\n", name));
                output.push_str(&format!("{} {}\n", name, counter.get()));
            }
            for (name, gauge) in self.gauges.read().unwrap().iter() {
                output.push_str(&format!("# TYPE {} gauge\n", name));
                output.push_str(&format!("{} {}\n", name, gauge.get()));
            }
            for (name, hist) in self.histograms.read().unwrap().iter() {
                output.push_str(&format!("# TYPE {} histogram\n", name));
                output.push_str(&format!("{}_sum {}\n", name, hist.sum()));
                output.push_str(&format!("{}_count {}\n", name, hist.count()));
            }
            output
        }
    }

    /// Global metrics instance
    static GLOBAL_REGISTRY: std::sync::OnceLock<Registry> = std::sync::OnceLock::new();

    pub fn global() -> &'static Registry {
        GLOBAL_REGISTRY.get_or_init(Registry::new)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CACHE MODULE - High-Performance Caching
// ═══════════════════════════════════════════════════════════════════════════════

pub mod cache {
    use std::collections::{HashMap, VecDeque};
    use std::sync::{Arc, RwLock, Mutex};
    use std::time::{Duration, Instant};
    use std::hash::Hash;

    /// Cache entry with metadata
    struct CacheEntry<V> {
        value: V,
        created: Instant,
        last_accessed: Instant,
        access_count: usize,
        ttl: Option<Duration>,
    }

    /// LRU Cache implementation
    pub struct LruCache<K: Eq + Hash + Clone, V: Clone> {
        entries: RwLock<HashMap<K, CacheEntry<V>>>,
        order: Mutex<VecDeque<K>>,
        capacity: usize,
        default_ttl: Option<Duration>,
        hits: std::sync::atomic::AtomicUsize,
        misses: std::sync::atomic::AtomicUsize,
    }

    impl<K: Eq + Hash + Clone, V: Clone> LruCache<K, V> {
        pub fn new(capacity: usize) -> Self {
            Self {
                entries: RwLock::new(HashMap::with_capacity(capacity)),
                order: Mutex::new(VecDeque::with_capacity(capacity)),
                capacity,
                default_ttl: None,
                hits: std::sync::atomic::AtomicUsize::new(0),
                misses: std::sync::atomic::AtomicUsize::new(0),
            }
        }

        pub fn with_ttl(mut self, ttl: Duration) -> Self {
            self.default_ttl = Some(ttl);
            self
        }

        pub fn get(&self, key: &K) -> Option<V> {
            let now = Instant::now();
            let mut entries = self.entries.write().unwrap();
            if let Some(entry) = entries.get_mut(key) {
                if let Some(ttl) = entry.ttl {
                    if now.duration_since(entry.created) > ttl {
                        entries.remove(key);
                        self.misses.fetch_add(1, std::sync::atomic::Ordering::Relaxed);
                        return None;
                    }
                }
                entry.last_accessed = now;
                entry.access_count += 1;
                let mut order = self.order.lock().unwrap();
                order.retain(|k| k != key);
                order.push_back(key.clone());
                self.hits.fetch_add(1, std::sync::atomic::Ordering::Relaxed);
                Some(entry.value.clone())
            } else {
                self.misses.fetch_add(1, std::sync::atomic::Ordering::Relaxed);
                None
            }
        }

        pub fn insert(&self, key: K, value: V) {
            self.insert_with_ttl(key, value, self.default_ttl);
        }

        pub fn insert_with_ttl(&self, key: K, value: V, ttl: Option<Duration>) {
            let now = Instant::now();
            let mut entries = self.entries.write().unwrap();
            let mut order = self.order.lock().unwrap();
            if entries.len() >= self.capacity && !entries.contains_key(&key) {
                if let Some(lru_key) = order.pop_front() {
                    entries.remove(&lru_key);
                }
            }
            order.retain(|k| k != &key);
            order.push_back(key.clone());
            entries.insert(key, CacheEntry {
                value, created: now, last_accessed: now, access_count: 1, ttl,
            });
        }

        pub fn remove(&self, key: &K) -> Option<V> {
            let mut entries = self.entries.write().unwrap();
            let mut order = self.order.lock().unwrap();
            order.retain(|k| k != key);
            entries.remove(key).map(|e| e.value)
        }

        pub fn clear(&self) {
            self.entries.write().unwrap().clear();
            self.order.lock().unwrap().clear();
        }

        pub fn len(&self) -> usize {
            self.entries.read().unwrap().len()
        }

        pub fn hit_rate(&self) -> f64 {
            use std::sync::atomic::Ordering;
            let hits = self.hits.load(Ordering::Relaxed) as f64;
            let misses = self.misses.load(Ordering::Relaxed) as f64;
            if hits + misses == 0.0 { 0.0 } else { hits / (hits + misses) }
        }

        pub fn evict_expired(&self) {
            let now = Instant::now();
            let mut entries = self.entries.write().unwrap();
            let mut order = self.order.lock().unwrap();
            let expired: Vec<K> = entries.iter()
                .filter(|(_, e)| e.ttl.map(|t| now.duration_since(e.created) > t).unwrap_or(false))
                .map(|(k, _)| k.clone())
                .collect();
            for key in expired {
                entries.remove(&key);
                order.retain(|k| k != &key);
            }
        }
    }

    /// LFU Cache implementation
    pub struct LfuCache<K: Eq + Hash + Clone, V: Clone> {
        entries: RwLock<HashMap<K, (V, usize)>>,
        freq_map: Mutex<HashMap<usize, Vec<K>>>,
        min_freq: std::sync::atomic::AtomicUsize,
        capacity: usize,
    }

    impl<K: Eq + Hash + Clone, V: Clone> LfuCache<K, V> {
        pub fn new(capacity: usize) -> Self {
            Self {
                entries: RwLock::new(HashMap::with_capacity(capacity)),
                freq_map: Mutex::new(HashMap::new()),
                min_freq: std::sync::atomic::AtomicUsize::new(0),
                capacity,
            }
        }

        pub fn get(&self, key: &K) -> Option<V> {
            let mut entries = self.entries.write().unwrap();
            if let Some((value, freq)) = entries.get_mut(key) {
                let old_freq = *freq;
                *freq += 1;
                let mut freq_map = self.freq_map.lock().unwrap();
                if let Some(keys) = freq_map.get_mut(&old_freq) {
                    keys.retain(|k| k != key);
                    if keys.is_empty() {
                        freq_map.remove(&old_freq);
                        if self.min_freq.load(std::sync::atomic::Ordering::Relaxed) == old_freq {
                            self.min_freq.fetch_add(1, std::sync::atomic::Ordering::Relaxed);
                        }
                    }
                }
                freq_map.entry(*freq).or_default().push(key.clone());
                Some(value.clone())
            } else { None }
        }

        pub fn insert(&self, key: K, value: V) {
            let mut entries = self.entries.write().unwrap();
            let mut freq_map = self.freq_map.lock().unwrap();
            if entries.len() >= self.capacity && !entries.contains_key(&key) {
                let min = self.min_freq.load(std::sync::atomic::Ordering::Relaxed);
                if let Some(keys) = freq_map.get_mut(&min) {
                    if let Some(lfu_key) = keys.first().cloned() {
                        keys.remove(0);
                        entries.remove(&lfu_key);
                        if keys.is_empty() { freq_map.remove(&min); }
                    }
                }
            }
            entries.insert(key.clone(), (value, 1));
            freq_map.entry(1).or_default().push(key);
            self.min_freq.store(1, std::sync::atomic::Ordering::Relaxed);
        }
    }

    /// Write-through cache with persistence
    pub trait CacheStore<K, V> {
        fn load(&self, key: &K) -> Option<V>;
        fn store(&self, key: &K, value: &V);
        fn remove(&self, key: &K);
    }

    pub struct WriteThroughCache<K: Eq + Hash + Clone, V: Clone, S: CacheStore<K, V>> {
        cache: LruCache<K, V>,
        store: S,
    }

    impl<K: Eq + Hash + Clone, V: Clone, S: CacheStore<K, V>> WriteThroughCache<K, V, S> {
        pub fn new(capacity: usize, store: S) -> Self {
            Self { cache: LruCache::new(capacity), store }
        }

        pub fn get(&self, key: &K) -> Option<V> {
            if let Some(v) = self.cache.get(key) {
                return Some(v);
            }
            if let Some(v) = self.store.load(key) {
                self.cache.insert(key.clone(), v.clone());
                return Some(v);
            }
            None
        }

        pub fn insert(&self, key: K, value: V) {
            self.store.store(&key, &value);
            self.cache.insert(key, value);
        }

        pub fn remove(&self, key: &K) {
            self.store.remove(key);
            self.cache.remove(key);
        }
    }

    /// Memoization helper
    pub struct Memoize<K: Eq + Hash + Clone, V: Clone, F: Fn(&K) -> V> {
        cache: LruCache<K, V>,
        func: F,
    }

    impl<K: Eq + Hash + Clone, V: Clone, F: Fn(&K) -> V> Memoize<K, V, F> {
        pub fn new(capacity: usize, func: F) -> Self {
            Self { cache: LruCache::new(capacity), func }
        }

        pub fn call(&self, key: &K) -> V {
            if let Some(v) = self.cache.get(key) {
                return v;
            }
            let value = (self.func)(key);
            self.cache.insert(key.clone(), value.clone());
            value
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED STRING UTILITIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Advanced string processing and text analysis
pub mod string_utils {
    use std::collections::{HashMap, HashSet, VecDeque};

    /// Levenshtein distance calculator for fuzzy string matching
    pub struct LevenshteinDistance;

    impl LevenshteinDistance {
        /// Calculate edit distance between two strings
        pub fn distance(a: &str, b: &str) -> usize {
            let a_chars: Vec<char> = a.chars().collect();
            let b_chars: Vec<char> = b.chars().collect();
            let m = a_chars.len();
            let n = b_chars.len();

            if m == 0 { return n; }
            if n == 0 { return m; }

            let mut matrix = vec![vec![0usize; n + 1]; m + 1];

            for i in 0..=m { matrix[i][0] = i; }
            for j in 0..=n { matrix[0][j] = j; }

            for i in 1..=m {
                for j in 1..=n {
                    let cost = if a_chars[i - 1] == b_chars[j - 1] { 0 } else { 1 };
                    matrix[i][j] = min!(
                        matrix[i - 1][j] + 1,
                        matrix[i][j - 1] + 1,
                        matrix[i - 1][j - 1] + cost
                    );
                }
            }
            matrix[m][n]
        }

        /// Calculate normalized similarity (0.0 to 1.0)
        pub fn similarity(a: &str, b: &str) -> f64 {
            let max_len = max!(a.len(), b.len());
            if max_len == 0 { return 1.0; }
            1.0 - (Self::distance(a, b) as f64 / max_len as f64)
        }
    }

    /// Damerau-Levenshtein distance (includes transpositions)
    pub struct DamerauLevenshtein;

    impl DamerauLevenshtein {
        pub fn distance(a: &str, b: &str) -> usize {
            let a_chars: Vec<char> = a.chars().collect();
            let b_chars: Vec<char> = b.chars().collect();
            let m = a_chars.len();
            let n = b_chars.len();

            if m == 0 { return n; }
            if n == 0 { return m; }

            let mut matrix = vec![vec![0usize; n + 1]; m + 1];

            for i in 0..=m { matrix[i][0] = i; }
            for j in 0..=n { matrix[0][j] = j; }

            for i in 1..=m {
                for j in 1..=n {
                    let cost = if a_chars[i - 1] == b_chars[j - 1] { 0 } else { 1 };
                    matrix[i][j] = min!(
                        matrix[i - 1][j] + 1,
                        matrix[i][j - 1] + 1,
                        matrix[i - 1][j - 1] + cost
                    );
                    if i > 1 && j > 1
                        && a_chars[i - 1] == b_chars[j - 2]
                        && a_chars[i - 2] == b_chars[j - 1]
                    {
                        matrix[i][j] = min!(matrix[i][j], matrix[i - 2][j - 2] + cost);
                    }
                }
            }
            matrix[m][n]
        }
    }

    /// Jaro-Winkler similarity for name matching
    pub struct JaroWinkler {
        prefix_scale: f64,
    }

    impl JaroWinkler {
        pub fn new() -> Self {
            Self { prefix_scale: 0.1 }
        }

        pub fn with_prefix_scale(prefix_scale: f64) -> Self {
            Self { prefix_scale: prefix_scale.clamp(0.0, 0.25) }
        }

        pub fn jaro_similarity(&self, a: &str, b: &str) -> f64 {
            if a.is_empty() && b.is_empty() { return 1.0; }
            if a.is_empty() || b.is_empty() { return 0.0; }

            let a_chars: Vec<char> = a.chars().collect();
            let b_chars: Vec<char> = b.chars().collect();
            let match_distance = max!(a_chars.len(), b_chars.len()) / 2 - 1;

            let mut a_matches = vec![false; a_chars.len()];
            let mut b_matches = vec![false; b_chars.len()];
            let mut matches = 0usize;
            let mut transpositions = 0usize;

            for i in 0..a_chars.len() {
                let start = if i > match_distance { i - match_distance } else { 0 };
                let end = min!(i + match_distance + 1, b_chars.len());

                for j in start..end {
                    if b_matches[j] || a_chars[i] != b_chars[j] { continue; }
                    a_matches[i] = true;
                    b_matches[j] = true;
                    matches += 1;
                    break;
                }
            }

            if matches == 0 { return 0.0; }

            let mut k = 0usize;
            for i in 0..a_chars.len() {
                if !a_matches[i] { continue; }
                while !b_matches[k] { k += 1; }
                if a_chars[i] != b_chars[k] { transpositions += 1; }
                k += 1;
            }

            let m = matches as f64;
            (m / a_chars.len() as f64 +
             m / b_chars.len() as f64 +
             (m - transpositions as f64 / 2.0) / m) / 3.0
        }

        pub fn similarity(&self, a: &str, b: &str) -> f64 {
            let jaro = self.jaro_similarity(a, b);

            let a_chars: Vec<char> = a.chars().collect();
            let b_chars: Vec<char> = b.chars().collect();
            let prefix_len = a_chars.iter()
                .zip(b_chars.iter())
                .take(4)
                .take_while(|(ac, bc)| ac == bc)
                .count();

            jaro + (prefix_len as f64 * self.prefix_scale * (1.0 - jaro))
        }
    }

    /// Soundex phonetic algorithm
    pub struct Soundex;

    impl Soundex {
        const CODES: [(char, char); 26] = [
            ('A', '0'), ('B', '1'), ('C', '2'), ('D', '3'), ('E', '0'), ('F', '1'),
            ('G', '2'), ('H', '0'), ('I', '0'), ('J', '2'), ('K', '2'), ('L', '4'),
            ('M', '5'), ('N', '5'), ('O', '0'), ('P', '1'), ('Q', '2'), ('R', '6'),
            ('S', '2'), ('T', '3'), ('U', '0'), ('V', '1'), ('W', '0'), ('X', '2'),
            ('Y', '0'), ('Z', '2'),
        ];

        pub fn encode(name: &str) -> String {
            let name = name.to_uppercase();
            let chars: Vec<char> = name.chars().filter(|c| c.is_alphabetic()).collect();

            if chars.is_empty() { return String::from("0000"); }

            let mut result = String::new();
            result.push(chars[0]);

            let mut last_code = Self::get_code(chars[0]);

            for &ch in chars.iter().skip(1) {
                let code = Self::get_code(ch);
                if code != '0' && code != last_code {
                    result.push(code);
                    if result.len() == 4 { break; }
                }
                last_code = code;
            }

            while result.len() < 4 {
                result.push('0');
            }
            result
        }

        fn get_code(ch: char) -> char {
            Self::CODES.iter()
                .find(|(c, _)| *c == ch)
                .map(|(_, code)| *code)
                .unwrap_or('0')
        }

        pub fn matches(a: &str, b: &str) -> bool {
            Self::encode(a) == Self::encode(b)
        }
    }

    /// Double Metaphone phonetic algorithm
    pub struct DoubleMetaphone;

    impl DoubleMetaphone {
        pub fn encode(word: &str) -> (String, String) {
            let word = word.to_uppercase();
            let chars: Vec<char> = word.chars().collect();
            let len = chars.len();

            if len == 0 { return (String::new(), String::new()); }

            let mut primary = String::new();
            let mut secondary = String::new();
            let mut current = 0usize;

            let is_vowel = |c: char| matches!(c, 'A' | 'E' | 'I' | 'O' | 'U');
            let get_at = |i: usize| -> char {
                if i < len { chars[i] } else { ' ' }
            };

            // Skip initial silent consonants
            if len >= 2 {
                match (chars[0], chars[1]) {
                    ('G', 'N') | ('K', 'N') | ('P', 'N') | ('W', 'R') | ('P', 'S') => {
                        current = 1;
                    }
                    _ => {}
                }
            }

            // Process initial vowel
            if is_vowel(get_at(current)) {
                primary.push('A');
                secondary.push('A');
                current += 1;
            }

            while current < len && primary.len() < 4 {
                match chars[current] {
                    'B' => {
                        primary.push('P');
                        secondary.push('P');
                        current += if get_at(current + 1) == 'B' { 2 } else { 1 };
                    }
                    'C' => {
                        if get_at(current + 1) == 'H' {
                            primary.push('X');
                            secondary.push('X');
                            current += 2;
                        } else if matches!(get_at(current + 1), 'I' | 'E' | 'Y') {
                            primary.push('S');
                            secondary.push('S');
                            current += 1;
                        } else {
                            primary.push('K');
                            secondary.push('K');
                            current += 1;
                        }
                    }
                    'D' => {
                        if get_at(current + 1) == 'G'
                            && matches!(get_at(current + 2), 'I' | 'E' | 'Y')
                        {
                            primary.push('J');
                            secondary.push('J');
                            current += 3;
                        } else {
                            primary.push('T');
                            secondary.push('T');
                            current += if get_at(current + 1) == 'D' { 2 } else { 1 };
                        }
                    }
                    'F' => {
                        primary.push('F');
                        secondary.push('F');
                        current += if get_at(current + 1) == 'F' { 2 } else { 1 };
                    }
                    'G' => {
                        if matches!(get_at(current + 1), 'I' | 'E' | 'Y') {
                            primary.push('J');
                            secondary.push('K');
                        } else {
                            primary.push('K');
                            secondary.push('K');
                        }
                        current += if get_at(current + 1) == 'G' { 2 } else { 1 };
                    }
                    'H' => {
                        if is_vowel(get_at(current + 1)) && !is_vowel(get_at(current.saturating_sub(1))) {
                            primary.push('H');
                            secondary.push('H');
                        }
                        current += 1;
                    }
                    'J' => {
                        primary.push('J');
                        secondary.push('J');
                        current += if get_at(current + 1) == 'J' { 2 } else { 1 };
                    }
                    'K' => {
                        primary.push('K');
                        secondary.push('K');
                        current += if get_at(current + 1) == 'K' { 2 } else { 1 };
                    }
                    'L' => {
                        primary.push('L');
                        secondary.push('L');
                        current += if get_at(current + 1) == 'L' { 2 } else { 1 };
                    }
                    'M' => {
                        primary.push('M');
                        secondary.push('M');
                        current += if get_at(current + 1) == 'M' { 2 } else { 1 };
                    }
                    'N' => {
                        primary.push('N');
                        secondary.push('N');
                        current += if get_at(current + 1) == 'N' { 2 } else { 1 };
                    }
                    'P' => {
                        if get_at(current + 1) == 'H' {
                            primary.push('F');
                            secondary.push('F');
                            current += 2;
                        } else {
                            primary.push('P');
                            secondary.push('P');
                            current += if get_at(current + 1) == 'P' { 2 } else { 1 };
                        }
                    }
                    'Q' => {
                        primary.push('K');
                        secondary.push('K');
                        current += if get_at(current + 1) == 'Q' { 2 } else { 1 };
                    }
                    'R' => {
                        primary.push('R');
                        secondary.push('R');
                        current += if get_at(current + 1) == 'R' { 2 } else { 1 };
                    }
                    'S' => {
                        if get_at(current + 1) == 'H' {
                            primary.push('X');
                            secondary.push('X');
                            current += 2;
                        } else {
                            primary.push('S');
                            secondary.push('S');
                            current += if get_at(current + 1) == 'S' { 2 } else { 1 };
                        }
                    }
                    'T' => {
                        if get_at(current + 1) == 'H' {
                            primary.push('0');
                            secondary.push('T');
                            current += 2;
                        } else {
                            primary.push('T');
                            secondary.push('T');
                            current += if get_at(current + 1) == 'T' { 2 } else { 1 };
                        }
                    }
                    'V' => {
                        primary.push('F');
                        secondary.push('F');
                        current += if get_at(current + 1) == 'V' { 2 } else { 1 };
                    }
                    'W' => {
                        if is_vowel(get_at(current + 1)) {
                            primary.push('A');
                            secondary.push('A');
                        }
                        current += 1;
                    }
                    'X' => {
                        primary.push('K');
                        primary.push('S');
                        secondary.push('K');
                        secondary.push('S');
                        current += if get_at(current + 1) == 'X' { 2 } else { 1 };
                    }
                    'Z' => {
                        primary.push('S');
                        secondary.push('S');
                        current += if get_at(current + 1) == 'Z' { 2 } else { 1 };
                    }
                    _ => {
                        current += 1;
                    }
                }
            }

            (primary, secondary)
        }

        pub fn matches(a: &str, b: &str) -> bool {
            let (a_pri, a_sec) = Self::encode(a);
            let (b_pri, b_sec) = Self::encode(b);
            a_pri == b_pri || a_pri == b_sec || a_sec == b_pri || a_sec == b_sec
        }
    }

    /// N-gram generator for text analysis
    pub struct NGram {
        n: usize,
    }

    impl NGram {
        pub fn new(n: usize) -> Self {
            Self { n: max!(n, 1) }
        }

        pub fn generate(&self, text: &str) -> Vec<String> {
            let chars: Vec<char> = text.chars().collect();
            if chars.len() < self.n {
                return vec![text.to_string()];
            }

            chars.windows(self.n)
                .map(|w| w.iter().collect())
                .collect()
        }

        pub fn word_ngrams(&self, text: &str) -> Vec<Vec<&str>> {
            let words: Vec<&str> = text.split_whitespace().collect();
            if words.len() < self.n {
                return vec![words];
            }

            words.windows(self.n)
                .map(|w| w.to_vec())
                .collect()
        }

        pub fn similarity(&self, a: &str, b: &str) -> f64 {
            let a_grams: HashSet<String> = self.generate(a).into_iter().collect();
            let b_grams: HashSet<String> = self.generate(b).into_iter().collect();

            if a_grams.is_empty() && b_grams.is_empty() { return 1.0; }
            if a_grams.is_empty() || b_grams.is_empty() { return 0.0; }

            let intersection = a_grams.intersection(&b_grams).count();
            let union = a_grams.union(&b_grams).count();

            intersection as f64 / union as f64
        }
    }

    /// Text tokenizer with multiple strategies
    pub struct Tokenizer {
        strategy: TokenizerStrategy,
    }

    pub enum TokenizerStrategy {
        Whitespace,
        WordBoundary,
        Sentence,
        Paragraph,
        Custom { delimiters: String },
    }

    impl Tokenizer {
        pub fn whitespace() -> Self {
            Self { strategy: TokenizerStrategy::Whitespace }
        }

        pub fn word_boundary() -> Self {
            Self { strategy: TokenizerStrategy::WordBoundary }
        }

        pub fn sentence() -> Self {
            Self { strategy: TokenizerStrategy::Sentence }
        }

        pub fn paragraph() -> Self {
            Self { strategy: TokenizerStrategy::Paragraph }
        }

        pub fn custom(delimiters: &str) -> Self {
            Self { strategy: TokenizerStrategy::Custom { delimiters: delimiters.to_string() } }
        }

        pub fn tokenize<'a>(&self, text: &'a str) -> Vec<&'a str> {
            match &self.strategy {
                TokenizerStrategy::Whitespace => {
                    text.split_whitespace().collect()
                }
                TokenizerStrategy::WordBoundary => {
                    text.split(|c: char| !c.is_alphanumeric())
                        .filter(|s| !s.is_empty())
                        .collect()
                }
                TokenizerStrategy::Sentence => {
                    text.split(|c: char| matches!(c, '.' | '!' | '?'))
                        .map(|s| s.trim())
                        .filter(|s| !s.is_empty())
                        .collect()
                }
                TokenizerStrategy::Paragraph => {
                    text.split("\n\n")
                        .map(|s| s.trim())
                        .filter(|s| !s.is_empty())
                        .collect()
                }
                TokenizerStrategy::Custom { delimiters } => {
                    text.split(|c| delimiters.contains(c))
                        .filter(|s| !s.is_empty())
                        .collect()
                }
            }
        }
    }

    /// Simple template engine
    pub struct Template {
        source: String,
        delimiters: (String, String),
    }

    impl Template {
        pub fn new(source: &str) -> Self {
            Self {
                source: source.to_string(),
                delimiters: ("{{".to_string(), "}}".to_string()),
            }
        }

        pub fn with_delimiters(source: &str, open: &str, close: &str) -> Self {
            Self {
                source: source.to_string(),
                delimiters: (open.to_string(), close.to_string()),
            }
        }

        pub fn render(&self, context: &HashMap<String, String>) -> String {
            let mut result = self.source.clone();

            for (key, value) in context {
                let placeholder = format!("{}{}{}", self.delimiters.0, key, self.delimiters.1);
                result = result.replace(&placeholder, value);
            }

            result
        }

        pub fn render_with_default(&self, context: &HashMap<String, String>, default: &str) -> String {
            let mut result = self.source.clone();
            let (open, close) = &self.delimiters;

            for (key, value) in context {
                let placeholder = format!("{}{}{}", open, key, close);
                result = result.replace(&placeholder, value);
            }

            // Replace remaining placeholders with default
            while let Some(start) = result.find(open.as_str()) {
                if let Some(end) = result[start..].find(close.as_str()) {
                    let end = start + end + close.len();
                    result.replace_range(start..end, default);
                } else {
                    break;
                }
            }

            result
        }
    }

    /// Word wrapper for text formatting
    pub struct WordWrapper {
        width: usize,
        indent: String,
        hanging_indent: Option<String>,
    }

    impl WordWrapper {
        pub fn new(width: usize) -> Self {
            Self {
                width,
                indent: String::new(),
                hanging_indent: None,
            }
        }

        pub fn with_indent(mut self, indent: &str) -> Self {
            self.indent = indent.to_string();
            self
        }

        pub fn with_hanging_indent(mut self, hanging: &str) -> Self {
            self.hanging_indent = Some(hanging.to_string());
            self
        }

        pub fn wrap(&self, text: &str) -> Vec<String> {
            let words: Vec<&str> = text.split_whitespace().collect();
            let mut lines = Vec::new();
            let mut current_line = self.indent.clone();
            let mut is_first_line = true;

            for word in words {
                let test_line = if current_line.is_empty() {
                    word.to_string()
                } else {
                    format!("{} {}", current_line, word)
                };

                if test_line.len() <= self.width {
                    current_line = test_line;
                } else {
                    if !current_line.is_empty() {
                        lines.push(current_line);
                    }
                    is_first_line = false;
                    let indent = self.hanging_indent.as_ref()
                        .filter(|_| !is_first_line)
                        .unwrap_or(&self.indent);
                    current_line = format!("{}{}", indent, word);
                }
            }

            if !current_line.is_empty() {
                lines.push(current_line);
            }

            lines
        }
    }

    /// Case converter for strings
    pub struct CaseConverter;

    impl CaseConverter {
        pub fn to_snake_case(s: &str) -> String {
            let mut result = String::new();
            for (i, ch) in s.chars().enumerate() {
                if ch.is_uppercase() {
                    if i > 0 {
                        result.push('_');
                    }
                    result.push(ch.to_lowercase().next().unwrap());
                } else if ch == '-' || ch == ' ' {
                    result.push('_');
                } else {
                    result.push(ch);
                }
            }
            result
        }

        pub fn to_camel_case(s: &str) -> String {
            let mut result = String::new();
            let mut capitalize_next = false;

            for ch in s.chars() {
                if ch == '_' || ch == '-' || ch == ' ' {
                    capitalize_next = true;
                } else if capitalize_next {
                    result.push(ch.to_uppercase().next().unwrap());
                    capitalize_next = false;
                } else {
                    result.push(ch);
                }
            }
            result
        }

        pub fn to_pascal_case(s: &str) -> String {
            let camel = Self::to_camel_case(s);
            let mut chars = camel.chars();
            match chars.next() {
                None => String::new(),
                Some(first) => first.to_uppercase().chain(chars).collect(),
            }
        }

        pub fn to_kebab_case(s: &str) -> String {
            Self::to_snake_case(s).replace('_', "-")
        }

        pub fn to_constant_case(s: &str) -> String {
            Self::to_snake_case(s).to_uppercase()
        }

        pub fn to_title_case(s: &str) -> String {
            s.split_whitespace()
                .map(|word| {
                    let mut chars = word.chars();
                    match chars.next() {
                        None => String::new(),
                        Some(first) => first.to_uppercase().chain(chars).collect(),
                    }
                })
                .collect::<Vec<_>>()
                .join(" ")
        }
    }

    /// String similarity metrics collection
    pub struct StringSimilarity;

    impl StringSimilarity {
        pub fn cosine_similarity(a: &str, b: &str) -> f64 {
            let a_chars: HashMap<char, usize> = a.chars().fold(HashMap::new(), |mut m, c| {
                *m.entry(c).or_insert(0) += 1;
                m
            });
            let b_chars: HashMap<char, usize> = b.chars().fold(HashMap::new(), |mut m, c| {
                *m.entry(c).or_insert(0) += 1;
                m
            });

            let dot_product: f64 = a_chars.iter()
                .filter_map(|(c, count)| b_chars.get(c).map(|bc| (*count * bc) as f64))
                .sum();

            let a_magnitude: f64 = a_chars.values().map(|v| (*v * *v) as f64).sum::<f64>().sqrt();
            let b_magnitude: f64 = b_chars.values().map(|v| (*v * *v) as f64).sum::<f64>().sqrt();

            if a_magnitude == 0.0 || b_magnitude == 0.0 {
                0.0
            } else {
                dot_product / (a_magnitude * b_magnitude)
            }
        }

        pub fn jaccard_similarity(a: &str, b: &str) -> f64 {
            let a_set: HashSet<char> = a.chars().collect();
            let b_set: HashSet<char> = b.chars().collect();

            if a_set.is_empty() && b_set.is_empty() { return 1.0; }
            if a_set.is_empty() || b_set.is_empty() { return 0.0; }

            let intersection = a_set.intersection(&b_set).count();
            let union = a_set.union(&b_set).count();

            intersection as f64 / union as f64
        }

        pub fn dice_coefficient(a: &str, b: &str) -> f64 {
            let ngram = NGram::new(2);
            let a_grams: HashSet<String> = ngram.generate(a).into_iter().collect();
            let b_grams: HashSet<String> = ngram.generate(b).into_iter().collect();

            if a_grams.is_empty() && b_grams.is_empty() { return 1.0; }
            if a_grams.is_empty() || b_grams.is_empty() { return 0.0; }

            let intersection = a_grams.intersection(&b_grams).count();
            (2.0 * intersection as f64) / (a_grams.len() + b_grams.len()) as f64
        }

        pub fn hamming_distance(a: &str, b: &str) -> Option<usize> {
            if a.len() != b.len() { return None; }
            Some(a.chars().zip(b.chars()).filter(|(ac, bc)| ac != bc).count())
        }

        pub fn longest_common_subsequence(a: &str, b: &str) -> String {
            let a_chars: Vec<char> = a.chars().collect();
            let b_chars: Vec<char> = b.chars().collect();
            let m = a_chars.len();
            let n = b_chars.len();

            let mut dp = vec![vec![0usize; n + 1]; m + 1];

            for i in 1..=m {
                for j in 1..=n {
                    if a_chars[i - 1] == b_chars[j - 1] {
                        dp[i][j] = dp[i - 1][j - 1] + 1;
                    } else {
                        dp[i][j] = max!(dp[i - 1][j], dp[i][j - 1]);
                    }
                }
            }

            let mut result = String::new();
            let mut i = m;
            let mut j = n;

            while i > 0 && j > 0 {
                if a_chars[i - 1] == b_chars[j - 1] {
                    result.insert(0, a_chars[i - 1]);
                    i -= 1;
                    j -= 1;
                } else if dp[i - 1][j] > dp[i][j - 1] {
                    i -= 1;
                } else {
                    j -= 1;
                }
            }

            result
        }

        pub fn longest_common_substring(a: &str, b: &str) -> String {
            let a_chars: Vec<char> = a.chars().collect();
            let b_chars: Vec<char> = b.chars().collect();
            let m = a_chars.len();
            let n = b_chars.len();

            let mut dp = vec![vec![0usize; n + 1]; m + 1];
            let mut max_len = 0usize;
            let mut end_pos = 0usize;

            for i in 1..=m {
                for j in 1..=n {
                    if a_chars[i - 1] == b_chars[j - 1] {
                        dp[i][j] = dp[i - 1][j - 1] + 1;
                        if dp[i][j] > max_len {
                            max_len = dp[i][j];
                            end_pos = i;
                        }
                    }
                }
            }

            a_chars[end_pos - max_len..end_pos].iter().collect()
        }
    }

    /// Text statistics calculator
    pub struct TextStatistics;

    impl TextStatistics {
        pub fn word_count(text: &str) -> usize {
            text.split_whitespace().count()
        }

        pub fn character_count(text: &str, include_whitespace: bool) -> usize {
            if include_whitespace {
                text.chars().count()
            } else {
                text.chars().filter(|c| !c.is_whitespace()).count()
            }
        }

        pub fn sentence_count(text: &str) -> usize {
            text.chars()
                .filter(|c| matches!(c, '.' | '!' | '?'))
                .count()
                .max(1)
        }

        pub fn paragraph_count(text: &str) -> usize {
            text.split("\n\n")
                .filter(|p| !p.trim().is_empty())
                .count()
                .max(1)
        }

        pub fn average_word_length(text: &str) -> f64 {
            let words: Vec<&str> = text.split_whitespace().collect();
            if words.is_empty() { return 0.0; }

            let total_length: usize = words.iter().map(|w| w.len()).sum();
            total_length as f64 / words.len() as f64
        }

        pub fn average_sentence_length(text: &str) -> f64 {
            let word_count = Self::word_count(text);
            let sentence_count = Self::sentence_count(text);
            if sentence_count == 0 { return 0.0; }

            word_count as f64 / sentence_count as f64
        }

        pub fn word_frequency(text: &str) -> HashMap<String, usize> {
            let mut freq = HashMap::new();
            for word in text.split_whitespace() {
                let word = word.to_lowercase()
                    .chars()
                    .filter(|c| c.is_alphanumeric())
                    .collect::<String>();
                if !word.is_empty() {
                    *freq.entry(word).or_insert(0) += 1;
                }
            }
            freq
        }

        pub fn flesch_reading_ease(text: &str) -> f64 {
            let words = Self::word_count(text) as f64;
            let sentences = Self::sentence_count(text) as f64;
            let syllables = Self::syllable_count(text) as f64;

            if words == 0.0 || sentences == 0.0 { return 0.0; }

            206.835 - (1.015 * (words / sentences)) - (84.6 * (syllables / words))
        }

        pub fn flesch_kincaid_grade(text: &str) -> f64 {
            let words = Self::word_count(text) as f64;
            let sentences = Self::sentence_count(text) as f64;
            let syllables = Self::syllable_count(text) as f64;

            if words == 0.0 || sentences == 0.0 { return 0.0; }

            (0.39 * (words / sentences)) + (11.8 * (syllables / words)) - 15.59
        }

        fn syllable_count(text: &str) -> usize {
            text.split_whitespace()
                .map(|word| Self::syllables_in_word(word))
                .sum()
        }

        fn syllables_in_word(word: &str) -> usize {
            let word = word.to_lowercase();
            let vowels = "aeiouy";
            let mut count = 0usize;
            let mut prev_was_vowel = false;

            for ch in word.chars() {
                let is_vowel = vowels.contains(ch);
                if is_vowel && !prev_was_vowel {
                    count += 1;
                }
                prev_was_vowel = is_vowel;
            }

            // Handle silent e
            if word.ends_with('e') && count > 1 {
                count -= 1;
            }

            count.max(1)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED COLLECTION TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Advanced data structures beyond standard collections
pub mod advanced_collections {
    use std::collections::{HashMap, HashSet, BTreeMap};
    use std::hash::{Hash, Hasher};

    /// Trie (prefix tree) for efficient string operations
    pub struct Trie {
        root: TrieNode,
    }

    struct TrieNode {
        children: HashMap<char, Box<TrieNode>>,
        is_end_of_word: bool,
        count: usize,
    }

    impl TrieNode {
        fn new() -> Self {
            Self {
                children: HashMap::new(),
                is_end_of_word: false,
                count: 0,
            }
        }
    }

    impl Trie {
        pub fn new() -> Self {
            Self { root: TrieNode::new() }
        }

        pub fn insert(&mut self, word: &str) {
            let mut current = &mut self.root;
            for ch in word.chars() {
                current = current.children
                    .entry(ch)
                    .or_insert_with(|| Box::new(TrieNode::new()));
            }
            current.is_end_of_word = true;
            current.count += 1;
        }

        pub fn search(&self, word: &str) -> bool {
            self.find_node(word)
                .map(|node| node.is_end_of_word)
                .unwrap_or(false)
        }

        pub fn starts_with(&self, prefix: &str) -> bool {
            self.find_node(prefix).is_some()
        }

        pub fn count(&self, word: &str) -> usize {
            self.find_node(word)
                .filter(|node| node.is_end_of_word)
                .map(|node| node.count)
                .unwrap_or(0)
        }

        fn find_node(&self, prefix: &str) -> Option<&TrieNode> {
            let mut current = &self.root;
            for ch in prefix.chars() {
                match current.children.get(&ch) {
                    Some(node) => current = node,
                    None => return None,
                }
            }
            Some(current)
        }

        pub fn words_with_prefix(&self, prefix: &str) -> Vec<String> {
            let mut results = Vec::new();
            if let Some(node) = self.find_node(prefix) {
                self.collect_words(node, prefix.to_string(), &mut results);
            }
            results
        }

        fn collect_words(&self, node: &TrieNode, current: String, results: &mut Vec<String>) {
            if node.is_end_of_word {
                results.push(current.clone());
            }
            for (ch, child) in &node.children {
                let mut next = current.clone();
                next.push(*ch);
                self.collect_words(child, next, results);
            }
        }

        pub fn delete(&mut self, word: &str) -> bool {
            Self::delete_recursive(&mut self.root, word, 0)
        }

        fn delete_recursive(node: &mut TrieNode, word: &str, depth: usize) -> bool {
            let chars: Vec<char> = word.chars().collect();

            if depth == chars.len() {
                if !node.is_end_of_word {
                    return false;
                }
                node.is_end_of_word = false;
                node.count = 0;
                return node.children.is_empty();
            }

            let ch = chars[depth];
            if let Some(child) = node.children.get_mut(&ch) {
                if Self::delete_recursive(child, word, depth + 1) {
                    node.children.remove(&ch);
                    return !node.is_end_of_word && node.children.is_empty();
                }
            }
            false
        }
    }

    /// Bloom filter for probabilistic set membership
    pub struct BloomFilter {
        bits: Vec<bool>,
        num_hashes: usize,
        size: usize,
    }

    impl BloomFilter {
        pub fn new(expected_items: usize, false_positive_rate: f64) -> Self {
            let size = Self::optimal_size(expected_items, false_positive_rate);
            let num_hashes = Self::optimal_hashes(size, expected_items);

            Self {
                bits: vec![false; size],
                num_hashes,
                size,
            }
        }

        fn optimal_size(n: usize, p: f64) -> usize {
            let m = -(n as f64 * p.ln()) / (2.0_f64.ln().powi(2));
            m.ceil() as usize
        }

        fn optimal_hashes(m: usize, n: usize) -> usize {
            let k = (m as f64 / n as f64) * 2.0_f64.ln();
            k.ceil() as usize
        }

        pub fn insert<T: Hash>(&mut self, item: &T) {
            for i in 0..self.num_hashes {
                let index = self.hash(item, i) % self.size;
                self.bits[index] = true;
            }
        }

        pub fn contains<T: Hash>(&self, item: &T) -> bool {
            for i in 0..self.num_hashes {
                let index = self.hash(item, i) % self.size;
                if !self.bits[index] {
                    return false;
                }
            }
            true
        }

        fn hash<T: Hash>(&self, item: &T, seed: usize) -> usize {
            use std::collections::hash_map::DefaultHasher;
            let mut hasher = DefaultHasher::new();
            item.hash(&mut hasher);
            seed.hash(&mut hasher);
            hasher.finish() as usize
        }

        pub fn false_positive_rate(&self) -> f64 {
            let set_bits = self.bits.iter().filter(|&&b| b).count();
            let fill_ratio = set_bits as f64 / self.size as f64;
            fill_ratio.powi(self.num_hashes as i32)
        }

        pub fn clear(&mut self) {
            self.bits.fill(false);
        }
    }

    /// Skip list for efficient ordered operations
    pub struct SkipList<K: Ord + Clone, V: Clone> {
        head: Vec<Option<Box<SkipNode<K, V>>>>,
        max_level: usize,
        level: usize,
        len: usize,
    }

    struct SkipNode<K, V> {
        key: K,
        value: V,
        forward: Vec<Option<Box<SkipNode<K, V>>>>,
    }

    impl<K: Ord + Clone, V: Clone> SkipList<K, V> {
        pub fn new(max_level: usize) -> Self {
            Self {
                head: vec![None; max_level],
                max_level,
                level: 0,
                len: 0,
            }
        }

        fn random_level(&self) -> usize {
            let mut level = 1;
            while level < self.max_level && rand_bool() {
                level += 1;
            }
            level
        }

        pub fn insert(&mut self, key: K, value: V) {
            let new_level = self.random_level();
            if new_level > self.level {
                self.level = new_level;
            }

            let new_node = Box::new(SkipNode {
                key: key.clone(),
                value,
                forward: vec![None; new_level],
            });

            let mut update: Vec<*mut Option<Box<SkipNode<K, V>>>> = vec![std::ptr::null_mut(); self.max_level];
            let mut current = &mut self.head as *mut Vec<Option<Box<SkipNode<K, V>>>>;

            for i in (0..self.level).rev() {
                unsafe {
                    loop {
                        if let Some(ref node) = (*current)[i] {
                            if node.key < key {
                                current = &mut (*current)[i].as_mut().unwrap().forward as *mut Vec<_>;
                                continue;
                            }
                        }
                        break;
                    }
                    update[i] = &mut (*current)[i] as *mut _;
                }
            }

            // Insert node at each level
            for i in 0..new_level {
                unsafe {
                    if !update[i].is_null() {
                        let next = (*update[i]).take();
                        let mut node = new_node.clone();
                        node.forward[i] = next;
                        *update[i] = Some(node);
                    }
                }
            }

            self.len += 1;
        }

        pub fn get(&self, key: &K) -> Option<&V> {
            let mut current = &self.head;

            for i in (0..self.level).rev() {
                loop {
                    if let Some(ref node) = current[i] {
                        if node.key < *key {
                            current = &node.forward;
                            continue;
                        } else if node.key == *key {
                            return Some(&node.value);
                        }
                    }
                    break;
                }
            }
            None
        }

        pub fn contains(&self, key: &K) -> bool {
            self.get(key).is_some()
        }

        pub fn len(&self) -> usize {
            self.len
        }

        pub fn is_empty(&self) -> bool {
            self.len == 0
        }
    }

    fn rand_bool() -> bool {
        use std::time::{SystemTime, UNIX_EPOCH};
        SystemTime::now()
            .duration_since(UNIX_EPOCH)
            .unwrap()
            .subsec_nanos() % 2 == 0
    }

    /// Disjoint set (Union-Find) with path compression
    pub struct DisjointSet {
        parent: Vec<usize>,
        rank: Vec<usize>,
        size: Vec<usize>,
    }

    impl DisjointSet {
        pub fn new(n: usize) -> Self {
            Self {
                parent: (0..n).collect(),
                rank: vec![0; n],
                size: vec![1; n],
            }
        }

        pub fn find(&mut self, x: usize) -> usize {
            if self.parent[x] != x {
                self.parent[x] = self.find(self.parent[x]); // Path compression
            }
            self.parent[x]
        }

        pub fn union(&mut self, x: usize, y: usize) -> bool {
            let px = self.find(x);
            let py = self.find(y);

            if px == py {
                return false;
            }

            // Union by rank
            if self.rank[px] < self.rank[py] {
                self.parent[px] = py;
                self.size[py] += self.size[px];
            } else if self.rank[px] > self.rank[py] {
                self.parent[py] = px;
                self.size[px] += self.size[py];
            } else {
                self.parent[py] = px;
                self.rank[px] += 1;
                self.size[px] += self.size[py];
            }
            true
        }

        pub fn connected(&mut self, x: usize, y: usize) -> bool {
            self.find(x) == self.find(y)
        }

        pub fn set_size(&mut self, x: usize) -> usize {
            let root = self.find(x);
            self.size[root]
        }

        pub fn num_sets(&mut self) -> usize {
            let n = self.parent.len();
            (0..n).filter(|&i| self.find(i) == i).count()
        }
    }

    /// Interval tree for range queries
    pub struct IntervalTree<V: Clone> {
        root: Option<Box<IntervalNode<V>>>,
    }

    struct IntervalNode<V> {
        interval: (i64, i64),
        max_end: i64,
        value: V,
        left: Option<Box<IntervalNode<V>>>,
        right: Option<Box<IntervalNode<V>>>,
    }

    impl<V: Clone> IntervalTree<V> {
        pub fn new() -> Self {
            Self { root: None }
        }

        pub fn insert(&mut self, start: i64, end: i64, value: V) {
            self.root = Self::insert_node(self.root.take(), start, end, value);
        }

        fn insert_node(
            node: Option<Box<IntervalNode<V>>>,
            start: i64,
            end: i64,
            value: V,
        ) -> Option<Box<IntervalNode<V>>> {
            match node {
                None => Some(Box::new(IntervalNode {
                    interval: (start, end),
                    max_end: end,
                    value,
                    left: None,
                    right: None,
                })),
                Some(mut n) => {
                    n.max_end = max!(n.max_end, end);
                    if start < n.interval.0 {
                        n.left = Self::insert_node(n.left, start, end, value);
                    } else {
                        n.right = Self::insert_node(n.right, start, end, value);
                    }
                    Some(n)
                }
            }
        }

        pub fn query(&self, point: i64) -> Vec<(i64, i64, &V)> {
            let mut results = Vec::new();
            Self::query_node(&self.root, point, &mut results);
            results
        }

        fn query_node<'a>(
            node: &'a Option<Box<IntervalNode<V>>>,
            point: i64,
            results: &mut Vec<(i64, i64, &'a V)>,
        ) {
            if let Some(n) = node {
                if point >= n.interval.0 && point <= n.interval.1 {
                    results.push((n.interval.0, n.interval.1, &n.value));
                }

                if n.left.as_ref().map_or(false, |l| l.max_end >= point) {
                    Self::query_node(&n.left, point, results);
                }

                Self::query_node(&n.right, point, results);
            }
        }

        pub fn overlapping(&self, start: i64, end: i64) -> Vec<(i64, i64, &V)> {
            let mut results = Vec::new();
            Self::overlap_node(&self.root, start, end, &mut results);
            results
        }

        fn overlap_node<'a>(
            node: &'a Option<Box<IntervalNode<V>>>,
            start: i64,
            end: i64,
            results: &mut Vec<(i64, i64, &'a V)>,
        ) {
            if let Some(n) = node {
                if start <= n.interval.1 && end >= n.interval.0 {
                    results.push((n.interval.0, n.interval.1, &n.value));
                }

                if n.left.as_ref().map_or(false, |l| l.max_end >= start) {
                    Self::overlap_node(&n.left, start, end, results);
                }

                if n.interval.0 <= end {
                    Self::overlap_node(&n.right, start, end, results);
                }
            }
        }
    }

    /// Segment tree for range queries and updates
    pub struct SegmentTree<T: Clone + Default> {
        tree: Vec<T>,
        n: usize,
        combine: fn(&T, &T) -> T,
    }

    impl<T: Clone + Default> SegmentTree<T> {
        pub fn new(data: &[T], combine: fn(&T, &T) -> T) -> Self {
            let n = data.len();
            let mut tree = vec![T::default(); 4 * n];

            let mut st = Self { tree, n, combine };
            st.build(data, 1, 0, n - 1);
            st
        }

        fn build(&mut self, data: &[T], node: usize, start: usize, end: usize) {
            if start == end {
                self.tree[node] = data[start].clone();
            } else {
                let mid = (start + end) / 2;
                self.build(data, 2 * node, start, mid);
                self.build(data, 2 * node + 1, mid + 1, end);
                self.tree[node] = (self.combine)(&self.tree[2 * node], &self.tree[2 * node + 1]);
            }
        }

        pub fn update(&mut self, idx: usize, value: T) {
            self.update_node(1, 0, self.n - 1, idx, value);
        }

        fn update_node(&mut self, node: usize, start: usize, end: usize, idx: usize, value: T) {
            if start == end {
                self.tree[node] = value;
            } else {
                let mid = (start + end) / 2;
                if idx <= mid {
                    self.update_node(2 * node, start, mid, idx, value);
                } else {
                    self.update_node(2 * node + 1, mid + 1, end, idx, value);
                }
                self.tree[node] = (self.combine)(&self.tree[2 * node], &self.tree[2 * node + 1]);
            }
        }

        pub fn query(&self, left: usize, right: usize) -> T {
            self.query_node(1, 0, self.n - 1, left, right)
        }

        fn query_node(&self, node: usize, start: usize, end: usize, left: usize, right: usize) -> T {
            if right < start || end < left {
                return T::default();
            }
            if left <= start && end <= right {
                return self.tree[node].clone();
            }
            let mid = (start + end) / 2;
            let left_result = self.query_node(2 * node, start, mid, left, right);
            let right_result = self.query_node(2 * node + 1, mid + 1, end, left, right);
            (self.combine)(&left_result, &right_result)
        }
    }

    /// Fenwick tree (Binary Indexed Tree) for prefix sums
    pub struct FenwickTree {
        tree: Vec<i64>,
        n: usize,
    }

    impl FenwickTree {
        pub fn new(n: usize) -> Self {
            Self {
                tree: vec![0; n + 1],
                n,
            }
        }

        pub fn from_slice(data: &[i64]) -> Self {
            let n = data.len();
            let mut ft = Self::new(n);
            for (i, &val) in data.iter().enumerate() {
                ft.update(i, val);
            }
            ft
        }

        pub fn update(&mut self, mut idx: usize, delta: i64) {
            idx += 1;
            while idx <= self.n {
                self.tree[idx] += delta;
                idx += idx & idx.wrapping_neg();
            }
        }

        pub fn prefix_sum(&self, mut idx: usize) -> i64 {
            idx += 1;
            let mut sum = 0;
            while idx > 0 {
                sum += self.tree[idx];
                idx -= idx & idx.wrapping_neg();
            }
            sum
        }

        pub fn range_sum(&self, left: usize, right: usize) -> i64 {
            if left == 0 {
                self.prefix_sum(right)
            } else {
                self.prefix_sum(right) - self.prefix_sum(left - 1)
            }
        }
    }

    /// LRU cache with O(1) operations
    pub struct LruCache<K: Eq + Hash + Clone, V: Clone> {
        capacity: usize,
        map: HashMap<K, usize>,
        entries: Vec<Option<(K, V)>>,
        order: VecDeque<usize>,
        free_slots: Vec<usize>,
    }

    use std::collections::VecDeque;

    impl<K: Eq + Hash + Clone, V: Clone> LruCache<K, V> {
        pub fn new(capacity: usize) -> Self {
            Self {
                capacity,
                map: HashMap::new(),
                entries: Vec::with_capacity(capacity),
                order: VecDeque::with_capacity(capacity),
                free_slots: Vec::new(),
            }
        }

        pub fn get(&mut self, key: &K) -> Option<&V> {
            if let Some(&idx) = self.map.get(key) {
                // Move to front
                self.order.retain(|&i| i != idx);
                self.order.push_front(idx);
                self.entries[idx].as_ref().map(|(_, v)| v)
            } else {
                None
            }
        }

        pub fn put(&mut self, key: K, value: V) {
            if let Some(&idx) = self.map.get(&key) {
                self.entries[idx] = Some((key.clone(), value));
                self.order.retain(|&i| i != idx);
                self.order.push_front(idx);
                return;
            }

            if self.map.len() >= self.capacity {
                if let Some(old_idx) = self.order.pop_back() {
                    if let Some((old_key, _)) = self.entries[old_idx].take() {
                        self.map.remove(&old_key);
                        self.free_slots.push(old_idx);
                    }
                }
            }

            let idx = if let Some(free_idx) = self.free_slots.pop() {
                self.entries[free_idx] = Some((key.clone(), value));
                free_idx
            } else {
                self.entries.push(Some((key.clone(), value)));
                self.entries.len() - 1
            };

            self.map.insert(key, idx);
            self.order.push_front(idx);
        }

        pub fn remove(&mut self, key: &K) -> Option<V> {
            if let Some(idx) = self.map.remove(key) {
                self.order.retain(|&i| i != idx);
                self.free_slots.push(idx);
                self.entries[idx].take().map(|(_, v)| v)
            } else {
                None
            }
        }

        pub fn len(&self) -> usize {
            self.map.len()
        }

        pub fn is_empty(&self) -> bool {
            self.map.is_empty()
        }

        pub fn capacity(&self) -> usize {
            self.capacity
        }

        pub fn clear(&mut self) {
            self.map.clear();
            self.entries.clear();
            self.order.clear();
            self.free_slots.clear();
        }
    }

    /// Multiset that allows duplicate elements
    pub struct MultiSet<T: Ord + Clone> {
        map: BTreeMap<T, usize>,
        len: usize,
    }

    impl<T: Ord + Clone> MultiSet<T> {
        pub fn new() -> Self {
            Self {
                map: BTreeMap::new(),
                len: 0,
            }
        }

        pub fn insert(&mut self, value: T) {
            *self.map.entry(value).or_insert(0) += 1;
            self.len += 1;
        }

        pub fn remove(&mut self, value: &T) -> bool {
            if let Some(count) = self.map.get_mut(value) {
                *count -= 1;
                if *count == 0 {
                    self.map.remove(value);
                }
                self.len -= 1;
                true
            } else {
                false
            }
        }

        pub fn remove_all(&mut self, value: &T) -> usize {
            if let Some(count) = self.map.remove(value) {
                self.len -= count;
                count
            } else {
                0
            }
        }

        pub fn count(&self, value: &T) -> usize {
            self.map.get(value).copied().unwrap_or(0)
        }

        pub fn contains(&self, value: &T) -> bool {
            self.map.contains_key(value)
        }

        pub fn len(&self) -> usize {
            self.len
        }

        pub fn is_empty(&self) -> bool {
            self.len == 0
        }

        pub fn unique_len(&self) -> usize {
            self.map.len()
        }

        pub fn min(&self) -> Option<&T> {
            self.map.keys().next()
        }

        pub fn max(&self) -> Option<&T> {
            self.map.keys().last()
        }

        pub fn iter(&self) -> impl Iterator<Item = &T> {
            self.map.iter().flat_map(|(k, &count)| std::iter::repeat(k).take(count))
        }
    }

    /// Bidirectional map
    pub struct BiMap<K: Eq + Hash + Clone, V: Eq + Hash + Clone> {
        forward: HashMap<K, V>,
        backward: HashMap<V, K>,
    }

    impl<K: Eq + Hash + Clone, V: Eq + Hash + Clone> BiMap<K, V> {
        pub fn new() -> Self {
            Self {
                forward: HashMap::new(),
                backward: HashMap::new(),
            }
        }

        pub fn insert(&mut self, key: K, value: V) -> Option<V> {
            if let Some(old_value) = self.forward.insert(key.clone(), value.clone()) {
                self.backward.remove(&old_value);
            }
            if let Some(old_key) = self.backward.insert(value, key) {
                self.forward.remove(&old_key);
            }
            None
        }

        pub fn get_by_key(&self, key: &K) -> Option<&V> {
            self.forward.get(key)
        }

        pub fn get_by_value(&self, value: &V) -> Option<&K> {
            self.backward.get(value)
        }

        pub fn remove_by_key(&mut self, key: &K) -> Option<V> {
            if let Some(value) = self.forward.remove(key) {
                self.backward.remove(&value);
                Some(value)
            } else {
                None
            }
        }

        pub fn remove_by_value(&mut self, value: &V) -> Option<K> {
            if let Some(key) = self.backward.remove(value) {
                self.forward.remove(&key);
                Some(key)
            } else {
                None
            }
        }

        pub fn contains_key(&self, key: &K) -> bool {
            self.forward.contains_key(key)
        }

        pub fn contains_value(&self, value: &V) -> bool {
            self.backward.contains_key(value)
        }

        pub fn len(&self) -> usize {
            self.forward.len()
        }

        pub fn is_empty(&self) -> bool {
            self.forward.is_empty()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GRAPH DATA STRUCTURES
// ═══════════════════════════════════════════════════════════════════════════════

/// Graph data structures and algorithms
pub mod graph {
    use std::collections::{HashMap, HashSet, BinaryHeap, VecDeque};
    use std::cmp::Ordering;

    /// Weighted directed graph
    pub struct Graph<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord> {
        adjacency: HashMap<V, Vec<(V, W)>>,
        vertices: HashSet<V>,
    }

    impl<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord> Graph<V, W> {
        pub fn new() -> Self {
            Self {
                adjacency: HashMap::new(),
                vertices: HashSet::new(),
            }
        }

        pub fn add_vertex(&mut self, vertex: V) {
            self.vertices.insert(vertex.clone());
            self.adjacency.entry(vertex).or_insert_with(Vec::new);
        }

        pub fn add_edge(&mut self, from: V, to: V, weight: W) {
            self.add_vertex(from.clone());
            self.add_vertex(to.clone());
            self.adjacency.get_mut(&from).unwrap().push((to, weight));
        }

        pub fn add_undirected_edge(&mut self, a: V, b: V, weight: W) {
            self.add_edge(a.clone(), b.clone(), weight.clone());
            self.add_edge(b, a, weight);
        }

        pub fn neighbors(&self, vertex: &V) -> Vec<&(V, W)> {
            self.adjacency.get(vertex)
                .map(|n| n.iter().collect())
                .unwrap_or_default()
        }

        pub fn vertices(&self) -> impl Iterator<Item = &V> {
            self.vertices.iter()
        }

        pub fn vertex_count(&self) -> usize {
            self.vertices.len()
        }

        pub fn edge_count(&self) -> usize {
            self.adjacency.values().map(|v| v.len()).sum()
        }

        pub fn has_vertex(&self, vertex: &V) -> bool {
            self.vertices.contains(vertex)
        }

        pub fn has_edge(&self, from: &V, to: &V) -> bool {
            self.adjacency.get(from)
                .map(|n| n.iter().any(|(v, _)| v == to))
                .unwrap_or(false)
        }

        pub fn remove_vertex(&mut self, vertex: &V) {
            self.vertices.remove(vertex);
            self.adjacency.remove(vertex);
            for edges in self.adjacency.values_mut() {
                edges.retain(|(v, _)| v != vertex);
            }
        }

        pub fn remove_edge(&mut self, from: &V, to: &V) {
            if let Some(edges) = self.adjacency.get_mut(from) {
                edges.retain(|(v, _)| v != to);
            }
        }
    }

    /// Graph traversal algorithms
    pub struct GraphTraversal;

    impl GraphTraversal {
        pub fn bfs<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            start: &V,
        ) -> Vec<V> {
            let mut visited = HashSet::new();
            let mut result = Vec::new();
            let mut queue = VecDeque::new();

            queue.push_back(start.clone());
            visited.insert(start.clone());

            while let Some(vertex) = queue.pop_front() {
                result.push(vertex.clone());

                for (neighbor, _) in graph.neighbors(&vertex) {
                    if !visited.contains(neighbor) {
                        visited.insert(neighbor.clone());
                        queue.push_back(neighbor.clone());
                    }
                }
            }

            result
        }

        pub fn dfs<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            start: &V,
        ) -> Vec<V> {
            let mut visited = HashSet::new();
            let mut result = Vec::new();
            Self::dfs_recursive(graph, start, &mut visited, &mut result);
            result
        }

        fn dfs_recursive<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            vertex: &V,
            visited: &mut HashSet<V>,
            result: &mut Vec<V>,
        ) {
            if visited.contains(vertex) {
                return;
            }

            visited.insert(vertex.clone());
            result.push(vertex.clone());

            for (neighbor, _) in graph.neighbors(vertex) {
                Self::dfs_recursive(graph, neighbor, visited, result);
            }
        }

        pub fn topological_sort<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
        ) -> Option<Vec<V>> {
            let mut in_degree: HashMap<V, usize> = HashMap::new();
            let mut result = Vec::new();
            let mut queue = VecDeque::new();

            for vertex in graph.vertices() {
                in_degree.insert(vertex.clone(), 0);
            }

            for vertex in graph.vertices() {
                for (neighbor, _) in graph.neighbors(vertex) {
                    *in_degree.get_mut(neighbor).unwrap() += 1;
                }
            }

            for (vertex, &degree) in &in_degree {
                if degree == 0 {
                    queue.push_back(vertex.clone());
                }
            }

            while let Some(vertex) = queue.pop_front() {
                result.push(vertex.clone());

                for (neighbor, _) in graph.neighbors(&vertex) {
                    let degree = in_degree.get_mut(neighbor).unwrap();
                    *degree -= 1;
                    if *degree == 0 {
                        queue.push_back(neighbor.clone());
                    }
                }
            }

            if result.len() == graph.vertex_count() {
                Some(result)
            } else {
                None // Cycle detected
            }
        }
    }

    /// Shortest path algorithms
    pub struct ShortestPath;

    #[derive(Clone)]
    struct DijkstraState<V, W> {
        cost: W,
        vertex: V,
    }

    impl<V: Eq, W: Ord> Ord for DijkstraState<V, W> {
        fn cmp(&self, other: &Self) -> Ordering {
            other.cost.cmp(&self.cost)
        }
    }

    impl<V: Eq, W: Ord> PartialOrd for DijkstraState<V, W> {
        fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
            Some(self.cmp(other))
        }
    }

    impl<V: Eq, W: Eq> Eq for DijkstraState<V, W> {}

    impl<V: Eq, W: Eq> PartialEq for DijkstraState<V, W> {
        fn eq(&self, other: &Self) -> bool {
            self.vertex == other.vertex && self.cost == other.cost
        }
    }

    impl ShortestPath {
        pub fn dijkstra<V: Clone + Eq + std::hash::Hash>(
            graph: &Graph<V, u64>,
            start: &V,
        ) -> HashMap<V, u64> {
            let mut distances: HashMap<V, u64> = HashMap::new();
            let mut heap = BinaryHeap::new();

            distances.insert(start.clone(), 0);
            heap.push(DijkstraState { cost: 0, vertex: start.clone() });

            while let Some(DijkstraState { cost, vertex }) = heap.pop() {
                if distances.get(&vertex).map_or(false, |&d| cost > d) {
                    continue;
                }

                for (neighbor, weight) in graph.neighbors(&vertex) {
                    let next_cost = cost + weight;
                    if distances.get(neighbor).map_or(true, |&d| next_cost < d) {
                        distances.insert(neighbor.clone(), next_cost);
                        heap.push(DijkstraState { cost: next_cost, vertex: neighbor.clone() });
                    }
                }
            }

            distances
        }

        pub fn dijkstra_path<V: Clone + Eq + std::hash::Hash>(
            graph: &Graph<V, u64>,
            start: &V,
            end: &V,
        ) -> Option<(u64, Vec<V>)> {
            let mut distances: HashMap<V, u64> = HashMap::new();
            let mut predecessors: HashMap<V, V> = HashMap::new();
            let mut heap = BinaryHeap::new();

            distances.insert(start.clone(), 0);
            heap.push(DijkstraState { cost: 0, vertex: start.clone() });

            while let Some(DijkstraState { cost, vertex }) = heap.pop() {
                if &vertex == end {
                    let mut path = vec![end.clone()];
                    let mut current = end.clone();
                    while let Some(pred) = predecessors.get(&current) {
                        path.push(pred.clone());
                        current = pred.clone();
                    }
                    path.reverse();
                    return Some((cost, path));
                }

                if distances.get(&vertex).map_or(false, |&d| cost > d) {
                    continue;
                }

                for (neighbor, weight) in graph.neighbors(&vertex) {
                    let next_cost = cost + weight;
                    if distances.get(neighbor).map_or(true, |&d| next_cost < d) {
                        distances.insert(neighbor.clone(), next_cost);
                        predecessors.insert(neighbor.clone(), vertex.clone());
                        heap.push(DijkstraState { cost: next_cost, vertex: neighbor.clone() });
                    }
                }
            }

            None
        }

        pub fn bellman_ford<V: Clone + Eq + std::hash::Hash>(
            graph: &Graph<V, i64>,
            start: &V,
        ) -> Option<HashMap<V, i64>> {
            let mut distances: HashMap<V, i64> = HashMap::new();
            distances.insert(start.clone(), 0);

            let vertices: Vec<V> = graph.vertices().cloned().collect();
            let n = vertices.len();

            for _ in 0..n - 1 {
                for vertex in &vertices {
                    if let Some(&dist) = distances.get(vertex) {
                        for (neighbor, weight) in graph.neighbors(vertex) {
                            let new_dist = dist + weight;
                            if distances.get(neighbor).map_or(true, |&d| new_dist < d) {
                                distances.insert(neighbor.clone(), new_dist);
                            }
                        }
                    }
                }
            }

            // Check for negative cycle
            for vertex in &vertices {
                if let Some(&dist) = distances.get(vertex) {
                    for (neighbor, weight) in graph.neighbors(vertex) {
                        if dist + weight < *distances.get(neighbor).unwrap_or(&i64::MAX) {
                            return None; // Negative cycle detected
                        }
                    }
                }
            }

            Some(distances)
        }

        pub fn floyd_warshall(
            n: usize,
            edges: &[(usize, usize, i64)],
        ) -> Vec<Vec<i64>> {
            let inf = i64::MAX / 2;
            let mut dist = vec![vec![inf; n]; n];

            for i in 0..n {
                dist[i][i] = 0;
            }

            for &(from, to, weight) in edges {
                dist[from][to] = weight;
            }

            for k in 0..n {
                for i in 0..n {
                    for j in 0..n {
                        if dist[i][k] + dist[k][j] < dist[i][j] {
                            dist[i][j] = dist[i][k] + dist[k][j];
                        }
                    }
                }
            }

            dist
        }
    }

    /// Minimum spanning tree algorithms
    pub struct MinimumSpanningTree;

    impl MinimumSpanningTree {
        pub fn kruskal<V: Clone + Eq + std::hash::Hash + Ord>(
            vertices: &[V],
            edges: &[(V, V, u64)],
        ) -> Vec<(V, V, u64)> {
            use super::advanced_collections::DisjointSet;

            let vertex_map: HashMap<V, usize> = vertices.iter()
                .enumerate()
                .map(|(i, v)| (v.clone(), i))
                .collect();

            let mut edges: Vec<_> = edges.iter().cloned().collect();
            edges.sort_by_key(|(_, _, w)| *w);

            let mut dsu = DisjointSet::new(vertices.len());
            let mut mst = Vec::new();

            for (from, to, weight) in edges {
                let from_idx = vertex_map[&from];
                let to_idx = vertex_map[&to];

                if !dsu.connected(from_idx, to_idx) {
                    dsu.union(from_idx, to_idx);
                    mst.push((from, to, weight));
                }
            }

            mst
        }

        pub fn prim(
            n: usize,
            edges: &[(usize, usize, u64)],
        ) -> Vec<(usize, usize, u64)> {
            let mut adj: Vec<Vec<(usize, u64)>> = vec![Vec::new(); n];
            for &(from, to, weight) in edges {
                adj[from].push((to, weight));
                adj[to].push((from, weight));
            }

            let mut in_mst = vec![false; n];
            let mut mst = Vec::new();
            let mut heap = BinaryHeap::new();

            in_mst[0] = true;
            for &(to, weight) in &adj[0] {
                heap.push(std::cmp::Reverse((weight, 0, to)));
            }

            while let Some(std::cmp::Reverse((weight, from, to))) = heap.pop() {
                if in_mst[to] {
                    continue;
                }

                in_mst[to] = true;
                mst.push((from, to, weight));

                for &(next, w) in &adj[to] {
                    if !in_mst[next] {
                        heap.push(std::cmp::Reverse((w, to, next)));
                    }
                }
            }

            mst
        }
    }

    /// Connected components
    pub struct ConnectedComponents;

    impl ConnectedComponents {
        pub fn find<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
        ) -> Vec<HashSet<V>> {
            let mut visited = HashSet::new();
            let mut components = Vec::new();

            for vertex in graph.vertices() {
                if visited.contains(vertex) {
                    continue;
                }

                let mut component = HashSet::new();
                let mut queue = VecDeque::new();
                queue.push_back(vertex.clone());

                while let Some(v) = queue.pop_front() {
                    if visited.contains(&v) {
                        continue;
                    }
                    visited.insert(v.clone());
                    component.insert(v.clone());

                    for (neighbor, _) in graph.neighbors(&v) {
                        if !visited.contains(neighbor) {
                            queue.push_back(neighbor.clone());
                        }
                    }
                }

                components.push(component);
            }

            components
        }

        pub fn strongly_connected<V: Clone + Eq + std::hash::Hash + Ord, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
        ) -> Vec<HashSet<V>> {
            // Kosaraju's algorithm
            let mut visited = HashSet::new();
            let mut order = Vec::new();

            // First DFS pass
            for vertex in graph.vertices() {
                if !visited.contains(vertex) {
                    Self::fill_order(graph, vertex, &mut visited, &mut order);
                }
            }

            // Build reverse graph
            let mut reverse = Graph::new();
            for vertex in graph.vertices() {
                reverse.add_vertex(vertex.clone());
                for (neighbor, weight) in graph.neighbors(vertex) {
                    reverse.add_edge(neighbor.clone(), vertex.clone(), weight.clone());
                }
            }

            // Second DFS pass
            visited.clear();
            let mut components = Vec::new();

            for vertex in order.into_iter().rev() {
                if !visited.contains(&vertex) {
                    let mut component = HashSet::new();
                    Self::collect_component(&reverse, &vertex, &mut visited, &mut component);
                    components.push(component);
                }
            }

            components
        }

        fn fill_order<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            vertex: &V,
            visited: &mut HashSet<V>,
            order: &mut Vec<V>,
        ) {
            visited.insert(vertex.clone());
            for (neighbor, _) in graph.neighbors(vertex) {
                if !visited.contains(neighbor) {
                    Self::fill_order(graph, neighbor, visited, order);
                }
            }
            order.push(vertex.clone());
        }

        fn collect_component<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            vertex: &V,
            visited: &mut HashSet<V>,
            component: &mut HashSet<V>,
        ) {
            visited.insert(vertex.clone());
            component.insert(vertex.clone());
            for (neighbor, _) in graph.neighbors(vertex) {
                if !visited.contains(neighbor) {
                    Self::collect_component(graph, neighbor, visited, component);
                }
            }
        }
    }

    /// Cycle detection
    pub struct CycleDetection;

    impl CycleDetection {
        pub fn has_cycle<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
        ) -> bool {
            let mut visited = HashSet::new();
            let mut rec_stack = HashSet::new();

            for vertex in graph.vertices() {
                if Self::is_cyclic(graph, vertex, &mut visited, &mut rec_stack) {
                    return true;
                }
            }
            false
        }

        fn is_cyclic<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            vertex: &V,
            visited: &mut HashSet<V>,
            rec_stack: &mut HashSet<V>,
        ) -> bool {
            if rec_stack.contains(vertex) {
                return true;
            }
            if visited.contains(vertex) {
                return false;
            }

            visited.insert(vertex.clone());
            rec_stack.insert(vertex.clone());

            for (neighbor, _) in graph.neighbors(vertex) {
                if Self::is_cyclic(graph, neighbor, visited, rec_stack) {
                    return true;
                }
            }

            rec_stack.remove(vertex);
            false
        }

        pub fn find_cycles<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
        ) -> Vec<Vec<V>> {
            let mut cycles = Vec::new();
            let mut visited = HashSet::new();
            let mut path = Vec::new();
            let mut path_set = HashSet::new();

            for vertex in graph.vertices() {
                if !visited.contains(vertex) {
                    Self::find_cycles_dfs(graph, vertex, &mut visited, &mut path, &mut path_set, &mut cycles);
                }
            }
            cycles
        }

        fn find_cycles_dfs<V: Clone + Eq + std::hash::Hash, W: Clone + Default + Ord>(
            graph: &Graph<V, W>,
            vertex: &V,
            visited: &mut HashSet<V>,
            path: &mut Vec<V>,
            path_set: &mut HashSet<V>,
            cycles: &mut Vec<Vec<V>>,
        ) {
            visited.insert(vertex.clone());
            path.push(vertex.clone());
            path_set.insert(vertex.clone());

            for (neighbor, _) in graph.neighbors(vertex) {
                if path_set.contains(neighbor) {
                    // Found a cycle
                    let start_idx = path.iter().position(|v| v == neighbor).unwrap();
                    let cycle: Vec<V> = path[start_idx..].to_vec();
                    cycles.push(cycle);
                } else if !visited.contains(neighbor) {
                    Self::find_cycles_dfs(graph, neighbor, visited, path, path_set, cycles);
                }
            }

            path.pop();
            path_set.remove(vertex);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYSTEM UTILITIES
// ═══════════════════════════════════════════════════════════════════════════════

/// System-level utilities and abstractions
pub mod system {
    use std::collections::{HashMap, HashSet};
    use std::time::{Duration, Instant, SystemTime, UNIX_EPOCH};

    /// Environment variable management
    pub struct Environment {
        vars: HashMap<String, String>,
    }

    impl Environment {
        pub fn new() -> Self {
            Self { vars: HashMap::new() }
        }

        pub fn from_system() -> Self {
            let mut env = Self::new();
            for (key, value) in std::env::vars() {
                env.vars.insert(key, value);
            }
            env
        }

        pub fn get(&self, key: &str) -> Option<&str> {
            self.vars.get(key).map(|s| s.as_str())
        }

        pub fn get_or(&self, key: &str, default: &str) -> String {
            self.vars.get(key).cloned().unwrap_or_else(|| default.to_string())
        }

        pub fn set(&mut self, key: &str, value: &str) {
            self.vars.insert(key.to_string(), value.to_string());
        }

        pub fn remove(&mut self, key: &str) -> Option<String> {
            self.vars.remove(key)
        }

        pub fn contains(&self, key: &str) -> bool {
            self.vars.contains_key(key)
        }

        pub fn keys(&self) -> impl Iterator<Item = &str> {
            self.vars.keys().map(|s| s.as_str())
        }

        pub fn values(&self) -> impl Iterator<Item = &str> {
            self.vars.values().map(|s| s.as_str())
        }

        pub fn expand(&self, template: &str) -> String {
            let mut result = template.to_string();
            for (key, value) in &self.vars {
                let pattern = format!("${{{}}}", key);
                result = result.replace(&pattern, value);
                let pattern = format!("${}", key);
                result = result.replace(&pattern, value);
            }
            result
        }

        pub fn export(&self) {
            for (key, value) in &self.vars {
                std::env::set_var(key, value);
            }
        }

        pub fn merge(&mut self, other: &Environment) {
            for (key, value) in &other.vars {
                self.vars.insert(key.clone(), value.clone());
            }
        }

        pub fn filter<F>(&self, predicate: F) -> Environment
        where
            F: Fn(&str, &str) -> bool,
        {
            let vars = self.vars.iter()
                .filter(|(k, v)| predicate(k, v))
                .map(|(k, v)| (k.clone(), v.clone()))
                .collect();
            Environment { vars }
        }
    }

    /// Path manipulation utilities
    pub struct PathUtils;

    impl PathUtils {
        pub fn join(base: &str, path: &str) -> String {
            if path.starts_with('/') || path.starts_with('\\') {
                path.to_string()
            } else if base.ends_with('/') || base.ends_with('\\') {
                format!("{}{}", base, path)
            } else {
                format!("{}/{}", base, path)
            }
        }

        pub fn normalize(path: &str) -> String {
            let separator = if path.contains('\\') { '\\' } else { '/' };
            let parts: Vec<&str> = path.split(|c| c == '/' || c == '\\').collect();
            let mut result = Vec::new();

            for part in parts {
                match part {
                    "" | "." => {}
                    ".." => {
                        if result.last().map_or(false, |s| *s != "..") {
                            result.pop();
                        } else if path.starts_with('/') || path.starts_with('\\') {
                            // Ignore .. at root
                        } else {
                            result.push("..");
                        }
                    }
                    _ => result.push(part),
                }
            }

            let normalized = result.join(&separator.to_string());
            if path.starts_with('/') || path.starts_with('\\') {
                format!("{}{}", separator, normalized)
            } else {
                normalized
            }
        }

        pub fn dirname(path: &str) -> &str {
            if let Some(pos) = path.rfind(|c| c == '/' || c == '\\') {
                if pos == 0 {
                    &path[..1]
                } else {
                    &path[..pos]
                }
            } else {
                "."
            }
        }

        pub fn basename(path: &str) -> &str {
            if let Some(pos) = path.rfind(|c| c == '/' || c == '\\') {
                &path[pos + 1..]
            } else {
                path
            }
        }

        pub fn extension(path: &str) -> Option<&str> {
            let basename = Self::basename(path);
            if let Some(pos) = basename.rfind('.') {
                if pos > 0 {
                    return Some(&basename[pos + 1..]);
                }
            }
            None
        }

        pub fn stem(path: &str) -> &str {
            let basename = Self::basename(path);
            if let Some(pos) = basename.rfind('.') {
                if pos > 0 {
                    return &basename[..pos];
                }
            }
            basename
        }

        pub fn with_extension(path: &str, ext: &str) -> String {
            let stem = Self::stem(path);
            let dir = Self::dirname(path);
            if ext.is_empty() {
                Self::join(dir, stem)
            } else {
                Self::join(dir, &format!("{}.{}", stem, ext))
            }
        }

        pub fn is_absolute(path: &str) -> bool {
            path.starts_with('/') ||
            (path.len() >= 2 && path.chars().nth(1) == Some(':'))
        }

        pub fn split(path: &str) -> Vec<&str> {
            path.split(|c| c == '/' || c == '\\')
                .filter(|s| !s.is_empty())
                .collect()
        }
    }

    /// Process information
    pub struct ProcessInfo {
        pub pid: u32,
        pub name: String,
        pub args: Vec<String>,
        pub env: HashMap<String, String>,
        pub cwd: String,
    }

    impl ProcessInfo {
        pub fn current() -> Self {
            Self {
                pid: std::process::id(),
                name: std::env::args().next().unwrap_or_default(),
                args: std::env::args().collect(),
                env: std::env::vars().collect(),
                cwd: std::env::current_dir()
                    .map(|p| p.to_string_lossy().to_string())
                    .unwrap_or_default(),
            }
        }
    }

    /// Resource limits
    pub struct ResourceLimits {
        pub max_memory: Option<usize>,
        pub max_cpu_time: Option<Duration>,
        pub max_file_size: Option<usize>,
        pub max_open_files: Option<usize>,
    }

    impl ResourceLimits {
        pub fn new() -> Self {
            Self {
                max_memory: None,
                max_cpu_time: None,
                max_file_size: None,
                max_open_files: None,
            }
        }

        pub fn with_memory(mut self, bytes: usize) -> Self {
            self.max_memory = Some(bytes);
            self
        }

        pub fn with_cpu_time(mut self, duration: Duration) -> Self {
            self.max_cpu_time = Some(duration);
            self
        }

        pub fn with_file_size(mut self, bytes: usize) -> Self {
            self.max_file_size = Some(bytes);
            self
        }

        pub fn with_open_files(mut self, count: usize) -> Self {
            self.max_open_files = Some(count);
            self
        }
    }

    /// High-resolution timer
    pub struct Timer {
        start: Instant,
        laps: Vec<Duration>,
    }

    impl Timer {
        pub fn start() -> Self {
            Self {
                start: Instant::now(),
                laps: Vec::new(),
            }
        }

        pub fn elapsed(&self) -> Duration {
            self.start.elapsed()
        }

        pub fn lap(&mut self) -> Duration {
            let now = Instant::now();
            let duration = now.duration_since(self.start);
            self.laps.push(duration);
            duration
        }

        pub fn reset(&mut self) {
            self.start = Instant::now();
            self.laps.clear();
        }

        pub fn laps(&self) -> &[Duration] {
            &self.laps
        }

        pub fn lap_times(&self) -> Vec<Duration> {
            let mut times = Vec::new();
            let mut prev = Duration::ZERO;
            for &lap in &self.laps {
                times.push(lap - prev);
                prev = lap;
            }
            times
        }
    }

    /// Stopwatch for cumulative timing
    pub struct Stopwatch {
        accumulated: Duration,
        start: Option<Instant>,
    }

    impl Stopwatch {
        pub fn new() -> Self {
            Self {
                accumulated: Duration::ZERO,
                start: None,
            }
        }

        pub fn start(&mut self) {
            if self.start.is_none() {
                self.start = Some(Instant::now());
            }
        }

        pub fn stop(&mut self) {
            if let Some(start) = self.start.take() {
                self.accumulated += start.elapsed();
            }
        }

        pub fn reset(&mut self) {
            self.accumulated = Duration::ZERO;
            self.start = None;
        }

        pub fn elapsed(&self) -> Duration {
            match self.start {
                Some(start) => self.accumulated + start.elapsed(),
                None => self.accumulated,
            }
        }

        pub fn is_running(&self) -> bool {
            self.start.is_some()
        }
    }

    /// Rate limiter using token bucket algorithm
    pub struct RateLimiter {
        rate: f64,
        capacity: f64,
        tokens: f64,
        last_update: Instant,
    }

    impl RateLimiter {
        pub fn new(rate: f64, capacity: f64) -> Self {
            Self {
                rate,
                capacity,
                tokens: capacity,
                last_update: Instant::now(),
            }
        }

        pub fn try_acquire(&mut self, tokens: f64) -> bool {
            self.refill();
            if self.tokens >= tokens {
                self.tokens -= tokens;
                true
            } else {
                false
            }
        }

        pub fn acquire(&mut self, tokens: f64) {
            loop {
                self.refill();
                if self.tokens >= tokens {
                    self.tokens -= tokens;
                    return;
                }
                let needed = tokens - self.tokens;
                let wait_time = Duration::from_secs_f64(needed / self.rate);
                std::thread::sleep(wait_time);
            }
        }

        fn refill(&mut self) {
            let now = Instant::now();
            let elapsed = now.duration_since(self.last_update).as_secs_f64();
            self.tokens = (self.tokens + elapsed * self.rate).min(self.capacity);
            self.last_update = now;
        }

        pub fn available(&mut self) -> f64 {
            self.refill();
            self.tokens
        }
    }

    /// Retry policy with exponential backoff
    pub struct RetryPolicy {
        max_attempts: usize,
        initial_delay: Duration,
        max_delay: Duration,
        multiplier: f64,
        jitter: bool,
    }

    impl RetryPolicy {
        pub fn new(max_attempts: usize) -> Self {
            Self {
                max_attempts,
                initial_delay: Duration::from_millis(100),
                max_delay: Duration::from_secs(30),
                multiplier: 2.0,
                jitter: true,
            }
        }

        pub fn with_initial_delay(mut self, delay: Duration) -> Self {
            self.initial_delay = delay;
            self
        }

        pub fn with_max_delay(mut self, delay: Duration) -> Self {
            self.max_delay = delay;
            self
        }

        pub fn with_multiplier(mut self, multiplier: f64) -> Self {
            self.multiplier = multiplier;
            self
        }

        pub fn with_jitter(mut self, jitter: bool) -> Self {
            self.jitter = jitter;
            self
        }

        pub fn execute<T, E, F>(&self, mut operation: F) -> Result<T, E>
        where
            F: FnMut() -> Result<T, E>,
        {
            let mut attempt = 0;
            let mut delay = self.initial_delay;

            loop {
                match operation() {
                    Ok(result) => return Ok(result),
                    Err(e) => {
                        attempt += 1;
                        if attempt >= self.max_attempts {
                            return Err(e);
                        }

                        let actual_delay = if self.jitter {
                            let jitter_factor = 0.5 + (attempt as f64 * 0.1).min(0.5);
                            Duration::from_secs_f64(delay.as_secs_f64() * jitter_factor)
                        } else {
                            delay
                        };

                        std::thread::sleep(actual_delay);
                        delay = delay.mul_f64(self.multiplier).min(self.max_delay);
                    }
                }
            }
        }

        pub fn delay_for_attempt(&self, attempt: usize) -> Duration {
            let mut delay = self.initial_delay;
            for _ in 0..attempt {
                delay = delay.mul_f64(self.multiplier).min(self.max_delay);
            }
            delay
        }
    }

    /// Circuit breaker pattern
    pub struct CircuitBreaker {
        failure_threshold: usize,
        reset_timeout: Duration,
        failure_count: usize,
        last_failure: Option<Instant>,
        state: CircuitState,
    }

    #[derive(Clone, Copy, PartialEq, Eq)]
    pub enum CircuitState {
        Closed,
        Open,
        HalfOpen,
    }

    impl CircuitBreaker {
        pub fn new(failure_threshold: usize, reset_timeout: Duration) -> Self {
            Self {
                failure_threshold,
                reset_timeout,
                failure_count: 0,
                last_failure: None,
                state: CircuitState::Closed,
            }
        }

        pub fn state(&self) -> CircuitState {
            self.state
        }

        pub fn is_closed(&self) -> bool {
            self.state == CircuitState::Closed
        }

        pub fn allow_request(&mut self) -> bool {
            match self.state {
                CircuitState::Closed => true,
                CircuitState::Open => {
                    if let Some(last) = self.last_failure {
                        if last.elapsed() >= self.reset_timeout {
                            self.state = CircuitState::HalfOpen;
                            true
                        } else {
                            false
                        }
                    } else {
                        true
                    }
                }
                CircuitState::HalfOpen => true,
            }
        }

        pub fn record_success(&mut self) {
            self.failure_count = 0;
            self.state = CircuitState::Closed;
        }

        pub fn record_failure(&mut self) {
            self.failure_count += 1;
            self.last_failure = Some(Instant::now());

            if self.failure_count >= self.failure_threshold {
                self.state = CircuitState::Open;
            }
        }

        pub fn execute<T, E, F>(&mut self, operation: F) -> Result<T, CircuitBreakerError<E>>
        where
            F: FnOnce() -> Result<T, E>,
        {
            if !self.allow_request() {
                return Err(CircuitBreakerError::CircuitOpen);
            }

            match operation() {
                Ok(result) => {
                    self.record_success();
                    Ok(result)
                }
                Err(e) => {
                    self.record_failure();
                    Err(CircuitBreakerError::OperationFailed(e))
                }
            }
        }
    }

    pub enum CircuitBreakerError<E> {
        CircuitOpen,
        OperationFailed(E),
    }

    /// Deadline tracker
    pub struct Deadline {
        end_time: Instant,
    }

    impl Deadline {
        pub fn new(timeout: Duration) -> Self {
            Self {
                end_time: Instant::now() + timeout,
            }
        }

        pub fn from_timestamp(end_time: Instant) -> Self {
            Self { end_time }
        }

        pub fn remaining(&self) -> Duration {
            self.end_time.saturating_duration_since(Instant::now())
        }

        pub fn is_expired(&self) -> bool {
            Instant::now() >= self.end_time
        }

        pub fn check(&self) -> Result<Duration, ()> {
            if self.is_expired() {
                Err(())
            } else {
                Ok(self.remaining())
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VALIDATION FRAMEWORK
// ═══════════════════════════════════════════════════════════════════════════════

/// Validation and constraint checking utilities
pub mod validation {
    use std::collections::HashMap;

    /// Validation error
    #[derive(Debug, Clone)]
    pub struct ValidationError {
        pub field: String,
        pub message: String,
        pub code: String,
    }

    impl ValidationError {
        pub fn new(field: &str, message: &str, code: &str) -> Self {
            Self {
                field: field.to_string(),
                message: message.to_string(),
                code: code.to_string(),
            }
        }
    }

    /// Validation result
    pub struct ValidationResult {
        errors: Vec<ValidationError>,
    }

    impl ValidationResult {
        pub fn new() -> Self {
            Self { errors: Vec::new() }
        }

        pub fn add_error(&mut self, error: ValidationError) {
            self.errors.push(error);
        }

        pub fn is_valid(&self) -> bool {
            self.errors.is_empty()
        }

        pub fn errors(&self) -> &[ValidationError] {
            &self.errors
        }

        pub fn merge(&mut self, other: ValidationResult) {
            self.errors.extend(other.errors);
        }

        pub fn error_count(&self) -> usize {
            self.errors.len()
        }

        pub fn errors_for_field(&self, field: &str) -> Vec<&ValidationError> {
            self.errors.iter().filter(|e| e.field == field).collect()
        }
    }

    /// Validator trait
    pub trait Validator<T> {
        fn validate(&self, value: &T) -> ValidationResult;
    }

    /// String validators
    pub struct StringValidators;

    impl StringValidators {
        pub fn not_empty(field: &str, value: &str) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value.is_empty() {
                result.add_error(ValidationError::new(
                    field,
                    "Must not be empty",
                    "NOT_EMPTY",
                ));
            }
            result
        }

        pub fn not_blank(field: &str, value: &str) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value.trim().is_empty() {
                result.add_error(ValidationError::new(
                    field,
                    "Must not be blank",
                    "NOT_BLANK",
                ));
            }
            result
        }

        pub fn min_length(field: &str, value: &str, min: usize) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value.len() < min {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must be at least {} characters", min),
                    "MIN_LENGTH",
                ));
            }
            result
        }

        pub fn max_length(field: &str, value: &str, max: usize) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value.len() > max {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must be at most {} characters", max),
                    "MAX_LENGTH",
                ));
            }
            result
        }

        pub fn length_between(field: &str, value: &str, min: usize, max: usize) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value.len() < min || value.len() > max {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must be between {} and {} characters", min, max),
                    "LENGTH_BETWEEN",
                ));
            }
            result
        }

        pub fn matches_regex(field: &str, value: &str, pattern: &str) -> ValidationResult {
            let mut result = ValidationResult::new();
            // Simplified regex matching (production would use regex crate)
            let patterns: HashMap<&str, fn(&str) -> bool> = HashMap::from([
                (r"^\d+$", |s: &str| s.chars().all(|c| c.is_ascii_digit())),
                (r"^[a-zA-Z]+$", |s: &str| s.chars().all(|c| c.is_ascii_alphabetic())),
                (r"^[a-zA-Z0-9]+$", |s: &str| s.chars().all(|c| c.is_ascii_alphanumeric())),
            ]);

            if let Some(matcher) = patterns.get(pattern) {
                if !matcher(value) {
                    result.add_error(ValidationError::new(
                        field,
                        &format!("Must match pattern {}", pattern),
                        "PATTERN_MISMATCH",
                    ));
                }
            }
            result
        }

        pub fn is_email(field: &str, value: &str) -> ValidationResult {
            let mut result = ValidationResult::new();
            if !value.contains('@') || !value.contains('.') {
                result.add_error(ValidationError::new(
                    field,
                    "Must be a valid email address",
                    "INVALID_EMAIL",
                ));
            }
            result
        }

        pub fn is_url(field: &str, value: &str) -> ValidationResult {
            let mut result = ValidationResult::new();
            if !value.starts_with("http://") && !value.starts_with("https://") {
                result.add_error(ValidationError::new(
                    field,
                    "Must be a valid URL",
                    "INVALID_URL",
                ));
            }
            result
        }

        pub fn is_alphanumeric(field: &str, value: &str) -> ValidationResult {
            let mut result = ValidationResult::new();
            if !value.chars().all(|c| c.is_alphanumeric()) {
                result.add_error(ValidationError::new(
                    field,
                    "Must contain only alphanumeric characters",
                    "ALPHANUMERIC",
                ));
            }
            result
        }
    }

    /// Numeric validators
    pub struct NumericValidators;

    impl NumericValidators {
        pub fn min<T: PartialOrd + std::fmt::Display>(field: &str, value: T, min: T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value < min {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must be at least {}", min),
                    "MIN_VALUE",
                ));
            }
            result
        }

        pub fn max<T: PartialOrd + std::fmt::Display>(field: &str, value: T, max: T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value > max {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must be at most {}", max),
                    "MAX_VALUE",
                ));
            }
            result
        }

        pub fn range<T: PartialOrd + std::fmt::Display>(field: &str, value: T, min: T, max: T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value < min || value > max {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must be between {} and {}", min, max),
                    "RANGE",
                ));
            }
            result
        }

        pub fn positive<T: PartialOrd + Default>(field: &str, value: T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value <= T::default() {
                result.add_error(ValidationError::new(
                    field,
                    "Must be positive",
                    "POSITIVE",
                ));
            }
            result
        }

        pub fn negative<T: PartialOrd + Default>(field: &str, value: T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value >= T::default() {
                result.add_error(ValidationError::new(
                    field,
                    "Must be negative",
                    "NEGATIVE",
                ));
            }
            result
        }

        pub fn not_zero<T: PartialEq + Default>(field: &str, value: T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if value == T::default() {
                result.add_error(ValidationError::new(
                    field,
                    "Must not be zero",
                    "NOT_ZERO",
                ));
            }
            result
        }
    }

    /// Collection validators
    pub struct CollectionValidators;

    impl CollectionValidators {
        pub fn not_empty<T>(field: &str, collection: &[T]) -> ValidationResult {
            let mut result = ValidationResult::new();
            if collection.is_empty() {
                result.add_error(ValidationError::new(
                    field,
                    "Must not be empty",
                    "NOT_EMPTY",
                ));
            }
            result
        }

        pub fn min_size<T>(field: &str, collection: &[T], min: usize) -> ValidationResult {
            let mut result = ValidationResult::new();
            if collection.len() < min {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must have at least {} elements", min),
                    "MIN_SIZE",
                ));
            }
            result
        }

        pub fn max_size<T>(field: &str, collection: &[T], max: usize) -> ValidationResult {
            let mut result = ValidationResult::new();
            if collection.len() > max {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must have at most {} elements", max),
                    "MAX_SIZE",
                ));
            }
            result
        }

        pub fn size_between<T>(field: &str, collection: &[T], min: usize, max: usize) -> ValidationResult {
            let mut result = ValidationResult::new();
            let len = collection.len();
            if len < min || len > max {
                result.add_error(ValidationError::new(
                    field,
                    &format!("Must have between {} and {} elements", min, max),
                    "SIZE_BETWEEN",
                ));
            }
            result
        }

        pub fn contains<T: PartialEq>(field: &str, collection: &[T], item: &T) -> ValidationResult {
            let mut result = ValidationResult::new();
            if !collection.contains(item) {
                result.add_error(ValidationError::new(
                    field,
                    "Must contain the required element",
                    "CONTAINS",
                ));
            }
            result
        }

        pub fn unique<T: Eq + std::hash::Hash>(field: &str, collection: &[T]) -> ValidationResult {
            use std::collections::HashSet;
            let mut result = ValidationResult::new();
            let mut seen = HashSet::new();
            for item in collection {
                if !seen.insert(item) {
                    result.add_error(ValidationError::new(
                        field,
                        "Must contain only unique elements",
                        "UNIQUE",
                    ));
                    break;
                }
            }
            result
        }
    }

    /// Composite validator builder
    pub struct ValidatorBuilder<T> {
        validators: Vec<Box<dyn Fn(&T) -> ValidationResult>>,
    }

    impl<T> ValidatorBuilder<T> {
        pub fn new() -> Self {
            Self { validators: Vec::new() }
        }

        pub fn add<F>(mut self, validator: F) -> Self
        where
            F: Fn(&T) -> ValidationResult + 'static,
        {
            self.validators.push(Box::new(validator));
            self
        }

        pub fn validate(&self, value: &T) -> ValidationResult {
            let mut result = ValidationResult::new();
            for validator in &self.validators {
                result.merge(validator(value));
            }
            result
        }
    }

    /// Schema-based validation
    pub struct Schema {
        fields: HashMap<String, Vec<Box<dyn Fn(&str) -> ValidationResult>>>,
    }

    impl Schema {
        pub fn new() -> Self {
            Self { fields: HashMap::new() }
        }

        pub fn field<F>(mut self, name: &str, validator: F) -> Self
        where
            F: Fn(&str) -> ValidationResult + 'static,
        {
            self.fields
                .entry(name.to_string())
                .or_insert_with(Vec::new)
                .push(Box::new(validator));
            self
        }

        pub fn validate(&self, data: &HashMap<String, String>) -> ValidationResult {
            let mut result = ValidationResult::new();

            for (field, validators) in &self.fields {
                let value = data.get(field).map(|s| s.as_str()).unwrap_or("");
                for validator in validators {
                    result.merge(validator(value));
                }
            }

            result
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NUMERIC UTILITIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Advanced numeric types and utilities
pub mod numeric {
    use std::ops::{Add, Sub, Mul, Div, Neg};
    use std::cmp::Ordering;

    /// Rational number (fraction)
    #[derive(Clone, Copy, Debug)]
    pub struct Rational {
        pub numerator: i64,
        pub denominator: i64,
    }

    impl Rational {
        pub fn new(numerator: i64, denominator: i64) -> Self {
            assert!(denominator != 0, "Denominator cannot be zero");
            let mut r = Self { numerator, denominator };
            r.reduce();
            r
        }

        pub fn from_integer(n: i64) -> Self {
            Self { numerator: n, denominator: 1 }
        }

        pub fn zero() -> Self {
            Self { numerator: 0, denominator: 1 }
        }

        pub fn one() -> Self {
            Self { numerator: 1, denominator: 1 }
        }

        fn gcd(mut a: i64, mut b: i64) -> i64 {
            a = a.abs();
            b = b.abs();
            while b != 0 {
                let t = b;
                b = a % b;
                a = t;
            }
            a
        }

        fn reduce(&mut self) {
            let g = Self::gcd(self.numerator, self.denominator);
            self.numerator /= g;
            self.denominator /= g;
            if self.denominator < 0 {
                self.numerator = -self.numerator;
                self.denominator = -self.denominator;
            }
        }

        pub fn reciprocal(self) -> Self {
            Self::new(self.denominator, self.numerator)
        }

        pub fn abs(self) -> Self {
            Self::new(self.numerator.abs(), self.denominator)
        }

        pub fn floor(self) -> i64 {
            if self.numerator >= 0 {
                self.numerator / self.denominator
            } else {
                (self.numerator - self.denominator + 1) / self.denominator
            }
        }

        pub fn ceil(self) -> i64 {
            if self.numerator >= 0 {
                (self.numerator + self.denominator - 1) / self.denominator
            } else {
                self.numerator / self.denominator
            }
        }

        pub fn round(self) -> i64 {
            let floor = self.floor();
            let frac = self - Self::from_integer(floor);
            if frac >= Self::new(1, 2) {
                floor + 1
            } else {
                floor
            }
        }

        pub fn to_f64(self) -> f64 {
            self.numerator as f64 / self.denominator as f64
        }

        pub fn is_integer(self) -> bool {
            self.denominator == 1
        }

        pub fn is_zero(self) -> bool {
            self.numerator == 0
        }

        pub fn is_positive(self) -> bool {
            self.numerator > 0
        }

        pub fn is_negative(self) -> bool {
            self.numerator < 0
        }
    }

    impl Add for Rational {
        type Output = Self;
        fn add(self, other: Self) -> Self {
            Self::new(
                self.numerator * other.denominator + other.numerator * self.denominator,
                self.denominator * other.denominator,
            )
        }
    }

    impl Sub for Rational {
        type Output = Self;
        fn sub(self, other: Self) -> Self {
            Self::new(
                self.numerator * other.denominator - other.numerator * self.denominator,
                self.denominator * other.denominator,
            )
        }
    }

    impl Mul for Rational {
        type Output = Self;
        fn mul(self, other: Self) -> Self {
            Self::new(
                self.numerator * other.numerator,
                self.denominator * other.denominator,
            )
        }
    }

    impl Div for Rational {
        type Output = Self;
        fn div(self, other: Self) -> Self {
            self * other.reciprocal()
        }
    }

    impl Neg for Rational {
        type Output = Self;
        fn neg(self) -> Self {
            Self::new(-self.numerator, self.denominator)
        }
    }

    impl PartialEq for Rational {
        fn eq(&self, other: &Self) -> bool {
            self.numerator == other.numerator && self.denominator == other.denominator
        }
    }

    impl Eq for Rational {}

    impl PartialOrd for Rational {
        fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
            Some(self.cmp(other))
        }
    }

    impl Ord for Rational {
        fn cmp(&self, other: &Self) -> Ordering {
            (self.numerator * other.denominator).cmp(&(other.numerator * self.denominator))
        }
    }

    /// Complex number
    #[derive(Clone, Copy, Debug)]
    pub struct Complex {
        pub real: f64,
        pub imag: f64,
    }

    impl Complex {
        pub fn new(real: f64, imag: f64) -> Self {
            Self { real, imag }
        }

        pub fn from_polar(magnitude: f64, phase: f64) -> Self {
            Self {
                real: magnitude * phase.cos(),
                imag: magnitude * phase.sin(),
            }
        }

        pub fn zero() -> Self {
            Self { real: 0.0, imag: 0.0 }
        }

        pub fn one() -> Self {
            Self { real: 1.0, imag: 0.0 }
        }

        pub fn i() -> Self {
            Self { real: 0.0, imag: 1.0 }
        }

        pub fn conjugate(self) -> Self {
            Self { real: self.real, imag: -self.imag }
        }

        pub fn magnitude(self) -> f64 {
            (self.real * self.real + self.imag * self.imag).sqrt()
        }

        pub fn magnitude_squared(self) -> f64 {
            self.real * self.real + self.imag * self.imag
        }

        pub fn phase(self) -> f64 {
            self.imag.atan2(self.real)
        }

        pub fn reciprocal(self) -> Self {
            let denom = self.magnitude_squared();
            Self {
                real: self.real / denom,
                imag: -self.imag / denom,
            }
        }

        pub fn exp(self) -> Self {
            let exp_real = self.real.exp();
            Self {
                real: exp_real * self.imag.cos(),
                imag: exp_real * self.imag.sin(),
            }
        }

        pub fn ln(self) -> Self {
            Self {
                real: self.magnitude().ln(),
                imag: self.phase(),
            }
        }

        pub fn pow(self, n: Self) -> Self {
            (n * self.ln()).exp()
        }

        pub fn sqrt(self) -> Self {
            let r = self.magnitude().sqrt();
            let theta = self.phase() / 2.0;
            Self::from_polar(r, theta)
        }

        pub fn sin(self) -> Self {
            Self {
                real: self.real.sin() * self.imag.cosh(),
                imag: self.real.cos() * self.imag.sinh(),
            }
        }

        pub fn cos(self) -> Self {
            Self {
                real: self.real.cos() * self.imag.cosh(),
                imag: -self.real.sin() * self.imag.sinh(),
            }
        }

        pub fn is_real(self) -> bool {
            self.imag.abs() < 1e-15
        }

        pub fn is_imaginary(self) -> bool {
            self.real.abs() < 1e-15
        }
    }

    impl Add for Complex {
        type Output = Self;
        fn add(self, other: Self) -> Self {
            Self {
                real: self.real + other.real,
                imag: self.imag + other.imag,
            }
        }
    }

    impl Sub for Complex {
        type Output = Self;
        fn sub(self, other: Self) -> Self {
            Self {
                real: self.real - other.real,
                imag: self.imag - other.imag,
            }
        }
    }

    impl Mul for Complex {
        type Output = Self;
        fn mul(self, other: Self) -> Self {
            Self {
                real: self.real * other.real - self.imag * other.imag,
                imag: self.real * other.imag + self.imag * other.real,
            }
        }
    }

    impl Div for Complex {
        type Output = Self;
        fn div(self, other: Self) -> Self {
            self * other.reciprocal()
        }
    }

    impl Neg for Complex {
        type Output = Self;
        fn neg(self) -> Self {
            Self { real: -self.real, imag: -self.imag }
        }
    }

    /// Fixed-point number with configurable precision
    #[derive(Clone, Copy, Debug)]
    pub struct FixedPoint<const FRAC_BITS: u32> {
        raw: i64,
    }

    impl<const FRAC_BITS: u32> FixedPoint<FRAC_BITS> {
        const SCALE: i64 = 1 << FRAC_BITS;

        pub fn new(value: f64) -> Self {
            Self {
                raw: (value * Self::SCALE as f64).round() as i64,
            }
        }

        pub fn from_raw(raw: i64) -> Self {
            Self { raw }
        }

        pub fn from_integer(n: i64) -> Self {
            Self { raw: n << FRAC_BITS }
        }

        pub fn raw(self) -> i64 {
            self.raw
        }

        pub fn to_f64(self) -> f64 {
            self.raw as f64 / Self::SCALE as f64
        }

        pub fn floor(self) -> i64 {
            self.raw >> FRAC_BITS
        }

        pub fn ceil(self) -> i64 {
            (self.raw + Self::SCALE - 1) >> FRAC_BITS
        }

        pub fn round(self) -> i64 {
            (self.raw + (Self::SCALE >> 1)) >> FRAC_BITS
        }

        pub fn abs(self) -> Self {
            Self { raw: self.raw.abs() }
        }

        pub fn fract(self) -> Self {
            Self { raw: self.raw & (Self::SCALE - 1) }
        }
    }

    impl<const FRAC_BITS: u32> Add for FixedPoint<FRAC_BITS> {
        type Output = Self;
        fn add(self, other: Self) -> Self {
            Self { raw: self.raw + other.raw }
        }
    }

    impl<const FRAC_BITS: u32> Sub for FixedPoint<FRAC_BITS> {
        type Output = Self;
        fn sub(self, other: Self) -> Self {
            Self { raw: self.raw - other.raw }
        }
    }

    impl<const FRAC_BITS: u32> Mul for FixedPoint<FRAC_BITS> {
        type Output = Self;
        fn mul(self, other: Self) -> Self {
            Self { raw: (self.raw * other.raw) >> FRAC_BITS }
        }
    }

    impl<const FRAC_BITS: u32> Div for FixedPoint<FRAC_BITS> {
        type Output = Self;
        fn div(self, other: Self) -> Self {
            Self { raw: (self.raw << FRAC_BITS) / other.raw }
        }
    }

    /// Saturating integer arithmetic
    pub struct Saturating<T>(pub T);

    impl Saturating<i32> {
        pub fn add(self, other: i32) -> i32 {
            self.0.saturating_add(other)
        }

        pub fn sub(self, other: i32) -> i32 {
            self.0.saturating_sub(other)
        }

        pub fn mul(self, other: i32) -> i32 {
            self.0.saturating_mul(other)
        }
    }

    impl Saturating<i64> {
        pub fn add(self, other: i64) -> i64 {
            self.0.saturating_add(other)
        }

        pub fn sub(self, other: i64) -> i64 {
            self.0.saturating_sub(other)
        }

        pub fn mul(self, other: i64) -> i64 {
            self.0.saturating_mul(other)
        }
    }

    /// Numeric range utilities
    pub struct Range {
        pub start: f64,
        pub end: f64,
    }

    impl Range {
        pub fn new(start: f64, end: f64) -> Self {
            Self { start, end }
        }

        pub fn length(&self) -> f64 {
            self.end - self.start
        }

        pub fn midpoint(&self) -> f64 {
            (self.start + self.end) / 2.0
        }

        pub fn contains(&self, value: f64) -> bool {
            value >= self.start && value <= self.end
        }

        pub fn clamp(&self, value: f64) -> f64 {
            value.max(self.start).min(self.end)
        }

        pub fn normalize(&self, value: f64) -> f64 {
            (value - self.start) / self.length()
        }

        pub fn denormalize(&self, t: f64) -> f64 {
            self.start + t * self.length()
        }

        pub fn lerp(&self, t: f64) -> f64 {
            self.denormalize(t)
        }

        pub fn map(&self, value: f64, target: &Range) -> f64 {
            let t = self.normalize(value);
            target.denormalize(t)
        }

        pub fn intersect(&self, other: &Range) -> Option<Range> {
            let start = self.start.max(other.start);
            let end = self.end.min(other.end);
            if start <= end {
                Some(Range::new(start, end))
            } else {
                None
            }
        }

        pub fn union(&self, other: &Range) -> Range {
            Range::new(self.start.min(other.start), self.end.max(other.end))
        }

        pub fn overlaps(&self, other: &Range) -> bool {
            self.start <= other.end && other.start <= self.end
        }

        pub fn subdivide(&self, n: usize) -> Vec<Range> {
            let step = self.length() / n as f64;
            (0..n)
                .map(|i| Range::new(
                    self.start + i as f64 * step,
                    self.start + (i + 1) as f64 * step,
                ))
                .collect()
        }
    }

    /// Statistical utilities
    pub struct Statistics;

    impl Statistics {
        pub fn mean(data: &[f64]) -> f64 {
            if data.is_empty() { return 0.0; }
            data.iter().sum::<f64>() / data.len() as f64
        }

        pub fn variance(data: &[f64]) -> f64 {
            if data.is_empty() { return 0.0; }
            let mean = Self::mean(data);
            data.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / data.len() as f64
        }

        pub fn std_dev(data: &[f64]) -> f64 {
            Self::variance(data).sqrt()
        }

        pub fn median(data: &mut [f64]) -> f64 {
            if data.is_empty() { return 0.0; }
            data.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let mid = data.len() / 2;
            if data.len() % 2 == 0 {
                (data[mid - 1] + data[mid]) / 2.0
            } else {
                data[mid]
            }
        }

        pub fn mode(data: &[f64]) -> Option<f64> {
            use std::collections::HashMap;
            let mut counts: HashMap<u64, usize> = HashMap::new();
            for &x in data {
                *counts.entry(x.to_bits()).or_insert(0) += 1;
            }
            counts.into_iter()
                .max_by_key(|(_, count)| *count)
                .map(|(bits, _)| f64::from_bits(bits))
        }

        pub fn percentile(data: &mut [f64], p: f64) -> f64 {
            if data.is_empty() { return 0.0; }
            data.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let idx = (p / 100.0 * (data.len() - 1) as f64).round() as usize;
            data[idx]
        }

        pub fn min(data: &[f64]) -> f64 {
            data.iter().cloned().fold(f64::INFINITY, f64::min)
        }

        pub fn max(data: &[f64]) -> f64 {
            data.iter().cloned().fold(f64::NEG_INFINITY, f64::max)
        }

        pub fn sum(data: &[f64]) -> f64 {
            data.iter().sum()
        }

        pub fn product(data: &[f64]) -> f64 {
            data.iter().product()
        }

        pub fn correlation(x: &[f64], y: &[f64]) -> f64 {
            if x.len() != y.len() || x.is_empty() { return 0.0; }

            let mean_x = Self::mean(x);
            let mean_y = Self::mean(y);
            let std_x = Self::std_dev(x);
            let std_y = Self::std_dev(y);

            if std_x == 0.0 || std_y == 0.0 { return 0.0; }

            let covariance: f64 = x.iter().zip(y.iter())
                .map(|(xi, yi)| (xi - mean_x) * (yi - mean_y))
                .sum::<f64>() / x.len() as f64;

            covariance / (std_x * std_y)
        }

        pub fn linear_regression(x: &[f64], y: &[f64]) -> (f64, f64) {
            if x.len() != y.len() || x.is_empty() { return (0.0, 0.0); }

            let n = x.len() as f64;
            let sum_x: f64 = x.iter().sum();
            let sum_y: f64 = y.iter().sum();
            let sum_xy: f64 = x.iter().zip(y.iter()).map(|(xi, yi)| xi * yi).sum();
            let sum_x2: f64 = x.iter().map(|xi| xi * xi).sum();

            let slope = (n * sum_xy - sum_x * sum_y) / (n * sum_x2 - sum_x * sum_x);
            let intercept = (sum_y - slope * sum_x) / n;

            (slope, intercept)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FUNCTIONAL UTILITIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Functional programming utilities
pub mod functional {
    use std::marker::PhantomData;

    /// Option extensions
    pub trait OptionExt<T> {
        fn or_try<E, F: FnOnce() -> Result<T, E>>(self, f: F) -> Result<T, E>;
        fn filter_map<U, F: FnOnce(T) -> Option<U>>(self, f: F) -> Option<U>;
        fn tap<F: FnOnce(&T)>(self, f: F) -> Self;
        fn tap_none<F: FnOnce()>(self, f: F) -> Self;
    }

    impl<T> OptionExt<T> for Option<T> {
        fn or_try<E, F: FnOnce() -> Result<T, E>>(self, f: F) -> Result<T, E> {
            match self {
                Some(t) => Ok(t),
                None => f(),
            }
        }

        fn filter_map<U, F: FnOnce(T) -> Option<U>>(self, f: F) -> Option<U> {
            self.and_then(f)
        }

        fn tap<F: FnOnce(&T)>(self, f: F) -> Self {
            if let Some(ref t) = self {
                f(t);
            }
            self
        }

        fn tap_none<F: FnOnce()>(self, f: F) -> Self {
            if self.is_none() {
                f();
            }
            self
        }
    }

    /// Result extensions
    pub trait ResultExt<T, E> {
        fn tap_ok<F: FnOnce(&T)>(self, f: F) -> Self;
        fn tap_err<F: FnOnce(&E)>(self, f: F) -> Self;
        fn map_both<T2, E2, FT: FnOnce(T) -> T2, FE: FnOnce(E) -> E2>(
            self,
            ft: FT,
            fe: FE,
        ) -> Result<T2, E2>;
    }

    impl<T, E> ResultExt<T, E> for Result<T, E> {
        fn tap_ok<F: FnOnce(&T)>(self, f: F) -> Self {
            if let Ok(ref t) = self {
                f(t);
            }
            self
        }

        fn tap_err<F: FnOnce(&E)>(self, f: F) -> Self {
            if let Err(ref e) = self {
                f(e);
            }
            self
        }

        fn map_both<T2, E2, FT: FnOnce(T) -> T2, FE: FnOnce(E) -> E2>(
            self,
            ft: FT,
            fe: FE,
        ) -> Result<T2, E2> {
            match self {
                Ok(t) => Ok(ft(t)),
                Err(e) => Err(fe(e)),
            }
        }
    }

    /// Iterator extensions
    pub trait IteratorExt: Iterator {
        fn try_fold_while<B, F, E>(self, init: B, f: F) -> Result<B, E>
        where
            F: FnMut(B, Self::Item) -> Result<ControlFlow<B, B>, E>;

        fn intersperse_with<F>(self, separator: F) -> IntersperseWith<Self, F>
        where
            Self: Sized,
            F: FnMut() -> Self::Item;

        fn chunks(self, size: usize) -> Chunks<Self>
        where
            Self: Sized;

        fn unique(self) -> Unique<Self>
        where
            Self: Sized,
            Self::Item: Eq + std::hash::Hash + Clone;
    }

    pub enum ControlFlow<B, C> {
        Continue(C),
        Break(B),
    }

    impl<I: Iterator> IteratorExt for I {
        fn try_fold_while<B, F, E>(mut self, init: B, mut f: F) -> Result<B, E>
        where
            F: FnMut(B, Self::Item) -> Result<ControlFlow<B, B>, E>,
        {
            let mut acc = init;
            while let Some(item) = self.next() {
                match f(acc, item)? {
                    ControlFlow::Continue(b) => acc = b,
                    ControlFlow::Break(b) => return Ok(b),
                }
            }
            Ok(acc)
        }

        fn intersperse_with<F>(self, separator: F) -> IntersperseWith<Self, F>
        where
            F: FnMut() -> Self::Item,
        {
            IntersperseWith {
                iter: self,
                separator,
                needs_sep: false,
                next_item: None,
            }
        }

        fn chunks(self, size: usize) -> Chunks<Self> {
            Chunks { iter: self, size }
        }

        fn unique(self) -> Unique<Self>
        where
            Self::Item: Eq + std::hash::Hash + Clone,
        {
            Unique {
                iter: self,
                seen: std::collections::HashSet::new(),
            }
        }
    }

    pub struct IntersperseWith<I: Iterator, F> {
        iter: I,
        separator: F,
        needs_sep: bool,
        next_item: Option<I::Item>,
    }

    impl<I: Iterator, F: FnMut() -> I::Item> Iterator for IntersperseWith<I, F> {
        type Item = I::Item;

        fn next(&mut self) -> Option<Self::Item> {
            if self.needs_sep {
                self.needs_sep = false;
                Some((self.separator)())
            } else {
                let item = self.next_item.take().or_else(|| self.iter.next())?;
                self.next_item = self.iter.next();
                self.needs_sep = self.next_item.is_some();
                Some(item)
            }
        }
    }

    pub struct Chunks<I: Iterator> {
        iter: I,
        size: usize,
    }

    impl<I: Iterator> Iterator for Chunks<I> {
        type Item = Vec<I::Item>;

        fn next(&mut self) -> Option<Self::Item> {
            let mut chunk = Vec::with_capacity(self.size);
            for _ in 0..self.size {
                match self.iter.next() {
                    Some(item) => chunk.push(item),
                    None => break,
                }
            }
            if chunk.is_empty() {
                None
            } else {
                Some(chunk)
            }
        }
    }

    pub struct Unique<I: Iterator>
    where
        I::Item: Eq + std::hash::Hash + Clone,
    {
        iter: I,
        seen: std::collections::HashSet<I::Item>,
    }

    impl<I: Iterator> Iterator for Unique<I>
    where
        I::Item: Eq + std::hash::Hash + Clone,
    {
        type Item = I::Item;

        fn next(&mut self) -> Option<Self::Item> {
            for item in self.iter.by_ref() {
                if self.seen.insert(item.clone()) {
                    return Some(item);
                }
            }
            None
        }
    }

    /// Lazy evaluation wrapper
    pub struct Lazy<T, F: FnOnce() -> T> {
        cell: std::cell::OnceCell<T>,
        init: std::cell::Cell<Option<F>>,
    }

    impl<T, F: FnOnce() -> T> Lazy<T, F> {
        pub fn new(init: F) -> Self {
            Self {
                cell: std::cell::OnceCell::new(),
                init: std::cell::Cell::new(Some(init)),
            }
        }

        pub fn get(&self) -> &T {
            self.cell.get_or_init(|| {
                (self.init.take().expect("Lazy already initialized"))()
            })
        }

        pub fn is_initialized(&self) -> bool {
            self.cell.get().is_some()
        }
    }

    /// Function composition utilities
    pub fn compose<A, B, C, F, G>(f: F, g: G) -> impl Fn(A) -> C
    where
        F: Fn(A) -> B,
        G: Fn(B) -> C,
    {
        move |a| g(f(a))
    }

    pub fn pipe<A, B, C, F, G>(f: F, g: G) -> impl Fn(A) -> C
    where
        F: Fn(A) -> B,
        G: Fn(B) -> C,
    {
        compose(f, g)
    }

    /// Curry a two-argument function
    pub fn curry2<A, B, C, F>(f: F) -> impl Fn(A) -> impl Fn(B) -> C
    where
        A: Clone,
        F: Fn(A, B) -> C + Clone,
    {
        move |a: A| {
            let f = f.clone();
            let a = a.clone();
            move |b: B| f(a.clone(), b)
        }
    }

    /// Memoization helper
    pub struct Memoized<K, V, F>
    where
        K: Eq + std::hash::Hash + Clone,
        V: Clone,
        F: Fn(&K) -> V,
    {
        cache: std::cell::RefCell<std::collections::HashMap<K, V>>,
        func: F,
    }

    impl<K, V, F> Memoized<K, V, F>
    where
        K: Eq + std::hash::Hash + Clone,
        V: Clone,
        F: Fn(&K) -> V,
    {
        pub fn new(func: F) -> Self {
            Self {
                cache: std::cell::RefCell::new(std::collections::HashMap::new()),
                func,
            }
        }

        pub fn call(&self, key: &K) -> V {
            if let Some(value) = self.cache.borrow().get(key) {
                return value.clone();
            }
            let value = (self.func)(key);
            self.cache.borrow_mut().insert(key.clone(), value.clone());
            value
        }

        pub fn clear(&self) {
            self.cache.borrow_mut().clear();
        }
    }

    /// Either type for sum types
    pub enum Either<L, R> {
        Left(L),
        Right(R),
    }

    impl<L, R> Either<L, R> {
        pub fn is_left(&self) -> bool {
            matches!(self, Either::Left(_))
        }

        pub fn is_right(&self) -> bool {
            matches!(self, Either::Right(_))
        }

        pub fn left(self) -> Option<L> {
            match self {
                Either::Left(l) => Some(l),
                Either::Right(_) => None,
            }
        }

        pub fn right(self) -> Option<R> {
            match self {
                Either::Left(_) => None,
                Either::Right(r) => Some(r),
            }
        }

        pub fn map_left<L2, F: FnOnce(L) -> L2>(self, f: F) -> Either<L2, R> {
            match self {
                Either::Left(l) => Either::Left(f(l)),
                Either::Right(r) => Either::Right(r),
            }
        }

        pub fn map_right<R2, F: FnOnce(R) -> R2>(self, f: F) -> Either<L, R2> {
            match self {
                Either::Left(l) => Either::Left(l),
                Either::Right(r) => Either::Right(f(r)),
            }
        }

        pub fn either<T, FL: FnOnce(L) -> T, FR: FnOnce(R) -> T>(self, fl: FL, fr: FR) -> T {
            match self {
                Either::Left(l) => fl(l),
                Either::Right(r) => fr(r),
            }
        }
    }

    /// NonEmpty list that is guaranteed to have at least one element
    pub struct NonEmpty<T> {
        head: T,
        tail: Vec<T>,
    }

    impl<T> NonEmpty<T> {
        pub fn new(head: T, tail: Vec<T>) -> Self {
            Self { head, tail }
        }

        pub fn singleton(value: T) -> Self {
            Self { head: value, tail: Vec::new() }
        }

        pub fn from_vec(vec: Vec<T>) -> Option<Self> {
            let mut iter = vec.into_iter();
            iter.next().map(|head| Self {
                head,
                tail: iter.collect(),
            })
        }

        pub fn head(&self) -> &T {
            &self.head
        }

        pub fn tail(&self) -> &[T] {
            &self.tail
        }

        pub fn len(&self) -> usize {
            1 + self.tail.len()
        }

        pub fn push(mut self, value: T) -> Self {
            self.tail.push(value);
            self
        }

        pub fn map<U, F: FnMut(T) -> U>(self, mut f: F) -> NonEmpty<U> {
            NonEmpty {
                head: f(self.head),
                tail: self.tail.into_iter().map(f).collect(),
            }
        }

        pub fn iter(&self) -> impl Iterator<Item = &T> {
            std::iter::once(&self.head).chain(self.tail.iter())
        }

        pub fn into_vec(self) -> Vec<T> {
            let mut vec = Vec::with_capacity(self.len());
            vec.push(self.head);
            vec.extend(self.tail);
            vec
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_math() {
        use std::math::*;
        assert!((sin(PI / 2.0) - 1.0).abs() < 1e-10);
        assert!((cos(0.0) - 1.0).abs() < 1e-10);
    }

    #[test]
    fn test_collections() {
        use std::collections::*;

        let mut map = HashMap::new();
        map.insert("key", 42);
        assert_eq!(map.get(&"key"), Some(&42));
    }

    #[test]
    fn test_tensor() {
        use std::ai::*;

        let t = Tensor::new(&[2, 3]);
        assert_eq!(t.shape(), &[2, 3]);
        assert_eq!(t.size(), 6);
    }

    #[test]
    fn test_json() {
        use serialization::json;

        let value = json::parse(r#"{"name": "test", "value": 42}"#).unwrap();
        assert!(value.is_object());
        assert_eq!(value.get("name").unwrap().as_str(), Some("test"));
        assert_eq!(value.get("value").unwrap().as_i64(), Some(42));
    }

    #[test]
    fn test_concurrency() {
        use concurrency::*;

        let counter = AtomicUsize::new(0);
        counter.fetch_add(1, Ordering::SeqCst);
        assert_eq!(counter.load(Ordering::SeqCst), 1);
    }
}
