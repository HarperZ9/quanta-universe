// MODULE 3: std::collections
// ═══════════════════════════════════════════════════════════════════════════════

pub mod collections {
    /// Dynamic array
    pub struct Vec<T> {
        data: *mut T,
        len: usize,
        capacity: usize,
    }
    
    impl<T> Vec<T> {
        pub fn new() -> Self {
            Vec { data: std::ptr::null_mut(), len: 0, capacity: 0 }
        }
        
        pub fn with_capacity(cap: usize) -> Self {
            let data = alloc::alloc_array::<T>(cap);
            Vec { data, len: 0, capacity: cap }
        }
        
        pub fn push(&mut self, value: T) {
            if self.len == self.capacity {
                self.grow();
            }
            unsafe {
                std::ptr::write(self.data.add(self.len), value);
            }
            self.len += 1;
        }
        
        pub fn pop(&mut self) -> Option<T> {
            if self.len == 0 { return None; }
            self.len -= 1;
            unsafe { Some(std::ptr::read(self.data.add(self.len))) }
        }
        
        pub fn get(&self, index: usize) -> Option<&T> {
            if index >= self.len { return None; }
            unsafe { Some(&*self.data.add(index)) }
        }
        
        pub fn len(&self) -> usize { self.len }
        pub fn is_empty(&self) -> bool { self.len == 0 }
        pub fn capacity(&self) -> usize { self.capacity }
        
        fn grow(&mut self) {
            let new_cap = if self.capacity == 0 { 4 } else { self.capacity * 2 };
            let new_data = alloc::alloc_array::<T>(new_cap);
            
            unsafe {
                std::ptr::copy_nonoverlapping(self.data, new_data, self.len);
            }
            
            if !self.data.is_null() {
                alloc::dealloc_array(self.data, self.capacity);
            }
            
            self.data = new_data;
            self.capacity = new_cap;
        }
    }
    
    /// Hash map
    pub struct HashMap<K, V> {
        buckets: Vec<Vec<(K, V)>>,
        len: usize,
    }
    
    impl<K: Hash + Eq, V> HashMap<K, V> {
        pub fn new() -> Self {
            let mut buckets = Vec::with_capacity(16);
            for _ in 0..16 { buckets.push(Vec::new()); }
            HashMap { buckets, len: 0 }
        }
        
        pub fn insert(&mut self, key: K, value: V) -> Option<V> {
            let bucket_idx = self.bucket_index(&key);
            
            // Check for existing key
            for (k, v) in &mut self.buckets[bucket_idx] {
                if k == &key {
                    let old = std::mem::replace(v, value);
                    return Some(old);
                }
            }
            
            // Insert new
            self.buckets[bucket_idx].push((key, value));
            self.len += 1;
            
            // Resize if needed
            if self.len > self.buckets.len() * 3 / 4 {
                self.resize();
            }
            
            None
        }
        
        pub fn get(&self, key: &K) -> Option<&V> {
            let bucket_idx = self.bucket_index(key);
            for (k, v) in &self.buckets[bucket_idx] {
                if k == key { return Some(v); }
            }
            None
        }
        
        pub fn remove(&mut self, key: &K) -> Option<V> {
            let bucket_idx = self.bucket_index(key);
            let bucket = &mut self.buckets[bucket_idx];
            
            for i in 0..bucket.len() {
                if &bucket[i].0 == key {
                    let (_, v) = bucket.remove(i);
                    self.len -= 1;
                    return Some(v);
                }
            }
            None
        }
        
        pub fn contains_key(&self, key: &K) -> bool {
            self.get(key).is_some()
        }
        
        pub fn len(&self) -> usize { self.len }
        pub fn is_empty(&self) -> bool { self.len == 0 }
        
        fn bucket_index(&self, key: &K) -> usize {
            let hash = key.hash();
            hash as usize % self.buckets.len()
        }
        
        fn resize(&mut self) {
            let new_size = self.buckets.len() * 2;
            let mut new_buckets = Vec::with_capacity(new_size);
            for _ in 0..new_size { new_buckets.push(Vec::new()); }
            
            for bucket in self.buckets.drain(..) {
                for (k, v) in bucket {
                    let idx = k.hash() as usize % new_size;
                    new_buckets[idx].push((k, v));
                }
            }
            
            self.buckets = new_buckets;
        }
    }
    
    /// Double-ended queue
    pub struct VecDeque<T> {
        buffer: Vec<Option<T>>,
        head: usize,
        tail: usize,
    }
    
    impl<T> VecDeque<T> {
        pub fn new() -> Self {
            VecDeque {
                buffer: Vec::with_capacity(16),
                head: 0,
                tail: 0,
            }
        }
        
        pub fn push_back(&mut self, value: T) {
            // Implementation
        }
        
        pub fn push_front(&mut self, value: T) {
            // Implementation
        }
        
        pub fn pop_back(&mut self) -> Option<T> { None }
        pub fn pop_front(&mut self) -> Option<T> { None }
        
        pub fn len(&self) -> usize { 0 }
        pub fn is_empty(&self) -> bool { self.len() == 0 }
    }
    
    /// Binary heap (priority queue)
    pub struct BinaryHeap<T: Ord> {
        data: Vec<T>,
    }
    
    impl<T: Ord> BinaryHeap<T> {
        pub fn new() -> Self { BinaryHeap { data: Vec::new() } }
        
        pub fn push(&mut self, value: T) {
            self.data.push(value);
            self.sift_up(self.data.len() - 1);
        }
        
        pub fn pop(&mut self) -> Option<T> {
            if self.data.is_empty() { return None; }
            let last_idx = self.data.len() - 1;
            self.data.swap(0, last_idx);
            let result = self.data.pop();
            if !self.data.is_empty() {
                self.sift_down(0);
            }
            result
        }
        
        pub fn peek(&self) -> Option<&T> {
            self.data.first()
        }
        
        fn sift_up(&mut self, mut idx: usize) {
            while idx > 0 {
                let parent = (idx - 1) / 2;
                if self.data[idx] <= self.data[parent] { break; }
                self.data.swap(idx, parent);
                idx = parent;
            }
        }
        
        fn sift_down(&mut self, mut idx: usize) {
            let len = self.data.len();
            loop {
                let left = 2 * idx + 1;
                let right = 2 * idx + 2;
                let mut largest = idx;
                
                if left < len && self.data[left] > self.data[largest] {
                    largest = left;
                }
                if right < len && self.data[right] > self.data[largest] {
                    largest = right;
                }
                
                if largest == idx { break; }
                self.data.swap(idx, largest);
                idx = largest;
            }
        }
    }
    
    /// Ordered set (B-tree based)
    pub struct BTreeSet<T: Ord> {
        // Simplified implementation
        data: Vec<T>,
    }
    
    impl<T: Ord> BTreeSet<T> {
        pub fn new() -> Self { BTreeSet { data: Vec::new() } }
        
        pub fn insert(&mut self, value: T) -> bool {
            match self.data.binary_search(&value) {
                Ok(_) => false,
                Err(idx) => {
                    self.data.insert(idx, value);
                    true
                }
            }
        }
        
        pub fn contains(&self, value: &T) -> bool {
            self.data.binary_search(value).is_ok()
        }
        
        pub fn remove(&mut self, value: &T) -> bool {
            match self.data.binary_search(value) {
                Ok(idx) => {
                    self.data.remove(idx);
                    true
                }
                Err(_) => false,
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODULE 4: std::io
// ═══════════════════════════════════════════════════════════════════════════════

pub mod io {
    pub trait Read {
        fn read(&mut self, buf: &mut [u8]) -> Result<usize, IoError>;
        
        fn read_exact(&mut self, buf: &mut [u8]) -> Result<(), IoError> {
            let mut total = 0;
            while total < buf.len() {
                match self.read(&mut buf[total..]) {
                    Ok(0) => return Err(IoError::UnexpectedEof),
                    Ok(n) => total += n,
                    Err(e) => return Err(e),
                }
            }
            Ok(())
        }
        
        fn read_to_end(&mut self, buf: &mut Vec<u8>) -> Result<usize, IoError> {
            let mut total = 0;
            let mut chunk = [0u8; 4096];
            loop {
                match self.read(&mut chunk) {
                    Ok(0) => break,
                    Ok(n) => {
                        buf.extend_from_slice(&chunk[..n]);
                        total += n;
                    }
                    Err(e) => return Err(e),
                }
            }
            Ok(total)
        }
    }
    
    pub trait Write {
        fn write(&mut self, buf: &[u8]) -> Result<usize, IoError>;
        fn flush(&mut self) -> Result<(), IoError>;
        
        fn write_all(&mut self, buf: &[u8]) -> Result<(), IoError> {
            let mut written = 0;
            while written < buf.len() {
                match self.write(&buf[written..]) {
                    Ok(0) => return Err(IoError::WriteZero),
                    Ok(n) => written += n,
                    Err(e) => return Err(e),
                }
            }
            Ok(())
        }
    }
    
    #[derive(Debug)]
    pub enum IoError {
        NotFound,
        PermissionDenied,
        ConnectionRefused,
        ConnectionReset,
        BrokenPipe,
        AlreadyExists,
        WouldBlock,
        InvalidInput,
        InvalidData,
        TimedOut,
        WriteZero,
        UnexpectedEof,
        Other(String),
    }
    
    /// Buffered reader
    pub struct BufReader<R: Read> {
        inner: R,
        buffer: Vec<u8>,
        pos: usize,
        cap: usize,
    }
    
    impl<R: Read> BufReader<R> {
        pub fn new(inner: R) -> Self {
            BufReader::with_capacity(8192, inner)
        }
        
        pub fn with_capacity(cap: usize, inner: R) -> Self {
            BufReader {
                inner,
                buffer: vec![0; cap],
                pos: 0,
                cap: 0,
            }
        }
        
        fn fill_buf(&mut self) -> Result<&[u8], IoError> {
            if self.pos >= self.cap {
                self.cap = self.inner.read(&mut self.buffer)?;
                self.pos = 0;
            }
            Ok(&self.buffer[self.pos..self.cap])
        }
        
        fn consume(&mut self, amt: usize) {
            self.pos = std::cmp::min(self.pos + amt, self.cap);
        }
        
        pub fn read_line(&mut self, buf: &mut String) -> Result<usize, IoError> {
            // Simplified: read until newline or EOF
            let mut total: usize = 0;
            let mut done = false;
            while !done {
                let buf_data = &self.buffer[self.pos..self.cap];
                if buf_data.is_empty() {
                    done = true;
                } else {
                    let mut found_newline = false;
                    let mut newline_pos: usize = 0;
                    let mut idx: usize = 0;
                    while idx < buf_data.len() {
                        if buf_data[idx] == 10 {
                            found_newline = true;
                            newline_pos = idx;
                            idx = buf_data.len();
                        }
                        idx = idx + 1;
                    }
                    if found_newline {
                        total = total + newline_pos + 1;
                        self.pos = self.pos + newline_pos + 1;
                        done = true;
                    } else {
                        total = total + buf_data.len();
                        self.pos = self.cap;
                    }
                }
            }
            Ok(total)
        }
    }
    
    /// Buffered writer
    pub struct BufWriter<W: Write> {
        inner: W,
        buffer: Vec<u8>,
    }
    
    impl<W: Write> BufWriter<W> {
        pub fn with_capacity(cap: usize, inner: W) -> Self {
            BufWriter {
                inner,
                buffer: Vec::with_capacity(cap),
            }
        }

        pub fn new(inner: W) -> Self {
            BufWriter::with_capacity(8192, inner)
        }
    }
    
    impl<W: Write> Write for BufWriter<W> {
        fn write(&mut self, buf: &[u8]) -> Result<usize, IoError> {
            if self.buffer.len() + buf.len() > self.buffer.capacity() {
                self.flush()?;
            }
            
            if buf.len() >= self.buffer.capacity() {
                self.inner.write(buf)
            } else {
                self.buffer.extend_from_slice(buf);
                Ok(buf.len())
            }
        }
        
        fn flush(&mut self) -> Result<(), IoError> {
            self.inner.write_all(&self.buffer)?;
            self.buffer.clear();
            self.inner.flush()
        }
    }
    
    // Standard streams
    pub struct Stdin;
    pub struct Stdout;
    pub struct Stderr;

    pub fn stdin() -> Stdin { Stdin }
    pub fn stdout() -> Stdout { Stdout }
    pub fn stderr() -> Stderr { Stderr }
    
    impl Read for Stdin {
        fn read(&mut self, buf: &mut [u8]) -> Result<usize, IoError> {
            // System call to read from stdin
            Ok(0)
        }
    }
    
    impl Write for Stdout {
        fn write(&mut self, buf: &[u8]) -> Result<usize, IoError> {
            // System call to write to stdout
            Ok(buf.len())
        }
        fn flush(&mut self) -> Result<(), IoError> { Ok(()) }
    }
    
    impl Write for Stderr {
        fn write(&mut self, buf: &[u8]) -> Result<usize, IoError> {
            Ok(buf.len())
        }
        fn flush(&mut self) -> Result<(), IoError> { Ok(()) }
    }
    
    // Convenience functions
    pub fn print(s: &str) {
        let _ = stdout().write_all(s.as_bytes());
    }
    
    pub fn println(s: &str) {
        print(s);
        print("\n");
    }
    
    pub fn eprint(s: &str) {
        let _ = stderr().write_all(s.as_bytes());
    }
    
    pub fn eprintln(s: &str) {
        eprint(s);
        eprint("\n");
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODULE 12: std::ai - AI/ML Primitives
// ═══════════════════════════════════════════════════════════════════════════════

pub mod ai {
    use std::collections::Vec;
    use std::math::{exp, log, sqrt, tanh};
    
    /// Tensor - multi-dimensional array for ML
    pub struct Tensor {
        data: Vec<f32>,
        shape: Vec<usize>,
        strides: Vec<usize>,
    }
    
    impl Tensor {
        pub fn new(shape: &[usize]) -> Self {
            let size: usize = shape.iter().product();
            let strides = Self::compute_strides(shape);
            Tensor {
                data: vec![0.0; size],
                shape: shape.to_vec(),
                strides,
            }
        }
        
        pub fn from_data(data: Vec<f32>, shape: &[usize]) -> Self {
            let strides = Self::compute_strides(shape);
            Tensor { data, shape: shape.to_vec(), strides }
        }
        
        fn compute_strides(shape: &[usize]) -> Vec<usize> {
            let mut strides = vec![1; shape.len()];
            for i in (0..shape.len()-1).rev() {
                strides[i] = strides[i+1] * shape[i+1];
            }
            strides
        }
        
        pub fn shape(&self) -> &[usize] { &self.shape }
        pub fn ndim(&self) -> usize { self.shape.len() }
        pub fn size(&self) -> usize { self.data.len() }
        
        pub fn get(&self, indices: &[usize]) -> f32 {
            let idx = self.linear_index(indices);
            self.data[idx]
        }
        
        pub fn set(&mut self, indices: &[usize], value: f32) {
            let idx = self.linear_index(indices);
            self.data[idx] = value;
        }
        
        fn linear_index(&self, indices: &[usize]) -> usize {
            indices.iter().zip(&self.strides).map(|(i, s)| i * s).sum()
        }
        
        // Matrix multiplication
        pub fn matmul(&self, other: &Tensor) -> Tensor {
            assert!(self.ndim() == 2 && other.ndim() == 2);
            assert!(self.shape[1] == other.shape[0]);
            
            let m = self.shape[0];
            let n = other.shape[1];
            let k = self.shape[1];
            
            let mut result = Tensor::new(&[m, n]);
            
            for i in 0..m {
                for j in 0..n {
                    let mut sum = 0.0;
                    for l in 0..k {
                        sum += self.get(&[i, l]) * other.get(&[l, j]);
                    }
                    result.set(&[i, j], sum);
                }
            }
            
            result
        }
        
        // Element-wise operations
        pub fn add(&self, other: &Tensor) -> Tensor {
            assert_eq!(self.shape, other.shape);
            let data: Vec<f32> = self.data.iter()
                .zip(&other.data)
                .map(|(a, b)| a + b)
                .collect();
            Tensor::from_data(data, &self.shape)
        }
        
        pub fn sub(&self, other: &Tensor) -> Tensor {
            assert_eq!(self.shape, other.shape);
            let data: Vec<f32> = self.data.iter()
                .zip(&other.data)
                .map(|(a, b)| a - b)
                .collect();
            Tensor::from_data(data, &self.shape)
        }
        
        pub fn mul(&self, other: &Tensor) -> Tensor {
            assert_eq!(self.shape, other.shape);
            let data: Vec<f32> = self.data.iter()
                .zip(&other.data)
                .map(|(a, b)| a * b)
                .collect();
            Tensor::from_data(data, &self.shape)
        }
        
        pub fn scale(&self, s: f32) -> Tensor {
            let data: Vec<f32> = self.data.iter().map(|x| x * s).collect();
            Tensor::from_data(data, &self.shape)
        }
        
        // Activation functions
        pub fn relu(&self) -> Tensor {
            let data: Vec<f32> = self.data.iter()
                .map(|&x| if x > 0.0 { x } else { 0.0 })
                .collect();
            Tensor::from_data(data, &self.shape)
        }
        
        pub fn sigmoid(&self) -> Tensor {
            let data: Vec<f32> = self.data.iter()
                .map(|&x| 1.0 / (1.0 + exp(-x)))
                .collect();
            Tensor::from_data(data, &self.shape)
        }
        
        pub fn tanh_act(&self) -> Tensor {
            let data: Vec<f32> = self.data.iter()
                .map(|&x| tanh(x as f64) as f32)
                .collect();
            Tensor::from_data(data, &self.shape)
        }
        
        pub fn softmax(&self) -> Tensor {
            let max_val = self.data.iter().cloned().fold(f32::NEG_INFINITY, f32::max);
            let exp_data: Vec<f32> = self.data.iter()
                .map(|&x| exp((x - max_val) as f64) as f32)
                .collect();
            let sum: f32 = exp_data.iter().sum();
            let data: Vec<f32> = exp_data.iter().map(|&x| x / sum).collect();
            Tensor::from_data(data, &self.shape)
        }
        
        // Reduction operations
        pub fn sum(&self) -> f32 {
            self.data.iter().sum()
        }
        
        pub fn mean(&self) -> f32 {
            self.sum() / self.data.len() as f32
        }
        
        pub fn max_value(&self) -> f32 {
            self.data.iter().cloned().fold(f32::NEG_INFINITY, f32::max)
        }
        
        pub fn argmax(&self) -> usize {
            self.data.iter()
                .enumerate()
                .max_by(|(_, a), (_, b)| a.partial_cmp(b).unwrap())
                .map(|(i, _)| i)
                .unwrap_or(0)
        }
    }
    
    /// Dense (fully connected) layer
    pub struct Dense {
        weights: Tensor,
        bias: Tensor,
    }
    
    impl Dense {
        pub fn new(input_size: usize, output_size: usize) -> Self {
            // Xavier initialization
            let scale = sqrt(2.0 / (input_size + output_size) as f64) as f32;
            let mut rng = std::random::Random::new();
            
            let weights_data: Vec<f32> = (0..input_size * output_size)
                .map(|_| rng.gaussian(0.0, scale as f64) as f32)
                .collect();
            
            Dense {
                weights: Tensor::from_data(weights_data, &[input_size, output_size]),
                bias: Tensor::new(&[output_size]),
            }
        }
        
        pub fn forward(&self, input: &Tensor) -> Tensor {
            input.matmul(&self.weights).add(&self.bias)
        }
    }
    
    /// Simple feedforward neural network
    pub struct NeuralNetwork {
        layers: Vec<Dense>,
        activation: Activation,
    }
    
    #[derive(Clone, Copy)]
    pub enum Activation {
        ReLU,
        Sigmoid,
        Tanh,
        Softmax,
    }
    
    impl NeuralNetwork {
        pub fn new(layer_sizes: &[usize], activation: Activation) -> Self {
            let layers: Vec<Dense> = layer_sizes.windows(2)
                .map(|w| Dense::new(w[0], w[1]))
                .collect();
            
            NeuralNetwork { layers, activation }
        }
        
        pub fn forward(&self, input: &Tensor) -> Tensor {
            let mut x = input.clone();
            
            for (i, layer) in self.layers.iter().enumerate() {
                x = layer.forward(&x);
                
                // Apply activation (except last layer for softmax)
                if i < self.layers.len() - 1 {
                    x = match self.activation {
                        Activation::ReLU => x.relu(),
                        Activation::Sigmoid => x.sigmoid(),
                        Activation::Tanh => x.tanh_act(),
                        Activation::Softmax => x.relu(),
                    };
                }
            }
            
            // Final activation
            match self.activation {
                Activation::Softmax => x.softmax(),
                _ => x,
            }
        }
        
        pub fn predict(&self, input: &Tensor) -> usize {
            let output = self.forward(input);
            output.argmax()
        }
    }
    
    /// Loss functions
    pub fn mse_loss(predicted: &Tensor, target: &Tensor) -> f32 {
        let diff = predicted.sub(target);
        let squared = diff.mul(&diff);
        squared.mean()
    }
    
    pub fn cross_entropy_loss(predicted: &Tensor, target: &Tensor) -> f32 {
        let epsilon = 1e-7;
        let mut loss = 0.0;
        for i in 0..predicted.size() {
            let p = predicted.data[i].max(epsilon).min(1.0 - epsilon);
            let t = target.data[i];
            loss -= t * log(p as f64) as f32 + (1.0 - t) * log((1.0 - p) as f64) as f32;
        }
        loss / predicted.size() as f32
    }
    
    /// Embedding layer
    pub struct Embedding {
        weights: Tensor,
        vocab_size: usize,
        embed_dim: usize,
    }
    
    impl Embedding {
        pub fn new(vocab_size: usize, embed_dim: usize) -> Self {
            let mut rng = std::random::Random::new();
            let weights_data: Vec<f32> = (0..vocab_size * embed_dim)
                .map(|_| rng.gaussian(0.0, 0.1) as f32)
                .collect();
            
            Embedding {
                weights: Tensor::from_data(weights_data, &[vocab_size, embed_dim]),
                vocab_size,
                embed_dim,
            }
        }
        
        pub fn forward(&self, indices: &[usize]) -> Tensor {
            let mut result = Tensor::new(&[indices.len(), self.embed_dim]);
            
            for (i, &idx) in indices.iter().enumerate() {
                for j in 0..self.embed_dim {
                    result.set(&[i, j], self.weights.get(&[idx, j]));
                }
            }
            
            result
        }
    }
}

