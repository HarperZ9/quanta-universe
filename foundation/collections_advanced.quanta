module std::collections::advanced

use std::collections::{Vec, HashMap, HashSet}
use std::sync::{Mutex, RwLock, AtomicUsize, Ordering}
use std::hash::{Hash, Hasher}
use std::random::Random

// ═══════════════════════════════════════════════════════════════════════════════
// SKIP LIST
// ═══════════════════════════════════════════════════════════════════════════════

/// Probabilistic sorted data structure with O(log n) average operations
pub struct SkipList<K: Ord, V> {
    head: Box<SkipNode<K, V>>,
    max_level: usize,
    len: usize,
    rng: Random,
}

struct SkipNode<K, V> {
    key: Option<K>,
    value: Option<V>,
    forward: Vec<Option<Box<SkipNode<K, V>>>>,
}

const MAX_LEVEL: usize = 16;
const P: f64 = 0.5;

impl<K: Ord, V> SkipList<K, V> {
    /// Create a new empty skip list
    pub fn new() -> Self {
        let head = Box::new(SkipNode {
            key: None,
            value: None,
            forward: vec![None; MAX_LEVEL],
        });

        SkipList {
            head,
            max_level: 1,
            len: 0,
            rng: Random::new(),
        }
    }

    /// Number of elements
    pub fn len(&self) -> usize {
        self.len
    }

    /// Is empty?
    pub fn is_empty(&self) -> bool {
        self.len == 0
    }

    /// Insert key-value pair
    pub fn insert(&mut self, key: K, value: V) -> Option<V> {
        let mut update: Vec<*mut SkipNode<K, V>> = vec![std::ptr::null_mut(); MAX_LEVEL];
        let mut current = &mut *self.head as *mut SkipNode<K, V>;

        // Find insertion point
        for level in (0..self.max_level).rev() {
            unsafe {
                while let Some(ref next) = (*current).forward[level] {
                    if let Some(ref next_key) = next.key {
                        if next_key < &key {
                            current = &mut **(*current).forward[level].as_mut().unwrap() as *mut _;
                            continue;
                        }
                    }
                    break;
                }
                update[level] = current;
            }
        }

        // Check if key exists
        unsafe {
            if let Some(ref mut next) = (*current).forward[0] {
                if let Some(ref next_key) = next.key {
                    if next_key == &key {
                        // Update existing value
                        let old_value = next.value.take();
                        next.value = Some(value);
                        return old_value;
                    }
                }
            }
        }

        // Generate random level
        let new_level = self.random_level();

        if new_level > self.max_level {
            for level in self.max_level..new_level {
                update[level] = &mut *self.head as *mut _;
            }
            self.max_level = new_level;
        }

        // Create new node
        let mut new_node = Box::new(SkipNode {
            key: Some(key),
            value: Some(value),
            forward: vec![None; new_level],
        });

        // Insert into lists
        for level in 0..new_level {
            unsafe {
                new_node.forward[level] = (*update[level]).forward[level].take();
                (*update[level]).forward[level] = Some(new_node);
                new_node = (*update[level]).forward[level].take().unwrap();
            }
        }

        self.len += 1;
        None
    }

    /// Get value by key
    pub fn get(&self, key: &K) -> Option<&V> {
        let mut current = &*self.head;

        for level in (0..self.max_level).rev() {
            while let Some(ref next) = current.forward[level] {
                if let Some(ref next_key) = next.key {
                    match next_key.cmp(key) {
                        Ordering::Less => {
                            current = next;
                            continue;
                        }
                        Ordering::Equal => {
                            return next.value.as_ref();
                        }
                        Ordering::Greater => break,
                    }
                }
                break;
            }
        }

        None
    }

    /// Remove key
    pub fn remove(&mut self, key: &K) -> Option<V> {
        let mut update: Vec<*mut SkipNode<K, V>> = vec![std::ptr::null_mut(); MAX_LEVEL];
        let mut current = &mut *self.head as *mut SkipNode<K, V>;

        for level in (0..self.max_level).rev() {
            unsafe {
                while let Some(ref next) = (*current).forward[level] {
                    if let Some(ref next_key) = next.key {
                        if next_key < key {
                            current = &mut **(*current).forward[level].as_mut().unwrap() as *mut _;
                            continue;
                        }
                    }
                    break;
                }
                update[level] = current;
            }
        }

        unsafe {
            if let Some(ref mut target) = (*current).forward[0] {
                if let Some(ref target_key) = target.key {
                    if target_key == key {
                        let value = target.value.take();

                        for level in 0..self.max_level {
                            if let Some(ref next) = (*update[level]).forward[level] {
                                if let Some(ref next_key) = next.key {
                                    if next_key == key {
                                        (*update[level]).forward[level] =
                                            (*update[level]).forward[level].as_mut().unwrap().forward[level].take();
                                    }
                                }
                            }
                        }

                        self.len -= 1;

                        // Reduce level if needed
                        while self.max_level > 1 && self.head.forward[self.max_level - 1].is_none() {
                            self.max_level -= 1;
                        }

                        return value;
                    }
                }
            }
        }

        None
    }

    /// Check if key exists
    pub fn contains_key(&self, key: &K) -> bool {
        self.get(key).is_some()
    }

    fn random_level(&mut self) -> usize {
        let mut level = 1;
        while self.rng.next_f64() < P && level < MAX_LEVEL {
            level += 1;
        }
        level
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BLOOM FILTER
// ═══════════════════════════════════════════════════════════════════════════════

/// Space-efficient probabilistic data structure for set membership
pub struct BloomFilter {
    bits: Vec<bool>,
    num_bits: usize,
    num_hashes: usize,
    count: usize,
}

impl BloomFilter {
    /// Create with expected size and false positive rate
    pub fn with_rate(expected_items: usize, false_positive_rate: f64) -> Self {
        // Calculate optimal size
        let ln2 = 0.693147180559945;
        let ln2_squared = ln2 * ln2;

        let num_bits = (-(expected_items as f64) * false_positive_rate.ln() / ln2_squared).ceil() as usize;
        let num_hashes = ((num_bits as f64 / expected_items as f64) * ln2).ceil() as usize;

        BloomFilter {
            bits: vec![false; num_bits],
            num_bits,
            num_hashes: num_hashes.max(1),
            count: 0,
        }
    }

    /// Create with specific size and hash count
    pub fn new(num_bits: usize, num_hashes: usize) -> Self {
        BloomFilter {
            bits: vec![false; num_bits],
            num_bits,
            num_hashes,
            count: 0,
        }
    }

    /// Add item to filter
    pub fn insert<T: Hash>(&mut self, item: &T) {
        for i in 0..self.num_hashes {
            let index = self.hash(item, i) % self.num_bits;
            self.bits[index] = true;
        }
        self.count += 1;
    }

    /// Check if item might be in filter
    /// Returns true if item is POSSIBLY in set (may be false positive)
    /// Returns false if item is DEFINITELY NOT in set
    pub fn contains<T: Hash>(&self, item: &T) -> bool {
        for i in 0..self.num_hashes {
            let index = self.hash(item, i) % self.num_bits;
            if !self.bits[index] {
                return false;
            }
        }
        true
    }

    /// Number of items added
    pub fn count(&self) -> usize {
        self.count
    }

    /// Estimate false positive rate
    pub fn estimated_fpr(&self) -> f64 {
        let ones: usize = self.bits.iter().filter(|&&b| b).count();
        let ratio = ones as f64 / self.num_bits as f64;
        ratio.powi(self.num_hashes as i32)
    }

    /// Clear the filter
    pub fn clear(&mut self) {
        for bit in &mut self.bits {
            *bit = false;
        }
        self.count = 0;
    }

    /// Merge with another bloom filter (union)
    pub fn union(&mut self, other: &BloomFilter) {
        assert_eq!(self.num_bits, other.num_bits);
        assert_eq!(self.num_hashes, other.num_hashes);

        for (a, b) in self.bits.iter_mut().zip(&other.bits) {
            *a = *a || *b;
        }
    }

    fn hash<T: Hash>(&self, item: &T, seed: usize) -> usize {
        use std::hash::FnvHasher;

        let mut hasher = FnvHasher::new();
        item.hash(&mut hasher);
        seed.hash(&mut hasher);
        hasher.finish() as usize
    }
}

/// Counting Bloom filter - supports deletion
pub struct CountingBloomFilter {
    counts: Vec<u8>,
    num_slots: usize,
    num_hashes: usize,
}

impl CountingBloomFilter {
    pub fn new(num_slots: usize, num_hashes: usize) -> Self {
        CountingBloomFilter {
            counts: vec![0; num_slots],
            num_slots,
            num_hashes,
        }
    }

    pub fn insert<T: Hash>(&mut self, item: &T) {
        for i in 0..self.num_hashes {
            let index = self.hash(item, i) % self.num_slots;
            self.counts[index] = self.counts[index].saturating_add(1);
        }
    }

    pub fn remove<T: Hash>(&mut self, item: &T) {
        for i in 0..self.num_hashes {
            let index = self.hash(item, i) % self.num_slots;
            self.counts[index] = self.counts[index].saturating_sub(1);
        }
    }

    pub fn contains<T: Hash>(&self, item: &T) -> bool {
        for i in 0..self.num_hashes {
            let index = self.hash(item, i) % self.num_slots;
            if self.counts[index] == 0 {
                return false;
            }
        }
        true
    }

    fn hash<T: Hash>(&self, item: &T, seed: usize) -> usize {
        use std::hash::FnvHasher;
        let mut hasher = FnvHasher::new();
        item.hash(&mut hasher);
        seed.hash(&mut hasher);
        hasher.finish() as usize
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LRU CACHE
// ═══════════════════════════════════════════════════════════════════════════════

/// Least Recently Used cache
pub struct LruCache<K: Eq + Hash + Clone, V> {
    map: HashMap<K, usize>,           // Key -> index in nodes
    nodes: Vec<LruNode<K, V>>,        // Node storage
    head: Option<usize>,              // Most recent
    tail: Option<usize>,              // Least recent
    free: Vec<usize>,                 // Free list
    capacity: usize,
}

struct LruNode<K, V> {
    key: K,
    value: V,
    prev: Option<usize>,
    next: Option<usize>,
}

impl<K: Eq + Hash + Clone, V> LruCache<K, V> {
    /// Create cache with capacity
    pub fn new(capacity: usize) -> Self {
        LruCache {
            map: HashMap::new(),
            nodes: Vec::with_capacity(capacity),
            head: None,
            tail: None,
            free: Vec::new(),
            capacity,
        }
    }

    /// Number of items
    pub fn len(&self) -> usize {
        self.map.len()
    }

    /// Is empty?
    pub fn is_empty(&self) -> bool {
        self.map.is_empty()
    }

    /// Capacity
    pub fn capacity(&self) -> usize {
        self.capacity
    }

    /// Get value (marks as recently used)
    pub fn get(&mut self, key: &K) -> Option<&V> {
        if let Some(&index) = self.map.get(key) {
            self.move_to_front(index);
            Some(&self.nodes[index].value)
        } else {
            None
        }
    }

    /// Get value without updating recency
    pub fn peek(&self, key: &K) -> Option<&V> {
        self.map.get(key).map(|&idx| &self.nodes[idx].value)
    }

    /// Insert or update key-value pair
    pub fn put(&mut self, key: K, value: V) -> Option<V> {
        if let Some(&index) = self.map.get(&key) {
            // Update existing
            let old_value = std::mem::replace(&mut self.nodes[index].value, value);
            self.move_to_front(index);
            return Some(old_value);
        }

        // Insert new
        if self.map.len() >= self.capacity {
            // Evict LRU
            self.evict_lru();
        }

        let index = self.allocate_node(key.clone(), value);
        self.map.insert(key, index);
        self.push_front(index);

        None
    }

    /// Remove key
    pub fn remove(&mut self, key: &K) -> Option<V> {
        if let Some(index) = self.map.remove(key) {
            self.unlink(index);
            let node = &mut self.nodes[index];
            self.free.push(index);
            // Return value (simplified - would need proper extraction)
            None
        } else {
            None
        }
    }

    /// Check if contains key
    pub fn contains(&self, key: &K) -> bool {
        self.map.contains_key(key)
    }

    /// Clear cache
    pub fn clear(&mut self) {
        self.map.clear();
        self.nodes.clear();
        self.head = None;
        self.tail = None;
        self.free.clear();
    }

    /// Iterate in LRU order (most recent first)
    pub fn iter(&self) -> LruIter<K, V> {
        LruIter {
            cache: self,
            current: self.head,
        }
    }

    fn allocate_node(&mut self, key: K, value: V) -> usize {
        if let Some(index) = self.free.pop() {
            self.nodes[index] = LruNode {
                key,
                value,
                prev: None,
                next: None,
            };
            index
        } else {
            let index = self.nodes.len();
            self.nodes.push(LruNode {
                key,
                value,
                prev: None,
                next: None,
            });
            index
        }
    }

    fn push_front(&mut self, index: usize) {
        self.nodes[index].next = self.head;
        self.nodes[index].prev = None;

        if let Some(head) = self.head {
            self.nodes[head].prev = Some(index);
        }

        self.head = Some(index);

        if self.tail.is_none() {
            self.tail = Some(index);
        }
    }

    fn unlink(&mut self, index: usize) {
        let prev = self.nodes[index].prev;
        let next = self.nodes[index].next;

        if let Some(prev_idx) = prev {
            self.nodes[prev_idx].next = next;
        } else {
            self.head = next;
        }

        if let Some(next_idx) = next {
            self.nodes[next_idx].prev = prev;
        } else {
            self.tail = prev;
        }
    }

    fn move_to_front(&mut self, index: usize) {
        if self.head == Some(index) {
            return;
        }

        self.unlink(index);
        self.push_front(index);
    }

    fn evict_lru(&mut self) {
        if let Some(tail_idx) = self.tail {
            let key = self.nodes[tail_idx].key.clone();
            self.map.remove(&key);
            self.unlink(tail_idx);
            self.free.push(tail_idx);
        }
    }
}

pub struct LruIter<'a, K, V> {
    cache: &'a LruCache<K, V>,
    current: Option<usize>,
}

impl<'a, K: Eq + Hash + Clone, V> Iterator for LruIter<'a, K, V> {
    type Item = (&'a K, &'a V);

    fn next(&mut self) -> Option<Self::Item> {
        self.current.map(|idx| {
            let node = &self.cache.nodes[idx];
            self.current = node.next;
            (&node.key, &node.value)
        })
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONCURRENT COLLECTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Thread-safe hash map
pub struct ConcurrentHashMap<K, V> {
    shards: Vec<RwLock<HashMap<K, V>>>,
    num_shards: usize,
}

impl<K: Hash + Eq + Clone, V: Clone> ConcurrentHashMap<K, V> {
    /// Create with default shard count
    pub fn new() -> Self {
        Self::with_shard_count(16)
    }

    /// Create with specific shard count
    pub fn with_shard_count(num_shards: usize) -> Self {
        let shards = (0..num_shards)
            .map(|_| RwLock::new(HashMap::new()))
            .collect();

        ConcurrentHashMap { shards, num_shards }
    }

    /// Insert key-value pair
    pub fn insert(&self, key: K, value: V) -> Option<V> {
        let shard_idx = self.shard_index(&key);
        let mut shard = self.shards[shard_idx].write();
        shard.insert(key, value)
    }

    /// Get value
    pub fn get(&self, key: &K) -> Option<V> {
        let shard_idx = self.shard_index(key);
        let shard = self.shards[shard_idx].read();
        shard.get(key).cloned()
    }

    /// Remove key
    pub fn remove(&self, key: &K) -> Option<V> {
        let shard_idx = self.shard_index(key);
        let mut shard = self.shards[shard_idx].write();
        shard.remove(key)
    }

    /// Check if contains key
    pub fn contains_key(&self, key: &K) -> bool {
        let shard_idx = self.shard_index(key);
        let shard = self.shards[shard_idx].read();
        shard.contains_key(key)
    }

    /// Approximate length (may be inconsistent under concurrent access)
    pub fn len(&self) -> usize {
        self.shards.iter().map(|s| s.read().len()).sum()
    }

    fn shard_index(&self, key: &K) -> usize {
        use std::hash::FnvHasher;
        let mut hasher = FnvHasher::new();
        key.hash(&mut hasher);
        hasher.finish() as usize % self.num_shards
    }
}

/// Lock-free concurrent queue (MPMC)
pub struct ConcurrentQueue<T> {
    inner: Mutex<VecDeque<T>>,
}

impl<T> ConcurrentQueue<T> {
    pub fn new() -> Self {
        ConcurrentQueue {
            inner: Mutex::new(VecDeque::new()),
        }
    }

    pub fn push(&self, value: T) {
        let mut queue = self.inner.lock();
        queue.push_back(value);
    }

    pub fn pop(&self) -> Option<T> {
        let mut queue = self.inner.lock();
        queue.pop_front()
    }

    pub fn is_empty(&self) -> bool {
        let queue = self.inner.lock();
        queue.is_empty()
    }

    pub fn len(&self) -> usize {
        let queue = self.inner.lock();
        queue.len()
    }
}

/// Concurrent set
pub struct ConcurrentHashSet<T> {
    map: ConcurrentHashMap<T, ()>,
}

impl<T: Hash + Eq + Clone> ConcurrentHashSet<T> {
    pub fn new() -> Self {
        ConcurrentHashSet {
            map: ConcurrentHashMap::new(),
        }
    }

    pub fn insert(&self, value: T) -> bool {
        self.map.insert(value, ()).is_none()
    }

    pub fn remove(&self, value: &T) -> bool {
        self.map.remove(value).is_some()
    }

    pub fn contains(&self, value: &T) -> bool {
        self.map.contains_key(value)
    }

    pub fn len(&self) -> usize {
        self.map.len()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTERVAL TREE
// ═══════════════════════════════════════════════════════════════════════════════

/// Interval with associated value
#[derive(Clone)]
pub struct Interval<T: Ord + Clone> {
    pub start: T,
    pub end: T,
}

impl<T: Ord + Clone> Interval<T> {
    pub fn new(start: T, end: T) -> Self {
        Interval { start, end }
    }

    pub fn contains(&self, point: &T) -> bool {
        &self.start <= point && point < &self.end
    }

    pub fn overlaps(&self, other: &Interval<T>) -> bool {
        self.start < other.end && other.start < self.end
    }
}

/// Interval tree for range queries
pub struct IntervalTree<T: Ord + Clone, V> {
    intervals: Vec<(Interval<T>, V)>,
}

impl<T: Ord + Clone, V> IntervalTree<T, V> {
    pub fn new() -> Self {
        IntervalTree { intervals: Vec::new() }
    }

    pub fn insert(&mut self, interval: Interval<T>, value: V) {
        self.intervals.push((interval, value));
    }

    pub fn query_point(&self, point: &T) -> Vec<&V> {
        self.intervals.iter()
            .filter(|(int, _)| int.contains(point))
            .map(|(_, v)| v)
            .collect()
    }

    pub fn query_overlap(&self, interval: &Interval<T>) -> Vec<&V> {
        self.intervals.iter()
            .filter(|(int, _)| int.overlaps(interval))
            .map(|(_, v)| v)
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRIE (PREFIX TREE)
// ═══════════════════════════════════════════════════════════════════════════════

/// Trie for string prefix operations
pub struct Trie<V> {
    root: TrieNode<V>,
}

struct TrieNode<V> {
    children: HashMap<char, TrieNode<V>>,
    value: Option<V>,
    is_end: bool,
}

impl<V> Trie<V> {
    pub fn new() -> Self {
        Trie {
            root: TrieNode {
                children: HashMap::new(),
                value: None,
                is_end: false,
            },
        }
    }

    /// Insert key-value pair
    pub fn insert(&mut self, key: &str, value: V) {
        let mut node = &mut self.root;

        for ch in key.chars() {
            node = node.children
                .entry(ch)
                .or_insert_with(|| TrieNode {
                    children: HashMap::new(),
                    value: None,
                    is_end: false,
                });
        }

        node.value = Some(value);
        node.is_end = true;
    }

    /// Get value by key
    pub fn get(&self, key: &str) -> Option<&V> {
        let mut node = &self.root;

        for ch in key.chars() {
            match node.children.get(&ch) {
                Some(child) => node = child,
                None => return None,
            }
        }

        if node.is_end {
            node.value.as_ref()
        } else {
            None
        }
    }

    /// Check if key exists
    pub fn contains(&self, key: &str) -> bool {
        self.get(key).is_some()
    }

    /// Check if any key starts with prefix
    pub fn starts_with(&self, prefix: &str) -> bool {
        let mut node = &self.root;

        for ch in prefix.chars() {
            match node.children.get(&ch) {
                Some(child) => node = child,
                None => return false,
            }
        }

        true
    }

    /// Get all keys with prefix
    pub fn keys_with_prefix(&self, prefix: &str) -> Vec<String> {
        let mut node = &self.root;

        for ch in prefix.chars() {
            match node.children.get(&ch) {
                Some(child) => node = child,
                None => return Vec::new(),
            }
        }

        let mut results = Vec::new();
        self.collect_keys(node, prefix.to_string(), &mut results);
        results
    }

    fn collect_keys(&self, node: &TrieNode<V>, prefix: String, results: &mut Vec<String>) {
        if node.is_end {
            results.push(prefix.clone());
        }

        for (&ch, child) in &node.children {
            let mut new_prefix = prefix.clone();
            new_prefix.push(ch);
            self.collect_keys(child, new_prefix, results);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DISJOINT SET (UNION-FIND)
// ═══════════════════════════════════════════════════════════════════════════════

/// Union-Find data structure with path compression
pub struct DisjointSet {
    parent: Vec<usize>,
    rank: Vec<usize>,
}

impl DisjointSet {
    /// Create with n elements (0..n)
    pub fn new(n: usize) -> Self {
        DisjointSet {
            parent: (0..n).collect(),
            rank: vec![0; n],
        }
    }

    /// Find root of element (with path compression)
    pub fn find(&mut self, x: usize) -> usize {
        if self.parent[x] != x {
            self.parent[x] = self.find(self.parent[x]);
        }
        self.parent[x]
    }

    /// Union two sets (by rank)
    pub fn union(&mut self, x: usize, y: usize) -> bool {
        let root_x = self.find(x);
        let root_y = self.find(y);

        if root_x == root_y {
            return false;
        }

        match self.rank[root_x].cmp(&self.rank[root_y]) {
            Ordering::Less => {
                self.parent[root_x] = root_y;
            }
            Ordering::Greater => {
                self.parent[root_y] = root_x;
            }
            Ordering::Equal => {
                self.parent[root_y] = root_x;
                self.rank[root_x] += 1;
            }
        }

        true
    }

    /// Check if two elements are in same set
    pub fn connected(&mut self, x: usize, y: usize) -> bool {
        self.find(x) == self.find(y)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_bloom_filter() {
        let mut bloom = BloomFilter::with_rate(1000, 0.01);

        bloom.insert(&"hello");
        bloom.insert(&"world");

        assert!(bloom.contains(&"hello"));
        assert!(bloom.contains(&"world"));
        assert!(!bloom.contains(&"foo"));
    }

    #[test]
    fn test_lru_cache() {
        let mut cache: LruCache<String, i32> = LruCache::new(3);

        cache.put("one".to_string(), 1);
        cache.put("two".to_string(), 2);
        cache.put("three".to_string(), 3);

        assert_eq!(cache.get(&"one".to_string()), Some(&1));

        // This should evict "two"
        cache.put("four".to_string(), 4);

        assert!(cache.contains(&"one".to_string()));
        assert!(!cache.contains(&"two".to_string()));
    }

    #[test]
    fn test_trie() {
        let mut trie: Trie<i32> = Trie::new();

        trie.insert("hello", 1);
        trie.insert("help", 2);
        trie.insert("world", 3);

        assert_eq!(trie.get("hello"), Some(&1));
        assert!(trie.starts_with("hel"));

        let keys = trie.keys_with_prefix("hel");
        assert_eq!(keys.len(), 2);
    }

    #[test]
    fn test_disjoint_set() {
        let mut ds = DisjointSet::new(5);

        ds.union(0, 1);
        ds.union(2, 3);

        assert!(ds.connected(0, 1));
        assert!(ds.connected(2, 3));
        assert!(!ds.connected(0, 2));

        ds.union(1, 2);
        assert!(ds.connected(0, 3));
    }
}
