/// Display profile containing calibration data
#[derive(Clone)]
pub struct DisplayProfile {
    pub name: String,
    pub white_point: XYZ,
    pub black_point: XYZ,
    pub primaries: DisplayPrimaries,
    pub gamma: GammaCurve,
    pub color_matrix: [[f64; 3]; 3],
    pub lut_3d: Option<LUT3D>,
    pub precision_tier: PrecisionTier,
}

/// Display primaries in xy chromaticity
#[derive(Clone, Copy)]
pub struct DisplayPrimaries {
    pub red: (f64, f64),
    pub green: (f64, f64),
    pub blue: (f64, f64),
    pub white: (f64, f64),
}

impl DisplayPrimaries {
    pub fn srgb() -> Self {
        DisplayPrimaries {
            red: (0.64, 0.33),
            green: (0.30, 0.60),
            blue: (0.15, 0.06),
            white: (0.3127, 0.3290),
        }
    }
    
    pub fn dci_p3() -> Self {
        DisplayPrimaries {
            red: (0.680, 0.320),
            green: (0.265, 0.690),
            blue: (0.150, 0.060),
            white: (0.3127, 0.3290),
        }
    }
    
    pub fn rec2020() -> Self {
        DisplayPrimaries {
            red: (0.708, 0.292),
            green: (0.170, 0.797),
            blue: (0.131, 0.046),
            white: (0.3127, 0.3290),
        }
    }
}

/// Gamma curve representation
#[derive(Clone)]
pub enum GammaCurve {
    Power(f64),
    SRGB,
    PQ,
    HLG,
    Custom(Vec<f64>),
}

impl GammaCurve {
    pub fn apply(&self, linear: f64) -> f64 {
        match self {
            GammaCurve::Power(gamma) => pow(linear.max(0.0), 1.0 / gamma),
            GammaCurve::SRGB => {
                if linear <= 0.0031308 {
                    linear * 12.92
                } else {
                    1.055 * pow(linear, 1.0 / 2.4) - 0.055
                }
            }
            GammaCurve::PQ => {
                let m1 = 0.1593017578125;
                let m2 = 78.84375;
                let c1 = 0.8359375;
                let c2 = 18.8515625;
                let c3 = 18.6875;
                
                let y = pow(linear / 10000.0, m1);
                pow((c1 + c2 * y) / (1.0 + c3 * y), m2)
            }
            GammaCurve::HLG => {
                let a = 0.17883277;
                let b = 0.28466892;
                let c = 0.55991073;
                
                if linear <= 1.0 / 12.0 {
                    sqrt(3.0 * linear)
                } else {
                    a * log(12.0 * linear - b) + c
                }
            }
            GammaCurve::Custom(lut) => {
                let idx = (linear.clamp(0.0, 1.0) * (lut.len() - 1) as f64) as usize;
                lut[idx.min(lut.len() - 1)]
            }
        }
    }
    
    pub fn inverse(&self, encoded: f64) -> f64 {
        match self {
            GammaCurve::Power(gamma) => pow(encoded.max(0.0), *gamma),
            GammaCurve::SRGB => {
                if encoded <= 0.04045 {
                    encoded / 12.92
                } else {
                    pow((encoded + 0.055) / 1.055, 2.4)
                }
            }
            _ => encoded // Simplified
        }
    }
}

/// 3D LUT for color correction
#[derive(Clone)]
pub struct LUT3D {
    pub size: usize,
    pub data: Vec<RGB>,
}

impl LUT3D {
    pub fn new(size: usize) -> Self {
        LUT3D {
            size,
            data: vec![RGB::black(); size * size * size],
        }
    }
    
    pub fn identity(size: usize) -> Self {
        let mut lut = LUT3D::new(size);
        
        for b in 0..size {
            for g in 0..size {
                for r in 0..size {
                    let idx = b * size * size + g * size + r;
                    lut.data[idx] = RGB::new(
                        r as f32 / (size - 1) as f32,
                        g as f32 / (size - 1) as f32,
                        b as f32 / (size - 1) as f32,
                    );
                }
            }
        }
        
        lut
    }
    
    /// Trilinear interpolation lookup
    pub fn lookup(&self, color: RGB) -> RGB {
        let size = self.size as f32;
        
        let r = (color.r.clamp(0.0, 1.0) * (size - 1.0)).min(size - 1.001);
        let g = (color.g.clamp(0.0, 1.0) * (size - 1.0)).min(size - 1.001);
        let b = (color.b.clamp(0.0, 1.0) * (size - 1.0)).min(size - 1.001);
        
        let r0 = r.floor() as usize;
        let g0 = g.floor() as usize;
        let b0 = b.floor() as usize;
        let r1 = r0 + 1;
        let g1 = g0 + 1;
        let b1 = b0 + 1;
        
        let fr = r.fract();
        let fg = g.fract();
        let fb = b.fract();
        
        let s = self.size;
        
        let c000 = &self.data[b0 * s * s + g0 * s + r0];
        let c001 = &self.data[b0 * s * s + g0 * s + r1];
        let c010 = &self.data[b0 * s * s + g1 * s + r0];
        let c011 = &self.data[b0 * s * s + g1 * s + r1];
        let c100 = &self.data[b1 * s * s + g0 * s + r0];
        let c101 = &self.data[b1 * s * s + g0 * s + r1];
        let c110 = &self.data[b1 * s * s + g1 * s + r0];
        let c111 = &self.data[b1 * s * s + g1 * s + r1];
        
        // Trilinear interpolation
        let lerp = |a: f32, b: f32, t: f32| a + (b - a) * t;
        
        RGB::new(
            lerp(
                lerp(lerp(c000.r, c001.r, fr), lerp(c010.r, c011.r, fr), fg),
                lerp(lerp(c100.r, c101.r, fr), lerp(c110.r, c111.r, fr), fg),
                fb
            ),
            lerp(
                lerp(lerp(c000.g, c001.g, fr), lerp(c010.g, c011.g, fr), fg),
                lerp(lerp(c100.g, c101.g, fr), lerp(c110.g, c111.g, fr), fg),
                fb
            ),
            lerp(
                lerp(lerp(c000.b, c001.b, fr), lerp(c010.b, c011.b, fr), fg),
                lerp(lerp(c100.b, c101.b, fr), lerp(c110.b, c111.b, fr), fg),
                fb
            ),
        )
    }
}

