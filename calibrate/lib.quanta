// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_gamma_curves() {
        let srgb = GammaCurve::SRGB;
        let encoded = srgb.apply(0.5);
        let decoded = srgb.inverse(encoded);
        assert!((decoded - 0.5).abs() < 0.001);
    }

    #[test]
    fn test_lut_identity() {
        let lut = LUT3D::identity(17);
        let color = RGB::new(0.5, 0.3, 0.7);
        let result = lut.lookup(color);
        assert!((result.r - 0.5).abs() < 0.1);
    }

    #[test]
    fn test_lumina_titan() {
        let mut titan = LuminaTitan::new();
        titan.calibrate("Generic IPS");
        assert!(titan.active_profile.is_some());
        assert!(titan.active_lut.is_some());
    }

    #[test]
    fn test_icc_generation() {
        let titan = LuminaTitan::new();
        let profile = titan.calibrator.estimate_profile("Generic IPS");
        let icc = ICCProfileGenerator::generate(&profile);
        assert!(icc.len() > 128);
    }

    #[test]
    fn test_vcgt_identity() {
        let vcgt = VCGT::identity(256);
        assert_eq!(vcgt.red[0], 0);
        assert_eq!(vcgt.red[255], 65535);
    }

    #[test]
    fn test_cube_export() {
        let lut = LUT3D::identity(9);
        let cube = lut.export_cube("Test LUT");
        assert!(cube.contains("TITLE \"Test LUT\""));
        assert!(cube.contains("LUT_3D_SIZE 9"));
    }

    #[test]
    fn test_edid_parse() {
        let calibrator = MultiMonitorCalibrator::new();
        // Would test with real EDID data
    }

    #[test]
    fn test_calibration_schedule() {
        let mut scheduler = CalibrationScheduler::new();
        scheduler.add_schedule(CalibrationSchedule {
            monitor_id: "test".to_string(),
            interval: ScheduleInterval::Weekly,
            enabled: true,
            target: CalibrationTarget::default(),
            notify_before: 60,
            auto_apply: false,
        });

        // Check immediately after adding - should be due
        let due = scheduler.check_due(0);
        assert!(due.contains(&"test".to_string()));
    }

    #[test]
    fn test_calibration_workflow() {
        let workflow = CalibrationWorkflow::new();
        assert_eq!(workflow.state, WorkflowState::NotStarted);
        assert!(!workflow.patches.is_empty());
    }
}
