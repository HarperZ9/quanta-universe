        let result = main();
        assert!(result.is_ok());
    }

    #[test]
    fn test_all_layers() {
        assert!(demo_foundation().is_ok());
        assert!(demo_rendering().is_ok());
        assert!(demo_trading().is_ok());
        assert!(demo_intelligence().is_ok());
        assert!(demo_integration().is_ok());
    }
