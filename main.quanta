// MAIN APPLICATION
// ═══════════════════════════════════════════════════════════════════════════════

fn main() -> Result<(), Error> {
    // Print banner
    print_banner();

    // Initialize the universe
    println!("Initializing QUANTA-UNIVERSE...");
    init()?;

    let uni = universe();
    println!("{}", uni.summary());
    println!();

    // Demonstrate each layer
    demo_foundation()?;
    demo_rendering()?;
    demo_trading()?;
    demo_intelligence()?;
    demo_integration()?;

    println!();
    println!("═══════════════════════════════════════════════════════════════════");
    println!("  QUANTA-UNIVERSE™ initialization complete!");
    println!("  All {} modules loaded and ready.", universe::TOTAL_MODULES);
    println!("═══════════════════════════════════════════════════════════════════");

    Ok(())
}

