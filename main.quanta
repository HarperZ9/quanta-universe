fn demo_foundation() -> Result<(), Error> {
    println!("┌─────────────────────────────────────────────────────────────────┐");
    println!("│  LAYER 0: FOUNDATION                                            │");
    println!("└─────────────────────────────────────────────────────────────────┘");

    // Demonstrate standard library
    let mut data: Vec<f64> = Vec::new();
    for i in 0..10 {
        data.push(sin(i as f64 * PI / 10.0));
    }
    println!("  • Vector operations: {} elements", data.len());

    let mut map: HashMap<String, i32> = HashMap::new();
    map.insert("quantalang".to_string(), 1);
    map.insert("foundation".to_string(), 2);
    println!("  • HashMap operations: {} entries", map.len());

    println!("  ✓ Foundation layer verified");
    println!();
    Ok(())
}

