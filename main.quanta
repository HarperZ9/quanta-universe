/// Run the full test suite
pub fn run_tests() -> Result<(), Error> {
    use tests::{TestRunner, main as test_main};
    test_main()
}

/// Build the entire universe
pub fn build() -> Result<(), Error> {
    use build::{BuildEngine, BuildConfig, main as build_main};
    build_main()
}

/// Display module information
pub fn info(module: &str) -> Result<(), Error> {
    let uni = universe();

    if let Some(m) = uni.get_module(module) {
        println!("Module: {}", m.name);
        println!("Version: {}", m.version);
        println!("Layer: {:?}", m.layer);
        println!("Status: {:?}", m.status);
        println!("Dependencies: {:?}", m.dependencies);
        println!("Patents: {:?}", m.patents);
        println!("Trademarks: {:?}", m.trademarks);
        println!("Value: ${} - ${}", m.value_min, m.value_max);
        Ok(())
    } else {
        Err(Error::new(format!("Module '{}' not found", module)))
    }
}

/// List all modules
pub fn list_modules() {
    let uni = universe();
    let modules = uni.list_modules();

    println!("QUANTA-UNIVERSE Modules ({}):", modules.len());
    println!("────────────────────────────────────────────────────────");

    for layer in [Layer::Foundation, Layer::Core, Layer::Rendering,
                  Layer::Trading, Layer::Intelligence, Layer::Integration, Layer::Tools] {
        println!("\n{} Layer:", layer.name());
        for m in uni.get_layer(layer) {
            let status = match m.status {
                ModuleStatus::Ready => "✓",
                ModuleStatus::Active => "●",
                ModuleStatus::Error => "✗",
                _ => "○",
            };
            println!("  {} {} v{}", status, m.name, m.version);
        }
    }
}

