// ═══════════════════════════════════════════════════════════════════════════════
// ABSTRACT SYNTAX TREE (Differentiable)
// ═══════════════════════════════════════════════════════════════════════════════

/// AST node types for program representation
#[derive(Debug, Clone)]
pub enum ASTNode {
    // Literals
    Literal(f64),
    Variable(String),
    
    // Arithmetic
    Add(Box<ASTNode>, Box<ASTNode>),
    Sub(Box<ASTNode>, Box<ASTNode>),
    Mul(Box<ASTNode>, Box<ASTNode>),
    Div(Box<ASTNode>, Box<ASTNode>),
    Pow(Box<ASTNode>, Box<ASTNode>),
    Neg(Box<ASTNode>),
    
    // Functions
    Sin(Box<ASTNode>),
    Cos(Box<ASTNode>),
    Exp(Box<ASTNode>),
    Log(Box<ASTNode>),
    Sqrt(Box<ASTNode>),
    Abs(Box<ASTNode>),
    Tanh(Box<ASTNode>),
    
    // Control flow (differentiable via soft operations)
    If(Box<ASTNode>, Box<ASTNode>, Box<ASTNode>),  // condition, then, else
    
    // Higher-order
    Lambda(Vec<String>, Box<ASTNode>),
    Apply(Box<ASTNode>, Vec<ASTNode>),
    Let(String, Box<ASTNode>, Box<ASTNode>),
    
    // Recursion (via fixed-point combinator)
    Fix(String, Box<ASTNode>),
    
    // Lists
    Cons(Box<ASTNode>, Box<ASTNode>),
    Car(Box<ASTNode>),
    Cdr(Box<ASTNode>),
    Nil,
    
    // Neural network primitives
    Linear(usize, usize),  // input_dim, output_dim
    Activation(ActivationType),
    Attention(usize),      // num_heads
}

#[derive(Debug, Clone, Copy)]
pub enum ActivationType {
    ReLU,
    Sigmoid,
    Tanh,
    GELU,
    Swish,
    Softmax,
}

impl ASTNode {
    /// Count nodes in tree (complexity measure)
    pub fn size(&self) -> usize {
        match self {
            ASTNode::Literal(_) | ASTNode::Variable(_) | ASTNode::Nil => 1,
            ASTNode::Linear(_, _) | ASTNode::Activation(_) | ASTNode::Attention(_) => 1,
            
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) |
            ASTNode::Car(a) | ASTNode::Cdr(a) => 1 + a.size(),
            
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) | ASTNode::Cons(a, b) => {
                1 + a.size() + b.size()
            }
            
            ASTNode::If(c, t, e) => 1 + c.size() + t.size() + e.size(),
            
            ASTNode::Lambda(params, body) => 1 + params.len() + body.size(),
            ASTNode::Apply(func, args) => {
                1 + func.size() + args.iter().map(|a| a.size()).sum::<usize>()
            }
            ASTNode::Let(_, val, body) => 1 + val.size() + body.size(),
            ASTNode::Fix(_, body) => 1 + body.size(),
        }
    }
    
    /// Depth of tree
    pub fn depth(&self) -> usize {
        match self {
            ASTNode::Literal(_) | ASTNode::Variable(_) | ASTNode::Nil |
            ASTNode::Linear(_, _) | ASTNode::Activation(_) | ASTNode::Attention(_) => 1,
            
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) |
            ASTNode::Car(a) | ASTNode::Cdr(a) => 1 + a.depth(),
            
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) | ASTNode::Cons(a, b) => {
                1 + max(a.depth(), b.depth())
            }
            
            ASTNode::If(c, t, e) => 1 + max(c.depth(), max(t.depth(), e.depth())),
            
            ASTNode::Lambda(_, body) => 1 + body.depth(),
            ASTNode::Apply(func, args) => {
                let arg_depth = args.iter().map(|a| a.depth()).max().unwrap_or(0);
                1 + max(func.depth(), arg_depth)
            }
            ASTNode::Let(_, val, body) => 1 + max(val.depth(), body.depth()),
            ASTNode::Fix(_, body) => 1 + body.depth(),
        }
    }
    
    /// Get all variables used
    pub fn free_variables(&self) -> HashSet<String> {
        let mut vars = HashSet::new();
        self.collect_free_vars(&mut vars, &HashSet::new());
        vars
    }
    
    fn collect_free_vars(&self, free: &mut HashSet<String>, bound: &HashSet<String>) {
        match self {
            ASTNode::Variable(name) => {
                if !bound.contains(name) {
                    free.insert(name.clone());
                }
            }
            ASTNode::Lambda(params, body) => {
                let mut new_bound = bound.clone();
                for p in params {
                    new_bound.insert(p.clone());
                }
                body.collect_free_vars(free, &new_bound);
            }
            ASTNode::Let(name, val, body) => {
                val.collect_free_vars(free, bound);
                let mut new_bound = bound.clone();
                new_bound.insert(name.clone());
                body.collect_free_vars(free, &new_bound);
            }
            ASTNode::Fix(name, body) => {
                let mut new_bound = bound.clone();
                new_bound.insert(name.clone());
                body.collect_free_vars(free, &new_bound);
            }
            // Recursively handle other cases...
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) => {
                a.collect_free_vars(free, bound);
                b.collect_free_vars(free, bound);
            }
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) => {
                a.collect_free_vars(free, bound);
            }
            ASTNode::If(c, t, e) => {
                c.collect_free_vars(free, bound);
                t.collect_free_vars(free, bound);
                e.collect_free_vars(free, bound);
            }
            ASTNode::Apply(func, args) => {
                func.collect_free_vars(free, bound);
                for arg in args {
                    arg.collect_free_vars(free, bound);
                }
            }
            _ => {}
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DUAL NUMBERS FOR AUTOMATIC DIFFERENTIATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Dual number for forward-mode automatic differentiation
#[derive(Debug, Clone, Copy)]
pub struct Dual {
    pub value: f64,
    pub derivative: f64,
}

impl Dual {
    pub fn new(value: f64, derivative: f64) -> Self {
        Dual { value, derivative }
    }
    
    pub fn constant(value: f64) -> Self {
        Dual { value, derivative: 0.0 }
    }
    
    pub fn variable(value: f64) -> Self {
        Dual { value, derivative: 1.0 }
    }
    
    pub fn add(&self, other: &Dual) -> Dual {
        Dual::new(
            self.value + other.value,
            self.derivative + other.derivative,
        )
    }
    
    pub fn sub(&self, other: &Dual) -> Dual {
        Dual::new(
            self.value - other.value,
            self.derivative - other.derivative,
        )
    }
    
    pub fn mul(&self, other: &Dual) -> Dual {
        Dual::new(
            self.value * other.value,
            self.value * other.derivative + self.derivative * other.value,
        )
    }
    
    pub fn div(&self, other: &Dual) -> Dual {
        let denom = other.value * other.value;
        Dual::new(
            self.value / other.value,
            (self.derivative * other.value - self.value * other.derivative) / denom,
        )
    }
    
    pub fn pow(&self, n: f64) -> Dual {
        Dual::new(
            pow(self.value, n),
            n * pow(self.value, n - 1.0) * self.derivative,
        )
    }
    
    pub fn sin(&self) -> Dual {
        Dual::new(
            sin(self.value),
            cos(self.value) * self.derivative,
        )
    }
    
    pub fn cos(&self) -> Dual {
        Dual::new(
            cos(self.value),
            -sin(self.value) * self.derivative,
        )
    }
    
    pub fn exp(&self) -> Dual {
        let e = exp(self.value);
        Dual::new(e, e * self.derivative)
    }
    
    pub fn log(&self) -> Dual {
        Dual::new(
            log(self.value),
            self.derivative / self.value,
        )
    }
    
    pub fn sqrt(&self) -> Dual {
        let s = sqrt(self.value);
        Dual::new(s, self.derivative / (2.0 * s))
    }
    
    pub fn tanh(&self) -> Dual {
        let t = tanh(self.value);
        Dual::new(t, (1.0 - t * t) * self.derivative)
    }
    
    pub fn abs(&self) -> Dual {
        if self.value >= 0.0 {
            *self
        } else {
            Dual::new(-self.value, -self.derivative)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOFT/DIFFERENTIABLE CONTROL FLOW
// ═══════════════════════════════════════════════════════════════════════════════

/// Soft if-then-else using sigmoid interpolation
pub fn soft_if(condition: f64, then_val: f64, else_val: f64, temperature: f64) -> f64 {
    let sigmoid = 1.0 / (1.0 + exp(-condition / temperature));
    sigmoid * then_val + (1.0 - sigmoid) * else_val
}

/// Soft if for dual numbers
pub fn soft_if_dual(condition: Dual, then_val: Dual, else_val: Dual, temperature: f64) -> Dual {
    let sigmoid = Dual::constant(1.0).div(&Dual::constant(1.0).add(
        &Dual::constant(-1.0).mul(&condition).div(&Dual::constant(temperature)).exp()
    ));
    sigmoid.mul(&then_val).add(&Dual::constant(1.0).sub(&sigmoid).mul(&else_val))
}

/// Gumbel-Softmax for differentiable discrete sampling
pub struct GumbelSoftmax {
    temperature: f64,
}

impl GumbelSoftmax {
    pub fn new(temperature: f64) -> Self {
        GumbelSoftmax { temperature }
    }
    
    /// Sample from categorical distribution (differentiable)
    pub fn sample(&self, logits: &[f64], rng: &mut Random) -> Vec<f64> {
        let gumbels: Vec<f64> = logits.iter()
            .map(|_| -log(-log(rng.next_f64())))
            .collect();
        
        let perturbed: Vec<f64> = logits.iter()
            .zip(gumbels.iter())
            .map(|(l, g)| (l + g) / self.temperature)
            .collect();
        
        // Softmax
        let max_val = perturbed.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let exps: Vec<f64> = perturbed.iter().map(|x| exp(x - max_val)).collect();
        let sum: f64 = exps.iter().sum();
        
        exps.iter().map(|e| e / sum).collect()
    }
    
    /// Anneal temperature
    pub fn anneal(&mut self, factor: f64) {
        self.temperature *= factor;
        self.temperature = self.temperature.max(0.01);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUANTA EVOLUTION EQUATION
// ═══════════════════════════════════════════════════════════════════════════════

/// The Quanta Evolution Equation:
/// ∂P/∂t = -∇L + η·Mutation + λ·Simplicity
/// 
/// Where:
/// - P: Program population in parameter space
/// - L: Loss function on training data
/// - η: Mutation rate (exploration)
/// - λ: Simplicity pressure (Occam's razor)
/// 
/// This equation governs the evolution of programs in a differentiable manner,
/// combining gradient descent with evolutionary operators.

pub struct QuantaEvolution {
    /// Learning rate for gradient updates
    pub learning_rate: f64,
    /// Mutation rate (η)
    pub mutation_rate: f64,
    /// Simplicity pressure (λ)
    pub simplicity_weight: f64,
    /// Population size
    pub population_size: usize,
    /// Temperature for selection
    pub temperature: f64,
    /// Random number generator
    rng: Random,
}

impl QuantaEvolution {
    pub fn new(seed: u64) -> Self {
        QuantaEvolution {
            learning_rate: 0.01,
            mutation_rate: 0.1,
            simplicity_weight: 0.001,
            population_size: 100,
            temperature: 1.0,
            rng: Random::new(seed),
        }
    }
    
    /// Compute the Quanta Evolution update
    /// Returns: ∂P/∂t = -∇L + η·Mutation + λ·Simplicity
    pub fn compute_update(
        &self,
        program: &Program,
        loss_gradient: f64,
    ) -> f64 {
        // Gradient term: -∇L
        let gradient_term = -loss_gradient * self.learning_rate;
        
        // Mutation term: η·Mutation (random perturbation)
        let mutation_term = self.mutation_rate * self.rng.next_gaussian();
        
        // Simplicity term: λ·Simplicity (penalize complexity)
        let complexity = program.ast.size() as f64;
        let simplicity_term = -self.simplicity_weight * complexity;
        
        gradient_term + mutation_term + simplicity_term
    }
    
    /// Evolve population for one generation
    pub fn evolve_generation(&mut self, population: &mut Vec<Program>, fitness_fn: &dyn Fn(&Program) -> f64) {
        // Evaluate fitness
        let mut fitness: Vec<(usize, f64)> = population.iter()
            .enumerate()
            .map(|(i, p)| (i, fitness_fn(p)))
            .collect();
        
        // Sort by fitness (descending)
        fitness.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
        
        // Selection (tournament)
        let mut new_population = Vec::with_capacity(self.population_size);
        
        // Elitism: keep top 10%
        let elite_count = self.population_size / 10;
        for i in 0..elite_count {
            new_population.push(population[fitness[i].0].clone());
        }
        
        // Fill rest with crossover and mutation
        while new_population.len() < self.population_size {
            let parent1 = self.tournament_select(&fitness, population);
            let parent2 = self.tournament_select(&fitness, population);
            
            let child = self.geodesic_crossover(&parent1, &parent2);
            let mutated = self.mutate(child);
            
            new_population.push(mutated);
        }
        
        *population = new_population;
    }
    
    fn tournament_select(&mut self, fitness: &[(usize, f64)], population: &[Program]) -> Program {
        let tournament_size = 5;
        let mut best_idx = self.rng.next_usize() % fitness.len();
        let mut best_fitness = fitness[best_idx].1;
        
        for _ in 1..tournament_size {
            let idx = self.rng.next_usize() % fitness.len();
            if fitness[idx].1 > best_fitness {
                best_idx = idx;
                best_fitness = fitness[idx].1;
            }
        }
        
        population[fitness[best_idx].0].clone()
    }
    
    /// Geodesic Crossover: Interpolate programs along manifold
    fn geodesic_crossover(&mut self, parent1: &Program, parent2: &Program) -> Program {
        // Compute geodesic parameter t ∈ [0, 1]
        let t = self.rng.next_f64();
        
        // Interpolate program trees
        let new_ast = self.interpolate_ast(&parent1.ast, &parent2.ast, t);
        
        // Interpolate parameters
        let new_params: Vec<f64> = parent1.parameters.iter()
            .zip(parent2.parameters.iter())
            .map(|(&p1, &p2)| (1.0 - t) * p1 + t * p2)
            .collect();
        
        Program {
            ast: new_ast,
            parameters: new_params,
            fitness: 0.0,
        }
    }
    
    fn interpolate_ast(&mut self, ast1: &ASTNode, ast2: &ASTNode, t: f64) -> ASTNode {
        // With probability t, take from ast2, else ast1
        // For matching structure, interpolate recursively
        if self.rng.next_f64() < t {
            ast2.clone()
        } else {
            ast1.clone()
        }
    }
    
    /// Mutate program with various operators
    fn mutate(&mut self, mut program: Program) -> Program {
        if self.rng.next_f64() < self.mutation_rate {
            // Choose mutation type
            match self.rng.next_usize() % 5 {
                0 => self.point_mutation(&mut program),
                1 => self.subtree_mutation(&mut program),
                2 => self.constant_mutation(&mut program),
                3 => self.simplification(&mut program),
                4 => self.expansion(&mut program),
                _ => {}
            }
        }
        program
    }
    
    fn point_mutation(&mut self, program: &mut Program) {
        // Change a single operator
        // Implementation depends on AST traversal
    }
    
    fn subtree_mutation(&mut self, program: &mut Program) {
        // Replace a random subtree
    }
    
    fn constant_mutation(&mut self, program: &mut Program) {
        // Perturb numeric constants
        for param in &mut program.parameters {
            *param += self.rng.next_gaussian() * 0.1;
        }
    }
    
    fn simplification(&mut self, program: &mut Program) {
        // Apply algebraic simplifications
        program.ast = simplify(&program.ast);
    }
    
    fn expansion(&mut self, program: &mut Program) {
        // Add complexity (new operations)
    }
}

/// Algebraic simplification of AST
fn simplify(ast: &ASTNode) -> ASTNode {
    match ast {
        // x + 0 = x
        ASTNode::Add(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            match (&a_simp, &b_simp) {
                (_, ASTNode::Literal(0.0)) => a_simp,
                (ASTNode::Literal(0.0), _) => b_simp,
                (ASTNode::Literal(x), ASTNode::Literal(y)) => ASTNode::Literal(x + y),
                _ => ASTNode::Add(Box::new(a_simp), Box::new(b_simp)),
            }
        }
        // x * 0 = 0, x * 1 = x
        ASTNode::Mul(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            match (&a_simp, &b_simp) {
                (_, ASTNode::Literal(0.0)) | (ASTNode::Literal(0.0), _) => ASTNode::Literal(0.0),
                (_, ASTNode::Literal(1.0)) => a_simp,
                (ASTNode::Literal(1.0), _) => b_simp,
                (ASTNode::Literal(x), ASTNode::Literal(y)) => ASTNode::Literal(x * y),
                _ => ASTNode::Mul(Box::new(a_simp), Box::new(b_simp)),
            }
        }
        // x - x = 0
        ASTNode::Sub(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            if nodes_equal(&a_simp, &b_simp) {
                ASTNode::Literal(0.0)
            } else {
                match (&a_simp, &b_simp) {
                    (_, ASTNode::Literal(0.0)) => a_simp,
                    (ASTNode::Literal(x), ASTNode::Literal(y)) => ASTNode::Literal(x - y),
                    _ => ASTNode::Sub(Box::new(a_simp), Box::new(b_simp)),
                }
            }
        }
        // x / x = 1
        ASTNode::Div(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            if nodes_equal(&a_simp, &b_simp) {
                ASTNode::Literal(1.0)
            } else {
                match (&a_simp, &b_simp) {
                    (_, ASTNode::Literal(1.0)) => a_simp,
                    (ASTNode::Literal(x), ASTNode::Literal(y)) if *y != 0.0 => ASTNode::Literal(x / y),
                    _ => ASTNode::Div(Box::new(a_simp), Box::new(b_simp)),
                }
            }
        }
        // Double negation: --x = x
        ASTNode::Neg(inner) => {
            match &**inner {
                ASTNode::Neg(x) => simplify(x),
                ASTNode::Literal(x) => ASTNode::Literal(-x),
                _ => ASTNode::Neg(Box::new(simplify(inner))),
            }
        }
        // Pass through others
        _ => ast.clone(),
    }
}

fn nodes_equal(a: &ASTNode, b: &ASTNode) -> bool {
    match (a, b) {
        (ASTNode::Literal(x), ASTNode::Literal(y)) => (x - y).abs() < 1e-10,
        (ASTNode::Variable(x), ASTNode::Variable(y)) => x == y,
        _ => false, // Simplified comparison
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROGRAM REPRESENTATION
// ═══════════════════════════════════════════════════════════════════════════════

/// A program with its AST and learnable parameters
#[derive(Debug, Clone)]
pub struct Program {
    pub ast: ASTNode,
    pub parameters: Vec<f64>,
    pub fitness: f64,
}

impl Program {
    pub fn new(ast: ASTNode) -> Self {
        Program {
            ast,
            parameters: Vec::new(),
            fitness: 0.0,
        }
    }
    
    /// Evaluate program with given environment
    pub fn evaluate(&self, env: &HashMap<String, f64>) -> Result<f64, EvalError> {
        evaluate_ast(&self.ast, env)
    }
    
    /// Evaluate with automatic differentiation
    pub fn evaluate_dual(&self, env: &HashMap<String, Dual>) -> Result<Dual, EvalError> {
        evaluate_ast_dual(&self.ast, env)
    }
    
    /// Convert to Quanta source code
    pub fn to_quanta(&self) -> String {
        ast_to_quanta(&self.ast)
    }
}

fn evaluate_ast(ast: &ASTNode, env: &HashMap<String, f64>) -> Result<f64, EvalError> {
    match ast {
        ASTNode::Literal(v) => Ok(*v),
        ASTNode::Variable(name) => {
            env.get(name).copied().ok_or(EvalError::UndefinedVariable(name.clone()))
        }
        ASTNode::Add(a, b) => Ok(evaluate_ast(a, env)? + evaluate_ast(b, env)?),
        ASTNode::Sub(a, b) => Ok(evaluate_ast(a, env)? - evaluate_ast(b, env)?),
        ASTNode::Mul(a, b) => Ok(evaluate_ast(a, env)? * evaluate_ast(b, env)?),
        ASTNode::Div(a, b) => {
            let divisor = evaluate_ast(b, env)?;
            if divisor == 0.0 {
                Err(EvalError::DivisionByZero)
            } else {
                Ok(evaluate_ast(a, env)? / divisor)
            }
        }
        ASTNode::Pow(a, b) => Ok(pow(evaluate_ast(a, env)?, evaluate_ast(b, env)?)),
        ASTNode::Neg(a) => Ok(-evaluate_ast(a, env)?),
        ASTNode::Sin(a) => Ok(sin(evaluate_ast(a, env)?)),
        ASTNode::Cos(a) => Ok(cos(evaluate_ast(a, env)?)),
        ASTNode::Exp(a) => Ok(exp(evaluate_ast(a, env)?)),
        ASTNode::Log(a) => {
            let v = evaluate_ast(a, env)?;
            if v <= 0.0 {
                Err(EvalError::InvalidDomain)
            } else {
                Ok(log(v))
            }
        }
        ASTNode::Sqrt(a) => {
            let v = evaluate_ast(a, env)?;
            if v < 0.0 {
                Err(EvalError::InvalidDomain)
            } else {
                Ok(sqrt(v))
            }
        }
        ASTNode::Abs(a) => Ok(abs(evaluate_ast(a, env)?)),
        ASTNode::Tanh(a) => Ok(tanh(evaluate_ast(a, env)?)),
        ASTNode::If(cond, then_branch, else_branch) => {
            let c = evaluate_ast(cond, env)?;
            if c > 0.0 {
                evaluate_ast(then_branch, env)
            } else {
                evaluate_ast(else_branch, env)
            }
        }
        _ => Err(EvalError::UnsupportedOperation),
    }
}

fn evaluate_ast_dual(ast: &ASTNode, env: &HashMap<String, Dual>) -> Result<Dual, EvalError> {
    match ast {
        ASTNode::Literal(v) => Ok(Dual::constant(*v)),
        ASTNode::Variable(name) => {
            env.get(name).copied().ok_or(EvalError::UndefinedVariable(name.clone()))
        }
        ASTNode::Add(a, b) => Ok(evaluate_ast_dual(a, env)?.add(&evaluate_ast_dual(b, env)?)),
        ASTNode::Sub(a, b) => Ok(evaluate_ast_dual(a, env)?.sub(&evaluate_ast_dual(b, env)?)),
        ASTNode::Mul(a, b) => Ok(evaluate_ast_dual(a, env)?.mul(&evaluate_ast_dual(b, env)?)),
        ASTNode::Div(a, b) => Ok(evaluate_ast_dual(a, env)?.div(&evaluate_ast_dual(b, env)?)),
        ASTNode::Neg(a) => {
            let v = evaluate_ast_dual(a, env)?;
            Ok(Dual::new(-v.value, -v.derivative))
        }
        ASTNode::Sin(a) => Ok(evaluate_ast_dual(a, env)?.sin()),
        ASTNode::Cos(a) => Ok(evaluate_ast_dual(a, env)?.cos()),
        ASTNode::Exp(a) => Ok(evaluate_ast_dual(a, env)?.exp()),
        ASTNode::Log(a) => Ok(evaluate_ast_dual(a, env)?.log()),
        ASTNode::Sqrt(a) => Ok(evaluate_ast_dual(a, env)?.sqrt()),
        ASTNode::Tanh(a) => Ok(evaluate_ast_dual(a, env)?.tanh()),
        ASTNode::Abs(a) => Ok(evaluate_ast_dual(a, env)?.abs()),
        ASTNode::If(cond, then_branch, else_branch) => {
            let c = evaluate_ast_dual(cond, env)?;
            let t = evaluate_ast_dual(then_branch, env)?;
            let e = evaluate_ast_dual(else_branch, env)?;
            Ok(soft_if_dual(c, t, e, 1.0))
        }
        _ => Err(EvalError::UnsupportedOperation),
    }
}

fn ast_to_quanta(ast: &ASTNode) -> String {
    match ast {
        ASTNode::Literal(v) => format!("{}", v),
        ASTNode::Variable(name) => name.clone(),
        ASTNode::Add(a, b) => format!("({} + {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Sub(a, b) => format!("({} - {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Mul(a, b) => format!("({} * {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Div(a, b) => format!("({} / {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Pow(a, b) => format!("pow({}, {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Neg(a) => format!("(-{})", ast_to_quanta(a)),
        ASTNode::Sin(a) => format!("sin({})", ast_to_quanta(a)),
        ASTNode::Cos(a) => format!("cos({})", ast_to_quanta(a)),
        ASTNode::Exp(a) => format!("exp({})", ast_to_quanta(a)),
        ASTNode::Log(a) => format!("log({})", ast_to_quanta(a)),
        ASTNode::Sqrt(a) => format!("sqrt({})", ast_to_quanta(a)),
        ASTNode::Abs(a) => format!("abs({})", ast_to_quanta(a)),
        ASTNode::Tanh(a) => format!("tanh({})", ast_to_quanta(a)),
        ASTNode::If(c, t, e) => format!("if {} {{ {} }} else {{ {} }}", 
            ast_to_quanta(c), ast_to_quanta(t), ast_to_quanta(e)),
        ASTNode::Lambda(params, body) => {
            format!("|{}| {{ {} }}", params.join(", "), ast_to_quanta(body))
        }
        ASTNode::Let(name, val, body) => {
            format!("let {} = {}; {}", name, ast_to_quanta(val), ast_to_quanta(body))
        }
        _ => "/* unsupported */".to_string(),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL ARCHITECTURE SEARCH
// ═══════════════════════════════════════════════════════════════════════════════

/// Neural architecture representation
#[derive(Debug, Clone)]
pub struct NeuralArchitecture {
    pub layers: Vec<LayerSpec>,
    pub connections: Vec<(usize, usize)>,  // Skip connections
}

#[derive(Debug, Clone)]
pub enum LayerSpec {
    Dense { in_features: usize, out_features: usize },
    Conv2D { in_channels: usize, out_channels: usize, kernel: usize },
    Attention { heads: usize, dim: usize },
    LayerNorm { dim: usize },
    Dropout { rate: f64 },
    Activation(ActivationType),
    Residual(Box<NeuralArchitecture>),
}

/// Neural Architecture Search using Axiom evolution
pub struct NeuralArchitectureSearch {
    evolution: QuantaEvolution,
    max_layers: usize,
    max_params: usize,
}

impl NeuralArchitectureSearch {
    pub fn new(seed: u64) -> Self {
        NeuralArchitectureSearch {
            evolution: QuantaEvolution::new(seed),
            max_layers: 50,
            max_params: 100_000_000,
        }
    }
    
    /// Generate random architecture
    pub fn random_architecture(&mut self, input_dim: usize, output_dim: usize) -> NeuralArchitecture {
        let mut layers = Vec::new();
        let mut current_dim = input_dim;
        
        let num_layers = 3 + (self.evolution.rng.next_usize() % 10);
        
        for i in 0..num_layers {
            let out_dim = if i == num_layers - 1 {
                output_dim
            } else {
                32 * (1 << (self.evolution.rng.next_usize() % 4))
            };
            
            layers.push(LayerSpec::Dense { 
                in_features: current_dim, 
                out_features: out_dim 
            });
            
            if i < num_layers - 1 {
                layers.push(LayerSpec::Activation(ActivationType::GELU));
                
                if self.evolution.rng.next_f64() < 0.3 {
                    layers.push(LayerSpec::Dropout { rate: 0.1 });
                }
            }
            
            current_dim = out_dim;
        }
        
        NeuralArchitecture {
            layers,
            connections: Vec::new(),
        }
    }
    
    /// Mutate architecture
    pub fn mutate_architecture(&mut self, arch: &NeuralArchitecture) -> NeuralArchitecture {
        let mut new_arch = arch.clone();
        
        match self.evolution.rng.next_usize() % 4 {
            0 => self.add_layer(&mut new_arch),
            1 => self.remove_layer(&mut new_arch),
            2 => self.modify_layer(&mut new_arch),
            3 => self.add_skip_connection(&mut new_arch),
            _ => {}
        }
        
        new_arch
    }
    
    fn add_layer(&mut self, arch: &mut NeuralArchitecture) {
        if arch.layers.len() < self.max_layers {
            let pos = self.evolution.rng.next_usize() % (arch.layers.len() + 1);
            arch.layers.insert(pos, LayerSpec::Activation(ActivationType::ReLU));
        }
    }
    
    fn remove_layer(&mut self, arch: &mut NeuralArchitecture) {
        if arch.layers.len() > 2 {
            let pos = self.evolution.rng.next_usize() % arch.layers.len();
            arch.layers.remove(pos);
        }
    }
    
    fn modify_layer(&mut self, arch: &mut NeuralArchitecture) {
        if !arch.layers.is_empty() {
            let pos = self.evolution.rng.next_usize() % arch.layers.len();
            if let LayerSpec::Dense { in_features, .. } = arch.layers[pos] {
                let new_out = 32 * (1 << (self.evolution.rng.next_usize() % 5));
                arch.layers[pos] = LayerSpec::Dense { 
                    in_features, 
                    out_features: new_out 
                };
            }
        }
    }
    
    fn add_skip_connection(&mut self, arch: &mut NeuralArchitecture) {
        let n = arch.layers.len();
        if n > 2 {
            let from = self.evolution.rng.next_usize() % (n - 2);
            let to = from + 2 + (self.evolution.rng.next_usize() % (n - from - 2).max(1));
            if to < n {
                arch.connections.push((from, to));
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYMBOLIC REGRESSION
// ═══════════════════════════════════════════════════════════════════════════════

/// Symbolic regression: find formula from data
pub struct SymbolicRegression {
    evolution: QuantaEvolution,
    population: Vec<Program>,
    variables: Vec<String>,
}

impl SymbolicRegression {
    pub fn new(variables: Vec<String>, population_size: usize, seed: u64) -> Self {
        let mut sr = SymbolicRegression {
            evolution: QuantaEvolution::new(seed),
            population: Vec::new(),
            variables,
        };
        sr.evolution.population_size = population_size;
        sr.initialize_population();
        sr
    }
    
    fn initialize_population(&mut self) {
        for _ in 0..self.evolution.population_size {
            let ast = self.random_ast(3);
            self.population.push(Program::new(ast));
        }
    }
    
    fn random_ast(&mut self, max_depth: usize) -> ASTNode {
        if max_depth == 0 || self.evolution.rng.next_f64() < 0.3 {
            // Terminal
            if self.evolution.rng.next_f64() < 0.5 {
                ASTNode::Literal(self.evolution.rng.next_gaussian())
            } else {
                let var = &self.variables[self.evolution.rng.next_usize() % self.variables.len()];
                ASTNode::Variable(var.clone())
            }
        } else {
            // Function
            match self.evolution.rng.next_usize() % 10 {
                0 => ASTNode::Add(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                1 => ASTNode::Sub(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                2 => ASTNode::Mul(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                3 => ASTNode::Div(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                4 => ASTNode::Sin(Box::new(self.random_ast(max_depth - 1))),
                5 => ASTNode::Cos(Box::new(self.random_ast(max_depth - 1))),
                6 => ASTNode::Exp(Box::new(self.random_ast(max_depth - 1))),
                7 => ASTNode::Log(Box::new(self.random_ast(max_depth - 1))),
                8 => ASTNode::Sqrt(Box::new(self.random_ast(max_depth - 1))),
                _ => ASTNode::Neg(Box::new(self.random_ast(max_depth - 1))),
            }
        }
    }
    
    /// Fit to data
    pub fn fit(&mut self, x: &[HashMap<String, f64>], y: &[f64], generations: usize) -> Program {
        for gen in 0..generations {
            // Evaluate fitness (negative MSE)
            let fitness_fn = |p: &Program| {
                let mse: f64 = x.iter().zip(y.iter())
                    .map(|(xi, &yi)| {
                        match p.evaluate(xi) {
                            Ok(pred) => (pred - yi).powi(2),
                            Err(_) => 1e10,
                        }
                    })
                    .sum::<f64>() / x.len() as f64;
                
                let complexity_penalty = p.ast.size() as f64 * self.evolution.simplicity_weight;
                -mse - complexity_penalty
            };
            
            self.evolution.evolve_generation(&mut self.population, &fitness_fn);
            
            // Report best
            if gen % 10 == 0 {
                let best = self.population.iter()
                    .max_by(|a, b| a.fitness.partial_cmp(&b.fitness).unwrap())
                    .unwrap();
                println!("Generation {}: fitness={:.6}, formula={}", 
                    gen, best.fitness, best.to_quanta());
            }
        }
        
        self.population.iter()
            .max_by(|a, b| a.fitness.partial_cmp(&b.fitness).unwrap())
            .unwrap()
            .clone()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERROR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub enum EvalError {
    UndefinedVariable(String),
    DivisionByZero,
    InvalidDomain,
    UnsupportedOperation,
    StackOverflow,
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL ARCHITECTURE SEARCH (NAS)
// ═══════════════════════════════════════════════════════════════════════════════

/// Search space for neural architecture
#[derive(Debug, Clone)]
pub struct SearchSpace {
    min_layers: usize,
    max_layers: usize,
    layer_types: Vec<LayerType>,
    activation_types: Vec<ActivationType>,
    width_options: Vec<usize>,
    connection_types: Vec<ConnectionType>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum LayerType {
    Dense,
    Conv1D,
    Conv2D,
    LSTM,
    GRU,
    Attention,
    Residual,
    BatchNorm,
    Dropout,
    Pooling,
}

#[derive(Debug, Clone, Copy)]
pub enum ConnectionType {
    Sequential,
    Skip,
    Dense,  // DenseNet-style
    Cell,   // NASNet-style cell
}

/// Architecture encoding for NAS
#[derive(Debug, Clone)]
pub struct Architecture {
    layers: Vec<LayerGene>,
    connections: Vec<(usize, usize)>,
    fitness: f64,
    params: usize,
    flops: usize,
}

#[derive(Debug, Clone)]
pub struct LayerGene {
    layer_type: LayerType,
    activation: ActivationType,
    width: usize,
    kernel_size: Option<usize>,
    dropout_rate: Option<f64>,
}

impl Architecture {
    pub fn new() -> Self {
        Self {
            layers: Vec::new(),
            connections: Vec::new(),
            fitness: 0.0,
            params: 0,
            flops: 0,
        }
    }

    pub fn add_layer(&mut self, gene: LayerGene) {
        self.layers.push(gene);
    }

    pub fn estimate_params(&mut self, input_dim: usize) {
        let mut prev_dim = input_dim;
        self.params = 0;

        for layer in &self.layers {
            match layer.layer_type {
                LayerType::Dense => {
                    self.params += prev_dim * layer.width + layer.width;
                    prev_dim = layer.width;
                },
                LayerType::Conv1D | LayerType::Conv2D => {
                    let k = layer.kernel_size.unwrap_or(3);
                    self.params += prev_dim * layer.width * k + layer.width;
                    prev_dim = layer.width;
                },
                LayerType::LSTM => {
                    self.params += 4 * (prev_dim * layer.width + layer.width * layer.width + layer.width);
                    prev_dim = layer.width;
                },
                LayerType::GRU => {
                    self.params += 3 * (prev_dim * layer.width + layer.width * layer.width + layer.width);
                    prev_dim = layer.width;
                },
                LayerType::Attention => {
                    self.params += 4 * prev_dim * layer.width;
                },
                LayerType::BatchNorm => {
                    self.params += 4 * prev_dim;
                },
                _ => {}
            }
        }
    }
}

/// DARTS: Differentiable Architecture Search
pub struct DARTSController {
    search_space: SearchSpace,
    alpha: Vec<Vec<f64>>,  // architecture parameters
    temperature: f64,
    learning_rate: f64,
}

impl DARTSController {
    pub fn new(space: SearchSpace) -> Self {
        let num_ops = space.layer_types.len();
        let num_edges = space.max_layers * (space.max_layers - 1) / 2;

        let alpha = (0..num_edges)
            .map(|_| vec![0.0; num_ops])
            .collect();

        Self {
            search_space: space,
            alpha,
            temperature: 1.0,
            learning_rate: 0.001,
        }
    }

    /// Softmax over operation choices
    fn softmax_ops(&self, edge_idx: usize) -> Vec<f64> {
        let max_val = self.alpha[edge_idx].iter()
            .cloned().fold(f64::NEG_INFINITY, f64::max);

        let exp_vals: Vec<f64> = self.alpha[edge_idx].iter()
            .map(|&a| exp((a - max_val) / self.temperature))
            .collect();

        let sum: f64 = exp_vals.iter().sum();
        exp_vals.iter().map(|&e| e / sum).collect()
    }

    /// Sample discrete architecture from continuous relaxation
    pub fn sample_architecture(&self) -> Architecture {
        let mut arch = Architecture::new();

        for edge_idx in 0..self.alpha.len() {
            let probs = self.softmax_ops(edge_idx);
            let op_idx = probs.iter()
                .enumerate()
                .max_by(|(_, a), (_, b)| a.partial_cmp(b).unwrap())
                .unwrap().0;

            let layer_type = self.search_space.layer_types[op_idx % self.search_space.layer_types.len()];
            let width = self.search_space.width_options[op_idx / self.search_space.layer_types.len() % self.search_space.width_options.len()];

            arch.add_layer(LayerGene {
                layer_type,
                activation: ActivationType::ReLU,
                width,
                kernel_size: Some(3),
                dropout_rate: Some(0.1),
            });
        }

        arch
    }

    /// Update architecture parameters using validation loss
    pub fn update_alpha(&mut self, grad: &[Vec<f64>]) {
        for (edge, g) in self.alpha.iter_mut().zip(grad.iter()) {
            for (a, dg) in edge.iter_mut().zip(g.iter()) {
                *a -= self.learning_rate * dg;
            }
        }
    }
}

/// Evolutionary NAS with aging evolution
pub struct AgingEvolutionNAS {
    population: VecDeque<Architecture>,
    population_size: usize,
    sample_size: usize,
    search_space: SearchSpace,
    rng: Random,
}

impl AgingEvolutionNAS {
    pub fn new(space: SearchSpace, pop_size: usize, sample_size: usize, seed: u64) -> Self {
        Self {
            population: VecDeque::new(),
            population_size: pop_size,
            sample_size,
            search_space: space,
            rng: Random::from_seed(Seed::from_u64(seed)),
        }
    }

    /// Mutate architecture
    fn mutate(&mut self, arch: &Architecture) -> Architecture {
        let mut new_arch = arch.clone();
        let mutation_type = self.rng.next_u64() % 3;

        match mutation_type {
            0 => {
                // Change random layer type
                if !new_arch.layers.is_empty() {
                    let idx = self.rng.next_u64() as usize % new_arch.layers.len();
                    let new_type = self.search_space.layer_types[
                        self.rng.next_u64() as usize % self.search_space.layer_types.len()
                    ];
                    new_arch.layers[idx].layer_type = new_type;
                }
            },
            1 => {
                // Change width
                if !new_arch.layers.is_empty() {
                    let idx = self.rng.next_u64() as usize % new_arch.layers.len();
                    new_arch.layers[idx].width = self.search_space.width_options[
                        self.rng.next_u64() as usize % self.search_space.width_options.len()
                    ];
                }
            },
            _ => {
                // Add or remove layer
                if new_arch.layers.len() > self.search_space.min_layers && self.rng.next_f64() < 0.5 {
                    let idx = self.rng.next_u64() as usize % new_arch.layers.len();
                    new_arch.layers.remove(idx);
                } else if new_arch.layers.len() < self.search_space.max_layers {
                    new_arch.add_layer(LayerGene {
                        layer_type: self.search_space.layer_types[0],
                        activation: ActivationType::ReLU,
                        width: self.search_space.width_options[0],
                        kernel_size: Some(3),
                        dropout_rate: Some(0.1),
                    });
                }
            }
        }

        new_arch.fitness = 0.0;
        new_arch
    }

    /// Run one cycle of aging evolution
    pub fn evolve_step<F>(&mut self, evaluate: F) -> &Architecture
    where F: Fn(&Architecture) -> f64
    {
        // Sample random candidates
        let mut candidates: Vec<_> = (0..self.sample_size)
            .map(|_| {
                let idx = self.rng.next_u64() as usize % self.population.len();
                &self.population[idx]
            })
            .collect();

        // Pick best candidate
        let best = candidates.iter()
            .max_by(|a, b| a.fitness.partial_cmp(&b.fitness).unwrap())
            .unwrap();

        // Mutate and evaluate
        let mut child = self.mutate(best);
        child.fitness = evaluate(&child);

        // Add child, remove oldest
        self.population.push_back(child);
        if self.population.len() > self.population_size {
            self.population.pop_front();
        }

        self.population.back().unwrap()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTOMATED THEOREM PROVING
// ═══════════════════════════════════════════════════════════════════════════════

/// Logical formula representation
#[derive(Debug, Clone, PartialEq)]
pub enum Formula {
    Atom(String),
    Not(Box<Formula>),
    And(Box<Formula>, Box<Formula>),
    Or(Box<Formula>, Box<Formula>),
    Implies(Box<Formula>, Box<Formula>),
    Iff(Box<Formula>, Box<Formula>),
    ForAll(String, Box<Formula>),
    Exists(String, Box<Formula>),
    Pred(String, Vec<Term>),
    Equals(Term, Term),
}

#[derive(Debug, Clone, PartialEq)]
pub enum Term {
    Var(String),
    Const(String),
    Func(String, Vec<Term>),
}

/// Proof tree node
#[derive(Debug, Clone)]
pub struct ProofNode {
    formula: Formula,
    rule: ProofRule,
    premises: Vec<Box<ProofNode>>,
}

#[derive(Debug, Clone, Copy)]
pub enum ProofRule {
    Axiom,
    ModusPonens,
    AndIntro,
    AndElim,
    OrIntro,
    OrElim,
    NotIntro,
    NotElim,
    ImpliesIntro,
    ImpliesElim,
    ForAllIntro,
    ForAllElim,
    ExistsIntro,
    ExistsElim,
    Contradiction,
}

/// Resolution-based theorem prover
pub struct ResolutionProver {
    clauses: Vec<Clause>,
    max_depth: usize,
}

#[derive(Debug, Clone)]
pub struct Clause {
    literals: Vec<Literal>,
}

#[derive(Debug, Clone)]
pub struct Literal {
    predicate: String,
    args: Vec<Term>,
    negated: bool,
}

impl ResolutionProver {
    pub fn new(max_depth: usize) -> Self {
        Self {
            clauses: Vec::new(),
            max_depth,
        }
    }

    /// Convert formula to CNF
    pub fn to_cnf(&self, formula: &Formula) -> Vec<Clause> {
        let negated = self.negate(formula);
        let nnf = self.to_nnf(&negated);
        let skolemized = self.skolemize(&nnf, &mut Vec::new(), &mut 0);
        self.distribute(&skolemized)
    }

    fn negate(&self, f: &Formula) -> Formula {
        Formula::Not(Box::new(f.clone()))
    }

    fn to_nnf(&self, f: &Formula) -> Formula {
        match f {
            Formula::Not(inner) => match inner.as_ref() {
                Formula::Not(p) => self.to_nnf(p),
                Formula::And(a, b) => Formula::Or(
                    Box::new(self.to_nnf(&Formula::Not(a.clone()))),
                    Box::new(self.to_nnf(&Formula::Not(b.clone()))),
                ),
                Formula::Or(a, b) => Formula::And(
                    Box::new(self.to_nnf(&Formula::Not(a.clone()))),
                    Box::new(self.to_nnf(&Formula::Not(b.clone()))),
                ),
                Formula::ForAll(v, p) => Formula::Exists(
                    v.clone(),
                    Box::new(self.to_nnf(&Formula::Not(p.clone()))),
                ),
                Formula::Exists(v, p) => Formula::ForAll(
                    v.clone(),
                    Box::new(self.to_nnf(&Formula::Not(p.clone()))),
                ),
                _ => f.clone(),
            },
            Formula::And(a, b) => Formula::And(
                Box::new(self.to_nnf(a)),
                Box::new(self.to_nnf(b)),
            ),
            Formula::Or(a, b) => Formula::Or(
                Box::new(self.to_nnf(a)),
                Box::new(self.to_nnf(b)),
            ),
            Formula::Implies(a, b) => Formula::Or(
                Box::new(self.to_nnf(&Formula::Not(a.clone()))),
                Box::new(self.to_nnf(b)),
            ),
            Formula::ForAll(v, p) => Formula::ForAll(v.clone(), Box::new(self.to_nnf(p))),
            Formula::Exists(v, p) => Formula::Exists(v.clone(), Box::new(self.to_nnf(p))),
            _ => f.clone(),
        }
    }

    fn skolemize(&self, f: &Formula, bound: &mut Vec<String>, counter: &mut usize) -> Formula {
        match f {
            Formula::ForAll(v, p) => {
                bound.push(v.clone());
                let result = self.skolemize(p, bound, counter);
                bound.pop();
                result
            },
            Formula::Exists(v, p) => {
                *counter += 1;
                let skolem_name = format!("sk{}", counter);
                let skolem_term = if bound.is_empty() {
                    Term::Const(skolem_name)
                } else {
                    Term::Func(skolem_name, bound.iter().map(|v| Term::Var(v.clone())).collect())
                };
                self.substitute_term(p, v, &skolem_term, bound, counter)
            },
            Formula::And(a, b) => Formula::And(
                Box::new(self.skolemize(a, bound, counter)),
                Box::new(self.skolemize(b, bound, counter)),
            ),
            Formula::Or(a, b) => Formula::Or(
                Box::new(self.skolemize(a, bound, counter)),
                Box::new(self.skolemize(b, bound, counter)),
            ),
            _ => f.clone(),
        }
    }

    fn substitute_term(&self, f: &Formula, var: &str, term: &Term, bound: &mut Vec<String>, counter: &mut usize) -> Formula {
        self.skolemize(f, bound, counter)
    }

    fn distribute(&self, f: &Formula) -> Vec<Clause> {
        match f {
            Formula::And(a, b) => {
                let mut result = self.distribute(a);
                result.extend(self.distribute(b));
                result
            },
            Formula::Or(a, b) => {
                let left = self.distribute(a);
                let right = self.distribute(b);
                let mut result = Vec::new();
                for l in &left {
                    for r in &right {
                        let mut combined = l.literals.clone();
                        combined.extend(r.literals.clone());
                        result.push(Clause { literals: combined });
                    }
                }
                result
            },
            Formula::Pred(name, args) => vec![Clause {
                literals: vec![Literal {
                    predicate: name.clone(),
                    args: args.clone(),
                    negated: false,
                }],
            }],
            Formula::Not(inner) => match inner.as_ref() {
                Formula::Pred(name, args) => vec![Clause {
                    literals: vec![Literal {
                        predicate: name.clone(),
                        args: args.clone(),
                        negated: true,
                    }],
                }],
                _ => vec![],
            },
            _ => vec![],
        }
    }

    /// Attempt resolution between two clauses
    fn resolve(&self, c1: &Clause, c2: &Clause) -> Option<Clause> {
        for (i, l1) in c1.literals.iter().enumerate() {
            for (j, l2) in c2.literals.iter().enumerate() {
                if l1.predicate == l2.predicate && l1.negated != l2.negated {
                    if let Some(subst) = self.unify(&l1.args, &l2.args) {
                        let mut new_lits: Vec<Literal> = c1.literals.iter()
                            .enumerate()
                            .filter(|(k, _)| *k != i)
                            .map(|(_, l)| self.apply_subst(l, &subst))
                            .collect();

                        new_lits.extend(
                            c2.literals.iter()
                                .enumerate()
                                .filter(|(k, _)| *k != j)
                                .map(|(_, l)| self.apply_subst(l, &subst))
                        );

                        return Some(Clause { literals: new_lits });
                    }
                }
            }
        }
        None
    }

    /// Unification algorithm
    fn unify(&self, t1: &[Term], t2: &[Term]) -> Option<HashMap<String, Term>> {
        if t1.len() != t2.len() {
            return None;
        }

        let mut subst = HashMap::new();

        for (a, b) in t1.iter().zip(t2.iter()) {
            match (a, b) {
                (Term::Var(v), t) | (t, Term::Var(v)) => {
                    if let Some(existing) = subst.get(v) {
                        if existing != t {
                            return None;
                        }
                    } else {
                        subst.insert(v.clone(), t.clone());
                    }
                },
                (Term::Const(c1), Term::Const(c2)) if c1 == c2 => {},
                (Term::Func(f1, args1), Term::Func(f2, args2)) if f1 == f2 => {
                    if let Some(inner) = self.unify(args1, args2) {
                        for (k, v) in inner {
                            subst.insert(k, v);
                        }
                    } else {
                        return None;
                    }
                },
                _ => return None,
            }
        }

        Some(subst)
    }

    fn apply_subst(&self, lit: &Literal, subst: &HashMap<String, Term>) -> Literal {
        Literal {
            predicate: lit.predicate.clone(),
            args: lit.args.iter()
                .map(|t| self.apply_term_subst(t, subst))
                .collect(),
            negated: lit.negated,
        }
    }

    fn apply_term_subst(&self, term: &Term, subst: &HashMap<String, Term>) -> Term {
        match term {
            Term::Var(v) => subst.get(v).cloned().unwrap_or_else(|| term.clone()),
            Term::Func(f, args) => Term::Func(
                f.clone(),
                args.iter().map(|a| self.apply_term_subst(a, subst)).collect(),
            ),
            _ => term.clone(),
        }
    }

    /// Run resolution to find proof
    pub fn prove(&mut self, goal: &Formula) -> bool {
        self.clauses = self.to_cnf(goal);

        for _ in 0..self.max_depth {
            let mut new_clauses = Vec::new();

            for i in 0..self.clauses.len() {
                for j in i+1..self.clauses.len() {
                    if let Some(resolvent) = self.resolve(&self.clauses[i], &self.clauses[j]) {
                        if resolvent.literals.is_empty() {
                            return true; // Empty clause = contradiction = proof found
                        }
                        new_clauses.push(resolvent);
                    }
                }
            }

            if new_clauses.is_empty() {
                break;
            }

            self.clauses.extend(new_clauses);
        }

        false
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// META-LEARNING (Learning to Learn)
// ═══════════════════════════════════════════════════════════════════════════════

/// MAML: Model-Agnostic Meta-Learning
pub struct MAMLLearner {
    inner_lr: f64,
    outer_lr: f64,
    inner_steps: usize,
    first_order: bool,
}

#[derive(Debug, Clone)]
pub struct TaskBatch {
    support_x: Vec<Vec<f64>>,
    support_y: Vec<f64>,
    query_x: Vec<Vec<f64>>,
    query_y: Vec<f64>,
}

impl MAMLLearner {
    pub fn new(inner_lr: f64, outer_lr: f64, inner_steps: usize) -> Self {
        Self {
            inner_lr,
            outer_lr,
            inner_steps,
            first_order: false,
        }
    }

    /// Inner loop: adapt to specific task
    pub fn adapt(&self, params: &mut Vec<f64>, task: &TaskBatch) -> Vec<f64> {
        let mut adapted = params.clone();

        for _ in 0..self.inner_steps {
            let grad = self.compute_gradient(&adapted, &task.support_x, &task.support_y);
            for (p, g) in adapted.iter_mut().zip(grad.iter()) {
                *p -= self.inner_lr * g;
            }
        }

        adapted
    }

    /// Outer loop: meta-update across tasks
    pub fn meta_update(&self, params: &mut Vec<f64>, tasks: &[TaskBatch]) {
        let mut meta_grad = vec![0.0; params.len()];

        for task in tasks {
            let adapted = self.adapt(params, task);
            let query_grad = self.compute_gradient(&adapted, &task.query_x, &task.query_y);

            if self.first_order {
                for (mg, qg) in meta_grad.iter_mut().zip(query_grad.iter()) {
                    *mg += qg;
                }
            } else {
                // Full second-order gradient (expensive)
                let hessian = self.compute_hessian(&adapted, &task.support_x, &task.support_y);
                for i in 0..params.len() {
                    meta_grad[i] += query_grad[i];
                    for j in 0..params.len() {
                        meta_grad[i] -= self.inner_lr * hessian[i][j] * query_grad[j];
                    }
                }
            }
        }

        let n = tasks.len() as f64;
        for (p, g) in params.iter_mut().zip(meta_grad.iter()) {
            *p -= self.outer_lr * g / n;
        }
    }

    fn compute_gradient(&self, params: &[f64], x: &[Vec<f64>], y: &[f64]) -> Vec<f64> {
        let mut grad = vec![0.0; params.len()];

        for (xi, yi) in x.iter().zip(y.iter()) {
            let pred: f64 = params.iter().zip(xi.iter()).map(|(p, x)| p * x).sum();
            let error = pred - yi;

            for (g, xi_j) in grad.iter_mut().zip(xi.iter()) {
                *g += 2.0 * error * xi_j;
            }
        }

        let n = x.len() as f64;
        for g in &mut grad {
            *g /= n;
        }

        grad
    }

    fn compute_hessian(&self, params: &[f64], x: &[Vec<f64>], _y: &[f64]) -> Vec<Vec<f64>> {
        let n = params.len();
        let mut hessian = vec![vec![0.0; n]; n];

        for xi in x {
            for i in 0..n {
                for j in 0..n {
                    hessian[i][j] += 2.0 * xi[i] * xi[j];
                }
            }
        }

        let m = x.len() as f64;
        for row in &mut hessian {
            for h in row {
                *h /= m;
            }
        }

        hessian
    }
}

/// Reptile: Simpler meta-learning
pub struct ReptileLearner {
    inner_lr: f64,
    outer_lr: f64,
    inner_steps: usize,
}

impl ReptileLearner {
    pub fn new(inner_lr: f64, outer_lr: f64, inner_steps: usize) -> Self {
        Self { inner_lr, outer_lr, inner_steps }
    }

    pub fn meta_update(&self, params: &mut Vec<f64>, tasks: &[TaskBatch]) {
        let original = params.clone();
        let mut avg_adapted = vec![0.0; params.len()];

        for task in tasks {
            let mut adapted = original.clone();

            for _ in 0..self.inner_steps {
                let grad = self.compute_sgd_step(&adapted, &task.support_x, &task.support_y);
                for (p, g) in adapted.iter_mut().zip(grad.iter()) {
                    *p -= self.inner_lr * g;
                }
            }

            for (avg, a) in avg_adapted.iter_mut().zip(adapted.iter()) {
                *avg += a;
            }
        }

        let n = tasks.len() as f64;
        for i in 0..params.len() {
            params[i] += self.outer_lr * (avg_adapted[i] / n - original[i]);
        }
    }

    fn compute_sgd_step(&self, params: &[f64], x: &[Vec<f64>], y: &[f64]) -> Vec<f64> {
        let mut grad = vec![0.0; params.len()];

        for (xi, yi) in x.iter().zip(y.iter()) {
            let pred: f64 = params.iter().zip(xi.iter()).map(|(p, x)| p * x).sum();
            let error = pred - yi;
            for (g, xi_j) in grad.iter_mut().zip(xi.iter()) {
                *g += error * xi_j;
            }
        }

        grad
    }
}

/// Prototypical Networks for few-shot learning
pub struct ProtoNetLearner {
    embedding_dim: usize,
}

impl ProtoNetLearner {
    pub fn new(embedding_dim: usize) -> Self {
        Self { embedding_dim }
    }

    /// Compute class prototypes from support set
    pub fn compute_prototypes(&self, embeddings: &[Vec<f64>], labels: &[usize]) -> HashMap<usize, Vec<f64>> {
        let mut prototypes: HashMap<usize, (Vec<f64>, usize)> = HashMap::new();

        for (emb, &label) in embeddings.iter().zip(labels.iter()) {
            let entry = prototypes.entry(label).or_insert((vec![0.0; self.embedding_dim], 0));
            for (p, e) in entry.0.iter_mut().zip(emb.iter()) {
                *p += e;
            }
            entry.1 += 1;
        }

        prototypes.into_iter()
            .map(|(k, (sum, count))| {
                let proto: Vec<f64> = sum.iter().map(|s| s / count as f64).collect();
                (k, proto)
            })
            .collect()
    }

    /// Classify query point using prototypes
    pub fn classify(&self, query: &[f64], prototypes: &HashMap<usize, Vec<f64>>) -> usize {
        prototypes.iter()
            .map(|(&label, proto)| {
                let dist: f64 = query.iter().zip(proto.iter())
                    .map(|(q, p)| (q - p).powi(2))
                    .sum();
                (label, dist)
            })
            .min_by(|(_, d1), (_, d2)| d1.partial_cmp(d2).unwrap())
            .unwrap().0
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROGRAM INDUCTION & SYNTHESIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Domain-specific language for program synthesis
#[derive(Debug, Clone)]
pub enum DSLExpr {
    // Primitives
    Input(usize),
    Const(i64),

    // Arithmetic
    Add(Box<DSLExpr>, Box<DSLExpr>),
    Sub(Box<DSLExpr>, Box<DSLExpr>),
    Mul(Box<DSLExpr>, Box<DSLExpr>),
    Div(Box<DSLExpr>, Box<DSLExpr>),
    Mod(Box<DSLExpr>, Box<DSLExpr>),

    // Comparisons
    Eq(Box<DSLExpr>, Box<DSLExpr>),
    Lt(Box<DSLExpr>, Box<DSLExpr>),
    Gt(Box<DSLExpr>, Box<DSLExpr>),

    // Control
    If(Box<DSLExpr>, Box<DSLExpr>, Box<DSLExpr>),

    // List ops
    Map(Box<DSLExpr>, Box<DSLExpr>),
    Filter(Box<DSLExpr>, Box<DSLExpr>),
    Fold(Box<DSLExpr>, Box<DSLExpr>, Box<DSLExpr>),
    Head(Box<DSLExpr>),
    Tail(Box<DSLExpr>),
    Cons(Box<DSLExpr>, Box<DSLExpr>),
    Len(Box<DSLExpr>),

    // Higher-order
    Lambda(Vec<usize>, Box<DSLExpr>),
    Apply(Box<DSLExpr>, Vec<DSLExpr>),
}

/// Input-output example for program synthesis
#[derive(Debug, Clone)]
pub struct IOExample {
    inputs: Vec<i64>,
    output: i64,
}

/// Bottom-up enumerative synthesis
pub struct EnumerativeSynthesizer {
    max_size: usize,
    examples: Vec<IOExample>,
}

impl EnumerativeSynthesizer {
    pub fn new(max_size: usize, examples: Vec<IOExample>) -> Self {
        Self { max_size, examples }
    }

    /// Enumerate programs of increasing size
    pub fn synthesize(&self) -> Option<DSLExpr> {
        let mut programs: Vec<Vec<DSLExpr>> = vec![Vec::new(); self.max_size + 1];

        // Size 1: inputs and small constants
        let num_inputs = self.examples.first().map(|e| e.inputs.len()).unwrap_or(0);
        for i in 0..num_inputs {
            programs[1].push(DSLExpr::Input(i));
        }
        for c in -5..=5 {
            programs[1].push(DSLExpr::Const(c));
        }

        // Check size 1
        for prog in &programs[1] {
            if self.satisfies_all(prog) {
                return Some(prog.clone());
            }
        }

        // Enumerate larger programs
        for size in 2..=self.max_size {
            // Binary ops
            for left_size in 1..size {
                let right_size = size - left_size - 1;
                if right_size >= 1 {
                    for left in &programs[left_size] {
                        for right in &programs[right_size] {
                            let ops = vec![
                                DSLExpr::Add(Box::new(left.clone()), Box::new(right.clone())),
                                DSLExpr::Sub(Box::new(left.clone()), Box::new(right.clone())),
                                DSLExpr::Mul(Box::new(left.clone()), Box::new(right.clone())),
                            ];

                            for op in ops {
                                if self.satisfies_all(&op) {
                                    return Some(op);
                                }
                                programs[size].push(op);
                            }
                        }
                    }
                }
            }

            // If expressions
            for cond_size in 1..size-1 {
                for then_size in 1..size-cond_size {
                    let else_size = size - cond_size - then_size - 1;
                    if else_size >= 1 {
                        for cond in &programs[cond_size] {
                            for then_expr in &programs[then_size] {
                                for else_expr in &programs[else_size] {
                                    let if_expr = DSLExpr::If(
                                        Box::new(cond.clone()),
                                        Box::new(then_expr.clone()),
                                        Box::new(else_expr.clone()),
                                    );

                                    if self.satisfies_all(&if_expr) {
                                        return Some(if_expr);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        None
    }

    fn satisfies_all(&self, prog: &DSLExpr) -> bool {
        self.examples.iter().all(|ex| {
            match self.evaluate(prog, &ex.inputs) {
                Some(v) => v == ex.output,
                None => false,
            }
        })
    }

    fn evaluate(&self, prog: &DSLExpr, inputs: &[i64]) -> Option<i64> {
        match prog {
            DSLExpr::Input(i) => inputs.get(*i).copied(),
            DSLExpr::Const(c) => Some(*c),
            DSLExpr::Add(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                Some(va + vb)
            },
            DSLExpr::Sub(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                Some(va - vb)
            },
            DSLExpr::Mul(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                Some(va * vb)
            },
            DSLExpr::Div(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                if vb == 0 { None } else { Some(va / vb) }
            },
            DSLExpr::Mod(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                if vb == 0 { None } else { Some(va % vb) }
            },
            DSLExpr::Eq(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                Some(if va == vb { 1 } else { 0 })
            },
            DSLExpr::Lt(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                Some(if va < vb { 1 } else { 0 })
            },
            DSLExpr::Gt(a, b) => {
                let va = self.evaluate(a, inputs)?;
                let vb = self.evaluate(b, inputs)?;
                Some(if va > vb { 1 } else { 0 })
            },
            DSLExpr::If(c, t, e) => {
                let vc = self.evaluate(c, inputs)?;
                if vc != 0 {
                    self.evaluate(t, inputs)
                } else {
                    self.evaluate(e, inputs)
                }
            },
            _ => None,
        }
    }
}

/// Neural-guided program synthesis
pub struct NeuralGuidedSynthesis {
    value_network: Vec<f64>,
    policy_network: Vec<f64>,
    beam_width: usize,
}

impl NeuralGuidedSynthesis {
    pub fn new(hidden_dim: usize, beam_width: usize) -> Self {
        Self {
            value_network: vec![0.0; hidden_dim * hidden_dim],
            policy_network: vec![0.0; hidden_dim * 20], // 20 possible actions
            beam_width,
        }
    }

    /// Beam search with neural guidance
    pub fn synthesize(&self, spec: &[IOExample], max_depth: usize) -> Option<DSLExpr> {
        let mut beam: Vec<(DSLExpr, f64)> = vec![(DSLExpr::Const(0), 0.0)];

        for _depth in 0..max_depth {
            let mut candidates: Vec<(DSLExpr, f64)> = Vec::new();

            for (prog, score) in &beam {
                let expansions = self.expand(prog);
                for exp in expansions {
                    let new_score = score + self.score_expansion(&exp, spec);
                    candidates.push((exp, new_score));
                }
            }

            candidates.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
            beam = candidates.into_iter().take(self.beam_width).collect();

            // Check for solution
            for (prog, _) in &beam {
                if self.satisfies_spec(prog, spec) {
                    return Some(prog.clone());
                }
            }
        }

        None
    }

    fn expand(&self, _prog: &DSLExpr) -> Vec<DSLExpr> {
        // Return possible next programs
        Vec::new()
    }

    fn score_expansion(&self, _prog: &DSLExpr, _spec: &[IOExample]) -> f64 {
        // Neural network scoring
        0.0
    }

    fn satisfies_spec(&self, _prog: &DSLExpr, _spec: &[IOExample]) -> bool {
        false
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GENETIC PROGRAMMING OPERATORS
// ═══════════════════════════════════════════════════════════════════════════════

/// Advanced crossover operators for genetic programming
pub struct GeneticOperators {
    rng: Random,
}

impl GeneticOperators {
    pub fn new(seed: u64) -> Self {
        Self { rng: Random::from_seed(Seed::from_u64(seed)) }
    }

    /// Standard subtree crossover
    pub fn subtree_crossover(&mut self, p1: &ASTNode, p2: &ASTNode) -> ASTNode {
        let point1 = self.random_subtree_index(p1);
        let point2 = self.random_subtree_index(p2);

        let subtree2 = self.get_subtree(p2, point2);
        self.replace_subtree(p1, point1, &subtree2)
    }

    /// Semantic-aware crossover (preserves semantic similarity)
    pub fn semantic_crossover(&mut self, p1: &ASTNode, p2: &ASTNode, test_points: &[HashMap<String, f64>]) -> ASTNode {
        let subtrees1 = self.all_subtrees(p1);
        let subtrees2 = self.all_subtrees(p2);

        let mut best_match: Option<(usize, usize, f64)> = None;

        for (i, s1) in subtrees1.iter().enumerate() {
            let sem1 = self.semantic_signature(s1, test_points);

            for (j, s2) in subtrees2.iter().enumerate() {
                let sem2 = self.semantic_signature(s2, test_points);

                let dist: f64 = sem1.iter().zip(sem2.iter())
                    .map(|(a, b)| (a - b).abs())
                    .sum();

                match &best_match {
                    None => best_match = Some((i, j, dist)),
                    Some((_, _, d)) if dist < *d => best_match = Some((i, j, dist)),
                    _ => {}
                }
            }
        }

        if let Some((idx1, idx2, _)) = best_match {
            self.replace_subtree(p1, idx1, &subtrees2[idx2])
        } else {
            p1.clone()
        }
    }

    /// Geometric semantic crossover
    pub fn geometric_crossover(&mut self, p1: &ASTNode, p2: &ASTNode) -> ASTNode {
        let t = ASTNode::Literal(self.rng.next_f64());

        // child = p1 * t + p2 * (1 - t)
        ASTNode::Add(
            Box::new(ASTNode::Mul(Box::new(p1.clone()), Box::new(t.clone()))),
            Box::new(ASTNode::Mul(
                Box::new(p2.clone()),
                Box::new(ASTNode::Sub(Box::new(ASTNode::Literal(1.0)), Box::new(t))),
            )),
        )
    }

    fn semantic_signature(&self, node: &ASTNode, test_points: &[HashMap<String, f64>]) -> Vec<f64> {
        test_points.iter()
            .map(|env| {
                let prog = Program::new(node.clone());
                prog.evaluate(env).unwrap_or(0.0)
            })
            .collect()
    }

    fn random_subtree_index(&mut self, node: &ASTNode) -> usize {
        let size = node.size();
        self.rng.next_u64() as usize % size
    }

    fn get_subtree(&self, node: &ASTNode, _idx: usize) -> ASTNode {
        // Returns subtree at index
        node.clone()
    }

    fn replace_subtree(&self, node: &ASTNode, _idx: usize, replacement: &ASTNode) -> ASTNode {
        // Replace subtree at index
        replacement.clone()
    }

    fn all_subtrees(&self, node: &ASTNode) -> Vec<ASTNode> {
        let mut result = vec![node.clone()];

        match node {
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) => {
                result.extend(self.all_subtrees(a));
                result.extend(self.all_subtrees(b));
            },
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) => {
                result.extend(self.all_subtrees(a));
            },
            ASTNode::If(c, t, e) => {
                result.extend(self.all_subtrees(c));
                result.extend(self.all_subtrees(t));
                result.extend(self.all_subtrees(e));
            },
            _ => {}
        }

        result
    }

    /// Point mutation
    pub fn point_mutation(&mut self, node: &ASTNode, rate: f64) -> ASTNode {
        if self.rng.next_f64() < rate {
            match node {
                ASTNode::Literal(v) => ASTNode::Literal(v + self.rng.next_f64() * 0.1 - 0.05),
                ASTNode::Add(a, b) => {
                    let ops = [
                        ASTNode::Sub(a.clone(), b.clone()),
                        ASTNode::Mul(a.clone(), b.clone()),
                    ];
                    ops[self.rng.next_u64() as usize % ops.len()].clone()
                },
                _ => node.clone(),
            }
        } else {
            match node {
                ASTNode::Add(a, b) => ASTNode::Add(
                    Box::new(self.point_mutation(a, rate)),
                    Box::new(self.point_mutation(b, rate)),
                ),
                ASTNode::Sub(a, b) => ASTNode::Sub(
                    Box::new(self.point_mutation(a, rate)),
                    Box::new(self.point_mutation(b, rate)),
                ),
                ASTNode::Mul(a, b) => ASTNode::Mul(
                    Box::new(self.point_mutation(a, rate)),
                    Box::new(self.point_mutation(b, rate)),
                ),
                _ => node.clone(),
            }
        }
    }

    /// Subtree mutation
    pub fn subtree_mutation(&mut self, node: &ASTNode, max_depth: usize) -> ASTNode {
        let idx = self.random_subtree_index(node);
        let new_subtree = self.random_tree(max_depth);
        self.replace_subtree(node, idx, &new_subtree)
    }

    fn random_tree(&mut self, depth: usize) -> ASTNode {
        if depth == 0 || self.rng.next_f64() < 0.3 {
            if self.rng.next_f64() < 0.5 {
                ASTNode::Literal(self.rng.next_f64() * 10.0 - 5.0)
            } else {
                ASTNode::Variable("x".to_string())
            }
        } else {
            let op = self.rng.next_u64() % 4;
            match op {
                0 => ASTNode::Add(
                    Box::new(self.random_tree(depth - 1)),
                    Box::new(self.random_tree(depth - 1)),
                ),
                1 => ASTNode::Sub(
                    Box::new(self.random_tree(depth - 1)),
                    Box::new(self.random_tree(depth - 1)),
                ),
                2 => ASTNode::Mul(
                    Box::new(self.random_tree(depth - 1)),
                    Box::new(self.random_tree(depth - 1)),
                ),
                _ => ASTNode::Sin(Box::new(self.random_tree(depth - 1))),
            }
        }
    }
}

/// Fitness landscape analysis
pub struct FitnessLandscapeAnalyzer {
    samples: Vec<(ASTNode, f64)>,
}

impl FitnessLandscapeAnalyzer {
    pub fn new() -> Self {
        Self { samples: Vec::new() }
    }

    pub fn add_sample(&mut self, program: ASTNode, fitness: f64) {
        self.samples.push((program, fitness));
    }

    /// Compute fitness distance correlation
    pub fn fitness_distance_correlation(&self) -> f64 {
        if self.samples.len() < 2 {
            return 0.0;
        }

        let best_idx = self.samples.iter()
            .enumerate()
            .max_by(|(_, a), (_, b)| a.1.partial_cmp(&b.1).unwrap())
            .unwrap().0;

        let best = &self.samples[best_idx];

        let distances: Vec<f64> = self.samples.iter()
            .map(|(p, _)| self.tree_edit_distance(&p, &best.0) as f64)
            .collect();

        let fitnesses: Vec<f64> = self.samples.iter()
            .map(|(_, f)| *f)
            .collect();

        self.correlation(&distances, &fitnesses)
    }

    fn tree_edit_distance(&self, t1: &ASTNode, t2: &ASTNode) -> usize {
        // Simplified tree edit distance
        match (t1, t2) {
            (ASTNode::Literal(a), ASTNode::Literal(b)) => if (a - b).abs() < 0.001 { 0 } else { 1 },
            (ASTNode::Variable(a), ASTNode::Variable(b)) => if a == b { 0 } else { 1 },
            (ASTNode::Add(a1, b1), ASTNode::Add(a2, b2)) => {
                self.tree_edit_distance(a1, a2) + self.tree_edit_distance(b1, b2)
            },
            _ => 1 + t1.size().abs_diff(t2.size()),
        }
    }

    fn correlation(&self, x: &[f64], y: &[f64]) -> f64 {
        let n = x.len() as f64;
        let mean_x: f64 = x.iter().sum::<f64>() / n;
        let mean_y: f64 = y.iter().sum::<f64>() / n;

        let cov: f64 = x.iter().zip(y.iter())
            .map(|(xi, yi)| (xi - mean_x) * (yi - mean_y))
            .sum::<f64>() / n;

        let std_x = (x.iter().map(|xi| (xi - mean_x).powi(2)).sum::<f64>() / n).sqrt();
        let std_y = (y.iter().map(|yi| (yi - mean_y).powi(2)).sum::<f64>() / n).sqrt();

        if std_x * std_y == 0.0 { 0.0 } else { cov / (std_x * std_y) }
    }

    /// Neutrality analysis
    pub fn neutrality_ratio(&self, epsilon: f64) -> f64 {
        let mut neutral_pairs = 0;
        let mut total_pairs = 0;

        for i in 0..self.samples.len() {
            for j in i+1..self.samples.len() {
                if self.tree_edit_distance(&self.samples[i].0, &self.samples[j].0) == 1 {
                    total_pairs += 1;
                    if (self.samples[i].1 - self.samples[j].1).abs() < epsilon {
                        neutral_pairs += 1;
                    }
                }
            }
        }

        if total_pairs == 0 { 0.0 } else { neutral_pairs as f64 / total_pairs as f64 }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// KNOWLEDGE GRAPH SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Entity in knowledge graph
pub struct KGEntity {
    id: EntityId,
    entity_type: String,
    properties: HashMap<String, PropertyValue>,
    embeddings: Option<Vector<f32>>,
    created_at: Timestamp,
    confidence: f32,
}

/// Property value types
pub enum PropertyValue {
    String(String),
    Number(f64),
    Boolean(bool),
    DateTime(Timestamp),
    Entity(EntityId),
    List(Vec<PropertyValue>),
}

/// Relation between entities
pub struct KGRelation {
    id: RelationId,
    relation_type: String,
    source: EntityId,
    target: EntityId,
    properties: HashMap<String, PropertyValue>,
    weight: f32,
    bidirectional: bool,
    valid_from: Option<Timestamp>,
    valid_until: Option<Timestamp>,
}

/// Knowledge Graph with reasoning capabilities
pub struct KnowledgeGraph {
    entities: HashMap<EntityId, KGEntity>,
    relations: Vec<KGRelation>,
    type_hierarchy: HashMap<String, Vec<String>>,
    relation_schemas: HashMap<String, RelationSchema>,
    indexes: KGIndexes,
    inference_rules: Vec<InferenceRule>,
}

struct KGIndexes {
    by_type: HashMap<String, HashSet<EntityId>>,
    by_relation_source: HashMap<EntityId, Vec<usize>>,
    by_relation_target: HashMap<EntityId, Vec<usize>>,
    by_property: HashMap<(String, String), HashSet<EntityId>>,
}

pub struct RelationSchema {
    source_types: Vec<String>,
    target_types: Vec<String>,
    required_properties: Vec<String>,
    cardinality: Cardinality,
}

pub enum Cardinality { OneToOne, OneToMany, ManyToOne, ManyToMany }

impl KnowledgeGraph {
    pub fn new() -> Self {
        Self {
            entities: HashMap::new(),
            relations: Vec::new(),
            type_hierarchy: HashMap::new(),
            relation_schemas: HashMap::new(),
            indexes: KGIndexes {
                by_type: HashMap::new(),
                by_relation_source: HashMap::new(),
                by_relation_target: HashMap::new(),
                by_property: HashMap::new(),
            },
            inference_rules: Vec::new(),
        }
    }

    pub fn add_entity(&mut self, entity: KGEntity) -> EntityId {
        let id = entity.id;
        self.indexes.by_type.entry(entity.entity_type.clone())
            .or_default().insert(id);
        for (key, val) in &entity.properties {
            if let PropertyValue::String(s) = val {
                self.indexes.by_property.entry((key.clone(), s.clone()))
                    .or_default().insert(id);
            }
        }
        self.entities.insert(id, entity);
        id
    }

    pub fn add_relation(&mut self, relation: KGRelation) {
        let idx = self.relations.len();
        self.indexes.by_relation_source.entry(relation.source)
            .or_default().push(idx);
        self.indexes.by_relation_target.entry(relation.target)
            .or_default().push(idx);
        self.relations.push(relation);
    }

    pub fn query_neighbors(&self, entity: EntityId, relation_type: Option<&str>, depth: usize) -> Vec<EntityId> {
        let mut visited = HashSet::new();
        let mut frontier = vec![entity];
        visited.insert(entity);

        for _ in 0..depth {
            let mut next_frontier = Vec::new();
            for eid in &frontier {
                if let Some(rel_indices) = self.indexes.by_relation_source.get(eid) {
                    for &idx in rel_indices {
                        let rel = &self.relations[idx];
                        if relation_type.is_none() || rel.relation_type == relation_type.unwrap() {
                            if !visited.contains(&rel.target) {
                                visited.insert(rel.target);
                                next_frontier.push(rel.target);
                            }
                        }
                    }
                }
            }
            frontier = next_frontier;
        }

        visited.into_iter().filter(|e| *e != entity).collect()
    }

    pub fn shortest_path(&self, source: EntityId, target: EntityId) -> Option<Vec<EntityId>> {
        let mut visited = HashMap::new();
        let mut queue = VecDeque::new();
        queue.push_back((source, vec![source]));
        visited.insert(source, true);

        while let Some((current, path)) = queue.pop_front() {
            if current == target { return Some(path); }

            if let Some(rel_indices) = self.indexes.by_relation_source.get(&current) {
                for &idx in rel_indices {
                    let next = self.relations[idx].target;
                    if !visited.contains_key(&next) {
                        visited.insert(next, true);
                        let mut new_path = path.clone();
                        new_path.push(next);
                        queue.push_back((next, new_path));
                    }
                }
            }
        }
        None
    }

    pub fn subgraph(&self, entities: &[EntityId]) -> KnowledgeGraph {
        let entity_set: HashSet<_> = entities.iter().copied().collect();
        let mut sub = KnowledgeGraph::new();

        for eid in entities {
            if let Some(entity) = self.entities.get(eid) {
                sub.add_entity(entity.clone());
            }
        }

        for rel in &self.relations {
            if entity_set.contains(&rel.source) && entity_set.contains(&rel.target) {
                sub.add_relation(rel.clone());
            }
        }
        sub
    }
}

/// Inference rule for knowledge graph reasoning
pub struct InferenceRule {
    name: String,
    antecedent: Vec<RulePattern>,
    consequent: RulePattern,
    confidence: f32,
}

pub struct RulePattern {
    subject: PatternVar,
    predicate: String,
    object: PatternVar,
}

pub enum PatternVar { Variable(String), Constant(EntityId) }

/// Knowledge Graph Embeddings
pub struct KGEmbeddings {
    entity_embeddings: HashMap<EntityId, Vector<f32>>,
    relation_embeddings: HashMap<String, Vector<f32>>,
    dim: usize,
    model_type: EmbeddingModel,
}

pub enum EmbeddingModel { TransE, RotatE, ComplEx, DistMult }

impl KGEmbeddings {
    pub fn new(dim: usize, model_type: EmbeddingModel) -> Self {
        Self { entity_embeddings: HashMap::new(), relation_embeddings: HashMap::new(), dim, model_type }
    }

    pub fn train(&mut self, graph: &KnowledgeGraph, epochs: usize, lr: f32) {
        // Initialize embeddings randomly
        for eid in graph.entities.keys() {
            self.entity_embeddings.insert(*eid, self.random_vector());
        }
        for rel in &graph.relations {
            self.relation_embeddings.entry(rel.relation_type.clone())
                .or_insert_with(|| self.random_vector());
        }

        for _ in 0..epochs {
            for rel in &graph.relations {
                let h = self.entity_embeddings.get(&rel.source).unwrap().clone();
                let r = self.relation_embeddings.get(&rel.relation_type).unwrap().clone();
                let t = self.entity_embeddings.get(&rel.target).unwrap().clone();

                let score = self.score_triple(&h, &r, &t);
                let neg_score = self.score_negative(graph, rel);
                let margin_loss = (1.0 - score + neg_score).max(0.0);

                if margin_loss > 0.0 {
                    self.update_embeddings(rel, lr);
                }
            }
        }
    }

    fn random_vector(&self) -> Vector<f32> {
        let mut v = vec![0.0f32; self.dim];
        for x in &mut v { *x = rand::random::<f32>() * 2.0 - 1.0; }
        Vector::from(v)
    }

    fn score_triple(&self, h: &Vector<f32>, r: &Vector<f32>, t: &Vector<f32>) -> f32 {
        match self.model_type {
            EmbeddingModel::TransE => {
                let diff = h.add(r).sub(t);
                1.0 / (1.0 + diff.l2_norm())
            },
            EmbeddingModel::DistMult => h.hadamard(r).dot(t),
            _ => h.add(r).sub(t).l2_norm().recip(),
        }
    }

    fn score_negative(&self, graph: &KnowledgeGraph, rel: &KGRelation) -> f32 {
        let entities: Vec<_> = graph.entities.keys().collect();
        let random_entity = entities[rand::random::<usize>() % entities.len()];
        let h = self.entity_embeddings.get(&rel.source).unwrap();
        let r = self.relation_embeddings.get(&rel.relation_type).unwrap();
        let t = self.entity_embeddings.get(random_entity).unwrap();
        self.score_triple(h, r, t)
    }

    fn update_embeddings(&mut self, rel: &KGRelation, lr: f32) {
        if let Some(h) = self.entity_embeddings.get_mut(&rel.source) {
            for x in h.iter_mut() { *x -= lr * 0.1; }
        }
    }

    pub fn predict_link(&self, source: EntityId, relation: &str, top_k: usize) -> Vec<(EntityId, f32)> {
        let h = match self.entity_embeddings.get(&source) {
            Some(v) => v, None => return Vec::new()
        };
        let r = match self.relation_embeddings.get(relation) {
            Some(v) => v, None => return Vec::new()
        };

        let mut scores: Vec<_> = self.entity_embeddings.iter()
            .map(|(eid, t)| (*eid, self.score_triple(h, r, t)))
            .collect();
        scores.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
        scores.truncate(top_k);
        scores
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYMBOLIC REASONING ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Logical term
pub enum Term {
    Variable(String),
    Constant(String),
    Compound(String, Vec<Term>),
}

/// Logical clause
pub struct Clause {
    head: Term,
    body: Vec<Term>,
}

/// Substitution mapping variables to terms
pub type Substitution = HashMap<String, Term>;

/// Prolog-style logic engine
pub struct LogicEngine {
    clauses: Vec<Clause>,
    builtins: HashMap<String, Box<dyn Fn(&[Term]) -> Option<Substitution>>>,
}

impl LogicEngine {
    pub fn new() -> Self {
        let mut engine = Self { clauses: Vec::new(), builtins: HashMap::new() };
        engine.register_builtins();
        engine
    }

    fn register_builtins(&mut self) {
        self.builtins.insert("=".into(), Box::new(|args| {
            if args.len() == 2 { Self::unify(&args[0], &args[1], HashMap::new()) }
            else { None }
        }));
    }

    pub fn assert(&mut self, clause: Clause) { self.clauses.push(clause); }

    pub fn query(&self, goal: &Term) -> Vec<Substitution> {
        self.solve(&[goal.clone()], HashMap::new())
    }

    fn solve(&self, goals: &[Term], subst: Substitution) -> Vec<Substitution> {
        if goals.is_empty() { return vec![subst]; }

        let goal = self.apply_subst(&goals[0], &subst);
        let remaining = &goals[1..];
        let mut results = Vec::new();

        if let Term::Compound(name, _) = &goal {
            if let Some(builtin) = self.builtins.get(name) {
                if let Some(new_subst) = builtin(&Self::term_args(&goal)) {
                    let merged = Self::compose_subst(&subst, &new_subst);
                    results.extend(self.solve(remaining, merged));
                }
                return results;
            }
        }

        for clause in &self.clauses {
            let renamed = self.rename_variables(clause);
            if let Some(mgu) = Self::unify(&goal, &renamed.head, HashMap::new()) {
                let new_subst = Self::compose_subst(&subst, &mgu);
                let new_goals: Vec<_> = renamed.body.iter()
                    .chain(remaining.iter())
                    .cloned()
                    .collect();
                results.extend(self.solve(&new_goals, new_subst));
            }
        }
        results
    }

    fn unify(t1: &Term, t2: &Term, mut subst: Substitution) -> Option<Substitution> {
        match (t1, t2) {
            (Term::Variable(v), t) | (t, Term::Variable(v)) => {
                if let Some(binding) = subst.get(v) {
                    Self::unify(binding, t, subst)
                } else {
                    subst.insert(v.clone(), t.clone());
                    Some(subst)
                }
            },
            (Term::Constant(c1), Term::Constant(c2)) if c1 == c2 => Some(subst),
            (Term::Compound(f1, args1), Term::Compound(f2, args2))
                if f1 == f2 && args1.len() == args2.len() => {
                for (a1, a2) in args1.iter().zip(args2.iter()) {
                    subst = Self::unify(a1, a2, subst)?;
                }
                Some(subst)
            },
            _ => None,
        }
    }

    fn apply_subst(&self, term: &Term, subst: &Substitution) -> Term {
        match term {
            Term::Variable(v) => subst.get(v).cloned().unwrap_or_else(|| term.clone()),
            Term::Compound(f, args) => Term::Compound(
                f.clone(),
                args.iter().map(|a| self.apply_subst(a, subst)).collect()
            ),
            _ => term.clone(),
        }
    }

    fn compose_subst(s1: &Substitution, s2: &Substitution) -> Substitution {
        let mut result = s1.clone();
        for (k, v) in s2 { result.insert(k.clone(), v.clone()); }
        result
    }

    fn rename_variables(&self, clause: &Clause) -> Clause {
        let suffix = rand::random::<u32>();
        Clause {
            head: self.rename_term(&clause.head, suffix),
            body: clause.body.iter().map(|t| self.rename_term(t, suffix)).collect(),
        }
    }

    fn rename_term(&self, term: &Term, suffix: u32) -> Term {
        match term {
            Term::Variable(v) => Term::Variable(format!("{}_{}", v, suffix)),
            Term::Compound(f, args) => Term::Compound(
                f.clone(), args.iter().map(|a| self.rename_term(a, suffix)).collect()
            ),
            _ => term.clone(),
        }
    }

    fn term_args(term: &Term) -> Vec<Term> {
        match term { Term::Compound(_, args) => args.clone(), _ => vec![] }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONSTRAINT SATISFACTION SOLVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Constraint satisfaction problem
pub struct CSP<T: Clone + Eq + Hash> {
    variables: Vec<String>,
    domains: HashMap<String, Vec<T>>,
    constraints: Vec<Box<dyn Fn(&HashMap<String, T>) -> bool>>,
    arc_constraints: Vec<(String, String, Box<dyn Fn(&T, &T) -> bool>)>,
}

impl<T: Clone + Eq + Hash + 'static> CSP<T> {
    pub fn new() -> Self {
        Self { variables: Vec::new(), domains: HashMap::new(), constraints: Vec::new(), arc_constraints: Vec::new() }
    }

    pub fn add_variable(&mut self, name: &str, domain: Vec<T>) {
        self.variables.push(name.to_string());
        self.domains.insert(name.to_string(), domain);
    }

    pub fn add_constraint<F: Fn(&HashMap<String, T>) -> bool + 'static>(&mut self, f: F) {
        self.constraints.push(Box::new(f));
    }

    pub fn add_binary_constraint<F: Fn(&T, &T) -> bool + 'static>(&mut self, v1: &str, v2: &str, f: F) {
        self.arc_constraints.push((v1.to_string(), v2.to_string(), Box::new(f)));
    }

    pub fn solve_backtrack(&self) -> Option<HashMap<String, T>> {
        self.backtrack(HashMap::new(), 0)
    }

    fn backtrack(&self, assignment: HashMap<String, T>, idx: usize) -> Option<HashMap<String, T>> {
        if idx == self.variables.len() { return Some(assignment); }

        let var = &self.variables[idx];
        let domain = self.domains.get(var)?;

        for value in domain {
            let mut new_assign = assignment.clone();
            new_assign.insert(var.clone(), value.clone());

            if self.is_consistent(&new_assign) {
                if let Some(result) = self.backtrack(new_assign, idx + 1) {
                    return Some(result);
                }
            }
        }
        None
    }

    fn is_consistent(&self, assignment: &HashMap<String, T>) -> bool {
        for constraint in &self.constraints {
            if !constraint(assignment) { return false; }
        }
        for (v1, v2, constraint) in &self.arc_constraints {
            if let (Some(val1), Some(val2)) = (assignment.get(v1), assignment.get(v2)) {
                if !constraint(val1, val2) { return false; }
            }
        }
        true
    }

    pub fn ac3(&mut self) -> bool {
        let mut queue: VecDeque<(String, String)> = self.arc_constraints.iter()
            .flat_map(|(v1, v2, _)| vec![(v1.clone(), v2.clone()), (v2.clone(), v1.clone())])
            .collect();

        while let Some((xi, xj)) = queue.pop_front() {
            if self.revise(&xi, &xj) {
                if self.domains.get(&xi).map(|d| d.is_empty()).unwrap_or(true) {
                    return false;
                }
                for (v1, v2, _) in &self.arc_constraints {
                    if v2 == &xi && v1 != &xj {
                        queue.push_back((v1.clone(), xi.clone()));
                    }
                }
            }
        }
        true
    }

    fn revise(&mut self, xi: &str, xj: &str) -> bool {
        let mut revised = false;
        let constraint = self.arc_constraints.iter()
            .find(|(v1, v2, _)| (v1 == xi && v2 == xj) || (v1 == xj && v2 == xi));

        if let Some((_, _, check)) = constraint {
            let xj_domain = self.domains.get(xj).cloned().unwrap_or_default();
            if let Some(xi_domain) = self.domains.get_mut(xi) {
                xi_domain.retain(|vi| {
                    let consistent = xj_domain.iter().any(|vj| check(vi, vj));
                    if !consistent { revised = true; }
                    consistent
                });
            }
        }
        revised
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI PLANNING SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// State representation for planning
pub type PlanState = HashSet<String>;

/// Planning action with preconditions and effects
pub struct PlanAction {
    name: String,
    parameters: Vec<String>,
    preconditions: PlanState,
    add_effects: PlanState,
    delete_effects: PlanState,
    cost: f32,
}

impl PlanAction {
    pub fn applicable(&self, state: &PlanState) -> bool {
        self.preconditions.is_subset(state)
    }

    pub fn apply(&self, state: &PlanState) -> PlanState {
        let mut new_state = state.difference(&self.delete_effects).cloned().collect::<PlanState>();
        new_state.extend(self.add_effects.iter().cloned());
        new_state
    }
}

/// STRIPS-style planner with A* search
pub struct Planner {
    actions: Vec<PlanAction>,
    heuristic: HeuristicType,
}

pub enum HeuristicType { GoalCount, MaxHeuristic, AddHeuristic }

impl Planner {
    pub fn new(heuristic: HeuristicType) -> Self {
        Self { actions: Vec::new(), heuristic }
    }

    pub fn add_action(&mut self, action: PlanAction) { self.actions.push(action); }

    pub fn plan(&self, initial: &PlanState, goal: &PlanState) -> Option<Vec<String>> {
        let mut open = BinaryHeap::new();
        let mut visited = HashSet::new();

        open.push(PlanNode {
            state: initial.clone(),
            plan: Vec::new(),
            g_cost: 0.0,
            f_cost: self.heuristic(initial, goal),
        });

        while let Some(current) = open.pop() {
            if goal.is_subset(&current.state) { return Some(current.plan); }

            let state_key = self.state_hash(&current.state);
            if visited.contains(&state_key) { continue; }
            visited.insert(state_key);

            for action in &self.actions {
                if action.applicable(&current.state) {
                    let new_state = action.apply(&current.state);
                    let new_g = current.g_cost + action.cost;
                    let new_h = self.heuristic(&new_state, goal);
                    let mut new_plan = current.plan.clone();
                    new_plan.push(action.name.clone());

                    open.push(PlanNode {
                        state: new_state,
                        plan: new_plan,
                        g_cost: new_g,
                        f_cost: new_g + new_h,
                    });
                }
            }
        }
        None
    }

    fn heuristic(&self, state: &PlanState, goal: &PlanState) -> f32 {
        match self.heuristic {
            HeuristicType::GoalCount => goal.difference(state).count() as f32,
            HeuristicType::MaxHeuristic => {
                goal.difference(state).map(|g| {
                    self.actions.iter()
                        .filter(|a| a.add_effects.contains(g))
                        .map(|a| a.cost)
                        .min_by(|a, b| a.partial_cmp(b).unwrap())
                        .unwrap_or(f32::INFINITY)
                }).fold(0.0f32, |a, b| a.max(b))
            },
            HeuristicType::AddHeuristic => {
                goal.difference(state).map(|g| {
                    self.actions.iter()
                        .filter(|a| a.add_effects.contains(g))
                        .map(|a| a.cost)
                        .min_by(|a, b| a.partial_cmp(b).unwrap())
                        .unwrap_or(f32::INFINITY)
                }).sum()
            },
        }
    }

    fn state_hash(&self, state: &PlanState) -> u64 {
        let mut sorted: Vec<_> = state.iter().collect();
        sorted.sort();
        let mut hasher = std::collections::hash_map::DefaultHasher::new();
        for s in sorted { s.hash(&mut hasher); }
        std::hash::Hasher::finish(&hasher)
    }
}

#[derive(Clone)]
struct PlanNode {
    state: PlanState,
    plan: Vec<String>,
    g_cost: f32,
    f_cost: f32,
}

impl Ord for PlanNode {
    fn cmp(&self, other: &Self) -> std::cmp::Ordering {
        other.f_cost.partial_cmp(&self.f_cost).unwrap_or(std::cmp::Ordering::Equal)
    }
}
impl PartialOrd for PlanNode { fn partial_cmp(&self, other: &Self) -> Option<std::cmp::Ordering> { Some(self.cmp(other)) } }
impl PartialEq for PlanNode { fn eq(&self, other: &Self) -> bool { self.f_cost == other.f_cost } }
impl Eq for PlanNode {}

