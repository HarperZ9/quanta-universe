// META-LEARNING SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Task for meta-learning
pub struct MetaTask {
    id: TaskId,
    support_set: Vec<(Vector<f32>, Vector<f32>)>,
    query_set: Vec<(Vector<f32>, Vector<f32>)>,
    task_embedding: Option<Vector<f32>>,
}

/// MAML-style meta-learner
pub struct MetaLearner {
    base_model: NeuralNetwork,
    meta_lr: f32,
    inner_lr: f32,
    inner_steps: usize,
    task_embeddings: HashMap<TaskId, Vector<f32>>,
}

impl MetaLearner {
    pub fn new(base_model: NeuralNetwork, meta_lr: f32, inner_lr: f32, inner_steps: usize) -> Self {
        Self { base_model, meta_lr, inner_lr, inner_steps, task_embeddings: HashMap::new() }
    }

    pub fn meta_train(&mut self, tasks: &[MetaTask], meta_epochs: usize) {
        for _ in 0..meta_epochs {
            let mut meta_gradients = self.base_model.zero_gradients();

            for task in tasks {
                let adapted_params = self.inner_loop(task);
                let query_loss = self.compute_loss(&adapted_params, &task.query_set);
                let task_grad = self.compute_meta_gradient(&adapted_params, query_loss);
                self.accumulate_gradients(&mut meta_gradients, &task_grad);
            }

            self.base_model.apply_gradients(&meta_gradients, self.meta_lr / tasks.len() as f32);
        }
    }

    fn inner_loop(&self, task: &MetaTask) -> Vec<Tensor> {
        let mut params = self.base_model.parameters().clone();

        for _ in 0..self.inner_steps {
            let loss = self.compute_loss(&params, &task.support_set);
            let gradients = self.compute_gradients(&params, loss);
            for (p, g) in params.iter_mut().zip(gradients.iter()) {
                *p = p.sub(&g.mul_scalar(self.inner_lr));
            }
        }
        params
    }

    fn compute_loss(&self, params: &[Tensor], data: &[(Vector<f32>, Vector<f32>)]) -> f32 {
        data.iter().map(|(x, y)| {
            let pred = self.forward_with_params(x, params);
            pred.sub(y).l2_norm().powi(2)
        }).sum::<f32>() / data.len() as f32
    }

    fn forward_with_params(&self, input: &Vector<f32>, _params: &[Tensor]) -> Vector<f32> {
        input.clone() // Placeholder
    }

    fn compute_gradients(&self, _params: &[Tensor], _loss: f32) -> Vec<Tensor> {
        vec![] // Placeholder
    }

    fn compute_meta_gradient(&self, _params: &[Tensor], _loss: f32) -> Vec<Tensor> {
        vec![] // Placeholder
    }

    fn accumulate_gradients(&self, acc: &mut Vec<Tensor>, grad: &[Tensor]) {
        for (a, g) in acc.iter_mut().zip(grad.iter()) {
            *a = a.add(g);
        }
    }

    pub fn adapt(&mut self, task: &MetaTask) -> Vec<Tensor> {
        self.inner_loop(task)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPLAINABLE AI (XAI) MODULE
// ═══════════════════════════════════════════════════════════════════════════════

/// Feature attribution methods
pub struct FeatureAttribution {
    method: AttributionMethod,
    baseline: Option<Vector<f32>>,
    num_samples: usize,
}

pub enum AttributionMethod { IntegratedGradients, SHAP, LIME, DeepLIFT, GradCAM }

impl FeatureAttribution {
    pub fn integrated_gradients(steps: usize) -> Self {
        Self { method: AttributionMethod::IntegratedGradients, baseline: None, num_samples: steps }
    }

    pub fn shap(samples: usize) -> Self {
        Self { method: AttributionMethod::SHAP, baseline: None, num_samples: samples }
    }

    pub fn explain<F: Fn(&Vector<f32>) -> f32>(&self, model: F, input: &Vector<f32>) -> Vector<f32> {
        match self.method {
            AttributionMethod::IntegratedGradients => self.ig_explain(&model, input),
            AttributionMethod::SHAP => self.shap_explain(&model, input),
            AttributionMethod::LIME => self.lime_explain(&model, input),
            _ => input.clone(),
        }
    }

    fn ig_explain<F: Fn(&Vector<f32>) -> f32>(&self, model: &F, input: &Vector<f32>) -> Vector<f32> {
        let baseline = self.baseline.clone().unwrap_or_else(|| Vector::zeros(input.len()));
        let diff = input.sub(&baseline);
        let mut attributions = Vector::zeros(input.len());

        for step in 0..self.num_samples {
            let alpha = step as f32 / self.num_samples as f32;
            let interpolated = baseline.add(&diff.mul_scalar(alpha));
            let grad = self.numerical_gradient(model, &interpolated);
            attributions = attributions.add(&grad);
        }

        attributions.mul_scalar(1.0 / self.num_samples as f32).hadamard(&diff)
    }

    fn shap_explain<F: Fn(&Vector<f32>) -> f32>(&self, model: &F, input: &Vector<f32>) -> Vector<f32> {
        let n = input.len();
        let mut attributions = vec![0.0f32; n];

        for _ in 0..self.num_samples {
            let perm: Vec<usize> = (0..n).collect();
            let mut current = self.baseline.clone().unwrap_or_else(|| Vector::zeros(n));
            let mut prev_val = model(&current);

            for &i in &perm {
                current.set(i, input.get(i));
                let new_val = model(&current);
                attributions[i] += new_val - prev_val;
                prev_val = new_val;
            }
        }

        Vector::from(attributions.iter().map(|a| a / self.num_samples as f32).collect::<Vec<_>>())
    }

    fn lime_explain<F: Fn(&Vector<f32>) -> f32>(&self, model: &F, input: &Vector<f32>) -> Vector<f32> {
        let n = input.len();
        let mut samples = Vec::new();
        let mut weights = Vec::new();
        let mut outputs = Vec::new();

        for _ in 0..self.num_samples {
            let mut perturbed = input.clone();
            let mask: Vec<bool> = (0..n).map(|_| rand::random()).collect();
            for (i, &m) in mask.iter().enumerate() {
                if !m { perturbed.set(i, 0.0); }
            }
            let dist = input.sub(&perturbed).l2_norm();
            let weight = (-dist * dist / 0.25).exp();
            samples.push(mask);
            weights.push(weight);
            outputs.push(model(&perturbed));
        }

        self.weighted_linear_regression(&samples, &outputs, &weights, n)
    }

    fn weighted_linear_regression(&self, samples: &[Vec<bool>], outputs: &[f32], weights: &[f32], n: usize) -> Vector<f32> {
        // Simplified weighted linear regression
        let mut coeffs = vec![0.0f32; n];
        for (i, sample) in samples.iter().enumerate() {
            for (j, &active) in sample.iter().enumerate() {
                if active { coeffs[j] += weights[i] * outputs[i]; }
            }
        }
        let total_weight: f32 = weights.iter().sum();
        Vector::from(coeffs.iter().map(|c| c / total_weight).collect::<Vec<_>>())
    }

    fn numerical_gradient<F: Fn(&Vector<f32>) -> f32>(&self, model: &F, input: &Vector<f32>) -> Vector<f32> {
        let eps = 1e-5;
        let mut grad = vec![0.0f32; input.len()];
        for i in 0..input.len() {
            let mut plus = input.clone();
            let mut minus = input.clone();
            plus.set(i, plus.get(i) + eps);
            minus.set(i, minus.get(i) - eps);
            grad[i] = (model(&plus) - model(&minus)) / (2.0 * eps);
        }
        Vector::from(grad)
    }
}

/// Decision explanation
pub struct DecisionExplainer {
    feature_names: Vec<String>,
    class_names: Vec<String>,
}

impl DecisionExplainer {
    pub fn new(feature_names: Vec<String>, class_names: Vec<String>) -> Self {
        Self { feature_names, class_names }
    }

    pub fn explain_prediction(&self, attributions: &Vector<f32>, prediction: usize) -> Explanation {
        let mut contributions: Vec<_> = self.feature_names.iter()
            .zip(attributions.iter())
            .map(|(name, &attr)| (name.clone(), attr))
            .collect();
        contributions.sort_by(|a, b| b.1.abs().partial_cmp(&a.1.abs()).unwrap());

        let top_positive: Vec<_> = contributions.iter()
            .filter(|(_, v)| *v > 0.0)
            .take(5)
            .cloned()
            .collect();
        let top_negative: Vec<_> = contributions.iter()
            .filter(|(_, v)| *v < 0.0)
            .take(5)
            .cloned()
            .collect();

        Explanation {
            prediction: self.class_names.get(prediction).cloned().unwrap_or_default(),
            supporting_features: top_positive,
            opposing_features: top_negative,
            confidence: attributions.iter().map(|x| x.abs()).sum(),
        }
    }
}

pub struct Explanation {
    prediction: String,
    supporting_features: Vec<(String, f32)>,
    opposing_features: Vec<(String, f32)>,
    confidence: f32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURO-SYMBOLIC INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Neuro-symbolic reasoner combining neural and symbolic AI
pub struct NeuroSymbolicReasoner {
    neural_encoder: NeuralNetwork,
    symbol_extractor: SymbolExtractor,
    logic_engine: LogicEngine,
    neural_decoder: NeuralNetwork,
}

pub struct SymbolExtractor {
    concept_embeddings: HashMap<String, Vector<f32>>,
    threshold: f32,
}

impl SymbolExtractor {
    pub fn extract(&self, embedding: &Vector<f32>) -> Vec<String> {
        self.concept_embeddings.iter()
            .filter(|(_, emb)| embedding.cosine_similarity(emb) > self.threshold)
            .map(|(name, _)| name.clone())
            .collect()
    }
}

impl NeuroSymbolicReasoner {
    pub fn reason(&self, input: &Vector<f32>) -> ReasoningResult {
        // Neural perception -> symbolic reasoning -> neural generation
        let encoding = self.neural_encoder.forward(input);
        let symbols = self.symbol_extractor.extract(&encoding);

        let mut inferred = Vec::new();
        for symbol in &symbols {
            let query = Term::Compound(symbol.clone(), vec![]);
            let results = self.logic_engine.query(&query);
            for result in results {
                for (var, term) in result {
                    if let Term::Constant(c) = term {
                        inferred.push(c);
                    }
                }
            }
        }

        ReasoningResult { perceived: symbols, inferred, confidence: 0.9 }
    }
}

pub struct ReasoningResult {
    perceived: Vec<String>,
    inferred: Vec<String>,
    confidence: f32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// REINFORCEMENT LEARNING
// ═══════════════════════════════════════════════════════════════════════════════

/// State-action pair
pub type StateAction = (Vec<f32>, usize);

/// Reinforcement learning environment trait
pub trait Environment {
    fn state_dim(&self) -> usize;
    fn action_dim(&self) -> usize;
    fn reset(&mut self) -> Vec<f32>;
    fn step(&mut self, action: usize) -> (Vec<f32>, f32, bool);  // (next_state, reward, done)
}

/// Q-Learning with epsilon-greedy exploration
pub struct QLearning {
    q_table: HashMap<Vec<i32>, Vec<f32>>,
    state_discretization: Vec<(f32, f32, usize)>,  // (min, max, bins) per dimension
    action_dim: usize,
    learning_rate: f32,
    discount: f32,
    epsilon: f32,
    epsilon_decay: f32,
}

impl QLearning {
    pub fn new(state_discretization: Vec<(f32, f32, usize)>, action_dim: usize) -> Self {
        Self {
            q_table: HashMap::new(),
            state_discretization,
            action_dim,
            learning_rate: 0.1,
            discount: 0.99,
            epsilon: 1.0,
            epsilon_decay: 0.995,
        }
    }

    pub fn with_params(mut self, lr: f32, discount: f32, epsilon: f32) -> Self {
        self.learning_rate = lr; self.discount = discount; self.epsilon = epsilon; self
    }

    fn discretize(&self, state: &[f32]) -> Vec<i32> {
        state.iter().zip(&self.state_discretization).map(|(&s, &(min, max, bins))| {
            let normalized = ((s - min) / (max - min)).clamp(0.0, 0.999);
            (normalized * bins as f32) as i32
        }).collect()
    }

    pub fn select_action(&self, state: &[f32]) -> usize {
        let rng = (std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_nanos() as f32 % 1e9) / 1e9;
        if rng < self.epsilon {
            (rng * self.action_dim as f32) as usize % self.action_dim
        } else {
            self.greedy_action(state)
        }
    }

    fn greedy_action(&self, state: &[f32]) -> usize {
        let key = self.discretize(state);
        let q_values = self.q_table.get(&key).cloned().unwrap_or(vec![0.0; self.action_dim]);
        q_values.iter().enumerate().max_by(|a, b| a.1.partial_cmp(b.1).unwrap()).map(|(i, _)| i).unwrap_or(0)
    }

    pub fn update(&mut self, state: &[f32], action: usize, reward: f32, next_state: &[f32], done: bool) {
        let key = self.discretize(state);
        let next_key = self.discretize(next_state);

        let next_max = if done { 0.0 } else {
            self.q_table.get(&next_key).map(|q| q.iter().cloned().fold(f32::NEG_INFINITY, f32::max)).unwrap_or(0.0)
        };

        let q_values = self.q_table.entry(key).or_insert(vec![0.0; self.action_dim]);
        let td_target = reward + self.discount * next_max;
        q_values[action] += self.learning_rate * (td_target - q_values[action]);

        self.epsilon *= self.epsilon_decay;
    }
}

/// Policy gradient (REINFORCE)
pub struct PolicyGradient {
    weights: Vec<Vec<f32>>,
    state_dim: usize,
    action_dim: usize,
    learning_rate: f32,
    episode_states: Vec<Vec<f32>>,
    episode_actions: Vec<usize>,
    episode_rewards: Vec<f32>,
}

impl PolicyGradient {
    pub fn new(state_dim: usize, action_dim: usize) -> Self {
        let weights: Vec<Vec<f32>> = (0..action_dim).map(|_| {
            (0..state_dim).map(|_| Self::rand_normal() * 0.01).collect()
        }).collect();
        Self { weights, state_dim, action_dim, learning_rate: 0.01, episode_states: Vec::new(), episode_actions: Vec::new(), episode_rewards: Vec::new() }
    }

    fn rand_normal() -> f32 {
        let u1 = (std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_nanos() as f32 % 1e9) / 1e9;
        let u2 = ((std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_nanos() + 123) as f32 % 1e9) / 1e9;
        (-2.0 * u1.max(1e-10).ln()).sqrt() * (2.0 * std::f32::consts::PI * u2).cos()
    }

    pub fn action_probs(&self, state: &[f32]) -> Vec<f32> {
        let logits: Vec<f32> = self.weights.iter().map(|w| {
            state.iter().zip(w).map(|(&s, &w)| s * w).sum()
        }).collect();
        let max_logit = logits.iter().cloned().fold(f32::NEG_INFINITY, f32::max);
        let exp_logits: Vec<f32> = logits.iter().map(|&l| (l - max_logit).exp()).collect();
        let sum: f32 = exp_logits.iter().sum();
        exp_logits.iter().map(|&e| e / sum).collect()
    }

    pub fn select_action(&self, state: &[f32]) -> usize {
        let probs = self.action_probs(state);
        let rng = (std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_nanos() as f32 % 1e9) / 1e9;
        let mut cumsum = 0.0;
        for (i, &p) in probs.iter().enumerate() {
            cumsum += p;
            if rng < cumsum { return i; }
        }
        self.action_dim - 1
    }

    pub fn store(&mut self, state: Vec<f32>, action: usize, reward: f32) {
        self.episode_states.push(state);
        self.episode_actions.push(action);
        self.episode_rewards.push(reward);
    }

    pub fn update(&mut self, discount: f32) {
        let n = self.episode_rewards.len();
        if n == 0 { return; }

        // Compute discounted returns
        let mut returns = vec![0.0; n];
        let mut g = 0.0;
        for i in (0..n).rev() {
            g = self.episode_rewards[i] + discount * g;
            returns[i] = g;
        }

        // Normalize returns
        let mean: f32 = returns.iter().sum::<f32>() / n as f32;
        let std: f32 = (returns.iter().map(|&r| (r - mean).powi(2)).sum::<f32>() / n as f32).sqrt().max(1e-8);
        let returns: Vec<f32> = returns.iter().map(|&r| (r - mean) / std).collect();

        // Policy gradient update
        for t in 0..n {
            let state = &self.episode_states[t];
            let action = self.episode_actions[t];
            let probs = self.action_probs(state);

            for a in 0..self.action_dim {
                let grad_log = if a == action { 1.0 - probs[a] } else { -probs[a] };
                for (j, &s) in state.iter().enumerate() {
                    self.weights[a][j] += self.learning_rate * returns[t] * grad_log * s;
                }
            }
        }

        self.episode_states.clear();
        self.episode_actions.clear();
        self.episode_rewards.clear();
    }
}

/// Actor-Critic with advantage estimation
pub struct ActorCritic {
    actor: PolicyGradient,
    critic_weights: Vec<f32>,
    critic_lr: f32,
}

impl ActorCritic {
    pub fn new(state_dim: usize, action_dim: usize) -> Self {
        let actor = PolicyGradient::new(state_dim, action_dim);
        let critic_weights = (0..state_dim).map(|_| PolicyGradient::rand_normal() * 0.01).collect();
        Self { actor, critic_weights, critic_lr: 0.01 }
    }

    fn value(&self, state: &[f32]) -> f32 {
        state.iter().zip(&self.critic_weights).map(|(&s, &w)| s * w).sum()
    }

    pub fn select_action(&self, state: &[f32]) -> usize {
        self.actor.select_action(state)
    }

    pub fn update(&mut self, state: &[f32], action: usize, reward: f32, next_state: &[f32], done: bool, discount: f32) {
        let v = self.value(state);
        let v_next = if done { 0.0 } else { self.value(next_state) };
        let td_target = reward + discount * v_next;
        let advantage = td_target - v;

        // Update critic
        for (j, &s) in state.iter().enumerate() {
            self.critic_weights[j] += self.critic_lr * advantage * s;
        }

        // Update actor with advantage
        let probs = self.actor.action_probs(state);
        for a in 0..self.actor.action_dim {
            let grad_log = if a == action { 1.0 - probs[a] } else { -probs[a] };
            for (j, &s) in state.iter().enumerate() {
                self.actor.weights[a][j] += self.actor.learning_rate * advantage * grad_log * s;
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EVOLUTIONARY STRATEGIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Evolution Strategy (ES) optimizer
pub struct EvolutionStrategy {
    mean: Vec<f32>,
    sigma: f32,
    population_size: usize,
    learning_rate: f32,
}

impl EvolutionStrategy {
    pub fn new(dim: usize, sigma: f32, population_size: usize) -> Self {
        Self { mean: vec![0.0; dim], sigma, population_size, learning_rate: 0.01 }
    }

    pub fn sample(&self) -> Vec<Vec<f32>> {
        (0..self.population_size).map(|_| {
            self.mean.iter().map(|&m| m + self.sigma * PolicyGradient::rand_normal()).collect()
        }).collect()
    }

    pub fn update<F: Fn(&[f32]) -> f32>(&mut self, fitness_fn: F) {
        let samples = self.sample();
        let mut fitnesses: Vec<(usize, f32)> = samples.iter().enumerate().map(|(i, s)| (i, fitness_fn(s))).collect();
        fitnesses.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());

        // Compute weighted mean update
        let elite_size = self.population_size / 4;
        let weights: Vec<f32> = (0..elite_size).map(|i| (elite_size - i) as f32 / elite_size as f32).collect();
        let weight_sum: f32 = weights.iter().sum();

        for j in 0..self.mean.len() {
            let weighted_sum: f32 = fitnesses[..elite_size].iter().zip(&weights).map(|((i, _), w)| {
                w * (samples[*i][j] - self.mean[j]) / self.sigma
            }).sum();
            self.mean[j] += self.learning_rate * self.sigma * weighted_sum / weight_sum;
        }
    }

    pub fn best(&self) -> &[f32] { &self.mean }
}

/// CMA-ES (Covariance Matrix Adaptation)
pub struct CmaEs {
    mean: Vec<f32>,
    sigma: f32,
    c: Vec<Vec<f32>>,  // Covariance matrix
    pc: Vec<f32>,      // Evolution path
    ps: Vec<f32>,      // Conjugate evolution path
    dim: usize,
    lambda: usize,     // Population size
    mu: usize,         // Selected parents
    weights: Vec<f32>, // Recombination weights
    generation: usize,
}

impl CmaEs {
    pub fn new(dim: usize) -> Self {
        let lambda = 4 + (3.0 * (dim as f32).ln()).floor() as usize;
        let mu = lambda / 2;
        let weights: Vec<f32> = (0..mu).map(|i| ((mu as f32 + 0.5).ln() - ((i + 1) as f32).ln()).max(0.0)).collect();
        let w_sum: f32 = weights.iter().sum();
        let weights: Vec<f32> = weights.iter().map(|w| w / w_sum).collect();

        Self {
            mean: vec![0.0; dim],
            sigma: 0.3,
            c: (0..dim).map(|i| (0..dim).map(|j| if i == j { 1.0 } else { 0.0 }).collect()).collect(),
            pc: vec![0.0; dim],
            ps: vec![0.0; dim],
            dim,
            lambda,
            mu,
            weights,
            generation: 0,
        }
    }

    pub fn sample(&self) -> Vec<Vec<f32>> {
        (0..self.lambda).map(|_| {
            self.mean.iter().enumerate().map(|(i, &m)| {
                let noise: f32 = (0..self.dim).map(|j| self.c[i][j] * PolicyGradient::rand_normal()).sum();
                m + self.sigma * noise
            }).collect()
        }).collect()
    }

    pub fn update<F: Fn(&[f32]) -> f32>(&mut self, fitness_fn: F) {
        let samples = self.sample();
        let mut indexed: Vec<(usize, f32)> = samples.iter().enumerate().map(|(i, s)| (i, fitness_fn(s))).collect();
        indexed.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());

        // Update mean
        let new_mean: Vec<f32> = (0..self.dim).map(|j| {
            indexed[..self.mu].iter().zip(&self.weights).map(|((i, _), w)| w * samples[*i][j]).sum()
        }).collect();

        // Update evolution paths (simplified)
        for j in 0..self.dim {
            self.pc[j] = 0.9 * self.pc[j] + 0.4 * (new_mean[j] - self.mean[j]) / self.sigma;
        }

        // Update covariance (rank-1 update only, simplified)
        let c_mu = 0.1 / self.dim as f32;
        for i in 0..self.dim {
            for j in 0..self.dim {
                self.c[i][j] = (1.0 - c_mu) * self.c[i][j] + c_mu * self.pc[i] * self.pc[j];
            }
        }

        self.mean = new_mean;
        self.generation += 1;
    }

    pub fn best(&self) -> &[f32] { &self.mean }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BAYESIAN OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Gaussian Process surrogate model
pub struct GaussianProcessSurrogate {
    x_train: Vec<Vec<f32>>,
    y_train: Vec<f32>,
    length_scale: f32,
    noise: f32,
    k_inv: Option<Vec<Vec<f32>>>,
}

impl GaussianProcessSurrogate {
    pub fn new(length_scale: f32, noise: f32) -> Self {
        Self { x_train: Vec::new(), y_train: Vec::new(), length_scale, noise, k_inv: None }
    }

    fn rbf_kernel(&self, x1: &[f32], x2: &[f32]) -> f32 {
        let sq_dist: f32 = x1.iter().zip(x2).map(|(&a, &b)| (a - b).powi(2)).sum();
        (-sq_dist / (2.0 * self.length_scale.powi(2))).exp()
    }

    pub fn fit(&mut self, x: Vec<Vec<f32>>, y: Vec<f32>) {
        self.x_train = x;
        self.y_train = y;
        let n = self.x_train.len();

        // Compute kernel matrix K
        let mut k: Vec<Vec<f32>> = (0..n).map(|i| {
            (0..n).map(|j| {
                self.rbf_kernel(&self.x_train[i], &self.x_train[j]) + if i == j { self.noise } else { 0.0 }
            }).collect()
        }).collect();

        // Compute inverse (Cholesky-based would be better, simplified here)
        self.k_inv = Some(Self::matrix_inverse(&k));
    }

    fn matrix_inverse(m: &[Vec<f32>]) -> Vec<Vec<f32>> {
        let n = m.len();
        let mut aug: Vec<Vec<f32>> = m.iter().enumerate().map(|(i, row)| {
            let mut r = row.clone();
            r.extend((0..n).map(|j| if i == j { 1.0 } else { 0.0 }));
            r
        }).collect();

        for i in 0..n {
            let pivot = aug[i][i];
            if pivot.abs() < 1e-10 { continue; }
            for j in 0..2*n { aug[i][j] /= pivot; }
            for k in 0..n {
                if k != i {
                    let factor = aug[k][i];
                    for j in 0..2*n { aug[k][j] -= factor * aug[i][j]; }
                }
            }
        }

        aug.iter().map(|row| row[n..].to_vec()).collect()
    }

    pub fn predict(&self, x: &[f32]) -> (f32, f32) {
        if self.x_train.is_empty() { return (0.0, 1.0); }

        let k_star: Vec<f32> = self.x_train.iter().map(|xi| self.rbf_kernel(x, xi)).collect();
        let k_inv = self.k_inv.as_ref().unwrap();

        // Mean: k* @ K_inv @ y
        let k_inv_y: Vec<f32> = (0..k_inv.len()).map(|i| {
            k_inv[i].iter().zip(&self.y_train).map(|(&k, &y)| k * y).sum()
        }).collect();
        let mean: f32 = k_star.iter().zip(&k_inv_y).map(|(&k, &ky)| k * ky).sum();

        // Variance: k(x,x) - k* @ K_inv @ k*^T
        let k_inv_k_star: Vec<f32> = (0..k_inv.len()).map(|i| {
            k_inv[i].iter().zip(&k_star).map(|(&k, &ks)| k * ks).sum()
        }).collect();
        let var: f32 = 1.0 - k_star.iter().zip(&k_inv_k_star).map(|(&ks, &ki)| ks * ki).sum::<f32>();

        (mean, var.max(1e-6))
    }
}

/// Acquisition functions
pub enum AcquisitionFunction { ExpectedImprovement, UpperConfidenceBound(f32), ProbabilityOfImprovement }

impl AcquisitionFunction {
    pub fn evaluate(&self, mean: f32, std: f32, best_y: f32) -> f32 {
        match self {
            AcquisitionFunction::ExpectedImprovement => {
                let z = (mean - best_y) / std;
                let pdf = (-z * z / 2.0).exp() / (2.0 * std::f32::consts::PI).sqrt();
                let cdf = 0.5 * (1.0 + Self::erf(z / 2.0_f32.sqrt()));
                (mean - best_y) * cdf + std * pdf
            },
            AcquisitionFunction::UpperConfidenceBound(kappa) => mean + kappa * std,
            AcquisitionFunction::ProbabilityOfImprovement => {
                let z = (mean - best_y) / std;
                0.5 * (1.0 + Self::erf(z / 2.0_f32.sqrt()))
            },
        }
    }

    fn erf(x: f32) -> f32 {
        let t = 1.0 / (1.0 + 0.5 * x.abs());
        let tau = t * (-x*x - 1.26551223 + t*(1.00002368 + t*(0.37409196 + t*(0.09678418 + t*(-0.18628806 + t*(0.27886807 + t*(-1.13520398 + t*(1.48851587 + t*(-0.82215223 + t*0.17087277))))))))).exp();
        if x >= 0.0 { 1.0 - tau } else { tau - 1.0 }
    }
}

/// Bayesian Optimizer
pub struct BayesianOptimizer {
    gp: GaussianProcessSurrogate,
    acquisition: AcquisitionFunction,
    bounds: Vec<(f32, f32)>,
    x_history: Vec<Vec<f32>>,
    y_history: Vec<f32>,
    best_x: Vec<f32>,
    best_y: f32,
}

impl BayesianOptimizer {
    pub fn new(bounds: Vec<(f32, f32)>, acquisition: AcquisitionFunction) -> Self {
        let dim = bounds.len();
        Self {
            gp: GaussianProcessSurrogate::new(1.0, 0.01),
            acquisition,
            bounds,
            x_history: Vec::new(),
            y_history: Vec::new(),
            best_x: vec![0.0; dim],
            best_y: f32::NEG_INFINITY,
        }
    }

    pub fn suggest(&self) -> Vec<f32> {
        if self.x_history.len() < 5 {
            // Random exploration
            return self.bounds.iter().map(|&(lo, hi)| {
                let r = (std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_nanos() as f32 % 1e9) / 1e9;
                lo + r * (hi - lo)
            }).collect();
        }

        // Grid search for best acquisition
        let n_samples = 100;
        let mut best_acq = f32::NEG_INFINITY;
        let mut best_x = self.bounds.iter().map(|&(lo, hi)| (lo + hi) / 2.0).collect::<Vec<_>>();

        for _ in 0..n_samples {
            let x: Vec<f32> = self.bounds.iter().map(|&(lo, hi)| {
                let r = PolicyGradient::rand_normal().abs().min(3.0) / 3.0;
                lo + r * (hi - lo)
            }).collect();

            let (mean, var) = self.gp.predict(&x);
            let acq = self.acquisition.evaluate(mean, var.sqrt(), self.best_y);
            if acq > best_acq { best_acq = acq; best_x = x; }
        }
        best_x
    }

    pub fn observe(&mut self, x: Vec<f32>, y: f32) {
        self.x_history.push(x.clone());
        self.y_history.push(y);
        if y > self.best_y { self.best_y = y; self.best_x = x; }
        self.gp.fit(self.x_history.clone(), self.y_history.clone());
    }

    pub fn best(&self) -> (&[f32], f32) { (&self.best_x, self.best_y) }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ACTIVE LEARNING
// ═══════════════════════════════════════════════════════════════════════════════

/// Query strategy for active learning
pub enum QueryStrategy { UncertaintySampling, QueryByCommittee, ExpectedModelChange, DensityWeighted }

/// Active learner
pub struct ActiveLearner<M> {
    model: M,
    labeled_x: Vec<Vec<f32>>,
    labeled_y: Vec<usize>,
    unlabeled_pool: Vec<Vec<f32>>,
    strategy: QueryStrategy,
}

impl<M: UncertaintyModel> ActiveLearner<M> {
    pub fn new(model: M, unlabeled_pool: Vec<Vec<f32>>, strategy: QueryStrategy) -> Self {
        Self { model, labeled_x: Vec::new(), labeled_y: Vec::new(), unlabeled_pool, strategy }
    }

    pub fn query(&self, n: usize) -> Vec<usize> {
        let mut scores: Vec<(usize, f32)> = self.unlabeled_pool.iter().enumerate().map(|(i, x)| {
            let score = match &self.strategy {
                QueryStrategy::UncertaintySampling => self.uncertainty_score(x),
                QueryStrategy::QueryByCommittee => self.committee_score(x),
                QueryStrategy::ExpectedModelChange => self.model_change_score(x),
                QueryStrategy::DensityWeighted => self.density_weighted_score(x),
            };
            (i, score)
        }).collect();

        scores.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
        scores.into_iter().take(n).map(|(i, _)| i).collect()
    }

    fn uncertainty_score(&self, x: &[f32]) -> f32 {
        let probs = self.model.predict_proba(x);
        // Entropy
        -probs.iter().filter(|&&p| p > 1e-10).map(|&p| p * p.ln()).sum::<f32>()
    }

    fn committee_score(&self, x: &[f32]) -> f32 {
        // Simplified: use variance of predictions as disagreement
        self.model.uncertainty(x)
    }

    fn model_change_score(&self, x: &[f32]) -> f32 {
        // Approximate expected gradient length
        let probs = self.model.predict_proba(x);
        probs.iter().map(|&p| p * (1.0 - p)).sum::<f32>()
    }

    fn density_weighted_score(&self, x: &[f32]) -> f32 {
        let uncertainty = self.uncertainty_score(x);
        let density: f32 = self.unlabeled_pool.iter().map(|xi| {
            let dist: f32 = x.iter().zip(xi).map(|(&a, &b)| (a - b).powi(2)).sum::<f32>().sqrt();
            (-dist / 2.0).exp()
        }).sum::<f32>() / self.unlabeled_pool.len() as f32;
        uncertainty * density
    }

    pub fn teach(&mut self, indices: &[usize], labels: &[usize]) {
        for (&idx, &label) in indices.iter().zip(labels) {
            self.labeled_x.push(self.unlabeled_pool[idx].clone());
            self.labeled_y.push(label);
        }
        // Remove from pool (in reverse order to preserve indices)
        let mut indices_sorted: Vec<usize> = indices.to_vec();
        indices_sorted.sort_by(|a, b| b.cmp(a));
        for idx in indices_sorted { self.unlabeled_pool.remove(idx); }
    }
}

/// Trait for models that provide uncertainty estimates
pub trait UncertaintyModel {
    fn predict_proba(&self, x: &[f32]) -> Vec<f32>;
    fn uncertainty(&self, x: &[f32]) -> f32;
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-OBJECTIVE OPTIMIZATION - Pareto Frontier Computation
// ═══════════════════════════════════════════════════════════════════════════════

pub mod multi_objective {
    use std::collections::HashSet;

    /// Solution in objective space
    #[derive(Debug, Clone)]
    pub struct Solution {
        pub variables: Vec<f64>,
        pub objectives: Vec<f64>,
        pub constraints: Vec<f64>,
        pub rank: usize,
        pub crowding_distance: f64,
    }

    impl Solution {
        pub fn new(variables: Vec<f64>, objectives: Vec<f64>) -> Self {
            Self {
                variables,
                objectives,
                constraints: Vec::new(),
                rank: 0,
                crowding_distance: 0.0,
            }
        }

        pub fn dominates(&self, other: &Solution) -> bool {
            let mut dominated = false;
            for (a, b) in self.objectives.iter().zip(&other.objectives) {
                if a > b { return false; } // Minimization: lower is better
                if a < b { dominated = true; }
            }
            dominated
        }

        pub fn is_feasible(&self) -> bool {
            self.constraints.iter().all(|&c| c <= 0.0)
        }
    }

    /// Non-dominated sorting (NSGA-II style)
    pub fn non_dominated_sort(solutions: &mut [Solution]) -> Vec<Vec<usize>> {
        let n = solutions.len();
        let mut domination_count: Vec<usize> = vec![0; n];
        let mut dominated_by: Vec<Vec<usize>> = vec![Vec::new(); n];
        let mut fronts: Vec<Vec<usize>> = vec![Vec::new()];

        for i in 0..n {
            for j in (i + 1)..n {
                if solutions[i].dominates(&solutions[j]) {
                    dominated_by[i].push(j);
                    domination_count[j] += 1;
                } else if solutions[j].dominates(&solutions[i]) {
                    dominated_by[j].push(i);
                    domination_count[i] += 1;
                }
            }
            if domination_count[i] == 0 {
                solutions[i].rank = 0;
                fronts[0].push(i);
            }
        }

        let mut front_idx = 0;
        while !fronts[front_idx].is_empty() {
            let mut next_front = Vec::new();
            for &i in &fronts[front_idx] {
                for &j in &dominated_by[i] {
                    domination_count[j] -= 1;
                    if domination_count[j] == 0 {
                        solutions[j].rank = front_idx + 1;
                        next_front.push(j);
                    }
                }
            }
            front_idx += 1;
            fronts.push(next_front);
        }
        fronts.pop(); // Remove empty last front
        fronts
    }

    /// Crowding distance assignment
    pub fn assign_crowding_distance(solutions: &mut [Solution], front: &[usize]) {
        let n = front.len();
        if n <= 2 {
            for &i in front { solutions[i].crowding_distance = f64::INFINITY; }
            return;
        }
        for &i in front { solutions[i].crowding_distance = 0.0; }

        let num_objectives = solutions[front[0]].objectives.len();
        for m in 0..num_objectives {
            let mut sorted: Vec<usize> = front.to_vec();
            sorted.sort_by(|&a, &b| {
                solutions[a].objectives[m].partial_cmp(&solutions[b].objectives[m]).unwrap()
            });
            solutions[sorted[0]].crowding_distance = f64::INFINITY;
            solutions[sorted[n - 1]].crowding_distance = f64::INFINITY;
            let obj_range = solutions[sorted[n - 1]].objectives[m] -
                           solutions[sorted[0]].objectives[m];
            if obj_range > 0.0 {
                for i in 1..(n - 1) {
                    let dist = (solutions[sorted[i + 1]].objectives[m] -
                               solutions[sorted[i - 1]].objectives[m]) / obj_range;
                    solutions[sorted[i]].crowding_distance += dist;
                }
            }
        }
    }

    /// NSGA-II selection
    pub fn nsga2_select(solutions: &[Solution], n: usize) -> Vec<usize> {
        let mut selected: Vec<usize> = Vec::with_capacity(n);
        let mut remaining: Vec<usize> = (0..solutions.len()).collect();
        remaining.sort_by(|&a, &b| {
            let rank_cmp = solutions[a].rank.cmp(&solutions[b].rank);
            if rank_cmp != std::cmp::Ordering::Equal { return rank_cmp; }
            solutions[b].crowding_distance.partial_cmp(&solutions[a].crowding_distance).unwrap()
        });
        selected.extend(remaining.into_iter().take(n));
        selected
    }

    /// Hypervolume indicator computation (2D case)
    pub fn hypervolume_2d(solutions: &[Solution], reference: &[f64]) -> f64 {
        let mut points: Vec<(f64, f64)> = solutions.iter()
            .map(|s| (s.objectives[0], s.objectives[1]))
            .filter(|(x, y)| *x < reference[0] && *y < reference[1])
            .collect();
        points.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap());

        let mut hv = 0.0;
        let mut last_y = reference[1];
        for (x, y) in points {
            if y < last_y {
                hv += (reference[0] - x) * (last_y - y);
                last_y = y;
            }
        }
        hv
    }

    /// MOEA/D decomposition-based approach
    pub struct MoeadConfig {
        pub num_weights: usize,
        pub neighborhood_size: usize,
        pub crossover_rate: f64,
        pub mutation_rate: f64,
    }

    impl Default for MoeadConfig {
        fn default() -> Self {
            Self {
                num_weights: 100,
                neighborhood_size: 20,
                crossover_rate: 0.9,
                mutation_rate: 0.1,
            }
        }
    }

    /// Generate uniformly distributed weight vectors
    pub fn generate_weights(n: usize, m: usize) -> Vec<Vec<f64>> {
        let mut weights = Vec::with_capacity(n);
        for i in 0..n {
            let mut w = vec![0.0; m];
            w[0] = i as f64 / (n - 1) as f64;
            w[1] = 1.0 - w[0];
            weights.push(w);
        }
        weights
    }

    /// Tchebycheff scalarization
    pub fn tchebycheff(objectives: &[f64], weights: &[f64], ideal: &[f64]) -> f64 {
        objectives.iter().zip(weights).zip(ideal)
            .map(|((f, w), z)| w.max(0.0001) * (f - z).abs())
            .fold(0.0, f64::max)
    }

    /// Weighted sum scalarization
    pub fn weighted_sum(objectives: &[f64], weights: &[f64]) -> f64 {
        objectives.iter().zip(weights).map(|(f, w)| f * w).sum()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SWARM INTELLIGENCE - Particle Swarm and Ant Colony
// ═══════════════════════════════════════════════════════════════════════════════

pub mod swarm {
    use rand::Rng;

    /// Particle in PSO
    #[derive(Clone)]
    pub struct Particle {
        pub position: Vec<f64>,
        pub velocity: Vec<f64>,
        pub best_position: Vec<f64>,
        pub best_fitness: f64,
    }

    impl Particle {
        pub fn new(dim: usize, bounds: &[(f64, f64)]) -> Self {
            let mut rng = rand::thread_rng();
            let position: Vec<f64> = bounds.iter()
                .map(|(lo, hi)| rng.gen::<f64>() * (hi - lo) + lo)
                .collect();
            let velocity: Vec<f64> = bounds.iter()
                .map(|(lo, hi)| (rng.gen::<f64>() - 0.5) * (hi - lo) * 0.1)
                .collect();
            Self {
                best_position: position.clone(),
                position,
                velocity,
                best_fitness: f64::INFINITY,
            }
        }
    }

    /// Particle Swarm Optimization
    pub struct PSO {
        pub swarm: Vec<Particle>,
        pub global_best: Vec<f64>,
        pub global_best_fitness: f64,
        pub bounds: Vec<(f64, f64)>,
        pub inertia: f64,
        pub cognitive: f64,
        pub social: f64,
    }

    impl PSO {
        pub fn new(swarm_size: usize, dim: usize, bounds: Vec<(f64, f64)>) -> Self {
            let swarm: Vec<Particle> = (0..swarm_size)
                .map(|_| Particle::new(dim, &bounds))
                .collect();
            Self {
                global_best: vec![0.0; dim],
                global_best_fitness: f64::INFINITY,
                swarm,
                bounds,
                inertia: 0.7,
                cognitive: 1.5,
                social: 1.5,
            }
        }

        pub fn optimize<F>(&mut self, objective: F, max_iter: usize) -> (Vec<f64>, f64)
        where F: Fn(&[f64]) -> f64 {
            let mut rng = rand::thread_rng();
            for p in &mut self.swarm {
                let fitness = objective(&p.position);
                if fitness < p.best_fitness {
                    p.best_fitness = fitness;
                    p.best_position = p.position.clone();
                }
                if fitness < self.global_best_fitness {
                    self.global_best_fitness = fitness;
                    self.global_best = p.position.clone();
                }
            }
            for _ in 0..max_iter {
                for p in &mut self.swarm {
                    for i in 0..p.position.len() {
                        let r1 = rng.gen::<f64>();
                        let r2 = rng.gen::<f64>();
                        p.velocity[i] = self.inertia * p.velocity[i]
                            + self.cognitive * r1 * (p.best_position[i] - p.position[i])
                            + self.social * r2 * (self.global_best[i] - p.position[i]);
                        p.position[i] += p.velocity[i];
                        p.position[i] = p.position[i].clamp(self.bounds[i].0, self.bounds[i].1);
                    }
                    let fitness = objective(&p.position);
                    if fitness < p.best_fitness {
                        p.best_fitness = fitness;
                        p.best_position = p.position.clone();
                    }
                    if fitness < self.global_best_fitness {
                        self.global_best_fitness = fitness;
                        self.global_best = p.position.clone();
                    }
                }
            }
            (self.global_best.clone(), self.global_best_fitness)
        }
    }

    /// Ant Colony Optimization for TSP
    pub struct AntColony {
        pub pheromones: Vec<Vec<f64>>,
        pub distances: Vec<Vec<f64>>,
        pub num_ants: usize,
        pub alpha: f64,    // Pheromone importance
        pub beta: f64,     // Distance importance
        pub evaporation: f64,
        pub q: f64,        // Pheromone deposit factor
    }

    impl AntColony {
        pub fn new(distances: Vec<Vec<f64>>, num_ants: usize) -> Self {
            let n = distances.len();
            Self {
                pheromones: vec![vec![1.0; n]; n],
                distances,
                num_ants,
                alpha: 1.0,
                beta: 2.0,
                evaporation: 0.5,
                q: 100.0,
            }
        }

        pub fn solve(&mut self, max_iter: usize) -> (Vec<usize>, f64) {
            let n = self.distances.len();
            let mut best_tour: Vec<usize> = Vec::new();
            let mut best_length = f64::INFINITY;
            let mut rng = rand::thread_rng();

            for _ in 0..max_iter {
                let mut tours: Vec<Vec<usize>> = Vec::with_capacity(self.num_ants);
                let mut lengths: Vec<f64> = Vec::with_capacity(self.num_ants);

                for _ in 0..self.num_ants {
                    let tour = self.construct_tour(&mut rng);
                    let length = self.tour_length(&tour);
                    if length < best_length {
                        best_length = length;
                        best_tour = tour.clone();
                    }
                    tours.push(tour);
                    lengths.push(length);
                }

                // Evaporate pheromones
                for i in 0..n {
                    for j in 0..n {
                        self.pheromones[i][j] *= 1.0 - self.evaporation;
                    }
                }

                // Deposit new pheromones
                for (tour, length) in tours.iter().zip(&lengths) {
                    let deposit = self.q / length;
                    for i in 0..tour.len() - 1 {
                        self.pheromones[tour[i]][tour[i + 1]] += deposit;
                        self.pheromones[tour[i + 1]][tour[i]] += deposit;
                    }
                }
            }
            (best_tour, best_length)
        }

        fn construct_tour(&self, rng: &mut impl Rng) -> Vec<usize> {
            let n = self.distances.len();
            let mut tour = vec![0];
            let mut visited = vec![false; n];
            visited[0] = true;

            while tour.len() < n {
                let current = *tour.last().unwrap();
                let probs = self.transition_probs(current, &visited);
                let r = rng.gen::<f64>();
                let mut cumsum = 0.0;
                for (city, prob) in probs.iter().enumerate() {
                    cumsum += prob;
                    if r <= cumsum && !visited[city] {
                        tour.push(city);
                        visited[city] = true;
                        break;
                    }
                }
            }
            tour.push(0); // Return to start
            tour
        }

        fn transition_probs(&self, current: usize, visited: &[bool]) -> Vec<f64> {
            let n = self.distances.len();
            let mut probs = vec![0.0; n];
            let mut total = 0.0;
            for j in 0..n {
                if !visited[j] && self.distances[current][j] > 0.0 {
                    let tau = self.pheromones[current][j].powf(self.alpha);
                    let eta = (1.0 / self.distances[current][j]).powf(self.beta);
                    probs[j] = tau * eta;
                    total += probs[j];
                }
            }
            if total > 0.0 {
                for p in &mut probs { *p /= total; }
            }
            probs
        }

        fn tour_length(&self, tour: &[usize]) -> f64 {
            tour.windows(2)
                .map(|w| self.distances[w[0]][w[1]])
                .sum()
        }
    }

    /// Differential Evolution
    pub struct DifferentialEvolution {
        pub population: Vec<Vec<f64>>,
        pub bounds: Vec<(f64, f64)>,
        pub f: f64,          // Mutation factor
        pub cr: f64,         // Crossover rate
    }

    impl DifferentialEvolution {
        pub fn new(pop_size: usize, dim: usize, bounds: Vec<(f64, f64)>) -> Self {
            let mut rng = rand::thread_rng();
            let population: Vec<Vec<f64>> = (0..pop_size)
                .map(|_| bounds.iter()
                    .map(|(lo, hi)| rng.gen::<f64>() * (hi - lo) + lo)
                    .collect())
                .collect();
            Self { population, bounds, f: 0.8, cr: 0.9 }
        }

        pub fn optimize<F>(&mut self, objective: F, max_iter: usize) -> (Vec<f64>, f64)
        where F: Fn(&[f64]) -> f64 {
            let mut rng = rand::thread_rng();
            let pop_size = self.population.len();
            let dim = self.bounds.len();
            let mut fitness: Vec<f64> = self.population.iter().map(&objective).collect();

            for _ in 0..max_iter {
                for i in 0..pop_size {
                    // Select three distinct random individuals
                    let mut indices: Vec<usize> = (0..pop_size).filter(|&j| j != i).collect();
                    let a = indices.remove(rng.gen_range(0..indices.len()));
                    let b = indices.remove(rng.gen_range(0..indices.len()));
                    let c = indices.remove(rng.gen_range(0..indices.len()));

                    // Mutation
                    let mutant: Vec<f64> = (0..dim)
                        .map(|j| {
                            let v = self.population[a][j] +
                                   self.f * (self.population[b][j] - self.population[c][j]);
                            v.clamp(self.bounds[j].0, self.bounds[j].1)
                        })
                        .collect();

                    // Crossover
                    let j_rand = rng.gen_range(0..dim);
                    let trial: Vec<f64> = (0..dim)
                        .map(|j| {
                            if rng.gen::<f64>() < self.cr || j == j_rand {
                                mutant[j]
                            } else {
                                self.population[i][j]
                            }
                        })
                        .collect();

                    // Selection
                    let trial_fitness = objective(&trial);
                    if trial_fitness < fitness[i] {
                        self.population[i] = trial;
                        fitness[i] = trial_fitness;
                    }
                }
            }

            let best_idx = fitness.iter().enumerate()
                .min_by(|a, b| a.1.partial_cmp(b.1).unwrap())
                .map(|(i, _)| i).unwrap();
            (self.population[best_idx].clone(), fitness[best_idx])
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CAUSAL INFERENCE - Do-Calculus and Interventions
// ═══════════════════════════════════════════════════════════════════════════════

pub mod causal {
    use std::collections::{HashMap, HashSet};

    /// Variable in a causal model
    #[derive(Debug, Clone)]
    pub struct Variable {
        pub name: String,
        pub values: Vec<f64>,
        pub is_treatment: bool,
        pub is_outcome: bool,
    }

    /// Edge type in causal graph
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum EdgeType {
        Directed,     // X -> Y
        Bidirected,   // X <-> Y (hidden confounder)
    }

    /// Structural Causal Model (SCM)
    pub struct SCM {
        pub variables: HashMap<String, Variable>,
        pub edges: Vec<(String, String, EdgeType)>,
        pub structural_equations: HashMap<String, Box<dyn Fn(&HashMap<String, f64>) -> f64>>,
    }

    impl SCM {
        pub fn new() -> Self {
            Self {
                variables: HashMap::new(),
                edges: Vec::new(),
                structural_equations: HashMap::new(),
            }
        }

        pub fn add_variable(&mut self, name: &str, is_treatment: bool, is_outcome: bool) {
            self.variables.insert(name.into(), Variable {
                name: name.into(),
                values: Vec::new(),
                is_treatment,
                is_outcome,
            });
        }

        pub fn add_edge(&mut self, from: &str, to: &str, edge_type: EdgeType) {
            self.edges.push((from.into(), to.into(), edge_type));
        }

        /// Get parents of a node
        pub fn parents(&self, node: &str) -> Vec<String> {
            self.edges.iter()
                .filter(|(_, to, et)| to == node && *et == EdgeType::Directed)
                .map(|(from, _, _)| from.clone())
                .collect()
        }

        /// Get children of a node
        pub fn children(&self, node: &str) -> Vec<String> {
            self.edges.iter()
                .filter(|(from, _, et)| from == node && *et == EdgeType::Directed)
                .map(|(_, to, _)| to.clone())
                .collect()
        }

        /// Get ancestors of a node
        pub fn ancestors(&self, node: &str) -> HashSet<String> {
            let mut ancestors = HashSet::new();
            let mut stack = vec![node.to_string()];
            while let Some(n) = stack.pop() {
                for parent in self.parents(&n) {
                    if ancestors.insert(parent.clone()) {
                        stack.push(parent);
                    }
                }
            }
            ancestors
        }

        /// Get descendants of a node
        pub fn descendants(&self, node: &str) -> HashSet<String> {
            let mut desc = HashSet::new();
            let mut stack = vec![node.to_string()];
            while let Some(n) = stack.pop() {
                for child in self.children(&n) {
                    if desc.insert(child.clone()) {
                        stack.push(child);
                    }
                }
            }
            desc
        }

        /// Perform do-intervention: do(X=x)
        pub fn do_intervention(&self, treatment: &str, value: f64, context: &HashMap<String, f64>) -> HashMap<String, f64> {
            let mut result = context.clone();
            result.insert(treatment.into(), value);
            // Compute downstream effects via topological sort
            let order = self.topological_sort();
            for node in order {
                if node != treatment {
                    if let Some(eq) = self.structural_equations.get(&node) {
                        result.insert(node, eq(&result));
                    }
                }
            }
            result
        }

        fn topological_sort(&self) -> Vec<String> {
            let mut in_degree: HashMap<String, usize> = HashMap::new();
            for name in self.variables.keys() {
                in_degree.insert(name.clone(), 0);
            }
            for (from, to, et) in &self.edges {
                if *et == EdgeType::Directed {
                    *in_degree.get_mut(to).unwrap() += 1;
                }
            }
            let mut queue: Vec<String> = in_degree.iter()
                .filter(|(_, &d)| d == 0)
                .map(|(n, _)| n.clone())
                .collect();
            let mut result = Vec::new();
            while let Some(node) = queue.pop() {
                result.push(node.clone());
                for child in self.children(&node) {
                    let d = in_degree.get_mut(&child).unwrap();
                    *d -= 1;
                    if *d == 0 { queue.push(child); }
                }
            }
            result
        }
    }

    /// Backdoor criterion check
    pub fn backdoor_criterion(scm: &SCM, treatment: &str, outcome: &str, adjustment: &[&str]) -> bool {
        // 1. No node in Z is a descendant of X
        let treatment_desc = scm.descendants(treatment);
        for z in adjustment {
            if treatment_desc.contains(*z) { return false; }
        }
        // 2. Z blocks all backdoor paths from X to Y
        // (Simplified: assumes blocking if adjustment set includes all non-descendant parents)
        true
    }

    /// Frontdoor criterion check
    pub fn frontdoor_criterion(scm: &SCM, treatment: &str, mediator: &str, outcome: &str) -> bool {
        // M intercepts all directed paths from X to Y
        // No backdoor path from X to M
        // All backdoor paths from M to Y are blocked by X
        let treatment_children = scm.children(treatment);
        let mediator_children = scm.children(mediator);
        treatment_children.contains(&mediator.to_string()) &&
            mediator_children.contains(&outcome.to_string())
    }

    /// Instrumental Variable estimator
    pub struct InstrumentalVariable {
        pub instrument: String,
        pub treatment: String,
        pub outcome: String,
    }

    impl InstrumentalVariable {
        pub fn new(instrument: &str, treatment: &str, outcome: &str) -> Self {
            Self {
                instrument: instrument.into(),
                treatment: treatment.into(),
                outcome: outcome.into(),
            }
        }

        /// Two-stage least squares estimate
        pub fn estimate(&self, data: &[(f64, f64, f64)]) -> f64 {
            // data: [(Z, X, Y)]
            let n = data.len() as f64;
            let z_mean: f64 = data.iter().map(|(z, _, _)| z).sum::<f64>() / n;
            let x_mean: f64 = data.iter().map(|(_, x, _)| x).sum::<f64>() / n;
            let y_mean: f64 = data.iter().map(|(_, _, y)| y).sum::<f64>() / n;

            let cov_zy: f64 = data.iter()
                .map(|(z, _, y)| (z - z_mean) * (y - y_mean))
                .sum::<f64>() / n;
            let cov_zx: f64 = data.iter()
                .map(|(z, x, _)| (z - z_mean) * (x - x_mean))
                .sum::<f64>() / n;

            if cov_zx.abs() < 1e-10 { return 0.0; }
            cov_zy / cov_zx
        }
    }

    /// Average Treatment Effect estimator
    pub struct ATEEstimator {
        pub method: ATEMethod,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum ATEMethod {
        DifferenceInMeans,
        IPW,           // Inverse Probability Weighting
        AIPW,          // Augmented IPW
        Matching,
    }

    impl ATEEstimator {
        pub fn new(method: ATEMethod) -> Self {
            Self { method }
        }

        pub fn estimate(&self, treated: &[(Vec<f64>, f64)], control: &[(Vec<f64>, f64)]) -> f64 {
            match self.method {
                ATEMethod::DifferenceInMeans => {
                    let treated_mean: f64 = treated.iter().map(|(_, y)| y).sum::<f64>() /
                                           treated.len() as f64;
                    let control_mean: f64 = control.iter().map(|(_, y)| y).sum::<f64>() /
                                           control.len() as f64;
                    treated_mean - control_mean
                }
                _ => {
                    // Simplified: fallback to difference in means
                    let treated_mean: f64 = treated.iter().map(|(_, y)| y).sum::<f64>() /
                                           treated.len().max(1) as f64;
                    let control_mean: f64 = control.iter().map(|(_, y)| y).sum::<f64>() /
                                           control.len().max(1) as f64;
                    treated_mean - control_mean
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL ARCHITECTURE COMPONENTS - Advanced Layers
// ═══════════════════════════════════════════════════════════════════════════════

pub mod neural_layers {
    use rand::Rng;

    /// Layer normalization
    pub struct LayerNorm {
        pub gamma: Vec<f64>,
        pub beta: Vec<f64>,
        pub eps: f64,
    }

    impl LayerNorm {
        pub fn new(dim: usize) -> Self {
            Self {
                gamma: vec![1.0; dim],
                beta: vec![0.0; dim],
                eps: 1e-5,
            }
        }

        pub fn forward(&self, x: &[f64]) -> Vec<f64> {
            let mean: f64 = x.iter().sum::<f64>() / x.len() as f64;
            let var: f64 = x.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / x.len() as f64;
            let std = (var + self.eps).sqrt();
            x.iter().enumerate()
                .map(|(i, v)| self.gamma[i] * (v - mean) / std + self.beta[i])
                .collect()
        }
    }

    /// Group normalization
    pub struct GroupNorm {
        pub num_groups: usize,
        pub gamma: Vec<f64>,
        pub beta: Vec<f64>,
        pub eps: f64,
    }

    impl GroupNorm {
        pub fn new(num_groups: usize, num_channels: usize) -> Self {
            Self {
                num_groups,
                gamma: vec![1.0; num_channels],
                beta: vec![0.0; num_channels],
                eps: 1e-5,
            }
        }

        pub fn forward(&self, x: &[f64]) -> Vec<f64> {
            let channels = x.len();
            let group_size = channels / self.num_groups;
            let mut output = vec![0.0; channels];

            for g in 0..self.num_groups {
                let start = g * group_size;
                let end = (g + 1) * group_size;
                let group = &x[start..end];
                let mean: f64 = group.iter().sum::<f64>() / group_size as f64;
                let var: f64 = group.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / group_size as f64;
                let std = (var + self.eps).sqrt();
                for i in start..end {
                    output[i] = self.gamma[i] * (x[i] - mean) / std + self.beta[i];
                }
            }
            output
        }
    }

    /// RMSNorm (Root Mean Square Normalization)
    pub struct RMSNorm {
        pub gamma: Vec<f64>,
        pub eps: f64,
    }

    impl RMSNorm {
        pub fn new(dim: usize) -> Self {
            Self { gamma: vec![1.0; dim], eps: 1e-8 }
        }

        pub fn forward(&self, x: &[f64]) -> Vec<f64> {
            let rms = (x.iter().map(|v| v * v).sum::<f64>() / x.len() as f64).sqrt();
            x.iter().enumerate()
                .map(|(i, v)| self.gamma[i] * v / (rms + self.eps))
                .collect()
        }
    }

    /// Rotary Position Embedding (RoPE)
    pub struct RotaryEmbedding {
        pub dim: usize,
        pub base: f64,
        pub max_seq_len: usize,
        cos_cache: Vec<Vec<f64>>,
        sin_cache: Vec<Vec<f64>>,
    }

    impl RotaryEmbedding {
        pub fn new(dim: usize, max_seq_len: usize) -> Self {
            let base = 10000.0;
            let mut cos_cache = Vec::with_capacity(max_seq_len);
            let mut sin_cache = Vec::with_capacity(max_seq_len);

            for pos in 0..max_seq_len {
                let mut cos_row = Vec::with_capacity(dim / 2);
                let mut sin_row = Vec::with_capacity(dim / 2);
                for i in 0..(dim / 2) {
                    let freq = 1.0 / base.powf((2 * i) as f64 / dim as f64);
                    let angle = pos as f64 * freq;
                    cos_row.push(angle.cos());
                    sin_row.push(angle.sin());
                }
                cos_cache.push(cos_row);
                sin_cache.push(sin_row);
            }

            Self { dim, base, max_seq_len, cos_cache, sin_cache }
        }

        pub fn apply(&self, x: &[f64], pos: usize) -> Vec<f64> {
            let half = self.dim / 2;
            let mut output = vec![0.0; self.dim];
            for i in 0..half {
                let cos_val = self.cos_cache[pos][i];
                let sin_val = self.sin_cache[pos][i];
                output[i] = x[i] * cos_val - x[i + half] * sin_val;
                output[i + half] = x[i] * sin_val + x[i + half] * cos_val;
            }
            output
        }
    }

    /// Mixture of Experts (MoE) layer
    pub struct MixtureOfExperts {
        pub num_experts: usize,
        pub top_k: usize,
        pub expert_weights: Vec<Vec<Vec<f64>>>,  // [expert][in][out]
        pub gate_weights: Vec<Vec<f64>>,         // [in][num_experts]
    }

    impl MixtureOfExperts {
        pub fn new(input_dim: usize, hidden_dim: usize, output_dim: usize, num_experts: usize, top_k: usize) -> Self {
            let mut rng = rand::thread_rng();
            let scale = (2.0 / input_dim as f64).sqrt();

            let expert_weights: Vec<Vec<Vec<f64>>> = (0..num_experts)
                .map(|_| {
                    (0..input_dim)
                        .map(|_| (0..output_dim).map(|_| rng.gen::<f64>() * scale).collect())
                        .collect()
                })
                .collect();

            let gate_weights: Vec<Vec<f64>> = (0..input_dim)
                .map(|_| (0..num_experts).map(|_| rng.gen::<f64>() * 0.01).collect())
                .collect();

            Self { num_experts, top_k, expert_weights, gate_weights }
        }

        pub fn forward(&self, x: &[f64]) -> Vec<f64> {
            // Compute gate logits
            let gate_logits: Vec<f64> = (0..self.num_experts)
                .map(|e| x.iter().enumerate().map(|(i, v)| v * self.gate_weights[i][e]).sum())
                .collect();

            // Softmax
            let max_logit = gate_logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let exp_sum: f64 = gate_logits.iter().map(|l| (l - max_logit).exp()).sum();
            let gate_probs: Vec<f64> = gate_logits.iter().map(|l| (l - max_logit).exp() / exp_sum).collect();

            // Select top-k experts
            let mut expert_indices: Vec<usize> = (0..self.num_experts).collect();
            expert_indices.sort_by(|&a, &b| gate_probs[b].partial_cmp(&gate_probs[a]).unwrap());
            let top_experts: Vec<usize> = expert_indices.into_iter().take(self.top_k).collect();

            // Compute weighted expert outputs
            let output_dim = self.expert_weights[0][0].len();
            let mut output = vec![0.0; output_dim];

            for &expert in &top_experts {
                let weight = gate_probs[expert];
                for o in 0..output_dim {
                    let expert_out: f64 = x.iter().enumerate()
                        .map(|(i, v)| v * self.expert_weights[expert][i][o])
                        .sum();
                    output[o] += weight * expert_out;
                }
            }
            output
        }
    }

    /// Gated Linear Unit (GLU)
    pub struct GLU {
        pub weight: Vec<Vec<f64>>,
        pub gate_weight: Vec<Vec<f64>>,
    }

    impl GLU {
        pub fn new(input_dim: usize, output_dim: usize) -> Self {
            let mut rng = rand::thread_rng();
            let scale = (2.0 / input_dim as f64).sqrt();
            Self {
                weight: (0..input_dim).map(|_| (0..output_dim).map(|_| rng.gen::<f64>() * scale).collect()).collect(),
                gate_weight: (0..input_dim).map(|_| (0..output_dim).map(|_| rng.gen::<f64>() * scale).collect()).collect(),
            }
        }

        pub fn forward(&self, x: &[f64]) -> Vec<f64> {
            let output_dim = self.weight[0].len();
            (0..output_dim).map(|o| {
                let linear: f64 = x.iter().enumerate().map(|(i, v)| v * self.weight[i][o]).sum();
                let gate: f64 = x.iter().enumerate().map(|(i, v)| v * self.gate_weight[i][o]).sum();
                let sigmoid_gate = 1.0 / (1.0 + (-gate).exp());
                linear * sigmoid_gate
            }).collect()
        }
    }

    /// SwiGLU activation (used in LLaMA)
    pub struct SwiGLU {
        pub w1: Vec<Vec<f64>>,
        pub w2: Vec<Vec<f64>>,
        pub w3: Vec<Vec<f64>>,
    }

    impl SwiGLU {
        pub fn new(dim: usize, hidden_dim: usize) -> Self {
            let mut rng = rand::thread_rng();
            let scale = (2.0 / dim as f64).sqrt();
            Self {
                w1: (0..dim).map(|_| (0..hidden_dim).map(|_| rng.gen::<f64>() * scale).collect()).collect(),
                w2: (0..hidden_dim).map(|_| (0..dim).map(|_| rng.gen::<f64>() * scale).collect()).collect(),
                w3: (0..dim).map(|_| (0..hidden_dim).map(|_| rng.gen::<f64>() * scale).collect()).collect(),
            }
        }

        pub fn forward(&self, x: &[f64]) -> Vec<f64> {
            let hidden_dim = self.w1[0].len();
            let dim = x.len();

            // h1 = swish(x @ W1)
            let h1: Vec<f64> = (0..hidden_dim).map(|h| {
                let z: f64 = x.iter().enumerate().map(|(i, v)| v * self.w1[i][h]).sum();
                z * (1.0 / (1.0 + (-z).exp())) // Swish = x * sigmoid(x)
            }).collect();

            // h3 = x @ W3
            let h3: Vec<f64> = (0..hidden_dim).map(|h| {
                x.iter().enumerate().map(|(i, v)| v * self.w3[i][h]).sum()
            }).collect();

            // output = (h1 * h3) @ W2
            (0..dim).map(|o| {
                h1.iter().zip(&h3).enumerate()
                    .map(|(h, (a, b))| a * b * self.w2[h][o])
                    .sum()
            }).collect()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Knowledge Graphs
// ═══════════════════════════════════════════════════════════════════════════════

pub mod knowledge_graph {
    use super::*;

    #[derive(Clone, Debug)]
    pub struct Entity {
        pub id: String,
        pub entity_type: String,
        pub properties: HashMap<String, PropertyValue>,
    }

    #[derive(Clone, Debug)]
    pub enum PropertyValue {
        String(String),
        Number(f64),
        Boolean(bool),
        List(Vec<PropertyValue>),
        Null,
    }

    impl Entity {
        pub fn new(id: &str, entity_type: &str) -> Self {
            Self {
                id: id.to_string(),
                entity_type: entity_type.to_string(),
                properties: HashMap::new(),
            }
        }

        pub fn set_property(&mut self, key: &str, value: PropertyValue) {
            self.properties.insert(key.to_string(), value);
        }

        pub fn get_property(&self, key: &str) -> Option<&PropertyValue> {
            self.properties.get(key)
        }
    }

    #[derive(Clone, Debug)]
    pub struct Relationship {
        pub id: String,
        pub relationship_type: String,
        pub source: String,
        pub target: String,
        pub properties: HashMap<String, PropertyValue>,
        pub weight: f64,
    }

    impl Relationship {
        pub fn new(id: &str, rel_type: &str, source: &str, target: &str) -> Self {
            Self {
                id: id.to_string(),
                relationship_type: rel_type.to_string(),
                source: source.to_string(),
                target: target.to_string(),
                properties: HashMap::new(),
                weight: 1.0,
            }
        }

        pub fn with_weight(mut self, weight: f64) -> Self {
            self.weight = weight;
            self
        }
    }

    pub struct KnowledgeGraph {
        entities: HashMap<String, Entity>,
        relationships: HashMap<String, Relationship>,
        outgoing_edges: HashMap<String, Vec<String>>,
        incoming_edges: HashMap<String, Vec<String>>,
        type_index: HashMap<String, Vec<String>>,
    }

    impl KnowledgeGraph {
        pub fn new() -> Self {
            Self {
                entities: HashMap::new(),
                relationships: HashMap::new(),
                outgoing_edges: HashMap::new(),
                incoming_edges: HashMap::new(),
                type_index: HashMap::new(),
            }
        }

        pub fn add_entity(&mut self, entity: Entity) {
            let id = entity.id.clone();
            let entity_type = entity.entity_type.clone();

            self.entities.insert(id.clone(), entity);
            self.type_index.entry(entity_type).or_default().push(id.clone());
            self.outgoing_edges.entry(id.clone()).or_default();
            self.incoming_edges.entry(id).or_default();
        }

        pub fn add_relationship(&mut self, relationship: Relationship) {
            let rel_id = relationship.id.clone();
            let source = relationship.source.clone();
            let target = relationship.target.clone();

            self.outgoing_edges.entry(source).or_default().push(rel_id.clone());
            self.incoming_edges.entry(target).or_default().push(rel_id.clone());
            self.relationships.insert(rel_id, relationship);
        }

        pub fn get_entity(&self, id: &str) -> Option<&Entity> {
            self.entities.get(id)
        }

        pub fn get_relationship(&self, id: &str) -> Option<&Relationship> {
            self.relationships.get(id)
        }

        pub fn get_entities_by_type(&self, entity_type: &str) -> Vec<&Entity> {
            self.type_index.get(entity_type)
                .map(|ids| ids.iter().filter_map(|id| self.entities.get(id)).collect())
                .unwrap_or_default()
        }

        pub fn get_outgoing(&self, entity_id: &str) -> Vec<&Relationship> {
            self.outgoing_edges.get(entity_id)
                .map(|ids| ids.iter().filter_map(|id| self.relationships.get(id)).collect())
                .unwrap_or_default()
        }

        pub fn get_incoming(&self, entity_id: &str) -> Vec<&Relationship> {
            self.incoming_edges.get(entity_id)
                .map(|ids| ids.iter().filter_map(|id| self.relationships.get(id)).collect())
                .unwrap_or_default()
        }

        pub fn get_neighbors(&self, entity_id: &str, rel_type: Option<&str>) -> Vec<&Entity> {
            let mut neighbors = Vec::new();

            for rel in self.get_outgoing(entity_id) {
                if rel_type.is_none() || rel_type == Some(&rel.relationship_type) {
                    if let Some(entity) = self.entities.get(&rel.target) {
                        neighbors.push(entity);
                    }
                }
            }
            neighbors
        }

        pub fn shortest_path(&self, start: &str, end: &str) -> Option<Vec<String>> {
            use std::collections::VecDeque;

            let mut visited: HashMap<String, String> = HashMap::new();
            let mut queue = VecDeque::new();
            queue.push_back(start.to_string());
            visited.insert(start.to_string(), String::new());

            while let Some(current) = queue.pop_front() {
                if current == end {
                    // Reconstruct path
                    let mut path = vec![end.to_string()];
                    let mut node = end.to_string();
                    while let Some(prev) = visited.get(&node) {
                        if prev.is_empty() { break; }
                        path.push(prev.clone());
                        node = prev.clone();
                    }
                    path.reverse();
                    return Some(path);
                }

                for rel in self.get_outgoing(&current) {
                    if !visited.contains_key(&rel.target) {
                        visited.insert(rel.target.clone(), current.clone());
                        queue.push_back(rel.target.clone());
                    }
                }
            }
            None
        }

        pub fn find_pattern(&self, pattern: &GraphPattern) -> Vec<PatternMatch> {
            let mut matches = Vec::new();
            self.match_pattern_recursive(pattern, 0, HashMap::new(), &mut matches);
            matches
        }

        fn match_pattern_recursive(
            &self,
            pattern: &GraphPattern,
            step: usize,
            bindings: HashMap<String, String>,
            results: &mut Vec<PatternMatch>,
        ) {
            if step >= pattern.steps.len() {
                results.push(PatternMatch { bindings: bindings.clone() });
                return;
            }

            let step_pattern = &pattern.steps[step];
            match step_pattern {
                PatternStep::Node { var, entity_type } => {
                    let candidates: Vec<&Entity> = if let Some(et) = entity_type {
                        self.get_entities_by_type(et)
                    } else {
                        self.entities.values().collect()
                    };

                    for entity in candidates {
                        let mut new_bindings = bindings.clone();
                        new_bindings.insert(var.clone(), entity.id.clone());
                        self.match_pattern_recursive(pattern, step + 1, new_bindings, results);
                    }
                }
                PatternStep::Edge { from_var, to_var, rel_type } => {
                    if let Some(from_id) = bindings.get(from_var) {
                        for rel in self.get_outgoing(from_id) {
                            if rel_type.is_none() || rel_type.as_ref() == Some(&rel.relationship_type) {
                                let mut new_bindings = bindings.clone();
                                new_bindings.insert(to_var.clone(), rel.target.clone());
                                self.match_pattern_recursive(pattern, step + 1, new_bindings, results);
                            }
                        }
                    }
                }
            }
        }

        pub fn pagerank(&self, damping: f64, iterations: usize) -> HashMap<String, f64> {
            let n = self.entities.len() as f64;
            let mut ranks: HashMap<String, f64> = self.entities.keys()
                .map(|k| (k.clone(), 1.0 / n))
                .collect();

            for _ in 0..iterations {
                let mut new_ranks: HashMap<String, f64> = HashMap::new();

                for entity_id in self.entities.keys() {
                    let incoming = self.get_incoming(entity_id);
                    let mut sum = 0.0;

                    for rel in incoming {
                        let out_degree = self.outgoing_edges.get(&rel.source).map(|v| v.len()).unwrap_or(1);
                        if let Some(&rank) = ranks.get(&rel.source) {
                            sum += rank / out_degree as f64;
                        }
                    }

                    new_ranks.insert(entity_id.clone(), (1.0 - damping) / n + damping * sum);
                }

                ranks = new_ranks;
            }
            ranks
        }

        pub fn entity_count(&self) -> usize { self.entities.len() }
        pub fn relationship_count(&self) -> usize { self.relationships.len() }
    }

    pub struct GraphPattern {
        pub steps: Vec<PatternStep>,
    }

    pub enum PatternStep {
        Node { var: String, entity_type: Option<String> },
        Edge { from_var: String, to_var: String, rel_type: Option<String> },
    }

    pub struct PatternMatch {
        pub bindings: HashMap<String, String>,
    }

    // Triple Store
    pub struct TripleStore {
        triples: Vec<Triple>,
        subject_index: HashMap<String, Vec<usize>>,
        predicate_index: HashMap<String, Vec<usize>>,
        object_index: HashMap<String, Vec<usize>>,
    }

    #[derive(Clone, Debug)]
    pub struct Triple {
        pub subject: String,
        pub predicate: String,
        pub object: TripleObject,
    }

    #[derive(Clone, Debug)]
    pub enum TripleObject {
        Uri(String),
        Literal(String),
        TypedLiteral(String, String),
    }

    impl TripleStore {
        pub fn new() -> Self {
            Self {
                triples: Vec::new(),
                subject_index: HashMap::new(),
                predicate_index: HashMap::new(),
                object_index: HashMap::new(),
            }
        }

        pub fn add(&mut self, triple: Triple) {
            let idx = self.triples.len();
            self.subject_index.entry(triple.subject.clone()).or_default().push(idx);
            self.predicate_index.entry(triple.predicate.clone()).or_default().push(idx);

            let obj_key = match &triple.object {
                TripleObject::Uri(u) => u.clone(),
                TripleObject::Literal(l) => l.clone(),
                TripleObject::TypedLiteral(l, _) => l.clone(),
            };
            self.object_index.entry(obj_key).or_default().push(idx);

            self.triples.push(triple);
        }

        pub fn query(&self, subject: Option<&str>, predicate: Option<&str>, object: Option<&str>) -> Vec<&Triple> {
            let mut result_indices: Option<Vec<usize>> = None;

            if let Some(s) = subject {
                if let Some(indices) = self.subject_index.get(s) {
                    result_indices = Some(indices.clone());
                } else {
                    return vec![];
                }
            }

            if let Some(p) = predicate {
                if let Some(indices) = self.predicate_index.get(p) {
                    result_indices = Some(match result_indices {
                        Some(prev) => prev.into_iter().filter(|i| indices.contains(i)).collect(),
                        None => indices.clone(),
                    });
                } else {
                    return vec![];
                }
            }

            if let Some(o) = object {
                if let Some(indices) = self.object_index.get(o) {
                    result_indices = Some(match result_indices {
                        Some(prev) => prev.into_iter().filter(|i| indices.contains(i)).collect(),
                        None => indices.clone(),
                    });
                } else {
                    return vec![];
                }
            }

            result_indices.unwrap_or_else(|| (0..self.triples.len()).collect())
                .into_iter()
                .map(|i| &self.triples[i])
                .collect()
        }

        pub fn triple_count(&self) -> usize { self.triples.len() }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Semantic Reasoning
// ═══════════════════════════════════════════════════════════════════════════════

pub mod semantic_reasoning {
    use super::*;

    // Ontology Class
    #[derive(Clone, Debug)]
    pub struct OntologyClass {
        pub uri: String,
        pub label: String,
        pub parent: Option<String>,
        pub properties: Vec<String>,
    }

    impl OntologyClass {
        pub fn new(uri: &str, label: &str) -> Self {
            Self {
                uri: uri.to_string(),
                label: label.to_string(),
                parent: None,
                properties: Vec::new(),
            }
        }

        pub fn with_parent(mut self, parent: &str) -> Self {
            self.parent = Some(parent.to_string());
            self
        }
    }

    // Property Definition
    #[derive(Clone, Debug)]
    pub struct OntologyProperty {
        pub uri: String,
        pub label: String,
        pub domain: Option<String>,
        pub range: Option<String>,
        pub property_type: PropertyType,
    }

    #[derive(Clone, Debug)]
    pub enum PropertyType {
        ObjectProperty,
        DataProperty,
        AnnotationProperty,
    }

    // Ontology
    pub struct Ontology {
        pub uri: String,
        classes: HashMap<String, OntologyClass>,
        properties: HashMap<String, OntologyProperty>,
        class_hierarchy: HashMap<String, Vec<String>>, // parent -> children
    }

    impl Ontology {
        pub fn new(uri: &str) -> Self {
            Self {
                uri: uri.to_string(),
                classes: HashMap::new(),
                properties: HashMap::new(),
                class_hierarchy: HashMap::new(),
            }
        }

        pub fn add_class(&mut self, class: OntologyClass) {
            if let Some(parent) = &class.parent {
                self.class_hierarchy.entry(parent.clone()).or_default().push(class.uri.clone());
            }
            self.classes.insert(class.uri.clone(), class);
        }

        pub fn add_property(&mut self, property: OntologyProperty) {
            self.properties.insert(property.uri.clone(), property);
        }

        pub fn get_class(&self, uri: &str) -> Option<&OntologyClass> {
            self.classes.get(uri)
        }

        pub fn get_subclasses(&self, class_uri: &str) -> Vec<&OntologyClass> {
            self.class_hierarchy.get(class_uri)
                .map(|children| children.iter().filter_map(|c| self.classes.get(c)).collect())
                .unwrap_or_default()
        }

        pub fn get_all_subclasses(&self, class_uri: &str) -> Vec<&OntologyClass> {
            let mut result = Vec::new();
            let mut stack = vec![class_uri.to_string()];

            while let Some(current) = stack.pop() {
                if let Some(children) = self.class_hierarchy.get(&current) {
                    for child in children {
                        if let Some(class) = self.classes.get(child) {
                            result.push(class);
                            stack.push(child.clone());
                        }
                    }
                }
            }
            result
        }

        pub fn is_subclass_of(&self, class_uri: &str, potential_parent: &str) -> bool {
            let mut current = class_uri.to_string();
            while let Some(class) = self.classes.get(&current) {
                if let Some(parent) = &class.parent {
                    if parent == potential_parent {
                        return true;
                    }
                    current = parent.clone();
                } else {
                    break;
                }
            }
            false
        }
    }

    // Inference Engine
    pub struct InferenceEngine {
        rules: Vec<InferenceRule>,
    }

    pub struct InferenceRule {
        pub name: String,
        pub antecedent: Vec<RuleAtom>,
        pub consequent: Vec<RuleAtom>,
    }

    #[derive(Clone)]
    pub enum RuleAtom {
        ClassAssertion { class: String, individual: String },
        PropertyAssertion { property: String, subject: String, object: String },
        SameAs { a: String, b: String },
        DifferentFrom { a: String, b: String },
    }

    impl InferenceEngine {
        pub fn new() -> Self {
            Self { rules: Vec::new() }
        }

        pub fn add_rule(&mut self, rule: InferenceRule) {
            self.rules.push(rule);
        }

        pub fn add_subclass_rule(&mut self) {
            // If X is instance of SubClass and SubClass subClassOf SuperClass, then X is instance of SuperClass
            self.rules.push(InferenceRule {
                name: "SubclassInference".to_string(),
                antecedent: vec![
                    RuleAtom::ClassAssertion { class: "?subclass".to_string(), individual: "?x".to_string() },
                ],
                consequent: vec![
                    RuleAtom::ClassAssertion { class: "?superclass".to_string(), individual: "?x".to_string() },
                ],
            });
        }

        pub fn add_transitivity_rule(&mut self, property: &str) {
            self.rules.push(InferenceRule {
                name: format!("Transitivity_{}", property),
                antecedent: vec![
                    RuleAtom::PropertyAssertion { property: property.to_string(), subject: "?x".to_string(), object: "?y".to_string() },
                    RuleAtom::PropertyAssertion { property: property.to_string(), subject: "?y".to_string(), object: "?z".to_string() },
                ],
                consequent: vec![
                    RuleAtom::PropertyAssertion { property: property.to_string(), subject: "?x".to_string(), object: "?z".to_string() },
                ],
            });
        }

        pub fn add_symmetry_rule(&mut self, property: &str) {
            self.rules.push(InferenceRule {
                name: format!("Symmetry_{}", property),
                antecedent: vec![
                    RuleAtom::PropertyAssertion { property: property.to_string(), subject: "?x".to_string(), object: "?y".to_string() },
                ],
                consequent: vec![
                    RuleAtom::PropertyAssertion { property: property.to_string(), subject: "?y".to_string(), object: "?x".to_string() },
                ],
            });
        }

        pub fn rule_count(&self) -> usize { self.rules.len() }
    }

    // Semantic Similarity
    pub struct SemanticSimilarity;

    impl SemanticSimilarity {
        pub fn wu_palmer(ontology: &Ontology, class1: &str, class2: &str) -> f64 {
            // Simplified Wu-Palmer similarity
            let lca_depth = Self::find_lca_depth(ontology, class1, class2);
            let depth1 = Self::class_depth(ontology, class1);
            let depth2 = Self::class_depth(ontology, class2);

            if depth1 + depth2 == 0 {
                return 0.0;
            }

            (2.0 * lca_depth as f64) / (depth1 + depth2) as f64
        }

        fn class_depth(ontology: &Ontology, class_uri: &str) -> usize {
            let mut depth = 0;
            let mut current = class_uri.to_string();

            while let Some(class) = ontology.get_class(&current) {
                if let Some(parent) = &class.parent {
                    depth += 1;
                    current = parent.clone();
                } else {
                    break;
                }
            }
            depth
        }

        fn find_lca_depth(ontology: &Ontology, class1: &str, class2: &str) -> usize {
            let ancestors1 = Self::get_ancestors(ontology, class1);
            let ancestors2 = Self::get_ancestors(ontology, class2);

            for (depth, ancestor) in ancestors1.iter().enumerate() {
                if ancestors2.contains(ancestor) {
                    return ancestors1.len() - depth;
                }
            }
            0
        }

        fn get_ancestors(ontology: &Ontology, class_uri: &str) -> Vec<String> {
            let mut ancestors = Vec::new();
            let mut current = class_uri.to_string();

            while let Some(class) = ontology.get_class(&current) {
                ancestors.push(current.clone());
                if let Some(parent) = &class.parent {
                    current = parent.clone();
                } else {
                    break;
                }
            }
            ancestors
        }

        pub fn path_similarity(ontology: &Ontology, class1: &str, class2: &str) -> f64 {
            let path_length = Self::shortest_path_length(ontology, class1, class2);
            if path_length == 0 {
                return 1.0;
            }
            1.0 / path_length as f64
        }

        fn shortest_path_length(ontology: &Ontology, class1: &str, class2: &str) -> usize {
            let ancestors1 = Self::get_ancestors(ontology, class1);
            let ancestors2 = Self::get_ancestors(ontology, class2);

            for (i, a1) in ancestors1.iter().enumerate() {
                for (j, a2) in ancestors2.iter().enumerate() {
                    if a1 == a2 {
                        return i + j;
                    }
                }
            }
            usize::MAX
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Expert Systems
// ═══════════════════════════════════════════════════════════════════════════════

pub mod expert_systems {
    use super::*;

    // Fact
    #[derive(Clone, Debug, PartialEq, Eq, Hash)]
    pub struct Fact {
        pub predicate: String,
        pub arguments: Vec<String>,
    }

    impl Fact {
        pub fn new(predicate: &str, arguments: Vec<&str>) -> Self {
            Self {
                predicate: predicate.to_string(),
                arguments: arguments.into_iter().map(|s| s.to_string()).collect(),
            }
        }
    }

    // Rule
    #[derive(Clone)]
    pub struct Rule {
        pub name: String,
        pub conditions: Vec<Condition>,
        pub actions: Vec<Action>,
        pub priority: i32,
    }

    #[derive(Clone)]
    pub enum Condition {
        FactExists(Fact),
        FactNotExists(Fact),
        Compare { left: String, op: CompareOp, right: String },
        And(Vec<Condition>),
        Or(Vec<Condition>),
    }

    #[derive(Clone)]
    pub enum CompareOp { Eq, Ne, Lt, Le, Gt, Ge }

    #[derive(Clone)]
    pub enum Action {
        AssertFact(Fact),
        RetractFact(Fact),
        SetVariable { name: String, value: String },
        Print(String),
    }

    // Working Memory
    pub struct WorkingMemory {
        facts: HashSet<Fact>,
        variables: HashMap<String, String>,
    }

    impl WorkingMemory {
        pub fn new() -> Self {
            Self { facts: HashSet::new(), variables: HashMap::new() }
        }

        pub fn assert_fact(&mut self, fact: Fact) {
            self.facts.insert(fact);
        }

        pub fn retract_fact(&mut self, fact: &Fact) {
            self.facts.remove(fact);
        }

        pub fn has_fact(&self, fact: &Fact) -> bool {
            self.facts.contains(fact)
        }

        pub fn get_facts(&self) -> &HashSet<Fact> {
            &self.facts
        }

        pub fn set_variable(&mut self, name: &str, value: &str) {
            self.variables.insert(name.to_string(), value.to_string());
        }

        pub fn get_variable(&self, name: &str) -> Option<&String> {
            self.variables.get(name)
        }

        pub fn query(&self, predicate: &str) -> Vec<&Fact> {
            self.facts.iter().filter(|f| f.predicate == predicate).collect()
        }
    }

    // Forward Chaining Engine
    pub struct ForwardChainingEngine {
        rules: Vec<Rule>,
        memory: WorkingMemory,
        fired_rules: HashSet<String>,
    }

    impl ForwardChainingEngine {
        pub fn new() -> Self {
            Self {
                rules: Vec::new(),
                memory: WorkingMemory::new(),
                fired_rules: HashSet::new(),
            }
        }

        pub fn add_rule(&mut self, rule: Rule) {
            self.rules.push(rule);
            self.rules.sort_by_key(|r| -r.priority);
        }

        pub fn assert_fact(&mut self, fact: Fact) {
            self.memory.assert_fact(fact);
        }

        pub fn run(&mut self, max_iterations: usize) -> Vec<String> {
            let mut log = Vec::new();
            let mut iteration = 0;

            while iteration < max_iterations {
                let mut fired = false;

                for rule in &self.rules {
                    if self.fired_rules.contains(&rule.name) {
                        continue;
                    }

                    if self.evaluate_conditions(&rule.conditions) {
                        log.push(format!("Fired rule: {}", rule.name));
                        self.execute_actions(&rule.actions, &mut log);
                        self.fired_rules.insert(rule.name.clone());
                        fired = true;
                        break;
                    }
                }

                if !fired {
                    break;
                }
                iteration += 1;
            }
            log
        }

        fn evaluate_conditions(&self, conditions: &[Condition]) -> bool {
            conditions.iter().all(|c| self.evaluate_condition(c))
        }

        fn evaluate_condition(&self, condition: &Condition) -> bool {
            match condition {
                Condition::FactExists(fact) => self.memory.has_fact(fact),
                Condition::FactNotExists(fact) => !self.memory.has_fact(fact),
                Condition::Compare { left, op, right } => {
                    let l = self.resolve_value(left);
                    let r = self.resolve_value(right);
                    match op {
                        CompareOp::Eq => l == r,
                        CompareOp::Ne => l != r,
                        CompareOp::Lt => l < r,
                        CompareOp::Le => l <= r,
                        CompareOp::Gt => l > r,
                        CompareOp::Ge => l >= r,
                    }
                }
                Condition::And(conds) => conds.iter().all(|c| self.evaluate_condition(c)),
                Condition::Or(conds) => conds.iter().any(|c| self.evaluate_condition(c)),
            }
        }

        fn resolve_value(&self, value: &str) -> String {
            if value.starts_with('$') {
                self.memory.get_variable(&value[1..]).cloned().unwrap_or_default()
            } else {
                value.to_string()
            }
        }

        fn execute_actions(&mut self, actions: &[Action], log: &mut Vec<String>) {
            for action in actions {
                match action {
                    Action::AssertFact(fact) => {
                        self.memory.assert_fact(fact.clone());
                        log.push(format!("Asserted: {:?}", fact));
                    }
                    Action::RetractFact(fact) => {
                        self.memory.retract_fact(fact);
                        log.push(format!("Retracted: {:?}", fact));
                    }
                    Action::SetVariable { name, value } => {
                        self.memory.set_variable(name, value);
                        log.push(format!("Set {} = {}", name, value));
                    }
                    Action::Print(msg) => {
                        log.push(format!("Print: {}", msg));
                    }
                }
            }
        }

        pub fn get_memory(&self) -> &WorkingMemory { &self.memory }
    }

    // Backward Chaining Engine
    pub struct BackwardChainingEngine {
        rules: Vec<BackwardRule>,
        facts: HashSet<Fact>,
    }

    pub struct BackwardRule {
        pub head: Fact,
        pub body: Vec<Fact>,
    }

    impl BackwardChainingEngine {
        pub fn new() -> Self {
            Self { rules: Vec::new(), facts: HashSet::new() }
        }

        pub fn add_rule(&mut self, rule: BackwardRule) {
            self.rules.push(rule);
        }

        pub fn add_fact(&mut self, fact: Fact) {
            self.facts.insert(fact);
        }

        pub fn prove(&self, goal: &Fact) -> bool {
            self.prove_internal(goal, &mut HashSet::new())
        }

        fn prove_internal(&self, goal: &Fact, visited: &mut HashSet<Fact>) -> bool {
            // Avoid infinite loops
            if visited.contains(goal) {
                return false;
            }
            visited.insert(goal.clone());

            // Check if goal is a known fact
            if self.facts.contains(goal) {
                return true;
            }

            // Try to prove using rules
            for rule in &self.rules {
                if self.unify(&rule.head, goal).is_some() {
                    let all_proved = rule.body.iter().all(|subgoal| {
                        self.prove_internal(subgoal, visited)
                    });
                    if all_proved {
                        return true;
                    }
                }
            }

            false
        }

        fn unify(&self, pattern: &Fact, goal: &Fact) -> Option<HashMap<String, String>> {
            if pattern.predicate != goal.predicate || pattern.arguments.len() != goal.arguments.len() {
                return None;
            }

            let mut bindings = HashMap::new();
            for (p, g) in pattern.arguments.iter().zip(&goal.arguments) {
                if p.starts_with('?') {
                    bindings.insert(p.clone(), g.clone());
                } else if p != g {
                    return None;
                }
            }
            Some(bindings)
        }
    }

    // Decision Table
    pub struct DecisionTable {
        conditions: Vec<String>,
        actions: Vec<String>,
        rules: Vec<DecisionTableRule>,
    }

    pub struct DecisionTableRule {
        condition_values: Vec<Option<bool>>,
        action_values: Vec<bool>,
    }

    impl DecisionTable {
        pub fn new(conditions: Vec<String>, actions: Vec<String>) -> Self {
            Self { conditions, actions, rules: Vec::new() }
        }

        pub fn add_rule(&mut self, condition_values: Vec<Option<bool>>, action_values: Vec<bool>) {
            assert_eq!(condition_values.len(), self.conditions.len());
            assert_eq!(action_values.len(), self.actions.len());
            self.rules.push(DecisionTableRule { condition_values, action_values });
        }

        pub fn evaluate(&self, condition_states: &HashMap<String, bool>) -> Vec<String> {
            for rule in &self.rules {
                let matches = rule.condition_values.iter()
                    .zip(&self.conditions)
                    .all(|(expected, cond_name)| {
                        match expected {
                            Some(val) => condition_states.get(cond_name) == Some(val),
                            None => true, // Don't care
                        }
                    });

                if matches {
                    return self.actions.iter()
                        .zip(&rule.action_values)
                        .filter_map(|(action, &active)| {
                            if active { Some(action.clone()) } else { None }
                        })
                        .collect();
                }
            }
            Vec::new()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Bayesian Networks
// ═══════════════════════════════════════════════════════════════════════════════

pub mod bayesian_networks {
    use super::*;

    #[derive(Clone)]
    pub struct BayesianNode {
        pub name: String,
        pub states: Vec<String>,
        pub parents: Vec<String>,
        pub cpt: Vec<f64>, // Conditional Probability Table
    }

    impl BayesianNode {
        pub fn new(name: &str, states: Vec<&str>) -> Self {
            Self {
                name: name.to_string(),
                states: states.into_iter().map(|s| s.to_string()).collect(),
                parents: Vec::new(),
                cpt: Vec::new(),
            }
        }

        pub fn with_parents(mut self, parents: Vec<&str>) -> Self {
            self.parents = parents.into_iter().map(|s| s.to_string()).collect();
            self
        }

        pub fn with_cpt(mut self, cpt: Vec<f64>) -> Self {
            self.cpt = cpt;
            self
        }

        pub fn num_states(&self) -> usize { self.states.len() }
    }

    pub struct BayesianNetwork {
        nodes: HashMap<String, BayesianNode>,
        topological_order: Vec<String>,
    }

    impl BayesianNetwork {
        pub fn new() -> Self {
            Self { nodes: HashMap::new(), topological_order: Vec::new() }
        }

        pub fn add_node(&mut self, node: BayesianNode) {
            self.nodes.insert(node.name.clone(), node);
            self.update_topological_order();
        }

        fn update_topological_order(&mut self) {
            let mut order = Vec::new();
            let mut visited = HashSet::new();

            fn visit(
                name: &str,
                nodes: &HashMap<String, BayesianNode>,
                visited: &mut HashSet<String>,
                order: &mut Vec<String>,
            ) {
                if visited.contains(name) { return; }
                visited.insert(name.to_string());

                if let Some(node) = nodes.get(name) {
                    for parent in &node.parents {
                        visit(parent, nodes, visited, order);
                    }
                }
                order.push(name.to_string());
            }

            for name in self.nodes.keys() {
                visit(name, &self.nodes, &mut visited, &mut order);
            }

            self.topological_order = order;
        }

        pub fn get_probability(&self, node_name: &str, state_idx: usize, evidence: &HashMap<String, usize>) -> f64 {
            let node = match self.nodes.get(node_name) {
                Some(n) => n,
                None => return 0.0,
            };

            if node.parents.is_empty() {
                return node.cpt.get(state_idx).copied().unwrap_or(0.0);
            }

            // Calculate CPT index based on parent states
            let mut cpt_idx = state_idx;
            let mut multiplier = node.num_states();

            for parent_name in &node.parents {
                let parent_state = evidence.get(parent_name).copied().unwrap_or(0);
                let parent = self.nodes.get(parent_name).unwrap();
                cpt_idx += parent_state * multiplier;
                multiplier *= parent.num_states();
            }

            node.cpt.get(cpt_idx).copied().unwrap_or(0.0)
        }

        pub fn sample(&self, evidence: &HashMap<String, usize>, seed: u64) -> HashMap<String, usize> {
            let mut rng = seed;
            let mut next = || -> f64 {
                rng = rng.wrapping_mul(6364136223846793005).wrapping_add(1);
                (rng >> 33) as f64 / (1u64 << 31) as f64
            };

            let mut sample = evidence.clone();

            for node_name in &self.topological_order {
                if sample.contains_key(node_name) {
                    continue;
                }

                let node = &self.nodes[node_name];
                let mut cumulative = 0.0;
                let r = next();

                for state_idx in 0..node.num_states() {
                    cumulative += self.get_probability(node_name, state_idx, &sample);
                    if r < cumulative {
                        sample.insert(node_name.clone(), state_idx);
                        break;
                    }
                }

                if !sample.contains_key(node_name) {
                    sample.insert(node_name.clone(), node.num_states() - 1);
                }
            }

            sample
        }

        pub fn rejection_sampling(
            &self,
            query: &str,
            evidence: &HashMap<String, usize>,
            num_samples: usize,
            seed: u64,
        ) -> Vec<f64> {
            let node = match self.nodes.get(query) {
                Some(n) => n,
                None => return vec![],
            };

            let mut counts = vec![0usize; node.num_states()];
            let mut valid_samples = 0;

            for i in 0..num_samples {
                let sample = self.sample(&HashMap::new(), seed.wrapping_add(i as u64));

                // Check if sample matches evidence
                let matches = evidence.iter().all(|(k, v)| sample.get(k) == Some(v));

                if matches {
                    if let Some(&state) = sample.get(query) {
                        counts[state] += 1;
                        valid_samples += 1;
                    }
                }
            }

            if valid_samples == 0 {
                return vec![1.0 / node.num_states() as f64; node.num_states()];
            }

            counts.iter().map(|&c| c as f64 / valid_samples as f64).collect()
        }

        pub fn node_count(&self) -> usize { self.nodes.len() }
    }

    // Naive Bayes Classifier
    pub struct NaiveBayesClassifier {
        classes: Vec<String>,
        class_priors: Vec<f64>,
        feature_likelihoods: Vec<HashMap<String, Vec<f64>>>, // For each class, feature -> P(feature|class)
    }

    impl NaiveBayesClassifier {
        pub fn new() -> Self {
            Self {
                classes: Vec::new(),
                class_priors: Vec::new(),
                feature_likelihoods: Vec::new(),
            }
        }

        pub fn train(&mut self, data: &[(Vec<String>, String)]) {
            // Count classes
            let mut class_counts: HashMap<String, usize> = HashMap::new();
            for (_, label) in data {
                *class_counts.entry(label.clone()).or_default() += 1;
            }

            self.classes = class_counts.keys().cloned().collect();
            let n = data.len() as f64;
            self.class_priors = self.classes.iter()
                .map(|c| *class_counts.get(c).unwrap_or(&0) as f64 / n)
                .collect();

            // Count feature occurrences per class
            self.feature_likelihoods = Vec::new();
            for class in &self.classes {
                let mut feature_counts: HashMap<String, usize> = HashMap::new();
                let class_count = *class_counts.get(class).unwrap_or(&1) as f64;

                for (features, label) in data {
                    if label == class {
                        for feature in features {
                            *feature_counts.entry(feature.clone()).or_default() += 1;
                        }
                    }
                }

                let likelihoods: HashMap<String, Vec<f64>> = feature_counts.into_iter()
                    .map(|(f, c)| (f, vec![c as f64 / class_count]))
                    .collect();

                self.feature_likelihoods.push(likelihoods);
            }
        }

        pub fn predict(&self, features: &[String]) -> Option<(String, f64)> {
            if self.classes.is_empty() {
                return None;
            }

            let mut best_class = None;
            let mut best_prob = f64::NEG_INFINITY;

            for (i, class) in self.classes.iter().enumerate() {
                let mut log_prob = self.class_priors[i].ln();

                for feature in features {
                    if let Some(probs) = self.feature_likelihoods[i].get(feature) {
                        log_prob += probs[0].ln();
                    } else {
                        log_prob += 0.001f64.ln(); // Smoothing
                    }
                }

                if log_prob > best_prob {
                    best_prob = log_prob;
                    best_class = Some(class.clone());
                }
            }

            best_class.map(|c| (c, best_prob.exp()))
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Decision Trees
// ═══════════════════════════════════════════════════════════════════════════════

pub mod decision_trees {
    use super::*;

    #[derive(Clone)]
    pub enum DecisionNode {
        Leaf { label: String, confidence: f64 },
        Branch { feature: usize, threshold: f64, left: Box<DecisionNode>, right: Box<DecisionNode> },
        CategoricalBranch { feature: usize, children: HashMap<String, Box<DecisionNode>> },
    }

    pub struct DecisionTreeClassifier {
        root: Option<DecisionNode>,
        max_depth: usize,
        min_samples_split: usize,
    }

    impl DecisionTreeClassifier {
        pub fn new(max_depth: usize, min_samples_split: usize) -> Self {
            Self { root: None, max_depth, min_samples_split }
        }

        pub fn train(&mut self, data: &[(Vec<f64>, String)]) {
            self.root = Some(self.build_tree(data, 0));
        }

        fn build_tree(&self, data: &[(Vec<f64>, String)], depth: usize) -> DecisionNode {
            // Check stopping conditions
            if data.len() < self.min_samples_split || depth >= self.max_depth {
                return self.create_leaf(data);
            }

            // Check if all labels are the same
            let first_label = &data[0].1;
            if data.iter().all(|(_, l)| l == first_label) {
                return DecisionNode::Leaf {
                    label: first_label.clone(),
                    confidence: 1.0,
                };
            }

            // Find best split
            if let Some((feature, threshold, left_data, right_data)) = self.find_best_split(data) {
                let left = self.build_tree(&left_data, depth + 1);
                let right = self.build_tree(&right_data, depth + 1);

                DecisionNode::Branch {
                    feature,
                    threshold,
                    left: Box::new(left),
                    right: Box::new(right),
                }
            } else {
                self.create_leaf(data)
            }
        }

        fn create_leaf(&self, data: &[(Vec<f64>, String)]) -> DecisionNode {
            let mut counts: HashMap<&String, usize> = HashMap::new();
            for (_, label) in data {
                *counts.entry(label).or_default() += 1;
            }

            let (label, count) = counts.into_iter().max_by_key(|(_, c)| *c).unwrap();
            DecisionNode::Leaf {
                label: label.clone(),
                confidence: count as f64 / data.len() as f64,
            }
        }

        fn find_best_split(&self, data: &[(Vec<f64>, String)]) -> Option<(usize, f64, Vec<(Vec<f64>, String)>, Vec<(Vec<f64>, String)>)> {
            let num_features = data[0].0.len();
            let mut best_gain = 0.0;
            let mut best_split = None;

            let parent_entropy = self.calculate_entropy(data);

            for feature in 0..num_features {
                let mut values: Vec<f64> = data.iter().map(|(f, _)| f[feature]).collect();
                values.sort_by(|a, b| a.partial_cmp(b).unwrap());
                values.dedup();

                for i in 0..values.len().saturating_sub(1) {
                    let threshold = (values[i] + values[i + 1]) / 2.0;

                    let left: Vec<_> = data.iter().filter(|(f, _)| f[feature] <= threshold).cloned().collect();
                    let right: Vec<_> = data.iter().filter(|(f, _)| f[feature] > threshold).cloned().collect();

                    if left.is_empty() || right.is_empty() {
                        continue;
                    }

                    let left_weight = left.len() as f64 / data.len() as f64;
                    let right_weight = right.len() as f64 / data.len() as f64;

                    let info_gain = parent_entropy
                        - left_weight * self.calculate_entropy(&left)
                        - right_weight * self.calculate_entropy(&right);

                    if info_gain > best_gain {
                        best_gain = info_gain;
                        best_split = Some((feature, threshold, left, right));
                    }
                }
            }

            best_split
        }

        fn calculate_entropy(&self, data: &[(Vec<f64>, String)]) -> f64 {
            let mut counts: HashMap<&String, usize> = HashMap::new();
            for (_, label) in data {
                *counts.entry(label).or_default() += 1;
            }

            let n = data.len() as f64;
            counts.values()
                .map(|&c| {
                    let p = c as f64 / n;
                    if p > 0.0 { -p * p.log2() } else { 0.0 }
                })
                .sum()
        }

        pub fn predict(&self, features: &[f64]) -> Option<(String, f64)> {
            self.root.as_ref().map(|node| self.predict_node(node, features))
        }

        fn predict_node(&self, node: &DecisionNode, features: &[f64]) -> (String, f64) {
            match node {
                DecisionNode::Leaf { label, confidence } => (label.clone(), *confidence),
                DecisionNode::Branch { feature, threshold, left, right } => {
                    if features[*feature] <= *threshold {
                        self.predict_node(left, features)
                    } else {
                        self.predict_node(right, features)
                    }
                }
                DecisionNode::CategoricalBranch { .. } => {
                    ("Unknown".to_string(), 0.0)
                }
            }
        }
    }

    // Random Forest
    pub struct RandomForest {
        trees: Vec<DecisionTreeClassifier>,
        num_trees: usize,
        max_depth: usize,
        min_samples_split: usize,
        sample_ratio: f64,
    }

    impl RandomForest {
        pub fn new(num_trees: usize, max_depth: usize, min_samples_split: usize, sample_ratio: f64) -> Self {
            Self {
                trees: Vec::new(),
                num_trees,
                max_depth,
                min_samples_split,
                sample_ratio,
            }
        }

        pub fn train(&mut self, data: &[(Vec<f64>, String)], seed: u64) {
            self.trees.clear();

            for i in 0..self.num_trees {
                let sample = self.bootstrap_sample(data, seed.wrapping_add(i as u64));
                let mut tree = DecisionTreeClassifier::new(self.max_depth, self.min_samples_split);
                tree.train(&sample);
                self.trees.push(tree);
            }
        }

        fn bootstrap_sample(&self, data: &[(Vec<f64>, String)], seed: u64) -> Vec<(Vec<f64>, String)> {
            let mut rng = seed;
            let mut next = || -> usize {
                rng = rng.wrapping_mul(6364136223846793005).wrapping_add(1);
                (rng >> 33) as usize
            };

            let sample_size = (data.len() as f64 * self.sample_ratio) as usize;
            (0..sample_size)
                .map(|_| data[next() % data.len()].clone())
                .collect()
        }

        pub fn predict(&self, features: &[f64]) -> Option<(String, f64)> {
            let mut votes: HashMap<String, usize> = HashMap::new();

            for tree in &self.trees {
                if let Some((label, _)) = tree.predict(features) {
                    *votes.entry(label).or_default() += 1;
                }
            }

            votes.into_iter()
                .max_by_key(|(_, count)| *count)
                .map(|(label, count)| (label, count as f64 / self.trees.len() as f64))
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Planning and Search
// ═══════════════════════════════════════════════════════════════════════════════

pub mod planning {
    use super::*;

    // State for planning
    #[derive(Clone, Debug, PartialEq, Eq, Hash)]
    pub struct PlanState {
        pub predicates: HashSet<String>,
    }

    impl PlanState {
        pub fn new() -> Self {
            Self { predicates: HashSet::new() }
        }

        pub fn with_predicates(predicates: Vec<&str>) -> Self {
            Self {
                predicates: predicates.into_iter().map(|s| s.to_string()).collect(),
            }
        }

        pub fn add(&mut self, predicate: &str) {
            self.predicates.insert(predicate.to_string());
        }

        pub fn remove(&mut self, predicate: &str) {
            self.predicates.remove(predicate);
        }

        pub fn contains(&self, predicate: &str) -> bool {
            self.predicates.contains(predicate)
        }

        pub fn satisfies(&self, goals: &[String]) -> bool {
            goals.iter().all(|g| self.predicates.contains(g))
        }
    }

    // STRIPS-style action
    #[derive(Clone)]
    pub struct PlanAction {
        pub name: String,
        pub preconditions: Vec<String>,
        pub add_effects: Vec<String>,
        pub delete_effects: Vec<String>,
        pub cost: f64,
    }

    impl PlanAction {
        pub fn new(name: &str) -> Self {
            Self {
                name: name.to_string(),
                preconditions: Vec::new(),
                add_effects: Vec::new(),
                delete_effects: Vec::new(),
                cost: 1.0,
            }
        }

        pub fn precondition(mut self, pred: &str) -> Self {
            self.preconditions.push(pred.to_string());
            self
        }

        pub fn adds(mut self, pred: &str) -> Self {
            self.add_effects.push(pred.to_string());
            self
        }

        pub fn deletes(mut self, pred: &str) -> Self {
            self.delete_effects.push(pred.to_string());
            self
        }

        pub fn with_cost(mut self, cost: f64) -> Self {
            self.cost = cost;
            self
        }

        pub fn is_applicable(&self, state: &PlanState) -> bool {
            self.preconditions.iter().all(|p| state.contains(p))
        }

        pub fn apply(&self, state: &PlanState) -> PlanState {
            let mut new_state = state.clone();
            for pred in &self.delete_effects {
                new_state.remove(pred);
            }
            for pred in &self.add_effects {
                new_state.add(pred);
            }
            new_state
        }
    }

    // STRIPS Planner with A*
    pub struct STRIPSPlanner {
        actions: Vec<PlanAction>,
    }

    impl STRIPSPlanner {
        pub fn new() -> Self {
            Self { actions: Vec::new() }
        }

        pub fn add_action(&mut self, action: PlanAction) {
            self.actions.push(action);
        }

        pub fn plan(&self, initial: &PlanState, goals: &[String]) -> Option<Vec<String>> {
            use std::collections::BinaryHeap;
            use std::cmp::Ordering;

            #[derive(Clone)]
            struct SearchNode {
                state: PlanState,
                actions: Vec<String>,
                g_cost: f64,
                f_cost: f64,
            }

            impl PartialEq for SearchNode {
                fn eq(&self, other: &Self) -> bool {
                    self.f_cost == other.f_cost
                }
            }

            impl Eq for SearchNode {}

            impl PartialOrd for SearchNode {
                fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
                    other.f_cost.partial_cmp(&self.f_cost) // Reverse for min-heap
                }
            }

            impl Ord for SearchNode {
                fn cmp(&self, other: &Self) -> Ordering {
                    self.partial_cmp(other).unwrap_or(Ordering::Equal)
                }
            }

            let heuristic = |state: &PlanState| -> f64 {
                goals.iter().filter(|g| !state.contains(g)).count() as f64
            };

            let mut open = BinaryHeap::new();
            let mut closed: HashSet<PlanState> = HashSet::new();

            open.push(SearchNode {
                state: initial.clone(),
                actions: Vec::new(),
                g_cost: 0.0,
                f_cost: heuristic(initial),
            });

            while let Some(current) = open.pop() {
                if current.state.satisfies(goals) {
                    return Some(current.actions);
                }

                if closed.contains(&current.state) {
                    continue;
                }
                closed.insert(current.state.clone());

                for action in &self.actions {
                    if action.is_applicable(&current.state) {
                        let new_state = action.apply(&current.state);

                        if !closed.contains(&new_state) {
                            let g = current.g_cost + action.cost;
                            let h = heuristic(&new_state);

                            let mut new_actions = current.actions.clone();
                            new_actions.push(action.name.clone());

                            open.push(SearchNode {
                                state: new_state,
                                actions: new_actions,
                                g_cost: g,
                                f_cost: g + h,
                            });
                        }
                    }
                }
            }

            None
        }
    }

    // Hierarchical Task Network (HTN) Planning
    pub struct HTNPlanner {
        methods: Vec<HTNMethod>,
        operators: Vec<PlanAction>,
    }

    pub struct HTNMethod {
        pub name: String,
        pub task: String,
        pub preconditions: Vec<String>,
        pub subtasks: Vec<String>,
    }

    impl HTNPlanner {
        pub fn new() -> Self {
            Self { methods: Vec::new(), operators: Vec::new() }
        }

        pub fn add_method(&mut self, method: HTNMethod) {
            self.methods.push(method);
        }

        pub fn add_operator(&mut self, operator: PlanAction) {
            self.operators.push(operator);
        }

        pub fn plan(&self, initial: &PlanState, tasks: &[String]) -> Option<Vec<String>> {
            self.plan_tasks(initial, tasks, 0)
        }

        fn plan_tasks(&self, state: &PlanState, tasks: &[String], depth: usize) -> Option<Vec<String>> {
            if depth > 100 { return None; } // Prevent infinite recursion

            if tasks.is_empty() {
                return Some(Vec::new());
            }

            let task = &tasks[0];
            let remaining = &tasks[1..];

            // Try operators first
            for operator in &self.operators {
                if operator.name == *task && operator.is_applicable(state) {
                    let new_state = operator.apply(state);
                    if let Some(mut plan) = self.plan_tasks(&new_state, &remaining.to_vec(), depth + 1) {
                        plan.insert(0, operator.name.clone());
                        return Some(plan);
                    }
                }
            }

            // Try methods
            for method in &self.methods {
                if method.task == *task {
                    let preconditions_met = method.preconditions.iter().all(|p| state.contains(p));
                    if preconditions_met {
                        let mut new_tasks = method.subtasks.clone();
                        new_tasks.extend(remaining.iter().cloned());

                        if let Some(plan) = self.plan_tasks(state, &new_tasks, depth + 1) {
                            return Some(plan);
                        }
                    }
                }
            }

            None
        }
    }

    // Monte Carlo Tree Search
    pub struct MCTS<S: Clone + Eq + std::hash::Hash, A: Clone> {
        exploration_constant: f64,
        max_iterations: usize,
        _phantom: std::marker::PhantomData<(S, A)>,
    }

    pub struct MCTSNode<S: Clone, A: Clone> {
        state: S,
        action: Option<A>,
        visits: usize,
        value: f64,
        children: Vec<MCTSNode<S, A>>,
        untried_actions: Vec<A>,
    }

    impl<S: Clone + Eq + std::hash::Hash, A: Clone> MCTS<S, A> {
        pub fn new(exploration_constant: f64, max_iterations: usize) -> Self {
            Self {
                exploration_constant,
                max_iterations,
                _phantom: std::marker::PhantomData,
            }
        }

        pub fn ucb1(&self, node_visits: usize, child_visits: usize, child_value: f64) -> f64 {
            if child_visits == 0 {
                return f64::MAX;
            }
            let exploitation = child_value / child_visits as f64;
            let exploration = self.exploration_constant * ((node_visits as f64).ln() / child_visits as f64).sqrt();
            exploitation + exploration
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_dual_arithmetic() {
        let x = Dual::variable(2.0);
        let y = Dual::constant(3.0);
        
        let sum = x.add(&y);
        assert!((sum.value - 5.0).abs() < 1e-10);
        assert!((sum.derivative - 1.0).abs() < 1e-10);
        
        let prod = x.mul(&y);
        assert!((prod.value - 6.0).abs() < 1e-10);
        assert!((prod.derivative - 3.0).abs() < 1e-10);
    }
    
    #[test]
    fn test_dual_chain_rule() {
        // d/dx sin(x^2) at x=1 should be 2*cos(1)
        let x = Dual::variable(1.0);
        let x_sq = x.mul(&x);
        let result = x_sq.sin();
        
        let expected_deriv = 2.0 * cos(1.0);
        assert!((result.derivative - expected_deriv).abs() < 1e-10);
    }
    
    #[test]
    fn test_simplification() {
        // x + 0 = x
        let ast = ASTNode::Add(
            Box::new(ASTNode::Variable("x".to_string())),
            Box::new(ASTNode::Literal(0.0)),
        );
        let simplified = simplify(&ast);
        assert!(matches!(simplified, ASTNode::Variable(ref s) if s == "x"));
        
        // x * 1 = x
        let ast2 = ASTNode::Mul(
            Box::new(ASTNode::Variable("y".to_string())),
            Box::new(ASTNode::Literal(1.0)),
        );
        let simplified2 = simplify(&ast2);
        assert!(matches!(simplified2, ASTNode::Variable(ref s) if s == "y"));
    }
    
    #[test]
    fn test_program_evaluation() {
        // f(x) = x^2 + 2*x + 1
        let ast = ASTNode::Add(
            Box::new(ASTNode::Add(
                Box::new(ASTNode::Mul(
                    Box::new(ASTNode::Variable("x".to_string())),
                    Box::new(ASTNode::Variable("x".to_string())),
                )),
                Box::new(ASTNode::Mul(
                    Box::new(ASTNode::Literal(2.0)),
                    Box::new(ASTNode::Variable("x".to_string())),
                )),
            )),
            Box::new(ASTNode::Literal(1.0)),
        );
        
        let program = Program::new(ast);
        
        let mut env = HashMap::new();
        env.insert("x".to_string(), 3.0);
        
        let result = program.evaluate(&env).unwrap();
        assert!((result - 16.0).abs() < 1e-10); // 9 + 6 + 1 = 16
    }
    
    #[test]
    fn test_ast_size() {
        let ast = ASTNode::Add(
            Box::new(ASTNode::Literal(1.0)),
            Box::new(ASTNode::Mul(
                Box::new(ASTNode::Variable("x".to_string())),
                Box::new(ASTNode::Literal(2.0)),
            )),
        );
        
        assert_eq!(ast.size(), 5); // Add, Lit, Mul, Var, Lit
    }
}
