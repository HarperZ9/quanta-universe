// EXECUTION ALGORITHMS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod execution {
    use super::*;

    /// Time-Weighted Average Price algorithm
    #[derive(Debug, Clone)]
    pub struct TWAP {
        pub symbol: String,
        pub total_quantity: f64,
        pub side: Side,
        pub start_time: DateTime,
        pub end_time: DateTime,
        pub num_slices: usize,
        pub executed_quantity: f64,
        pub executed_slices: usize,
        pub child_orders: Vec<Order>,
    }

    impl TWAP {
        pub fn new(symbol: &str, quantity: f64, side: Side, duration_minutes: i64, num_slices: usize) -> Self {
            let start = DateTime::now();
            TWAP {
                symbol: symbol.to_string(),
                total_quantity: quantity,
                side,
                start_time: start,
                end_time: start.add_minutes(duration_minutes),
                num_slices,
                executed_quantity: 0.0,
                executed_slices: 0,
                child_orders: Vec::new(),
            }
        }

        pub fn slice_quantity(&self) -> f64 {
            self.total_quantity / self.num_slices as f64
        }

        pub fn slice_interval_ms(&self) -> i64 {
            let total_ms = (self.end_time.timestamp - self.start_time.timestamp) * 1000;
            total_ms / self.num_slices as i64
        }

        pub fn should_execute_slice(&self, current_time: &DateTime) -> bool {
            if self.executed_slices >= self.num_slices {
                return false;
            }
            let elapsed = current_time.timestamp - self.start_time.timestamp;
            let expected_slices = (elapsed * 1000 / self.slice_interval_ms().max(1)) as usize;
            expected_slices > self.executed_slices
        }

        pub fn generate_slice_order(&mut self) -> Option<Order> {
            if self.executed_slices >= self.num_slices {
                return None;
            }
            let remaining = self.total_quantity - self.executed_quantity;
            let slice_qty = (self.slice_quantity()).min(remaining);
            if slice_qty <= 0.0 {
                return None;
            }

            let order = Order {
                id: format!("{}_slice_{}", self.symbol, self.executed_slices),
                symbol: self.symbol.clone(),
                side: self.side.clone(),
                order_type: OrderType::Market,
                quantity: slice_qty,
                limit_price: None,
                stop_price: None,
                time_in_force: TimeInForce::IOC,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            };
            self.child_orders.push(order.clone());
            self.executed_slices += 1;
            Some(order)
        }

        pub fn on_fill(&mut self, quantity: f64, _price: f64) {
            self.executed_quantity += quantity;
        }

        pub fn completion_ratio(&self) -> f64 {
            self.executed_quantity / self.total_quantity
        }

        pub fn is_complete(&self) -> bool {
            self.executed_quantity >= self.total_quantity * 0.9999
        }

        pub fn vwap_achieved(&self) -> f64 {
            let mut total_value = 0.0;
            let mut total_qty = 0.0;
            for order in &self.child_orders {
                if order.filled_quantity > 0.0 {
                    total_value += order.filled_quantity * order.average_fill_price;
                    total_qty += order.filled_quantity;
                }
            }
            if total_qty > 0.0 { total_value / total_qty } else { 0.0 }
        }
    }

    /// Volume-Weighted Average Price algorithm
    #[derive(Debug, Clone)]
    pub struct VWAP {
        pub symbol: String,
        pub total_quantity: f64,
        pub side: Side,
        pub volume_profile: Vec<f64>,
        pub executed_quantity: f64,
        pub current_bucket: usize,
        pub child_orders: Vec<Order>,
        pub participation_rate: f64,
    }

    impl VWAP {
        pub fn new(symbol: &str, quantity: f64, side: Side, volume_profile: Vec<f64>) -> Self {
            VWAP {
                symbol: symbol.to_string(),
                total_quantity: quantity,
                side,
                volume_profile,
                executed_quantity: 0.0,
                current_bucket: 0,
                child_orders: Vec::new(),
                participation_rate: 0.1,
            }
        }

        pub fn with_participation_rate(mut self, rate: f64) -> Self {
            self.participation_rate = rate.clamp(0.01, 0.5);
            self
        }

        pub fn bucket_target(&self, bucket: usize) -> f64 {
            if bucket >= self.volume_profile.len() {
                return 0.0;
            }
            let total_profile: f64 = self.volume_profile.iter().sum();
            if total_profile <= 0.0 {
                return self.total_quantity / self.volume_profile.len() as f64;
            }
            self.total_quantity * (self.volume_profile[bucket] / total_profile)
        }

        pub fn on_market_volume(&mut self, bucket: usize, market_volume: f64) -> Option<Order> {
            self.current_bucket = bucket;
            let target = self.bucket_target(bucket);
            let max_participation = market_volume * self.participation_rate;
            let qty = target.min(max_participation).min(self.total_quantity - self.executed_quantity);

            if qty <= 0.0 {
                return None;
            }

            let order = Order {
                id: format!("{}_vwap_{}", self.symbol, bucket),
                symbol: self.symbol.clone(),
                side: self.side.clone(),
                order_type: OrderType::Market,
                quantity: qty,
                limit_price: None,
                stop_price: None,
                time_in_force: TimeInForce::IOC,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            };
            self.child_orders.push(order.clone());
            Some(order)
        }

        pub fn on_fill(&mut self, quantity: f64, _price: f64) {
            self.executed_quantity += quantity;
        }

        pub fn is_complete(&self) -> bool {
            self.executed_quantity >= self.total_quantity * 0.9999
        }
    }

    /// Iceberg order - hides total quantity
    #[derive(Debug, Clone)]
    pub struct IcebergOrder {
        pub symbol: String,
        pub total_quantity: f64,
        pub display_quantity: f64,
        pub side: Side,
        pub limit_price: f64,
        pub executed_quantity: f64,
        pub active_order: Option<Order>,
        pub variance: f64,
    }

    impl IcebergOrder {
        pub fn new(symbol: &str, total_qty: f64, display_qty: f64, side: Side, price: f64) -> Self {
            IcebergOrder {
                symbol: symbol.to_string(),
                total_quantity: total_qty,
                display_quantity: display_qty,
                side,
                limit_price: price,
                executed_quantity: 0.0,
                active_order: None,
                variance: 0.1,
            }
        }

        pub fn with_variance(mut self, v: f64) -> Self {
            self.variance = v.clamp(0.0, 0.5);
            self
        }

        fn randomized_display(&self) -> f64 {
            let factor = 1.0 + (rand_f64() - 0.5) * 2.0 * self.variance;
            self.display_quantity * factor
        }

        pub fn get_or_create_order(&mut self) -> Option<Order> {
            if self.executed_quantity >= self.total_quantity {
                return None;
            }
            if self.active_order.is_some() {
                return self.active_order.clone();
            }

            let remaining = self.total_quantity - self.executed_quantity;
            let qty = self.randomized_display().min(remaining);

            let order = Order {
                id: format!("{}_ice_{}", self.symbol, self.executed_quantity as i64),
                symbol: self.symbol.clone(),
                side: self.side.clone(),
                order_type: OrderType::Limit,
                quantity: qty,
                limit_price: Some(self.limit_price),
                stop_price: None,
                time_in_force: TimeInForce::GTC,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            };
            self.active_order = Some(order.clone());
            Some(order)
        }

        pub fn on_fill(&mut self, quantity: f64) {
            self.executed_quantity += quantity;
            if let Some(ref mut order) = self.active_order {
                order.filled_quantity += quantity;
                if order.filled_quantity >= order.quantity * 0.9999 {
                    self.active_order = None;
                }
            }
        }

        pub fn is_complete(&self) -> bool {
            self.executed_quantity >= self.total_quantity * 0.9999
        }
    }

    /// Implementation Shortfall algorithm
    #[derive(Debug, Clone)]
    pub struct ImplementationShortfall {
        pub symbol: String,
        pub total_quantity: f64,
        pub side: Side,
        pub arrival_price: f64,
        pub urgency: f64,
        pub risk_aversion: f64,
        pub volatility: f64,
        pub executed_quantity: f64,
        pub slippage_cost: f64,
    }

    impl ImplementationShortfall {
        pub fn new(symbol: &str, qty: f64, side: Side, arrival_price: f64, vol: f64) -> Self {
            ImplementationShortfall {
                symbol: symbol.to_string(),
                total_quantity: qty,
                side,
                arrival_price,
                urgency: 0.5,
                risk_aversion: 0.001,
                volatility: vol,
                executed_quantity: 0.0,
                slippage_cost: 0.0,
            }
        }

        pub fn with_urgency(mut self, u: f64) -> Self {
            self.urgency = u.clamp(0.0, 1.0);
            self
        }

        /// Almgren-Chriss optimal trajectory
        pub fn optimal_trajectory(&self, num_periods: usize) -> Vec<f64> {
            let kappa = self.urgency * (self.risk_aversion / self.volatility).sqrt();
            let mut trajectory = Vec::with_capacity(num_periods + 1);

            for j in 0..=num_periods {
                let t = j as f64 / num_periods as f64;
                let remaining = (kappa * (1.0 - t)).sinh() / kappa.sinh();
                trajectory.push(self.total_quantity * remaining);
            }
            trajectory
        }

        pub fn target_quantity_at(&self, time_fraction: f64, num_periods: usize) -> f64 {
            let traj = self.optimal_trajectory(num_periods);
            let idx = ((1.0 - time_fraction) * num_periods as f64).round() as usize;
            self.total_quantity - traj.get(idx).copied().unwrap_or(0.0)
        }

        pub fn on_fill(&mut self, qty: f64, price: f64) {
            let slip = match self.side {
                Side::Buy => price - self.arrival_price,
                Side::Sell => self.arrival_price - price,
            };
            self.slippage_cost += slip * qty;
            self.executed_quantity += qty;
        }

        pub fn implementation_shortfall_bps(&self) -> f64 {
            if self.executed_quantity == 0.0 || self.arrival_price == 0.0 {
                return 0.0;
            }
            (self.slippage_cost / (self.executed_quantity * self.arrival_price)) * 10000.0
        }
    }

    /// Percentage of Volume (POV) algorithm
    #[derive(Debug, Clone)]
    pub struct POV {
        pub symbol: String,
        pub total_quantity: f64,
        pub side: Side,
        pub target_rate: f64,
        pub min_rate: f64,
        pub max_rate: f64,
        pub executed_quantity: f64,
        pub market_volume_seen: f64,
    }

    impl POV {
        pub fn new(symbol: &str, qty: f64, side: Side, target_rate: f64) -> Self {
            POV {
                symbol: symbol.to_string(),
                total_quantity: qty,
                side,
                target_rate: target_rate.clamp(0.01, 0.5),
                min_rate: 0.01,
                max_rate: 0.25,
                executed_quantity: 0.0,
                market_volume_seen: 0.0,
            }
        }

        pub fn on_market_trade(&mut self, volume: f64, price: f64) -> Option<Order> {
            self.market_volume_seen += volume;

            let target_exec = self.market_volume_seen * self.target_rate;
            let shortfall = target_exec - self.executed_quantity;

            if shortfall <= 0.0 || self.executed_quantity >= self.total_quantity {
                return None;
            }

            let qty = shortfall.min(self.total_quantity - self.executed_quantity);

            Some(Order {
                id: format!("{}_pov_{}", self.symbol, self.market_volume_seen as i64),
                symbol: self.symbol.clone(),
                side: self.side.clone(),
                order_type: OrderType::Limit,
                quantity: qty,
                limit_price: Some(price),
                stop_price: None,
                time_in_force: TimeInForce::IOC,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            })
        }

        pub fn on_fill(&mut self, qty: f64) {
            self.executed_quantity += qty;
        }

        pub fn actual_participation_rate(&self) -> f64 {
            if self.market_volume_seen > 0.0 {
                self.executed_quantity / self.market_volume_seen
            } else {
                0.0
            }
        }
    }

    /// Smart Order Router
    #[derive(Debug, Clone)]
    pub struct SmartOrderRouter {
        pub venues: Vec<VenueInfo>,
        pub routing_strategy: RoutingStrategy,
    }

    #[derive(Debug, Clone)]
    pub struct VenueInfo {
        pub name: String,
        pub fee_maker: f64,
        pub fee_taker: f64,
        pub rebate: f64,
        pub latency_ms: f64,
        pub fill_rate: f64,
        pub available_liquidity: f64,
    }

    #[derive(Debug, Clone)]
    pub enum RoutingStrategy {
        BestPrice,
        LowestFee,
        HighestFillRate,
        Spray,
        Sequential,
    }

    impl SmartOrderRouter {
        pub fn new() -> Self {
            SmartOrderRouter {
                venues: Vec::new(),
                routing_strategy: RoutingStrategy::BestPrice,
            }
        }

        pub fn add_venue(&mut self, venue: VenueInfo) {
            self.venues.push(venue);
        }

        pub fn with_strategy(mut self, strategy: RoutingStrategy) -> Self {
            self.routing_strategy = strategy;
            self
        }

        pub fn route(&self, order: &Order, prices: &HashMap<String, f64>) -> Vec<(String, f64)> {
            match self.routing_strategy {
                RoutingStrategy::BestPrice => self.route_best_price(order, prices),
                RoutingStrategy::LowestFee => self.route_lowest_fee(order),
                RoutingStrategy::HighestFillRate => self.route_highest_fill(order),
                RoutingStrategy::Spray => self.route_spray(order),
                RoutingStrategy::Sequential => self.route_sequential(order),
            }
        }

        fn route_best_price(&self, order: &Order, prices: &HashMap<String, f64>) -> Vec<(String, f64)> {
            let mut venues_with_prices: Vec<_> = self.venues.iter()
                .filter_map(|v| {
                    prices.get(&v.name).map(|&p| (v.name.clone(), p, v.available_liquidity))
                })
                .collect();

            match order.side {
                Side::Buy => venues_with_prices.sort_by(|a, b| a.1.partial_cmp(&b.1).unwrap()),
                Side::Sell => venues_with_prices.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap()),
            }

            let mut remaining = order.quantity;
            let mut allocations = Vec::new();

            for (venue, _, liq) in venues_with_prices {
                if remaining <= 0.0 { break; }
                let fill = remaining.min(liq);
                allocations.push((venue, fill));
                remaining -= fill;
            }
            allocations
        }

        fn route_lowest_fee(&self, order: &Order) -> Vec<(String, f64)> {
            let mut sorted: Vec<_> = self.venues.iter().collect();
            sorted.sort_by(|a, b| a.fee_taker.partial_cmp(&b.fee_taker).unwrap());

            let mut remaining = order.quantity;
            let mut allocations = Vec::new();

            for venue in sorted {
                if remaining <= 0.0 { break; }
                let fill = remaining.min(venue.available_liquidity);
                allocations.push((venue.name.clone(), fill));
                remaining -= fill;
            }
            allocations
        }

        fn route_highest_fill(&self, order: &Order) -> Vec<(String, f64)> {
            let mut sorted: Vec<_> = self.venues.iter().collect();
            sorted.sort_by(|a, b| b.fill_rate.partial_cmp(&a.fill_rate).unwrap());

            let mut remaining = order.quantity;
            let mut allocations = Vec::new();

            for venue in sorted {
                if remaining <= 0.0 { break; }
                let fill = remaining.min(venue.available_liquidity);
                allocations.push((venue.name.clone(), fill));
                remaining -= fill;
            }
            allocations
        }

        fn route_spray(&self, order: &Order) -> Vec<(String, f64)> {
            let total_liq: f64 = self.venues.iter().map(|v| v.available_liquidity).sum();
            if total_liq == 0.0 {
                return vec![];
            }

            self.venues.iter()
                .map(|v| {
                    let alloc = order.quantity * (v.available_liquidity / total_liq);
                    (v.name.clone(), alloc.min(v.available_liquidity))
                })
                .filter(|(_, q)| *q > 0.0)
                .collect()
        }

        fn route_sequential(&self, order: &Order) -> Vec<(String, f64)> {
            let mut remaining = order.quantity;
            let mut allocations = Vec::new();

            for venue in &self.venues {
                if remaining <= 0.0 { break; }
                let fill = remaining.min(venue.available_liquidity);
                allocations.push((venue.name.clone(), fill));
                remaining -= fill;
            }
            allocations
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET MICROSTRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod microstructure {
    use super::*;

    /// Limit Order Book
    #[derive(Debug, Clone)]
    pub struct OrderBook {
        pub symbol: String,
        pub bids: Vec<PriceLevel>,
        pub asks: Vec<PriceLevel>,
        pub last_update: DateTime,
    }

    #[derive(Debug, Clone)]
    pub struct PriceLevel {
        pub price: f64,
        pub quantity: f64,
        pub order_count: usize,
        pub orders: Vec<BookOrder>,
    }

    #[derive(Debug, Clone)]
    pub struct BookOrder {
        pub id: String,
        pub quantity: f64,
        pub timestamp: DateTime,
    }

    impl OrderBook {
        pub fn new(symbol: &str) -> Self {
            OrderBook {
                symbol: symbol.to_string(),
                bids: Vec::new(),
                asks: Vec::new(),
                last_update: DateTime::now(),
            }
        }

        pub fn best_bid(&self) -> Option<f64> {
            self.bids.first().map(|l| l.price)
        }

        pub fn best_ask(&self) -> Option<f64> {
            self.asks.first().map(|l| l.price)
        }

        pub fn mid_price(&self) -> Option<f64> {
            match (self.best_bid(), self.best_ask()) {
                (Some(b), Some(a)) => Some((b + a) / 2.0),
                _ => None,
            }
        }

        pub fn spread(&self) -> Option<f64> {
            match (self.best_bid(), self.best_ask()) {
                (Some(b), Some(a)) => Some(a - b),
                _ => None,
            }
        }

        pub fn spread_bps(&self) -> Option<f64> {
            match (self.spread(), self.mid_price()) {
                (Some(s), Some(m)) if m > 0.0 => Some(s / m * 10000.0),
                _ => None,
            }
        }

        pub fn bid_depth(&self, levels: usize) -> f64 {
            self.bids.iter().take(levels).map(|l| l.quantity).sum()
        }

        pub fn ask_depth(&self, levels: usize) -> f64 {
            self.asks.iter().take(levels).map(|l| l.quantity).sum()
        }

        pub fn imbalance(&self, levels: usize) -> f64 {
            let bid_d = self.bid_depth(levels);
            let ask_d = self.ask_depth(levels);
            let total = bid_d + ask_d;
            if total > 0.0 {
                (bid_d - ask_d) / total
            } else {
                0.0
            }
        }

        pub fn vwap_bid(&self, quantity: f64) -> Option<f64> {
            self.vwap_side(&self.bids, quantity)
        }

        pub fn vwap_ask(&self, quantity: f64) -> Option<f64> {
            self.vwap_side(&self.asks, quantity)
        }

        fn vwap_side(&self, levels: &[PriceLevel], quantity: f64) -> Option<f64> {
            let mut remaining = quantity;
            let mut total_value = 0.0;
            let mut total_qty = 0.0;

            for level in levels {
                if remaining <= 0.0 { break; }
                let fill = remaining.min(level.quantity);
                total_value += fill * level.price;
                total_qty += fill;
                remaining -= fill;
            }

            if total_qty > 0.0 {
                Some(total_value / total_qty)
            } else {
                None
            }
        }

        pub fn market_impact_buy(&self, quantity: f64) -> Option<f64> {
            let mid = self.mid_price()?;
            let vwap = self.vwap_ask(quantity)?;
            Some((vwap - mid) / mid * 10000.0)
        }

        pub fn market_impact_sell(&self, quantity: f64) -> Option<f64> {
            let mid = self.mid_price()?;
            let vwap = self.vwap_bid(quantity)?;
            Some((mid - vwap) / mid * 10000.0)
        }

        pub fn add_order(&mut self, side: Side, price: f64, quantity: f64, order_id: &str) {
            let levels = match side {
                Side::Buy => &mut self.bids,
                Side::Sell => &mut self.asks,
            };

            let order = BookOrder {
                id: order_id.to_string(),
                quantity,
                timestamp: DateTime::now(),
            };

            if let Some(level) = levels.iter_mut().find(|l| (l.price - price).abs() < 1e-10) {
                level.quantity += quantity;
                level.order_count += 1;
                level.orders.push(order);
            } else {
                let new_level = PriceLevel {
                    price,
                    quantity,
                    order_count: 1,
                    orders: vec![order],
                };
                levels.push(new_level);
                match side {
                    Side::Buy => levels.sort_by(|a, b| b.price.partial_cmp(&a.price).unwrap()),
                    Side::Sell => levels.sort_by(|a, b| a.price.partial_cmp(&b.price).unwrap()),
                }
            }
            self.last_update = DateTime::now();
        }

        pub fn cancel_order(&mut self, side: Side, order_id: &str) -> bool {
            let levels = match side {
                Side::Buy => &mut self.bids,
                Side::Sell => &mut self.asks,
            };

            for level in levels.iter_mut() {
                if let Some(idx) = level.orders.iter().position(|o| o.id == order_id) {
                    let qty = level.orders[idx].quantity;
                    level.orders.remove(idx);
                    level.quantity -= qty;
                    level.order_count -= 1;
                    self.last_update = DateTime::now();
                    return true;
                }
            }
            false
        }

        pub fn execute_market_order(&mut self, side: Side, quantity: f64) -> Vec<(f64, f64)> {
            let levels = match side {
                Side::Buy => &mut self.asks,
                Side::Sell => &mut self.bids,
            };

            let mut remaining = quantity;
            let mut fills = Vec::new();

            while remaining > 0.0 && !levels.is_empty() {
                let level = &mut levels[0];
                let fill_qty = remaining.min(level.quantity);
                fills.push((level.price, fill_qty));
                level.quantity -= fill_qty;
                remaining -= fill_qty;

                if level.quantity <= 0.0 {
                    levels.remove(0);
                }
            }
            self.last_update = DateTime::now();
            fills
        }
    }

    /// Market Maker with inventory management
    #[derive(Debug, Clone)]
    pub struct MarketMaker {
        pub symbol: String,
        pub inventory: f64,
        pub max_inventory: f64,
        pub base_spread: f64,
        pub skew_factor: f64,
        pub fair_value: f64,
        pub active_quotes: Vec<Quote>,
    }

    #[derive(Debug, Clone)]
    pub struct Quote {
        pub bid_price: f64,
        pub bid_size: f64,
        pub ask_price: f64,
        pub ask_size: f64,
        pub timestamp: DateTime,
    }

    impl MarketMaker {
        pub fn new(symbol: &str, max_inv: f64, base_spread: f64) -> Self {
            MarketMaker {
                symbol: symbol.to_string(),
                inventory: 0.0,
                max_inventory: max_inv,
                base_spread: base_spread,
                skew_factor: 0.0001,
                fair_value: 100.0,
                active_quotes: Vec::new(),
            }
        }

        pub fn inventory_ratio(&self) -> f64 {
            self.inventory / self.max_inventory
        }

        pub fn skew(&self) -> f64 {
            -self.inventory_ratio() * self.skew_factor * self.fair_value
        }

        pub fn generate_quote(&mut self, fair_value: f64, volatility: f64) -> Quote {
            self.fair_value = fair_value;

            let vol_spread = volatility * fair_value * 0.5;
            let half_spread = (self.base_spread + vol_spread) / 2.0;
            let skew = self.skew();

            let bid = fair_value - half_spread + skew;
            let ask = fair_value + half_spread + skew;

            let inv_ratio = self.inventory_ratio().abs();
            let bid_size = self.max_inventory * 0.1 * (1.0 - inv_ratio.max(0.0));
            let ask_size = self.max_inventory * 0.1 * (1.0 + inv_ratio.min(0.0));

            let quote = Quote {
                bid_price: bid,
                bid_size: bid_size.max(0.0),
                ask_price: ask,
                ask_size: ask_size.max(0.0),
                timestamp: DateTime::now(),
            };
            self.active_quotes.push(quote.clone());
            quote
        }

        pub fn on_fill(&mut self, side: Side, quantity: f64, price: f64) -> f64 {
            let pnl = match side {
                Side::Buy => {
                    self.inventory += quantity;
                    (self.fair_value - price) * quantity
                }
                Side::Sell => {
                    self.inventory -= quantity;
                    (price - self.fair_value) * quantity
                }
            };
            pnl
        }

        pub fn mark_to_market(&self, current_price: f64) -> f64 {
            self.inventory * (current_price - self.fair_value)
        }
    }

    /// Trade classifier (Lee-Ready algorithm)
    pub struct TradeClassifier {
        pub tick_test_weight: f64,
        pub quote_test_weight: f64,
    }

    impl TradeClassifier {
        pub fn new() -> Self {
            TradeClassifier {
                tick_test_weight: 0.5,
                quote_test_weight: 0.5,
            }
        }

        /// Classify trade as buy (+1) or sell (-1)
        pub fn classify(&self, trade_price: f64, prev_price: f64, bid: f64, ask: f64) -> i32 {
            let mid = (bid + ask) / 2.0;

            // Quote test
            let quote_sign = if trade_price > mid { 1.0 }
                else if trade_price < mid { -1.0 }
                else { 0.0 };

            // Tick test
            let tick_sign = if trade_price > prev_price { 1.0 }
                else if trade_price < prev_price { -1.0 }
                else { 0.0 };

            let combined = self.quote_test_weight * quote_sign + self.tick_test_weight * tick_sign;

            if combined > 0.0 { 1 } else if combined < 0.0 { -1 } else { 1 }
        }

        /// Bulk order flow estimation
        pub fn estimate_order_flow(&self, trades: &[(f64, f64, f64, f64, f64)]) -> f64 {
            let mut flow = 0.0;
            for &(price, prev_price, bid, ask, volume) in trades {
                let sign = self.classify(price, prev_price, bid, ask);
                flow += sign as f64 * volume;
            }
            flow
        }
    }

    /// Kyle's Lambda - price impact coefficient
    pub fn kyle_lambda(prices: &[f64], volumes: &[f64], signs: &[i32]) -> f64 {
        let n = prices.len().min(volumes.len()).min(signs.len());
        if n < 2 { return 0.0; }

        let mut returns = Vec::with_capacity(n - 1);
        let mut signed_volumes = Vec::with_capacity(n - 1);

        for i in 1..n {
            returns.push(prices[i] - prices[i-1]);
            signed_volumes.push(signs[i] as f64 * volumes[i]);
        }

        let r_mean: f64 = returns.iter().sum::<f64>() / returns.len() as f64;
        let v_mean: f64 = signed_volumes.iter().sum::<f64>() / signed_volumes.len() as f64;

        let mut cov = 0.0;
        let mut var = 0.0;

        for i in 0..returns.len() {
            cov += (returns[i] - r_mean) * (signed_volumes[i] - v_mean);
            var += (signed_volumes[i] - v_mean).powi(2);
        }

        if var > 0.0 { cov / var } else { 0.0 }
    }

    /// Amihud illiquidity measure
    pub fn amihud_illiquidity(returns: &[f64], volumes: &[f64]) -> f64 {
        let n = returns.len().min(volumes.len());
        if n == 0 { return 0.0; }

        let mut sum = 0.0;
        let mut count = 0;

        for i in 0..n {
            if volumes[i] > 0.0 {
                sum += returns[i].abs() / volumes[i];
                count += 1;
            }
        }

        if count > 0 { sum / count as f64 } else { 0.0 }
    }

    /// Roll's spread estimator
    pub fn roll_spread(prices: &[f64]) -> f64 {
        if prices.len() < 3 { return 0.0; }

        let mut returns = Vec::with_capacity(prices.len() - 1);
        for i in 1..prices.len() {
            returns.push(prices[i] - prices[i-1]);
        }

        let mut autocovar = 0.0;
        for i in 1..returns.len() {
            autocovar += returns[i] * returns[i-1];
        }
        autocovar /= (returns.len() - 1) as f64;

        if autocovar < 0.0 {
            2.0 * (-autocovar).sqrt()
        } else {
            0.0
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OPTIONS PRICING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod options {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum OptionType {
        Call,
        Put,
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum ExerciseStyle {
        European,
        American,
    }

    #[derive(Debug, Clone)]
    pub struct OptionContract {
        pub underlying: String,
        pub strike: f64,
        pub expiry: DateTime,
        pub option_type: OptionType,
        pub exercise_style: ExerciseStyle,
    }

    /// Black-Scholes pricing model
    pub struct BlackScholes {
        pub spot: f64,
        pub strike: f64,
        pub rate: f64,
        pub volatility: f64,
        pub time_to_expiry: f64,
        pub dividend_yield: f64,
    }

    impl BlackScholes {
        pub fn new(spot: f64, strike: f64, rate: f64, vol: f64, tte: f64) -> Self {
            BlackScholes {
                spot, strike, rate,
                volatility: vol,
                time_to_expiry: tte,
                dividend_yield: 0.0,
            }
        }

        pub fn with_dividend(mut self, div: f64) -> Self {
            self.dividend_yield = div;
            self
        }

        fn d1(&self) -> f64 {
            let s = self.spot * (-self.dividend_yield * self.time_to_expiry).exp();
            let num = (s / self.strike).ln() + (self.rate + 0.5 * self.volatility.powi(2)) * self.time_to_expiry;
            num / (self.volatility * self.time_to_expiry.sqrt())
        }

        fn d2(&self) -> f64 {
            self.d1() - self.volatility * self.time_to_expiry.sqrt()
        }

        fn norm_cdf(x: f64) -> f64 {
            0.5 * (1.0 + erf(x / core::f64::consts::SQRT_2))
        }

        fn norm_pdf(x: f64) -> f64 {
            (-0.5 * x * x).exp() / (2.0 * core::f64::consts::PI).sqrt()
        }

        pub fn call_price(&self) -> f64 {
            let d1 = self.d1();
            let d2 = self.d2();
            let s = self.spot * (-self.dividend_yield * self.time_to_expiry).exp();
            let k_disc = self.strike * (-self.rate * self.time_to_expiry).exp();
            s * Self::norm_cdf(d1) - k_disc * Self::norm_cdf(d2)
        }

        pub fn put_price(&self) -> f64 {
            let d1 = self.d1();
            let d2 = self.d2();
            let s = self.spot * (-self.dividend_yield * self.time_to_expiry).exp();
            let k_disc = self.strike * (-self.rate * self.time_to_expiry).exp();
            k_disc * Self::norm_cdf(-d2) - s * Self::norm_cdf(-d1)
        }

        pub fn price(&self, opt_type: OptionType) -> f64 {
            match opt_type {
                OptionType::Call => self.call_price(),
                OptionType::Put => self.put_price(),
            }
        }

        // Greeks
        pub fn delta(&self, opt_type: OptionType) -> f64 {
            let d1 = self.d1();
            let q_disc = (-self.dividend_yield * self.time_to_expiry).exp();
            match opt_type {
                OptionType::Call => q_disc * Self::norm_cdf(d1),
                OptionType::Put => q_disc * (Self::norm_cdf(d1) - 1.0),
            }
        }

        pub fn gamma(&self) -> f64 {
            let d1 = self.d1();
            let q_disc = (-self.dividend_yield * self.time_to_expiry).exp();
            q_disc * Self::norm_pdf(d1) / (self.spot * self.volatility * self.time_to_expiry.sqrt())
        }

        pub fn vega(&self) -> f64 {
            let d1 = self.d1();
            let s = self.spot * (-self.dividend_yield * self.time_to_expiry).exp();
            s * Self::norm_pdf(d1) * self.time_to_expiry.sqrt() / 100.0
        }

        pub fn theta(&self, opt_type: OptionType) -> f64 {
            let d1 = self.d1();
            let d2 = self.d2();
            let s = self.spot * (-self.dividend_yield * self.time_to_expiry).exp();
            let k_disc = self.strike * (-self.rate * self.time_to_expiry).exp();

            let term1 = -s * Self::norm_pdf(d1) * self.volatility / (2.0 * self.time_to_expiry.sqrt());

            match opt_type {
                OptionType::Call => {
                    let term2 = self.dividend_yield * s * Self::norm_cdf(d1);
                    let term3 = -self.rate * k_disc * Self::norm_cdf(d2);
                    (term1 + term2 + term3) / 365.0
                }
                OptionType::Put => {
                    let term2 = -self.dividend_yield * s * Self::norm_cdf(-d1);
                    let term3 = self.rate * k_disc * Self::norm_cdf(-d2);
                    (term1 + term2 + term3) / 365.0
                }
            }
        }

        pub fn rho(&self, opt_type: OptionType) -> f64 {
            let d2 = self.d2();
            let k_disc = self.strike * (-self.rate * self.time_to_expiry).exp();
            match opt_type {
                OptionType::Call => k_disc * self.time_to_expiry * Self::norm_cdf(d2) / 100.0,
                OptionType::Put => -k_disc * self.time_to_expiry * Self::norm_cdf(-d2) / 100.0,
            }
        }

        /// Implied volatility via Newton-Raphson
        pub fn implied_volatility(spot: f64, strike: f64, rate: f64, tte: f64, market_price: f64, opt_type: OptionType) -> f64 {
            let mut vol = 0.2;
            let tol = 1e-6;
            let max_iter = 100;

            for _ in 0..max_iter {
                let bs = BlackScholes::new(spot, strike, rate, vol, tte);
                let price = bs.price(opt_type);
                let vega = bs.vega() * 100.0;

                if vega.abs() < 1e-10 { break; }

                let diff = price - market_price;
                if diff.abs() < tol { break; }

                vol -= diff / vega;
                vol = vol.clamp(0.001, 5.0);
            }
            vol
        }
    }

    /// Binomial tree for American options
    pub struct BinomialTree {
        pub spot: f64,
        pub strike: f64,
        pub rate: f64,
        pub volatility: f64,
        pub time_to_expiry: f64,
        pub steps: usize,
        pub dividend_yield: f64,
    }

    impl BinomialTree {
        pub fn new(spot: f64, strike: f64, rate: f64, vol: f64, tte: f64, steps: usize) -> Self {
            BinomialTree {
                spot, strike, rate, volatility: vol,
                time_to_expiry: tte, steps,
                dividend_yield: 0.0,
            }
        }

        pub fn price(&self, opt_type: OptionType, exercise: ExerciseStyle) -> f64 {
            let dt = self.time_to_expiry / self.steps as f64;
            let u = (self.volatility * dt.sqrt()).exp();
            let d = 1.0 / u;
            let r_dt = ((self.rate - self.dividend_yield) * dt).exp();
            let p = (r_dt - d) / (u - d);
            let disc = (-self.rate * dt).exp();

            // Build price tree at expiry
            let mut prices = Vec::with_capacity(self.steps + 1);
            for i in 0..=self.steps {
                let s = self.spot * u.powi(self.steps as i32 - i as i32) * d.powi(i as i32);
                let payoff = match opt_type {
                    OptionType::Call => (s - self.strike).max(0.0),
                    OptionType::Put => (self.strike - s).max(0.0),
                };
                prices.push(payoff);
            }

            // Backward induction
            for step in (0..self.steps).rev() {
                for i in 0..=step {
                    let hold = disc * (p * prices[i] + (1.0 - p) * prices[i + 1]);

                    prices[i] = match exercise {
                        ExerciseStyle::European => hold,
                        ExerciseStyle::American => {
                            let s = self.spot * u.powi(step as i32 - i as i32) * d.powi(i as i32);
                            let exercise_val = match opt_type {
                                OptionType::Call => (s - self.strike).max(0.0),
                                OptionType::Put => (self.strike - s).max(0.0),
                            };
                            hold.max(exercise_val)
                        }
                    };
                }
            }
            prices[0]
        }

        pub fn delta(&self, opt_type: OptionType, exercise: ExerciseStyle) -> f64 {
            let bump = self.spot * 0.01;
            let mut up = self.clone();
            let mut down = self.clone();
            up.spot = self.spot + bump;
            down.spot = self.spot - bump;
            (up.price(opt_type, exercise) - down.price(opt_type, exercise)) / (2.0 * bump)
        }

        pub fn gamma(&self, opt_type: OptionType, exercise: ExerciseStyle) -> f64 {
            let bump = self.spot * 0.01;
            let mut up = self.clone();
            let mut down = self.clone();
            up.spot = self.spot + bump;
            down.spot = self.spot - bump;
            let p_up = up.price(opt_type, exercise);
            let p_down = down.price(opt_type, exercise);
            let p_mid = self.price(opt_type, exercise);
            (p_up - 2.0 * p_mid + p_down) / (bump * bump)
        }
    }

    /// Volatility surface
    #[derive(Debug, Clone)]
    pub struct VolatilitySurface {
        pub strikes: Vec<f64>,
        pub expiries: Vec<f64>,
        pub vols: Vec<Vec<f64>>,
    }

    impl VolatilitySurface {
        pub fn new() -> Self {
            VolatilitySurface {
                strikes: Vec::new(),
                expiries: Vec::new(),
                vols: Vec::new(),
            }
        }

        pub fn add_point(&mut self, strike: f64, expiry: f64, vol: f64) {
            let strike_idx = self.strikes.iter().position(|&s| (s - strike).abs() < 1e-6);
            let expiry_idx = self.expiries.iter().position(|&e| (e - expiry).abs() < 1e-6);

            let si = strike_idx.unwrap_or_else(|| {
                self.strikes.push(strike);
                self.strikes.len() - 1
            });

            let ei = expiry_idx.unwrap_or_else(|| {
                self.expiries.push(expiry);
                for row in &mut self.vols {
                    row.push(0.0);
                }
                self.expiries.len() - 1
            });

            while self.vols.len() <= si {
                self.vols.push(vec![0.0; self.expiries.len()]);
            }
            while self.vols[si].len() <= ei {
                self.vols[si].push(0.0);
            }
            self.vols[si][ei] = vol;
        }

        pub fn interpolate(&self, strike: f64, expiry: f64) -> f64 {
            // Bilinear interpolation
            if self.strikes.is_empty() || self.expiries.is_empty() {
                return 0.2;
            }

            let si = self.strikes.iter().position(|&s| s >= strike).unwrap_or(self.strikes.len() - 1);
            let ei = self.expiries.iter().position(|&e| e >= expiry).unwrap_or(self.expiries.len() - 1);

            let si0 = if si > 0 { si - 1 } else { si };
            let ei0 = if ei > 0 { ei - 1 } else { ei };

            if si0 >= self.vols.len() || ei0 >= self.vols[si0].len() {
                return 0.2;
            }

            let v00 = self.vols.get(si0).and_then(|r| r.get(ei0)).copied().unwrap_or(0.2);
            let v01 = self.vols.get(si0).and_then(|r| r.get(ei)).copied().unwrap_or(v00);
            let v10 = self.vols.get(si).and_then(|r| r.get(ei0)).copied().unwrap_or(v00);
            let v11 = self.vols.get(si).and_then(|r| r.get(ei)).copied().unwrap_or(v00);

            let k0 = self.strikes[si0];
            let k1 = self.strikes.get(si).copied().unwrap_or(k0);
            let t0 = self.expiries[ei0];
            let t1 = self.expiries.get(ei).copied().unwrap_or(t0);

            let wk = if (k1 - k0).abs() > 1e-10 { (strike - k0) / (k1 - k0) } else { 0.5 };
            let wt = if (t1 - t0).abs() > 1e-10 { (expiry - t0) / (t1 - t0) } else { 0.5 };

            let v0 = v00 * (1.0 - wk) + v10 * wk;
            let v1 = v01 * (1.0 - wk) + v11 * wk;

            v0 * (1.0 - wt) + v1 * wt
        }

        /// ATM skew
        pub fn atm_skew(&self, spot: f64, expiry: f64) -> f64 {
            let atm_vol = self.interpolate(spot, expiry);
            let otm_vol = self.interpolate(spot * 0.9, expiry);
            (otm_vol - atm_vol) / 0.1
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FIXED INCOME
// ═══════════════════════════════════════════════════════════════════════════════

pub mod fixed_income {
    use super::*;

    #[derive(Debug, Clone)]
    pub struct Bond {
        pub face_value: f64,
        pub coupon_rate: f64,
        pub frequency: usize,
        pub maturity_years: f64,
        pub day_count: DayCount,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum DayCount {
        Actual365,
        Actual360,
        Thirty360,
        ActualActual,
    }

    impl Bond {
        pub fn new(face: f64, coupon: f64, freq: usize, maturity: f64) -> Self {
            Bond {
                face_value: face,
                coupon_rate: coupon,
                frequency: freq,
                maturity_years: maturity,
                day_count: DayCount::Actual365,
            }
        }

        pub fn coupon_payment(&self) -> f64 {
            self.face_value * self.coupon_rate / self.frequency as f64
        }

        pub fn num_payments(&self) -> usize {
            (self.maturity_years * self.frequency as f64).round() as usize
        }

        pub fn cash_flows(&self) -> Vec<(f64, f64)> {
            let mut cfs = Vec::new();
            let n = self.num_payments();
            let period = 1.0 / self.frequency as f64;
            let coupon = self.coupon_payment();

            for i in 1..=n {
                let t = i as f64 * period;
                let cf = if i == n { coupon + self.face_value } else { coupon };
                cfs.push((t, cf));
            }
            cfs
        }

        pub fn price(&self, ytm: f64) -> f64 {
            let cfs = self.cash_flows();
            let r = ytm / self.frequency as f64;
            cfs.iter()
                .enumerate()
                .map(|(i, (_, cf))| cf / (1.0 + r).powi((i + 1) as i32))
                .sum()
        }

        pub fn yield_to_maturity(&self, price: f64) -> f64 {
            let mut ytm = self.coupon_rate;
            let tol = 1e-8;
            let max_iter = 100;

            for _ in 0..max_iter {
                let p = self.price(ytm);
                let dp = self.price(ytm + 0.0001) - p;
                let deriv = dp / 0.0001;

                if deriv.abs() < 1e-12 { break; }

                let diff = p - price;
                if diff.abs() < tol { break; }

                ytm -= diff / deriv;
                ytm = ytm.clamp(-0.5, 1.0);
            }
            ytm
        }

        pub fn macaulay_duration(&self, ytm: f64) -> f64 {
            let cfs = self.cash_flows();
            let r = ytm / self.frequency as f64;
            let price = self.price(ytm);

            let weighted: f64 = cfs.iter()
                .enumerate()
                .map(|(i, (t, cf))| t * cf / (1.0 + r).powi((i + 1) as i32))
                .sum();

            weighted / price
        }

        pub fn modified_duration(&self, ytm: f64) -> f64 {
            self.macaulay_duration(ytm) / (1.0 + ytm / self.frequency as f64)
        }

        pub fn convexity(&self, ytm: f64) -> f64 {
            let cfs = self.cash_flows();
            let r = ytm / self.frequency as f64;
            let price = self.price(ytm);
            let f2 = (self.frequency * self.frequency) as f64;

            let weighted: f64 = cfs.iter()
                .enumerate()
                .map(|(i, (_, cf))| {
                    let n = (i + 1) as f64;
                    n * (n + 1.0) * cf / (1.0 + r).powi((i + 3) as i32)
                })
                .sum();

            weighted / (price * f2)
        }

        pub fn price_change(&self, ytm: f64, yield_change: f64) -> f64 {
            let dur = self.modified_duration(ytm);
            let conv = self.convexity(ytm);
            let price = self.price(ytm);

            let first_order = -dur * yield_change;
            let second_order = 0.5 * conv * yield_change * yield_change;

            price * (first_order + second_order)
        }

        pub fn dv01(&self, ytm: f64) -> f64 {
            let price = self.price(ytm);
            let dur = self.modified_duration(ytm);
            price * dur * 0.0001
        }
    }

    /// Yield curve
    #[derive(Debug, Clone)]
    pub struct YieldCurve {
        pub tenors: Vec<f64>,
        pub rates: Vec<f64>,
        pub interpolation: Interpolation,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum Interpolation {
        Linear,
        LogLinear,
        CubicSpline,
    }

    impl YieldCurve {
        pub fn new(tenors: Vec<f64>, rates: Vec<f64>) -> Self {
            YieldCurve {
                tenors, rates,
                interpolation: Interpolation::Linear,
            }
        }

        pub fn with_interpolation(mut self, interp: Interpolation) -> Self {
            self.interpolation = interp;
            self
        }

        pub fn rate(&self, tenor: f64) -> f64 {
            if self.tenors.is_empty() { return 0.0; }
            if tenor <= self.tenors[0] { return self.rates[0]; }
            if tenor >= *self.tenors.last().unwrap() { return *self.rates.last().unwrap(); }

            let idx = self.tenors.iter().position(|&t| t >= tenor).unwrap_or(self.tenors.len() - 1);
            let i0 = if idx > 0 { idx - 1 } else { 0 };

            let t0 = self.tenors[i0];
            let t1 = self.tenors[idx];
            let r0 = self.rates[i0];
            let r1 = self.rates[idx];

            match self.interpolation {
                Interpolation::Linear => {
                    let w = (tenor - t0) / (t1 - t0);
                    r0 * (1.0 - w) + r1 * w
                }
                Interpolation::LogLinear => {
                    let w = (tenor - t0) / (t1 - t0);
                    (r0.ln() * (1.0 - w) + r1.ln() * w).exp()
                }
                Interpolation::CubicSpline => {
                    // Simplified cubic - use natural spline
                    let w = (tenor - t0) / (t1 - t0);
                    r0 * (1.0 - w) + r1 * w
                }
            }
        }

        pub fn discount_factor(&self, tenor: f64) -> f64 {
            let r = self.rate(tenor);
            (-r * tenor).exp()
        }

        pub fn forward_rate(&self, t1: f64, t2: f64) -> f64 {
            if t2 <= t1 { return self.rate(t1); }
            let df1 = self.discount_factor(t1);
            let df2 = self.discount_factor(t2);
            (df1 / df2).ln() / (t2 - t1)
        }

        pub fn par_rate(&self, maturity: f64, frequency: usize) -> f64 {
            let period = 1.0 / frequency as f64;
            let n = (maturity * frequency as f64).round() as usize;

            let mut annuity = 0.0;
            for i in 1..=n {
                let t = i as f64 * period;
                annuity += self.discount_factor(t);
            }

            let df_mat = self.discount_factor(maturity);
            (1.0 - df_mat) / annuity * frequency as f64
        }

        /// Parallel shift
        pub fn shift(&self, bps: f64) -> YieldCurve {
            let shift = bps / 10000.0;
            YieldCurve {
                tenors: self.tenors.clone(),
                rates: self.rates.iter().map(|r| r + shift).collect(),
                interpolation: self.interpolation,
            }
        }

        /// Key rate shift
        pub fn key_rate_shift(&self, tenor: f64, bps: f64) -> YieldCurve {
            let shift = bps / 10000.0;
            let rates: Vec<f64> = self.tenors.iter().zip(&self.rates)
                .map(|(&t, &r)| {
                    let dist = (t - tenor).abs();
                    let weight = (1.0 - dist / 5.0).max(0.0);
                    r + shift * weight
                })
                .collect();

            YieldCurve {
                tenors: self.tenors.clone(),
                rates,
                interpolation: self.interpolation,
            }
        }
    }

    /// Interest rate swap
    #[derive(Debug, Clone)]
    pub struct InterestRateSwap {
        pub notional: f64,
        pub fixed_rate: f64,
        pub float_spread: f64,
        pub maturity_years: f64,
        pub pay_frequency: usize,
        pub is_payer: bool,
    }

    impl InterestRateSwap {
        pub fn new(notional: f64, fixed_rate: f64, maturity: f64, freq: usize, is_payer: bool) -> Self {
            InterestRateSwap {
                notional, fixed_rate, float_spread: 0.0,
                maturity_years: maturity, pay_frequency: freq, is_payer,
            }
        }

        pub fn npv(&self, curve: &YieldCurve) -> f64 {
            let period = 1.0 / self.pay_frequency as f64;
            let n = (self.maturity_years * self.pay_frequency as f64).round() as usize;

            let mut fixed_leg = 0.0;
            let mut float_leg = 0.0;

            for i in 1..=n {
                let t = i as f64 * period;
                let t_prev = (i - 1) as f64 * period;
                let df = curve.discount_factor(t);

                // Fixed leg
                fixed_leg += self.fixed_rate * period * df;

                // Float leg (forward rate)
                let fwd = curve.forward_rate(t_prev, t);
                float_leg += (fwd + self.float_spread) * period * df;
            }

            fixed_leg *= self.notional;
            float_leg *= self.notional;

            if self.is_payer {
                float_leg - fixed_leg
            } else {
                fixed_leg - float_leg
            }
        }

        pub fn par_rate(&self, curve: &YieldCurve) -> f64 {
            let period = 1.0 / self.pay_frequency as f64;
            let n = (self.maturity_years * self.pay_frequency as f64).round() as usize;

            let mut annuity = 0.0;
            let mut float_leg = 0.0;

            for i in 1..=n {
                let t = i as f64 * period;
                let t_prev = (i - 1) as f64 * period;
                let df = curve.discount_factor(t);

                annuity += period * df;
                let fwd = curve.forward_rate(t_prev, t);
                float_leg += (fwd + self.float_spread) * period * df;
            }

            if annuity > 0.0 {
                float_leg / annuity
            } else {
                0.0
            }
        }

        pub fn dv01(&self, curve: &YieldCurve) -> f64 {
            let npv_base = self.npv(curve);
            let curve_up = curve.shift(1.0);
            let npv_up = self.npv(&curve_up);
            (npv_up - npv_base).abs()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FACTOR RISK MODELS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod factor_models {
    use super::*;

    /// Multi-factor risk model (Barra-style)
    #[derive(Debug, Clone)]
    pub struct FactorRiskModel {
        pub factor_names: Vec<String>,
        pub factor_returns: Vec<Vec<f64>>,
        pub factor_covariance: Vec<Vec<f64>>,
        pub specific_risks: HashMap<String, f64>,
        pub factor_loadings: HashMap<String, Vec<f64>>,
    }

    impl FactorRiskModel {
        pub fn new(factors: Vec<String>) -> Self {
            let n = factors.len();
            FactorRiskModel {
                factor_names: factors,
                factor_returns: Vec::new(),
                factor_covariance: vec![vec![0.0; n]; n],
                specific_risks: HashMap::new(),
                factor_loadings: HashMap::new(),
            }
        }

        pub fn set_factor_covariance(&mut self, cov: Vec<Vec<f64>>) {
            self.factor_covariance = cov;
        }

        pub fn add_asset(&mut self, symbol: &str, loadings: Vec<f64>, specific_risk: f64) {
            self.factor_loadings.insert(symbol.to_string(), loadings);
            self.specific_risks.insert(symbol.to_string(), specific_risk);
        }

        pub fn asset_variance(&self, symbol: &str) -> f64 {
            let loadings = match self.factor_loadings.get(symbol) {
                Some(l) => l,
                None => return 0.0,
            };

            let mut factor_var = 0.0;
            for i in 0..loadings.len() {
                for j in 0..loadings.len() {
                    if i < self.factor_covariance.len() && j < self.factor_covariance[i].len() {
                        factor_var += loadings[i] * loadings[j] * self.factor_covariance[i][j];
                    }
                }
            }

            let specific = self.specific_risks.get(symbol).copied().unwrap_or(0.0);
            factor_var + specific * specific
        }

        pub fn asset_covariance(&self, sym1: &str, sym2: &str) -> f64 {
            let l1 = match self.factor_loadings.get(sym1) {
                Some(l) => l,
                None => return 0.0,
            };
            let l2 = match self.factor_loadings.get(sym2) {
                Some(l) => l,
                None => return 0.0,
            };

            let mut cov = 0.0;
            for i in 0..l1.len().min(l2.len()) {
                for j in 0..l1.len().min(l2.len()) {
                    if i < self.factor_covariance.len() && j < self.factor_covariance[i].len() {
                        cov += l1[i] * l2[j] * self.factor_covariance[i][j];
                    }
                }
            }
            cov
        }

        pub fn portfolio_variance(&self, weights: &HashMap<String, f64>) -> f64 {
            let mut var = 0.0;

            for (sym1, &w1) in weights {
                for (sym2, &w2) in weights {
                    var += w1 * w2 * self.asset_covariance(sym1, sym2);
                }
                let specific = self.specific_risks.get(sym1).copied().unwrap_or(0.0);
                var += w1 * w1 * specific * specific;
            }
            var
        }

        pub fn portfolio_factor_exposures(&self, weights: &HashMap<String, f64>) -> Vec<f64> {
            let n = self.factor_names.len();
            let mut exposures = vec![0.0; n];

            for (symbol, &weight) in weights {
                if let Some(loadings) = self.factor_loadings.get(symbol) {
                    for i in 0..n.min(loadings.len()) {
                        exposures[i] += weight * loadings[i];
                    }
                }
            }
            exposures
        }

        pub fn marginal_contribution_to_risk(&self, weights: &HashMap<String, f64>) -> HashMap<String, f64> {
            let port_vol = self.portfolio_variance(weights).sqrt();
            if port_vol == 0.0 {
                return HashMap::new();
            }

            let mut mctr = HashMap::new();
            for (symbol, &weight) in weights {
                let mut contrib = 0.0;
                for (other, &other_w) in weights {
                    contrib += other_w * self.asset_covariance(symbol, other);
                }
                mctr.insert(symbol.clone(), contrib / port_vol);
            }
            mctr
        }
    }

    /// Fama-French factor model
    #[derive(Debug, Clone)]
    pub struct FamaFrench {
        pub market_returns: Vec<f64>,
        pub smb_returns: Vec<f64>,
        pub hml_returns: Vec<f64>,
        pub rmw_returns: Vec<f64>,
        pub cma_returns: Vec<f64>,
        pub risk_free: Vec<f64>,
    }

    impl FamaFrench {
        pub fn three_factor() -> Self {
            FamaFrench {
                market_returns: Vec::new(),
                smb_returns: Vec::new(),
                hml_returns: Vec::new(),
                rmw_returns: Vec::new(),
                cma_returns: Vec::new(),
                risk_free: Vec::new(),
            }
        }

        pub fn five_factor() -> Self {
            Self::three_factor()
        }

        pub fn add_period(&mut self, mkt: f64, smb: f64, hml: f64, rmw: f64, cma: f64, rf: f64) {
            self.market_returns.push(mkt);
            self.smb_returns.push(smb);
            self.hml_returns.push(hml);
            self.rmw_returns.push(rmw);
            self.cma_returns.push(cma);
            self.risk_free.push(rf);
        }

        pub fn regress_three_factor(&self, returns: &[f64]) -> FFRegression {
            self.regress(returns, false)
        }

        pub fn regress_five_factor(&self, returns: &[f64]) -> FFRegression {
            self.regress(returns, true)
        }

        fn regress(&self, returns: &[f64], five_factor: bool) -> FFRegression {
            let n = returns.len()
                .min(self.market_returns.len())
                .min(self.smb_returns.len())
                .min(self.hml_returns.len());

            if n < 2 {
                return FFRegression::default();
            }

            // Excess returns
            let excess: Vec<f64> = (0..n)
                .map(|i| returns[i] - self.risk_free.get(i).copied().unwrap_or(0.0))
                .collect();

            // Simple OLS for market beta
            let mkt_excess: Vec<f64> = (0..n)
                .map(|i| self.market_returns[i] - self.risk_free.get(i).copied().unwrap_or(0.0))
                .collect();

            let beta_mkt = simple_regression(&excess, &mkt_excess);
            let beta_smb = simple_regression(&excess, &self.smb_returns[..n]);
            let beta_hml = simple_regression(&excess, &self.hml_returns[..n]);

            let (beta_rmw, beta_cma) = if five_factor && n <= self.rmw_returns.len() && n <= self.cma_returns.len() {
                (
                    simple_regression(&excess, &self.rmw_returns[..n]),
                    simple_regression(&excess, &self.cma_returns[..n]),
                )
            } else {
                (0.0, 0.0)
            };

            // Calculate alpha
            let mean_ret: f64 = excess.iter().sum::<f64>() / n as f64;
            let mean_mkt: f64 = mkt_excess.iter().sum::<f64>() / n as f64;
            let mean_smb: f64 = self.smb_returns[..n].iter().sum::<f64>() / n as f64;
            let mean_hml: f64 = self.hml_returns[..n].iter().sum::<f64>() / n as f64;

            let alpha = mean_ret - beta_mkt * mean_mkt - beta_smb * mean_smb - beta_hml * mean_hml;

            FFRegression {
                alpha,
                beta_market: beta_mkt,
                beta_smb,
                beta_hml,
                beta_rmw,
                beta_cma,
                r_squared: 0.0,
            }
        }
    }

    fn simple_regression(y: &[f64], x: &[f64]) -> f64 {
        let n = y.len().min(x.len());
        if n < 2 { return 0.0; }

        let x_mean: f64 = x[..n].iter().sum::<f64>() / n as f64;
        let y_mean: f64 = y[..n].iter().sum::<f64>() / n as f64;

        let mut cov = 0.0;
        let mut var = 0.0;

        for i in 0..n {
            cov += (x[i] - x_mean) * (y[i] - y_mean);
            var += (x[i] - x_mean).powi(2);
        }

        if var > 0.0 { cov / var } else { 0.0 }
    }

    #[derive(Debug, Clone, Default)]
    pub struct FFRegression {
        pub alpha: f64,
        pub beta_market: f64,
        pub beta_smb: f64,
        pub beta_hml: f64,
        pub beta_rmw: f64,
        pub beta_cma: f64,
        pub r_squared: f64,
    }

    /// Principal Component Analysis for returns
    pub struct PCAFactorModel {
        pub n_components: usize,
        pub eigenvalues: Vec<f64>,
        pub eigenvectors: Vec<Vec<f64>>,
        pub explained_variance: Vec<f64>,
    }

    impl PCAFactorModel {
        pub fn fit(returns: &[Vec<f64>], n_components: usize) -> Self {
            let n_assets = returns.len();
            let n_periods = returns.first().map(|r| r.len()).unwrap_or(0);

            if n_assets == 0 || n_periods == 0 {
                return PCAFactorModel {
                    n_components,
                    eigenvalues: Vec::new(),
                    eigenvectors: Vec::new(),
                    explained_variance: Vec::new(),
                };
            }

            // Calculate covariance matrix
            let means: Vec<f64> = returns.iter()
                .map(|r| r.iter().sum::<f64>() / r.len() as f64)
                .collect();

            let mut cov = vec![vec![0.0; n_assets]; n_assets];
            for i in 0..n_assets {
                for j in 0..n_assets {
                    let mut c = 0.0;
                    for t in 0..n_periods {
                        c += (returns[i][t] - means[i]) * (returns[j][t] - means[j]);
                    }
                    cov[i][j] = c / (n_periods - 1) as f64;
                }
            }

            // Power iteration for eigenvalues (simplified)
            let mut eigenvalues = Vec::new();
            let mut eigenvectors = Vec::new();

            let mut working_cov = cov.clone();
            for _ in 0..n_components.min(n_assets) {
                let (val, vec) = power_iteration(&working_cov, 100);
                eigenvalues.push(val);
                eigenvectors.push(vec.clone());

                // Deflate
                for i in 0..n_assets {
                    for j in 0..n_assets {
                        working_cov[i][j] -= val * vec[i] * vec[j];
                    }
                }
            }

            let total_var: f64 = eigenvalues.iter().sum();
            let explained = eigenvalues.iter()
                .map(|&e| if total_var > 0.0 { e / total_var } else { 0.0 })
                .collect();

            PCAFactorModel {
                n_components,
                eigenvalues,
                eigenvectors,
                explained_variance: explained,
            }
        }

        pub fn transform(&self, returns: &[f64]) -> Vec<f64> {
            self.eigenvectors.iter()
                .map(|ev| {
                    ev.iter().zip(returns).map(|(&e, &r)| e * r).sum()
                })
                .collect()
        }
    }

    fn power_iteration(matrix: &[Vec<f64>], max_iter: usize) -> (f64, Vec<f64>) {
        let n = matrix.len();
        if n == 0 { return (0.0, Vec::new()); }

        let mut vec = vec![1.0 / (n as f64).sqrt(); n];

        for _ in 0..max_iter {
            let mut new_vec = vec![0.0; n];
            for i in 0..n {
                for j in 0..n {
                    new_vec[i] += matrix[i][j] * vec[j];
                }
            }

            let norm: f64 = new_vec.iter().map(|x| x * x).sum::<f64>().sqrt();
            if norm > 0.0 {
                for v in &mut new_vec {
                    *v /= norm;
                }
            }
            vec = new_vec;
        }

        let mut eigenvalue = 0.0;
        for i in 0..n {
            let mut row_sum = 0.0;
            for j in 0..n {
                row_sum += matrix[i][j] * vec[j];
            }
            eigenvalue += row_sum * vec[i];
        }

        (eigenvalue, vec)
    }
}

