pub mod analytics {
    use super::*;

    /// Trade analysis
    pub struct TradeAnalyzer {
        pub trades: Vec<Trade>,
    }

    impl TradeAnalyzer {
        pub fn new(trades: Vec<Trade>) -> Self {
            TradeAnalyzer { trades }
        }

        /// Group trades by symbol
        pub fn by_symbol(&self) -> HashMap<String, Vec<&Trade>> {
            let mut grouped: HashMap<String, Vec<&Trade>> = HashMap::new();
            for trade in &self.trades {
                grouped.entry(trade.symbol.clone()).or_insert(Vec::new()).push(trade);
            }
            grouped
        }

        /// Calculate average trade duration
        pub fn average_holding_period(&self) -> f64 {
            // Would need entry/exit pairing
            0.0
        }

        /// Calculate trade frequency
        pub fn trades_per_day(&self) -> f64 {
            if self.trades.len() < 2 {
                return 0.0;
            }

            let first = self.trades.first().unwrap().timestamp;
            let last = self.trades.last().unwrap().timestamp;
            let days = (last.timestamp() - first.timestamp()) as f64 / 86400.0;

            if days > 0.0 {
                self.trades.len() as f64 / days
            } else {
                self.trades.len() as f64
            }
        }

        /// Calculate commission impact
        pub fn total_commission(&self) -> f64 {
            self.trades.iter().map(|t| t.commission).sum()
        }

        /// Calculate gross P&L by side
        pub fn pnl_by_side(&self) -> (f64, f64) {
            let long_pnl = 0.0; // Would need proper position tracking
            let short_pnl = 0.0;
            (long_pnl, short_pnl)
        }
    }

    /// Rolling performance metrics
    pub struct RollingMetrics {
        pub window: usize,
    }

    impl RollingMetrics {
        pub fn new(window: usize) -> Self {
            RollingMetrics { window }
        }

        /// Rolling Sharpe ratio
        pub fn rolling_sharpe(&self, returns: &[f64], risk_free_rate: f64) -> Vec<f64> {
            if returns.len() < self.window {
                return vec![];
            }

            returns.windows(self.window)
                .map(|w| risk::sharpe_ratio(w, risk_free_rate))
                .collect()
        }

        /// Rolling volatility
        pub fn rolling_volatility(&self, returns: &[f64]) -> Vec<f64> {
            if returns.len() < self.window {
                return vec![];
            }

            returns.windows(self.window)
                .map(|w| {
                    let mean = w.iter().sum::<f64>() / w.len() as f64;
                    let var: f64 = w.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / (w.len() - 1) as f64;
                    sqrt(var) * sqrt(252.0) // Annualized
                })
                .collect()
        }

        /// Rolling beta vs benchmark
        pub fn rolling_beta(&self, returns: &[f64], benchmark: &[f64]) -> Vec<f64> {
            if returns.len() < self.window || benchmark.len() < self.window {
                return vec![];
            }

            returns.windows(self.window)
                .zip(benchmark.windows(self.window))
                .map(|(r, b)| {
                    let r_mean = r.iter().sum::<f64>() / r.len() as f64;
                    let b_mean = b.iter().sum::<f64>() / b.len() as f64;

                    let mut cov = 0.0;
                    let mut b_var = 0.0;

                    for i in 0..r.len() {
                        cov += (r[i] - r_mean) * (b[i] - b_mean);
                        b_var += (b[i] - b_mean).powi(2);
                    }

                    if b_var > 0.0 { cov / b_var } else { 0.0 }
                })
                .collect()
        }
    }

    /// Drawdown analysis
    pub struct DrawdownAnalyzer {
        pub equity_curve: Vec<f64>,
    }

    impl DrawdownAnalyzer {
        pub fn new(equity_curve: Vec<f64>) -> Self {
            DrawdownAnalyzer { equity_curve }
        }

        /// Get all drawdown periods
        pub fn drawdown_periods(&self) -> Vec<DrawdownPeriod> {
            let mut periods = Vec::new();
            let mut peak = self.equity_curve[0];
            let mut peak_idx = 0;
            let mut in_drawdown = false;
            let mut current_start = 0;
            let mut max_dd = 0.0;
            let mut max_dd_idx = 0;

            for (i, &equity) in self.equity_curve.iter().enumerate() {
                if equity > peak {
                    if in_drawdown {
                        // End of drawdown
                        periods.push(DrawdownPeriod {
                            start_idx: current_start,
                            trough_idx: max_dd_idx,
                            recovery_idx: Some(i),
                            max_drawdown: max_dd,
                            duration: i - current_start,
                            recovery_duration: i - max_dd_idx,
                        });
                        in_drawdown = false;
                    }
                    peak = equity;
                    peak_idx = i;
                    max_dd = 0.0;
                } else {
                    let dd = (peak - equity) / peak;
                    if !in_drawdown && dd > 0.01 { // 1% threshold
                        in_drawdown = true;
                        current_start = peak_idx;
                    }
                    if dd > max_dd {
                        max_dd = dd;
                        max_dd_idx = i;
                    }
                }
            }

            // Handle ongoing drawdown
            if in_drawdown {
                periods.push(DrawdownPeriod {
                    start_idx: current_start,
                    trough_idx: max_dd_idx,
                    recovery_idx: None,
                    max_drawdown: max_dd,
                    duration: self.equity_curve.len() - current_start,
                    recovery_duration: 0,
                });
            }

            periods
        }

        /// Get underwater curve (drawdown over time)
        pub fn underwater_curve(&self) -> Vec<f64> {
            let mut peak = self.equity_curve[0];

            self.equity_curve.iter()
                .map(|&equity| {
                    if equity > peak {
                        peak = equity;
                    }
                    (equity - peak) / peak
                })
                .collect()
        }

        /// Average drawdown duration
        pub fn average_drawdown_duration(&self) -> f64 {
            let periods = self.drawdown_periods();
            if periods.is_empty() {
                return 0.0;
            }
            periods.iter().map(|p| p.duration as f64).sum::<f64>() / periods.len() as f64
        }

        /// Average recovery time
        pub fn average_recovery_time(&self) -> f64 {
            let periods = self.drawdown_periods();
            let recovered: Vec<_> = periods.iter().filter(|p| p.recovery_idx.is_some()).collect();
            if recovered.is_empty() {
                return 0.0;
            }
            recovered.iter().map(|p| p.recovery_duration as f64).sum::<f64>() / recovered.len() as f64
        }
    }

    #[derive(Debug, Clone)]
    pub struct DrawdownPeriod {
        pub start_idx: usize,
        pub trough_idx: usize,
        pub recovery_idx: Option<usize>,
        pub max_drawdown: f64,
        pub duration: usize,
        pub recovery_duration: usize,
    }

    /// Attribution analysis
    pub struct AttributionAnalyzer {
        pub returns: Vec<f64>,
        pub factor_returns: HashMap<String, Vec<f64>>,
    }

    impl AttributionAnalyzer {
        pub fn new(returns: Vec<f64>) -> Self {
            AttributionAnalyzer {
                returns,
                factor_returns: HashMap::new(),
            }
        }

        pub fn add_factor(&mut self, name: &str, returns: Vec<f64>) {
            self.factor_returns.insert(name.to_string(), returns);
        }

        /// Simple factor attribution (regression betas)
        pub fn factor_exposures(&self) -> HashMap<String, f64> {
            let mut exposures = HashMap::new();
            let r_mean = self.returns.iter().sum::<f64>() / self.returns.len() as f64;

            for (name, factor) in &self.factor_returns {
                if factor.len() != self.returns.len() {
                    continue;
                }

                let f_mean = factor.iter().sum::<f64>() / factor.len() as f64;

                let mut cov = 0.0;
                let mut f_var = 0.0;

                for i in 0..self.returns.len() {
                    cov += (self.returns[i] - r_mean) * (factor[i] - f_mean);
                    f_var += (factor[i] - f_mean).powi(2);
                }

                let beta = if f_var > 0.0 { cov / f_var } else { 0.0 };
                exposures.insert(name.clone(), beta);
            }

            exposures
        }

        /// Calculate alpha (residual return)
        pub fn alpha(&self) -> f64 {
            let exposures = self.factor_exposures();
            let r_mean = self.returns.iter().sum::<f64>() / self.returns.len() as f64;

            let mut factor_contribution = 0.0;
            for (name, &beta) in &exposures {
                if let Some(factor) = self.factor_returns.get(name) {
                    let f_mean = factor.iter().sum::<f64>() / factor.len() as f64;
                    factor_contribution += beta * f_mean;
                }
            }

            r_mean - factor_contribution
        }
    }
}

