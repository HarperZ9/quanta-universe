// BROKER API ABSTRACTION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod broker {
    use super::*;

    /// Broker connection status
    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum ConnectionStatus {
        Disconnected,
        Connecting,
        Connected,
        Authenticated,
        Error,
    }

    /// Account information
    #[derive(Debug, Clone)]
    pub struct AccountInfo {
        pub account_id: String,
        pub account_type: AccountType,
        pub currency: String,
        pub buying_power: f64,
        pub cash: f64,
        pub portfolio_value: f64,
        pub equity: f64,
        pub margin_used: f64,
        pub margin_available: f64,
        pub day_trades_remaining: Option<u32>,
        pub pattern_day_trader: bool,
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum AccountType {
        Cash,
        Margin,
        IRA,
        Paper,
    }

    /// Broker API trait - implement for each broker
    pub trait BrokerApi {
        fn name(&self) -> &str;
        fn connect(&mut self) -> Result<(), String>;
        fn disconnect(&mut self);
        fn status(&self) -> ConnectionStatus;
        fn account_info(&self) -> Result<AccountInfo, String>;
        fn positions(&self) -> Result<Vec<Position>, String>;
        fn submit_order(&mut self, order: &Order) -> Result<String, String>;
        fn cancel_order(&mut self, order_id: &str) -> Result<(), String>;
        fn get_order(&self, order_id: &str) -> Result<Order, String>;
        fn market_data(&self, symbol: &str) -> Result<Quote, String>;
        fn historical_data(&self, symbol: &str, start: DateTime, end: DateTime, timeframe: &str) -> Result<Vec<Candle>, String>;
    }

    /// Alpaca API implementation
    pub struct AlpacaApi {
        pub api_key: String,
        pub api_secret: String,
        pub base_url: String,
        pub data_url: String,
        pub status: ConnectionStatus,
        pub account: Option<AccountInfo>,
        pub is_paper: bool,
    }

    impl AlpacaApi {
        pub fn new(api_key: &str, api_secret: &str, paper: bool) -> Self {
            let base_url = if paper {
                "https://paper-api.alpaca.markets".to_string()
            } else {
                "https://api.alpaca.markets".to_string()
            };

            AlpacaApi {
                api_key: api_key.to_string(),
                api_secret: api_secret.to_string(),
                base_url,
                data_url: "https://data.alpaca.markets".to_string(),
                status: ConnectionStatus::Disconnected,
                account: None,
                is_paper: paper,
            }
        }

        fn make_request(&self, method: &str, endpoint: &str, body: Option<&str>) -> Result<String, String> {
            // HTTP request implementation would go here
            // Returns JSON response as string
            Ok("{}".to_string())
        }

        fn parse_order_response(&self, json: &str) -> Result<Order, String> {
            // Parse Alpaca order JSON
            Ok(Order {
                id: String::new(),
                symbol: String::new(),
                side: Side::Buy,
                order_type: OrderType::Market,
                quantity: 0.0,
                limit_price: None,
                stop_price: None,
                time_in_force: TimeInForce::Day,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            })
        }
    }

    impl BrokerApi for AlpacaApi {
        fn name(&self) -> &str { "Alpaca" }

        fn connect(&mut self) -> Result<(), String> {
            self.status = ConnectionStatus::Connecting;

            // Test connection with account endpoint
            match self.make_request("GET", "/v2/account", None) {
                Ok(response) => {
                    self.status = ConnectionStatus::Authenticated;
                    // Parse account info
                    self.account = Some(AccountInfo {
                        account_id: String::new(),
                        account_type: if self.is_paper { AccountType::Paper } else { AccountType::Margin },
                        currency: "USD".to_string(),
                        buying_power: 0.0,
                        cash: 0.0,
                        portfolio_value: 0.0,
                        equity: 0.0,
                        margin_used: 0.0,
                        margin_available: 0.0,
                        day_trades_remaining: Some(3),
                        pattern_day_trader: false,
                    });
                    Ok(())
                }
                Err(e) => {
                    self.status = ConnectionStatus::Error;
                    Err(e)
                }
            }
        }

        fn disconnect(&mut self) {
            self.status = ConnectionStatus::Disconnected;
            self.account = None;
        }

        fn status(&self) -> ConnectionStatus { self.status }

        fn account_info(&self) -> Result<AccountInfo, String> {
            self.account.clone().ok_or("Not connected".to_string())
        }

        fn positions(&self) -> Result<Vec<Position>, String> {
            let response = self.make_request("GET", "/v2/positions", None)?;
            // Parse positions JSON
            Ok(Vec::new())
        }

        fn submit_order(&mut self, order: &Order) -> Result<String, String> {
            let side = match order.side {
                Side::Buy => "buy",
                Side::Sell => "sell",
            };

            let order_type = match order.order_type {
                OrderType::Market => "market",
                OrderType::Limit => "limit",
                OrderType::Stop => "stop",
                OrderType::StopLimit => "stop_limit",
                OrderType::TrailingStop => "trailing_stop",
            };

            let tif = match order.time_in_force {
                TimeInForce::Day => "day",
                TimeInForce::GTC => "gtc",
                TimeInForce::IOC => "ioc",
                TimeInForce::FOK => "fok",
                TimeInForce::GTD(_) => "gtd",
            };

            let body = format!(r#"{{
                "symbol": "{}",
                "qty": {},
                "side": "{}",
                "type": "{}",
                "time_in_force": "{}"
                {}
                {}
            }}"#,
                order.symbol,
                order.quantity,
                side,
                order_type,
                tif,
                order.limit_price.map(|p| format!(r#", "limit_price": {}"#, p)).unwrap_or_default(),
                order.stop_price.map(|p| format!(r#", "stop_price": {}"#, p)).unwrap_or_default(),
            );

            let response = self.make_request("POST", "/v2/orders", Some(&body))?;
            // Extract order ID from response
            Ok(String::new())
        }

        fn cancel_order(&mut self, order_id: &str) -> Result<(), String> {
            self.make_request("DELETE", &format!("/v2/orders/{}", order_id), None)?;
            Ok(())
        }

        fn get_order(&self, order_id: &str) -> Result<Order, String> {
            let response = self.make_request("GET", &format!("/v2/orders/{}", order_id), None)?;
            self.parse_order_response(&response)
        }

        fn market_data(&self, symbol: &str) -> Result<Quote, String> {
            let response = self.make_request("GET", &format!("/v2/stocks/{}/quotes/latest", symbol), None)?;
            Ok(Quote {
                timestamp: DateTime::now(),
                bid: 0.0,
                ask: 0.0,
                bid_size: 0.0,
                ask_size: 0.0,
            })
        }

        fn historical_data(&self, symbol: &str, start: DateTime, end: DateTime, timeframe: &str) -> Result<Vec<Candle>, String> {
            let endpoint = format!(
                "/v2/stocks/{}/bars?timeframe={}&start={}&end={}",
                symbol, timeframe, start, end
            );
            let response = self.make_request("GET", &endpoint, None)?;
            // Parse bars JSON
            Ok(Vec::new())
        }
    }

