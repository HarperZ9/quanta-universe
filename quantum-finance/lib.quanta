/// Strategy trait - implement for custom strategies
pub trait Strategy {
    fn name(&self) -> &str;
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal>;
}

/// Trading signal
#[derive(Debug, Clone)]
pub struct Signal {
    pub symbol: String,
    pub side: Side,
    pub strength: f64,      // [-1, 1] confidence
    pub target_price: Option<f64>,
    pub stop_loss: Option<f64>,
    pub take_profit: Option<f64>,
    pub timestamp: DateTime,
}

/// Momentum Strategy
pub struct MomentumStrategy {
    pub fast_period: usize,
    pub slow_period: usize,
    pub rsi_period: usize,
    pub rsi_overbought: f64,
    pub rsi_oversold: f64,
}

impl MomentumStrategy {
    pub fn new() -> Self {
        MomentumStrategy {
            fast_period: 12,
            slow_period: 26,
            rsi_period: 14,
            rsi_overbought: 70.0,
            rsi_oversold: 30.0,
        }
    }
}

impl Strategy for MomentumStrategy {
    fn name(&self) -> &str { "Momentum" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.slow_period + 1 {
            return signals;
        }
        
        let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
        let fast_ema = indicators::ema(&closes, self.fast_period);
        let slow_ema = indicators::ema(&closes, self.slow_period);
        let rsi = indicators::rsi(&closes, self.rsi_period);
        
        let last = candles.last().unwrap();
        let fast = *fast_ema.last().unwrap_or(&0.0);
        let slow = *slow_ema.last().unwrap_or(&0.0);
        let rsi_val = *rsi.last().unwrap_or(&50.0);
        
        // Bullish: Fast > Slow and RSI not overbought
        if fast > slow && rsi_val < self.rsi_overbought {
            let strength = (fast - slow) / slow * 10.0; // Normalize
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: strength.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 0.98),
                take_profit: Some(last.close * 1.05),
                timestamp: last.timestamp,
            });
        }
        
        // Bearish: Fast < Slow and RSI not oversold
        if fast < slow && rsi_val > self.rsi_oversold {
            let strength = (slow - fast) / slow * 10.0;
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: strength.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 1.02),
                take_profit: Some(last.close * 0.95),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Mean Reversion Strategy
pub struct MeanReversionStrategy {
    pub period: usize,
    pub std_dev_entry: f64,
    pub std_dev_exit: f64,
}

impl MeanReversionStrategy {
    pub fn new() -> Self {
        MeanReversionStrategy {
            period: 20,
            std_dev_entry: 2.0,
            std_dev_exit: 0.5,
        }
    }
}

impl Strategy for MeanReversionStrategy {
    fn name(&self) -> &str { "Mean Reversion" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.period {
            return signals;
        }
        
        let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
        let (upper, middle, lower) = indicators::bollinger_bands(&closes, self.period, self.std_dev_entry);
        
        let last = candles.last().unwrap();
        let price = last.close;
        let upper_band = *upper.last().unwrap_or(&price);
        let lower_band = *lower.last().unwrap_or(&price);
        let mean = *middle.last().unwrap_or(&price);
        
        // Buy when price touches lower band
        if price <= lower_band {
            let distance = (mean - price) / (mean - lower_band);
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: distance.min(1.0),
                target_price: Some(mean),
                stop_loss: Some(lower_band * 0.98),
                take_profit: Some(mean + (mean - lower_band) * 0.5),
                timestamp: last.timestamp,
            });
        }
        
        // Sell when price touches upper band
        if price >= upper_band {
            let distance = (price - mean) / (upper_band - mean);
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: distance.min(1.0),
                target_price: Some(mean),
                stop_loss: Some(upper_band * 1.02),
                take_profit: Some(mean - (upper_band - mean) * 0.5),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Trend Following Strategy
pub struct TrendFollowingStrategy {
    pub fast_period: usize,
    pub slow_period: usize,
    pub atr_period: usize,
    pub atr_multiplier: f64,
}

impl TrendFollowingStrategy {
    pub fn new() -> Self {
        TrendFollowingStrategy {
            fast_period: 20,
            slow_period: 50,
            atr_period: 14,
            atr_multiplier: 2.0,
        }
    }
}

impl Strategy for TrendFollowingStrategy {
    fn name(&self) -> &str { "Trend Following" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.slow_period {
            return signals;
        }
        
        let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
        let fast_ma = indicators::sma(&closes, self.fast_period);
        let slow_ma = indicators::sma(&closes, self.slow_period);
        let atr = indicators::atr(candles, self.atr_period);
        
        let last = candles.last().unwrap();
        let fast = *fast_ma.last().unwrap_or(&0.0);
        let slow = *slow_ma.last().unwrap_or(&0.0);
        let atr_val = *atr.last().unwrap_or(&0.0);
        
        // Golden cross - buy
        if fast > slow {
            let trend_strength = (fast - slow) / slow * 100.0;
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: (trend_strength / 5.0).min(1.0),
                target_price: None,
                stop_loss: Some(last.close - self.atr_multiplier * atr_val),
                take_profit: Some(last.close + self.atr_multiplier * atr_val * 2.0),
                timestamp: last.timestamp,
            });
        }
        
        // Death cross - sell
        if fast < slow {
            let trend_strength = (slow - fast) / slow * 100.0;
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: (trend_strength / 5.0).min(1.0),
                target_price: None,
                stop_loss: Some(last.close + self.atr_multiplier * atr_val),
                take_profit: Some(last.close - self.atr_multiplier * atr_val * 2.0),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Breakout Strategy
pub struct BreakoutStrategy {
    pub lookback: usize,
    pub volume_threshold: f64,
}

impl BreakoutStrategy {
    pub fn new() -> Self {
        BreakoutStrategy {
            lookback: 20,
            volume_threshold: 1.5,
        }
    }
}

impl Strategy for BreakoutStrategy {
    fn name(&self) -> &str { "Breakout" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.lookback {
            return signals;
        }
        
        let window = &candles[candles.len() - self.lookback..];
        let highest: f64 = window.iter().map(|c| c.high).fold(f64::NEG_INFINITY, f64::max);
        let lowest: f64 = window.iter().map(|c| c.low).fold(f64::INFINITY, f64::min);
        let avg_volume: f64 = window.iter().map(|c| c.volume).sum::<f64>() / self.lookback as f64;
        
        let last = candles.last().unwrap();
        
        // Bullish breakout
        if last.close > highest && last.volume > avg_volume * self.volume_threshold {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: ((last.close - highest) / highest * 100.0).min(1.0),
                target_price: Some(highest + (highest - lowest)),
                stop_loss: Some(highest * 0.98),
                take_profit: Some(last.close * 1.10),
                timestamp: last.timestamp,
            });
        }
        
        // Bearish breakout
        if last.close < lowest && last.volume > avg_volume * self.volume_threshold {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: ((lowest - last.close) / lowest * 100.0).min(1.0),
                target_price: Some(lowest - (highest - lowest)),
                stop_loss: Some(lowest * 1.02),
                take_profit: Some(last.close * 0.90),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Ensemble Strategy - combines multiple strategies
pub struct EnsembleStrategy {
    strategies: Vec<Box<dyn Strategy>>,
    weights: Vec<f64>,
}

impl EnsembleStrategy {
    pub fn new() -> Self {
        let strategies: Vec<Box<dyn Strategy>> = vec![
            Box::new(MomentumStrategy::new()),
            Box::new(MeanReversionStrategy::new()),
            Box::new(TrendFollowingStrategy::new()),
            Box::new(BreakoutStrategy::new()),
        ];
        let weights = vec![0.25, 0.25, 0.30, 0.20];
        
        EnsembleStrategy { strategies, weights }
    }
}

impl Strategy for EnsembleStrategy {
    fn name(&self) -> &str { "Ensemble" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut buy_score = 0.0;
        let mut sell_score = 0.0;
        
        for (strategy, &weight) in self.strategies.iter_mut().zip(self.weights.iter()) {
            let signals = strategy.generate_signals(candles);
            for signal in signals {
                match signal.side {
                    Side::Buy => buy_score += signal.strength * weight,
                    Side::Sell => sell_score += signal.strength * weight,
                }
            }
        }
        
        let mut signals = Vec::new();
        let last = candles.last().unwrap();
        
        if buy_score > sell_score && buy_score > 0.3 {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: buy_score.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 0.97),
                take_profit: Some(last.close * 1.06),
                timestamp: last.timestamp,
            });
        } else if sell_score > buy_score && sell_score > 0.3 {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: sell_score.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 1.03),
                take_profit: Some(last.close * 0.94),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// RISK MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod risk {
    use super::*;
    
    /// Risk level classification
    #[derive(Debug, Clone, Copy, PartialEq, Ord, PartialOrd, Eq)]
    pub enum RiskLevel {
        Minimal,
        Low,
        Moderate,
        High,
        Critical,
    }
    
    /// Position sizing methods
    pub enum PositionSizing {
        Fixed(f64),
        PercentOfEquity(f64),
        Kelly(f64, f64),  // win_rate, win_loss_ratio
        VolatilityAdjusted(f64, f64),  // target_risk, atr
    }
    
    /// Calculate position size
    pub fn calculate_position_size(
        equity: f64,
        method: PositionSizing,
        price: f64,
    ) -> f64 {
        let notional = match method {
            PositionSizing::Fixed(amount) => amount,
            PositionSizing::PercentOfEquity(pct) => equity * pct,
            PositionSizing::Kelly(win_rate, ratio) => {
                let kelly = win_rate - (1.0 - win_rate) / ratio;
                equity * kelly.max(0.0).min(0.5) // Cap at 50%
            }
            PositionSizing::VolatilityAdjusted(target_risk, atr) => {
                if atr > 0.0 {
                    equity * target_risk / atr
                } else {
                    equity * 0.02
                }
            }
        };
        
        notional / price
    }
    
    /// Value at Risk (parametric)
    pub fn var_parametric(returns: &[f64], confidence: f64) -> f64 {
        let n = returns.len() as f64;
        let mean: f64 = returns.iter().sum::<f64>() / n;
        let variance: f64 = returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / n;
        let std = sqrt(variance);
        
        // Z-score for confidence level
        let z = match confidence {
            c if c >= 0.99 => 2.326,
            c if c >= 0.95 => 1.645,
            c if c >= 0.90 => 1.282,
            _ => 1.0,
        };
        
        mean - z * std
    }
    
    /// Expected Shortfall (CVaR)
    pub fn expected_shortfall(returns: &[f64], confidence: f64) -> f64 {
        let mut sorted = returns.to_vec();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
        
        let cutoff = ((1.0 - confidence) * sorted.len() as f64) as usize;
        let tail = &sorted[..cutoff.max(1)];
        
        tail.iter().sum::<f64>() / tail.len() as f64
    }
    
    /// Maximum drawdown
    pub fn max_drawdown(equity_curve: &[f64]) -> (f64, usize, usize) {
        let mut max_dd = 0.0;
        let mut peak_idx = 0;
        let mut trough_idx = 0;
        let mut peak = equity_curve[0];
        
        for (i, &equity) in equity_curve.iter().enumerate() {
            if equity > peak {
                peak = equity;
                peak_idx = i;
            }
            
            let dd = (peak - equity) / peak;
            if dd > max_dd {
                max_dd = dd;
                trough_idx = i;
            }
        }
        
        (max_dd, peak_idx, trough_idx)
    }
    
    /// Sharpe Ratio
    pub fn sharpe_ratio(returns: &[f64], risk_free_rate: f64) -> f64 {
        let n = returns.len() as f64;
        let mean: f64 = returns.iter().sum::<f64>() / n;
        let excess_return = mean - risk_free_rate / 252.0; // Daily risk-free rate
        
        let variance: f64 = returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / n;
        let std = sqrt(variance);
        
        if std > 0.0 {
            excess_return / std * sqrt(252.0) // Annualized
        } else {
            0.0
        }
    }
    
    /// Sortino Ratio (downside deviation)
    pub fn sortino_ratio(returns: &[f64], risk_free_rate: f64) -> f64 {
        let n = returns.len() as f64;
        let mean: f64 = returns.iter().sum::<f64>() / n;
        let excess_return = mean - risk_free_rate / 252.0;
        
        // Downside deviation
        let downside_var: f64 = returns.iter()
            .filter(|&&r| r < 0.0)
            .map(|r| r.powi(2))
            .sum::<f64>() / n;
        let downside_std = sqrt(downside_var);
        
        if downside_std > 0.0 {
            excess_return / downside_std * sqrt(252.0)
        } else {
            0.0
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRADING ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Main trading engine
pub struct TradingEngine {
    pub positions: HashMap<String, Position>,
    pub orders: HashMap<String, Order>,
    pub trades: Vec<Trade>,
    pub equity: f64,
    pub strategies: Vec<Box<dyn Strategy>>,
    pub risk_per_trade: f64,
}

impl TradingEngine {
    pub fn new(initial_capital: f64) -> Self {
        TradingEngine {
            positions: HashMap::new(),
            orders: HashMap::new(),
            trades: Vec::new(),
            equity: initial_capital,
            strategies: Vec::new(),
            risk_per_trade: 0.02, // 2% risk per trade
        }
    }
    
    pub fn add_strategy(&mut self, strategy: Box<dyn Strategy>) {
        self.strategies.push(strategy);
    }
    
    /// Process new market data
    pub fn on_candle(&mut self, symbol: &str, candles: &[Candle]) -> Vec<Order> {
        let mut orders = Vec::new();
        
        // Generate signals from all strategies
        for strategy in &mut self.strategies {
            let signals = strategy.generate_signals(candles);
            
            for signal in signals {
                if signal.strength > 0.5 { // Only act on strong signals
                    let order = self.create_order(symbol, &signal, candles.last().unwrap());
                    if let Some(o) = order {
                        orders.push(o);
                    }
                }
            }
        }
        
        orders
    }
    
    fn create_order(&self, symbol: &str, signal: &Signal, candle: &Candle) -> Option<Order> {
        let position_size = risk::calculate_position_size(
            self.equity,
            risk::PositionSizing::PercentOfEquity(self.risk_per_trade),
            candle.close,
        );
        
        if position_size < 0.0001 {
            return None;
        }
        
        Some(Order {
            id: format!("ORD-{}", uuid::Uuid::new_v4()),
            symbol: symbol.to_string(),
            side: signal.side,
            order_type: OrderType::Limit,
            quantity: position_size,
            limit_price: Some(candle.close),
            stop_price: signal.stop_loss,
            time_in_force: TimeInForce::Day,
            status: OrderStatus::Pending,
            filled_quantity: 0.0,
            average_fill_price: 0.0,
            created_at: signal.timestamp,
            updated_at: signal.timestamp,
        })
    }
    
    /// Process order fill
    pub fn on_fill(&mut self, trade: Trade) {
        // Update position
        let position = self.positions
            .entry(trade.symbol.clone())
            .or_insert(Position::new(&trade.symbol));
        
        match trade.side {
            Side::Buy => {
                let new_cost = position.quantity * position.average_cost + trade.quantity * trade.price;
                position.quantity += trade.quantity;
                position.average_cost = new_cost / position.quantity;
            }
            Side::Sell => {
                let realized = (trade.price - position.average_cost) * trade.quantity;
                position.realized_pnl += realized;
                position.quantity -= trade.quantity;
            }
        }
        
        // Deduct commission
        self.equity -= trade.commission;
        
        // Store trade
        self.trades.push(trade);
    }
    
    /// Get portfolio value
    pub fn portfolio_value(&self, prices: &HashMap<String, f64>) -> f64 {
        let position_value: f64 = self.positions.iter()
            .map(|(symbol, pos)| {
                prices.get(symbol).unwrap_or(&0.0) * pos.quantity
            })
            .sum();
        
        self.equity + position_value
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER MANAGEMENT SYSTEM (OMS)
// ═══════════════════════════════════════════════════════════════════════════════

pub mod oms {
    use super::*;

    /// Order ID generator
    pub struct OrderIdGenerator {
        counter: u64,
        prefix: String,
    }

    impl OrderIdGenerator {
        pub fn new(prefix: &str) -> Self {
            OrderIdGenerator {
                counter: 0,
                prefix: prefix.to_string(),
            }
        }

        pub fn next(&mut self) -> String {
            self.counter += 1;
            format!("{}-{:012}", self.prefix, self.counter)
        }
    }

    /// Order validation result
    #[derive(Debug, Clone)]
    pub struct ValidationResult {
        pub is_valid: bool,
        pub errors: Vec<String>,
        pub warnings: Vec<String>,
    }

    impl ValidationResult {
        pub fn valid() -> Self {
            ValidationResult { is_valid: true, errors: Vec::new(), warnings: Vec::new() }
        }

        pub fn invalid(error: &str) -> Self {
            ValidationResult { is_valid: false, errors: vec![error.to_string()], warnings: Vec::new() }
        }

        pub fn add_error(&mut self, error: &str) {
            self.errors.push(error.to_string());
            self.is_valid = false;
        }

        pub fn add_warning(&mut self, warning: &str) {
            self.warnings.push(warning.to_string());
        }
    }

    /// Order validator
    pub struct OrderValidator {
        pub max_order_size: f64,
        pub max_notional: f64,
        pub allowed_symbols: Option<Vec<String>>,
        pub min_price: f64,
        pub max_price: f64,
    }

    impl OrderValidator {
        pub fn new() -> Self {
            OrderValidator {
                max_order_size: 100000.0,
                max_notional: 10000000.0,
                allowed_symbols: None,
                min_price: 0.0001,
                max_price: 1000000.0,
            }
        }

        pub fn validate(&self, order: &Order, market_price: f64) -> ValidationResult {
            let mut result = ValidationResult::valid();

            // Check quantity
            if order.quantity <= 0.0 {
                result.add_error("Quantity must be positive");
            }
            if order.quantity > self.max_order_size {
                result.add_error(&format!("Quantity {} exceeds max {}", order.quantity, self.max_order_size));
            }

            // Check limit price
            if let Some(price) = order.limit_price {
                if price < self.min_price || price > self.max_price {
                    result.add_error(&format!("Limit price {} outside valid range", price));
                }

                // Price reasonableness check
                let deviation = (price - market_price).abs() / market_price;
                if deviation > 0.10 {
                    result.add_warning(&format!("Limit price deviates {}% from market", deviation * 100.0));
                }
            }

            // Check stop price
            if let Some(stop) = order.stop_price {
                match order.side {
                    Side::Buy => {
                        if stop < market_price {
                            result.add_error("Buy stop must be above market price");
                        }
                    }
                    Side::Sell => {
                        if stop > market_price {
                            result.add_error("Sell stop must be below market price");
                        }
                    }
                }
            }

            // Check notional
            let notional = order.quantity * order.limit_price.unwrap_or(market_price);
            if notional > self.max_notional {
                result.add_error(&format!("Notional {} exceeds max {}", notional, self.max_notional));
            }

            // Check allowed symbols
            if let Some(ref allowed) = self.allowed_symbols {
                if !allowed.contains(&order.symbol) {
                    result.add_error(&format!("Symbol {} not in allowed list", order.symbol));
                }
            }

            result
        }
    }

    /// Order event type
    #[derive(Debug, Clone)]
    pub enum OrderEvent {
        Created(Order),
        Submitted(String),
        Acknowledged(String),
        PartialFill { order_id: String, quantity: f64, price: f64 },
        Filled { order_id: String, quantity: f64, price: f64 },
        Cancelled(String),
        Rejected { order_id: String, reason: String },
        Expired(String),
        Modified { order_id: String, new_quantity: Option<f64>, new_price: Option<f64> },
    }

    /// Order event handler trait
    pub trait OrderEventHandler {
        fn on_event(&mut self, event: &OrderEvent);
    }

    /// Order routing destination
    #[derive(Debug, Clone, PartialEq)]
    pub enum RoutingDestination {
        Primary,
        Secondary,
        DarkPool,
        SmartRouter,
        Direct(String),
    }

    /// Smart Order Router
    pub struct SmartOrderRouter {
        pub destinations: Vec<RoutingDestination>,
        pub routing_rules: Vec<RoutingRule>,
    }

    pub struct RoutingRule {
        pub condition: fn(&Order) -> bool,
        pub destination: RoutingDestination,
        pub priority: u8,
    }

    impl SmartOrderRouter {
        pub fn new() -> Self {
            SmartOrderRouter {
                destinations: vec![
                    RoutingDestination::Primary,
                    RoutingDestination::SmartRouter,
                ],
                routing_rules: Vec::new(),
            }
        }

        pub fn add_rule(&mut self, rule: RoutingRule) {
            self.routing_rules.push(rule);
            self.routing_rules.sort_by(|a, b| b.priority.cmp(&a.priority));
        }

        pub fn route(&self, order: &Order) -> RoutingDestination {
            for rule in &self.routing_rules {
                if (rule.condition)(order) {
                    return rule.destination.clone();
                }
            }
            RoutingDestination::SmartRouter
        }

        /// Split order for TWAP execution
        pub fn split_twap(&self, order: &Order, num_slices: usize, interval_seconds: u64) -> Vec<(Order, u64)> {
            let slice_qty = order.quantity / num_slices as f64;
            (0..num_slices)
                .map(|i| {
                    let mut slice = order.clone();
                    slice.id = format!("{}-{}", order.id, i);
                    slice.quantity = slice_qty;
                    (slice, i as u64 * interval_seconds)
                })
                .collect()
        }

        /// Split order for VWAP execution
        pub fn split_vwap(&self, order: &Order, volume_profile: &[f64]) -> Vec<(Order, f64)> {
            let total_volume: f64 = volume_profile.iter().sum();
            volume_profile.iter()
                .enumerate()
                .map(|(i, &vol)| {
                    let mut slice = order.clone();
                    slice.id = format!("{}-{}", order.id, i);
                    slice.quantity = order.quantity * vol / total_volume;
                    (slice, vol / total_volume)
                })
                .collect()
        }
    }

    /// Fill tracker for order execution
    pub struct FillTracker {
        pub fills: Vec<Fill>,
        pub total_filled: f64,
        pub average_price: f64,
        pub total_commission: f64,
    }

    #[derive(Debug, Clone)]
    pub struct Fill {
        pub fill_id: String,
        pub order_id: String,
        pub quantity: f64,
        pub price: f64,
        pub commission: f64,
        pub timestamp: DateTime,
        pub venue: String,
        pub liquidity: LiquidityType,
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum LiquidityType {
        Add,      // Posted order (maker)
        Remove,   // Took liquidity (taker)
        Unknown,
    }

    impl FillTracker {
        pub fn new() -> Self {
            FillTracker {
                fills: Vec::new(),
                total_filled: 0.0,
                average_price: 0.0,
                total_commission: 0.0,
            }
        }

        pub fn add_fill(&mut self, fill: Fill) {
            let new_total = self.total_filled + fill.quantity;
            self.average_price = (self.average_price * self.total_filled + fill.price * fill.quantity) / new_total;
            self.total_filled = new_total;
            self.total_commission += fill.commission;
            self.fills.push(fill);
        }

        pub fn is_complete(&self, order_qty: f64) -> bool {
            (self.total_filled - order_qty).abs() < 1e-8
        }

        pub fn remaining(&self, order_qty: f64) -> f64 {
            (order_qty - self.total_filled).max(0.0)
        }

        /// Calculate slippage vs limit price
        pub fn slippage(&self, limit_price: f64, side: Side) -> f64 {
            match side {
                Side::Buy => (self.average_price - limit_price) / limit_price,
                Side::Sell => (limit_price - self.average_price) / limit_price,
            }
        }

        /// Get execution summary
        pub fn summary(&self) -> FillSummary {
            FillSummary {
                num_fills: self.fills.len(),
                total_quantity: self.total_filled,
                average_price: self.average_price,
                total_commission: self.total_commission,
                first_fill_time: self.fills.first().map(|f| f.timestamp),
                last_fill_time: self.fills.last().map(|f| f.timestamp),
                venues: self.fills.iter().map(|f| f.venue.clone()).collect::<Vec<_>>(),
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct FillSummary {
        pub num_fills: usize,
        pub total_quantity: f64,
        pub average_price: f64,
        pub total_commission: f64,
        pub first_fill_time: Option<DateTime>,
        pub last_fill_time: Option<DateTime>,
        pub venues: Vec<String>,
    }

    /// Order book for managing working orders
    pub struct OrderManager {
        pub orders: HashMap<String, Order>,
        pub fill_trackers: HashMap<String, FillTracker>,
        pub order_history: Vec<Order>,
        pub validators: Vec<OrderValidator>,
        pub router: SmartOrderRouter,
        pub id_gen: OrderIdGenerator,
        pub event_handlers: Vec<Box<dyn OrderEventHandler>>,
    }

    impl OrderManager {
        pub fn new() -> Self {
            OrderManager {
                orders: HashMap::new(),
                fill_trackers: HashMap::new(),
                order_history: Vec::new(),
                validators: vec![OrderValidator::new()],
                router: SmartOrderRouter::new(),
                id_gen: OrderIdGenerator::new("ORD"),
                event_handlers: Vec::new(),
            }
        }

        pub fn add_handler(&mut self, handler: Box<dyn OrderEventHandler>) {
            self.event_handlers.push(handler);
        }

        fn emit_event(&mut self, event: &OrderEvent) {
            for handler in &mut self.event_handlers {
                handler.on_event(event);
            }
        }

        /// Submit new order
        pub fn submit(&mut self, mut order: Order, market_price: f64) -> Result<String, ValidationResult> {
            // Validate
            for validator in &self.validators {
                let result = validator.validate(&order, market_price);
                if !result.is_valid {
                    return Err(result);
                }
            }

            // Assign ID if not set
            if order.id.is_empty() {
                order.id = self.id_gen.next();
            }

            // Route order
            let destination = self.router.route(&order);

            order.status = OrderStatus::Submitted;
            let id = order.id.clone();

            self.emit_event(&OrderEvent::Created(order.clone()));
            self.orders.insert(id.clone(), order);
            self.fill_trackers.insert(id.clone(), FillTracker::new());

            Ok(id)
        }

        /// Cancel order
        pub fn cancel(&mut self, order_id: &str) -> Result<(), String> {
            if let Some(order) = self.orders.get_mut(order_id) {
                match order.status {
                    OrderStatus::Filled | OrderStatus::Cancelled | OrderStatus::Expired => {
                        return Err(format!("Cannot cancel order in {} state", format!("{:?}", order.status)));
                    }
                    _ => {
                        order.status = OrderStatus::Cancelled;
                        self.emit_event(&OrderEvent::Cancelled(order_id.to_string()));
                        self.archive_order(order_id);
                        Ok(())
                    }
                }
            } else {
                Err(format!("Order {} not found", order_id))
            }
        }

        /// Modify order (price/quantity)
        pub fn modify(&mut self, order_id: &str, new_qty: Option<f64>, new_price: Option<f64>) -> Result<(), String> {
            if let Some(order) = self.orders.get_mut(order_id) {
                match order.status {
                    OrderStatus::Pending | OrderStatus::Submitted | OrderStatus::PartiallyFilled => {
                        if let Some(qty) = new_qty {
                            let tracker = self.fill_trackers.get(order_id);
                            let filled = tracker.map(|t| t.total_filled).unwrap_or(0.0);
                            if qty < filled {
                                return Err("New quantity less than filled".to_string());
                            }
                            order.quantity = qty;
                        }
                        if let Some(price) = new_price {
                            order.limit_price = Some(price);
                        }
                        self.emit_event(&OrderEvent::Modified {
                            order_id: order_id.to_string(),
                            new_quantity: new_qty,
                            new_price
                        });
                        Ok(())
                    }
                    _ => Err(format!("Cannot modify order in {:?} state", order.status))
                }
            } else {
                Err(format!("Order {} not found", order_id))
            }
        }

        /// Process fill
        pub fn on_fill(&mut self, fill: Fill) -> Result<(), String> {
            let order_id = fill.order_id.clone();

            if let Some(tracker) = self.fill_trackers.get_mut(&order_id) {
                tracker.add_fill(fill.clone());

                if let Some(order) = self.orders.get_mut(&order_id) {
                    order.filled_quantity = tracker.total_filled;
                    order.average_fill_price = tracker.average_price;

                    if tracker.is_complete(order.quantity) {
                        order.status = OrderStatus::Filled;
                        self.emit_event(&OrderEvent::Filled {
                            order_id: order_id.clone(),
                            quantity: fill.quantity,
                            price: fill.price
                        });
                        self.archive_order(&order_id);
                    } else {
                        order.status = OrderStatus::PartiallyFilled;
                        self.emit_event(&OrderEvent::PartialFill {
                            order_id: order_id.clone(),
                            quantity: fill.quantity,
                            price: fill.price
                        });
                    }
                }
                Ok(())
            } else {
                Err(format!("No tracker for order {}", order_id))
            }
        }

        fn archive_order(&mut self, order_id: &str) {
            if let Some(order) = self.orders.remove(order_id) {
                self.order_history.push(order);
            }
            self.fill_trackers.remove(order_id);
        }

        /// Get all working orders
        pub fn working_orders(&self) -> Vec<&Order> {
            self.orders.values()
                .filter(|o| matches!(o.status,
                    OrderStatus::Pending |
                    OrderStatus::Submitted |
                    OrderStatus::PartiallyFilled))
                .collect()
        }

        /// Get order by ID
        pub fn get_order(&self, id: &str) -> Option<&Order> {
            self.orders.get(id).or_else(||
                self.order_history.iter().find(|o| o.id == id))
        }
    }
}

