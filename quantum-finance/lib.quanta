// CRYPTOCURRENCY TRADING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod crypto {
    use super::*;

    /// Cryptocurrency exchange connector
    #[derive(Debug, Clone)]
    pub struct CryptoExchange {
        pub name: String,
        pub api_endpoint: String,
        pub rate_limit: usize,
        pub maker_fee: f64,
        pub taker_fee: f64,
        pub supported_pairs: Vec<String>,
    }

    impl CryptoExchange {
        pub fn new(name: &str, endpoint: &str) -> Self {
            CryptoExchange {
                name: name.to_string(),
                api_endpoint: endpoint.to_string(),
                rate_limit: 100,
                maker_fee: 0.001,
                taker_fee: 0.002,
                supported_pairs: Vec::new(),
            }
        }

        pub fn add_pair(&mut self, pair: &str) {
            self.supported_pairs.push(pair.to_string());
        }
    }

    /// Perpetual futures contract
    #[derive(Debug, Clone)]
    pub struct PerpetualFutures {
        pub symbol: String,
        pub mark_price: f64,
        pub index_price: f64,
        pub funding_rate: f64,
        pub open_interest: f64,
        pub max_leverage: f64,
    }

    impl PerpetualFutures {
        pub fn new(symbol: &str) -> Self {
            PerpetualFutures {
                symbol: symbol.to_string(),
                mark_price: 0.0,
                index_price: 0.0,
                funding_rate: 0.0,
                open_interest: 0.0,
                max_leverage: 100.0,
            }
        }

        pub fn basis(&self) -> f64 {
            if self.index_price > 0.0 {
                (self.mark_price - self.index_price) / self.index_price
            } else {
                0.0
            }
        }

        pub fn funding_payment(&self, position_size: f64) -> f64 {
            position_size * self.mark_price * self.funding_rate
        }

        pub fn liquidation_price(&self, entry_price: f64, leverage: f64, is_long: bool) -> f64 {
            let maint_margin = 0.005;
            if is_long {
                entry_price * (1.0 - 1.0 / leverage + maint_margin)
            } else {
                entry_price * (1.0 + 1.0 / leverage - maint_margin)
            }
        }
    }

    /// DeFi yield farming position
    #[derive(Debug, Clone)]
    pub struct YieldFarmPosition {
        pub protocol: String,
        pub pool: String,
        pub token_a: String,
        pub token_b: String,
        pub amount_a: f64,
        pub amount_b: f64,
        pub lp_tokens: f64,
        pub entry_prices: (f64, f64),
        pub rewards_earned: f64,
    }

    impl YieldFarmPosition {
        pub fn new(protocol: &str, pool: &str, token_a: &str, token_b: &str) -> Self {
            YieldFarmPosition {
                protocol: protocol.to_string(),
                pool: pool.to_string(),
                token_a: token_a.to_string(),
                token_b: token_b.to_string(),
                amount_a: 0.0,
                amount_b: 0.0,
                lp_tokens: 0.0,
                entry_prices: (0.0, 0.0),
                rewards_earned: 0.0,
            }
        }

        pub fn deposit(&mut self, amount_a: f64, amount_b: f64, price_a: f64, price_b: f64) {
            self.amount_a += amount_a;
            self.amount_b += amount_b;
            self.entry_prices = (price_a, price_b);
            // Simplified LP token calculation
            self.lp_tokens = (amount_a * amount_b).sqrt();
        }

        pub fn current_value(&self, price_a: f64, price_b: f64) -> f64 {
            self.amount_a * price_a + self.amount_b * price_b + self.rewards_earned
        }

        /// Calculate impermanent loss
        pub fn impermanent_loss(&self, price_a: f64, price_b: f64) -> f64 {
            let (entry_a, entry_b) = self.entry_prices;
            if entry_a == 0.0 || entry_b == 0.0 {
                return 0.0;
            }

            let price_ratio = (price_a / entry_a) / (price_b / entry_b);
            let sqrt_ratio = price_ratio.sqrt();

            2.0 * sqrt_ratio / (1.0 + price_ratio) - 1.0
        }

        pub fn apy(&self, price_a: f64, price_b: f64, days_elapsed: f64) -> f64 {
            if days_elapsed <= 0.0 { return 0.0; }

            let initial = self.entry_prices.0 * self.amount_a + self.entry_prices.1 * self.amount_b;
            if initial <= 0.0 { return 0.0; }

            let current = self.current_value(price_a, price_b);
            let daily_return = (current / initial).powf(1.0 / days_elapsed) - 1.0;
            daily_return * 365.0
        }
    }

    /// Automated Market Maker (constant product)
    #[derive(Debug, Clone)]
    pub struct ConstantProductAMM {
        pub reserve_a: f64,
        pub reserve_b: f64,
        pub fee: f64,
        pub k: f64,
    }

    impl ConstantProductAMM {
        pub fn new(reserve_a: f64, reserve_b: f64, fee: f64) -> Self {
            ConstantProductAMM {
                reserve_a,
                reserve_b,
                fee,
                k: reserve_a * reserve_b,
            }
        }

        pub fn price_a_in_b(&self) -> f64 {
            if self.reserve_a > 0.0 {
                self.reserve_b / self.reserve_a
            } else {
                0.0
            }
        }

        pub fn price_b_in_a(&self) -> f64 {
            if self.reserve_b > 0.0 {
                self.reserve_a / self.reserve_b
            } else {
                0.0
            }
        }

        pub fn swap_a_for_b(&mut self, amount_a: f64) -> f64 {
            let amount_a_with_fee = amount_a * (1.0 - self.fee);
            let new_reserve_a = self.reserve_a + amount_a_with_fee;
            let new_reserve_b = self.k / new_reserve_a;
            let amount_b_out = self.reserve_b - new_reserve_b;

            self.reserve_a = new_reserve_a;
            self.reserve_b = new_reserve_b;

            amount_b_out
        }

        pub fn swap_b_for_a(&mut self, amount_b: f64) -> f64 {
            let amount_b_with_fee = amount_b * (1.0 - self.fee);
            let new_reserve_b = self.reserve_b + amount_b_with_fee;
            let new_reserve_a = self.k / new_reserve_b;
            let amount_a_out = self.reserve_a - new_reserve_a;

            self.reserve_a = new_reserve_a;
            self.reserve_b = new_reserve_b;

            amount_a_out
        }

        pub fn get_quote_a_for_b(&self, amount_a: f64) -> f64 {
            let amount_a_with_fee = amount_a * (1.0 - self.fee);
            let new_reserve_a = self.reserve_a + amount_a_with_fee;
            let new_reserve_b = self.k / new_reserve_a;
            self.reserve_b - new_reserve_b
        }

        pub fn price_impact(&self, amount_a: f64) -> f64 {
            let spot_price = self.price_a_in_b();
            let output = self.get_quote_a_for_b(amount_a);
            let effective_price = output / amount_a;
            (spot_price - effective_price) / spot_price
        }

        pub fn add_liquidity(&mut self, amount_a: f64) -> (f64, f64) {
            let ratio = self.reserve_b / self.reserve_a;
            let amount_b = amount_a * ratio;

            self.reserve_a += amount_a;
            self.reserve_b += amount_b;
            self.k = self.reserve_a * self.reserve_b;

            (amount_a, amount_b)
        }
    }

    /// Crypto arbitrage detector
    #[derive(Debug, Clone)]
    pub struct ArbitrageDetector {
        pub exchanges: Vec<String>,
        pub prices: HashMap<String, HashMap<String, f64>>,
        pub min_profit_threshold: f64,
    }

    impl ArbitrageDetector {
        pub fn new(threshold: f64) -> Self {
            ArbitrageDetector {
                exchanges: Vec::new(),
                prices: HashMap::new(),
                min_profit_threshold: threshold,
            }
        }

        pub fn add_exchange(&mut self, name: &str) {
            self.exchanges.push(name.to_string());
            self.prices.insert(name.to_string(), HashMap::new());
        }

        pub fn update_price(&mut self, exchange: &str, pair: &str, price: f64) {
            if let Some(ex_prices) = self.prices.get_mut(exchange) {
                ex_prices.insert(pair.to_string(), price);
            }
        }

        pub fn find_opportunities(&self, pair: &str) -> Vec<ArbitrageOpportunity> {
            let mut opportunities = Vec::new();

            for buy_ex in &self.exchanges {
                for sell_ex in &self.exchanges {
                    if buy_ex == sell_ex { continue; }

                    let buy_price = self.prices.get(buy_ex)
                        .and_then(|p| p.get(pair))
                        .copied();
                    let sell_price = self.prices.get(sell_ex)
                        .and_then(|p| p.get(pair))
                        .copied();

                    if let (Some(bp), Some(sp)) = (buy_price, sell_price) {
                        if bp > 0.0 {
                            let profit_pct = (sp - bp) / bp;
                            if profit_pct > self.min_profit_threshold {
                                opportunities.push(ArbitrageOpportunity {
                                    pair: pair.to_string(),
                                    buy_exchange: buy_ex.clone(),
                                    sell_exchange: sell_ex.clone(),
                                    buy_price: bp,
                                    sell_price: sp,
                                    profit_percentage: profit_pct,
                                });
                            }
                        }
                    }
                }
            }
            opportunities.sort_by(|a, b| b.profit_percentage.partial_cmp(&a.profit_percentage).unwrap());
            opportunities
        }

        /// Triangular arbitrage detection
        pub fn find_triangular(&self, exchange: &str, base: &str) -> Vec<TriangularArb> {
            let mut arbs = Vec::new();
            let prices = match self.prices.get(exchange) {
                Some(p) => p,
                None => return arbs,
            };

            // Find all pairs involving base
            let pairs: Vec<_> = prices.keys().cloned().collect();

            for pair1 in &pairs {
                if !pair1.starts_with(base) && !pair1.ends_with(base) { continue; }

                for pair2 in &pairs {
                    if pair1 == pair2 { continue; }

                    for pair3 in &pairs {
                        if pair3 == pair1 || pair3 == pair2 { continue; }

                        // Check if forms a cycle back to base
                        if let (Some(&p1), Some(&p2), Some(&p3)) = (
                            prices.get(pair1),
                            prices.get(pair2),
                            prices.get(pair3),
                        ) {
                            let product = p1 * p2 * p3;
                            let profit = (product - 1.0).abs();

                            if profit > self.min_profit_threshold {
                                arbs.push(TriangularArb {
                                    exchange: exchange.to_string(),
                                    path: vec![pair1.clone(), pair2.clone(), pair3.clone()],
                                    profit_percentage: profit,
                                });
                            }
                        }
                    }
                }
            }
            arbs
        }
    }

    #[derive(Debug, Clone)]
    pub struct ArbitrageOpportunity {
        pub pair: String,
        pub buy_exchange: String,
        pub sell_exchange: String,
        pub buy_price: f64,
        pub sell_price: f64,
        pub profit_percentage: f64,
    }

    #[derive(Debug, Clone)]
    pub struct TriangularArb {
        pub exchange: String,
        pub path: Vec<String>,
        pub profit_percentage: f64,
    }

    /// On-chain metrics
    #[derive(Debug, Clone)]
    pub struct OnChainMetrics {
        pub active_addresses: u64,
        pub transaction_count: u64,
        pub transaction_volume: f64,
        pub hash_rate: f64,
        pub difficulty: f64,
        pub nvt_ratio: f64,
        pub mvrv_ratio: f64,
        pub realized_cap: f64,
        pub market_cap: f64,
    }

    impl OnChainMetrics {
        pub fn new() -> Self {
            OnChainMetrics {
                active_addresses: 0,
                transaction_count: 0,
                transaction_volume: 0.0,
                hash_rate: 0.0,
                difficulty: 0.0,
                nvt_ratio: 0.0,
                mvrv_ratio: 0.0,
                realized_cap: 0.0,
                market_cap: 0.0,
            }
        }

        pub fn calculate_nvt(&mut self) {
            if self.transaction_volume > 0.0 {
                self.nvt_ratio = self.market_cap / (self.transaction_volume * 365.0);
            }
        }

        pub fn calculate_mvrv(&mut self) {
            if self.realized_cap > 0.0 {
                self.mvrv_ratio = self.market_cap / self.realized_cap;
            }
        }

        pub fn is_overvalued(&self) -> bool {
            self.mvrv_ratio > 3.5 || self.nvt_ratio > 150.0
        }

        pub fn is_undervalued(&self) -> bool {
            self.mvrv_ratio < 1.0 || self.nvt_ratio < 20.0
        }
    }
}

