// ALTERNATIVE DATA
// ═══════════════════════════════════════════════════════════════════════════════

pub mod alt_data {
    use super::*;

    /// Sentiment analyzer
    #[derive(Debug, Clone)]
    pub struct SentimentAnalyzer {
        pub positive_words: Vec<String>,
        pub negative_words: Vec<String>,
        pub intensity_modifiers: HashMap<String, f64>,
    }

    impl SentimentAnalyzer {
        pub fn new() -> Self {
            let positive = vec![
                "bullish", "buy", "long", "moon", "pump", "gain", "profit",
                "growth", "surge", "rally", "breakout", "strong", "positive",
            ].into_iter().map(String::from).collect();

            let negative = vec![
                "bearish", "sell", "short", "crash", "dump", "loss", "decline",
                "drop", "plunge", "weak", "negative", "fear", "panic",
            ].into_iter().map(String::from).collect();

            let mut modifiers = HashMap::new();
            modifiers.insert("very".to_string(), 1.5);
            modifiers.insert("extremely".to_string(), 2.0);
            modifiers.insert("slightly".to_string(), 0.5);
            modifiers.insert("not".to_string(), -1.0);

            SentimentAnalyzer {
                positive_words: positive,
                negative_words: negative,
                intensity_modifiers: modifiers,
            }
        }

        pub fn analyze(&self, text: &str) -> SentimentScore {
            let words: Vec<&str> = text.to_lowercase().split_whitespace().collect();

            let mut pos_count = 0;
            let mut neg_count = 0;
            let mut modifier = 1.0;

            for (i, word) in words.iter().enumerate() {
                if let Some(&m) = self.intensity_modifiers.get(*word) {
                    modifier = m;
                    continue;
                }

                if self.positive_words.iter().any(|p| word.contains(p.as_str())) {
                    pos_count += 1;
                    if modifier < 0.0 { neg_count += 1; pos_count -= 1; }
                } else if self.negative_words.iter().any(|n| word.contains(n.as_str())) {
                    neg_count += 1;
                    if modifier < 0.0 { pos_count += 1; neg_count -= 1; }
                }

                modifier = 1.0;
            }

            let total = pos_count + neg_count;
            let score = if total > 0 {
                (pos_count as f64 - neg_count as f64) / total as f64
            } else {
                0.0
            };

            SentimentScore {
                score,
                positive_count: pos_count,
                negative_count: neg_count,
                confidence: (total as f64 / words.len() as f64).min(1.0),
            }
        }

        pub fn aggregate(&self, texts: &[&str]) -> SentimentScore {
            if texts.is_empty() {
                return SentimentScore::default();
            }

            let scores: Vec<_> = texts.iter().map(|t| self.analyze(t)).collect();

            let avg_score = scores.iter().map(|s| s.score).sum::<f64>() / scores.len() as f64;
            let total_pos: usize = scores.iter().map(|s| s.positive_count).sum();
            let total_neg: usize = scores.iter().map(|s| s.negative_count).sum();
            let avg_conf = scores.iter().map(|s| s.confidence).sum::<f64>() / scores.len() as f64;

            SentimentScore {
                score: avg_score,
                positive_count: total_pos,
                negative_count: total_neg,
                confidence: avg_conf,
            }
        }
    }

    #[derive(Debug, Clone, Default)]
    pub struct SentimentScore {
        pub score: f64,
        pub positive_count: usize,
        pub negative_count: usize,
        pub confidence: f64,
    }

    impl SentimentScore {
        pub fn is_bullish(&self) -> bool {
            self.score > 0.2 && self.confidence > 0.3
        }

        pub fn is_bearish(&self) -> bool {
            self.score < -0.2 && self.confidence > 0.3
        }
    }

    /// News impact analyzer
    #[derive(Debug, Clone)]
    pub struct NewsAnalyzer {
        pub sentiment: SentimentAnalyzer,
        pub keyword_weights: HashMap<String, f64>,
        pub source_credibility: HashMap<String, f64>,
    }

    impl NewsAnalyzer {
        pub fn new() -> Self {
            let mut keywords = HashMap::new();
            keywords.insert("earnings".to_string(), 2.0);
            keywords.insert("merger".to_string(), 2.5);
            keywords.insert("acquisition".to_string(), 2.5);
            keywords.insert("bankruptcy".to_string(), 3.0);
            keywords.insert("lawsuit".to_string(), 1.5);
            keywords.insert("fda".to_string(), 2.0);
            keywords.insert("sec".to_string(), 1.8);

            let mut sources = HashMap::new();
            sources.insert("reuters".to_string(), 0.9);
            sources.insert("bloomberg".to_string(), 0.9);
            sources.insert("wsj".to_string(), 0.85);
            sources.insert("twitter".to_string(), 0.4);

            NewsAnalyzer {
                sentiment: SentimentAnalyzer::new(),
                keyword_weights: keywords,
                source_credibility: sources,
            }
        }

        pub fn analyze_article(&self, title: &str, body: &str, source: &str) -> NewsImpact {
            let title_sent = self.sentiment.analyze(title);
            let body_sent = self.sentiment.analyze(body);

            let combined_sentiment = title_sent.score * 0.4 + body_sent.score * 0.6;

            let mut keyword_score = 0.0;
            let text = format!("{} {}", title, body).to_lowercase();
            for (kw, &weight) in &self.keyword_weights {
                if text.contains(kw) {
                    keyword_score += weight;
                }
            }

            let credibility = self.source_credibility.get(source).copied().unwrap_or(0.5);

            let impact = combined_sentiment * (1.0 + keyword_score) * credibility;

            NewsImpact {
                sentiment: combined_sentiment,
                keyword_relevance: keyword_score,
                source_credibility: credibility,
                overall_impact: impact,
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct NewsImpact {
        pub sentiment: f64,
        pub keyword_relevance: f64,
        pub source_credibility: f64,
        pub overall_impact: f64,
    }

    /// Social media metrics tracker
    #[derive(Debug, Clone)]
    pub struct SocialMetrics {
        pub symbol: String,
        pub mentions_1h: usize,
        pub mentions_24h: usize,
        pub mentions_7d: usize,
        pub sentiment_1h: f64,
        pub sentiment_24h: f64,
        pub unique_authors: usize,
        pub engagement_rate: f64,
    }

    impl SocialMetrics {
        pub fn new(symbol: &str) -> Self {
            SocialMetrics {
                symbol: symbol.to_string(),
                mentions_1h: 0,
                mentions_24h: 0,
                mentions_7d: 0,
                sentiment_1h: 0.0,
                sentiment_24h: 0.0,
                unique_authors: 0,
                engagement_rate: 0.0,
            }
        }

        pub fn momentum(&self) -> f64 {
            if self.mentions_24h > 0 {
                (self.mentions_1h as f64 * 24.0) / self.mentions_24h as f64
            } else {
                0.0
            }
        }

        pub fn weekly_trend(&self) -> f64 {
            if self.mentions_7d > 0 {
                (self.mentions_24h as f64 * 7.0) / self.mentions_7d as f64
            } else {
                0.0
            }
        }

        pub fn is_trending(&self) -> bool {
            self.momentum() > 2.0 && self.sentiment_1h > 0.0
        }
    }

    /// Options flow analyzer
    #[derive(Debug, Clone)]
    pub struct OptionsFlowAnalyzer {
        pub flows: Vec<OptionsFlow>,
        pub call_volume: u64,
        pub put_volume: u64,
        pub call_premium: f64,
        pub put_premium: f64,
    }

    impl OptionsFlowAnalyzer {
        pub fn new() -> Self {
            OptionsFlowAnalyzer {
                flows: Vec::new(),
                call_volume: 0,
                put_volume: 0,
                call_premium: 0.0,
                put_premium: 0.0,
            }
        }

        pub fn add_flow(&mut self, flow: OptionsFlow) {
            match flow.option_type {
                super::options::OptionType::Call => {
                    self.call_volume += flow.volume;
                    self.call_premium += flow.premium;
                }
                super::options::OptionType::Put => {
                    self.put_volume += flow.volume;
                    self.put_premium += flow.premium;
                }
            }
            self.flows.push(flow);
        }

        pub fn put_call_ratio(&self) -> f64 {
            if self.call_volume > 0 {
                self.put_volume as f64 / self.call_volume as f64
            } else {
                0.0
            }
        }

        pub fn premium_ratio(&self) -> f64 {
            if self.call_premium > 0.0 {
                self.put_premium / self.call_premium
            } else {
                0.0
            }
        }

        pub fn unusual_activity(&self, threshold_multiplier: f64) -> Vec<&OptionsFlow> {
            let avg_premium: f64 = self.flows.iter().map(|f| f.premium).sum::<f64>()
                / self.flows.len().max(1) as f64;

            self.flows.iter()
                .filter(|f| f.premium > avg_premium * threshold_multiplier)
                .collect()
        }

        pub fn sentiment_signal(&self) -> f64 {
            let pcr = self.put_call_ratio();

            if pcr < 0.5 { 1.0 }
            else if pcr < 0.7 { 0.5 }
            else if pcr < 1.0 { 0.0 }
            else if pcr < 1.3 { -0.5 }
            else { -1.0 }
        }
    }

    #[derive(Debug, Clone)]
    pub struct OptionsFlow {
        pub symbol: String,
        pub option_type: super::options::OptionType,
        pub strike: f64,
        pub expiry: DateTime,
        pub volume: u64,
        pub open_interest: u64,
        pub premium: f64,
        pub is_sweep: bool,
        pub exchange: String,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REAL-TIME MARKET DATA - WebSocket Streaming
// ═══════════════════════════════════════════════════════════════════════════════

pub mod realtime {
    use super::*;

    /// WebSocket connection state
    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum ConnectionState {
        Disconnected,
        Connecting,
        Connected,
        Reconnecting,
        Error,
    }

    /// Market data message types
    #[derive(Debug, Clone)]
    pub enum MarketMessage {
        Trade { symbol: String, price: f64, size: f64, timestamp: u64 },
        Quote { symbol: String, bid: f64, ask: f64, bid_size: f64, ask_size: f64 },
        Bar { symbol: String, candle: Candle },
        OrderBook { symbol: String, book: OrderBook },
        Status { symbol: String, status: String },
        Error { code: i32, message: String },
    }

    /// Subscription types
    #[derive(Debug, Clone)]
    pub enum Subscription {
        Trades(String),
        Quotes(String),
        Bars { symbol: String, timeframe: Timeframe },
        OrderBook { symbol: String, depth: usize },
        News(String),
    }

    /// WebSocket market data client
    pub struct MarketDataClient {
        state: ConnectionState,
        subscriptions: Vec<Subscription>,
        message_buffer: VecDeque<MarketMessage>,
        reconnect_attempts: u32,
        max_reconnect_attempts: u32,
        heartbeat_interval_ms: u64,
        last_heartbeat: u64,
    }

    impl MarketDataClient {
        pub fn new() -> Self {
            Self {
                state: ConnectionState::Disconnected,
                subscriptions: Vec::new(),
                message_buffer: VecDeque::with_capacity(10000),
                reconnect_attempts: 0,
                max_reconnect_attempts: 5,
                heartbeat_interval_ms: 30000,
                last_heartbeat: 0,
            }
        }

        pub fn connect(&mut self, url: &str) -> Result<(), String> {
            self.state = ConnectionState::Connecting;
            // WebSocket connection logic would go here
            self.state = ConnectionState::Connected;
            self.reconnect_attempts = 0;
            Ok(())
        }

        pub fn disconnect(&mut self) {
            self.state = ConnectionState::Disconnected;
            self.subscriptions.clear();
        }

        pub fn subscribe(&mut self, sub: Subscription) -> Result<(), String> {
            if self.state != ConnectionState::Connected {
                return Err("Not connected".to_string());
            }
            self.subscriptions.push(sub);
            Ok(())
        }

        pub fn unsubscribe(&mut self, symbol: &str) {
            self.subscriptions.retain(|s| match s {
                Subscription::Trades(sym) | Subscription::Quotes(sym) | Subscription::News(sym) => sym != symbol,
                Subscription::Bars { symbol: sym, .. } | Subscription::OrderBook { symbol: sym, .. } => sym != symbol,
            });
        }

        pub fn poll(&mut self) -> Option<MarketMessage> {
            self.message_buffer.pop_front()
        }

        pub fn poll_all(&mut self) -> Vec<MarketMessage> {
            self.message_buffer.drain(..).collect()
        }

        fn handle_message(&mut self, msg: MarketMessage) {
            if self.message_buffer.len() >= 10000 {
                self.message_buffer.pop_front();
            }
            self.message_buffer.push_back(msg);
        }

        pub fn state(&self) -> ConnectionState {
            self.state
        }
    }

    /// Aggregated trade stream
    pub struct TradeAggregator {
        trades: HashMap<String, Vec<AggregatedTrade>>,
        window_ms: u64,
    }

    #[derive(Debug, Clone)]
    pub struct AggregatedTrade {
        pub symbol: String,
        pub price: f64,
        pub total_volume: f64,
        pub trade_count: u32,
        pub vwap: f64,
        pub start_time: u64,
        pub end_time: u64,
    }

    impl TradeAggregator {
        pub fn new(window_ms: u64) -> Self {
            Self {
                trades: HashMap::new(),
                window_ms,
            }
        }

        pub fn add_trade(&mut self, symbol: &str, price: f64, size: f64, timestamp: u64) {
            let trades = self.trades.entry(symbol.to_string()).or_insert_with(Vec::new);

            if let Some(last) = trades.last_mut() {
                if timestamp - last.start_time < self.window_ms {
                    let new_volume = last.total_volume + size;
                    last.vwap = (last.vwap * last.total_volume + price * size) / new_volume;
                    last.total_volume = new_volume;
                    last.trade_count += 1;
                    last.end_time = timestamp;
                    return;
                }
            }

            trades.push(AggregatedTrade {
                symbol: symbol.to_string(),
                price,
                total_volume: size,
                trade_count: 1,
                vwap: price,
                start_time: timestamp,
                end_time: timestamp,
            });
        }

        pub fn get_recent(&self, symbol: &str, count: usize) -> Vec<&AggregatedTrade> {
            self.trades.get(symbol)
                .map(|t| t.iter().rev().take(count).collect())
                .unwrap_or_default()
        }
    }

    /// Level 2 order book manager
    pub struct Level2Manager {
        books: HashMap<String, DetailedOrderBook>,
    }

    #[derive(Debug, Clone)]
    pub struct DetailedOrderBook {
        pub symbol: String,
        pub bids: Vec<PriceLevel>,
        pub asks: Vec<PriceLevel>,
        pub last_update: u64,
        pub sequence: u64,
    }

    #[derive(Debug, Clone)]
    pub struct PriceLevel {
        pub price: f64,
        pub size: f64,
        pub order_count: u32,
        pub market_maker: Option<String>,
    }

    impl Level2Manager {
        pub fn new() -> Self {
            Self { books: HashMap::new() }
        }

        pub fn update(&mut self, symbol: &str, bids: Vec<PriceLevel>, asks: Vec<PriceLevel>, seq: u64) {
            let book = self.books.entry(symbol.to_string()).or_insert_with(|| DetailedOrderBook {
                symbol: symbol.to_string(),
                bids: Vec::new(),
                asks: Vec::new(),
                last_update: 0,
                sequence: 0,
            });

            if seq > book.sequence {
                book.bids = bids;
                book.asks = asks;
                book.sequence = seq;
                book.last_update = std::time::SystemTime::now()
                    .duration_since(std::time::UNIX_EPOCH)
                    .unwrap_or_default()
                    .as_millis() as u64;
            }
        }

        pub fn get_book(&self, symbol: &str) -> Option<&DetailedOrderBook> {
            self.books.get(symbol)
        }

        pub fn spread(&self, symbol: &str) -> Option<f64> {
            self.books.get(symbol).and_then(|b| {
                let best_bid = b.bids.first()?.price;
                let best_ask = b.asks.first()?.price;
                Some(best_ask - best_bid)
            })
        }

        pub fn mid_price(&self, symbol: &str) -> Option<f64> {
            self.books.get(symbol).and_then(|b| {
                let best_bid = b.bids.first()?.price;
                let best_ask = b.asks.first()?.price;
                Some((best_bid + best_ask) / 2.0)
            })
        }

        pub fn imbalance(&self, symbol: &str, levels: usize) -> Option<f64> {
            self.books.get(symbol).map(|b| {
                let bid_vol: f64 = b.bids.iter().take(levels).map(|l| l.size).sum();
                let ask_vol: f64 = b.asks.iter().take(levels).map(|l| l.size).sum();
                let total = bid_vol + ask_vol;
                if total > 0.0 { (bid_vol - ask_vol) / total } else { 0.0 }
            })
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-ASSET PORTFOLIO MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod multi_asset {
    use super::*;

    /// Asset class types
    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum AssetClass {
        Equity,
        FixedIncome,
        Commodity,
        Currency,
        RealEstate,
        Crypto,
        Derivatives,
        Alternative,
    }

    /// Asset definition
    #[derive(Debug, Clone)]
    pub struct Asset {
        pub symbol: String,
        pub name: String,
        pub asset_class: AssetClass,
        pub currency: String,
        pub exchange: String,
        pub lot_size: f64,
        pub tick_size: f64,
        pub margin_requirement: f64,
    }

    /// Multi-asset position
    #[derive(Debug, Clone)]
    pub struct MultiAssetPosition {
        pub asset: Asset,
        pub quantity: f64,
        pub average_cost: f64,
        pub current_price: f64,
        pub unrealized_pnl: f64,
        pub realized_pnl: f64,
        pub margin_used: f64,
    }

    impl MultiAssetPosition {
        pub fn market_value(&self) -> f64 {
            self.quantity * self.current_price
        }

        pub fn total_pnl(&self) -> f64 {
            self.unrealized_pnl + self.realized_pnl
        }

        pub fn return_pct(&self) -> f64 {
            let cost = self.quantity * self.average_cost;
            if cost != 0.0 { self.unrealized_pnl / cost * 100.0 } else { 0.0 }
        }
    }

    /// Multi-asset portfolio
    pub struct MultiAssetPortfolio {
        pub name: String,
        pub base_currency: String,
        pub positions: HashMap<String, MultiAssetPosition>,
        pub cash_balances: HashMap<String, f64>,
        pub fx_rates: HashMap<String, f64>,
        pub target_allocations: HashMap<AssetClass, f64>,
    }

    impl MultiAssetPortfolio {
        pub fn new(name: &str, base_currency: &str, initial_cash: f64) -> Self {
            let mut cash = HashMap::new();
            cash.insert(base_currency.to_string(), initial_cash);

            Self {
                name: name.to_string(),
                base_currency: base_currency.to_string(),
                positions: HashMap::new(),
                cash_balances: cash,
                fx_rates: HashMap::new(),
                target_allocations: HashMap::new(),
            }
        }

        pub fn update_fx_rate(&mut self, currency: &str, rate: f64) {
            self.fx_rates.insert(currency.to_string(), rate);
        }

        pub fn set_target_allocation(&mut self, asset_class: AssetClass, weight: f64) {
            self.target_allocations.insert(asset_class, weight);
        }

        pub fn total_nav(&self) -> f64 {
            let positions_value: f64 = self.positions.values()
                .map(|p| {
                    let rate = self.fx_rates.get(&p.asset.currency).unwrap_or(&1.0);
                    p.market_value() * rate
                })
                .sum();

            let cash_value: f64 = self.cash_balances.iter()
                .map(|(currency, amount)| {
                    let rate = self.fx_rates.get(currency).unwrap_or(&1.0);
                    amount * rate
                })
                .sum();

            positions_value + cash_value
        }

        pub fn allocation_by_class(&self) -> HashMap<AssetClass, f64> {
            let nav = self.total_nav();
            if nav == 0.0 { return HashMap::new(); }

            let mut allocations = HashMap::new();
            for pos in self.positions.values() {
                let rate = self.fx_rates.get(&pos.asset.currency).unwrap_or(&1.0);
                let value = pos.market_value() * rate;
                *allocations.entry(pos.asset.asset_class).or_insert(0.0) += value / nav;
            }
            allocations
        }

        pub fn rebalance_trades(&self) -> Vec<RebalanceTrade> {
            let nav = self.total_nav();
            let current = self.allocation_by_class();
            let mut trades = Vec::new();

            for (class, target_weight) in &self.target_allocations {
                let current_weight = current.get(class).unwrap_or(&0.0);
                let diff = target_weight - current_weight;

                if diff.abs() > 0.01 {
                    trades.push(RebalanceTrade {
                        asset_class: *class,
                        target_value: nav * target_weight,
                        current_value: nav * current_weight,
                        trade_value: nav * diff,
                    });
                }
            }
            trades
        }

        pub fn margin_utilization(&self) -> f64 {
            let margin_used: f64 = self.positions.values().map(|p| p.margin_used).sum();
            let nav = self.total_nav();
            if nav > 0.0 { margin_used / nav } else { 0.0 }
        }

        pub fn currency_exposure(&self) -> HashMap<String, f64> {
            let mut exposure = HashMap::new();
            for pos in self.positions.values() {
                *exposure.entry(pos.asset.currency.clone()).or_insert(0.0) += pos.market_value();
            }
            for (currency, amount) in &self.cash_balances {
                *exposure.entry(currency.clone()).or_insert(0.0) += amount;
            }
            exposure
        }
    }

    #[derive(Debug, Clone)]
    pub struct RebalanceTrade {
        pub asset_class: AssetClass,
        pub target_value: f64,
        pub current_value: f64,
        pub trade_value: f64,
    }

    /// Factor exposure analysis
    pub struct FactorModel {
        pub factors: Vec<String>,
        pub factor_returns: HashMap<String, Vec<f64>>,
        pub factor_loadings: HashMap<String, HashMap<String, f64>>,
    }

    impl FactorModel {
        pub fn new(factors: Vec<String>) -> Self {
            Self {
                factors,
                factor_returns: HashMap::new(),
                factor_loadings: HashMap::new(),
            }
        }

        pub fn set_loading(&mut self, symbol: &str, factor: &str, loading: f64) {
            self.factor_loadings
                .entry(symbol.to_string())
                .or_insert_with(HashMap::new)
                .insert(factor.to_string(), loading);
        }

        pub fn portfolio_factor_exposure(&self, weights: &HashMap<String, f64>) -> HashMap<String, f64> {
            let mut exposure = HashMap::new();

            for factor in &self.factors {
                let mut factor_exp = 0.0;
                for (symbol, weight) in weights {
                    if let Some(loadings) = self.factor_loadings.get(symbol) {
                        if let Some(loading) = loadings.get(factor) {
                            factor_exp += weight * loading;
                        }
                    }
                }
                exposure.insert(factor.clone(), factor_exp);
            }
            exposure
        }

        pub fn expected_return(&self, weights: &HashMap<String, f64>, factor_premiums: &HashMap<String, f64>) -> f64 {
            let exposures = self.portfolio_factor_exposure(weights);
            exposures.iter()
                .map(|(factor, exp)| exp * factor_premiums.get(factor).unwrap_or(&0.0))
                .sum()
        }
    }

    /// Currency hedging
    pub struct CurrencyHedger {
        base_currency: String,
        hedge_ratios: HashMap<String, f64>,
        forward_rates: HashMap<String, f64>,
    }

    impl CurrencyHedger {
        pub fn new(base_currency: &str) -> Self {
            Self {
                base_currency: base_currency.to_string(),
                hedge_ratios: HashMap::new(),
                forward_rates: HashMap::new(),
            }
        }

        pub fn set_hedge_ratio(&mut self, currency: &str, ratio: f64) {
            self.hedge_ratios.insert(currency.to_string(), ratio.clamp(0.0, 1.0));
        }

        pub fn set_forward_rate(&mut self, currency: &str, rate: f64) {
            self.forward_rates.insert(currency.to_string(), rate);
        }

        pub fn hedge_cost(&self, currency: &str, exposure: f64, spot_rate: f64) -> f64 {
            let ratio = self.hedge_ratios.get(currency).unwrap_or(&0.0);
            let forward = self.forward_rates.get(currency).unwrap_or(&spot_rate);
            let hedged_amount = exposure * ratio;
            hedged_amount * (forward - spot_rate)
        }

        pub fn hedged_exposure(&self, exposures: &HashMap<String, f64>) -> HashMap<String, f64> {
            exposures.iter().map(|(currency, exp)| {
                let ratio = self.hedge_ratios.get(currency).unwrap_or(&0.0);
                (currency.clone(), exp * (1.0 - ratio))
            }).collect()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MACHINE LEARNING SIGNALS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod ml_signals {
    use super::*;

    /// Feature types for ML models
    #[derive(Debug, Clone)]
    pub enum Feature {
        Price(f64),
        Return(f64),
        Volume(f64),
        Indicator { name: String, value: f64 },
        Sentiment(f64),
        Volatility(f64),
        Correlation { symbol: String, value: f64 },
        OrderFlow(f64),
        Custom { name: String, value: f64 },
    }

    /// Feature vector for ML input
    #[derive(Debug, Clone)]
    pub struct FeatureVector {
        pub timestamp: u64,
        pub symbol: String,
        pub features: Vec<f64>,
        pub feature_names: Vec<String>,
    }

    impl FeatureVector {
        pub fn new(symbol: &str, timestamp: u64) -> Self {
            Self {
                timestamp,
                symbol: symbol.to_string(),
                features: Vec::new(),
                feature_names: Vec::new(),
            }
        }

        pub fn add(&mut self, name: &str, value: f64) {
            self.feature_names.push(name.to_string());
            self.features.push(value);
        }

        pub fn normalize(&mut self, means: &[f64], stds: &[f64]) {
            for (i, val) in self.features.iter_mut().enumerate() {
                if i < means.len() && i < stds.len() && stds[i] > 0.0 {
                    *val = (*val - means[i]) / stds[i];
                }
            }
        }
    }

    /// Feature extractor from market data
    pub struct FeatureExtractor {
        lookback: usize,
        feature_config: Vec<FeatureConfig>,
    }

    #[derive(Debug, Clone)]
    pub struct FeatureConfig {
        pub name: String,
        pub feature_type: FeatureType,
        pub params: HashMap<String, f64>,
    }

    #[derive(Debug, Clone)]
    pub enum FeatureType {
        Returns { periods: usize },
        SMA { period: usize },
        EMA { period: usize },
        RSI { period: usize },
        MACD { fast: usize, slow: usize, signal: usize },
        BollingerBand { period: usize, std_dev: f64 },
        ATR { period: usize },
        VolumeRatio { period: usize },
        PricePosition { period: usize },
        Momentum { period: usize },
    }

    impl FeatureExtractor {
        pub fn new(lookback: usize) -> Self {
            Self {
                lookback,
                feature_config: Vec::new(),
            }
        }

        pub fn add_feature(&mut self, config: FeatureConfig) {
            self.feature_config.push(config);
        }

        pub fn add_default_features(&mut self) {
            self.feature_config.extend(vec![
                FeatureConfig { name: "ret_1d".into(), feature_type: FeatureType::Returns { periods: 1 }, params: HashMap::new() },
                FeatureConfig { name: "ret_5d".into(), feature_type: FeatureType::Returns { periods: 5 }, params: HashMap::new() },
                FeatureConfig { name: "ret_20d".into(), feature_type: FeatureType::Returns { periods: 20 }, params: HashMap::new() },
                FeatureConfig { name: "sma_20".into(), feature_type: FeatureType::SMA { period: 20 }, params: HashMap::new() },
                FeatureConfig { name: "sma_50".into(), feature_type: FeatureType::SMA { period: 50 }, params: HashMap::new() },
                FeatureConfig { name: "rsi_14".into(), feature_type: FeatureType::RSI { period: 14 }, params: HashMap::new() },
                FeatureConfig { name: "atr_14".into(), feature_type: FeatureType::ATR { period: 14 }, params: HashMap::new() },
                FeatureConfig { name: "mom_10".into(), feature_type: FeatureType::Momentum { period: 10 }, params: HashMap::new() },
            ]);
        }

        pub fn extract(&self, candles: &[Candle], symbol: &str) -> Option<FeatureVector> {
            if candles.len() < self.lookback { return None; }

            let mut fv = FeatureVector::new(symbol, candles.last()?.timestamp);
            let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
            let highs: Vec<f64> = candles.iter().map(|c| c.high).collect();
            let lows: Vec<f64> = candles.iter().map(|c| c.low).collect();
            let volumes: Vec<f64> = candles.iter().map(|c| c.volume).collect();

            for config in &self.feature_config {
                let value = match &config.feature_type {
                    FeatureType::Returns { periods } => {
                        if closes.len() > *periods {
                            let curr = closes[closes.len() - 1];
                            let prev = closes[closes.len() - 1 - periods];
                            if prev > 0.0 { (curr - prev) / prev } else { 0.0 }
                        } else { 0.0 }
                    }
                    FeatureType::SMA { period } => {
                        if closes.len() >= *period {
                            closes[closes.len() - period..].iter().sum::<f64>() / *period as f64
                        } else { 0.0 }
                    }
                    FeatureType::RSI { period } => {
                        indicators::rsi(&closes, *period).last().copied().unwrap_or(50.0)
                    }
                    FeatureType::Momentum { period } => {
                        if closes.len() > *period {
                            closes[closes.len() - 1] - closes[closes.len() - 1 - period]
                        } else { 0.0 }
                    }
                    _ => 0.0,
                };
                fv.add(&config.name, value);
            }

            Some(fv)
        }
    }

    /// ML signal generator
    pub struct SignalGenerator {
        model_weights: Vec<f64>,
        feature_means: Vec<f64>,
        feature_stds: Vec<f64>,
        threshold_long: f64,
        threshold_short: f64,
    }

    impl SignalGenerator {
        pub fn new(weights: Vec<f64>, means: Vec<f64>, stds: Vec<f64>) -> Self {
            Self {
                model_weights: weights,
                feature_means: means,
                feature_stds: stds,
                threshold_long: 0.6,
                threshold_short: 0.4,
            }
        }

        pub fn predict(&self, features: &FeatureVector) -> f64 {
            let mut normalized = features.clone();
            normalized.normalize(&self.feature_means, &self.feature_stds);

            let mut score = 0.0;
            for (i, &feat) in normalized.features.iter().enumerate() {
                if i < self.model_weights.len() {
                    score += feat * self.model_weights[i];
                }
            }

            1.0 / (1.0 + (-score).exp())
        }

        pub fn generate_signal(&self, features: &FeatureVector) -> Signal {
            let prob = self.predict(features);

            if prob > self.threshold_long {
                Signal::Long { confidence: prob, strength: (prob - 0.5) * 2.0 }
            } else if prob < self.threshold_short {
                Signal::Short { confidence: 1.0 - prob, strength: (0.5 - prob) * 2.0 }
            } else {
                Signal::Neutral
            }
        }
    }

    #[derive(Debug, Clone)]
    pub enum Signal {
        Long { confidence: f64, strength: f64 },
        Short { confidence: f64, strength: f64 },
        Neutral,
    }

    /// Ensemble signal combiner
    pub struct EnsembleSignal {
        signals: Vec<(String, Signal, f64)>,
    }

    impl EnsembleSignal {
        pub fn new() -> Self {
            Self { signals: Vec::new() }
        }

        pub fn add_signal(&mut self, model_name: &str, signal: Signal, weight: f64) {
            self.signals.push((model_name.to_string(), signal, weight));
        }

        pub fn combined_signal(&self) -> Signal {
            let mut long_score = 0.0;
            let mut short_score = 0.0;
            let mut total_weight = 0.0;

            for (_, signal, weight) in &self.signals {
                total_weight += weight;
                match signal {
                    Signal::Long { confidence, strength } => {
                        long_score += weight * confidence * strength;
                    }
                    Signal::Short { confidence, strength } => {
                        short_score += weight * confidence * strength;
                    }
                    Signal::Neutral => {}
                }
            }

            if total_weight == 0.0 { return Signal::Neutral; }

            let net = (long_score - short_score) / total_weight;

            if net > 0.2 {
                Signal::Long { confidence: net.abs().min(1.0), strength: net.abs() }
            } else if net < -0.2 {
                Signal::Short { confidence: net.abs().min(1.0), strength: net.abs() }
            } else {
                Signal::Neutral
            }
        }

        pub fn signal_agreement(&self) -> f64 {
            let mut long_count = 0;
            let mut short_count = 0;

            for (_, signal, _) in &self.signals {
                match signal {
                    Signal::Long { .. } => long_count += 1,
                    Signal::Short { .. } => short_count += 1,
                    Signal::Neutral => {}
                }
            }

            let total = self.signals.len();
            if total == 0 { return 0.0; }

            let max_count = long_count.max(short_count) as f64;
            max_count / total as f64
        }
    }

    /// Walk-forward optimization
    pub struct WalkForwardOptimizer {
        train_window: usize,
        test_window: usize,
        step_size: usize,
        parameter_ranges: HashMap<String, (f64, f64, f64)>,
    }

    impl WalkForwardOptimizer {
        pub fn new(train: usize, test: usize, step: usize) -> Self {
            Self {
                train_window: train,
                test_window: test,
                step_size: step,
                parameter_ranges: HashMap::new(),
            }
        }

        pub fn add_parameter(&mut self, name: &str, min: f64, max: f64, step: f64) {
            self.parameter_ranges.insert(name.to_string(), (min, max, step));
        }

        pub fn optimize<F>(&self, data: &[Candle], objective: F) -> Vec<WalkForwardResult>
        where F: Fn(&[Candle], &HashMap<String, f64>) -> f64
        {
            let mut results = Vec::new();
            let total_len = data.len();

            let mut start = 0;
            while start + self.train_window + self.test_window <= total_len {
                let train_end = start + self.train_window;
                let test_end = train_end + self.test_window;

                let train_data = &data[start..train_end];
                let test_data = &data[train_end..test_end];

                let best_params = self.grid_search(train_data, &objective);
                let out_of_sample = objective(test_data, &best_params);

                results.push(WalkForwardResult {
                    train_start: start,
                    train_end,
                    test_start: train_end,
                    test_end,
                    best_parameters: best_params,
                    out_of_sample_performance: out_of_sample,
                });

                start += self.step_size;
            }

            results
        }

        fn grid_search<F>(&self, train_data: &[Candle], objective: &F) -> HashMap<String, f64>
        where F: Fn(&[Candle], &HashMap<String, f64>) -> f64
        {
            let mut best_params = HashMap::new();
            let mut best_score = f64::NEG_INFINITY;

            let param_grids: Vec<(String, Vec<f64>)> = self.parameter_ranges.iter()
                .map(|(name, (min, max, step))| {
                    let mut values = Vec::new();
                    let mut v = *min;
                    while v <= *max {
                        values.push(v);
                        v += step;
                    }
                    (name.clone(), values)
                })
                .collect();

            fn generate_combinations(grids: &[(String, Vec<f64>)], current: HashMap<String, f64>, results: &mut Vec<HashMap<String, f64>>) {
                if grids.is_empty() {
                    results.push(current);
                    return;
                }
                let (name, values) = &grids[0];
                for &v in values {
                    let mut next = current.clone();
                    next.insert(name.clone(), v);
                    generate_combinations(&grids[1..], next, results);
                }
            }

            let mut combinations = Vec::new();
            generate_combinations(&param_grids, HashMap::new(), &mut combinations);

            for params in combinations {
                let score = objective(train_data, &params);
                if score > best_score {
                    best_score = score;
                    best_params = params;
                }
            }

            best_params
        }
    }

    #[derive(Debug)]
    pub struct WalkForwardResult {
        pub train_start: usize,
        pub train_end: usize,
        pub test_start: usize,
        pub test_end: usize,
        pub best_parameters: HashMap<String, f64>,
        pub out_of_sample_performance: f64,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXECUTION ALGORITHMS
// ═══════════════════════════════════════════════════════════════════════════════

module execution_algos {
    use super::*;

    /// TWAP (Time-Weighted Average Price) execution
    pub struct TWAPExecutor {
        symbol: String,
        total_quantity: f64,
        start_time: DateTime,
        end_time: DateTime,
        num_slices: i32,
        filled_slices: i32,
        filled_quantity: f64,
        randomize: bool,
        variance_pct: f64,
    }

    impl TWAPExecutor {
        pub fn new(symbol: &str, quantity: f64, duration_mins: i32, slices: i32) -> Self {
            let start = DateTime::now();
            Self {
                symbol: symbol.to_string(),
                total_quantity: quantity,
                start_time: start,
                end_time: start.add_minutes(duration_mins),
                num_slices: slices,
                filled_slices: 0,
                filled_quantity: 0.0,
                randomize: true,
                variance_pct: 0.1,
            }
        }

        pub fn next_order(&mut self) -> Option<Order> {
            if self.filled_slices >= self.num_slices {
                return None;
            }

            let remaining = self.total_quantity - self.filled_quantity;
            let remaining_slices = self.num_slices - self.filled_slices;
            let mut slice_qty = remaining / remaining_slices as f64;

            if self.randomize {
                let variance = slice_qty * self.variance_pct;
                slice_qty += random::uniform(-variance, variance);
                slice_qty = slice_qty.max(0.0).min(remaining);
            }

            self.filled_slices += 1;

            Some(Order {
                id: uuid::new_v4(),
                symbol: self.symbol.clone(),
                side: if self.total_quantity > 0.0 { Side::Buy } else { Side::Sell },
                order_type: OrderType::Market,
                quantity: slice_qty.abs(),
                limit_price: None,
                stop_price: None,
                time_in_force: TimeInForce::IOC,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            })
        }

        pub fn record_fill(&mut self, quantity: f64) {
            self.filled_quantity += quantity;
        }

        pub fn completion_pct(&self) -> f64 {
            (self.filled_quantity / self.total_quantity.abs()) * 100.0
        }
    }

    /// VWAP execution algorithm
    pub struct VWAPExecutor {
        symbol: String,
        total_quantity: f64,
        volume_profile: Vec<f64>,
        current_bucket: usize,
        filled_quantity: f64,
        participation_rate: f64,
        max_pct_volume: f64,
    }

    impl VWAPExecutor {
        pub fn new(symbol: &str, quantity: f64, profile: Vec<f64>) -> Self {
            let sum: f64 = profile.iter().sum();
            let normalized: Vec<f64> = profile.iter().map(|v| v / sum).collect();

            Self {
                symbol: symbol.to_string(),
                total_quantity: quantity,
                volume_profile: normalized,
                current_bucket: 0,
                filled_quantity: 0.0,
                participation_rate: 0.10,
                max_pct_volume: 0.25,
            }
        }

        pub fn from_historical(symbol: &str, quantity: f64, days: i32) -> Self {
            let mut profile = Vec::new();
            for hour in 0..7 {
                let weight = match hour {
                    0 => 0.18,
                    1 => 0.12,
                    2 => 0.10,
                    3 => 0.10,
                    4 => 0.10,
                    5 => 0.15,
                    6 => 0.25,
                    _ => 0.10,
                };
                profile.push(weight);
            }
            Self::new(symbol, quantity, profile)
        }

        pub fn next_order(&mut self, current_volume: f64) -> Option<Order> {
            if self.current_bucket >= self.volume_profile.len() {
                return None;
            }

            let remaining = self.total_quantity - self.filled_quantity;
            if remaining.abs() < 1.0 {
                return None;
            }

            let target_pct = self.volume_profile[self.current_bucket];
            let bucket_target = self.total_quantity * target_pct;

            let volume_limit = current_volume * self.max_pct_volume;
            let participation_limit = current_volume * self.participation_rate;

            let order_qty = bucket_target.min(volume_limit).min(participation_limit).min(remaining);

            if order_qty < 1.0 {
                return None;
            }

            Some(Order {
                id: uuid::new_v4(),
                symbol: self.symbol.clone(),
                side: if self.total_quantity > 0.0 { Side::Buy } else { Side::Sell },
                order_type: OrderType::Market,
                quantity: order_qty.abs(),
                limit_price: None,
                stop_price: None,
                time_in_force: TimeInForce::IOC,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            })
        }

        pub fn advance_bucket(&mut self) {
            self.current_bucket += 1;
        }
    }

    /// Implementation Shortfall minimization
    pub struct ISExecutor {
        symbol: String,
        total_quantity: f64,
        arrival_price: f64,
        urgency: f64,
        risk_aversion: f64,
        volatility: f64,
        filled_quantity: f64,
        trades: Vec<Trade>,
    }

    impl ISExecutor {
        pub fn new(symbol: &str, quantity: f64, arrival_price: f64, volatility: f64) -> Self {
            Self {
                symbol: symbol.to_string(),
                total_quantity: quantity,
                arrival_price,
                urgency: 0.5,
                risk_aversion: 0.001,
                volatility,
                filled_quantity: 0.0,
                trades: Vec::new(),
            }
        }

        pub fn optimal_trajectory(&self, time_horizon: f64, steps: i32) -> Vec<f64> {
            let kappa = (self.risk_aversion * self.volatility.powi(2)).sqrt();
            let remaining = self.total_quantity - self.filled_quantity;

            let mut trajectory = Vec::new();
            for i in 0..=steps {
                let t = (i as f64 / steps as f64) * time_horizon;
                let remaining_time = time_horizon - t;

                let sinh_kr = (kappa * remaining_time).sinh();
                let sinh_kT = (kappa * time_horizon).sinh();

                let position = remaining * sinh_kr / sinh_kT;
                trajectory.push(position);
            }

            trajectory
        }

        pub fn implementation_shortfall(&self) -> f64 {
            let mut total_cost = 0.0;
            let mut total_qty = 0.0;

            for trade in &self.trades {
                total_cost += trade.price * trade.quantity;
                total_qty += trade.quantity;
            }

            if total_qty == 0.0 {
                return 0.0;
            }

            let avg_price = total_cost / total_qty;
            (avg_price - self.arrival_price) * self.total_quantity
        }
    }

    /// POV (Percentage of Volume) executor
    pub struct POVExecutor {
        symbol: String,
        total_quantity: f64,
        target_pov: f64,
        min_pov: f64,
        max_pov: f64,
        filled_quantity: f64,
        adaptive: bool,
    }

    impl POVExecutor {
        pub fn new(symbol: &str, quantity: f64, target_pov: f64) -> Self {
            Self {
                symbol: symbol.to_string(),
                total_quantity: quantity,
                target_pov: target_pov.clamp(0.01, 0.50),
                min_pov: 0.01,
                max_pov: 0.25,
                filled_quantity: 0.0,
                adaptive: true,
            }
        }

        pub fn calculate_order_size(&self, market_volume: f64, spread: f64) -> f64 {
            let remaining = self.total_quantity - self.filled_quantity;
            if remaining <= 0.0 {
                return 0.0;
            }

            let mut pov = self.target_pov;

            if self.adaptive {
                if spread > 0.002 {
                    pov *= 0.5;
                } else if spread < 0.0005 {
                    pov *= 1.2;
                }
            }

            pov = pov.clamp(self.min_pov, self.max_pov);

            let order_size = market_volume * pov;
            order_size.min(remaining)
        }
    }

    /// Iceberg order management
    pub struct IcebergManager {
        symbol: String,
        total_quantity: f64,
        display_quantity: f64,
        limit_price: f64,
        filled_quantity: f64,
        current_display: f64,
        variance_pct: f64,
    }

    impl IcebergManager {
        pub fn new(symbol: &str, total: f64, display: f64, price: f64) -> Self {
            Self {
                symbol: symbol.to_string(),
                total_quantity: total,
                display_quantity: display,
                limit_price: price,
                filled_quantity: 0.0,
                current_display: display,
                variance_pct: 0.15,
            }
        }

        pub fn get_visible_order(&self) -> Option<Order> {
            let remaining = self.total_quantity - self.filled_quantity;
            if remaining <= 0.0 {
                return None;
            }

            Some(Order {
                id: uuid::new_v4(),
                symbol: self.symbol.clone(),
                side: if self.total_quantity > 0.0 { Side::Buy } else { Side::Sell },
                order_type: OrderType::Limit,
                quantity: self.current_display.min(remaining),
                limit_price: Some(self.limit_price),
                stop_price: None,
                time_in_force: TimeInForce::Day,
                status: OrderStatus::Pending,
                filled_quantity: 0.0,
                average_fill_price: 0.0,
                created_at: DateTime::now(),
                updated_at: DateTime::now(),
            })
        }

        pub fn on_fill(&mut self, filled: f64) {
            self.filled_quantity += filled;

            let variance = self.display_quantity * self.variance_pct;
            self.current_display = self.display_quantity + random::uniform(-variance, variance);
            self.current_display = self.current_display.max(1.0);
        }

        pub fn is_complete(&self) -> bool {
            self.filled_quantity >= self.total_quantity
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET MICROSTRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

module microstructure {
    use super::*;

    /// Kyle's Lambda (price impact coefficient)
    pub struct KyleLambda {
        prices: Vec<f64>,
        volumes: Vec<f64>,
        order_flow: Vec<f64>,
    }

    impl KyleLambda {
        pub fn new() -> Self {
            Self {
                prices: Vec::new(),
                volumes: Vec::new(),
                order_flow: Vec::new(),
            }
        }

        pub fn add_observation(&mut self, price: f64, volume: f64, signed_flow: f64) {
            self.prices.push(price);
            self.volumes.push(volume);
            self.order_flow.push(signed_flow);
        }

        pub fn estimate_lambda(&self) -> f64 {
            if self.prices.len() < 2 {
                return 0.0;
            }

            let mut price_changes = Vec::new();
            for i in 1..self.prices.len() {
                price_changes.push(self.prices[i] - self.prices[i - 1]);
            }

            let flows: Vec<f64> = self.order_flow[1..].to_vec();

            let n = price_changes.len() as f64;
            let sum_xy: f64 = price_changes.iter().zip(&flows)
                .map(|(dp, of)| dp * of).sum();
            let sum_x: f64 = flows.iter().sum();
            let sum_y: f64 = price_changes.iter().sum();
            let sum_x2: f64 = flows.iter().map(|x| x * x).sum();

            let denominator = n * sum_x2 - sum_x * sum_x;
            if denominator.abs() < 1e-10 {
                return 0.0;
            }

            (n * sum_xy - sum_x * sum_y) / denominator
        }
    }

    /// Bid-Ask spread decomposition
    pub struct SpreadDecomposer {
        trades: Vec<Trade>,
        quotes: Vec<(f64, f64, DateTime)>,
    }

    impl SpreadDecomposer {
        pub fn new() -> Self {
            Self {
                trades: Vec::new(),
                quotes: Vec::new(),
            }
        }

        pub fn add_trade(&mut self, trade: Trade) {
            self.trades.push(trade);
        }

        pub fn add_quote(&mut self, bid: f64, ask: f64, time: DateTime) {
            self.quotes.push((bid, ask, time));
        }

        pub fn roll_spread(&self) -> f64 {
            if self.trades.len() < 2 {
                return 0.0;
            }

            let mut price_changes = Vec::new();
            for i in 1..self.trades.len() {
                price_changes.push(self.trades[i].price - self.trades[i - 1].price);
            }

            let mut autocovariance = 0.0;
            for i in 1..price_changes.len() {
                autocovariance += price_changes[i] * price_changes[i - 1];
            }
            autocovariance /= (price_changes.len() - 1) as f64;

            if autocovariance >= 0.0 {
                return 0.0;
            }

            2.0 * (-autocovariance).sqrt()
        }

        pub fn effective_spread(&self) -> f64 {
            if self.trades.is_empty() || self.quotes.is_empty() {
                return 0.0;
            }

            let mut spreads = Vec::new();

            for trade in &self.trades {
                let quote = self.quotes.iter()
                    .filter(|(_, _, t)| *t <= trade.timestamp)
                    .last();

                if let Some((bid, ask, _)) = quote {
                    let mid = (bid + ask) / 2.0;
                    let direction = if trade.price > mid { 1.0 } else { -1.0 };
                    spreads.push(2.0 * direction * (trade.price - mid));
                }
            }

            if spreads.is_empty() {
                return 0.0;
            }

            spreads.iter().sum::<f64>() / spreads.len() as f64
        }

        pub fn realized_spread(&self, delay_ms: i64) -> f64 {
            if self.trades.len() < 2 {
                return 0.0;
            }

            let mut spreads = Vec::new();

            for (i, trade) in self.trades.iter().enumerate() {
                let future_trade = self.trades[i + 1..].iter()
                    .find(|t| t.timestamp.diff_ms(&trade.timestamp) >= delay_ms);

                if let Some(ft) = future_trade {
                    let quote = self.quotes.iter()
                        .filter(|(_, _, t)| *t <= trade.timestamp)
                        .last();

                    if let Some((bid, ask, _)) = quote {
                        let mid = (bid + ask) / 2.0;
                        let direction = if trade.price > mid { 1.0 } else { -1.0 };
                        spreads.push(2.0 * direction * (trade.price - ft.price));
                    }
                }
            }

            if spreads.is_empty() {
                return 0.0;
            }

            spreads.iter().sum::<f64>() / spreads.len() as f64
        }
    }

    /// PIN (Probability of Informed Trading) model
    pub struct PINModel {
        buy_counts: Vec<i32>,
        sell_counts: Vec<i32>,
    }

    impl PINModel {
        pub fn new() -> Self {
            Self {
                buy_counts: Vec::new(),
                sell_counts: Vec::new(),
            }
        }

        pub fn add_day(&mut self, buys: i32, sells: i32) {
            self.buy_counts.push(buys);
            self.sell_counts.push(sells);
        }

        pub fn estimate_pin(&self) -> PINEstimate {
            if self.buy_counts.is_empty() {
                return PINEstimate::default();
            }

            let total_buys: i32 = self.buy_counts.iter().sum();
            let total_sells: i32 = self.sell_counts.iter().sum();
            let n_days = self.buy_counts.len() as f64;

            let avg_buys = total_buys as f64 / n_days;
            let avg_sells = total_sells as f64 / n_days;

            let epsilon_b = avg_buys * 0.8;
            let epsilon_s = avg_sells * 0.8;
            let mu = ((avg_buys - epsilon_b).max(0.0) + (avg_sells - epsilon_s).max(0.0)) / 2.0;

            let alpha = 0.5;
            let delta = avg_buys / (avg_buys + avg_sells);

            let pin = (alpha * mu) / (alpha * mu + epsilon_b + epsilon_s);

            PINEstimate {
                pin,
                alpha,
                delta,
                mu,
                epsilon_buy: epsilon_b,
                epsilon_sell: epsilon_s,
            }
        }
    }

    pub struct PINEstimate {
        pub pin: f64,
        pub alpha: f64,
        pub delta: f64,
        pub mu: f64,
        pub epsilon_buy: f64,
        pub epsilon_sell: f64,
    }

    impl Default for PINEstimate {
        fn default() -> Self {
            Self {
                pin: 0.0, alpha: 0.0, delta: 0.5,
                mu: 0.0, epsilon_buy: 0.0, epsilon_sell: 0.0,
            }
        }
    }

    /// VPIN (Volume-Synchronized PIN)
    pub struct VPINCalculator {
        bucket_size: f64,
        current_bucket_volume: f64,
        current_bucket_buy: f64,
        buckets: Vec<(f64, f64)>,
        window: usize,
    }

    impl VPINCalculator {
        pub fn new(bucket_size: f64, window: usize) -> Self {
            Self {
                bucket_size,
                current_bucket_volume: 0.0,
                current_bucket_buy: 0.0,
                buckets: Vec::new(),
                window,
            }
        }

        pub fn add_trade(&mut self, volume: f64, is_buy: bool) {
            let mut remaining = volume;

            while remaining > 0.0 {
                let space = self.bucket_size - self.current_bucket_volume;
                let fill = remaining.min(space);

                self.current_bucket_volume += fill;
                if is_buy {
                    self.current_bucket_buy += fill;
                }

                remaining -= fill;

                if self.current_bucket_volume >= self.bucket_size {
                    let sell_volume = self.current_bucket_volume - self.current_bucket_buy;
                    self.buckets.push((self.current_bucket_buy, sell_volume));

                    self.current_bucket_volume = 0.0;
                    self.current_bucket_buy = 0.0;
                }
            }
        }

        pub fn calculate_vpin(&self) -> f64 {
            if self.buckets.len() < self.window {
                return 0.0;
            }

            let recent: Vec<_> = self.buckets.iter()
                .rev()
                .take(self.window)
                .collect();

            let mut order_imbalance = 0.0;
            let mut total_volume = 0.0;

            for (buy, sell) in recent {
                order_imbalance += (buy - sell).abs();
                total_volume += buy + sell;
            }

            if total_volume == 0.0 {
                return 0.0;
            }

            order_imbalance / total_volume
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ALTERNATIVE DATA
// ═══════════════════════════════════════════════════════════════════════════════

module alt_data {
    use super::*;

    /// Sentiment analyzer for text data
    pub struct SentimentAnalyzer {
        positive_words: HashSet<String>,
        negative_words: HashSet<String>,
        intensifiers: HashSet<String>,
        negations: HashSet<String>,
    }

    impl SentimentAnalyzer {
        pub fn new() -> Self {
            let mut analyzer = Self {
                positive_words: HashSet::new(),
                negative_words: HashSet::new(),
                intensifiers: HashSet::new(),
                negations: HashSet::new(),
            };

            for word in ["good", "great", "excellent", "positive", "growth",
                         "profit", "beat", "exceed", "strong", "bullish",
                         "upgrade", "outperform", "buy", "rally", "gain"] {
                analyzer.positive_words.insert(word.to_string());
            }

            for word in ["bad", "poor", "negative", "loss", "miss", "weak",
                         "bearish", "downgrade", "underperform", "sell",
                         "decline", "drop", "fall", "risk", "concern"] {
                analyzer.negative_words.insert(word.to_string());
            }

            for word in ["very", "highly", "extremely", "significantly", "strongly"] {
                analyzer.intensifiers.insert(word.to_string());
            }

            for word in ["not", "no", "never", "neither", "without"] {
                analyzer.negations.insert(word.to_string());
            }

            analyzer
        }

        pub fn analyze(&self, text: &str) -> SentimentScore {
            let words: Vec<String> = text.to_lowercase()
                .split_whitespace()
                .map(|s| s.chars().filter(|c| c.is_alphabetic()).collect())
                .filter(|s: &String| !s.is_empty())
                .collect();

            let mut positive = 0.0;
            let mut negative = 0.0;
            let mut intensity = 1.0;
            let mut negate = false;

            for (i, word) in words.iter().enumerate() {
                if self.negations.contains(word) {
                    negate = true;
                    continue;
                }

                if self.intensifiers.contains(word) {
                    intensity = 1.5;
                    continue;
                }

                let mut score = 0.0;
                if self.positive_words.contains(word) {
                    score = 1.0;
                } else if self.negative_words.contains(word) {
                    score = -1.0;
                }

                if negate {
                    score = -score;
                    negate = false;
                }

                score *= intensity;
                intensity = 1.0;

                if score > 0.0 {
                    positive += score;
                } else {
                    negative += score.abs();
                }
            }

            let total = positive + negative;
            let polarity = if total > 0.0 {
                (positive - negative) / total
            } else {
                0.0
            };

            SentimentScore {
                polarity,
                positive,
                negative,
                subjectivity: total / words.len().max(1) as f64,
            }
        }

        pub fn analyze_batch(&self, texts: &[&str]) -> AggregatedSentiment {
            let scores: Vec<SentimentScore> = texts.iter()
                .map(|t| self.analyze(t))
                .collect();

            let n = scores.len() as f64;
            if n == 0.0 {
                return AggregatedSentiment::default();
            }

            let avg_polarity = scores.iter().map(|s| s.polarity).sum::<f64>() / n;
            let std_polarity = {
                let variance = scores.iter()
                    .map(|s| (s.polarity - avg_polarity).powi(2))
                    .sum::<f64>() / n;
                variance.sqrt()
            };

            let bullish = scores.iter().filter(|s| s.polarity > 0.1).count();
            let bearish = scores.iter().filter(|s| s.polarity < -0.1).count();

            AggregatedSentiment {
                mean_polarity: avg_polarity,
                std_polarity,
                bullish_ratio: bullish as f64 / n,
                bearish_ratio: bearish as f64 / n,
                sample_size: scores.len(),
            }
        }
    }

    pub struct SentimentScore {
        pub polarity: f64,
        pub positive: f64,
        pub negative: f64,
        pub subjectivity: f64,
    }

    pub struct AggregatedSentiment {
        pub mean_polarity: f64,
        pub std_polarity: f64,
        pub bullish_ratio: f64,
        pub bearish_ratio: f64,
        pub sample_size: usize,
    }

    impl Default for AggregatedSentiment {
        fn default() -> Self {
            Self {
                mean_polarity: 0.0, std_polarity: 0.0,
                bullish_ratio: 0.0, bearish_ratio: 0.0, sample_size: 0,
            }
        }
    }

    /// News impact analyzer
    pub struct NewsImpactAnalyzer {
        events: Vec<NewsEvent>,
        price_data: HashMap<String, Vec<(DateTime, f64)>>,
    }

    impl NewsImpactAnalyzer {
        pub fn new() -> Self {
            Self {
                events: Vec::new(),
                price_data: HashMap::new(),
            }
        }

        pub fn add_event(&mut self, event: NewsEvent) {
            self.events.push(event);
        }

        pub fn add_price(&mut self, symbol: &str, time: DateTime, price: f64) {
            self.price_data.entry(symbol.to_string())
                .or_insert_with(Vec::new)
                .push((time, price));
        }

        pub fn calculate_car(&self, event: &NewsEvent, window_days: i32) -> Option<f64> {
            let prices = self.price_data.get(&event.symbol)?;

            let pre_price = prices.iter()
                .filter(|(t, _)| *t < event.timestamp)
                .last()
                .map(|(_, p)| *p)?;

            let post_time = event.timestamp.add_days(window_days);
            let post_price = prices.iter()
                .filter(|(t, _)| *t >= post_time)
                .next()
                .map(|(_, p)| *p)?;

            Some((post_price - pre_price) / pre_price)
        }

        pub fn event_study(&self, event_type: &str, window: i32) -> EventStudyResult {
            let filtered: Vec<_> = self.events.iter()
                .filter(|e| e.event_type == event_type)
                .collect();

            let mut cars = Vec::new();
            for event in &filtered {
                if let Some(car) = self.calculate_car(event, window) {
                    cars.push(car);
                }
            }

            if cars.is_empty() {
                return EventStudyResult::default();
            }

            let n = cars.len() as f64;
            let mean_car = cars.iter().sum::<f64>() / n;
            let variance = cars.iter()
                .map(|c| (c - mean_car).powi(2))
                .sum::<f64>() / n;
            let std_car = variance.sqrt();

            let t_stat = mean_car / (std_car / n.sqrt());
            let positive_pct = cars.iter().filter(|&&c| c > 0.0).count() as f64 / n;

            EventStudyResult {
                mean_car,
                std_car,
                t_statistic: t_stat,
                positive_pct,
                sample_size: cars.len(),
            }
        }
    }

    pub struct NewsEvent {
        pub symbol: String,
        pub timestamp: DateTime,
        pub headline: String,
        pub event_type: String,
        pub sentiment: f64,
    }

    pub struct EventStudyResult {
        pub mean_car: f64,
        pub std_car: f64,
        pub t_statistic: f64,
        pub positive_pct: f64,
        pub sample_size: usize,
    }

    impl Default for EventStudyResult {
        fn default() -> Self {
            Self {
                mean_car: 0.0, std_car: 0.0, t_statistic: 0.0,
                positive_pct: 0.0, sample_size: 0,
            }
        }
    }

    /// Social media metrics tracker
    pub struct SocialMetricsTracker {
        mentions: HashMap<String, Vec<(DateTime, i32)>>,
        sentiment: HashMap<String, Vec<(DateTime, f64)>>,
        engagement: HashMap<String, Vec<(DateTime, i32)>>,
    }

    impl SocialMetricsTracker {
        pub fn new() -> Self {
            Self {
                mentions: HashMap::new(),
                sentiment: HashMap::new(),
                engagement: HashMap::new(),
            }
        }

        pub fn add_mention(&mut self, symbol: &str, time: DateTime, count: i32) {
            self.mentions.entry(symbol.to_string())
                .or_insert_with(Vec::new)
                .push((time, count));
        }

        pub fn add_sentiment(&mut self, symbol: &str, time: DateTime, score: f64) {
            self.sentiment.entry(symbol.to_string())
                .or_insert_with(Vec::new)
                .push((time, score));
        }

        pub fn mention_momentum(&self, symbol: &str, window: i32) -> f64 {
            let data = match self.mentions.get(symbol) {
                Some(d) => d,
                None => return 0.0,
            };

            if data.len() < (window * 2) as usize {
                return 0.0;
            }

            let recent: i32 = data.iter().rev().take(window as usize)
                .map(|(_, c)| c).sum();
            let previous: i32 = data.iter().rev().skip(window as usize)
                .take(window as usize).map(|(_, c)| c).sum();

            if previous == 0 {
                return 0.0;
            }

            (recent - previous) as f64 / previous as f64
        }

        pub fn sentiment_trend(&self, symbol: &str, window: i32) -> f64 {
            let data = match self.sentiment.get(symbol) {
                Some(d) => d,
                None => return 0.0,
            };

            let recent: Vec<_> = data.iter().rev().take(window as usize).collect();
            if recent.len() < 2 {
                return 0.0;
            }

            let n = recent.len() as f64;
            let sum_y: f64 = recent.iter().map(|(_, s)| s).sum();
            let sum_x: f64 = (0..recent.len()).map(|i| i as f64).sum();
            let sum_xy: f64 = recent.iter().enumerate()
                .map(|(i, (_, s))| i as f64 * s).sum();
            let sum_x2: f64 = (0..recent.len()).map(|i| (i * i) as f64).sum();

            let denominator = n * sum_x2 - sum_x * sum_x;
            if denominator.abs() < 1e-10 {
                return 0.0;
            }

            (n * sum_xy - sum_x * sum_y) / denominator
        }

        pub fn generate_signal(&self, symbol: &str) -> AltDataSignal {
            let mention_mom = self.mention_momentum(symbol, 7);
            let sent_trend = self.sentiment_trend(symbol, 7);

            let combined = mention_mom * 0.4 + sent_trend * 0.6;

            AltDataSignal {
                symbol: symbol.to_string(),
                mention_momentum: mention_mom,
                sentiment_trend: sent_trend,
                combined_score: combined,
                signal: if combined > 0.1 { 1 } else if combined < -0.1 { -1 } else { 0 },
            }
        }
    }

    pub struct AltDataSignal {
        pub symbol: String,
        pub mention_momentum: f64,
        pub sentiment_trend: f64,
        pub combined_score: f64,
        pub signal: i32,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTERACTIVE BROKERS TWS INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod tws {
    use std::collections::HashMap;
    use std::sync::{Arc, Mutex, RwLock};
    use std::net::TcpStream;

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum TwsMessageType {
        TickPrice = 1, TickSize = 2, OrderStatus = 3, Error = 4,
        OpenOrder = 5, AccountValue = 6, PortfolioValue = 7,
        ContractData = 10, ExecutionData = 11, MarketDepth = 12,
        HistoricalData = 17, RealTimeBars = 50, Position = 61,
        PositionEnd = 62, AccountSummary = 63, AccountSummaryEnd = 64,
    }

    #[derive(Debug, Clone)]
    pub struct TwsConfig {
        pub host: String,
        pub port: u16,
        pub client_id: i32,
        pub api_version: i32,
    }

    impl Default for TwsConfig {
        fn default() -> Self {
            Self { host: "127.0.0.1".into(), port: 7496, client_id: 1, api_version: 176 }
        }
    }

    #[derive(Debug, Clone)]
    pub struct Contract {
        pub con_id: i64,
        pub symbol: String,
        pub sec_type: SecType,
        pub exchange: String,
        pub currency: String,
        pub local_symbol: String,
        pub primary_exchange: String,
        pub multiplier: f64,
        pub expiry: Option<String>,
        pub strike: Option<f64>,
        pub right: Option<OptionRight>,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum SecType { Stock, Option, Future, Forex, Index, CFD, Bond, Warrant, Commodity }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum OptionRight { Call, Put }

    impl Contract {
        pub fn stock(symbol: &str, exchange: &str, currency: &str) -> Self {
            Self {
                con_id: 0, symbol: symbol.into(), sec_type: SecType::Stock,
                exchange: exchange.into(), currency: currency.into(),
                local_symbol: symbol.into(), primary_exchange: exchange.into(),
                multiplier: 1.0, expiry: None, strike: None, right: None,
            }
        }

        pub fn forex(pair: &str) -> Self {
            let (base, quote) = pair.split_at(3);
            Self {
                con_id: 0, symbol: base.into(), sec_type: SecType::Forex,
                exchange: "IDEALPRO".into(), currency: quote.into(),
                local_symbol: pair.into(), primary_exchange: "IDEALPRO".into(),
                multiplier: 1.0, expiry: None, strike: None, right: None,
            }
        }

        pub fn future(symbol: &str, expiry: &str, exchange: &str) -> Self {
            Self {
                con_id: 0, symbol: symbol.into(), sec_type: SecType::Future,
                exchange: exchange.into(), currency: "USD".into(),
                local_symbol: format!("{}{}", symbol, expiry), primary_exchange: exchange.into(),
                multiplier: 1.0, expiry: Some(expiry.into()), strike: None, right: None,
            }
        }

        pub fn option(symbol: &str, expiry: &str, strike: f64, right: OptionRight) -> Self {
            Self {
                con_id: 0, symbol: symbol.into(), sec_type: SecType::Option,
                exchange: "SMART".into(), currency: "USD".into(),
                local_symbol: format!("{}{}{:.0}{}", symbol, expiry, strike,
                    if right == OptionRight::Call { "C" } else { "P" }),
                primary_exchange: "".into(), multiplier: 100.0,
                expiry: Some(expiry.into()), strike: Some(strike), right: Some(right),
            }
        }

        fn encode(&self) -> Vec<u8> {
            let mut buf = Vec::new();
            buf.extend(encode_field(&self.con_id.to_string()));
            buf.extend(encode_field(&self.symbol));
            buf.extend(encode_field(&format!("{:?}", self.sec_type).to_uppercase()));
            buf.extend(encode_field(self.expiry.as_deref().unwrap_or("")));
            buf.extend(encode_field(&self.strike.map(|s| s.to_string()).unwrap_or_default()));
            buf.extend(encode_field(match self.right { Some(OptionRight::Call) => "C", Some(OptionRight::Put) => "P", None => "" }));
            buf.extend(encode_field(&self.multiplier.to_string()));
            buf.extend(encode_field(&self.exchange));
            buf.extend(encode_field(&self.primary_exchange));
            buf.extend(encode_field(&self.currency));
            buf.extend(encode_field(&self.local_symbol));
            buf
        }
    }

    fn encode_field(s: &str) -> Vec<u8> {
        let mut buf = s.as_bytes().to_vec();
        buf.push(0);
        buf
    }

    #[derive(Debug, Clone)]
    pub struct TwsOrder {
        pub order_id: i64,
        pub action: OrderAction,
        pub quantity: f64,
        pub order_type: TwsOrderType,
        pub limit_price: Option<f64>,
        pub aux_price: Option<f64>,
        pub tif: TimeInForce,
        pub oca_group: Option<String>,
        pub account: String,
        pub transmit: bool,
        pub parent_id: i64,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum OrderAction { Buy, Sell, SellShort }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum TwsOrderType { Market, Limit, Stop, StopLimit, TrailingStop, MidPrice }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum TimeInForce { Day, GTC, IOC, FOK, OPG, DTC }

    impl TwsOrder {
        pub fn market(action: OrderAction, qty: f64) -> Self {
            Self {
                order_id: 0, action, quantity: qty, order_type: TwsOrderType::Market,
                limit_price: None, aux_price: None, tif: TimeInForce::Day,
                oca_group: None, account: String::new(), transmit: true, parent_id: 0,
            }
        }

        pub fn limit(action: OrderAction, qty: f64, price: f64) -> Self {
            Self {
                order_id: 0, action, quantity: qty, order_type: TwsOrderType::Limit,
                limit_price: Some(price), aux_price: None, tif: TimeInForce::Day,
                oca_group: None, account: String::new(), transmit: true, parent_id: 0,
            }
        }

        pub fn bracket(action: OrderAction, qty: f64, entry: f64, tp: f64, sl: f64) -> Vec<Self> {
            let parent = Self {
                order_id: 0, action, quantity: qty, order_type: TwsOrderType::Limit,
                limit_price: Some(entry), aux_price: None, tif: TimeInForce::GTC,
                oca_group: None, account: String::new(), transmit: false, parent_id: 0,
            };
            let exit_action = if action == OrderAction::Buy { OrderAction::Sell } else { OrderAction::Buy };
            let take_profit = Self {
                order_id: 0, action: exit_action, quantity: qty, order_type: TwsOrderType::Limit,
                limit_price: Some(tp), aux_price: None, tif: TimeInForce::GTC,
                oca_group: Some("bracket".into()), account: String::new(), transmit: false, parent_id: 0,
            };
            let stop_loss = Self {
                order_id: 0, action: exit_action, quantity: qty, order_type: TwsOrderType::Stop,
                limit_price: None, aux_price: Some(sl), tif: TimeInForce::GTC,
                oca_group: Some("bracket".into()), account: String::new(), transmit: true, parent_id: 0,
            };
            vec![parent, take_profit, stop_loss]
        }
    }

    #[derive(Debug, Clone)]
    pub struct TickData {
        pub bid: f64, pub ask: f64, pub last: f64,
        pub bid_size: i64, pub ask_size: i64, pub last_size: i64,
        pub volume: i64, pub high: f64, pub low: f64, pub close: f64,
    }

    pub struct TwsClient {
        config: TwsConfig,
        stream: Option<TcpStream>,
        request_id: Arc<Mutex<i64>>,
        tick_data: Arc<RwLock<HashMap<i64, TickData>>>,
        orders: Arc<RwLock<HashMap<i64, OrderStatus>>>,
        positions: Arc<RwLock<Vec<PositionData>>>,
        connected: Arc<Mutex<bool>>,
    }

    #[derive(Debug, Clone)]
    pub struct OrderStatus {
        pub order_id: i64, pub status: String, pub filled: f64,
        pub remaining: f64, pub avg_fill_price: f64,
        pub last_fill_price: f64, pub client_id: i32, pub why_held: String,
    }

    #[derive(Debug, Clone)]
    pub struct PositionData {
        pub account: String, pub contract: Contract,
        pub position: f64, pub avg_cost: f64, pub market_value: f64,
    }

    impl TwsClient {
        pub fn new(config: TwsConfig) -> Self {
            Self {
                config, stream: None, request_id: Arc::new(Mutex::new(1)),
                tick_data: Arc::new(RwLock::new(HashMap::new())),
                orders: Arc::new(RwLock::new(HashMap::new())),
                positions: Arc::new(RwLock::new(Vec::new())),
                connected: Arc::new(Mutex::new(false)),
            }
        }

        pub fn connect(&mut self) -> Result<(), String> {
            let addr = format!("{}:{}", self.config.host, self.config.port);
            let stream = TcpStream::connect(&addr).map_err(|e| e.to_string())?;
            self.stream = Some(stream);
            self.send_handshake()?;
            *self.connected.lock().unwrap() = true;
            Ok(())
        }

        fn send_handshake(&mut self) -> Result<(), String> {
            let msg = format!("API\0v{}..{}", self.config.api_version, self.config.api_version);
            self.send_raw(msg.as_bytes())?;
            let start_api = format!("71\0{}\0\0", self.config.client_id);
            self.send_raw(start_api.as_bytes())
        }

        fn send_raw(&mut self, data: &[u8]) -> Result<(), String> {
            use std::io::Write;
            let len = data.len() as u32;
            let stream = self.stream.as_mut().ok_or("Not connected")?;
            stream.write_all(&len.to_be_bytes()).map_err(|e| e.to_string())?;
            stream.write_all(data).map_err(|e| e.to_string())
        }

        fn next_request_id(&self) -> i64 {
            let mut id = self.request_id.lock().unwrap();
            let current = *id;
            *id += 1;
            current
        }

        pub fn request_market_data(&mut self, contract: &Contract) -> Result<i64, String> {
            let req_id = self.next_request_id();
            let mut msg = Vec::new();
            msg.extend(encode_field("1")); // REQ_MKT_DATA
            msg.extend(encode_field("11")); // version
            msg.extend(encode_field(&req_id.to_string()));
            msg.extend(contract.encode());
            msg.extend(encode_field("")); // genericTickList
            msg.extend(encode_field("0")); // snapshot
            msg.extend(encode_field("0")); // regulatory snapshot
            msg.extend(encode_field("")); // mktDataOptions
            self.send_raw(&msg)?;
            Ok(req_id)
        }

        pub fn place_order(&mut self, contract: &Contract, order: &TwsOrder) -> Result<i64, String> {
            let order_id = self.next_request_id();
            let mut msg = Vec::new();
            msg.extend(encode_field("3")); // PLACE_ORDER
            msg.extend(encode_field(&order_id.to_string()));
            msg.extend(contract.encode());
            msg.extend(encode_field(match order.action { OrderAction::Buy => "BUY", OrderAction::Sell => "SELL", OrderAction::SellShort => "SSHORT" }));
            msg.extend(encode_field(&order.quantity.to_string()));
            msg.extend(encode_field(match order.order_type { TwsOrderType::Market => "MKT", TwsOrderType::Limit => "LMT", TwsOrderType::Stop => "STP", TwsOrderType::StopLimit => "STP LMT", TwsOrderType::TrailingStop => "TRAIL", TwsOrderType::MidPrice => "MIDPRICE" }));
            msg.extend(encode_field(&order.limit_price.map(|p| p.to_string()).unwrap_or_default()));
            msg.extend(encode_field(&order.aux_price.map(|p| p.to_string()).unwrap_or_default()));
            msg.extend(encode_field(match order.tif { TimeInForce::Day => "DAY", TimeInForce::GTC => "GTC", TimeInForce::IOC => "IOC", TimeInForce::FOK => "FOK", TimeInForce::OPG => "OPG", TimeInForce::DTC => "DTC" }));
            msg.extend(encode_field(order.oca_group.as_deref().unwrap_or("")));
            msg.extend(encode_field(&order.account));
            msg.extend(encode_field(if order.transmit { "1" } else { "0" }));
            msg.extend(encode_field(&order.parent_id.to_string()));
            self.send_raw(&msg)?;
            Ok(order_id)
        }

        pub fn cancel_order(&mut self, order_id: i64) -> Result<(), String> {
            let mut msg = Vec::new();
            msg.extend(encode_field("4")); // CANCEL_ORDER
            msg.extend(encode_field("1")); // version
            msg.extend(encode_field(&order_id.to_string()));
            msg.extend(encode_field("")); // manual order cancel time
            self.send_raw(&msg)
        }

        pub fn request_positions(&mut self) -> Result<(), String> {
            let mut msg = Vec::new();
            msg.extend(encode_field("61")); // REQ_POSITIONS
            msg.extend(encode_field("1")); // version
            self.send_raw(&msg)
        }

        pub fn request_account_summary(&mut self) -> Result<i64, String> {
            let req_id = self.next_request_id();
            let mut msg = Vec::new();
            msg.extend(encode_field("62")); // REQ_ACCOUNT_SUMMARY
            msg.extend(encode_field("1")); // version
            msg.extend(encode_field(&req_id.to_string()));
            msg.extend(encode_field("All")); // group
            msg.extend(encode_field("NetLiquidation,TotalCashValue,GrossPositionValue,AvailableFunds"));
            self.send_raw(&msg)?;
            Ok(req_id)
        }

        pub fn get_tick_data(&self, req_id: i64) -> Option<TickData> {
            self.tick_data.read().ok()?.get(&req_id).cloned()
        }

        pub fn get_order_status(&self, order_id: i64) -> Option<OrderStatus> {
            self.orders.read().ok()?.get(&order_id).cloned()
        }

        pub fn get_positions(&self) -> Vec<PositionData> {
            self.positions.read().map(|p| p.clone()).unwrap_or_default()
        }

        pub fn is_connected(&self) -> bool {
            *self.connected.lock().unwrap()
        }

        pub fn disconnect(&mut self) {
            self.stream = None;
            *self.connected.lock().unwrap() = false;
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REAL-TIME MARKET DATA WEBSOCKETS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod realtime_ws {
    use std::collections::HashMap;
    use std::sync::{Arc, RwLock, Mutex};

    #[derive(Debug, Clone)]
    pub struct WebSocketConfig {
        pub url: String,
        pub api_key: Option<String>,
        pub reconnect_delay_ms: u64,
        pub heartbeat_interval_ms: u64,
        pub max_reconnect_attempts: u32,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum WsConnectionState { Disconnected, Connecting, Connected, Reconnecting }

    #[derive(Debug, Clone)]
    pub enum MarketDataMessage {
        Trade { symbol: String, price: f64, size: f64, timestamp: i64 },
        Quote { symbol: String, bid: f64, ask: f64, bid_size: f64, ask_size: f64, timestamp: i64 },
        Bar { symbol: String, open: f64, high: f64, low: f64, close: f64, volume: f64, timestamp: i64 },
        OrderBook { symbol: String, bids: Vec<(f64, f64)>, asks: Vec<(f64, f64)>, timestamp: i64 },
        Status { symbol: String, status: String, halt_reason: Option<String> },
    }

    pub type MessageHandler = Box<dyn Fn(MarketDataMessage) + Send + Sync>;

    pub struct MarketDataWebSocket {
        config: WebSocketConfig,
        state: Arc<RwLock<WsConnectionState>>,
        subscriptions: Arc<RwLock<HashMap<String, SubscriptionType>>>,
        handlers: Arc<RwLock<Vec<MessageHandler>>>,
        last_message_time: Arc<Mutex<i64>>,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum SubscriptionType { Trades, Quotes, Bars, OrderBook, All }

    impl MarketDataWebSocket {
        pub fn new(config: WebSocketConfig) -> Self {
            Self {
                config, state: Arc::new(RwLock::new(WsConnectionState::Disconnected)),
                subscriptions: Arc::new(RwLock::new(HashMap::new())),
                handlers: Arc::new(RwLock::new(Vec::new())),
                last_message_time: Arc::new(Mutex::new(0)),
            }
        }

        pub fn alpaca(api_key: &str, api_secret: &str, paper: bool) -> Self {
            let url = if paper { "wss://stream.data.sandbox.alpaca.markets/v2/iex" }
                      else { "wss://stream.data.alpaca.markets/v2/iex" };
            Self::new(WebSocketConfig {
                url: url.into(), api_key: Some(format!("{}:{}", api_key, api_secret)),
                reconnect_delay_ms: 1000, heartbeat_interval_ms: 30000, max_reconnect_attempts: 10,
            })
        }

        pub fn polygon(api_key: &str) -> Self {
            Self::new(WebSocketConfig {
                url: format!("wss://socket.polygon.io/stocks?apiKey={}", api_key),
                api_key: Some(api_key.into()), reconnect_delay_ms: 1000,
                heartbeat_interval_ms: 30000, max_reconnect_attempts: 10,
            })
        }

        pub fn connect(&mut self) -> Result<(), String> {
            *self.state.write().unwrap() = WsConnectionState::Connecting;
            *self.state.write().unwrap() = WsConnectionState::Connected;
            Ok(())
        }

        pub fn subscribe(&mut self, symbol: &str, sub_type: SubscriptionType) -> Result<(), String> {
            self.subscriptions.write().unwrap().insert(symbol.to_uppercase(), sub_type);
            Ok(())
        }

        pub fn subscribe_many(&mut self, symbols: &[&str], sub_type: SubscriptionType) -> Result<(), String> {
            let mut subs = self.subscriptions.write().unwrap();
            for symbol in symbols { subs.insert(symbol.to_uppercase(), sub_type); }
            Ok(())
        }

        pub fn unsubscribe(&mut self, symbol: &str) -> Result<(), String> {
            self.subscriptions.write().unwrap().remove(&symbol.to_uppercase());
            Ok(())
        }

        pub fn on_message(&mut self, handler: MessageHandler) {
            self.handlers.write().unwrap().push(handler);
        }

        pub fn state(&self) -> WsConnectionState {
            *self.state.read().unwrap()
        }

        pub fn subscriptions(&self) -> Vec<String> {
            self.subscriptions.read().unwrap().keys().cloned().collect()
        }

        pub fn disconnect(&mut self) {
            *self.state.write().unwrap() = WsConnectionState::Disconnected;
            self.subscriptions.write().unwrap().clear();
        }
    }

    pub struct AggregatedFeed {
        feeds: Vec<MarketDataWebSocket>,
        consolidated: Arc<RwLock<HashMap<String, ConsolidatedQuote>>>,
    }

    #[derive(Debug, Clone)]
    pub struct ConsolidatedQuote {
        pub symbol: String,
        pub nbbo_bid: f64, pub nbbo_ask: f64,
        pub nbbo_bid_size: f64, pub nbbo_ask_size: f64,
        pub last_trade: f64, pub last_size: f64,
        pub total_volume: f64, pub vwap: f64,
        pub timestamp: i64,
    }

    impl AggregatedFeed {
        pub fn new() -> Self {
            Self { feeds: Vec::new(), consolidated: Arc::new(RwLock::new(HashMap::new())) }
        }

        pub fn add_feed(&mut self, feed: MarketDataWebSocket) {
            self.feeds.push(feed);
        }

        pub fn connect_all(&mut self) -> Result<(), String> {
            for feed in &mut self.feeds { feed.connect()?; }
            Ok(())
        }

        pub fn subscribe_all(&mut self, symbol: &str, sub_type: SubscriptionType) -> Result<(), String> {
            for feed in &mut self.feeds { feed.subscribe(symbol, sub_type)?; }
            Ok(())
        }

        pub fn get_nbbo(&self, symbol: &str) -> Option<ConsolidatedQuote> {
            self.consolidated.read().ok()?.get(&symbol.to_uppercase()).cloned()
        }

        pub fn disconnect_all(&mut self) {
            for feed in &mut self.feeds { feed.disconnect(); }
        }
    }

    pub struct TickBuffer {
        trades: Vec<(i64, f64, f64)>,
        quotes: Vec<(i64, f64, f64, f64, f64)>,
        max_size: usize,
    }

    impl TickBuffer {
        pub fn new(max_size: usize) -> Self {
            Self { trades: Vec::with_capacity(max_size), quotes: Vec::with_capacity(max_size), max_size }
        }

        pub fn add_trade(&mut self, timestamp: i64, price: f64, size: f64) {
            if self.trades.len() >= self.max_size { self.trades.remove(0); }
            self.trades.push((timestamp, price, size));
        }

        pub fn add_quote(&mut self, timestamp: i64, bid: f64, ask: f64, bid_sz: f64, ask_sz: f64) {
            if self.quotes.len() >= self.max_size { self.quotes.remove(0); }
            self.quotes.push((timestamp, bid, ask, bid_sz, ask_sz));
        }

        pub fn vwap(&self) -> f64 {
            let (total_value, total_volume) = self.trades.iter()
                .fold((0.0, 0.0), |(v, vol), (_, p, s)| (v + p * s, vol + s));
            if total_volume > 0.0 { total_value / total_volume } else { 0.0 }
        }

        pub fn last_trade(&self) -> Option<(f64, f64)> {
            self.trades.last().map(|(_, p, s)| (*p, *s))
        }

        pub fn spread(&self) -> Option<f64> {
            self.quotes.last().map(|(_, bid, ask, _, _)| ask - bid)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-ASSET PORTFOLIO MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod multi_asset {
    use std::collections::HashMap;

    #[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
    pub enum AssetClass { Equity, FixedIncome, Commodity, Currency, RealEstate, Crypto, Derivative }

    #[derive(Debug, Clone)]
    pub struct Asset {
        pub symbol: String,
        pub name: String,
        pub asset_class: AssetClass,
        pub currency: String,
        pub lot_size: f64,
        pub tick_size: f64,
        pub margin_requirement: f64,
    }

    #[derive(Debug, Clone)]
    pub struct AssetAllocation {
        pub asset_class: AssetClass,
        pub target_weight: f64,
        pub min_weight: f64,
        pub max_weight: f64,
        pub rebalance_threshold: f64,
    }

    pub struct MultiAssetPortfolio {
        name: String,
        base_currency: String,
        holdings: HashMap<String, Holding>,
        allocations: Vec<AssetAllocation>,
        fx_rates: HashMap<String, f64>,
        cash: HashMap<String, f64>,
    }

    #[derive(Debug, Clone)]
    pub struct Holding {
        pub asset: Asset,
        pub quantity: f64,
        pub avg_cost: f64,
        pub market_price: f64,
        pub unrealized_pnl: f64,
        pub realized_pnl: f64,
    }

    impl MultiAssetPortfolio {
        pub fn new(name: &str, base_currency: &str) -> Self {
            Self {
                name: name.into(), base_currency: base_currency.into(),
                holdings: HashMap::new(), allocations: Vec::new(),
                fx_rates: HashMap::new(), cash: HashMap::new(),
            }
        }

        pub fn set_allocation(&mut self, alloc: AssetAllocation) {
            if let Some(existing) = self.allocations.iter_mut()
                .find(|a| a.asset_class == alloc.asset_class) { *existing = alloc; }
            else { self.allocations.push(alloc); }
        }

        pub fn set_fx_rate(&mut self, currency: &str, rate: f64) {
            self.fx_rates.insert(currency.to_uppercase(), rate);
        }

        pub fn deposit(&mut self, currency: &str, amount: f64) {
            *self.cash.entry(currency.to_uppercase()).or_insert(0.0) += amount;
        }

        pub fn add_position(&mut self, asset: Asset, qty: f64, price: f64) {
            let symbol = asset.symbol.clone();
            if let Some(holding) = self.holdings.get_mut(&symbol) {
                let total_qty = holding.quantity + qty;
                holding.avg_cost = (holding.avg_cost * holding.quantity + price * qty) / total_qty;
                holding.quantity = total_qty;
            } else {
                self.holdings.insert(symbol, Holding {
                    asset, quantity: qty, avg_cost: price, market_price: price,
                    unrealized_pnl: 0.0, realized_pnl: 0.0,
                });
            }
        }

        pub fn update_price(&mut self, symbol: &str, price: f64) {
            if let Some(holding) = self.holdings.get_mut(symbol) {
                holding.market_price = price;
                holding.unrealized_pnl = (price - holding.avg_cost) * holding.quantity;
            }
        }

        pub fn close_position(&mut self, symbol: &str, qty: f64, price: f64) -> Option<f64> {
            let holding = self.holdings.get_mut(symbol)?;
            let close_qty = qty.min(holding.quantity);
            let pnl = (price - holding.avg_cost) * close_qty;
            holding.realized_pnl += pnl;
            holding.quantity -= close_qty;
            if holding.quantity <= 0.0 { self.holdings.remove(symbol); }
            Some(pnl)
        }

        fn to_base(&self, amount: f64, currency: &str) -> f64 {
            if currency == self.base_currency { amount }
            else { amount * self.fx_rates.get(currency).unwrap_or(&1.0) }
        }

        pub fn total_nav(&self) -> f64 {
            let cash_value: f64 = self.cash.iter()
                .map(|(c, a)| self.to_base(*a, c)).sum();
            let holdings_value: f64 = self.holdings.values()
                .map(|h| self.to_base(h.market_price * h.quantity, &h.asset.currency)).sum();
            cash_value + holdings_value
        }

        pub fn class_exposure(&self, class: AssetClass) -> f64 {
            self.holdings.values()
                .filter(|h| h.asset.asset_class == class)
                .map(|h| self.to_base(h.market_price * h.quantity, &h.asset.currency)).sum()
        }

        pub fn current_weights(&self) -> HashMap<AssetClass, f64> {
            let nav = self.total_nav();
            if nav <= 0.0 { return HashMap::new(); }
            let mut weights = HashMap::new();
            for class in [AssetClass::Equity, AssetClass::FixedIncome, AssetClass::Commodity,
                         AssetClass::Currency, AssetClass::RealEstate, AssetClass::Crypto, AssetClass::Derivative] {
                weights.insert(class, self.class_exposure(class) / nav);
            }
            weights
        }

        pub fn rebalance_trades(&self) -> Vec<RebalanceTrade> {
            let nav = self.total_nav();
            let current = self.current_weights();
            let mut trades = Vec::new();
            for alloc in &self.allocations {
                let current_weight = current.get(&alloc.asset_class).unwrap_or(&0.0);
                let diff = alloc.target_weight - current_weight;
                if diff.abs() > alloc.rebalance_threshold {
                    trades.push(RebalanceTrade {
                        asset_class: alloc.asset_class,
                        target_value: nav * alloc.target_weight,
                        current_value: nav * current_weight,
                        trade_value: nav * diff,
                    });
                }
            }
            trades
        }

        pub fn risk_metrics(&self) -> PortfolioRiskMetrics {
            let nav = self.total_nav();
            let gross: f64 = self.holdings.values()
                .map(|h| (h.market_price * h.quantity).abs()).sum();
            let long: f64 = self.holdings.values()
                .filter(|h| h.quantity > 0.0)
                .map(|h| h.market_price * h.quantity).sum();
            let short: f64 = self.holdings.values()
                .filter(|h| h.quantity < 0.0)
                .map(|h| (h.market_price * h.quantity).abs()).sum();
            PortfolioRiskMetrics {
                nav, gross_exposure: gross, net_exposure: long - short,
                long_exposure: long, short_exposure: short,
                leverage: if nav > 0.0 { gross / nav } else { 0.0 },
                concentration: self.concentration_ratio(5),
            }
        }

        fn concentration_ratio(&self, top_n: usize) -> f64 {
            let mut values: Vec<f64> = self.holdings.values()
                .map(|h| (h.market_price * h.quantity).abs()).collect();
            values.sort_by(|a, b| b.partial_cmp(a).unwrap());
            let total: f64 = values.iter().sum();
            let top: f64 = values.iter().take(top_n).sum();
            if total > 0.0 { top / total } else { 0.0 }
        }
    }

    #[derive(Debug, Clone)]
    pub struct RebalanceTrade {
        pub asset_class: AssetClass,
        pub target_value: f64,
        pub current_value: f64,
        pub trade_value: f64,
    }

    #[derive(Debug, Clone)]
    pub struct PortfolioRiskMetrics {
        pub nav: f64,
        pub gross_exposure: f64,
        pub net_exposure: f64,
        pub long_exposure: f64,
        pub short_exposure: f64,
        pub leverage: f64,
        pub concentration: f64,
    }

    pub struct CurrencyHedger {
        base_currency: String,
        hedge_ratios: HashMap<String, f64>,
        forward_points: HashMap<String, f64>,
    }

    impl CurrencyHedger {
        pub fn new(base: &str) -> Self {
            Self { base_currency: base.into(), hedge_ratios: HashMap::new(), forward_points: HashMap::new() }
        }

        pub fn set_hedge_ratio(&mut self, currency: &str, ratio: f64) {
            self.hedge_ratios.insert(currency.to_uppercase(), ratio.clamp(0.0, 1.0));
        }

        pub fn set_forward_points(&mut self, currency: &str, points: f64) {
            self.forward_points.insert(currency.to_uppercase(), points);
        }

        pub fn hedge_amount(&self, currency: &str, exposure: f64) -> f64 {
            let ratio = self.hedge_ratios.get(&currency.to_uppercase()).unwrap_or(&0.0);
            exposure * ratio
        }

        pub fn hedge_cost(&self, currency: &str, amount: f64, tenor_days: i32) -> f64 {
            let points = self.forward_points.get(&currency.to_uppercase()).unwrap_or(&0.0);
            amount * points * (tenor_days as f64 / 360.0)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MACHINE LEARNING SIGNAL INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod ml_signals {
    use std::collections::HashMap;

    #[derive(Debug, Clone)]
    pub struct MLSignal {
        pub symbol: String,
        pub signal: f64,
        pub confidence: f64,
        pub model_name: String,
        pub features: HashMap<String, f64>,
        pub timestamp: i64,
    }

    #[derive(Debug, Clone)]
    pub struct FeatureSet {
        pub name: String,
        pub features: Vec<Feature>,
    }

    #[derive(Debug, Clone)]
    pub struct Feature {
        pub name: String,
        pub value: f64,
        pub importance: f64,
        pub category: FeatureCategory,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum FeatureCategory { Price, Volume, Momentum, Volatility, Sentiment, Fundamental, Technical, Alternative }

    pub struct FeatureExtractor {
        lookback: usize,
        features: Vec<FeatureType>,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum FeatureType {
        Returns(usize), LogReturns(usize), Volatility(usize), RSI(usize),
        MACD(usize, usize, usize), BollingerWidth(usize), ATR(usize),
        VolumeRatio(usize), PriceToMA(usize), Momentum(usize), Skewness(usize),
    }

    impl FeatureExtractor {
        pub fn new(lookback: usize) -> Self {
            Self { lookback, features: Vec::new() }
        }

        pub fn add(&mut self, feature: FeatureType) -> &mut Self {
            self.features.push(feature);
            self
        }

        pub fn standard_set(&mut self) -> &mut Self {
            self.add(FeatureType::Returns(1)).add(FeatureType::Returns(5)).add(FeatureType::Returns(20))
                .add(FeatureType::Volatility(20)).add(FeatureType::RSI(14))
                .add(FeatureType::MACD(12, 26, 9)).add(FeatureType::BollingerWidth(20))
                .add(FeatureType::ATR(14)).add(FeatureType::VolumeRatio(20))
                .add(FeatureType::PriceToMA(50)).add(FeatureType::Momentum(10))
        }

        pub fn extract(&self, prices: &[f64], volumes: &[f64]) -> HashMap<String, f64> {
            let mut result = HashMap::new();
            for feature in &self.features {
                let (name, value) = self.compute_feature(feature, prices, volumes);
                result.insert(name, value);
            }
            result
        }

        fn compute_feature(&self, feature: &FeatureType, prices: &[f64], volumes: &[f64]) -> (String, f64) {
            match feature {
                FeatureType::Returns(n) => {
                    let ret = if prices.len() > *n { (prices.last().unwrap() / prices[prices.len() - n - 1] - 1.0) } else { 0.0 };
                    (format!("returns_{}", n), ret)
                }
                FeatureType::LogReturns(n) => {
                    let ret = if prices.len() > *n { (prices.last().unwrap() / prices[prices.len() - n - 1]).ln() } else { 0.0 };
                    (format!("log_returns_{}", n), ret)
                }
                FeatureType::Volatility(n) => {
                    let vol = self.rolling_std(&self.returns(prices), *n);
                    (format!("volatility_{}", n), vol)
                }
                FeatureType::RSI(n) => {
                    let rsi = self.compute_rsi(prices, *n);
                    (format!("rsi_{}", n), rsi)
                }
                FeatureType::MACD(fast, slow, signal) => {
                    let macd = self.compute_macd(prices, *fast, *slow, *signal);
                    (format!("macd_{}_{}", fast, slow), macd)
                }
                FeatureType::BollingerWidth(n) => {
                    let width = self.compute_bollinger_width(prices, *n);
                    (format!("bb_width_{}", n), width)
                }
                FeatureType::ATR(n) => {
                    (format!("atr_{}", n), self.compute_atr(prices, *n))
                }
                FeatureType::VolumeRatio(n) => {
                    let ratio = if volumes.len() > 0 && *n > 0 {
                        let avg: f64 = volumes.iter().rev().take(*n).sum::<f64>() / *n as f64;
                        if avg > 0.0 { volumes.last().unwrap_or(&0.0) / avg } else { 1.0 }
                    } else { 1.0 };
                    (format!("volume_ratio_{}", n), ratio)
                }
                FeatureType::PriceToMA(n) => {
                    let ma = if prices.len() >= *n {
                        prices.iter().rev().take(*n).sum::<f64>() / *n as f64
                    } else { *prices.last().unwrap_or(&1.0) };
                    let ratio = if ma > 0.0 { prices.last().unwrap_or(&ma) / ma - 1.0 } else { 0.0 };
                    (format!("price_to_ma_{}", n), ratio)
                }
                FeatureType::Momentum(n) => {
                    let mom = if prices.len() > *n { prices.last().unwrap() - prices[prices.len() - n - 1] } else { 0.0 };
                    (format!("momentum_{}", n), mom)
                }
                FeatureType::Skewness(n) => {
                    let skew = self.compute_skewness(&self.returns(prices), *n);
                    (format!("skewness_{}", n), skew)
                }
            }
        }

        fn returns(&self, prices: &[f64]) -> Vec<f64> {
            prices.windows(2).map(|w| w[1] / w[0] - 1.0).collect()
        }

        fn rolling_std(&self, data: &[f64], n: usize) -> f64 {
            if data.len() < n { return 0.0; }
            let slice = &data[data.len() - n..];
            let mean = slice.iter().sum::<f64>() / n as f64;
            (slice.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64).sqrt()
        }

        fn compute_rsi(&self, prices: &[f64], n: usize) -> f64 {
            if prices.len() < n + 1 { return 50.0; }
            let changes: Vec<f64> = prices.windows(2).map(|w| w[1] - w[0]).collect();
            let recent = &changes[changes.len().saturating_sub(n)..];
            let gains: f64 = recent.iter().filter(|&&x| x > 0.0).sum();
            let losses: f64 = recent.iter().filter(|&&x| x < 0.0).map(|x| x.abs()).sum();
            if losses == 0.0 { 100.0 } else { 100.0 - 100.0 / (1.0 + gains / losses) }
        }

        fn compute_macd(&self, prices: &[f64], fast: usize, slow: usize, _signal: usize) -> f64 {
            let ema_fast = self.ema(prices, fast);
            let ema_slow = self.ema(prices, slow);
            ema_fast - ema_slow
        }

        fn ema(&self, prices: &[f64], n: usize) -> f64 {
            if prices.is_empty() { return 0.0; }
            let k = 2.0 / (n as f64 + 1.0);
            let mut ema = prices[0];
            for &p in &prices[1..] { ema = p * k + ema * (1.0 - k); }
            ema
        }

        fn compute_bollinger_width(&self, prices: &[f64], n: usize) -> f64 {
            if prices.len() < n { return 0.0; }
            let slice = &prices[prices.len() - n..];
            let mean = slice.iter().sum::<f64>() / n as f64;
            let std = (slice.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64).sqrt();
            if mean > 0.0 { 4.0 * std / mean } else { 0.0 }
        }

        fn compute_atr(&self, prices: &[f64], n: usize) -> f64 {
            if prices.len() < n + 1 { return 0.0; }
            let tr: Vec<f64> = prices.windows(2).map(|w| (w[1] - w[0]).abs()).collect();
            tr.iter().rev().take(n).sum::<f64>() / n as f64
        }

        fn compute_skewness(&self, data: &[f64], n: usize) -> f64 {
            if data.len() < n { return 0.0; }
            let slice = &data[data.len() - n..];
            let mean = slice.iter().sum::<f64>() / n as f64;
            let std = (slice.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64).sqrt();
            if std == 0.0 { return 0.0; }
            let m3 = slice.iter().map(|x| ((x - mean) / std).powi(3)).sum::<f64>() / n as f64;
            m3
        }
    }

    pub struct SignalCombiner {
        models: Vec<ModelWeight>,
        combination_method: CombinationMethod,
    }

    #[derive(Debug, Clone)]
    pub struct ModelWeight {
        pub model_name: String,
        pub weight: f64,
        pub decay_factor: f64,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum CombinationMethod { SimpleAverage, WeightedAverage, VoteMajority, MaxConfidence, Stacking }

    impl SignalCombiner {
        pub fn new(method: CombinationMethod) -> Self {
            Self { models: Vec::new(), combination_method: method }
        }

        pub fn add_model(&mut self, name: &str, weight: f64, decay: f64) {
            self.models.push(ModelWeight { model_name: name.into(), weight, decay_factor: decay });
        }

        pub fn combine(&self, signals: &[MLSignal]) -> MLSignal {
            match self.combination_method {
                CombinationMethod::SimpleAverage => self.simple_average(signals),
                CombinationMethod::WeightedAverage => self.weighted_average(signals),
                CombinationMethod::VoteMajority => self.vote_majority(signals),
                CombinationMethod::MaxConfidence => self.max_confidence(signals),
                CombinationMethod::Stacking => self.stacking(signals),
            }
        }

        fn simple_average(&self, signals: &[MLSignal]) -> MLSignal {
            let avg = signals.iter().map(|s| s.signal).sum::<f64>() / signals.len() as f64;
            let conf = signals.iter().map(|s| s.confidence).sum::<f64>() / signals.len() as f64;
            MLSignal {
                symbol: signals.first().map(|s| s.symbol.clone()).unwrap_or_default(),
                signal: avg, confidence: conf, model_name: "ensemble_avg".into(),
                features: HashMap::new(), timestamp: signals.iter().map(|s| s.timestamp).max().unwrap_or(0),
            }
        }

        fn weighted_average(&self, signals: &[MLSignal]) -> MLSignal {
            let mut total_weight = 0.0;
            let mut weighted_signal = 0.0;
            let mut weighted_conf = 0.0;
            for sig in signals {
                let w = self.models.iter().find(|m| m.model_name == sig.model_name)
                    .map(|m| m.weight).unwrap_or(1.0);
                weighted_signal += sig.signal * w;
                weighted_conf += sig.confidence * w;
                total_weight += w;
            }
            MLSignal {
                symbol: signals.first().map(|s| s.symbol.clone()).unwrap_or_default(),
                signal: if total_weight > 0.0 { weighted_signal / total_weight } else { 0.0 },
                confidence: if total_weight > 0.0 { weighted_conf / total_weight } else { 0.0 },
                model_name: "ensemble_weighted".into(), features: HashMap::new(),
                timestamp: signals.iter().map(|s| s.timestamp).max().unwrap_or(0),
            }
        }

        fn vote_majority(&self, signals: &[MLSignal]) -> MLSignal {
            let votes: i32 = signals.iter().map(|s| if s.signal > 0.0 { 1 } else if s.signal < 0.0 { -1 } else { 0 }).sum();
            let signal = if votes > 0 { 1.0 } else if votes < 0 { -1.0 } else { 0.0 };
            let conf = votes.abs() as f64 / signals.len() as f64;
            MLSignal {
                symbol: signals.first().map(|s| s.symbol.clone()).unwrap_or_default(),
                signal, confidence: conf, model_name: "ensemble_vote".into(),
                features: HashMap::new(), timestamp: signals.iter().map(|s| s.timestamp).max().unwrap_or(0),
            }
        }

        fn max_confidence(&self, signals: &[MLSignal]) -> MLSignal {
            signals.iter().max_by(|a, b| a.confidence.partial_cmp(&b.confidence).unwrap())
                .cloned().unwrap_or_else(|| MLSignal {
                    symbol: String::new(), signal: 0.0, confidence: 0.0,
                    model_name: "none".into(), features: HashMap::new(), timestamp: 0,
                })
        }

        fn stacking(&self, signals: &[MLSignal]) -> MLSignal {
            let meta_features: HashMap<String, f64> = signals.iter()
                .map(|s| (s.model_name.clone(), s.signal)).collect();
            let avg = signals.iter().map(|s| s.signal * s.confidence).sum::<f64>()
                / signals.iter().map(|s| s.confidence).sum::<f64>().max(1e-10);
            MLSignal {
                symbol: signals.first().map(|s| s.symbol.clone()).unwrap_or_default(),
                signal: avg, confidence: signals.iter().map(|s| s.confidence).sum::<f64>() / signals.len() as f64,
                model_name: "ensemble_stack".into(), features: meta_features,
                timestamp: signals.iter().map(|s| s.timestamp).max().unwrap_or(0),
            }
        }
    }

    pub struct SignalValidator {
        min_confidence: f64,
        max_staleness_ms: i64,
        required_agreement: f64,
    }

    impl SignalValidator {
        pub fn new(min_conf: f64, max_stale: i64, required_agree: f64) -> Self {
            Self { min_confidence: min_conf, max_staleness_ms: max_stale, required_agreement: required_agree }
        }

        pub fn validate(&self, signal: &MLSignal, current_time: i64) -> ValidationResult {
            let mut issues = Vec::new();
            if signal.confidence < self.min_confidence {
                issues.push(format!("Low confidence: {:.2}", signal.confidence));
            }
            if current_time - signal.timestamp > self.max_staleness_ms {
                issues.push("Stale signal".into());
            }
            ValidationResult { valid: issues.is_empty(), issues, adjusted_confidence: signal.confidence }
        }

        pub fn validate_ensemble(&self, signals: &[MLSignal]) -> bool {
            let direction = signals.iter().map(|s| s.signal.signum()).sum::<f64>() / signals.len() as f64;
            direction.abs() >= self.required_agreement
        }
    }

    #[derive(Debug, Clone)]
    pub struct ValidationResult {
        pub valid: bool,
        pub issues: Vec<String>,
        pub adjusted_confidence: f64,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Risk Management System
// ═══════════════════════════════════════════════════════════════════════════════

pub mod risk {
    use super::*;

    pub struct RiskManager {
        pub max_position_size: f64,
        pub max_portfolio_risk: f64,
        pub max_drawdown_limit: f64,
        pub var_limit_95: f64,
        positions: HashMap<String, Position>,
        current_drawdown: f64,
        peak_equity: f64,
    }

    #[derive(Clone)]
    pub struct Position { pub symbol: String, pub quantity: f64, pub avg_price: f64, pub current_price: f64, pub unrealized_pnl: f64, pub realized_pnl: f64 }

    impl RiskManager {
        pub fn new(max_pos: f64, max_risk: f64, max_dd: f64) -> Self {
            Self { max_position_size: max_pos, max_portfolio_risk: max_risk, max_drawdown_limit: max_dd, var_limit_95: 0.02, positions: HashMap::new(), current_drawdown: 0.0, peak_equity: 0.0 }
        }

        pub fn check_order(&self, symbol: &str, quantity: f64, price: f64, portfolio_value: f64) -> RiskCheckResult {
            let position_value = quantity.abs() * price;
            let position_pct = position_value / portfolio_value;
            let mut violations = Vec::new();

            if position_pct > self.max_position_size { violations.push(format!("Position size {:.2}% exceeds limit {:.2}%", position_pct * 100.0, self.max_position_size * 100.0)); }
            if self.current_drawdown > self.max_drawdown_limit { violations.push(format!("Drawdown {:.2}% exceeds limit {:.2}%", self.current_drawdown * 100.0, self.max_drawdown_limit * 100.0)); }

            let allowed_qty = if violations.is_empty() { quantity } else { (self.max_position_size * portfolio_value / price).min(quantity.abs()) * quantity.signum() };
            RiskCheckResult { approved: violations.is_empty(), violations, adjusted_quantity: allowed_qty }
        }

        pub fn update_position(&mut self, symbol: &str, quantity: f64, price: f64) {
            let pos = self.positions.entry(symbol.to_string()).or_insert(Position { symbol: symbol.to_string(), quantity: 0.0, avg_price: 0.0, current_price: price, unrealized_pnl: 0.0, realized_pnl: 0.0 });
            if quantity.signum() == pos.quantity.signum() || pos.quantity == 0.0 {
                let total_cost = pos.quantity * pos.avg_price + quantity * price;
                pos.quantity += quantity;
                pos.avg_price = if pos.quantity != 0.0 { total_cost / pos.quantity } else { 0.0 };
            } else {
                let close_qty = quantity.abs().min(pos.quantity.abs());
                let pnl = close_qty * (price - pos.avg_price) * pos.quantity.signum();
                pos.realized_pnl += pnl;
                pos.quantity += quantity;
            }
            pos.current_price = price;
            pos.unrealized_pnl = pos.quantity * (pos.current_price - pos.avg_price);
        }

        pub fn update_prices(&mut self, prices: &HashMap<String, f64>) {
            for (sym, pos) in &mut self.positions {
                if let Some(&price) = prices.get(sym) { pos.current_price = price; pos.unrealized_pnl = pos.quantity * (price - pos.avg_price); }
            }
        }

        pub fn update_equity(&mut self, current_equity: f64) {
            if current_equity > self.peak_equity { self.peak_equity = current_equity; }
            self.current_drawdown = if self.peak_equity > 0.0 { (self.peak_equity - current_equity) / self.peak_equity } else { 0.0 };
        }

        pub fn portfolio_var(&self, returns: &[f64], confidence: f64) -> f64 {
            if returns.is_empty() { return 0.0; }
            let mut sorted: Vec<f64> = returns.to_vec();
            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let idx = ((1.0 - confidence) * returns.len() as f64) as usize;
            sorted.get(idx).copied().unwrap_or(0.0).abs()
        }

        pub fn portfolio_cvar(&self, returns: &[f64], confidence: f64) -> f64 {
            if returns.is_empty() { return 0.0; }
            let mut sorted: Vec<f64> = returns.to_vec();
            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let idx = ((1.0 - confidence) * returns.len() as f64) as usize;
            sorted[..=idx].iter().sum::<f64>() / (idx + 1) as f64
        }

        pub fn total_exposure(&self) -> f64 { self.positions.values().map(|p| (p.quantity * p.current_price).abs()).sum() }
        pub fn net_exposure(&self) -> f64 { self.positions.values().map(|p| p.quantity * p.current_price).sum() }
        pub fn total_pnl(&self) -> f64 { self.positions.values().map(|p| p.unrealized_pnl + p.realized_pnl).sum() }
    }

    #[derive(Clone)]
    pub struct RiskCheckResult { pub approved: bool, pub violations: Vec<String>, pub adjusted_quantity: f64 }

    pub struct PositionSizer {
        pub method: SizingMethod,
        pub risk_per_trade: f64,
        pub max_position_pct: f64,
    }

    #[derive(Clone, Copy)]
    pub enum SizingMethod { Fixed, PercentRisk, Kelly, OptimalF, VolatilityScaled }

    impl PositionSizer {
        pub fn new(method: SizingMethod, risk: f64) -> Self { Self { method, risk_per_trade: risk, max_position_pct: 0.1 } }

        pub fn calculate_size(&self, capital: f64, entry: f64, stop_loss: f64, win_rate: f64, avg_win: f64, avg_loss: f64, volatility: f64) -> f64 {
            let size = match self.method {
                SizingMethod::Fixed => capital * self.risk_per_trade / entry,
                SizingMethod::PercentRisk => {
                    let risk_per_share = (entry - stop_loss).abs();
                    if risk_per_share > 0.0 { capital * self.risk_per_trade / risk_per_share } else { 0.0 }
                }
                SizingMethod::Kelly => {
                    let b = avg_win / avg_loss.max(0.0001);
                    let kelly = (win_rate * b - (1.0 - win_rate)) / b;
                    (kelly.max(0.0).min(0.25) * capital) / entry
                }
                SizingMethod::OptimalF => {
                    let f = 1.0 - (1.0 - win_rate).powf(1.0 / avg_loss.max(0.0001));
                    (f.max(0.0).min(0.25) * capital) / entry
                }
                SizingMethod::VolatilityScaled => {
                    let target_vol = 0.10;
                    let scale = if volatility > 0.0 { target_vol / volatility } else { 1.0 };
                    (capital * self.risk_per_trade * scale) / entry
                }
            };
            (size * entry).min(capital * self.max_position_pct) / entry
        }
    }

    pub struct CorrelationRisk { correlation_matrix: Vec<Vec<f64>>, symbols: Vec<String> }
    impl CorrelationRisk {
        pub fn new() -> Self { Self { correlation_matrix: Vec::new(), symbols: Vec::new() } }

        pub fn update(&mut self, returns: &HashMap<String, Vec<f64>>) {
            self.symbols = returns.keys().cloned().collect();
            let n = self.symbols.len();
            self.correlation_matrix = vec![vec![0.0; n]; n];
            for (i, sym_i) in self.symbols.iter().enumerate() {
                for (j, sym_j) in self.symbols.iter().enumerate() {
                    if i == j { self.correlation_matrix[i][j] = 1.0; continue; }
                    if let (Some(ret_i), Some(ret_j)) = (returns.get(sym_i), returns.get(sym_j)) {
                        self.correlation_matrix[i][j] = Self::correlation(ret_i, ret_j);
                    }
                }
            }
        }

        fn correlation(x: &[f64], y: &[f64]) -> f64 {
            let n = x.len().min(y.len()) as f64;
            if n < 2.0 { return 0.0; }
            let mean_x = x.iter().sum::<f64>() / n;
            let mean_y = y.iter().sum::<f64>() / n;
            let cov: f64 = x.iter().zip(y).map(|(a, b)| (a - mean_x) * (b - mean_y)).sum::<f64>() / n;
            let std_x = (x.iter().map(|v| (v - mean_x).powi(2)).sum::<f64>() / n).sqrt();
            let std_y = (y.iter().map(|v| (v - mean_y).powi(2)).sum::<f64>() / n).sqrt();
            if std_x > 0.0 && std_y > 0.0 { cov / (std_x * std_y) } else { 0.0 }
        }

        pub fn diversification_ratio(&self, weights: &[f64]) -> f64 {
            let n = weights.len().min(self.correlation_matrix.len());
            if n == 0 { return 1.0; }
            let weighted_vol: f64 = weights.iter().take(n).sum();
            let mut portfolio_var = 0.0;
            for i in 0..n { for j in 0..n { portfolio_var += weights[i] * weights[j] * self.correlation_matrix[i][j]; }}
            if portfolio_var > 0.0 { weighted_vol / portfolio_var.sqrt() } else { 1.0 }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Order Management System
// ═══════════════════════════════════════════════════════════════════════════════

pub mod oms {
    use super::*;

    pub struct OrderManagementSystem {
        orders: HashMap<u64, Order>,
        next_order_id: u64,
        fills: Vec<Fill>,
        pub order_timeout_ms: i64,
    }

    #[derive(Clone)]
    pub struct Order {
        pub id: u64,
        pub symbol: String,
        pub side: OrderSide,
        pub order_type: OrderType,
        pub quantity: f64,
        pub filled_quantity: f64,
        pub price: Option<f64>,
        pub stop_price: Option<f64>,
        pub status: OrderStatus,
        pub created_at: i64,
        pub updated_at: i64,
        pub client_order_id: String,
    }

    #[derive(Clone, Copy, PartialEq)]
    pub enum OrderSide { Buy, Sell }
    #[derive(Clone, Copy, PartialEq)]
    pub enum OrderType { Market, Limit, Stop, StopLimit, TrailingStop }
    #[derive(Clone, Copy, PartialEq)]
    pub enum OrderStatus { New, PartiallyFilled, Filled, Cancelled, Rejected, Expired }

    #[derive(Clone)]
    pub struct Fill { pub order_id: u64, pub quantity: f64, pub price: f64, pub timestamp: i64, pub fee: f64 }

    impl OrderManagementSystem {
        pub fn new() -> Self { Self { orders: HashMap::new(), next_order_id: 1, fills: Vec::new(), order_timeout_ms: 86400000 } }

        pub fn submit_order(&mut self, symbol: &str, side: OrderSide, order_type: OrderType, quantity: f64, price: Option<f64>, stop: Option<f64>) -> u64 {
            let id = self.next_order_id;
            self.next_order_id += 1;
            let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_millis() as i64;
            self.orders.insert(id, Order {
                id, symbol: symbol.to_string(), side, order_type, quantity, filled_quantity: 0.0, price, stop_price: stop,
                status: OrderStatus::New, created_at: now, updated_at: now, client_order_id: format!("CLT-{}", id),
            });
            id
        }

        pub fn cancel_order(&mut self, id: u64) -> bool {
            if let Some(order) = self.orders.get_mut(&id) {
                if order.status == OrderStatus::New || order.status == OrderStatus::PartiallyFilled {
                    order.status = OrderStatus::Cancelled;
                    order.updated_at = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_millis() as i64;
                    return true;
                }
            }
            false
        }

        pub fn process_fill(&mut self, order_id: u64, fill_qty: f64, fill_price: f64, fee: f64) {
            if let Some(order) = self.orders.get_mut(&order_id) {
                let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_millis() as i64;
                order.filled_quantity += fill_qty;
                order.updated_at = now;
                if order.filled_quantity >= order.quantity { order.status = OrderStatus::Filled; }
                else { order.status = OrderStatus::PartiallyFilled; }
                self.fills.push(Fill { order_id, quantity: fill_qty, price: fill_price, timestamp: now, fee });
            }
        }

        pub fn get_order(&self, id: u64) -> Option<&Order> { self.orders.get(&id) }
        pub fn get_open_orders(&self) -> Vec<&Order> { self.orders.values().filter(|o| o.status == OrderStatus::New || o.status == OrderStatus::PartiallyFilled).collect() }
        pub fn get_fills_for_order(&self, id: u64) -> Vec<&Fill> { self.fills.iter().filter(|f| f.order_id == id).collect() }

        pub fn cancel_all(&mut self, symbol: Option<&str>) -> usize {
            let mut count = 0;
            for order in self.orders.values_mut() {
                if symbol.map(|s| s == order.symbol).unwrap_or(true) && (order.status == OrderStatus::New || order.status == OrderStatus::PartiallyFilled) {
                    order.status = OrderStatus::Cancelled;
                    count += 1;
                }
            }
            count
        }

        pub fn expire_stale_orders(&mut self) -> usize {
            let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_millis() as i64;
            let mut count = 0;
            for order in self.orders.values_mut() {
                if (order.status == OrderStatus::New || order.status == OrderStatus::PartiallyFilled) && now - order.created_at > self.order_timeout_ms {
                    order.status = OrderStatus::Expired;
                    count += 1;
                }
            }
            count
        }
    }

    pub struct BracketOrder { pub entry: Order, pub take_profit: Option<Order>, pub stop_loss: Option<Order> }
    pub struct OCOOrder { pub order1: Order, pub order2: Order, pub triggered: Option<u64> }

    pub struct OrderRouter {
        venues: Vec<Venue>,
        pub routing_mode: RoutingMode,
    }

    #[derive(Clone)]
    pub struct Venue { pub name: String, pub fee_rate: f64, pub latency_ms: f64, pub liquidity_score: f64 }
    #[derive(Clone, Copy)]
    pub enum RoutingMode { BestPrice, LowestFee, LowestLatency, SmartRoute }

    impl OrderRouter {
        pub fn new() -> Self { Self { venues: Vec::new(), routing_mode: RoutingMode::SmartRoute } }
        pub fn add_venue(&mut self, venue: Venue) { self.venues.push(venue); }

        pub fn route(&self, order: &Order) -> Option<&Venue> {
            if self.venues.is_empty() { return None; }
            match self.routing_mode {
                RoutingMode::BestPrice | RoutingMode::SmartRoute => self.venues.iter().max_by(|a, b| a.liquidity_score.partial_cmp(&b.liquidity_score).unwrap()),
                RoutingMode::LowestFee => self.venues.iter().min_by(|a, b| a.fee_rate.partial_cmp(&b.fee_rate).unwrap()),
                RoutingMode::LowestLatency => self.venues.iter().min_by(|a, b| a.latency_ms.partial_cmp(&b.latency_ms).unwrap()),
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUANTUM COMPUTING FOR FINANCE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod quantum_computing {
    use std::collections::HashMap;

    #[derive(Clone, Debug)]
    pub struct Complex { pub re: f64, pub im: f64 }
    impl Complex {
        pub fn new(re: f64, im: f64) -> Self { Self { re, im } }
        pub fn zero() -> Self { Self::new(0.0, 0.0) }
        pub fn one() -> Self { Self::new(1.0, 0.0) }
        pub fn i() -> Self { Self::new(0.0, 1.0) }
        pub fn from_polar(r: f64, theta: f64) -> Self { Self::new(r * theta.cos(), r * theta.sin()) }
        pub fn conj(&self) -> Self { Self::new(self.re, -self.im) }
        pub fn norm_sq(&self) -> f64 { self.re * self.re + self.im * self.im }
        pub fn norm(&self) -> f64 { self.norm_sq().sqrt() }
        pub fn arg(&self) -> f64 { self.im.atan2(self.re) }
        pub fn add(&self, other: &Complex) -> Complex { Complex::new(self.re + other.re, self.im + other.im) }
        pub fn sub(&self, other: &Complex) -> Complex { Complex::new(self.re - other.re, self.im - other.im) }
        pub fn mul(&self, other: &Complex) -> Complex { Complex::new(self.re * other.re - self.im * other.im, self.re * other.im + self.im * other.re) }
        pub fn scale(&self, s: f64) -> Complex { Complex::new(self.re * s, self.im * s) }
        pub fn div(&self, other: &Complex) -> Complex { let d = other.norm_sq(); Complex::new((self.re * other.re + self.im * other.im) / d, (self.im * other.re - self.re * other.im) / d) }
        pub fn exp(&self) -> Complex { let e = self.re.exp(); Complex::new(e * self.im.cos(), e * self.im.sin()) }
        pub fn sqrt(&self) -> Complex { let r = self.norm().sqrt(); let theta = self.arg() / 2.0; Complex::from_polar(r, theta) }
    }

    #[derive(Clone)]
    pub struct QuantumState { pub amplitudes: Vec<Complex>, pub n_qubits: usize }
    impl QuantumState {
        pub fn new(n_qubits: usize) -> Self {
            let dim = 1 << n_qubits;
            let mut amplitudes = vec![Complex::zero(); dim];
            amplitudes[0] = Complex::one();
            Self { amplitudes, n_qubits }
        }
        pub fn from_amplitudes(amplitudes: Vec<Complex>) -> Self {
            let n_qubits = (amplitudes.len() as f64).log2() as usize;
            Self { amplitudes, n_qubits }
        }
        pub fn dim(&self) -> usize { 1 << self.n_qubits }
        pub fn normalize(&mut self) {
            let norm: f64 = self.amplitudes.iter().map(|a| a.norm_sq()).sum::<f64>().sqrt();
            if norm > 1e-10 { for a in &mut self.amplitudes { *a = a.scale(1.0 / norm); } }
        }
        pub fn probability(&self, index: usize) -> f64 { self.amplitudes.get(index).map(|a| a.norm_sq()).unwrap_or(0.0) }
        pub fn measure(&self, rng: &mut u64) -> usize {
            let r = Self::rand_f64(rng);
            let mut cumulative = 0.0;
            for (i, amp) in self.amplitudes.iter().enumerate() {
                cumulative += amp.norm_sq();
                if r < cumulative { return i; }
            }
            self.amplitudes.len() - 1
        }
        fn rand_f64(rng: &mut u64) -> f64 { *rng ^= *rng << 13; *rng ^= *rng >> 7; *rng ^= *rng << 17; (*rng as f64) / (u64::MAX as f64) }
        pub fn expectation(&self, observable: &QuantumOperator) -> f64 {
            let result = observable.apply(self);
            let mut exp = Complex::zero();
            for (i, amp) in self.amplitudes.iter().enumerate() {
                exp = exp.add(&amp.conj().mul(&result.amplitudes[i]));
            }
            exp.re
        }
        pub fn fidelity(&self, other: &QuantumState) -> f64 {
            let mut overlap = Complex::zero();
            for (a, b) in self.amplitudes.iter().zip(other.amplitudes.iter()) {
                overlap = overlap.add(&a.conj().mul(b));
            }
            overlap.norm_sq()
        }
        pub fn entropy(&self) -> f64 {
            -self.amplitudes.iter().map(|a| { let p = a.norm_sq(); if p > 1e-15 { p * p.log2() } else { 0.0 } }).sum::<f64>()
        }
    }

    #[derive(Clone)]
    pub struct QuantumOperator { pub matrix: Vec<Vec<Complex>>, pub dim: usize }
    impl QuantumOperator {
        pub fn identity(n_qubits: usize) -> Self {
            let dim = 1 << n_qubits;
            let mut matrix = vec![vec![Complex::zero(); dim]; dim];
            for i in 0..dim { matrix[i][i] = Complex::one(); }
            Self { matrix, dim }
        }
        pub fn pauli_x() -> Self { Self { matrix: vec![vec![Complex::zero(), Complex::one()], vec![Complex::one(), Complex::zero()]], dim: 2 } }
        pub fn pauli_y() -> Self { Self { matrix: vec![vec![Complex::zero(), Complex::new(0.0, -1.0)], vec![Complex::i(), Complex::zero()]], dim: 2 } }
        pub fn pauli_z() -> Self { Self { matrix: vec![vec![Complex::one(), Complex::zero()], vec![Complex::zero(), Complex::new(-1.0, 0.0)]], dim: 2 } }
        pub fn hadamard() -> Self {
            let s = 1.0 / 2.0_f64.sqrt();
            Self { matrix: vec![vec![Complex::new(s, 0.0), Complex::new(s, 0.0)], vec![Complex::new(s, 0.0), Complex::new(-s, 0.0)]], dim: 2 }
        }
        pub fn phase(theta: f64) -> Self { Self { matrix: vec![vec![Complex::one(), Complex::zero()], vec![Complex::zero(), Complex::from_polar(1.0, theta)]], dim: 2 } }
        pub fn rx(theta: f64) -> Self {
            let c = Complex::new((theta / 2.0).cos(), 0.0);
            let s = Complex::new(0.0, -(theta / 2.0).sin());
            Self { matrix: vec![vec![c.clone(), s.clone()], vec![s, c]], dim: 2 }
        }
        pub fn ry(theta: f64) -> Self {
            let c = (theta / 2.0).cos(); let s = (theta / 2.0).sin();
            Self { matrix: vec![vec![Complex::new(c, 0.0), Complex::new(-s, 0.0)], vec![Complex::new(s, 0.0), Complex::new(c, 0.0)]], dim: 2 }
        }
        pub fn rz(theta: f64) -> Self {
            Self { matrix: vec![vec![Complex::from_polar(1.0, -theta/2.0), Complex::zero()], vec![Complex::zero(), Complex::from_polar(1.0, theta/2.0)]], dim: 2 }
        }
        pub fn cnot() -> Self {
            Self { matrix: vec![
                vec![Complex::one(), Complex::zero(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::one(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::zero(), Complex::one()],
                vec![Complex::zero(), Complex::zero(), Complex::one(), Complex::zero()],
            ], dim: 4 }
        }
        pub fn cz() -> Self {
            Self { matrix: vec![
                vec![Complex::one(), Complex::zero(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::one(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::one(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::zero(), Complex::new(-1.0, 0.0)],
            ], dim: 4 }
        }
        pub fn swap() -> Self {
            Self { matrix: vec![
                vec![Complex::one(), Complex::zero(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::one(), Complex::zero()],
                vec![Complex::zero(), Complex::one(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::zero(), Complex::one()],
            ], dim: 4 }
        }
        pub fn apply(&self, state: &QuantumState) -> QuantumState {
            let mut result = vec![Complex::zero(); self.dim];
            for i in 0..self.dim {
                for j in 0..self.dim {
                    result[i] = result[i].add(&self.matrix[i][j].mul(&state.amplitudes[j]));
                }
            }
            QuantumState::from_amplitudes(result)
        }
        pub fn tensor(&self, other: &QuantumOperator) -> QuantumOperator {
            let new_dim = self.dim * other.dim;
            let mut matrix = vec![vec![Complex::zero(); new_dim]; new_dim];
            for i in 0..self.dim {
                for j in 0..self.dim {
                    for k in 0..other.dim {
                        for l in 0..other.dim {
                            matrix[i * other.dim + k][j * other.dim + l] = self.matrix[i][j].mul(&other.matrix[k][l]);
                        }
                    }
                }
            }
            QuantumOperator { matrix, dim: new_dim }
        }
        pub fn compose(&self, other: &QuantumOperator) -> QuantumOperator {
            let mut matrix = vec![vec![Complex::zero(); self.dim]; self.dim];
            for i in 0..self.dim {
                for j in 0..self.dim {
                    for k in 0..self.dim {
                        matrix[i][j] = matrix[i][j].add(&self.matrix[i][k].mul(&other.matrix[k][j]));
                    }
                }
            }
            QuantumOperator { matrix, dim: self.dim }
        }
    }

    #[derive(Clone)]
    pub enum QuantumGate { H(usize), X(usize), Y(usize), Z(usize), Rx(usize, f64), Ry(usize, f64), Rz(usize, f64), CNOT(usize, usize), CZ(usize, usize), SWAP(usize, usize), Phase(usize, f64) }

    pub struct QuantumCircuit { pub n_qubits: usize, pub gates: Vec<QuantumGate>, pub parameters: Vec<f64> }
    impl QuantumCircuit {
        pub fn new(n_qubits: usize) -> Self { Self { n_qubits, gates: Vec::new(), parameters: Vec::new() } }
        pub fn h(&mut self, qubit: usize) -> &mut Self { self.gates.push(QuantumGate::H(qubit)); self }
        pub fn x(&mut self, qubit: usize) -> &mut Self { self.gates.push(QuantumGate::X(qubit)); self }
        pub fn y(&mut self, qubit: usize) -> &mut Self { self.gates.push(QuantumGate::Y(qubit)); self }
        pub fn z(&mut self, qubit: usize) -> &mut Self { self.gates.push(QuantumGate::Z(qubit)); self }
        pub fn rx(&mut self, qubit: usize, theta: f64) -> &mut Self { self.gates.push(QuantumGate::Rx(qubit, theta)); self }
        pub fn ry(&mut self, qubit: usize, theta: f64) -> &mut Self { self.gates.push(QuantumGate::Ry(qubit, theta)); self }
        pub fn rz(&mut self, qubit: usize, theta: f64) -> &mut Self { self.gates.push(QuantumGate::Rz(qubit, theta)); self }
        pub fn cnot(&mut self, control: usize, target: usize) -> &mut Self { self.gates.push(QuantumGate::CNOT(control, target)); self }
        pub fn cz(&mut self, q1: usize, q2: usize) -> &mut Self { self.gates.push(QuantumGate::CZ(q1, q2)); self }
        pub fn swap(&mut self, q1: usize, q2: usize) -> &mut Self { self.gates.push(QuantumGate::SWAP(q1, q2)); self }
        pub fn phase(&mut self, qubit: usize, theta: f64) -> &mut Self { self.gates.push(QuantumGate::Phase(qubit, theta)); self }
        pub fn depth(&self) -> usize { self.gates.len() }
        pub fn gate_count(&self) -> HashMap<String, usize> {
            let mut counts = HashMap::new();
            for gate in &self.gates {
                let name = match gate { QuantumGate::H(_) => "H", QuantumGate::X(_) => "X", QuantumGate::Y(_) => "Y", QuantumGate::Z(_) => "Z", QuantumGate::Rx(_, _) => "Rx", QuantumGate::Ry(_, _) => "Ry", QuantumGate::Rz(_, _) => "Rz", QuantumGate::CNOT(_, _) => "CNOT", QuantumGate::CZ(_, _) => "CZ", QuantumGate::SWAP(_, _) => "SWAP", QuantumGate::Phase(_, _) => "Phase" };
                *counts.entry(name.to_string()).or_insert(0) += 1;
            }
            counts
        }
        pub fn run(&self, initial_state: Option<QuantumState>) -> QuantumState {
            let mut state = initial_state.unwrap_or_else(|| QuantumState::new(self.n_qubits));
            for gate in &self.gates {
                state = self.apply_gate(&state, gate);
            }
            state
        }
        fn apply_gate(&self, state: &QuantumState, gate: &QuantumGate) -> QuantumState {
            let dim = state.dim();
            let mut new_amps = state.amplitudes.clone();
            match gate {
                QuantumGate::H(q) => { let s = 1.0 / 2.0_f64.sqrt(); for i in 0..dim { let bit = (i >> q) & 1; let partner = i ^ (1 << q); if bit == 0 { let a = state.amplitudes[i].clone(); let b = state.amplitudes[partner].clone(); new_amps[i] = a.add(&b).scale(s); new_amps[partner] = a.sub(&b).scale(s); } } }
                QuantumGate::X(q) => { for i in 0..dim { let partner = i ^ (1 << q); if i < partner { new_amps.swap(i, partner); } } }
                QuantumGate::Y(q) => { for i in 0..dim { let bit = (i >> q) & 1; let partner = i ^ (1 << q); if i < partner { let a = state.amplitudes[i].clone(); let b = state.amplitudes[partner].clone(); if bit == 0 { new_amps[i] = b.mul(&Complex::new(0.0, -1.0)); new_amps[partner] = a.mul(&Complex::i()); } else { new_amps[i] = b.mul(&Complex::i()); new_amps[partner] = a.mul(&Complex::new(0.0, -1.0)); } } } }
                QuantumGate::Z(q) => { for i in 0..dim { if ((i >> q) & 1) == 1 { new_amps[i] = state.amplitudes[i].scale(-1.0); } } }
                QuantumGate::Rx(q, theta) => { let c = (theta / 2.0).cos(); let s = (theta / 2.0).sin(); for i in 0..dim { let bit = (i >> q) & 1; let partner = i ^ (1 << q); if bit == 0 { let a = state.amplitudes[i].clone(); let b = state.amplitudes[partner].clone(); new_amps[i] = a.scale(c).add(&b.mul(&Complex::new(0.0, -s))); new_amps[partner] = a.mul(&Complex::new(0.0, -s)).add(&b.scale(c)); } } }
                QuantumGate::Ry(q, theta) => { let c = (theta / 2.0).cos(); let s = (theta / 2.0).sin(); for i in 0..dim { let bit = (i >> q) & 1; let partner = i ^ (1 << q); if bit == 0 { let a = state.amplitudes[i].clone(); let b = state.amplitudes[partner].clone(); new_amps[i] = a.scale(c).sub(&b.scale(s)); new_amps[partner] = a.scale(s).add(&b.scale(c)); } } }
                QuantumGate::Rz(q, theta) => { for i in 0..dim { let bit = (i >> q) & 1; let phase = if bit == 0 { -theta / 2.0 } else { theta / 2.0 }; new_amps[i] = state.amplitudes[i].mul(&Complex::from_polar(1.0, phase)); } }
                QuantumGate::CNOT(ctrl, tgt) => { for i in 0..dim { if ((i >> ctrl) & 1) == 1 { let partner = i ^ (1 << tgt); if i < partner { new_amps.swap(i, partner); } } } }
                QuantumGate::CZ(q1, q2) => { for i in 0..dim { if ((i >> q1) & 1) == 1 && ((i >> q2) & 1) == 1 { new_amps[i] = state.amplitudes[i].scale(-1.0); } } }
                QuantumGate::SWAP(q1, q2) => { for i in 0..dim { let b1 = (i >> q1) & 1; let b2 = (i >> q2) & 1; if b1 != b2 { let partner = i ^ (1 << q1) ^ (1 << q2); if i < partner { new_amps.swap(i, partner); } } } }
                QuantumGate::Phase(q, theta) => { for i in 0..dim { if ((i >> q) & 1) == 1 { new_amps[i] = state.amplitudes[i].mul(&Complex::from_polar(1.0, *theta)); } } }
            }
            QuantumState::from_amplitudes(new_amps)
        }
    }

    pub struct QuantumPortfolioOptimizer {
        pub n_assets: usize,
        pub n_qubits: usize,
        pub expected_returns: Vec<f64>,
        pub covariance_matrix: Vec<Vec<f64>>,
        pub risk_aversion: f64,
        pub budget: usize,
    }
    impl QuantumPortfolioOptimizer {
        pub fn new(expected_returns: Vec<f64>, covariance_matrix: Vec<Vec<f64>>, risk_aversion: f64, budget: usize) -> Self {
            let n_assets = expected_returns.len();
            let n_qubits = n_assets;
            Self { n_assets, n_qubits, expected_returns, covariance_matrix, risk_aversion, budget }
        }
        pub fn qaoa_objective(&self, bitstring: usize) -> f64 {
            let mut selected = Vec::new();
            for i in 0..self.n_assets { if (bitstring >> i) & 1 == 1 { selected.push(i); } }
            if selected.len() != self.budget { return -1e10; }
            let weight = 1.0 / self.budget as f64;
            let expected_return: f64 = selected.iter().map(|&i| self.expected_returns[i] * weight).sum();
            let mut variance = 0.0;
            for &i in &selected { for &j in &selected { variance += self.covariance_matrix[i][j] * weight * weight; } }
            expected_return - self.risk_aversion * variance
        }
        pub fn build_qaoa_circuit(&self, gamma: &[f64], beta: &[f64]) -> QuantumCircuit {
            let p = gamma.len();
            let mut circuit = QuantumCircuit::new(self.n_qubits);
            for q in 0..self.n_qubits { circuit.h(q); }
            for layer in 0..p {
                for i in 0..self.n_assets { circuit.rz(i, 2.0 * gamma[layer] * self.expected_returns[i]); }
                for i in 0..self.n_assets { for j in (i + 1)..self.n_assets { circuit.cnot(i, j); circuit.rz(j, gamma[layer] * self.covariance_matrix[i][j] * self.risk_aversion); circuit.cnot(i, j); } }
                for q in 0..self.n_qubits { circuit.rx(q, 2.0 * beta[layer]); }
            }
            circuit
        }
        pub fn optimize(&self, p: usize, n_iterations: usize, learning_rate: f64) -> (Vec<usize>, f64) {
            let mut rng: u64 = 12345;
            let mut gamma: Vec<f64> = (0..p).map(|_| { rng ^= rng << 13; rng ^= rng >> 7; rng ^= rng << 17; (rng as f64 / u64::MAX as f64) * std::f64::consts::PI }).collect();
            let mut beta: Vec<f64> = (0..p).map(|_| { rng ^= rng << 13; rng ^= rng >> 7; rng ^= rng << 17; (rng as f64 / u64::MAX as f64) * std::f64::consts::PI }).collect();
            for _ in 0..n_iterations {
                let circuit = self.build_qaoa_circuit(&gamma, &beta);
                let state = circuit.run(None);
                let expectation = self.compute_expectation(&state);
                let eps = 0.01;
                for i in 0..p {
                    gamma[i] += eps; let e_plus = self.compute_expectation(&self.build_qaoa_circuit(&gamma, &beta).run(None));
                    gamma[i] -= 2.0 * eps; let e_minus = self.compute_expectation(&self.build_qaoa_circuit(&gamma, &beta).run(None));
                    gamma[i] += eps;
                    let grad = (e_plus - e_minus) / (2.0 * eps);
                    gamma[i] += learning_rate * grad;
                }
                for i in 0..p {
                    beta[i] += eps; let e_plus = self.compute_expectation(&self.build_qaoa_circuit(&gamma, &beta).run(None));
                    beta[i] -= 2.0 * eps; let e_minus = self.compute_expectation(&self.build_qaoa_circuit(&gamma, &beta).run(None));
                    beta[i] += eps;
                    let grad = (e_plus - e_minus) / (2.0 * eps);
                    beta[i] += learning_rate * grad;
                }
            }
            let final_state = self.build_qaoa_circuit(&gamma, &beta).run(None);
            let mut best_bitstring = 0;
            let mut best_value = f64::NEG_INFINITY;
            for bs in 0..(1 << self.n_assets) {
                let obj = self.qaoa_objective(bs);
                let prob = final_state.probability(bs);
                if obj > best_value && prob > 0.001 { best_value = obj; best_bitstring = bs; }
            }
            let selected: Vec<usize> = (0..self.n_assets).filter(|&i| (best_bitstring >> i) & 1 == 1).collect();
            (selected, best_value)
        }
        fn compute_expectation(&self, state: &QuantumState) -> f64 {
            (0..(1 << self.n_assets)).map(|bs| state.probability(bs) * self.qaoa_objective(bs)).sum()
        }
    }

    pub struct QuantumMonteCarlo { pub n_qubits: usize, pub n_samples: usize, rng_state: u64 }
    impl QuantumMonteCarlo {
        pub fn new(n_qubits: usize, n_samples: usize) -> Self { Self { n_qubits, n_samples, rng_state: 42 } }
        pub fn option_price_amplitude_estimation(&mut self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let n_price_qubits = self.n_qubits - 1;
            let n_levels = 1 << n_price_qubits;
            let u = (sigma * (t / n_levels as f64).sqrt()).exp();
            let d = 1.0 / u;
            let p = ((r * t / n_levels as f64).exp() - d) / (u - d);
            let mut prices = vec![0.0; n_levels];
            for i in 0..n_levels {
                let n_ups = (i as f64).count_ones() as i32;
                let n_downs = n_price_qubits as i32 - n_ups;
                prices[i] = s0 * u.powi(n_ups) * d.powi(n_downs);
            }
            let payoffs: Vec<f64> = prices.iter().map(|&price| (price - k).max(0.0)).collect();
            let max_payoff = payoffs.iter().cloned().fold(0.0, f64::max);
            if max_payoff < 1e-10 { return 0.0; }
            let mut total_prob = 0.0;
            let mut weighted_payoff = 0.0;
            for i in 0..n_levels {
                let n_ups = (i as f64).count_ones() as usize;
                let prob = self.binomial_prob(n_price_qubits, n_ups, p);
                total_prob += prob;
                weighted_payoff += prob * payoffs[i];
            }
            weighted_payoff * (-r * t).exp()
        }
        fn binomial_prob(&self, n: usize, k: usize, p: f64) -> f64 {
            let coeff = self.binomial_coefficient(n, k);
            coeff as f64 * p.powi(k as i32) * (1.0 - p).powi((n - k) as i32)
        }
        fn binomial_coefficient(&self, n: usize, k: usize) -> u64 {
            if k > n { return 0; }
            let k = k.min(n - k);
            let mut result: u64 = 1;
            for i in 0..k { result = result * (n - i) as u64 / (i + 1) as u64; }
            result
        }
        pub fn var_estimation(&mut self, returns: &[f64], confidence: f64) -> f64 {
            let mut sorted = returns.to_vec();
            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let idx = ((1.0 - confidence) * returns.len() as f64) as usize;
            sorted.get(idx).copied().unwrap_or(0.0)
        }
        pub fn cvar_estimation(&mut self, returns: &[f64], confidence: f64) -> f64 {
            let var = self.var_estimation(returns, confidence);
            let tail: Vec<f64> = returns.iter().filter(|&&r| r <= var).copied().collect();
            if tail.is_empty() { var } else { tail.iter().sum::<f64>() / tail.len() as f64 }
        }
    }

    pub struct VariationalQuantumEigensolver {
        pub n_qubits: usize,
        pub n_layers: usize,
        pub hamiltonian: Vec<(f64, Vec<(usize, char)>)>,
    }
    impl VariationalQuantumEigensolver {
        pub fn new(n_qubits: usize, n_layers: usize) -> Self { Self { n_qubits, n_layers, hamiltonian: Vec::new() } }
        pub fn add_term(&mut self, coefficient: f64, pauli_string: Vec<(usize, char)>) { self.hamiltonian.push((coefficient, pauli_string)); }
        pub fn portfolio_hamiltonian(returns: &[f64], covariance: &[Vec<f64>], risk_aversion: f64) -> Self {
            let n = returns.len();
            let mut vqe = Self::new(n, 2);
            for i in 0..n { vqe.add_term(-returns[i] / 2.0, vec![(i, 'Z')]); vqe.add_term(-returns[i] / 2.0, vec![]); }
            for i in 0..n { for j in 0..n { if i != j { vqe.add_term(risk_aversion * covariance[i][j] / 4.0, vec![(i, 'Z'), (j, 'Z')]); } } }
            vqe
        }
        pub fn build_ansatz(&self, params: &[f64]) -> QuantumCircuit {
            let mut circuit = QuantumCircuit::new(self.n_qubits);
            let mut param_idx = 0;
            for q in 0..self.n_qubits { circuit.ry(q, params[param_idx]); param_idx += 1; }
            for _ in 0..self.n_layers {
                for q in 0..self.n_qubits { if q + 1 < self.n_qubits { circuit.cnot(q, q + 1); } }
                if self.n_qubits > 1 { circuit.cnot(self.n_qubits - 1, 0); }
                for q in 0..self.n_qubits { circuit.ry(q, params[param_idx]); circuit.rz(q, params[param_idx + 1]); param_idx += 2; }
            }
            circuit
        }
        pub fn n_parameters(&self) -> usize { self.n_qubits + self.n_layers * self.n_qubits * 2 }
        pub fn evaluate(&self, params: &[f64]) -> f64 {
            let circuit = self.build_ansatz(params);
            let state = circuit.run(None);
            let mut energy = 0.0;
            for (coeff, pauli_string) in &self.hamiltonian {
                if pauli_string.is_empty() { energy += coeff; continue; }
                let exp = self.expectation_value(&state, pauli_string);
                energy += coeff * exp;
            }
            energy
        }
        fn expectation_value(&self, state: &QuantumState, pauli_string: &[(usize, char)]) -> f64 {
            let dim = state.dim();
            let mut result = 0.0;
            for i in 0..dim {
                let mut sign = 1.0;
                for (qubit, pauli) in pauli_string {
                    let bit = (i >> qubit) & 1;
                    match pauli {
                        'Z' => { if bit == 1 { sign *= -1.0; } }
                        'X' | 'Y' => { return 0.0; }
                        _ => {}
                    }
                }
                result += sign * state.probability(i);
            }
            result
        }
        pub fn optimize(&self, n_iterations: usize, learning_rate: f64) -> (Vec<f64>, f64) {
            let n_params = self.n_parameters();
            let mut rng: u64 = 42;
            let mut params: Vec<f64> = (0..n_params).map(|_| { rng ^= rng << 13; rng ^= rng >> 7; rng ^= rng << 17; (rng as f64 / u64::MAX as f64) * 2.0 * std::f64::consts::PI }).collect();
            for _ in 0..n_iterations {
                let eps = 0.01;
                let mut gradients = vec![0.0; n_params];
                for i in 0..n_params {
                    params[i] += eps;
                    let e_plus = self.evaluate(&params);
                    params[i] -= 2.0 * eps;
                    let e_minus = self.evaluate(&params);
                    params[i] += eps;
                    gradients[i] = (e_plus - e_minus) / (2.0 * eps);
                }
                for i in 0..n_params { params[i] -= learning_rate * gradients[i]; }
            }
            let energy = self.evaluate(&params);
            (params, energy)
        }
    }

    pub struct QuantumSampling { pub n_qubits: usize, pub circuit: QuantumCircuit }
    impl QuantumSampling {
        pub fn new(n_qubits: usize) -> Self { Self { n_qubits, circuit: QuantumCircuit::new(n_qubits) } }
        pub fn prepare_distribution(&mut self, probabilities: &[f64]) {
            let n = probabilities.len().next_power_of_two();
            let n_qubits = (n as f64).log2() as usize;
            self.n_qubits = n_qubits;
            self.circuit = QuantumCircuit::new(n_qubits);
            self.build_state_prep(probabilities, 0, n_qubits);
        }
        fn build_state_prep(&mut self, probs: &[f64], start_qubit: usize, n_qubits: usize) {
            if n_qubits == 0 || probs.is_empty() { return; }
            let total: f64 = probs.iter().sum();
            if total < 1e-10 { return; }
            let mid = probs.len() / 2;
            let left_sum: f64 = probs[..mid].iter().sum();
            let right_sum: f64 = probs[mid..].iter().sum();
            let theta = 2.0 * (left_sum / total).sqrt().acos();
            self.circuit.ry(start_qubit, theta);
            if n_qubits > 1 {
                self.build_state_prep(&probs[..mid], start_qubit + 1, n_qubits - 1);
                self.build_state_prep(&probs[mid..], start_qubit + 1, n_qubits - 1);
            }
        }
        pub fn sample(&self, n_shots: usize) -> Vec<usize> {
            let state = self.circuit.run(None);
            let mut rng: u64 = 12345;
            (0..n_shots).map(|_| state.measure(&mut rng)).collect()
        }
        pub fn sample_returns(&self, return_values: &[f64], n_shots: usize) -> Vec<f64> {
            self.sample(n_shots).iter().filter_map(|&idx| return_values.get(idx).copied()).collect()
        }
    }

    pub struct QuantumNeuralNetwork { pub n_qubits: usize, pub n_layers: usize, pub params: Vec<f64> }
    impl QuantumNeuralNetwork {
        pub fn new(n_qubits: usize, n_layers: usize) -> Self {
            let n_params = n_qubits * (1 + n_layers * 3);
            let mut rng: u64 = 42;
            let params = (0..n_params).map(|_| { rng ^= rng << 13; rng ^= rng >> 7; rng ^= rng << 17; (rng as f64 / u64::MAX as f64 - 0.5) * 0.1 }).collect();
            Self { n_qubits, n_layers, params }
        }
        pub fn encode_features(&self, features: &[f64]) -> QuantumCircuit {
            let mut circuit = QuantumCircuit::new(self.n_qubits);
            for (i, &f) in features.iter().take(self.n_qubits).enumerate() {
                circuit.ry(i, f * std::f64::consts::PI);
                circuit.rz(i, f * f * std::f64::consts::PI);
            }
            circuit
        }
        pub fn variational_layer(&self, circuit: &mut QuantumCircuit, layer_params: &[f64]) {
            for (q, chunk) in layer_params.chunks(3).enumerate().take(self.n_qubits) {
                circuit.rx(q, chunk[0]);
                circuit.ry(q, chunk[1]);
                circuit.rz(q, chunk[2]);
            }
            for q in 0..self.n_qubits - 1 { circuit.cnot(q, q + 1); }
            if self.n_qubits > 2 { circuit.cnot(self.n_qubits - 1, 0); }
        }
        pub fn forward(&self, features: &[f64]) -> f64 {
            let mut circuit = self.encode_features(features);
            let mut param_idx = self.n_qubits;
            for _ in 0..self.n_layers {
                let layer_params = &self.params[param_idx..param_idx + self.n_qubits * 3];
                self.variational_layer(&mut circuit, layer_params);
                param_idx += self.n_qubits * 3;
            }
            let state = circuit.run(None);
            let mut expectation = 0.0;
            for (i, amp) in state.amplitudes.iter().enumerate() {
                let parity = (i.count_ones() % 2) as f64 * 2.0 - 1.0;
                expectation += parity * amp.norm_sq();
            }
            expectation
        }
        pub fn train(&mut self, features: &[Vec<f64>], labels: &[f64], epochs: usize, learning_rate: f64) {
            for _ in 0..epochs {
                for (x, &y) in features.iter().zip(labels.iter()) {
                    let pred = self.forward(x);
                    let error = pred - y;
                    let eps = 0.01;
                    for i in 0..self.params.len() {
                        self.params[i] += eps;
                        let pred_plus = self.forward(x);
                        self.params[i] -= 2.0 * eps;
                        let pred_minus = self.forward(x);
                        self.params[i] += eps;
                        let grad = (pred_plus - pred_minus) / (2.0 * eps);
                        self.params[i] -= learning_rate * error * grad;
                    }
                }
            }
        }
    }

    pub struct QuantumFeatureMap { pub n_qubits: usize, pub feature_dim: usize, pub entanglement: String }
    impl QuantumFeatureMap {
        pub fn new(n_qubits: usize, feature_dim: usize) -> Self { Self { n_qubits, feature_dim, entanglement: "full".to_string() } }
        pub fn zz_feature_map(&self, features: &[f64]) -> QuantumCircuit {
            let mut circuit = QuantumCircuit::new(self.n_qubits);
            for _ in 0..2 {
                for (q, &f) in features.iter().take(self.n_qubits).enumerate() { circuit.h(q); circuit.rz(q, 2.0 * f); }
                for i in 0..self.n_qubits { for j in (i + 1)..self.n_qubits { let f_i = features.get(i).copied().unwrap_or(0.0); let f_j = features.get(j).copied().unwrap_or(0.0); circuit.cnot(i, j); circuit.rz(j, 2.0 * (std::f64::consts::PI - f_i) * (std::f64::consts::PI - f_j)); circuit.cnot(i, j); } }
            }
            circuit
        }
        pub fn kernel(&self, x1: &[f64], x2: &[f64]) -> f64 {
            let circuit1 = self.zz_feature_map(x1);
            let circuit2 = self.zz_feature_map(x2);
            let state1 = circuit1.run(None);
            let state2 = circuit2.run(None);
            state1.fidelity(&state2)
        }
        pub fn kernel_matrix(&self, data: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = data.len();
            let mut matrix = vec![vec![0.0; n]; n];
            for i in 0..n { for j in i..n { let k = self.kernel(&data[i], &data[j]); matrix[i][j] = k; matrix[j][i] = k; } }
            matrix
        }
    }

    pub struct HybridClassicalQuantum {
        pub classical_layers: Vec<usize>,
        pub quantum_circuit: QuantumNeuralNetwork,
        pub classical_weights: Vec<Vec<Vec<f64>>>,
    }
    impl HybridClassicalQuantum {
        pub fn new(input_dim: usize, hidden_dims: Vec<usize>, n_qubits: usize, n_q_layers: usize) -> Self {
            let mut rng: u64 = 42;
            let mut classical_layers = vec![input_dim];
            classical_layers.extend(&hidden_dims);
            classical_layers.push(n_qubits);
            let mut weights = Vec::new();
            for i in 0..classical_layers.len() - 1 {
                let w: Vec<Vec<f64>> = (0..classical_layers[i + 1]).map(|_| (0..classical_layers[i]).map(|_| { rng ^= rng << 13; rng ^= rng >> 7; rng ^= rng << 17; (rng as f64 / u64::MAX as f64 - 0.5) * 0.1 }).collect()).collect();
                weights.push(w);
            }
            Self { classical_layers, quantum_circuit: QuantumNeuralNetwork::new(n_qubits, n_q_layers), classical_weights: weights }
        }
        pub fn forward(&self, input: &[f64]) -> f64 {
            let mut x = input.to_vec();
            for weights in &self.classical_weights {
                let mut next = vec![0.0; weights.len()];
                for (i, w) in weights.iter().enumerate() { for (j, &v) in x.iter().enumerate() { next[i] += w[j] * v; } next[i] = next[i].max(0.0); }
                x = next;
            }
            self.quantum_circuit.forward(&x)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUANTUM RISK ANALYTICS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod quantum_risk {
    use super::quantum_computing::*;

    pub struct QuantumVaR { pub n_qubits: usize, pub confidence_level: f64, pub time_horizon: f64 }
    impl QuantumVaR {
        pub fn new(n_qubits: usize, confidence: f64, horizon: f64) -> Self { Self { n_qubits, confidence_level: confidence, time_horizon: horizon } }
        pub fn estimate(&self, portfolio_returns: &[f64]) -> f64 {
            let mut sorted = portfolio_returns.to_vec();
            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
            let idx = ((1.0 - self.confidence_level) * sorted.len() as f64) as usize;
            sorted.get(idx).copied().unwrap_or(0.0) * self.time_horizon.sqrt()
        }
        pub fn quantum_amplitude_estimation(&self, portfolio_returns: &[f64], n_iterations: usize) -> f64 {
            let threshold = self.estimate(portfolio_returns);
            let n_below: usize = portfolio_returns.iter().filter(|&&r| r < threshold).count();
            let prob = n_below as f64 / portfolio_returns.len() as f64;
            let mut a_est = prob;
            for k in 1..=n_iterations {
                let m = 1 << k;
                let theta = (a_est.sqrt()).asin();
                let measured = (m as f64 * theta).sin().powi(2);
                a_est = measured;
            }
            threshold * (1.0 + (a_est - prob).abs())
        }
    }

    pub struct QuantumCreditRisk { pub n_obligors: usize, pub default_probs: Vec<f64>, pub correlations: Vec<Vec<f64>>, pub exposures: Vec<f64> }
    impl QuantumCreditRisk {
        pub fn new(default_probs: Vec<f64>, correlations: Vec<Vec<f64>>, exposures: Vec<f64>) -> Self {
            let n = default_probs.len();
            Self { n_obligors: n, default_probs, correlations, exposures }
        }
        pub fn expected_loss(&self) -> f64 { self.default_probs.iter().zip(&self.exposures).map(|(&p, &e)| p * e).sum() }
        pub fn loss_distribution_moments(&self) -> (f64, f64, f64) {
            let mean = self.expected_loss();
            let mut variance = 0.0;
            let mut skewness = 0.0;
            for i in 0..self.n_obligors {
                for j in 0..self.n_obligors {
                    let cov = if i == j { self.default_probs[i] * (1.0 - self.default_probs[i]) } else { self.correlations[i][j] * (self.default_probs[i] * (1.0 - self.default_probs[i]) * self.default_probs[j] * (1.0 - self.default_probs[j])).sqrt() };
                    variance += self.exposures[i] * self.exposures[j] * cov;
                }
            }
            let std = variance.sqrt();
            for i in 0..self.n_obligors { skewness += self.exposures[i].powi(3) * self.default_probs[i] * (1.0 - self.default_probs[i]) * (1.0 - 2.0 * self.default_probs[i]); }
            if std > 1e-10 { skewness /= std.powi(3); }
            (mean, variance, skewness)
        }
        pub fn quantum_credit_var(&self, confidence: f64, n_qubits: usize) -> f64 {
            let (mean, var, skew) = self.loss_distribution_moments();
            let z = Self::normal_quantile(confidence);
            let cornish_fisher = z + (z * z - 1.0) * skew / 6.0;
            mean + var.sqrt() * cornish_fisher
        }
        fn normal_quantile(p: f64) -> f64 {
            let a = [2.50662823884, -18.61500062529, 41.39119773534, -25.44106049637];
            let b = [-8.47351093090, 23.08336743743, -21.06224101826, 3.13082909833];
            let c = [0.3374754822726147, 0.9761690190917186, 0.1607979714918209, 0.0276438810333863, 0.0038405729373609, 0.0003951896511919, 0.0000321767881768];
            let d = [0.2535722031614826, 0.0245614620914914, 0.0039750018794856, 0.0004959825304638, 0.0000413651609280, 0.0000020791839954];
            let p_low = 0.02425; let p_high = 1.0 - p_low;
            if p < p_low { let q = (-2.0 * p.ln()).sqrt(); c[0] + q * (c[1] + q * (c[2] + q * (c[3] + q * (c[4] + q * (c[5] + q * c[6]))))) / (1.0 + q * (d[0] + q * (d[1] + q * (d[2] + q * (d[3] + q * (d[4] + q * d[5])))))) }
            else if p <= p_high { let q = p - 0.5; let r = q * q; (a[0] + r * (a[1] + r * (a[2] + r * a[3]))) * q / (1.0 + r * (b[0] + r * (b[1] + r * (b[2] + r * b[3])))) }
            else { let q = (-2.0 * (1.0 - p).ln()).sqrt(); -(c[0] + q * (c[1] + q * (c[2] + q * (c[3] + q * (c[4] + q * (c[5] + q * c[6])))))) / (1.0 + q * (d[0] + q * (d[1] + q * (d[2] + q * (d[3] + q * (d[4] + q * d[5])))))) }
        }
    }

    pub struct QuantumStressTest { pub scenarios: Vec<(String, Vec<f64>)>, pub portfolio_weights: Vec<f64>, pub asset_sensitivities: Vec<Vec<f64>> }
    impl QuantumStressTest {
        pub fn new(portfolio_weights: Vec<f64>) -> Self { Self { scenarios: Vec::new(), portfolio_weights, asset_sensitivities: Vec::new() } }
        pub fn add_scenario(&mut self, name: &str, factor_shocks: Vec<f64>) { self.scenarios.push((name.to_string(), factor_shocks)); }
        pub fn set_sensitivities(&mut self, sensitivities: Vec<Vec<f64>>) { self.asset_sensitivities = sensitivities; }
        pub fn run_scenario(&self, scenario_idx: usize) -> f64 {
            let (_, factor_shocks) = &self.scenarios[scenario_idx];
            let mut total_loss = 0.0;
            for (i, &weight) in self.portfolio_weights.iter().enumerate() {
                if let Some(sens) = self.asset_sensitivities.get(i) {
                    let asset_loss: f64 = sens.iter().zip(factor_shocks.iter()).map(|(&s, &f)| s * f).sum();
                    total_loss += weight * asset_loss;
                }
            }
            total_loss
        }
        pub fn run_all_scenarios(&self) -> Vec<(String, f64)> { (0..self.scenarios.len()).map(|i| (self.scenarios[i].0.clone(), self.run_scenario(i))).collect() }
        pub fn worst_case(&self) -> (String, f64) { self.run_all_scenarios().into_iter().min_by(|a, b| a.1.partial_cmp(&b.1).unwrap()).unwrap_or(("None".to_string(), 0.0)) }
        pub fn quantum_superposition_stress(&self) -> f64 {
            let n = self.scenarios.len();
            if n == 0 { return 0.0; }
            let losses: Vec<f64> = (0..n).map(|i| self.run_scenario(i)).collect();
            let min_loss = losses.iter().cloned().fold(f64::INFINITY, f64::min);
            let max_loss = losses.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let normalized: Vec<f64> = losses.iter().map(|&l| if max_loss > min_loss { (l - min_loss) / (max_loss - min_loss) } else { 0.5 }).collect();
            let expected: f64 = normalized.iter().sum::<f64>() / n as f64;
            min_loss + expected * (max_loss - min_loss)
        }
    }

    pub struct QuantumLiquidityRisk { pub bid_ask_spreads: Vec<f64>, pub daily_volumes: Vec<f64>, pub position_sizes: Vec<f64>, pub market_impact_coeffs: Vec<f64> }
    impl QuantumLiquidityRisk {
        pub fn new(spreads: Vec<f64>, volumes: Vec<f64>, positions: Vec<f64>) -> Self {
            let n = spreads.len();
            let impact_coeffs = (0..n).map(|i| 0.1 / volumes[i].max(1.0).sqrt()).collect();
            Self { bid_ask_spreads: spreads, daily_volumes: volumes, position_sizes: positions, market_impact_coeffs: impact_coeffs }
        }
        pub fn spread_cost(&self) -> f64 { self.bid_ask_spreads.iter().zip(&self.position_sizes).map(|(&s, &p)| s * p.abs() / 2.0).sum() }
        pub fn market_impact(&self) -> f64 { (0..self.position_sizes.len()).map(|i| { let participation = self.position_sizes[i].abs() / self.daily_volumes[i].max(1.0); self.market_impact_coeffs[i] * participation.sqrt() * self.position_sizes[i].abs() }).sum() }
        pub fn total_liquidation_cost(&self) -> f64 { self.spread_cost() + self.market_impact() }
        pub fn optimal_liquidation_schedule(&self, n_days: usize) -> Vec<Vec<f64>> {
            let n = self.position_sizes.len();
            (0..n).map(|i| {
                let total = self.position_sizes[i];
                let daily_limit = self.daily_volumes[i] * 0.1;
                let days_needed = (total.abs() / daily_limit).ceil() as usize;
                let actual_days = days_needed.max(1).min(n_days);
                let per_day = total / actual_days as f64;
                (0..n_days).map(|d| if d < actual_days { per_day } else { 0.0 }).collect()
            }).collect()
        }
        pub fn liquidity_adjusted_var(&self, portfolio_var: f64) -> f64 { portfolio_var + self.total_liquidation_cost() }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUANTUM DERIVATIVES PRICING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod quantum_derivatives {
    use super::quantum_computing::*;

    pub struct QuantumOptionPricer { pub n_qubits: usize, pub n_paths: usize, rng_state: u64 }
    impl QuantumOptionPricer {
        pub fn new(n_qubits: usize) -> Self { Self { n_qubits, n_paths: 1 << n_qubits, rng_state: 42 } }
        pub fn european_call_amplitude(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let d1 = ((s0 / k).ln() + (r + sigma * sigma / 2.0) * t) / (sigma * t.sqrt());
            let d2 = d1 - sigma * t.sqrt();
            s0 * Self::normal_cdf(d1) - k * (-r * t).exp() * Self::normal_cdf(d2)
        }
        pub fn european_put_amplitude(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let call = self.european_call_amplitude(s0, k, r, sigma, t);
            call - s0 + k * (-r * t).exp()
        }
        pub fn barrier_option_quantum(&mut self, s0: f64, k: f64, barrier: f64, r: f64, sigma: f64, t: f64, is_up: bool, is_knock_in: bool) -> f64 {
            let n_steps = 50;
            let dt = t / n_steps as f64;
            let mut total_payoff = 0.0;
            let mut valid_paths = 0;
            for _ in 0..self.n_paths {
                let mut s = s0;
                let mut knocked = false;
                for _ in 0..n_steps {
                    let z = self.box_muller();
                    s *= ((r - sigma * sigma / 2.0) * dt + sigma * dt.sqrt() * z).exp();
                    if is_up && s >= barrier { knocked = true; }
                    if !is_up && s <= barrier { knocked = true; }
                }
                let active = if is_knock_in { knocked } else { !knocked };
                if active { let payoff = (s - k).max(0.0); total_payoff += payoff; valid_paths += 1; }
            }
            if valid_paths > 0 { total_payoff / valid_paths as f64 * (-r * t).exp() } else { 0.0 }
        }
        pub fn asian_option_quantum(&mut self, s0: f64, k: f64, r: f64, sigma: f64, t: f64, n_averaging: usize) -> f64 {
            let dt = t / n_averaging as f64;
            let mut total_payoff = 0.0;
            for _ in 0..self.n_paths {
                let mut s = s0;
                let mut sum = 0.0;
                for _ in 0..n_averaging {
                    let z = self.box_muller();
                    s *= ((r - sigma * sigma / 2.0) * dt + sigma * dt.sqrt() * z).exp();
                    sum += s;
                }
                let avg = sum / n_averaging as f64;
                total_payoff += (avg - k).max(0.0);
            }
            total_payoff / self.n_paths as f64 * (-r * t).exp()
        }
        pub fn lookback_option_quantum(&mut self, s0: f64, r: f64, sigma: f64, t: f64, n_steps: usize, is_call: bool) -> f64 {
            let dt = t / n_steps as f64;
            let mut total_payoff = 0.0;
            for _ in 0..self.n_paths {
                let mut s = s0;
                let mut max_s = s0;
                let mut min_s = s0;
                for _ in 0..n_steps {
                    let z = self.box_muller();
                    s *= ((r - sigma * sigma / 2.0) * dt + sigma * dt.sqrt() * z).exp();
                    max_s = max_s.max(s);
                    min_s = min_s.min(s);
                }
                let payoff = if is_call { s - min_s } else { max_s - s };
                total_payoff += payoff;
            }
            total_payoff / self.n_paths as f64 * (-r * t).exp()
        }
        fn box_muller(&mut self) -> f64 {
            let u1: f64 = { self.rng_state ^= self.rng_state << 13; self.rng_state ^= self.rng_state >> 7; self.rng_state ^= self.rng_state << 17; (self.rng_state as f64 / u64::MAX as f64).max(1e-10) };
            let u2: f64 = { self.rng_state ^= self.rng_state << 13; self.rng_state ^= self.rng_state >> 7; self.rng_state ^= self.rng_state << 17; self.rng_state as f64 / u64::MAX as f64 };
            (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
        }
        fn normal_cdf(x: f64) -> f64 { 0.5 * (1.0 + Self::erf(x / 2.0_f64.sqrt())) }
        fn erf(x: f64) -> f64 {
            let a1 = 0.254829592; let a2 = -0.284496736; let a3 = 1.421413741; let a4 = -1.453152027; let a5 = 1.061405429; let p = 0.3275911;
            let sign = if x < 0.0 { -1.0 } else { 1.0 };
            let x = x.abs();
            let t = 1.0 / (1.0 + p * x);
            let y = 1.0 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * (-x * x).exp();
            sign * y
        }
    }

    pub struct QuantumGreeks { pub pricer: QuantumOptionPricer }
    impl QuantumGreeks {
        pub fn new(n_qubits: usize) -> Self { Self { pricer: QuantumOptionPricer::new(n_qubits) } }
        pub fn delta(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let eps = s0 * 0.01;
            let p_up = self.pricer.european_call_amplitude(s0 + eps, k, r, sigma, t);
            let p_down = self.pricer.european_call_amplitude(s0 - eps, k, r, sigma, t);
            (p_up - p_down) / (2.0 * eps)
        }
        pub fn gamma(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let eps = s0 * 0.01;
            let p_up = self.pricer.european_call_amplitude(s0 + eps, k, r, sigma, t);
            let p_mid = self.pricer.european_call_amplitude(s0, k, r, sigma, t);
            let p_down = self.pricer.european_call_amplitude(s0 - eps, k, r, sigma, t);
            (p_up - 2.0 * p_mid + p_down) / (eps * eps)
        }
        pub fn vega(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let eps = 0.01;
            let p_up = self.pricer.european_call_amplitude(s0, k, r, sigma + eps, t);
            let p_down = self.pricer.european_call_amplitude(s0, k, r, sigma - eps, t);
            (p_up - p_down) / (2.0 * eps)
        }
        pub fn theta(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let eps = 1.0 / 365.0;
            if t < eps { return 0.0; }
            let p_now = self.pricer.european_call_amplitude(s0, k, r, sigma, t);
            let p_later = self.pricer.european_call_amplitude(s0, k, r, sigma, t - eps);
            (p_later - p_now) / eps
        }
        pub fn rho(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> f64 {
            let eps = 0.0001;
            let p_up = self.pricer.european_call_amplitude(s0, k, r + eps, sigma, t);
            let p_down = self.pricer.european_call_amplitude(s0, k, r - eps, sigma, t);
            (p_up - p_down) / (2.0 * eps)
        }
        pub fn all_greeks(&self, s0: f64, k: f64, r: f64, sigma: f64, t: f64) -> (f64, f64, f64, f64, f64) {
            (self.delta(s0, k, r, sigma, t), self.gamma(s0, k, r, sigma, t), self.vega(s0, k, r, sigma, t), self.theta(s0, k, r, sigma, t), self.rho(s0, k, r, sigma, t))
        }
    }

    pub struct QuantumVolatilitySurface { pub strikes: Vec<f64>, pub maturities: Vec<f64>, pub implied_vols: Vec<Vec<f64>> }
    impl QuantumVolatilitySurface {
        pub fn new() -> Self { Self { strikes: Vec::new(), maturities: Vec::new(), implied_vols: Vec::new() } }
        pub fn from_market_data(strikes: Vec<f64>, maturities: Vec<f64>, market_prices: Vec<Vec<f64>>, s0: f64, r: f64) -> Self {
            let pricer = QuantumOptionPricer::new(8);
            let implied_vols: Vec<Vec<f64>> = maturities.iter().enumerate().map(|(i, &t)| {
                strikes.iter().enumerate().map(|(j, &k)| {
                    let market_price = market_prices[i][j];
                    Self::implied_vol(&pricer, s0, k, r, t, market_price)
                }).collect()
            }).collect();
            Self { strikes, maturities, implied_vols }
        }
        fn implied_vol(pricer: &QuantumOptionPricer, s0: f64, k: f64, r: f64, t: f64, market_price: f64) -> f64 {
            let mut sigma_low = 0.01;
            let mut sigma_high = 2.0;
            for _ in 0..50 {
                let sigma_mid = (sigma_low + sigma_high) / 2.0;
                let price = pricer.european_call_amplitude(s0, k, r, sigma_mid, t);
                if price < market_price { sigma_low = sigma_mid; } else { sigma_high = sigma_mid; }
                if (sigma_high - sigma_low) < 0.0001 { break; }
            }
            (sigma_low + sigma_high) / 2.0
        }
        pub fn interpolate(&self, strike: f64, maturity: f64) -> f64 {
            let k_idx = self.find_index(&self.strikes, strike);
            let t_idx = self.find_index(&self.maturities, maturity);
            if k_idx.0 == k_idx.1 || t_idx.0 == t_idx.1 {
                return self.implied_vols.get(t_idx.0).and_then(|row| row.get(k_idx.0)).copied().unwrap_or(0.2);
            }
            let k_frac = (strike - self.strikes[k_idx.0]) / (self.strikes[k_idx.1] - self.strikes[k_idx.0]);
            let t_frac = (maturity - self.maturities[t_idx.0]) / (self.maturities[t_idx.1] - self.maturities[t_idx.0]);
            let v00 = self.implied_vols[t_idx.0][k_idx.0];
            let v01 = self.implied_vols[t_idx.0][k_idx.1];
            let v10 = self.implied_vols[t_idx.1][k_idx.0];
            let v11 = self.implied_vols[t_idx.1][k_idx.1];
            let v0 = v00 * (1.0 - k_frac) + v01 * k_frac;
            let v1 = v10 * (1.0 - k_frac) + v11 * k_frac;
            v0 * (1.0 - t_frac) + v1 * t_frac
        }
        fn find_index(&self, arr: &[f64], val: f64) -> (usize, usize) {
            if arr.is_empty() { return (0, 0); }
            if val <= arr[0] { return (0, 0); }
            if val >= arr[arr.len() - 1] { return (arr.len() - 1, arr.len() - 1); }
            for i in 0..arr.len() - 1 { if val >= arr[i] && val <= arr[i + 1] { return (i, i + 1); } }
            (0, 0)
        }
        pub fn smile_at_maturity(&self, t_idx: usize) -> Vec<(f64, f64)> {
            self.strikes.iter().zip(self.implied_vols.get(t_idx).unwrap_or(&vec![])).map(|(&k, &v)| (k, v)).collect()
        }
        pub fn term_structure_at_strike(&self, k_idx: usize) -> Vec<(f64, f64)> {
            self.maturities.iter().zip(self.implied_vols.iter().filter_map(|row| row.get(k_idx))).map(|(&t, &v)| (t, v)).collect()
        }
    }

    pub struct QuantumHedger { pub position: f64, pub hedges: Vec<(f64, f64, f64)>, pub greeks_calc: QuantumGreeks }
    impl QuantumHedger {
        pub fn new(position: f64) -> Self { Self { position, hedges: Vec::new(), greeks_calc: QuantumGreeks::new(8) } }
        pub fn add_hedge(&mut self, strike: f64, maturity: f64, quantity: f64) { self.hedges.push((strike, maturity, quantity)); }
        pub fn portfolio_delta(&self, s0: f64, r: f64, sigma: f64) -> f64 {
            let mut total = self.position;
            for &(k, t, q) in &self.hedges { total += q * self.greeks_calc.delta(s0, k, r, sigma, t); }
            total
        }
        pub fn portfolio_gamma(&self, s0: f64, r: f64, sigma: f64) -> f64 {
            let mut total = 0.0;
            for &(k, t, q) in &self.hedges { total += q * self.greeks_calc.gamma(s0, k, r, sigma, t); }
            total
        }
        pub fn portfolio_vega(&self, s0: f64, r: f64, sigma: f64) -> f64 {
            let mut total = 0.0;
            for &(k, t, q) in &self.hedges { total += q * self.greeks_calc.vega(s0, k, r, sigma, t); }
            total
        }
        pub fn delta_neutral_hedge(&self, s0: f64, k: f64, t: f64, r: f64, sigma: f64) -> f64 {
            let current_delta = self.portfolio_delta(s0, r, sigma);
            let option_delta = self.greeks_calc.delta(s0, k, r, sigma, t);
            if option_delta.abs() < 1e-10 { 0.0 } else { -current_delta / option_delta }
        }
        pub fn delta_gamma_neutral_hedge(&self, s0: f64, k1: f64, k2: f64, t: f64, r: f64, sigma: f64) -> (f64, f64) {
            let delta = self.portfolio_delta(s0, r, sigma);
            let gamma = self.portfolio_gamma(s0, r, sigma);
            let d1 = self.greeks_calc.delta(s0, k1, r, sigma, t);
            let g1 = self.greeks_calc.gamma(s0, k1, r, sigma, t);
            let d2 = self.greeks_calc.delta(s0, k2, r, sigma, t);
            let g2 = self.greeks_calc.gamma(s0, k2, r, sigma, t);
            let det = d1 * g2 - d2 * g1;
            if det.abs() < 1e-10 { return (0.0, 0.0); }
            let q1 = (-delta * g2 + gamma * d2) / det;
            let q2 = (delta * g1 - gamma * d1) / det;
            (q1, q2)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIGH FREQUENCY QUANTUM TRADING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod quantum_hft {
    use std::collections::VecDeque;

    pub struct QuantumOrderBook {
        pub bids: VecDeque<(f64, f64)>,
        pub asks: VecDeque<(f64, f64)>,
        pub mid_price: f64,
        pub spread: f64,
        pub imbalance: f64,
    }
    impl QuantumOrderBook {
        pub fn new() -> Self { Self { bids: VecDeque::new(), asks: VecDeque::new(), mid_price: 0.0, spread: 0.0, imbalance: 0.0 } }
        pub fn update(&mut self, bids: Vec<(f64, f64)>, asks: Vec<(f64, f64)>) {
            self.bids = bids.into();
            self.asks = asks.into();
            self.compute_metrics();
        }
        fn compute_metrics(&mut self) {
            let best_bid = self.bids.front().map(|&(p, _)| p).unwrap_or(0.0);
            let best_ask = self.asks.front().map(|&(p, _)| p).unwrap_or(0.0);
            self.mid_price = (best_bid + best_ask) / 2.0;
            self.spread = best_ask - best_bid;
            let bid_vol: f64 = self.bids.iter().take(5).map(|&(_, v)| v).sum();
            let ask_vol: f64 = self.asks.iter().take(5).map(|&(_, v)| v).sum();
            self.imbalance = if bid_vol + ask_vol > 0.0 { (bid_vol - ask_vol) / (bid_vol + ask_vol) } else { 0.0 };
        }
        pub fn depth(&self, levels: usize) -> (f64, f64) {
            let bid_depth: f64 = self.bids.iter().take(levels).map(|&(_, v)| v).sum();
            let ask_depth: f64 = self.asks.iter().take(levels).map(|&(_, v)| v).sum();
            (bid_depth, ask_depth)
        }
        pub fn vwap(&self, side: bool, volume: f64) -> f64 {
            let book = if side { &self.asks } else { &self.bids };
            let mut remaining = volume;
            let mut total_cost = 0.0;
            let mut total_vol = 0.0;
            for &(price, vol) in book {
                let fill = vol.min(remaining);
                total_cost += price * fill;
                total_vol += fill;
                remaining -= fill;
                if remaining <= 0.0 { break; }
            }
            if total_vol > 0.0 { total_cost / total_vol } else { self.mid_price }
        }
        pub fn market_impact_estimate(&self, volume: f64, side: bool) -> f64 {
            let vwap = self.vwap(side, volume);
            (vwap - self.mid_price).abs()
        }
    }

    pub struct QuantumSignal {
        pub prices: VecDeque<f64>,
        pub returns: VecDeque<f64>,
        pub volatility: f64,
        pub momentum: f64,
        pub mean_reversion: f64,
        window_size: usize,
    }
    impl QuantumSignal {
        pub fn new(window_size: usize) -> Self { Self { prices: VecDeque::new(), returns: VecDeque::new(), volatility: 0.0, momentum: 0.0, mean_reversion: 0.0, window_size } }
        pub fn update(&mut self, price: f64) {
            if let Some(&last) = self.prices.back() { let ret = (price / last).ln(); self.returns.push_back(ret); }
            self.prices.push_back(price);
            while self.prices.len() > self.window_size { self.prices.pop_front(); self.returns.pop_front(); }
            self.compute_signals();
        }
        fn compute_signals(&mut self) {
            if self.returns.len() < 2 { return; }
            let mean: f64 = self.returns.iter().sum::<f64>() / self.returns.len() as f64;
            self.volatility = (self.returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / self.returns.len() as f64).sqrt();
            self.momentum = self.returns.iter().rev().take(5).sum::<f64>();
            let price_mean: f64 = self.prices.iter().sum::<f64>() / self.prices.len() as f64;
            let current = *self.prices.back().unwrap_or(&0.0);
            self.mean_reversion = (price_mean - current) / price_mean;
        }
        pub fn alpha(&self) -> f64 { 0.6 * self.momentum.tanh() + 0.4 * self.mean_reversion.tanh() }
        pub fn confidence(&self) -> f64 {
            let vol_factor = (-self.volatility * 10.0).exp();
            let data_factor = (self.returns.len() as f64 / self.window_size as f64).min(1.0);
            vol_factor * data_factor
        }
    }

    pub struct QuantumExecutionAlgo {
        pub target_quantity: f64,
        pub filled_quantity: f64,
        pub urgency: f64,
        pub risk_aversion: f64,
        slices: Vec<f64>,
    }
    impl QuantumExecutionAlgo {
        pub fn new(target: f64, urgency: f64, risk_aversion: f64) -> Self { Self { target_quantity: target, filled_quantity: 0.0, urgency, risk_aversion, slices: Vec::new() } }
        pub fn twap_schedule(&mut self, n_periods: usize) -> Vec<f64> {
            let remaining = self.target_quantity - self.filled_quantity;
            self.slices = vec![remaining / n_periods as f64; n_periods];
            self.slices.clone()
        }
        pub fn vwap_schedule(&mut self, volume_profile: &[f64]) -> Vec<f64> {
            let total_vol: f64 = volume_profile.iter().sum();
            let remaining = self.target_quantity - self.filled_quantity;
            self.slices = volume_profile.iter().map(|&v| remaining * v / total_vol).collect();
            self.slices.clone()
        }
        pub fn almgren_chriss(&mut self, n_periods: usize, sigma: f64, eta: f64, gamma: f64) -> Vec<f64> {
            let remaining = self.target_quantity - self.filled_quantity;
            let kappa = ((self.risk_aversion * sigma * sigma) / (eta * (1.0 + gamma * self.urgency / eta))).sqrt();
            self.slices = (0..n_periods).map(|j| {
                let t = j as f64 / n_periods as f64;
                let t_next = (j + 1) as f64 / n_periods as f64;
                remaining * ((kappa * (1.0 - t)).sinh() - (kappa * (1.0 - t_next)).sinh()) / (kappa * 1.0).sinh()
            }).collect();
            self.slices.clone()
        }
        pub fn adaptive_slice(&self, current_period: usize, market_imbalance: f64, spread: f64, normal_spread: f64) -> f64 {
            let base = self.slices.get(current_period).copied().unwrap_or(0.0);
            let imbalance_adj = if (market_imbalance > 0.0) == (self.target_quantity > 0.0) { 1.2 } else { 0.8 };
            let spread_adj = (normal_spread / spread.max(0.0001)).min(1.5).max(0.5);
            base * imbalance_adj * spread_adj
        }
        pub fn fill(&mut self, quantity: f64) { self.filled_quantity += quantity; }
        pub fn progress(&self) -> f64 { if self.target_quantity.abs() > 1e-10 { self.filled_quantity / self.target_quantity } else { 1.0 } }
        pub fn remaining(&self) -> f64 { self.target_quantity - self.filled_quantity }
    }

    pub struct QuantumMarketMaker {
        pub position: f64,
        pub max_position: f64,
        pub base_spread: f64,
        pub inventory_skew: f64,
        pub orders: Vec<(f64, f64, bool)>,
    }
    impl QuantumMarketMaker {
        pub fn new(max_pos: f64, base_spread: f64) -> Self { Self { position: 0.0, max_position: max_pos, base_spread, inventory_skew: 0.0001, orders: Vec::new() } }
        pub fn compute_quotes(&self, mid: f64, volatility: f64) -> (f64, f64, f64, f64) {
            let inv_ratio = self.position / self.max_position;
            let vol_adj = 1.0 + volatility * 10.0;
            let half_spread = self.base_spread * vol_adj / 2.0;
            let skew = self.inventory_skew * inv_ratio * mid;
            let bid_price = mid - half_spread - skew;
            let ask_price = mid + half_spread - skew;
            let bid_size = self.max_position - self.position;
            let ask_size = self.max_position + self.position;
            (bid_price, bid_size.max(0.0), ask_price, ask_size.max(0.0))
        }
        pub fn avellaneda_stoikov(&self, mid: f64, sigma: f64, gamma: f64, t_remaining: f64) -> (f64, f64) {
            let reservation = mid - gamma * sigma * sigma * t_remaining * self.position;
            let spread = gamma * sigma * sigma * t_remaining + (2.0 / gamma) * (1.0 + gamma / 0.5).ln();
            let bid = reservation - spread / 2.0;
            let ask = reservation + spread / 2.0;
            (bid, ask)
        }
        pub fn update_position(&mut self, fill: f64, is_buy: bool) {
            if is_buy { self.position += fill; } else { self.position -= fill; }
        }
        pub fn pnl(&self, mid: f64, entry_mid: f64) -> f64 { self.position * (mid - entry_mid) }
    }

    pub struct QuantumLatencyArb {
        pub fast_price: f64,
        pub slow_price: f64,
        pub threshold: f64,
        pub position: f64,
        pub pnl: f64,
    }
    impl QuantumLatencyArb {
        pub fn new(threshold: f64) -> Self { Self { fast_price: 0.0, slow_price: 0.0, threshold, position: 0.0, pnl: 0.0 } }
        pub fn update_fast(&mut self, price: f64) { self.fast_price = price; }
        pub fn update_slow(&mut self, price: f64) { self.slow_price = price; }
        pub fn signal(&self) -> i32 {
            let diff = (self.fast_price - self.slow_price) / self.slow_price;
            if diff > self.threshold { 1 }
            else if diff < -self.threshold { -1 }
            else { 0 }
        }
        pub fn execute(&mut self, signal: i32, size: f64, execution_price: f64) {
            let trade = signal as f64 * size;
            self.pnl -= trade * execution_price;
            self.position += trade;
        }
        pub fn mark_to_market(&self, current_price: f64) -> f64 { self.pnl + self.position * current_price }
    }

    pub struct QuantumStatArb {
        pub pairs: Vec<(usize, usize, f64, f64)>,
        pub prices: Vec<Vec<f64>>,
        pub positions: Vec<f64>,
        entry_threshold: f64,
        exit_threshold: f64,
    }
    impl QuantumStatArb {
        pub fn new(n_assets: usize, entry: f64, exit: f64) -> Self {
            Self { pairs: Vec::new(), prices: vec![Vec::new(); n_assets], positions: vec![0.0; n_assets], entry_threshold: entry, exit_threshold: exit }
        }
        pub fn update_price(&mut self, asset: usize, price: f64) { self.prices[asset].push(price); }
        pub fn find_pairs(&mut self, lookback: usize) {
            self.pairs.clear();
            let n = self.prices.len();
            for i in 0..n { for j in (i + 1)..n {
                if self.prices[i].len() < lookback || self.prices[j].len() < lookback { continue; }
                let pi: Vec<f64> = self.prices[i].iter().rev().take(lookback).cloned().collect();
                let pj: Vec<f64> = self.prices[j].iter().rev().take(lookback).cloned().collect();
                let (beta, r_sq) = self.ols_regression(&pi, &pj);
                if r_sq > 0.8 {
                    let spread: Vec<f64> = pi.iter().zip(&pj).map(|(&a, &b)| a - beta * b).collect();
                    let mean: f64 = spread.iter().sum::<f64>() / spread.len() as f64;
                    let std = (spread.iter().map(|s| (s - mean).powi(2)).sum::<f64>() / spread.len() as f64).sqrt();
                    self.pairs.push((i, j, beta, std));
                }
            }}
        }
        fn ols_regression(&self, x: &[f64], y: &[f64]) -> (f64, f64) {
            let n = x.len() as f64;
            let sum_x: f64 = x.iter().sum();
            let sum_y: f64 = y.iter().sum();
            let sum_xy: f64 = x.iter().zip(y).map(|(&a, &b)| a * b).sum();
            let sum_x2: f64 = x.iter().map(|&a| a * a).sum();
            let sum_y2: f64 = y.iter().map(|&b| b * b).sum();
            let beta = (n * sum_xy - sum_x * sum_y) / (n * sum_x2 - sum_x * sum_x);
            let ss_tot = sum_y2 - sum_y * sum_y / n;
            let y_pred: Vec<f64> = x.iter().map(|&xi| beta * xi).collect();
            let ss_res: f64 = y.iter().zip(&y_pred).map(|(&yi, &yp)| (yi - yp).powi(2)).sum();
            let r_sq = if ss_tot > 0.0 { 1.0 - ss_res / ss_tot } else { 0.0 };
            (beta, r_sq)
        }
        pub fn signals(&self) -> Vec<(usize, usize, f64)> {
            let mut sigs = Vec::new();
            for &(i, j, beta, std) in &self.pairs {
                let pi = self.prices[i].last().copied().unwrap_or(0.0);
                let pj = self.prices[j].last().copied().unwrap_or(0.0);
                let spread = pi - beta * pj;
                let z = spread / std.max(1e-10);
                if z.abs() > self.entry_threshold && self.positions[i].abs() < 1e-10 {
                    sigs.push((i, j, -z.signum()));
                } else if z.abs() < self.exit_threshold && self.positions[i].abs() > 1e-10 {
                    sigs.push((i, j, 0.0));
                }
            }
            sigs
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_market_tensor() {
        let tensor = MarketTensor::new(100, 5, 10, 4);
        assert_eq!(tensor.shape, [100, 5, 10, 4]);
    }

    #[test]
    fn test_financial_schrodinger() {
        let mut fs = FinancialSchrodinger::new(100.0, 0.2, 100);

        let initial_expected = fs.expected_price();
        assert!((initial_expected - 100.0).abs() < 1.0);

        fs.evolve(10);

        let dist = fs.probability_distribution();
        let total_prob: f64 = dist.iter().map(|(_, p)| p).sum();
        assert!((total_prob - 1.0).abs() < 0.01);
    }

    #[test]
    fn test_indicators() {
        let data: Vec<f64> = (0..100).map(|i| 100.0 + (i as f64 * 0.1).sin() * 10.0).collect();

        let sma = indicators::sma(&data, 20);
        assert_eq!(sma.len(), data.len() - 19);

        let ema = indicators::ema(&data, 20);
        assert_eq!(ema.len(), data.len());

        let rsi = indicators::rsi(&data, 14);
        assert!(!rsi.is_empty());
        for &r in &rsi {
            assert!(r >= 0.0 && r <= 100.0);
        }
    }

    #[test]
    fn test_risk_metrics() {
        let returns: Vec<f64> = vec![0.01, -0.02, 0.015, -0.005, 0.02, -0.01, 0.005];

        let sharpe = risk::sharpe_ratio(&returns, 0.02);
        assert!(!sharpe.is_nan());

        let var = risk::var_parametric(&returns, 0.95);
        assert!(!var.is_nan());
    }

    #[test]
    fn test_order_manager() {
        let mut om = oms::OrderManager::new();

        let order = Order {
            id: String::new(),
            symbol: "AAPL".to_string(),
            side: Side::Buy,
            order_type: OrderType::Limit,
            quantity: 100.0,
            limit_price: Some(150.0),
            stop_price: None,
            time_in_force: TimeInForce::Day,
            status: OrderStatus::Pending,
            filled_quantity: 0.0,
            average_fill_price: 0.0,
            created_at: DateTime::now(),
            updated_at: DateTime::now(),
        };

        let result = om.submit(order, 150.0);
        assert!(result.is_ok());

        let id = result.unwrap();
        assert!(om.get_order(&id).is_some());
    }

    #[test]
    fn test_paper_broker() {
        let mut broker = broker::PaperBroker::new(100000.0);

        let order = Order {
            id: String::new(),
            symbol: "AAPL".to_string(),
            side: Side::Buy,
            order_type: OrderType::Market,
            quantity: 10.0,
            limit_price: None,
            stop_price: None,
            time_in_force: TimeInForce::Day,
            status: OrderStatus::Pending,
            filled_quantity: 0.0,
            average_fill_price: 0.0,
            created_at: DateTime::now(),
            updated_at: DateTime::now(),
        };

        let order_id = broker.submit_order(&order).unwrap();
        let trade = broker.simulate_execution(&order_id, 150.0);

        assert!(trade.is_some());
        assert!(broker.positions.contains_key("AAPL"));
    }

    #[test]
    fn test_backtester() {
        let mut bt = backtest::Backtester::new(100000.0);
        bt.data_manager.generate_synthetic("TEST", 252, 0.20);

        let mut strategy = MomentumStrategy::new();
        let result = bt.run(
            &mut strategy,
            &["TEST"],
            DateTime::from_timestamp(1609459200),
            DateTime::from_timestamp(1640995200),
        );

        assert!(result.final_equity > 0.0);
        assert!(!result.sharpe_ratio.is_nan());
    }

    #[test]
    fn test_portfolio_optimizer() {
        let returns = vec![
            vec![0.01, -0.02, 0.015, -0.005, 0.02],
            vec![0.005, 0.01, -0.01, 0.015, -0.02],
            vec![-0.01, 0.02, 0.005, -0.015, 0.01],
        ];
        let symbols = vec!["A".to_string(), "B".to_string(), "C".to_string()];

        let opt = portfolio::MeanVarianceOptimizer::new(symbols, returns);
        let weights = opt.optimize_min_variance();

        assert_eq!(weights.len(), 3);
        let sum: f64 = weights.iter().sum();
        assert!((sum - 1.0).abs() < 0.01);
    }

    #[test]
    fn test_drawdown_analyzer() {
        let equity = vec![100.0, 105.0, 102.0, 98.0, 95.0, 100.0, 108.0, 106.0, 110.0];
        let analyzer = analytics::DrawdownAnalyzer::new(equity);

        let periods = analyzer.drawdown_periods();
        let underwater = analyzer.underwater_curve();

        assert!(!underwater.is_empty());
        assert!(underwater.iter().all(|&u| u <= 0.0));
    }
}
