    /// Paper trading broker for testing
    pub struct PaperBroker {
        pub account: AccountInfo,
        pub positions: HashMap<String, Position>,
        pub orders: HashMap<String, Order>,
        pub trades: Vec<Trade>,
        pub next_order_id: u64,
        pub latency_ms: u64,
        pub slippage_bps: f64,
        pub commission_per_share: f64,
    }

    impl PaperBroker {
        pub fn new(initial_capital: f64) -> Self {
            PaperBroker {
                account: AccountInfo {
                    account_id: "PAPER-001".to_string(),
                    account_type: AccountType::Paper,
                    currency: "USD".to_string(),
                    buying_power: initial_capital * 4.0, // 4x margin
                    cash: initial_capital,
                    portfolio_value: initial_capital,
                    equity: initial_capital,
                    margin_used: 0.0,
                    margin_available: initial_capital * 4.0,
                    day_trades_remaining: None,
                    pattern_day_trader: false,
                },
                positions: HashMap::new(),
                orders: HashMap::new(),
                trades: Vec::new(),
                next_order_id: 1,
                latency_ms: 50,
                slippage_bps: 5.0,
                commission_per_share: 0.005,
            }
        }

        /// Simulate order execution
        pub fn simulate_execution(&mut self, order_id: &str, market_price: f64) -> Option<Trade> {
            if let Some(order) = self.orders.get_mut(order_id) {
                if order.status != OrderStatus::Submitted {
                    return None;
                }

                // Apply slippage
                let slippage = market_price * self.slippage_bps / 10000.0;
                let exec_price = match order.side {
                    Side::Buy => market_price + slippage,
                    Side::Sell => market_price - slippage,
                };

                // Check limit price
                if let Some(limit) = order.limit_price {
                    match order.side {
                        Side::Buy if exec_price > limit => return None,
                        Side::Sell if exec_price < limit => return None,
                        _ => {}
                    }
                }

                // Calculate commission
                let commission = order.quantity * self.commission_per_share;

                // Create trade
                let trade = Trade {
                    id: format!("TRD-{}", self.trades.len() + 1),
                    order_id: order_id.to_string(),
                    symbol: order.symbol.clone(),
                    side: order.side,
                    quantity: order.quantity,
                    price: exec_price,
                    commission,
                    timestamp: DateTime::now(),
                };

                // Update order
                order.status = OrderStatus::Filled;
                order.filled_quantity = order.quantity;
                order.average_fill_price = exec_price;

                // Update position
                let pos = self.positions
                    .entry(order.symbol.clone())
                    .or_insert(Position::new(&order.symbol));

                match order.side {
                    Side::Buy => {
                        let new_cost = pos.quantity * pos.average_cost + order.quantity * exec_price;
                        pos.quantity += order.quantity;
                        pos.average_cost = if pos.quantity > 0.0 { new_cost / pos.quantity } else { 0.0 };
                    }
                    Side::Sell => {
                        let realized = (exec_price - pos.average_cost) * order.quantity;
                        pos.realized_pnl += realized;
                        pos.quantity -= order.quantity;
                    }
                }

                // Update account
                let notional = order.quantity * exec_price;
                match order.side {
                    Side::Buy => {
                        self.account.cash -= notional + commission;
                        self.account.margin_used += notional / 4.0;
                    }
                    Side::Sell => {
                        self.account.cash += notional - commission;
                        self.account.margin_used -= notional / 4.0;
                    }
                }

                self.trades.push(trade.clone());
                Some(trade)
            } else {
                None
            }
        }

        /// Update account value with current prices
        pub fn mark_to_market(&mut self, prices: &HashMap<String, f64>) {
            let mut portfolio_value = self.account.cash;

            for (symbol, pos) in &mut self.positions {
                if let Some(&price) = prices.get(symbol) {
                    pos.update_market_price(price);
                    portfolio_value += pos.market_value;
                }
            }

            self.account.portfolio_value = portfolio_value;
            self.account.equity = portfolio_value;
            self.account.buying_power = (portfolio_value - self.account.margin_used) * 4.0;
            self.account.margin_available = self.account.buying_power;
        }
    }

    impl BrokerApi for PaperBroker {
        fn name(&self) -> &str { "Paper" }

        fn connect(&mut self) -> Result<(), String> { Ok(()) }
        fn disconnect(&mut self) {}
        fn status(&self) -> ConnectionStatus { ConnectionStatus::Authenticated }

        fn account_info(&self) -> Result<AccountInfo, String> {
            Ok(self.account.clone())
        }

        fn positions(&self) -> Result<Vec<Position>, String> {
            Ok(self.positions.values().cloned().collect())
        }

        fn submit_order(&mut self, order: &Order) -> Result<String, String> {
            let id = if order.id.is_empty() {
                let id = format!("PAPER-{:08}", self.next_order_id);
                self.next_order_id += 1;
                id
            } else {
                order.id.clone()
            };

            let mut new_order = order.clone();
            new_order.id = id.clone();
            new_order.status = OrderStatus::Submitted;
            self.orders.insert(id.clone(), new_order);

            Ok(id)
        }

        fn cancel_order(&mut self, order_id: &str) -> Result<(), String> {
            if let Some(order) = self.orders.get_mut(order_id) {
                order.status = OrderStatus::Cancelled;
                Ok(())
            } else {
                Err("Order not found".to_string())
            }
        }

        fn get_order(&self, order_id: &str) -> Result<Order, String> {
            self.orders.get(order_id).cloned().ok_or("Order not found".to_string())
        }

        fn market_data(&self, symbol: &str) -> Result<Quote, String> {
            Ok(Quote {
                timestamp: DateTime::now(),
                bid: 100.0,
                ask: 100.01,
                bid_size: 1000.0,
                ask_size: 1000.0,
            })
        }

        fn historical_data(&self, symbol: &str, start: DateTime, end: DateTime, timeframe: &str) -> Result<Vec<Candle>, String> {
            Ok(Vec::new())
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BACKTESTING FRAMEWORK
// ═══════════════════════════════════════════════════════════════════════════════

pub mod backtest {
    use super::*;

    /// Market data point for backtesting
    #[derive(Debug, Clone)]
    pub struct MarketDataPoint {
        pub timestamp: DateTime,
        pub symbol: String,
        pub data: MarketDataType,
    }

    #[derive(Debug, Clone)]
    pub enum MarketDataType {
        Trade { price: f64, size: f64 },
        Quote { bid: f64, ask: f64, bid_size: f64, ask_size: f64 },
        Bar(Candle),
    }

    /// Historical data manager
    pub struct DataManager {
        pub data: HashMap<String, Vec<Candle>>,
        pub cache_dir: String,
    }

    impl DataManager {
        pub fn new(cache_dir: &str) -> Self {
            DataManager {
                data: HashMap::new(),
                cache_dir: cache_dir.to_string(),
            }
        }

        /// Load data from CSV
        pub fn load_csv(&mut self, symbol: &str, path: &str) -> Result<(), String> {
            // CSV parsing would go here
            Ok(())
        }

        /// Generate synthetic data for testing
        pub fn generate_synthetic(&mut self, symbol: &str, days: usize, volatility: f64) {
            let mut candles = Vec::with_capacity(days);
            let mut price = 100.0;
            let dt = 86400.0; // 1 day in seconds

            for i in 0..days {
                let drift = 0.0001; // Small positive drift
                let rand = (i as f64 * 0.618).sin() * 2.0 - 1.0; // Pseudo-random
                let change = drift + volatility * rand * sqrt(dt / 252.0);

                price *= 1.0 + change;

                let open = price * (1.0 + rand * 0.001);
                let high = price * (1.0 + rand.abs() * 0.01);
                let low = price * (1.0 - rand.abs() * 0.01);
                let volume = 1000000.0 * (1.0 + rand * 0.5);

                candles.push(Candle {
                    timestamp: DateTime::from_timestamp(1609459200 + i as i64 * 86400),
                    open,
                    high,
                    low,
                    close: price,
                    volume,
                });
            }

            self.data.insert(symbol.to_string(), candles);
        }

        /// Get data for symbol
        pub fn get(&self, symbol: &str) -> Option<&Vec<Candle>> {
            self.data.get(symbol)
        }

        /// Get slice of data
        pub fn get_range(&self, symbol: &str, start: DateTime, end: DateTime) -> Vec<Candle> {
            self.data.get(symbol)
                .map(|candles| {
                    candles.iter()
                        .filter(|c| c.timestamp >= start && c.timestamp <= end)
                        .cloned()
                        .collect()
                })
                .unwrap_or_default()
        }
    }

    /// Backtest event
    #[derive(Debug, Clone)]
    pub enum BacktestEvent {
        MarketData(MarketDataPoint),
        OrderSubmitted(Order),
        OrderFilled(Trade),
        OrderCancelled(String),
        PositionUpdate(Position),
        DayEnd { date: DateTime, equity: f64, positions: Vec<Position> },
    }

    /// Event-driven backtester
    pub struct Backtester {
        pub data_manager: DataManager,
        pub initial_capital: f64,
        pub commission: f64,
        pub slippage_bps: f64,
        pub events: Vec<BacktestEvent>,
    }

    impl Backtester {
        pub fn new(initial_capital: f64) -> Self {
            Backtester {
                data_manager: DataManager::new("./data"),
                initial_capital,
                commission: 0.001, // 0.1%
                slippage_bps: 5.0,
                events: Vec::new(),
            }
        }

        /// Run backtest with strategy
        pub fn run(&mut self, strategy: &mut dyn Strategy, symbols: &[&str], start: DateTime, end: DateTime) -> BacktestResult {
            let mut equity = self.initial_capital;
            let mut cash = self.initial_capital;
            let mut positions: HashMap<String, Position> = HashMap::new();
            let mut trades: Vec<Trade> = Vec::new();
            let mut equity_curve: Vec<f64> = vec![equity];
            let mut returns: Vec<f64> = Vec::new();

            // Combine and sort all candles
            let mut all_candles: Vec<(String, Candle)> = Vec::new();
            for symbol in symbols {
                if let Some(candles) = self.data_manager.get(symbol) {
                    for candle in candles {
                        if candle.timestamp >= start && candle.timestamp <= end {
                            all_candles.push((symbol.to_string(), candle.clone()));
                        }
                    }
                }
            }
            all_candles.sort_by(|a, b| a.1.timestamp.cmp(&b.1.timestamp));

            // Build lookback window per symbol
            let mut windows: HashMap<String, Vec<Candle>> = HashMap::new();
            let lookback = 100;

            for (symbol, candle) in &all_candles {
                let window = windows.entry(symbol.clone()).or_insert(Vec::new());
                window.push(candle.clone());
                if window.len() > lookback {
                    window.remove(0);
                }

                // Update position market value
                if let Some(pos) = positions.get_mut(symbol) {
                    pos.update_market_price(candle.close);
                }

                // Generate signals
                let signals = strategy.generate_signals(window);

                for signal in signals {
                    // Determine position size
                    let target_size = equity * 0.02 / candle.close; // 2% risk

                    let current_qty = positions.get(symbol).map(|p| p.quantity).unwrap_or(0.0);

                    let order_qty = match signal.side {
                        Side::Buy if current_qty <= 0.0 => target_size - current_qty,
                        Side::Sell if current_qty >= 0.0 => current_qty + target_size,
                        _ => 0.0,
                    };

                    if order_qty.abs() < 0.01 {
                        continue;
                    }

                    // Simulate execution
                    let slippage = candle.close * self.slippage_bps / 10000.0;
                    let exec_price = match signal.side {
                        Side::Buy => candle.close + slippage,
                        Side::Sell => candle.close - slippage,
                    };

                    let commission = order_qty.abs() * exec_price * self.commission;

                    let trade = Trade {
                        id: format!("BT-{}", trades.len()),
                        order_id: String::new(),
                        symbol: symbol.clone(),
                        side: signal.side,
                        quantity: order_qty.abs(),
                        price: exec_price,
                        commission,
                        timestamp: candle.timestamp,
                    };

                    // Update position
                    let pos = positions.entry(symbol.clone()).or_insert(Position::new(symbol));
                    match signal.side {
                        Side::Buy => {
                            let cost = pos.quantity * pos.average_cost + order_qty * exec_price;
                            pos.quantity += order_qty;
                            pos.average_cost = if pos.quantity > 0.0 { cost / pos.quantity } else { 0.0 };
                            cash -= order_qty * exec_price + commission;
                        }
                        Side::Sell => {
                            let realized = (exec_price - pos.average_cost) * order_qty.abs();
                            pos.realized_pnl += realized;
                            pos.quantity -= order_qty.abs();
                            cash += order_qty.abs() * exec_price - commission;
                        }
                    }

                    trades.push(trade);
                }

                // Calculate equity
                let position_value: f64 = positions.values()
                    .map(|p| p.quantity * candle.close)
                    .sum();
                let new_equity = cash + position_value;

                if new_equity != equity {
                    returns.push((new_equity - equity) / equity);
                }
                equity = new_equity;
                equity_curve.push(equity);
            }

            // Calculate performance metrics
            BacktestResult {
                initial_capital: self.initial_capital,
                final_equity: equity,
                total_return: (equity - self.initial_capital) / self.initial_capital,
                num_trades: trades.len(),
                winning_trades: trades.iter()
                    .filter(|t| {
                        positions.get(&t.symbol)
                            .map(|p| p.realized_pnl > 0.0)
                            .unwrap_or(false)
                    })
                    .count(),
                sharpe_ratio: risk::sharpe_ratio(&returns, 0.02),
                sortino_ratio: risk::sortino_ratio(&returns, 0.02),
                max_drawdown: risk::max_drawdown(&equity_curve).0,
                var_95: risk::var_parametric(&returns, 0.95),
                cvar_95: risk::expected_shortfall(&returns, 0.95),
                equity_curve,
                trades,
                final_positions: positions.into_values().collect(),
            }
        }
    }

    /// Backtest results
    #[derive(Debug, Clone)]
    pub struct BacktestResult {
        pub initial_capital: f64,
        pub final_equity: f64,
        pub total_return: f64,
        pub num_trades: usize,
        pub winning_trades: usize,
        pub sharpe_ratio: f64,
        pub sortino_ratio: f64,
        pub max_drawdown: f64,
        pub var_95: f64,
        pub cvar_95: f64,
        pub equity_curve: Vec<f64>,
        pub trades: Vec<Trade>,
        pub final_positions: Vec<Position>,
    }

    impl BacktestResult {
        pub fn win_rate(&self) -> f64 {
            if self.num_trades > 0 {
                self.winning_trades as f64 / self.num_trades as f64
            } else {
                0.0
            }
        }

        pub fn profit_factor(&self) -> f64 {
            let gross_profit: f64 = self.trades.iter()
                .filter(|t| t.price > 0.0) // Simplified - would need proper P&L tracking
                .map(|t| t.quantity * t.price)
                .sum();
            let gross_loss: f64 = self.trades.iter()
                .filter(|t| t.price < 0.0)
                .map(|t| (t.quantity * t.price).abs())
                .sum();

            if gross_loss > 0.0 {
                gross_profit / gross_loss
            } else {
                f64::INFINITY
            }
        }

        pub fn calmar_ratio(&self) -> f64 {
            if self.max_drawdown > 0.0 {
                self.total_return / self.max_drawdown
            } else {
                f64::INFINITY
            }
        }

        /// Generate performance report
        pub fn report(&self) -> String {
            format!(r#"
═══════════════════════════════════════════════════════════════════════════════
BACKTEST PERFORMANCE REPORT
═══════════════════════════════════════════════════════════════════════════════

RETURNS
  Initial Capital:     ${:.2}
  Final Equity:        ${:.2}
  Total Return:        {:.2}%

RISK METRICS
  Sharpe Ratio:        {:.2}
  Sortino Ratio:       {:.2}
  Max Drawdown:        {:.2}%
  VaR (95%):           {:.2}%
  CVaR (95%):          {:.2}%
  Calmar Ratio:        {:.2}

TRADING STATISTICS
  Total Trades:        {}
  Winning Trades:      {}
  Win Rate:            {:.1}%
  Profit Factor:       {:.2}

═══════════════════════════════════════════════════════════════════════════════
"#,
                self.initial_capital,
                self.final_equity,
                self.total_return * 100.0,
                self.sharpe_ratio,
                self.sortino_ratio,
                self.max_drawdown * 100.0,
                self.var_95 * 100.0,
                self.cvar_95 * 100.0,
                self.calmar_ratio(),
                self.num_trades,
                self.winning_trades,
                self.win_rate() * 100.0,
                self.profit_factor(),
            )
        }
    }

    /// Walk-forward optimization
    pub struct WalkForwardOptimizer {
        pub in_sample_ratio: f64,
        pub num_splits: usize,
    }

    impl WalkForwardOptimizer {
        pub fn new(in_sample_ratio: f64, num_splits: usize) -> Self {
            WalkForwardOptimizer { in_sample_ratio, num_splits }
        }

        /// Generate time splits
        pub fn generate_splits(&self, start: DateTime, end: DateTime) -> Vec<(DateTime, DateTime, DateTime)> {
            let total_seconds = end.timestamp() - start.timestamp();
            let split_size = total_seconds / self.num_splits as i64;
            let in_sample_size = (split_size as f64 * self.in_sample_ratio) as i64;

            (0..self.num_splits)
                .map(|i| {
                    let split_start = DateTime::from_timestamp(start.timestamp() + i as i64 * split_size);
                    let in_sample_end = DateTime::from_timestamp(split_start.timestamp() + in_sample_size);
                    let split_end = DateTime::from_timestamp(split_start.timestamp() + split_size);
                    (split_start, in_sample_end, split_end)
                })
                .collect()
        }
    }

    /// Monte Carlo simulator for strategy robustness
    pub struct MonteCarloSimulator {
        pub num_simulations: usize,
    }

    impl MonteCarloSimulator {
        pub fn new(num_simulations: usize) -> Self {
            MonteCarloSimulator { num_simulations }
        }

        /// Run Monte Carlo simulation by shuffling trade order
        pub fn simulate_trades(&self, trades: &[Trade], initial_capital: f64) -> MonteCarloResult {
            let mut results: Vec<f64> = Vec::with_capacity(self.num_simulations);
            let mut max_drawdowns: Vec<f64> = Vec::with_capacity(self.num_simulations);

            for sim in 0..self.num_simulations {
                // Simple shuffle using simulation number as seed
                let mut shuffled = trades.to_vec();
                for i in 0..shuffled.len() {
                    let j = (i * 7919 + sim) % shuffled.len(); // Pseudo-random swap
                    shuffled.swap(i, j);
                }

                // Calculate equity curve
                let mut equity = initial_capital;
                let mut peak = equity;
                let mut max_dd = 0.0;

                for trade in &shuffled {
                    let pnl = match trade.side {
                        Side::Buy => trade.quantity * trade.price * 0.02, // Simplified
                        Side::Sell => -trade.quantity * trade.price * 0.02,
                    };
                    equity += pnl - trade.commission;

                    if equity > peak {
                        peak = equity;
                    }
                    let dd = (peak - equity) / peak;
                    if dd > max_dd {
                        max_dd = dd;
                    }
                }

                results.push((equity - initial_capital) / initial_capital);
                max_drawdowns.push(max_dd);
            }

            results.sort_by(|a, b| a.partial_cmp(b).unwrap());
            max_drawdowns.sort_by(|a, b| a.partial_cmp(b).unwrap());

            MonteCarloResult {
                num_simulations: self.num_simulations,
                mean_return: results.iter().sum::<f64>() / results.len() as f64,
                median_return: results[results.len() / 2],
                percentile_5: results[(results.len() as f64 * 0.05) as usize],
                percentile_95: results[(results.len() as f64 * 0.95) as usize],
                mean_max_drawdown: max_drawdowns.iter().sum::<f64>() / max_drawdowns.len() as f64,
                worst_drawdown: *max_drawdowns.last().unwrap_or(&0.0),
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct MonteCarloResult {
        pub num_simulations: usize,
        pub mean_return: f64,
        pub median_return: f64,
        pub percentile_5: f64,
        pub percentile_95: f64,
        pub mean_max_drawdown: f64,
        pub worst_drawdown: f64,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PORTFOLIO OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod portfolio {
    use super::*;

    /// Portfolio optimization objective
    #[derive(Debug, Clone, Copy)]
    pub enum OptimizationObjective {
        MaxSharpe,
        MinVariance,
        MaxReturn,
        RiskParity,
        MaxDiversification,
    }

    /// Portfolio constraints
    #[derive(Debug, Clone)]
    pub struct PortfolioConstraints {
        pub min_weight: f64,
        pub max_weight: f64,
        pub max_sector_exposure: Option<HashMap<String, f64>>,
        pub min_assets: usize,
        pub max_assets: usize,
        pub long_only: bool,
    }

    impl Default for PortfolioConstraints {
        fn default() -> Self {
            PortfolioConstraints {
                min_weight: 0.0,
                max_weight: 0.40,
                max_sector_exposure: None,
                min_assets: 3,
                max_assets: 20,
                long_only: true,
            }
        }
    }

    /// Mean-Variance optimizer
    pub struct MeanVarianceOptimizer {
        pub returns: Vec<Vec<f64>>,  // [asset][time]
        pub symbols: Vec<String>,
        pub constraints: PortfolioConstraints,
    }

    impl MeanVarianceOptimizer {
        pub fn new(symbols: Vec<String>, returns: Vec<Vec<f64>>) -> Self {
            MeanVarianceOptimizer {
                returns,
                symbols,
                constraints: PortfolioConstraints::default(),
            }
        }

        /// Calculate mean returns
        pub fn mean_returns(&self) -> Vec<f64> {
            self.returns.iter()
                .map(|r| r.iter().sum::<f64>() / r.len() as f64)
                .collect()
        }

        /// Calculate covariance matrix
        pub fn covariance_matrix(&self) -> Vec<Vec<f64>> {
            let n = self.returns.len();
            let means = self.mean_returns();
            let t = self.returns[0].len() as f64;

            let mut cov = vec![vec![0.0; n]; n];

            for i in 0..n {
                for j in 0..n {
                    let mut sum = 0.0;
                    for k in 0..self.returns[0].len() {
                        sum += (self.returns[i][k] - means[i]) * (self.returns[j][k] - means[j]);
                    }
                    cov[i][j] = sum / (t - 1.0);
                }
            }

            cov
        }

        /// Calculate portfolio variance
        pub fn portfolio_variance(&self, weights: &[f64]) -> f64 {
            let cov = self.covariance_matrix();
            let n = weights.len();

            let mut variance = 0.0;
            for i in 0..n {
                for j in 0..n {
                    variance += weights[i] * weights[j] * cov[i][j];
                }
            }
            variance
        }

        /// Calculate portfolio return
        pub fn portfolio_return(&self, weights: &[f64]) -> f64 {
            let means = self.mean_returns();
            weights.iter().zip(means.iter()).map(|(w, r)| w * r).sum()
        }

        /// Calculate Sharpe ratio
        pub fn sharpe_ratio(&self, weights: &[f64], risk_free_rate: f64) -> f64 {
            let ret = self.portfolio_return(weights);
            let vol = sqrt(self.portfolio_variance(weights));
            if vol > 0.0 {
                (ret - risk_free_rate / 252.0) / vol * sqrt(252.0)
            } else {
                0.0
            }
        }

        /// Optimize for minimum variance (analytical solution)
        pub fn optimize_min_variance(&self) -> Vec<f64> {
            let cov = self.covariance_matrix();
            let n = self.symbols.len();

            // Simplified: equal weight as starting point
            // Full implementation would use quadratic programming
            let mut weights = vec![1.0 / n as f64; n];

            // Apply constraints
            for w in &mut weights {
                *w = w.max(self.constraints.min_weight).min(self.constraints.max_weight);
            }

            // Renormalize
            let sum: f64 = weights.iter().sum();
            for w in &mut weights {
                *w /= sum;
            }

            weights
        }

        /// Optimize using gradient descent
        pub fn optimize(&self, objective: OptimizationObjective, learning_rate: f64, iterations: usize) -> Vec<f64> {
            let n = self.symbols.len();
            let mut weights = vec![1.0 / n as f64; n];

            for _ in 0..iterations {
                // Calculate gradient (numerical)
                let eps = 1e-6;
                let mut gradient = vec![0.0; n];

                let current_obj = self.objective_value(&weights, objective);

                for i in 0..n {
                    weights[i] += eps;
                    let new_obj = self.objective_value(&weights, objective);
                    gradient[i] = (new_obj - current_obj) / eps;
                    weights[i] -= eps;
                }

                // Update weights
                for i in 0..n {
                    weights[i] += learning_rate * gradient[i];
                }

                // Project to constraints
                self.project_constraints(&mut weights);
            }

            weights
        }

        fn objective_value(&self, weights: &[f64], objective: OptimizationObjective) -> f64 {
            match objective {
                OptimizationObjective::MaxSharpe => self.sharpe_ratio(weights, 0.02),
                OptimizationObjective::MinVariance => -self.portfolio_variance(weights),
                OptimizationObjective::MaxReturn => self.portfolio_return(weights),
                OptimizationObjective::RiskParity => {
                    // Equal risk contribution
                    let vol = sqrt(self.portfolio_variance(weights));
                    let n = weights.len();
                    let target_contrib = vol / n as f64;

                    let cov = self.covariance_matrix();
                    let mut sum_sq_diff = 0.0;

                    for i in 0..n {
                        let mut marginal = 0.0;
                        for j in 0..n {
                            marginal += weights[j] * cov[i][j];
                        }
                        let contrib = weights[i] * marginal / vol;
                        sum_sq_diff += (contrib - target_contrib).powi(2);
                    }

                    -sum_sq_diff // Minimize
                }
                OptimizationObjective::MaxDiversification => {
                    let vol = sqrt(self.portfolio_variance(weights));
                    let cov = self.covariance_matrix();

                    let weighted_avg_vol: f64 = weights.iter()
                        .enumerate()
                        .map(|(i, &w)| w * sqrt(cov[i][i]))
                        .sum();

                    weighted_avg_vol / vol // Diversification ratio
                }
            }
        }

        fn project_constraints(&self, weights: &mut Vec<f64>) {
            // Apply bounds
            for w in weights.iter_mut() {
                if self.constraints.long_only {
                    *w = w.max(0.0);
                }
                *w = w.max(self.constraints.min_weight).min(self.constraints.max_weight);
            }

            // Renormalize to sum to 1
            let sum: f64 = weights.iter().sum();
            if sum > 0.0 {
                for w in weights.iter_mut() {
                    *w /= sum;
                }
            }
        }

        /// Efficient frontier calculation
        pub fn efficient_frontier(&self, num_points: usize) -> Vec<(f64, f64, Vec<f64>)> {
            let mut frontier = Vec::with_capacity(num_points);

            // Get min/max return portfolios
            let min_var_weights = self.optimize_min_variance();
            let min_ret = self.portfolio_return(&min_var_weights);

            let max_ret_weights = self.optimize(OptimizationObjective::MaxReturn, 0.01, 100);
            let max_ret = self.portfolio_return(&max_ret_weights);

            // Generate points along the frontier
            for i in 0..num_points {
                let target_ret = min_ret + (max_ret - min_ret) * (i as f64) / (num_points as f64 - 1.0);

                // Simplified: interpolate weights
                let alpha = (target_ret - min_ret) / (max_ret - min_ret);
                let weights: Vec<f64> = min_var_weights.iter()
                    .zip(max_ret_weights.iter())
                    .map(|(&w1, &w2)| w1 * (1.0 - alpha) + w2 * alpha)
                    .collect();

                let ret = self.portfolio_return(&weights);
                let vol = sqrt(self.portfolio_variance(&weights));

                frontier.push((ret, vol, weights));
            }

            frontier
        }
    }

    /// Black-Litterman model
    pub struct BlackLitterman {
        pub market_weights: Vec<f64>,
        pub covariance: Vec<Vec<f64>>,
        pub risk_aversion: f64,
        pub tau: f64,
        pub views: Vec<View>,
    }

    #[derive(Debug, Clone)]
    pub struct View {
        pub assets: Vec<(usize, f64)>, // (asset_index, weight)
        pub expected_return: f64,
        pub confidence: f64,
    }

    impl BlackLitterman {
        pub fn new(market_weights: Vec<f64>, covariance: Vec<Vec<f64>>) -> Self {
            BlackLitterman {
                market_weights,
                covariance,
                risk_aversion: 2.5,
                tau: 0.05,
                views: Vec::new(),
            }
        }

        pub fn add_view(&mut self, view: View) {
            self.views.push(view);
        }

        /// Calculate implied equilibrium returns
        pub fn implied_returns(&self) -> Vec<f64> {
            let n = self.market_weights.len();
            let mut returns = vec![0.0; n];

            for i in 0..n {
                for j in 0..n {
                    returns[i] += self.risk_aversion * self.covariance[i][j] * self.market_weights[j];
                }
            }

            returns
        }

        /// Compute posterior returns incorporating views
        pub fn posterior_returns(&self) -> Vec<f64> {
            if self.views.is_empty() {
                return self.implied_returns();
            }

            let prior = self.implied_returns();
            let n = prior.len();
            let k = self.views.len();

            // Build P matrix (view portfolios)
            let mut p = vec![vec![0.0; n]; k];
            let mut q = vec![0.0; k]; // View returns
            let mut omega_diag = vec![0.0; k]; // View uncertainty

            for (v, view) in self.views.iter().enumerate() {
                for &(asset, weight) in &view.assets {
                    p[v][asset] = weight;
                }
                q[v] = view.expected_return;

                // Omega diagonal: uncertainty proportional to view variance
                let mut view_var = 0.0;
                for &(i, wi) in &view.assets {
                    for &(j, wj) in &view.assets {
                        view_var += wi * wj * self.covariance[i][j];
                    }
                }
                omega_diag[v] = view_var / view.confidence;
            }

            // Simplified BL formula (full would use matrix inversion)
            // posterior = prior + tau * Sigma * P' * (P * tau * Sigma * P' + Omega)^-1 * (q - P * prior)

            let mut posterior = prior.clone();
            for (v, view) in self.views.iter().enumerate() {
                let view_diff = q[v] - view.assets.iter()
                    .map(|&(a, w)| w * prior[a])
                    .sum::<f64>();

                for &(asset, weight) in &view.assets {
                    let adj = self.tau * weight * view_diff * view.confidence;
                    posterior[asset] += adj;
                }
            }

            posterior
        }
    }

    /// Hierarchical Risk Parity
    pub struct HierarchicalRiskParity {
        pub returns: Vec<Vec<f64>>,
        pub symbols: Vec<String>,
    }

    impl HierarchicalRiskParity {
        pub fn new(symbols: Vec<String>, returns: Vec<Vec<f64>>) -> Self {
            HierarchicalRiskParity { returns, symbols }
        }

        /// Calculate correlation matrix
        pub fn correlation_matrix(&self) -> Vec<Vec<f64>> {
            let n = self.returns.len();
            let t = self.returns[0].len() as f64;

            // Calculate means and std devs
            let means: Vec<f64> = self.returns.iter()
                .map(|r| r.iter().sum::<f64>() / t)
                .collect();

            let stds: Vec<f64> = self.returns.iter()
                .enumerate()
                .map(|(i, r)| {
                    let var: f64 = r.iter().map(|x| (x - means[i]).powi(2)).sum::<f64>() / (t - 1.0);
                    sqrt(var)
                })
                .collect();

            let mut corr = vec![vec![0.0; n]; n];

            for i in 0..n {
                for j in 0..n {
                    if i == j {
                        corr[i][j] = 1.0;
                    } else {
                        let mut cov = 0.0;
                        for k in 0..self.returns[0].len() {
                            cov += (self.returns[i][k] - means[i]) * (self.returns[j][k] - means[j]);
                        }
                        cov /= t - 1.0;
                        corr[i][j] = cov / (stds[i] * stds[j]);
                    }
                }
            }

            corr
        }

        /// Hierarchical clustering using single linkage
        pub fn cluster(&self) -> Vec<(usize, usize, f64)> {
            let corr = self.correlation_matrix();
            let n = corr.len();

            // Distance matrix (1 - |corr|)
            let mut dist = vec![vec![0.0; n]; n];
            for i in 0..n {
                for j in 0..n {
                    dist[i][j] = 1.0 - corr[i][j].abs();
                }
            }

            let mut clusters: Vec<Vec<usize>> = (0..n).map(|i| vec![i]).collect();
            let mut merges = Vec::new();

            while clusters.len() > 1 {
                // Find closest pair
                let mut min_dist = f64::INFINITY;
                let mut merge_i = 0;
                let mut merge_j = 1;

                for i in 0..clusters.len() {
                    for j in i+1..clusters.len() {
                        // Single linkage: min distance between clusters
                        for &a in &clusters[i] {
                            for &b in &clusters[j] {
                                if dist[a][b] < min_dist {
                                    min_dist = dist[a][b];
                                    merge_i = i;
                                    merge_j = j;
                                }
                            }
                        }
                    }
                }

                // Record merge
                let left = clusters[merge_i][0];
                let right = clusters[merge_j][0];
                merges.push((left, right, min_dist));

                // Merge clusters
                let merged = [clusters[merge_i].clone(), clusters[merge_j].clone()].concat();
                clusters.remove(merge_j);
                clusters.remove(merge_i);
                clusters.push(merged);
            }

            merges
        }

        /// Compute weights using recursive bisection
        pub fn optimize(&self) -> Vec<f64> {
            let n = self.symbols.len();
            let mut weights = vec![1.0; n];

            // Get cluster ordering
            let merges = self.cluster();

            // Simplified: allocate based on inverse volatility within clusters
            let vols: Vec<f64> = self.returns.iter()
                .map(|r| {
                    let mean = r.iter().sum::<f64>() / r.len() as f64;
                    let var: f64 = r.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / (r.len() - 1) as f64;
                    sqrt(var)
                })
                .collect();

            let total_inv_vol: f64 = vols.iter().map(|v| 1.0 / v).sum();

            for i in 0..n {
                weights[i] = (1.0 / vols[i]) / total_inv_vol;
            }

            weights
        }
    }
}

