/// Comprehensive backtest results
#[derive(Debug, Clone)]
pub struct BacktestResult {
    pub initial_capital: f64,
    pub final_capital: f64,
    pub total_return: f64,
    pub annualized_return: f64,
    pub sharpe_ratio: f64,
    pub sortino_ratio: f64,
    pub calmar_ratio: f64,
    pub max_drawdown: f64,
    pub total_trades: usize,
    pub winning_trades: usize,
    pub losing_trades: usize,
    pub win_rate: f64,
    pub avg_win: f64,
    pub avg_loss: f64,
    pub profit_factor: f64,
    pub total_commission: f64,
    pub equity_curve: Vec<(u64, f64)>,
    pub trades: Vec<Trade>,
}

impl BacktestResult {
    /// Generate text report
    pub fn report(&self) -> String {
        format!(r#"
═══════════════════════════════════════════════════════════════
                    BACKTEST RESULTS
═══════════════════════════════════════════════════════════════

  PERFORMANCE METRICS
  ───────────────────────────────────────────────────────────
  Initial Capital:     ${:.2}
  Final Capital:       ${:.2}
  Total Return:        {:.2}%
  Annualized Return:   {:.2}%
  Sharpe Ratio:        {:.2}
  Sortino Ratio:       {:.2}
  Calmar Ratio:        {:.2}
  Max Drawdown:        {:.2}%

  TRADING STATISTICS
  ───────────────────────────────────────────────────────────
  Total Trades:        {}
  Winning Trades:      {}
  Losing Trades:       {}
  Win Rate:            {:.2}%
  Avg Win:             ${:.2}
  Avg Loss:            ${:.2}
  Profit Factor:       {:.2}
  Total Commission:    ${:.2}

═══════════════════════════════════════════════════════════════
"#,
            self.initial_capital,
            self.final_capital,
            self.total_return * 100.0,
            self.annualized_return * 100.0,
            self.sharpe_ratio,
            self.sortino_ratio,
            self.calmar_ratio,
            self.max_drawdown * 100.0,
            self.total_trades,
            self.winning_trades,
            self.losing_trades,
            self.win_rate * 100.0,
            self.avg_win,
            self.avg_loss,
            self.profit_factor,
            self.total_commission
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WALK-FORWARD OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Walk-forward optimization configuration
pub struct WalkForwardConfig {
    pub in_sample_bars: usize,
    pub out_of_sample_bars: usize,
    pub step_bars: usize,
}

/// Walk-forward optimizer
pub struct WalkForwardOptimizer {
    config: WalkForwardConfig,
}

impl WalkForwardOptimizer {
    pub fn new(config: WalkForwardConfig) -> Self {
        WalkForwardOptimizer { config }
    }

    /// Generate train/test splits
    pub fn splits(&self, total_bars: usize) -> Vec<(std::ops::Range<usize>, std::ops::Range<usize>)> {
        let mut splits = Vec::new();
        let mut start = 0;

        while start + self.config.in_sample_bars + self.config.out_of_sample_bars <= total_bars {
            let train_end = start + self.config.in_sample_bars;
            let test_end = train_end + self.config.out_of_sample_bars;

            splits.push((start..train_end, train_end..test_end));
            start += self.config.step_bars;
        }

        splits
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MONTE CARLO SIMULATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Monte Carlo result
#[derive(Debug)]
pub struct MonteCarloResult {
    pub simulations: usize,
    pub mean_return: f64,
    pub std_return: f64,
    pub var_95: f64,
    pub var_99: f64,
    pub max_drawdown_95: f64,
    pub probability_profit: f64,
}

/// Monte Carlo simulator for strategy robustness testing
pub struct MonteCarloSimulator {
    simulations: usize,
}

impl MonteCarloSimulator {
    pub fn new(simulations: usize) -> Self {
        MonteCarloSimulator { simulations }
    }

    /// Run Monte Carlo simulation by shuffling trades
    pub fn simulate_shuffled_trades(&self, trades: &[Trade]) -> MonteCarloResult {
        if trades.is_empty() {
            return MonteCarloResult {
                simulations: 0,
                mean_return: 0.0,
                std_return: 0.0,
                var_95: 0.0,
                var_99: 0.0,
                max_drawdown_95: 0.0,
                probability_profit: 0.0,
            };
        }

        let mut rng = std::random::Random::new();
        let mut final_returns = Vec::with_capacity(self.simulations);
        let mut max_drawdowns = Vec::with_capacity(self.simulations);

        for _ in 0..self.simulations {
            // Shuffle trade order
            let mut shuffled = trades.to_vec();
            for i in (1..shuffled.len()).rev() {
                let j = (rng.uniform(0.0, 1.0) * (i + 1) as f64) as usize;
                shuffled.swap(i, j);
            }

            // Calculate equity curve
            let mut equity = 100000.0;
            let mut peak = equity;
            let mut max_dd = 0.0;

            for trade in &shuffled {
                equity += trade.pnl;
                peak = peak.max(equity);
                let dd = (peak - equity) / peak;
                max_dd = max_dd.max(dd);
            }

            final_returns.push((equity - 100000.0) / 100000.0);
            max_drawdowns.push(max_dd);
        }

        // Sort for VaR calculation
        final_returns.sort_by(|a, b| a.partial_cmp(b).unwrap());
        max_drawdowns.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let mean_return = final_returns.iter().sum::<f64>() / self.simulations as f64;
        let variance = final_returns.iter().map(|r| (r - mean_return).powi(2)).sum::<f64>() / self.simulations as f64;

        let var_95_idx = (0.05 * self.simulations as f64) as usize;
        let var_99_idx = (0.01 * self.simulations as f64) as usize;
        let dd_95_idx = (0.95 * self.simulations as f64) as usize;

        let probability_profit = final_returns.iter().filter(|&&r| r > 0.0).count() as f64 / self.simulations as f64;

        MonteCarloResult {
            simulations: self.simulations,
            mean_return,
            std_return: sqrt(variance),
            var_95: final_returns[var_95_idx],
            var_99: final_returns[var_99_idx],
            max_drawdown_95: max_drawdowns[dd_95_idx.min(max_drawdowns.len() - 1)],
            probability_profit,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXAMPLE STRATEGIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Simple Moving Average Crossover Strategy
pub struct SMACrossover {
    symbol: String,
    fast_period: usize,
    slow_period: usize,
    position_size: f64,
    prev_fast: Option<f64>,
    prev_slow: Option<f64>,
}

impl SMACrossover {
    pub fn new(symbol: &str, fast_period: usize, slow_period: usize, position_size: f64) -> Self {
        SMACrossover {
            symbol: symbol.to_string(),
            fast_period,
            slow_period,
            position_size,
            prev_fast: None,
            prev_slow: None,
        }
    }

    fn sma(bars: &[Bar], period: usize) -> Option<f64> {
        if bars.len() < period {
            return None;
        }
        let sum: f64 = bars[bars.len() - period..].iter().map(|b| b.close).sum();
        Some(sum / period as f64)
    }
}

impl Strategy for SMACrossover {
    fn name(&self) -> &str {
        "SMA Crossover"
    }

    fn on_bar(&mut self, context: &StrategyContext) -> Vec<Signal> {
        let mut signals = Vec::new();

        if let Some(bars) = context.lookback(&self.symbol, self.slow_period + 1) {
            let fast_sma = Self::sma(bars, self.fast_period);
            let slow_sma = Self::sma(bars, self.slow_period);

            if let (Some(fast), Some(slow), Some(prev_fast), Some(prev_slow)) =
                (fast_sma, slow_sma, self.prev_fast, self.prev_slow) {

                let current_position = context.position(&self.symbol);

                // Bullish crossover
                if prev_fast <= prev_slow && fast > slow && current_position <= 0.0 {
                    if current_position < 0.0 {
                        signals.push(Signal::Close { symbol: self.symbol.clone() });
                    }
                    signals.push(Signal::Buy {
                        symbol: self.symbol.clone(),
                        quantity: self.position_size,
                    });
                }
                // Bearish crossover
                else if prev_fast >= prev_slow && fast < slow && current_position >= 0.0 {
                    if current_position > 0.0 {
                        signals.push(Signal::Close { symbol: self.symbol.clone() });
                    }
                    signals.push(Signal::Sell {
                        symbol: self.symbol.clone(),
                        quantity: self.position_size,
                    });
                }
            }

            self.prev_fast = fast_sma;
            self.prev_slow = slow_sma;
        }

        signals
    }
}

/// Mean Reversion Strategy (RSI-based)
pub struct RSIMeanReversion {
    symbol: String,
    rsi_period: usize,
    oversold: f64,
    overbought: f64,
    position_size: f64,
}

impl RSIMeanReversion {
    pub fn new(symbol: &str, rsi_period: usize, oversold: f64, overbought: f64, position_size: f64) -> Self {
        RSIMeanReversion {
            symbol: symbol.to_string(),
            rsi_period,
            oversold,
            overbought,
            position_size,
        }
    }

    fn rsi(bars: &[Bar], period: usize) -> Option<f64> {
        if bars.len() < period + 1 {
            return None;
        }

        let mut gains = 0.0;
        let mut losses = 0.0;

        for i in (bars.len() - period)..bars.len() {
            let change = bars[i].close - bars[i - 1].close;
            if change > 0.0 {
                gains += change;
            } else {
                losses -= change;
            }
        }

        let avg_gain = gains / period as f64;
        let avg_loss = losses / period as f64;

        if avg_loss < 1e-10 {
            return Some(100.0);
        }

        let rs = avg_gain / avg_loss;
        Some(100.0 - 100.0 / (1.0 + rs))
    }
}

impl Strategy for RSIMeanReversion {
    fn name(&self) -> &str {
        "RSI Mean Reversion"
    }

    fn on_bar(&mut self, context: &StrategyContext) -> Vec<Signal> {
        let mut signals = Vec::new();

        if let Some(bars) = context.lookback(&self.symbol, self.rsi_period + 2) {
            if let Some(rsi) = Self::rsi(bars, self.rsi_period) {
                let current_position = context.position(&self.symbol);

                if rsi < self.oversold && current_position <= 0.0 {
                    if current_position < 0.0 {
                        signals.push(Signal::Close { symbol: self.symbol.clone() });
                    }
                    signals.push(Signal::Buy {
                        symbol: self.symbol.clone(),
                        quantity: self.position_size,
                    });
                } else if rsi > self.overbought && current_position >= 0.0 {
                    if current_position > 0.0 {
                        signals.push(Signal::Close { symbol: self.symbol.clone() });
                    }
                    signals.push(Signal::Sell {
                        symbol: self.symbol.clone(),
                        quantity: self.position_size,
                    });
                }
            }
        }

        signals
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    fn generate_test_data(n: usize) -> Vec<Bar> {
        let mut bars = Vec::with_capacity(n);
        let mut price = 100.0;

        for i in 0..n {
            let change = (i as f64 * 0.1).sin() * 2.0;
            price += change;

            bars.push(Bar::new(
                i as u64 * 86400,
                price,
                price + 1.0,
                price - 1.0,
                price + change * 0.1,
                1000000.0,
            ));
        }

        bars
    }

    #[test]
    fn test_backtest_engine() {
        let mut engine = BacktestEngine::new(BacktestConfig::default());
        engine.add_data("TEST", generate_test_data(100));

        let mut strategy = SMACrossover::new("TEST", 5, 20, 100.0);
        let result = engine.run(&mut strategy);

        assert!(result.total_trades > 0);
        assert!(!result.equity_curve.is_empty());
    }

    #[test]
    fn test_position_update() {
        let mut position = Position::new("TEST");

        // Buy 100 shares at $50
        position.update(100.0, 50.0);
        assert!((position.quantity - 100.0).abs() < 0.001);
        assert!((position.average_cost - 50.0).abs() < 0.001);

        // Buy 50 more at $60
        position.update(50.0, 60.0);
        assert!((position.quantity - 150.0).abs() < 0.001);
        assert!((position.average_cost - 53.33).abs() < 0.1);

        // Sell 100 at $70
        position.update(-100.0, 70.0);
        assert!((position.quantity - 50.0).abs() < 0.001);
        assert!(position.realized_pnl > 0.0);
    }

    #[test]
    fn test_walk_forward() {
        let wf = WalkForwardOptimizer::new(WalkForwardConfig {
            in_sample_bars: 100,
            out_of_sample_bars: 20,
            step_bars: 20,
        });

        let splits = wf.splits(200);
        assert!(!splits.is_empty());
        assert_eq!(splits[0].0, 0..100);
        assert_eq!(splits[0].1, 100..120);
    }

    #[test]
    fn test_monte_carlo() {
        let trades = vec![
            Trade { timestamp: 0, symbol: "TEST".to_string(), side: OrderSide::Buy, quantity: 100.0, price: 50.0, commission: 1.0, pnl: 500.0 },
            Trade { timestamp: 1, symbol: "TEST".to_string(), side: OrderSide::Sell, quantity: 100.0, price: 45.0, commission: 1.0, pnl: -200.0 },
            Trade { timestamp: 2, symbol: "TEST".to_string(), side: OrderSide::Buy, quantity: 100.0, price: 48.0, commission: 1.0, pnl: 300.0 },
        ];

        let mc = MonteCarloSimulator::new(1000);
        let result = mc.simulate_shuffled_trades(&trades);

        assert_eq!(result.simulations, 1000);
        assert!(result.probability_profit > 0.0);
    }
}
