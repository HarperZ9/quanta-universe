    }
}

// ============================================================================
// REGION: Dynamic Batching
// ============================================================================

/// Dynamic batcher for variable batch sizes
pub struct DynamicBatcher {
    max_batch_size: usize,
    timeout_ms: u64,
    pending_requests: Vec<BatchRequest>,
    batch_size_history: Vec<usize>,
}

/// Batch request
struct BatchRequest {
    id: u64,
    input: Tensor,
    timestamp: Instant,
}

impl DynamicBatcher {
    /// Create new dynamic batcher
    pub fn new(max_batch_size: usize, timeout_ms: u64) -> Self {
        DynamicBatcher {
            max_batch_size,
            timeout_ms,
            pending_requests: Vec::new(),
            batch_size_history: Vec::new(),
        }
    }

    /// Add request to batch
    pub fn add_request(&mut self, id: u64, input: Tensor) {
        self.pending_requests.push(BatchRequest {
            id,
            input,
            timestamp: Instant::now(),
        });
    }

    /// Check if batch is ready
    pub fn is_ready(&self) -> bool {
        if self.pending_requests.is_empty() {
            return false;
        }

        // Batch is ready if:
        // 1. Max batch size reached
        // 2. Timeout expired for oldest request
        if self.pending_requests.len() >= self.max_batch_size {
            return true;
        }

        let oldest = self.pending_requests.first().unwrap();
        oldest.timestamp.elapsed().as_millis() as u64 >= self.timeout_ms
    }

    /// Get batched inputs
    pub fn get_batch(&mut self) -> Option<(Vec<u64>, Tensor)> {
        if self.pending_requests.is_empty() {
            return None;
        }

        let batch_size = self.pending_requests.len().min(self.max_batch_size);
        let requests: Vec<_> = self.pending_requests.drain(..batch_size).collect();

        let ids: Vec<u64> = requests.iter().map(|r| r.id).collect();
        let tensors: Vec<&Tensor> = requests.iter().map(|r| &r.input).collect();

        // Stack inputs into batch
        let batched = Tensor::stack(&tensors, 0);

        self.batch_size_history.push(batch_size);
        if self.batch_size_history.len() > 100 {
            self.batch_size_history.remove(0);
        }

        Some((ids, batched))
    }

    /// Get average batch size
    pub fn avg_batch_size(&self) -> f32 {
        if self.batch_size_history.is_empty() {
            return 0.0;
        }
        self.batch_size_history.iter().sum::<usize>() as f32 / self.batch_size_history.len() as f32
    }
}

// ============================================================================
// REGION: Model Cache
// ============================================================================

/// Model cache for loaded models
pub struct ModelCache {
    cache: HashMap<String, Arc<InferenceSession>>,
    max_models: usize,
    access_order: Vec<String>,
}

impl ModelCache {
    /// Create new model cache
    pub fn new(max_models: usize) -> Self {
        ModelCache {
            cache: HashMap::new(),
            max_models,
            access_order: Vec::new(),
        }
    }

    /// Get model from cache
    pub fn get(&mut self, key: &str) -> Option<Arc<InferenceSession>> {
        if let Some(session) = self.cache.get(key) {
            // Update access order
            self.access_order.retain(|k| k != key);
            self.access_order.push(key.to_string());
            Some(Arc::clone(session))
        } else {
            None
        }
    }

    /// Insert model into cache
    pub fn insert(&mut self, key: String, session: InferenceSession) {
        // Evict oldest if at capacity
        while self.cache.len() >= self.max_models && !self.access_order.is_empty() {
            let oldest = self.access_order.remove(0);
            self.cache.remove(&oldest);
        }

        self.cache.insert(key.clone(), Arc::new(session));
        self.access_order.push(key);
    }

    /// Clear cache
    pub fn clear(&mut self) {
        self.cache.clear();
        self.access_order.clear();
    }

    /// Get cache size
    pub fn len(&self) -> usize {
        self.cache.len()
    }
}

// ============================================================================
// REGION: Inference Engine
// ============================================================================

/// High-level inference engine
pub struct InferenceEngine {
    model_cache: ModelCache,
    execution_provider: ExecutionProvider,
    optimizer: GraphOptimizer,
    profiling_enabled: bool,
}

impl InferenceEngine {
    /// Create new inference engine
    pub fn new(execution_provider: ExecutionProvider) -> Self {
        let optimizer = GraphOptimizer::new(execution_provider.graph_optimization_level);

        InferenceEngine {
            model_cache: ModelCache::new(10),
            execution_provider,
            optimizer,
            profiling_enabled: false,
        }
    }

    /// Enable profiling
    pub fn enable_profiling(&mut self, enabled: bool) {
        self.profiling_enabled = enabled;
    }

    /// Load model
    pub fn load_model(&mut self, path: &str) -> Result<(), String> {
        let options = SessionOptions {
            execution_providers: vec![self.execution_provider.clone()],
            enable_profiling: self.profiling_enabled,
            ..Default::default()
        };

        let session = InferenceSession::from_file(path, options)?;
        self.model_cache.insert(path.to_string(), session);
        Ok(())
    }

    /// Run inference
    pub fn infer(&mut self, model_path: &str, inputs: HashMap<String, Tensor>) -> Result<HashMap<String, Tensor>, String> {
        // Get or load model
        if self.model_cache.get(model_path).is_none() {
            self.load_model(model_path)?;
        }

        // This is a simplified interface - real implementation would handle Arc<Mutex<Session>>
        Err("Session mutation not supported through cache".to_string())
    }

    /// Benchmark model
    pub fn benchmark(&mut self, model_path: &str, input_shapes: &[Shape], iterations: usize) -> Result<BenchmarkResult, String> {
        // Generate random inputs
        let mut inputs = HashMap::new();
        for (i, shape) in input_shapes.iter().enumerate() {
            let name = format!("input_{}", i);
            let tensor = Tensor::rand(*shape, DataType::Float32, Device::Cpu);
            inputs.insert(name, tensor);
        }

        // Warmup
        for _ in 0..5 {
            let _ = self.infer(model_path, inputs.clone());
        }

        // Benchmark
        let mut times = Vec::with_capacity(iterations);
        for _ in 0..iterations {
            let start = Instant::now();
            let _ = self.infer(model_path, inputs.clone());
            times.push(start.elapsed().as_secs_f64() * 1000.0);
        }

        times.sort_by(|a, b| a.partial_cmp(b).unwrap());

        Ok(BenchmarkResult {
            iterations,
            mean_ms: times.iter().sum::<f64>() / iterations as f64,
            min_ms: times[0],
            max_ms: times[iterations - 1],
            median_ms: times[iterations / 2],
            p95_ms: times[(iterations as f64 * 0.95) as usize],
            p99_ms: times[(iterations as f64 * 0.99) as usize],
            throughput: iterations as f64 / (times.iter().sum::<f64>() / 1000.0),
        })
    }
}

/// Benchmark result
#[derive(Clone, Debug)]
pub struct BenchmarkResult {
    pub iterations: usize,
    pub mean_ms: f64,
    pub min_ms: f64,
    pub max_ms: f64,
    pub median_ms: f64,
    pub p95_ms: f64,
    pub p99_ms: f64,
    pub throughput: f64, // inferences per second
}

impl std::fmt::Display for BenchmarkResult {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        writeln!(f, "Benchmark Results ({} iterations)", self.iterations)?;
        writeln!(f, "  Mean:   {:.2}ms", self.mean_ms)?;
        writeln!(f, "  Min:    {:.2}ms", self.min_ms)?;
        writeln!(f, "  Max:    {:.2}ms", self.max_ms)?;
        writeln!(f, "  Median: {:.2}ms", self.median_ms)?;
        writeln!(f, "  P95:    {:.2}ms", self.p95_ms)?;
        writeln!(f, "  P99:    {:.2}ms", self.p99_ms)?;
        writeln!(f, "  Throughput: {:.1} inf/s", self.throughput)
    }
}

// ============================================================================
// REGION: Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_execution_provider() {
        let ep = ExecutionProvider::cpu();
        assert_eq!(ep.backend, InferenceBackend::CPU);
        assert!(ep.backend.is_available());
    }

    #[test]
    fn test_memory_allocator() {
        let mut allocator = MemoryAllocator::new(1024);
        let ptr = allocator.allocate(256, 64);
        assert!(ptr.is_some());
        assert_eq!(allocator.used_memory(), 256);
    }

    #[test]
    fn test_profiler() {
        let mut profiler = Profiler::new();
        profiler.start_run();
        std::thread::sleep(std::time::Duration::from_millis(10));
        profiler.end_run();

        assert_eq!(profiler.data.total_runs, 1);
        assert!(profiler.data.avg_time_ms >= 10.0);
    }

    #[test]
    fn test_dynamic_batcher() {
        let mut batcher = DynamicBatcher::new(4, 100);

        let t1 = Tensor::zeros(Shape::d2(1, 10), DataType::Float32, Device::Cpu);
        let t2 = Tensor::zeros(Shape::d2(1, 10), DataType::Float32, Device::Cpu);

        batcher.add_request(1, t1);
        batcher.add_request(2, t2);

        assert!(!batcher.is_ready()); // Not at max batch size
    }

    #[test]
    fn test_model_cache() {
        let cache = ModelCache::new(3);
        assert_eq!(cache.len(), 0);
    }

    #[test]
    fn test_cpu_kernel() {
        let kernel = CPUKernel {
            op_type: OperatorType::Add,
            attrs: NodeAttributes::default(),
        };

        let a = Tensor::ones(Shape::d2(2, 3), DataType::Float32, Device::Cpu);
        let b = Tensor::ones(Shape::d2(2, 3), DataType::Float32, Device::Cpu);
        let allocator = MemoryAllocator::new(1024);

        let result = kernel.execute(&[&a, &b], &allocator);
        assert!(result.is_ok());

        let outputs = result.unwrap();
        assert_eq!(outputs.len(), 1);
        assert!((outputs[0].sum() - 12.0).abs() < 1e-6);
    }
}
