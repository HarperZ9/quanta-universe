/// Swin Transformer Block
pub struct SwinTransformerBlock {
    dim: usize,
    num_heads: usize,
    window_size: usize,
    shift_size: usize,
    mlp_ratio: f32,
    /// Layer normalization 1
    norm1: LayerNorm,
    /// Window attention
    attn: WindowAttention,
    /// Layer normalization 2
    norm2: LayerNorm,
    /// MLP
    mlp: MLP,
}

/// MLP block for transformer
pub struct MLP {
    fc1: Linear,
    fc2: Linear,
    activation: GELU,
}

impl MLP {
    pub fn new(in_features: usize, hidden_features: usize, out_features: usize) -> Self {
        Self {
            fc1: Linear::new(in_features, hidden_features, true),
            fc2: Linear::new(hidden_features, out_features, true),
            activation: GELU::new(),
        }
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let mut x = self.fc1.forward(input);
        x = self.activation.forward(&x);
        self.fc2.forward(&x)
    }
}

impl SwinTransformerBlock {
    pub fn new(
        dim: usize,
        num_heads: usize,
        window_size: usize,
        shift_size: usize,
        mlp_ratio: f32,
    ) -> Self {
        let mlp_hidden = (dim as f32 * mlp_ratio) as usize;

        Self {
            dim,
            num_heads,
            window_size,
            shift_size,
            mlp_ratio,
            norm1: LayerNorm::new(dim, 1e-5),
            attn: WindowAttention::new(dim, window_size, num_heads),
            norm2: LayerNorm::new(dim, 1e-5),
            mlp: MLP::new(dim, mlp_hidden, dim),
        }
    }

    pub fn forward(&self, input: &Tensor, height: usize, width: usize) -> Tensor {
        let shape = input.shape();
        let batch = shape.dim(0);
        let seq_len = shape.dim(1);
        let dim = shape.dim(2);

        let shortcut = input.clone();
        let mut x = self.norm1.forward(input);

        // Reshape to 2D feature map
        x = x.reshape(&[batch, height, width, dim]);

        // Cyclic shift if needed
        if self.shift_size > 0 {
            x = self.cyclic_shift(&x, self.shift_size);
        }

        // Partition into windows
        let x_windows = self.window_partition(&x);

        // Window attention
        let attn_windows = self.attn.forward(&x_windows, None);

        // Merge windows
        x = self.window_reverse(&attn_windows, height, width);

        // Reverse cyclic shift
        if self.shift_size > 0 {
            x = self.cyclic_shift(&x, self.window_size - self.shift_size);
        }

        // Reshape back
        x = x.reshape(&[batch, seq_len, dim]);

        // Residual connection
        x = shortcut.add(&x);

        // MLP block
        let shortcut2 = x.clone();
        x = self.norm2.forward(&x);
        x = self.mlp.forward(&x);
        shortcut2.add(&x)
    }

    fn cyclic_shift(&self, input: &Tensor, shift: usize) -> Tensor {
        // Roll tensor along height and width dimensions
        input.clone() // Simplified
    }

    fn window_partition(&self, input: &Tensor) -> Tensor {
        let shape = input.shape();
        let batch = shape.dim(0);
        let height = shape.dim(1);
        let width = shape.dim(2);
        let dim = shape.dim(3);

        let num_windows_h = height / self.window_size;
        let num_windows_w = width / self.window_size;

        // Reshape and transpose to get windows
        let x = input.reshape(&[
            batch,
            num_windows_h,
            self.window_size,
            num_windows_w,
            self.window_size,
            dim,
        ]);

        // Permute to [batch * num_windows, window_size * window_size, dim]
        let num_windows = num_windows_h * num_windows_w;
        let window_area = self.window_size * self.window_size;

        x.reshape(&[batch * num_windows, window_area, dim])
    }

    fn window_reverse(&self, windows: &Tensor, height: usize, width: usize) -> Tensor {
        let shape = windows.shape();
        let batch_windows = shape.dim(0);
        let window_area = shape.dim(1);
        let dim = shape.dim(2);

        let num_windows_h = height / self.window_size;
        let num_windows_w = width / self.window_size;
        let batch = batch_windows / (num_windows_h * num_windows_w);

        // Reshape back to image
        windows.reshape(&[batch, height, width, dim])
    }
}

/// Residual Swin Transformer Block (RSTB)
pub struct RSTB {
    dim: usize,
    depth: usize,
    num_heads: usize,
    window_size: usize,
    mlp_ratio: f32,
    /// Swin transformer blocks
    blocks: Vec<SwinTransformerBlock>,
    /// Convolution at the end
    conv: Conv2d,
}

impl RSTB {
    pub fn new(
        dim: usize,
        depth: usize,
        num_heads: usize,
        window_size: usize,
        mlp_ratio: f32,
    ) -> Self {
        let mut blocks = Vec::with_capacity(depth);

        for i in 0..depth {
            let shift_size = if i % 2 == 0 { 0 } else { window_size / 2 };
            blocks.push(SwinTransformerBlock::new(
                dim,
                num_heads,
                window_size,
                shift_size,
                mlp_ratio,
            ));
        }

        // 1x1 convolution for channel matching
        let conv = Conv2d::new(dim, dim, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        Self {
            dim,
            depth,
            num_heads,
            window_size,
            mlp_ratio,
            blocks,
            conv,
        }
    }

    pub fn forward(&self, input: &Tensor, height: usize, width: usize) -> Tensor {
        let mut x = input.clone();

        for block in &self.blocks {
            x = block.forward(&x, height, width);
        }

        // Reshape to image for conv
        let shape = x.shape();
        let batch = shape.dim(0);
        let dim = shape.dim(2);

        x = x.reshape(&[batch, height, width, dim]);
        x = x.transpose(1, 3); // [B, C, H, W]
        x = self.conv.forward(&x);
        x = x.transpose(1, 3); // [B, H, W, C]
        x = x.reshape(&[batch, height * width, dim]);

        // Residual connection
        input.add(&x)
    }
}

/// SwinIR: Swin Transformer for Image Restoration
pub struct SwinIR {
    scale: usize,
    in_channels: usize,
    embed_dim: usize,
    depths: Vec<usize>,
    num_heads: Vec<usize>,
    window_size: usize,
    mlp_ratio: f32,
    /// Shallow feature extraction
    conv_first: Conv2d,
    /// Patch embedding (linear projection)
    patch_embed: Linear,
    /// Deep feature extraction (RSTBs)
    rstbs: Vec<RSTB>,
    /// Norm layer
    norm: LayerNorm,
    /// Reconstruction
    conv_after_body: Conv2d,
    /// Upsampler
    upsample: Upsample,
    /// Final conv
    conv_last: Conv2d,
}

impl SwinIR {
    pub fn new(
        scale: usize,
        in_channels: usize,
        embed_dim: usize,
        depths: Vec<usize>,
        num_heads: Vec<usize>,
        window_size: usize,
        mlp_ratio: f32,
    ) -> Self {
        let conv_first = Conv2d::new(in_channels, embed_dim, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);
        let patch_embed = Linear::new(embed_dim, embed_dim, true);

        let mut rstbs = Vec::with_capacity(depths.len());
        for i in 0..depths.len() {
            rstbs.push(RSTB::new(
                embed_dim,
                depths[i],
                num_heads[i],
                window_size,
                mlp_ratio,
            ));
        }

        let norm = LayerNorm::new(embed_dim, 1e-5);
        let conv_after_body = Conv2d::new(embed_dim, embed_dim, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);
        let upsample = Upsample::new(scale as f32, "nearest");
        let conv_last = Conv2d::new(embed_dim, in_channels, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        Self {
            scale,
            in_channels,
            embed_dim,
            depths,
            num_heads,
            window_size,
            mlp_ratio,
            conv_first,
            patch_embed,
            rstbs,
            norm,
            conv_after_body,
            upsample,
            conv_last,
        }
    }

    pub fn new_lightweight(scale: usize) -> Self {
        Self::new(
            scale,
            3,
            60,
            vec![6, 6, 6, 6],
            vec![6, 6, 6, 6],
            8,
            2.0,
        )
    }

    pub fn new_default(scale: usize) -> Self {
        Self::new(
            scale,
            3,
            180,
            vec![6, 6, 6, 6, 6, 6],
            vec![6, 6, 6, 6, 6, 6],
            8,
            2.0,
        )
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let shape = input.shape();
        let batch = shape.dim(0);
        let height = shape.dim(2);
        let width = shape.dim(3);

        // Shallow feature extraction
        let mut x = self.conv_first.forward(input);
        let shallow_features = x.clone();

        // Reshape for transformer: [B, C, H, W] -> [B, H*W, C]
        x = x.transpose(1, 2); // [B, H, C, W]
        x = x.transpose(2, 3); // [B, H, W, C]
        x = x.reshape(&[batch, height * width, self.embed_dim]);

        // Patch embedding
        x = self.patch_embed.forward(&x);

        // Deep feature extraction
        for rstb in &self.rstbs {
            x = rstb.forward(&x, height, width);
        }

        // Norm
        x = self.norm.forward(&x);

        // Reshape back: [B, H*W, C] -> [B, C, H, W]
        x = x.reshape(&[batch, height, width, self.embed_dim]);
        x = x.transpose(2, 3); // [B, H, C, W]
        x = x.transpose(1, 2); // [B, C, H, W]

        // Conv and residual
        x = self.conv_after_body.forward(&x);
        x = x.add(&shallow_features);

        // Upscale
        x = self.upsample.forward(&x);

        // Final conv
        self.conv_last.forward(&x)
    }
}

// ============================================================================
// REAL-ESRGAN (Real-World Enhanced Super-Resolution GAN)
// ============================================================================

/// Residual Dense Block
pub struct ResidualDenseBlock {
    num_features: usize,
    growth_rate: usize,
    convs: Vec<Conv2d>,
    lrelu: LeakyReLU,
    res_scale: f32,
}

impl ResidualDenseBlock {
    pub fn new(num_features: usize, growth_rate: usize, num_layers: usize) -> Self {
        let mut convs = Vec::with_capacity(num_layers);

        for i in 0..num_layers {
            let in_ch = num_features + i * growth_rate;
            convs.push(Conv2d::new(in_ch, growth_rate, (3, 3), (1, 1), (1, 1), (1, 1), 1, true));
        }

        // Final conv back to original channels
        convs.push(Conv2d::new(
            num_features + num_layers * growth_rate,
            num_features,
            (3, 3),
            (1, 1),
            (1, 1),
            (1, 1),
            1,
            true,
        ));

        Self {
            num_features,
            growth_rate,
            convs,
            lrelu: LeakyReLU::new(0.2),
            res_scale: 0.2,
        }
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let mut features = vec![input.clone()];

        // Dense connections
        for i in 0..(self.convs.len() - 1) {
            // Concatenate all previous features
            let concat = Tensor::cat(&features, 1);
            let mut out = self.convs[i].forward(&concat);
            out = self.lrelu.forward(&out);
            features.push(out);
        }

        // Final conv (no activation)
        let concat = Tensor::cat(&features, 1);
        let out = self.convs.last().unwrap().forward(&concat);

        // Residual scaling
        let scaled = out.mul_scalar(self.res_scale);
        input.add(&scaled)
    }
}

/// Residual in Residual Dense Block (RRDB)
pub struct RRDB {
    rdb1: ResidualDenseBlock,
    rdb2: ResidualDenseBlock,
    rdb3: ResidualDenseBlock,
    res_scale: f32,
}

impl RRDB {
    pub fn new(num_features: usize, growth_rate: usize) -> Self {
        Self {
            rdb1: ResidualDenseBlock::new(num_features, growth_rate, 5),
            rdb2: ResidualDenseBlock::new(num_features, growth_rate, 5),
            rdb3: ResidualDenseBlock::new(num_features, growth_rate, 5),
            res_scale: 0.2,
        }
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let mut out = self.rdb1.forward(input);
        out = self.rdb2.forward(&out);
        out = self.rdb3.forward(&out);

        let scaled = out.mul_scalar(self.res_scale);
        input.add(&scaled)
    }
}

/// Real-ESRGAN Generator
pub struct RealESRGAN {
    scale: usize,
    in_channels: usize,
    out_channels: usize,
    num_features: usize,
    num_blocks: usize,
    growth_rate: usize,
    /// First convolution
    conv_first: Conv2d,
    /// RRDB trunk
    trunk: Vec<RRDB>,
    /// Trunk convolution
    trunk_conv: Conv2d,
    /// Upsampling layers
    upconv1: Conv2d,
    upconv2: Conv2d,
    /// High-res convolutions
    hr_conv: Conv2d,
    /// Final convolution
    conv_last: Conv2d,
    /// Activation
    lrelu: LeakyReLU,
}

impl RealESRGAN {
    pub fn new(
        scale: usize,
        in_channels: usize,
        out_channels: usize,
        num_features: usize,
        num_blocks: usize,
        growth_rate: usize,
    ) -> Self {
        let conv_first = Conv2d::new(in_channels, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        let mut trunk = Vec::with_capacity(num_blocks);
        for _ in 0..num_blocks {
            trunk.push(RRDB::new(num_features, growth_rate));
        }

        let trunk_conv = Conv2d::new(num_features, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        // Upsampling (for 4x scale)
        let upconv1 = Conv2d::new(num_features, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);
        let upconv2 = Conv2d::new(num_features, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        let hr_conv = Conv2d::new(num_features, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);
        let conv_last = Conv2d::new(num_features, out_channels, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        Self {
            scale,
            in_channels,
            out_channels,
            num_features,
            num_blocks,
            growth_rate,
            conv_first,
            trunk,
            trunk_conv,
            upconv1,
            upconv2,
            hr_conv,
            conv_last,
            lrelu: LeakyReLU::new(0.2),
        }
    }

    pub fn new_x4() -> Self {
        Self::new(4, 3, 3, 64, 23, 32)
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let mut feat = self.conv_first.forward(input);
        let feat_first = feat.clone();

        // RRDB trunk
        for rrdb in &self.trunk {
            feat = rrdb.forward(&feat);
        }

        feat = self.trunk_conv.forward(&feat);
        feat = feat.add(&feat_first);

        // Upsampling
        let upsample2x = Upsample::new(2.0, "nearest");

        feat = upsample2x.forward(&feat);
        feat = self.upconv1.forward(&feat);
        feat = self.lrelu.forward(&feat);

        if self.scale == 4 {
            feat = upsample2x.forward(&feat);
            feat = self.upconv2.forward(&feat);
            feat = self.lrelu.forward(&feat);
        }

        // High-res processing
        feat = self.hr_conv.forward(&feat);
        feat = self.lrelu.forward(&feat);

        self.conv_last.forward(&feat)
    }
}

// ============================================================================
// TEMPORAL SUPER-RESOLUTION (DLSS-LIKE)
// ============================================================================

/// Motion vector format
pub struct MotionVector {
    pub dx: f32,
    pub dy: f32,
}

/// Temporal accumulation buffer
pub struct TemporalBuffer {
    /// History color buffer
    history_color: Tensor,
    /// History depth buffer
    history_depth: Tensor,
    /// History motion vectors
    history_motion: Tensor,
    /// Frame count
    frame_count: usize,
    /// Buffer dimensions
    width: usize,
    height: usize,
    /// Maximum history frames
    max_history: usize,
}

impl TemporalBuffer {
    pub fn new(width: usize, height: usize, max_history: usize) -> Self {
        Self {
            history_color: Tensor::zeros(&[max_history, 3, height, width], DataType::Float32),
            history_depth: Tensor::zeros(&[max_history, 1, height, width], DataType::Float32),
            history_motion: Tensor::zeros(&[max_history, 2, height, width], DataType::Float32),
            frame_count: 0,
            width,
            height,
            max_history,
        }
    }

    pub fn push(&mut self, color: &Tensor, depth: &Tensor, motion: &Tensor) {
        // Shift history and add new frame
        // (In real implementation, use circular buffer)
        self.frame_count += 1;
    }

    pub fn get_history(&self, frames_back: usize) -> Option<(&Tensor, &Tensor, &Tensor)> {
        if frames_back >= self.max_history || frames_back >= self.frame_count {
            return None;
        }

        // Return slices of the history tensors
        Some((&self.history_color, &self.history_depth, &self.history_motion))
    }

    pub fn reset(&mut self) {
        self.frame_count = 0;
        self.history_color = Tensor::zeros(
            &[self.max_history, 3, self.height, self.width],
            DataType::Float32,
        );
    }
}

/// Jitter pattern for temporal anti-aliasing
pub struct JitterPattern {
    /// Jitter offsets
    offsets: Vec<(f32, f32)>,
    /// Current index
    current_index: usize,
}

impl JitterPattern {
    pub fn halton_2_3(count: usize) -> Self {
        let mut offsets = Vec::with_capacity(count);

        for i in 0..count {
            let x = Self::halton_sequence(i + 1, 2);
            let y = Self::halton_sequence(i + 1, 3);
            offsets.push((x - 0.5, y - 0.5));
        }

        Self {
            offsets,
            current_index: 0,
        }
    }

    fn halton_sequence(mut index: usize, base: usize) -> f32 {
        let mut f = 1.0f32;
        let mut r = 0.0f32;

        while index > 0 {
            f /= base as f32;
            r += f * (index % base) as f32;
            index /= base;
        }

        r
    }

    pub fn next(&mut self) -> (f32, f32) {
        let offset = self.offsets[self.current_index];
        self.current_index = (self.current_index + 1) % self.offsets.len();
        offset
    }

    pub fn current(&self) -> (f32, f32) {
        self.offsets[self.current_index]
    }

    pub fn reset(&mut self) {
        self.current_index = 0;
    }
}

/// Feature extraction network for temporal SR
pub struct TemporalFeatureExtractor {
    /// Initial convolution
    conv1: Conv2d,
    /// Residual blocks
    res_blocks: Vec<ResidualBlock>,
    /// Motion feature extraction
    motion_conv: Conv2d,
    /// Depth feature extraction
    depth_conv: Conv2d,
    /// Feature fusion
    fusion_conv: Conv2d,
}

impl TemporalFeatureExtractor {
    pub fn new(in_channels: usize, num_features: usize, num_blocks: usize) -> Self {
        let conv1 = Conv2d::new(in_channels, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        let mut res_blocks = Vec::with_capacity(num_blocks);
        for _ in 0..num_blocks {
            res_blocks.push(ResidualBlock::new(num_features, num_features));
        }

        let motion_conv = Conv2d::new(2, num_features / 4, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);
        let depth_conv = Conv2d::new(1, num_features / 4, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);
        let fusion_conv = Conv2d::new(
            num_features + num_features / 2,
            num_features,
            (1, 1),
            (1, 1),
            (0, 0),
            (1, 1),
            1,
            true,
        );

        Self {
            conv1,
            res_blocks,
            motion_conv,
            depth_conv,
            fusion_conv,
        }
    }

    pub fn forward(&self, color: &Tensor, motion: &Tensor, depth: &Tensor) -> Tensor {
        // Extract color features
        let mut color_feat = self.conv1.forward(color);
        for block in &self.res_blocks {
            color_feat = block.forward(&color_feat);
        }

        // Extract motion features
        let motion_feat = self.motion_conv.forward(motion);

        // Extract depth features
        let depth_feat = self.depth_conv.forward(depth);

        // Concatenate and fuse
        let concat = Tensor::cat(&[color_feat, motion_feat, depth_feat], 1);
        self.fusion_conv.forward(&concat)
    }
}

/// Temporal warping module
pub struct TemporalWarping {
    /// Bilinear sampling grid
    grid_sample_mode: GridSampleMode,
}

pub enum GridSampleMode {
    Bilinear,
    Nearest,
    Bicubic,
}

impl TemporalWarping {
    pub fn new(mode: GridSampleMode) -> Self {
        Self {
            grid_sample_mode: mode,
        }
    }

    pub fn warp(&self, input: &Tensor, motion: &Tensor) -> Tensor {
        let shape = input.shape();
        let batch = shape.dim(0);
        let channels = shape.dim(1);
        let height = shape.dim(2);
        let width = shape.dim(3);

        // Create sampling grid from motion vectors
        let mut output = Tensor::zeros(&[batch, channels, height, width], input.dtype());

        // For each pixel, sample from previous frame using motion vector
        for b in 0..batch {
            for c in 0..channels {
                for y in 0..height {
                    for x in 0..width {
                        // Get motion vector at this pixel
                        let dx = motion.get_f32(&[b, 0, y, x]);
                        let dy = motion.get_f32(&[b, 1, y, x]);

                        // Source coordinates
                        let src_x = x as f32 + dx;
                        let src_y = y as f32 + dy;

                        // Bilinear sampling
                        let value = self.bilinear_sample(input, b, c, src_y, src_x, height, width);
                        output.set_f32(&[b, c, y, x], value);
                    }
                }
            }
        }

        output
    }

    fn bilinear_sample(
        &self,
        input: &Tensor,
        batch: usize,
        channel: usize,
        y: f32,
        x: f32,
        height: usize,
        width: usize,
    ) -> f32 {
        let x0 = x.floor() as i32;
        let x1 = x0 + 1;
        let y0 = y.floor() as i32;
        let y1 = y0 + 1;

        let x_lerp = x - x0 as f32;
        let y_lerp = y - y0 as f32;

        // Clamp coordinates
        let x0 = x0.clamp(0, width as i32 - 1) as usize;
        let x1 = x1.clamp(0, width as i32 - 1) as usize;
        let y0 = y0.clamp(0, height as i32 - 1) as usize;
        let y1 = y1.clamp(0, height as i32 - 1) as usize;

        // Sample four corners
        let v00 = input.get_f32(&[batch, channel, y0, x0]);
        let v01 = input.get_f32(&[batch, channel, y0, x1]);
        let v10 = input.get_f32(&[batch, channel, y1, x0]);
        let v11 = input.get_f32(&[batch, channel, y1, x1]);

        // Bilinear interpolation
        let v0 = v00 * (1.0 - x_lerp) + v01 * x_lerp;
        let v1 = v10 * (1.0 - x_lerp) + v11 * x_lerp;

        v0 * (1.0 - y_lerp) + v1 * y_lerp
    }
}

/// Temporal fusion network
pub struct TemporalFusion {
    /// Number of history frames to use
    num_history: usize,
    /// Feature channels
    num_features: usize,
    /// Cross-frame attention
    attention: Conv2d,
    /// Fusion convolutions
    fusion_convs: Vec<Conv2d>,
    /// Output conv
    output_conv: Conv2d,
}

impl TemporalFusion {
    pub fn new(num_history: usize, num_features: usize) -> Self {
        let attention = Conv2d::new(
            num_features * (num_history + 1),
            num_history + 1,
            (3, 3),
            (1, 1),
            (1, 1),
            (1, 1),
            1,
            true,
        );

        let mut fusion_convs = Vec::new();
        fusion_convs.push(Conv2d::new(
            num_features * (num_history + 1),
            num_features * 2,
            (3, 3),
            (1, 1),
            (1, 1),
            (1, 1),
            1,
            true,
        ));
        fusion_convs.push(Conv2d::new(
            num_features * 2,
            num_features,
            (3, 3),
            (1, 1),
            (1, 1),
            (1, 1),
            1,
            true,
        ));

        let output_conv = Conv2d::new(num_features, num_features, (3, 3), (1, 1), (1, 1), (1, 1), 1, true);

        Self {
            num_history,
            num_features,
            attention,
            fusion_convs,
            output_conv,
        }
    }

    pub fn forward(&self, current: &Tensor, history: &[Tensor]) -> Tensor {
        // Concatenate current and history features
        let mut all_features = vec![current.clone()];
        all_features.extend(history.iter().cloned());
        let concat = Tensor::cat(&all_features, 1);

        // Compute attention weights
        let attn = self.attention.forward(&concat);
        let attn = softmax(&attn, 1);

        // Apply attention and fuse
        let mut fused = concat.clone();
        for conv in &self.fusion_convs {
            fused = conv.forward(&fused);
            fused = ReLU::new().forward(&fused);
        }

        self.output_conv.forward(&fused)
    }
}

/// Temporal Super-Resolution Network (DLSS-like)
pub struct TemporalSR {
    /// Input scale factor
    scale: usize,
    /// Render resolution
    render_width: usize,
    render_height: usize,
    /// Output resolution
    output_width: usize,
    output_height: usize,
    /// Feature channels
    num_features: usize,
    /// Number of history frames
    num_history: usize,
    /// Temporal buffer
    temporal_buffer: TemporalBuffer,
    /// Jitter pattern
    jitter: JitterPattern,
    /// Feature extractor
    feature_extractor: TemporalFeatureExtractor,
    /// Temporal warping
    warping: TemporalWarping,
    /// Temporal fusion
    fusion: TemporalFusion,
    /// Upscaling network
    upscaler: EDSR,
    /// Sharpening strength
    sharpening: f32,
    /// History confidence threshold
    confidence_threshold: f32,
}

impl TemporalSR {
    pub fn new(
        scale: usize,
        render_width: usize,
        render_height: usize,
        num_features: usize,
        num_history: usize,
    ) -> Self {
        let output_width = render_width * scale;
        let output_height = render_height * scale;

        Self {
            scale,
            render_width,
            render_height,
            output_width,
            output_height,
            num_features,
            num_history,
            temporal_buffer: TemporalBuffer::new(output_width, output_height, num_history + 1),
            jitter: JitterPattern::halton_2_3(16),
            feature_extractor: TemporalFeatureExtractor::new(3, num_features, 4),
            warping: TemporalWarping::new(GridSampleMode::Bilinear),
            fusion: TemporalFusion::new(num_history, num_features),
            upscaler: EDSR::new_baseline(scale),
            sharpening: 0.5,
            confidence_threshold: 0.8,
        }
    }

    pub fn new_with_quality(quality: UpscaleQuality, output_width: usize, output_height: usize) -> Self {
        let (render_width, render_height) = quality.render_resolution(output_width as u32, output_height as u32);
        let scale = (output_width as f32 / render_width as f32).round() as usize;

        Self::new(
            scale.max(1),
            render_width as usize,
            render_height as usize,
            64,
            4,
        )
    }

    pub fn get_jitter(&mut self) -> (f32, f32) {
        self.jitter.next()
    }

    pub fn upscale(
        &mut self,
        color: &Tensor,
        depth: &Tensor,
        motion: &Tensor,
        exposure: f32,
    ) -> Tensor {
        // Extract features from current frame
        let current_features = self.feature_extractor.forward(color, motion, depth);

        // Warp and collect history features
        let mut history_features = Vec::with_capacity(self.num_history);

        for i in 1..=self.num_history {
            if let Some((hist_color, hist_depth, hist_motion)) = self.temporal_buffer.get_history(i) {
                // Warp history to current frame
                let warped = self.warping.warp(hist_color, motion);
                let hist_feat = self.feature_extractor.forward(&warped, hist_motion, hist_depth);
                history_features.push(hist_feat);
            }
        }

        // Temporal fusion
        let fused = if history_features.is_empty() {
            current_features.clone()
        } else {
            self.fusion.forward(&current_features, &history_features)
        };

        // Upscale
        // First, reshape fused features back to low-res color format
        // (simplified - real implementation would need proper feature-to-color conversion)
        let upscaled = self.upscaler.forward(color);

        // Apply sharpening
        let sharpened = self.apply_sharpening(&upscaled);

        // Store in temporal buffer
        self.temporal_buffer.push(&sharpened, depth, motion);

        sharpened
    }

    fn apply_sharpening(&self, input: &Tensor) -> Tensor {
        if self.sharpening <= 0.0 {
            return input.clone();
        }

        // Simple unsharp mask
        // blur = gaussian_blur(input)
        // sharpened = input + sharpening * (input - blur)

        // For now, return input unchanged
        input.clone()
    }

    pub fn reset(&mut self) {
        self.temporal_buffer.reset();
        self.jitter.reset();
    }

    pub fn set_sharpening(&mut self, strength: f32) {
        self.sharpening = strength.clamp(0.0, 1.0);
    }
}

// ============================================================================
// FSR-STYLE UPSCALING (AMD FidelityFX inspired)
// ============================================================================

/// Edge-Adaptive Spatial Upsampling (EASU) - FSR pass 1
pub struct EASU {
    /// Filter kernel size
    kernel_size: usize,
    /// Edge detection threshold
    edge_threshold: f32,
}

impl EASU {
    pub fn new(edge_threshold: f32) -> Self {
        Self {
            kernel_size: 12,
            edge_threshold,
        }
    }

    pub fn forward(&self, input: &Tensor, scale: f32) -> Tensor {
        let shape = input.shape();
        let batch = shape.dim(0);
        let channels = shape.dim(1);
        let height = shape.dim(2);
        let width = shape.dim(3);

        let out_height = (height as f32 * scale) as usize;
        let out_width = (width as f32 * scale) as usize;

        let mut output = Tensor::zeros(&[batch, channels, out_height, out_width], input.dtype());

        // Edge-adaptive upsampling
        for b in 0..batch {
            for c in 0..channels {
                for oy in 0..out_height {
                    for ox in 0..out_width {
                        // Map output coords to input coords
                        let iy = oy as f32 / scale;
                        let ix = ox as f32 / scale;

                        // Compute edge-adaptive weight
                        let value = self.sample_easu(input, b, c, iy, ix, height, width);
                        output.set_f32(&[b, c, oy, ox], value);
                    }
                }
            }
        }

        output
    }

    fn sample_easu(
        &self,
        input: &Tensor,
        batch: usize,
        channel: usize,
        y: f32,
        x: f32,
        height: usize,
        width: usize,
    ) -> f32 {
        // Lanczos-based sampling with edge detection
        let x0 = (x.floor() as i32).clamp(0, width as i32 - 1) as usize;
        let y0 = (y.floor() as i32).clamp(0, height as i32 - 1) as usize;
        let x1 = (x0 + 1).min(width - 1);
        let y1 = (y0 + 1).min(height - 1);

        // Sample neighbors
        let p00 = input.get_f32(&[batch, channel, y0, x0]);
        let p01 = input.get_f32(&[batch, channel, y0, x1]);
        let p10 = input.get_f32(&[batch, channel, y1, x0]);
        let p11 = input.get_f32(&[batch, channel, y1, x1]);

        // Compute local edge strength
        let dx = (p01 - p00).abs() + (p11 - p10).abs();
        let dy = (p10 - p00).abs() + (p11 - p01).abs();
        let edge_strength = (dx * dx + dy * dy).sqrt();

        // Adaptive interpolation based on edge
        let fx = x - x.floor();
        let fy = y - y.floor();

        if edge_strength > self.edge_threshold {
            // Sharp edge: use nearest neighbor-ish
            let nx = if fx < 0.5 { x0 } else { x1 };
            let ny = if fy < 0.5 { y0 } else { y1 };
            input.get_f32(&[batch, channel, ny, nx])
        } else {
            // Smooth area: bilinear
            let v0 = p00 * (1.0 - fx) + p01 * fx;
            let v1 = p10 * (1.0 - fx) + p11 * fx;
            v0 * (1.0 - fy) + v1 * fy
        }
    }
}

/// Robust Contrast Adaptive Sharpening (RCAS) - FSR pass 2
pub struct RCAS {
    /// Sharpness strength (0-2)
    sharpness: f32,
    /// Denoise strength
    denoise: f32,
}

impl RCAS {
    pub fn new(sharpness: f32, denoise: f32) -> Self {
        Self {
            sharpness: sharpness.clamp(0.0, 2.0),
            denoise: denoise.clamp(0.0, 1.0),
        }
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let shape = input.shape();
        let batch = shape.dim(0);
        let channels = shape.dim(1);
        let height = shape.dim(2);
        let width = shape.dim(3);

        let mut output = Tensor::zeros(&[batch, channels, height, width], input.dtype());

        for b in 0..batch {
            for c in 0..channels {
                for y in 1..(height - 1) {
                    for x in 1..(width - 1) {
                        let sharpened = self.sharpen_pixel(input, b, c, y, x);
                        output.set_f32(&[b, c, y, x], sharpened);
                    }
                }
            }
        }

        // Copy edges
        for b in 0..batch {
            for c in 0..channels {
                for x in 0..width {
                    output.set_f32(&[b, c, 0, x], input.get_f32(&[b, c, 0, x]));
                    output.set_f32(&[b, c, height - 1, x], input.get_f32(&[b, c, height - 1, x]));
                }
                for y in 0..height {
                    output.set_f32(&[b, c, y, 0], input.get_f32(&[b, c, y, 0]));
                    output.set_f32(&[b, c, y, width - 1], input.get_f32(&[b, c, y, width - 1]));
                }
            }
        }

        output
    }

    fn sharpen_pixel(&self, input: &Tensor, b: usize, c: usize, y: usize, x: usize) -> f32 {
        // Get 3x3 neighborhood
        let n = input.get_f32(&[b, c, y - 1, x]);
        let s = input.get_f32(&[b, c, y + 1, x]);
        let e = input.get_f32(&[b, c, y, x + 1]);
        let w = input.get_f32(&[b, c, y, x - 1]);
        let m = input.get_f32(&[b, c, y, x]);

        // Compute min/max for clamping
        let min_val = n.min(s).min(e).min(w).min(m);
        let max_val = n.max(s).max(e).max(w).max(m);

        // Compute sharpening amount based on local contrast
        let contrast = max_val - min_val;
        let sharp_amount = self.sharpness * (1.0 - contrast).max(0.0);

        // Apply unsharp mask
        let blur = (n + s + e + w) * 0.25;
        let detail = m - blur;
        let sharpened = m + detail * sharp_amount;

        // Clamp to prevent ringing
        sharpened.clamp(min_val, max_val)
    }
}

/// FSR-style upscaling pipeline
pub struct FSRUpscaler {
    /// Scale factor
    scale: f32,
    /// EASU pass
    easu: EASU,
    /// RCAS pass
    rcas: RCAS,
    /// HDR mode
    hdr: bool,
}

impl FSRUpscaler {
    pub fn new(scale: f32, sharpness: f32) -> Self {
        Self {
            scale,
            easu: EASU::new(0.1),
            rcas: RCAS::new(sharpness, 0.25),
            hdr: false,
        }
    }

    pub fn set_hdr(&mut self, enabled: bool) {
        self.hdr = enabled;
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        // Pass 1: EASU (upscaling)
        let upscaled = self.easu.forward(input, self.scale);

        // Pass 2: RCAS (sharpening)
        self.rcas.forward(&upscaled)
    }
}

// ============================================================================
// UNIFIED UPSCALING INTERFACE
// ============================================================================

/// Configuration for neural upscaling
pub struct UpscaleConfig {
    /// Upscaling method
    pub method: UpscaleMethod,
    /// Quality preset
    pub quality: UpscaleQuality,
    /// Enable temporal accumulation
    pub temporal: bool,
    /// Sharpening strength (0-1)
    pub sharpening: f32,
    /// Enable HDR processing
    pub hdr: bool,
    /// Inference backend
    pub backend: InferenceBackend,
    /// Model path (for loading pretrained weights)
    pub model_path: Option<String>,
}

impl Default for UpscaleConfig {
    fn default() -> Self {
        Self {
            method: UpscaleMethod::ESPCN,
            quality: UpscaleQuality::Quality,
            temporal: false,
            sharpening: 0.5,
            hdr: false,
            backend: InferenceBackend::DirectML,
            model_path: None,
        }
    }
}

/// Neural upscaling engine
pub struct NeuralUpscaler {
    /// Configuration
    config: UpscaleConfig,
    /// Output dimensions
    output_width: usize,
    output_height: usize,
    /// Render dimensions
    render_width: usize,
    render_height: usize,
    /// ESPCN model
    espcn: Option<ESPCN>,
    /// EDSR model
    edsr: Option<EDSR>,
    /// RCAN model
    rcan: Option<RCAN>,
    /// SwinIR model
    swinir: Option<SwinIR>,
    /// Real-ESRGAN model
    real_esrgan: Option<RealESRGAN>,
    /// Temporal SR
    temporal_sr: Option<TemporalSR>,
    /// FSR upscaler
    fsr: Option<FSRUpscaler>,
    /// Inference session
    session: Option<InferenceSession>,
    /// Frame count
    frame_count: usize,
}

impl NeuralUpscaler {
    pub fn new(config: UpscaleConfig, output_width: usize, output_height: usize) -> Self {
        let (render_width, render_height) = config.quality.render_resolution(
            output_width as u32,
            output_height as u32,
        );

        let scale = (output_width as f32 / render_width as f32).round() as usize;

        let mut upscaler = Self {
            config,
            output_width,
            output_height,
            render_width: render_width as usize,
            render_height: render_height as usize,
            espcn: None,
            edsr: None,
            rcan: None,
            swinir: None,
            real_esrgan: None,
            temporal_sr: None,
            fsr: None,
            session: None,
            frame_count: 0,
        };

        // Initialize the appropriate model
        upscaler.init_model(scale);

        upscaler
    }

    fn init_model(&mut self, scale: usize) {
        match self.config.method {
            UpscaleMethod::Bicubic | UpscaleMethod::Lanczos => {
                // No neural network needed
            }
            UpscaleMethod::ESPCN => {
                self.espcn = Some(ESPCN::new(scale, 3, 64));
            }
            UpscaleMethod::EDSR => {
                self.edsr = Some(EDSR::new_baseline(scale));
            }
            UpscaleMethod::RCAN => {
                self.rcan = Some(RCAN::new_default(scale));
            }
            UpscaleMethod::SwinIR => {
                self.swinir = Some(SwinIR::new_lightweight(scale));
            }
            UpscaleMethod::RealESRGAN => {
                self.real_esrgan = Some(RealESRGAN::new_x4());
            }
            UpscaleMethod::TemporalSR => {
                self.temporal_sr = Some(TemporalSR::new(
                    scale,
                    self.render_width,
                    self.render_height,
                    64,
                    4,
                ));
            }
            UpscaleMethod::FSRStyle => {
                self.fsr = Some(FSRUpscaler::new(scale as f32, self.config.sharpening));
            }
            UpscaleMethod::CustomNetwork => {
                // Load custom ONNX model
                if let Some(ref path) = self.config.model_path {
                    // self.session = Some(InferenceSession::load(path));
                }
            }
        }
    }

    pub fn upscale(&mut self, input: &Tensor) -> Tensor {
        match self.config.method {
            UpscaleMethod::Bicubic => self.bicubic_upscale(input),
            UpscaleMethod::Lanczos => self.lanczos_upscale(input),
            UpscaleMethod::ESPCN => {
                if let Some(ref model) = self.espcn {
                    model.forward(input)
                } else {
                    self.bicubic_upscale(input)
                }
            }
            UpscaleMethod::EDSR => {
                if let Some(ref model) = self.edsr {
                    model.forward(input)
                } else {
                    self.bicubic_upscale(input)
                }
            }
            UpscaleMethod::RCAN => {
                if let Some(ref model) = self.rcan {
                    model.forward(input)
                } else {
                    self.bicubic_upscale(input)
                }
            }
            UpscaleMethod::SwinIR => {
                if let Some(ref model) = self.swinir {
                    model.forward(input)
                } else {
                    self.bicubic_upscale(input)
                }
            }
            UpscaleMethod::RealESRGAN => {
                if let Some(ref model) = self.real_esrgan {
                    model.forward(input)
                } else {
                    self.bicubic_upscale(input)
                }
            }
            UpscaleMethod::TemporalSR | UpscaleMethod::FSRStyle => {
                // These need motion/depth - use simple upscale fallback
                self.bicubic_upscale(input)
            }
            UpscaleMethod::CustomNetwork => {
                // Run ONNX inference
                self.bicubic_upscale(input)
            }
        }
    }

    pub fn upscale_temporal(
        &mut self,
        color: &Tensor,
        depth: &Tensor,
        motion: &Tensor,
        exposure: f32,
    ) -> Tensor {
        self.frame_count += 1;

        match self.config.method {
            UpscaleMethod::TemporalSR => {
                if let Some(ref mut tsr) = self.temporal_sr {
                    tsr.upscale(color, depth, motion, exposure)
                } else {
                    self.upscale(color)
                }
            }
            UpscaleMethod::FSRStyle => {
                if let Some(ref fsr) = self.fsr {
                    fsr.forward(color)
                } else {
                    self.upscale(color)
                }
            }
            _ => self.upscale(color),
        }
    }

    fn bicubic_upscale(&self, input: &Tensor) -> Tensor {
        let scale_x = self.output_width as f32 / input.shape().dim(3) as f32;
        let scale_y = self.output_height as f32 / input.shape().dim(2) as f32;

        let upsample = Upsample::new(scale_x, "bicubic");
        upsample.forward(input)
    }

    fn lanczos_upscale(&self, input: &Tensor) -> Tensor {
        // Lanczos is essentially bicubic with different kernel
        self.bicubic_upscale(input)
    }

    pub fn get_jitter(&mut self) -> Option<(f32, f32)> {
        if let Some(ref mut tsr) = self.temporal_sr {
            Some(tsr.get_jitter())
        } else {
            None
        }
    }

    pub fn reset_temporal(&mut self) {
        if let Some(ref mut tsr) = self.temporal_sr {
            tsr.reset();
        }
        self.frame_count = 0;
    }

    pub fn render_resolution(&self) -> (usize, usize) {
        (self.render_width, self.render_height)
    }

    pub fn output_resolution(&self) -> (usize, usize) {
        (self.output_width, self.output_height)
    }

    pub fn set_quality(&mut self, quality: UpscaleQuality) {
        let (render_width, render_height) = quality.render_resolution(
            self.output_width as u32,
            self.output_height as u32,
        );

        self.render_width = render_width as usize;
        self.render_height = render_height as usize;
        self.config.quality = quality;

        // Reinitialize model with new scale
        let scale = (self.output_width as f32 / render_width as f32).round() as usize;
        self.init_model(scale);
    }

    pub fn set_sharpening(&mut self, strength: f32) {
        self.config.sharpening = strength.clamp(0.0, 1.0);

        if let Some(ref mut tsr) = self.temporal_sr {
            tsr.set_sharpening(strength);
        }
        if let Some(ref mut fsr) = self.fsr {
            fsr.rcas.sharpness = strength * 2.0;
        }
    }

    pub fn model_name(&self) -> &str {
        match self.config.method {
            UpscaleMethod::Bicubic => "Bicubic",
            UpscaleMethod::Lanczos => "Lanczos",
            UpscaleMethod::ESPCN => "ESPCN",
            UpscaleMethod::EDSR => "EDSR",
            UpscaleMethod::RCAN => "RCAN",
            UpscaleMethod::SwinIR => "SwinIR",
            UpscaleMethod::RealESRGAN => "Real-ESRGAN",
            UpscaleMethod::TemporalSR => "Temporal SR",
            UpscaleMethod::FSRStyle => "FSR-Style",
            UpscaleMethod::CustomNetwork => "Custom",
        }
    }
}

// ============================================================================
// PERCEPTUAL LOSS FOR TRAINING
// ============================================================================

/// VGG feature extractor for perceptual loss
pub struct VGGFeatureExtractor {
    /// VGG layers
    layers: Vec<Conv2d>,
    /// ReLU activations
    relus: Vec<ReLU>,
    /// Max pooling
    pools: Vec<MaxPool2d>,
    /// Feature layer indices to extract
    feature_layers: Vec<usize>,
}

pub struct MaxPool2d {
    kernel_size: (usize, usize),
    stride: (usize, usize),
    padding: (usize, usize),
}

impl MaxPool2d {
    pub fn new(kernel_size: (usize, usize), stride: (usize, usize), padding: (usize, usize)) -> Self {
        Self {
            kernel_size,
            stride,
            padding,
        }
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        // Max pooling implementation
        input.clone() // Simplified
    }
}

impl VGGFeatureExtractor {
    pub fn new_vgg19(feature_layers: Vec<usize>) -> Self {
        // VGG19 configuration
        let cfg = [64, 64, 'M', 128, 128, 'M', 256, 256, 256, 256, 'M',
                   512, 512, 512, 512, 'M', 512, 512, 512, 512, 'M'];

        let mut layers = Vec::new();
        let mut relus = Vec::new();
        let mut pools = Vec::new();

        let mut in_channels = 3;

        for &c in &cfg {
            match c {
                'M' => {
                    pools.push(MaxPool2d::new((2, 2), (2, 2), (0, 0)));
                }
                n if n > 0 => {
                    let out_channels = n as usize;
                    layers.push(Conv2d::new(
                        in_channels,
                        out_channels,
                        (3, 3),
                        (1, 1),
                        (1, 1),
                        (1, 1),
                        1,
                        true,
                    ));
                    relus.push(ReLU::new());
                    in_channels = out_channels;
                }
                _ => {}
            }
        }

        Self {
            layers,
            relus,
            pools,
            feature_layers,
        }
    }

    pub fn forward(&self, input: &Tensor) -> Vec<Tensor> {
        let mut features = Vec::new();
        let mut x = input.clone();
        let mut layer_idx = 0;
        let mut pool_idx = 0;

        for i in 0..self.layers.len() {
            x = self.layers[i].forward(&x);
            x = self.relus[i].forward(&x);

            if self.feature_layers.contains(&layer_idx) {
                features.push(x.clone());
            }

            layer_idx += 1;

            // Apply pooling after certain layers
            if pool_idx < self.pools.len() && (layer_idx == 2 || layer_idx == 4 ||
               layer_idx == 8 || layer_idx == 12 || layer_idx == 16) {
                x = self.pools[pool_idx].forward(&x);
                pool_idx += 1;
            }
        }

        features
    }
}

/// Perceptual loss using VGG features
pub struct PerceptualLoss {
    /// VGG feature extractor
    vgg: VGGFeatureExtractor,
    /// Loss weights for each feature layer
    weights: Vec<f32>,
    /// L1 loss
    l1_loss: L1Loss,
}

impl PerceptualLoss {
    pub fn new(feature_layers: Vec<usize>, weights: Vec<f32>) -> Self {
        Self {
            vgg: VGGFeatureExtractor::new_vgg19(feature_layers),
            weights,
            l1_loss: L1Loss::new(),
        }
    }

    pub fn forward(&self, pred: &Tensor, target: &Tensor) -> f32 {
        let pred_features = self.vgg.forward(pred);
        let target_features = self.vgg.forward(target);

        let mut total_loss = 0.0f32;

        for (i, (pf, tf)) in pred_features.iter().zip(target_features.iter()).enumerate() {
            let weight = if i < self.weights.len() { self.weights[i] } else { 1.0 };
            total_loss += weight * self.l1_loss.forward(pf, tf);
        }

        total_loss
    }
}

/// GAN discriminator for super-resolution
pub struct SRDiscriminator {
    /// Feature extraction layers
    features: Vec<Conv2d>,
    /// Batch normalizations
    bns: Vec<BatchNorm2d>,
    /// Leaky ReLU
    lrelu: LeakyReLU,
    /// Classifier
    classifier: Vec<Linear>,
}

impl SRDiscriminator {
    pub fn new(in_channels: usize, num_features: usize) -> Self {
        let mut features = Vec::new();
        let mut bns = Vec::new();

        // Layer configurations: (out_channels, stride)
        let cfg = [
            (num_features, 1),
            (num_features, 2),
            (num_features * 2, 1),
            (num_features * 2, 2),
            (num_features * 4, 1),
            (num_features * 4, 2),
            (num_features * 8, 1),
            (num_features * 8, 2),
        ];

        let mut in_ch = in_channels;
        for (i, &(out_ch, stride)) in cfg.iter().enumerate() {
            features.push(Conv2d::new(
                in_ch,
                out_ch,
                (3, 3),
                (stride, stride),
                (1, 1),
                (1, 1),
                1,
                true,
            ));
            if i > 0 {
                bns.push(BatchNorm2d::new(out_ch, 1e-5, 0.1, true));
            }
            in_ch = out_ch;
        }

        // Classifier
        let classifier = vec![
            Linear::new(num_features * 8 * 6 * 6, 1024, true),
            Linear::new(1024, 1, true),
        ];

        Self {
            features,
            bns,
            lrelu: LeakyReLU::new(0.2),
            classifier,
        }
    }

    pub fn forward(&self, input: &Tensor) -> Tensor {
        let mut x = input.clone();
        let mut bn_idx = 0;

        for (i, conv) in self.features.iter().enumerate() {
            x = conv.forward(&x);
            if i > 0 {
                x = self.bns[bn_idx].forward(&x);
                bn_idx += 1;
            }
            x = self.lrelu.forward(&x);
        }

        // Flatten
        let shape = x.shape();
        let batch = shape.dim(0);
        x = x.reshape(&[batch, shape.dim(1) * shape.dim(2) * shape.dim(3)]);

        // Classifier
        x = self.classifier[0].forward(&x);
        x = self.lrelu.forward(&x);
        self.classifier[1].forward(&x)
    }
}

