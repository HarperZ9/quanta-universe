// ============================================================================
// NEUTRINO: Neural Rendering Engine for Real-Time Graphics
// ============================================================================
// A comprehensive neural network framework optimized for real-time rendering
// applications including super-resolution, denoising, and neural radiance fields.
//
// Core Features:
// - GPU-accelerated tensor operations
// - Optimized inference engine
// - Pre-trained model support (ONNX, TensorRT)
// - Real-time super-resolution (DLSS-like)
// - Neural denoising for ray tracing
// - Neural radiance fields (NeRF)
// - Image enhancement networks
// ============================================================================

module neutrino;

pub mod inference;
pub mod upscaling;
pub mod denoise;
pub mod enhancement;
pub mod nerf;

use core::mem;
use core::ptr;
use core::simd::{f32x4, f32x8, f32x16};

// ============================================================================
// REGION: Data Types
// ============================================================================

/// Supported data types for tensors
#[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
pub enum DataType {
    /// 32-bit floating point
    Float32,
    /// 16-bit floating point (half precision)
    Float16,
    /// Brain floating point (truncated float32)
    BFloat16,
    /// 8-bit signed integer
    Int8,
    /// 8-bit unsigned integer
    UInt8,
    /// 32-bit signed integer
    Int32,
    /// 64-bit signed integer
    Int64,
    /// Boolean
    Bool,
    /// 4-bit integer (quantized)
    Int4,
    /// 8-bit floating point (E4M3)
    Float8E4M3,
    /// 8-bit floating point (E5M2)
    Float8E5M2,
}

impl DataType {
    /// Get the size in bytes of this data type
    pub fn size_bytes(self) -> usize {
        match self {
            DataType::Float32 => 4,
            DataType::Float16 => 2,
            DataType::BFloat16 => 2,
            DataType::Int8 => 1,
            DataType::UInt8 => 1,
            DataType::Int32 => 4,
            DataType::Int64 => 8,
            DataType::Bool => 1,
            DataType::Int4 => 1, // Packed, 2 values per byte
            DataType::Float8E4M3 => 1,
            DataType::Float8E5M2 => 1,
        }
    }

    /// Check if this is a floating point type
    pub fn is_floating_point(self) -> bool {
        matches!(self,
            DataType::Float32 |
            DataType::Float16 |
            DataType::BFloat16 |
            DataType::Float8E4M3 |
            DataType::Float8E5M2
        )
    }

    /// Check if this is an integer type
    pub fn is_integer(self) -> bool {
        matches!(self,
            DataType::Int8 |
            DataType::UInt8 |
            DataType::Int32 |
            DataType::Int64 |
            DataType::Int4
        )
    }

    /// Check if this is a quantized type
    pub fn is_quantized(self) -> bool {
        matches!(self,
            DataType::Int8 |
            DataType::Int4 |
            DataType::Float8E4M3 |
            DataType::Float8E5M2
        )
    }
}

// ============================================================================
// REGION: Half-Precision Float Support
// ============================================================================

/// 16-bit floating point number (IEEE 754 half-precision)
#[derive(Clone, Copy, Default)]
#[repr(transparent)]
pub struct Float16(u16);

impl Float16 {
    pub const ZERO: Float16 = Float16(0x0000);
    pub const ONE: Float16 = Float16(0x3C00);
    pub const NEG_ONE: Float16 = Float16(0xBC00);
    pub const INFINITY: Float16 = Float16(0x7C00);
    pub const NEG_INFINITY: Float16 = Float16(0xFC00);
    pub const NAN: Float16 = Float16(0x7E00);
    pub const MIN: Float16 = Float16(0xFBFF);
    pub const MAX: Float16 = Float16(0x7BFF);
    pub const EPSILON: Float16 = Float16(0x1400);

    /// Create from raw bits
    pub const fn from_bits(bits: u16) -> Self {
        Float16(bits)
    }

    /// Get raw bits
    pub const fn to_bits(self) -> u16 {
        self.0
    }

    /// Convert from f32
    pub fn from_f32(value: f32) -> Self {
        let bits = value.to_bits();
        let sign = (bits >> 31) & 1;
        let exponent = ((bits >> 23) & 0xFF) as i32;
        let mantissa = bits & 0x7FFFFF;

        if exponent == 0xFF {
            // Infinity or NaN
            if mantissa == 0 {
                Float16(((sign << 15) | 0x7C00) as u16)
            } else {
                Float16(((sign << 15) | 0x7E00) as u16)
            }
        } else if exponent == 0 {
            // Subnormal or zero
            Float16((sign << 15) as u16)
        } else {
            let new_exp = exponent - 127 + 15;
            if new_exp >= 31 {
                // Overflow to infinity
                Float16(((sign << 15) | 0x7C00) as u16)
            } else if new_exp <= 0 {
                // Underflow to zero or subnormal
                if new_exp < -10 {
                    Float16((sign << 15) as u16)
                } else {
                    let mant = (mantissa | 0x800000) >> (1 - new_exp);
                    Float16(((sign << 15) | ((mant >> 13) as u32)) as u16)
                }
            } else {
                let new_mant = mantissa >> 13;
                Float16(((sign << 15) | ((new_exp as u32) << 10) | new_mant) as u16)
            }
        }
    }

    /// Convert to f32
    pub fn to_f32(self) -> f32 {
        let bits = self.0 as u32;
        let sign = (bits >> 15) & 1;
        let exponent = (bits >> 10) & 0x1F;
        let mantissa = bits & 0x3FF;

        if exponent == 0x1F {
            // Infinity or NaN
            if mantissa == 0 {
                f32::from_bits((sign << 31) | 0x7F800000)
            } else {
                f32::from_bits((sign << 31) | 0x7FC00000)
            }
        } else if exponent == 0 {
            if mantissa == 0 {
                // Zero
                f32::from_bits(sign << 31)
            } else {
                // Subnormal
                let mut mant = mantissa;
                let mut exp = 1i32;
                while (mant & 0x400) == 0 {
                    mant <<= 1;
                    exp -= 1;
                }
                mant &= 0x3FF;
                let new_exp = (127 - 15 + exp) as u32;
                f32::from_bits((sign << 31) | (new_exp << 23) | (mant << 13))
            }
        } else {
            let new_exp = (exponent as i32 - 15 + 127) as u32;
            f32::from_bits((sign << 31) | (new_exp << 23) | (mantissa << 13))
        }
    }
}

/// BFloat16 - Brain floating point (truncated float32)
#[derive(Clone, Copy, Default)]
#[repr(transparent)]
pub struct BFloat16(u16);

impl BFloat16 {
    pub const ZERO: BFloat16 = BFloat16(0x0000);
    pub const ONE: BFloat16 = BFloat16(0x3F80);

    /// Create from raw bits
    pub const fn from_bits(bits: u16) -> Self {
        BFloat16(bits)
    }

    /// Get raw bits
    pub const fn to_bits(self) -> u16 {
        self.0
    }

    /// Convert from f32 (simple truncation)
    pub fn from_f32(value: f32) -> Self {
        let bits = value.to_bits();
        // Round to nearest even
        let round_bit = (bits >> 15) & 1;
        let sticky_bit = if (bits & 0x7FFF) != 0 { 1 } else { 0 };
        let upper = (bits >> 16) as u16;
        if round_bit == 1 && (sticky_bit == 1 || (upper & 1) == 1) {
            BFloat16(upper.wrapping_add(1))
        } else {
            BFloat16(upper)
        }
    }

    /// Convert to f32
    pub fn to_f32(self) -> f32 {
        f32::from_bits((self.0 as u32) << 16)
    }
}

// ============================================================================
// REGION: Tensor Shape
// ============================================================================

/// Maximum number of dimensions for a tensor
pub const MAX_DIMS: usize = 8;

/// Tensor shape with up to MAX_DIMS dimensions
#[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
pub struct Shape {
    dims: [usize; MAX_DIMS],
    ndim: usize,
}

impl Shape {
    /// Create a scalar shape (0 dimensions)
    pub const fn scalar() -> Self {
        Shape {
            dims: [0; MAX_DIMS],
            ndim: 0,
        }
    }

    /// Create a 1D shape
    pub const fn d1(d0: usize) -> Self {
        let mut dims = [0; MAX_DIMS];
        dims[0] = d0;
        Shape { dims, ndim: 1 }
    }

    /// Create a 2D shape
    pub const fn d2(d0: usize, d1: usize) -> Self {
        let mut dims = [0; MAX_DIMS];
        dims[0] = d0;
        dims[1] = d1;
        Shape { dims, ndim: 2 }
    }

    /// Create a 3D shape
    pub const fn d3(d0: usize, d1: usize, d2: usize) -> Self {
        let mut dims = [0; MAX_DIMS];
        dims[0] = d0;
        dims[1] = d1;
        dims[2] = d2;
        Shape { dims, ndim: 3 }
    }

    /// Create a 4D shape (common for NCHW tensors)
    pub const fn d4(d0: usize, d1: usize, d2: usize, d3: usize) -> Self {
        let mut dims = [0; MAX_DIMS];
        dims[0] = d0;
        dims[1] = d1;
        dims[2] = d2;
        dims[3] = d3;
        Shape { dims, ndim: 4 }
    }

    /// Create a 5D shape
    pub const fn d5(d0: usize, d1: usize, d2: usize, d3: usize, d4: usize) -> Self {
        let mut dims = [0; MAX_DIMS];
        dims[0] = d0;
        dims[1] = d1;
        dims[2] = d2;
        dims[3] = d3;
        dims[4] = d4;
        Shape { dims, ndim: 5 }
    }

    /// Create from a slice of dimensions
    pub fn from_slice(dims: &[usize]) -> Self {
        assert!(dims.len() <= MAX_DIMS, "Too many dimensions");
        let mut shape = Shape {
            dims: [0; MAX_DIMS],
            ndim: dims.len(),
        };
        for (i, &d) in dims.iter().enumerate() {
            shape.dims[i] = d;
        }
        shape
    }

    /// Get the number of dimensions
    pub const fn ndim(&self) -> usize {
        self.ndim
    }

    /// Get dimension at index
    pub fn dim(&self, index: usize) -> usize {
        assert!(index < self.ndim, "Dimension index out of bounds");
        self.dims[index]
    }

    /// Get dimensions as a slice
    pub fn as_slice(&self) -> &[usize] {
        &self.dims[..self.ndim]
    }

    /// Total number of elements
    pub fn numel(&self) -> usize {
        if self.ndim == 0 {
            1
        } else {
            self.dims[..self.ndim].iter().product()
        }
    }

    /// Check if shape is empty (has a zero dimension)
    pub fn is_empty(&self) -> bool {
        self.dims[..self.ndim].iter().any(|&d| d == 0)
    }

    /// Compute strides for contiguous layout
    pub fn contiguous_strides(&self) -> [usize; MAX_DIMS] {
        let mut strides = [0; MAX_DIMS];
        if self.ndim > 0 {
            strides[self.ndim - 1] = 1;
            for i in (0..self.ndim - 1).rev() {
                strides[i] = strides[i + 1] * self.dims[i + 1];
            }
        }
        strides
    }

    /// Reshape to new dimensions (must have same numel)
    pub fn reshape(&self, new_dims: &[usize]) -> Option<Shape> {
        let new_shape = Shape::from_slice(new_dims);
        if self.numel() == new_shape.numel() {
            Some(new_shape)
        } else {
            None
        }
    }

    /// Broadcast shapes together
    pub fn broadcast(a: &Shape, b: &Shape) -> Option<Shape> {
        let max_ndim = a.ndim.max(b.ndim);
        let mut result = Shape {
            dims: [0; MAX_DIMS],
            ndim: max_ndim,
        };

        for i in 0..max_ndim {
            let a_dim = if i < a.ndim { a.dims[a.ndim - 1 - i] } else { 1 };
            let b_dim = if i < b.ndim { b.dims[b.ndim - 1 - i] } else { 1 };

            if a_dim == b_dim {
                result.dims[max_ndim - 1 - i] = a_dim;
            } else if a_dim == 1 {
                result.dims[max_ndim - 1 - i] = b_dim;
            } else if b_dim == 1 {
                result.dims[max_ndim - 1 - i] = a_dim;
            } else {
                return None; // Not broadcastable
            }
        }

        Some(result)
    }

    /// Squeeze (remove dimensions of size 1)
    pub fn squeeze(&self) -> Shape {
        let mut result = Shape {
            dims: [0; MAX_DIMS],
            ndim: 0,
        };
        for i in 0..self.ndim {
            if self.dims[i] != 1 {
                result.dims[result.ndim] = self.dims[i];
                result.ndim += 1;
            }
        }
        if result.ndim == 0 {
            result.ndim = 1;
            result.dims[0] = 1;
        }
        result
    }

    /// Unsqueeze (add dimension of size 1 at index)
    pub fn unsqueeze(&self, dim: usize) -> Shape {
        assert!(dim <= self.ndim, "Invalid dimension for unsqueeze");
        assert!(self.ndim < MAX_DIMS, "Cannot add more dimensions");

        let mut result = Shape {
            dims: [0; MAX_DIMS],
            ndim: self.ndim + 1,
        };
        for i in 0..dim {
            result.dims[i] = self.dims[i];
        }
        result.dims[dim] = 1;
        for i in dim..self.ndim {
            result.dims[i + 1] = self.dims[i];
        }
        result
    }

    /// Transpose two dimensions
    pub fn transpose(&self, dim0: usize, dim1: usize) -> Shape {
        assert!(dim0 < self.ndim && dim1 < self.ndim, "Invalid dimensions");
        let mut result = *self;
        result.dims.swap(dim0, dim1);
        result
    }

    /// Permute dimensions
    pub fn permute(&self, dims: &[usize]) -> Shape {
        assert_eq!(dims.len(), self.ndim, "Permutation length must match ndim");
        let mut result = Shape {
            dims: [0; MAX_DIMS],
            ndim: self.ndim,
        };
        for (i, &d) in dims.iter().enumerate() {
            assert!(d < self.ndim, "Invalid dimension in permutation");
            result.dims[i] = self.dims[d];
        }
        result
    }
}

impl std::fmt::Display for Shape {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "(")?;
        for i in 0..self.ndim {
            if i > 0 {
                write!(f, ", ")?;
            }
            write!(f, "{}", self.dims[i])?;
        }
        if self.ndim == 1 {
            write!(f, ",")?;
        }
        write!(f, ")")
    }
}

// ============================================================================
// REGION: Memory Layout
// ============================================================================

/// Memory layout for tensors
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum Layout {
    /// Contiguous row-major (C-order)
    RowMajor,
    /// Contiguous column-major (Fortran-order)
    ColumnMajor,
    /// Strided (non-contiguous)
    Strided,
    /// Channels-first (NCHW)
    ChannelsFirst,
    /// Channels-last (NHWC)
    ChannelsLast,
}

/// Device type for tensor storage
#[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
pub enum Device {
    /// CPU memory
    Cpu,
    /// GPU memory (CUDA/DirectX)
    Gpu(u32),
    /// Unified memory (accessible from both CPU and GPU)
    Unified(u32),
}

impl Device {
    /// Get the GPU index if this is a GPU device
    pub fn gpu_index(&self) -> Option<u32> {
        match self {
            Device::Gpu(idx) | Device::Unified(idx) => Some(*idx),
            Device::Cpu => None,
        }
    }

    /// Check if this is a GPU device
    pub fn is_gpu(&self) -> bool {
        matches!(self, Device::Gpu(_) | Device::Unified(_))
    }
}

// ============================================================================
// REGION: Tensor Storage
// ============================================================================

/// Raw tensor storage
pub struct TensorStorage {
    data: *mut u8,
    size_bytes: usize,
    dtype: DataType,
    device: Device,
    owns_data: bool,
}

impl TensorStorage {
    /// Allocate new storage
    pub fn allocate(size_bytes: usize, dtype: DataType, device: Device) -> Self {
        let data = match device {
            Device::Cpu => {
                let layout = std::alloc::Layout::from_size_align(size_bytes, 64).unwrap();
                unsafe { std::alloc::alloc_zeroed(layout) }
            }
            Device::Gpu(_) | Device::Unified(_) => {
                // GPU allocation would go through CUDA/DirectX
                // For now, allocate on CPU
                let layout = std::alloc::Layout::from_size_align(size_bytes, 64).unwrap();
                unsafe { std::alloc::alloc_zeroed(layout) }
            }
        };

        TensorStorage {
            data,
            size_bytes,
            dtype,
            device,
            owns_data: true,
        }
    }

    /// Create from existing pointer (does not take ownership)
    pub unsafe fn from_ptr(data: *mut u8, size_bytes: usize, dtype: DataType, device: Device) -> Self {
        TensorStorage {
            data,
            size_bytes,
            dtype,
            device,
            owns_data: false,
        }
    }

    /// Get raw pointer
    pub fn as_ptr(&self) -> *const u8 {
        self.data
    }

    /// Get mutable raw pointer
    pub fn as_mut_ptr(&mut self) -> *mut u8 {
        self.data
    }

    /// Get data as typed slice
    pub fn as_slice<T>(&self) -> &[T] {
        let len = self.size_bytes / std::mem::size_of::<T>();
        unsafe { std::slice::from_raw_parts(self.data as *const T, len) }
    }

    /// Get data as mutable typed slice
    pub fn as_mut_slice<T>(&mut self) -> &mut [T] {
        let len = self.size_bytes / std::mem::size_of::<T>();
        unsafe { std::slice::from_raw_parts_mut(self.data as *mut T, len) }
    }

    /// Copy data from another storage
    pub fn copy_from(&mut self, other: &TensorStorage) {
        assert_eq!(self.size_bytes, other.size_bytes);
        assert_eq!(self.dtype, other.dtype);

        // Handle cross-device copies
        match (self.device, other.device) {
            (Device::Cpu, Device::Cpu) => unsafe {
                ptr::copy_nonoverlapping(other.data, self.data, self.size_bytes);
            },
            _ => {
                // GPU transfers would use CUDA/DirectX APIs
                unsafe {
                    ptr::copy_nonoverlapping(other.data, self.data, self.size_bytes);
                }
            }
        }
    }
}

impl Drop for TensorStorage {
    fn drop(&mut self) {
        if self.owns_data && !self.data.is_null() {
            match self.device {
                Device::Cpu => {
                    let layout = std::alloc::Layout::from_size_align(self.size_bytes, 64).unwrap();
                    unsafe { std::alloc::dealloc(self.data, layout) };
                }
                Device::Gpu(_) | Device::Unified(_) => {
                    // GPU deallocation
                    let layout = std::alloc::Layout::from_size_align(self.size_bytes, 64).unwrap();
                    unsafe { std::alloc::dealloc(self.data, layout) };
                }
            }
        }
    }
}

// ============================================================================
// REGION: Tensor
// ============================================================================

/// N-dimensional tensor
pub struct Tensor {
    storage: TensorStorage,
    shape: Shape,
    strides: [usize; MAX_DIMS],
    offset: usize,
    dtype: DataType,
    requires_grad: bool,
    grad: Option<Box<Tensor>>,
    name: Option<String>,
}

impl Tensor {
    /// Create a new tensor filled with zeros
    pub fn zeros(shape: Shape, dtype: DataType, device: Device) -> Self {
        let size_bytes = shape.numel() * dtype.size_bytes();
        let storage = TensorStorage::allocate(size_bytes, dtype, device);
        let strides = shape.contiguous_strides();

        Tensor {
            storage,
            shape,
            strides,
            offset: 0,
            dtype,
            requires_grad: false,
            grad: None,
            name: None,
        }
    }

    /// Create a new tensor filled with ones
    pub fn ones(shape: Shape, dtype: DataType, device: Device) -> Self {
        let mut tensor = Self::zeros(shape, dtype, device);
        tensor.fill_scalar(1.0);
        tensor
    }

    /// Create a tensor from a slice of f32 values
    pub fn from_slice_f32(data: &[f32], shape: Shape, device: Device) -> Self {
        assert_eq!(data.len(), shape.numel(), "Data length must match shape");
        let mut tensor = Self::zeros(shape, DataType::Float32, device);
        tensor.storage.as_mut_slice::<f32>().copy_from_slice(data);
        tensor
    }

    /// Create a tensor from a slice of f16 values
    pub fn from_slice_f16(data: &[Float16], shape: Shape, device: Device) -> Self {
        assert_eq!(data.len(), shape.numel(), "Data length must match shape");
        let mut tensor = Self::zeros(shape, DataType::Float16, device);
        let storage_slice = tensor.storage.as_mut_slice::<u16>();
        for (i, &val) in data.iter().enumerate() {
            storage_slice[i] = val.to_bits();
        }
        tensor
    }

    /// Create a random tensor with uniform distribution [0, 1)
    pub fn rand(shape: Shape, dtype: DataType, device: Device) -> Self {
        let mut tensor = Self::zeros(shape, dtype, device);
        let data = tensor.storage.as_mut_slice::<f32>();
        let mut rng = XorShift64::new(0x12345678);
        for val in data.iter_mut() {
            *val = rng.next_f32();
        }
        tensor
    }

    /// Create a random tensor with normal distribution (mean=0, std=1)
    pub fn randn(shape: Shape, dtype: DataType, device: Device) -> Self {
        let mut tensor = Self::zeros(shape, dtype, device);
        let data = tensor.storage.as_mut_slice::<f32>();
        let mut rng = XorShift64::new(0x12345678);

        // Box-Muller transform
        let mut i = 0;
        while i < data.len() {
            let u1 = rng.next_f32().max(1e-10);
            let u2 = rng.next_f32();
            let mag = (-2.0 * u1.ln()).sqrt();
            let z0 = mag * (2.0 * std::f32::consts::PI * u2).cos();
            let z1 = mag * (2.0 * std::f32::consts::PI * u2).sin();
            data[i] = z0;
            if i + 1 < data.len() {
                data[i + 1] = z1;
            }
            i += 2;
        }
        tensor
    }

    /// Create an identity matrix
    pub fn eye(n: usize, dtype: DataType, device: Device) -> Self {
        let shape = Shape::d2(n, n);
        let mut tensor = Self::zeros(shape, dtype, device);
        let data = tensor.storage.as_mut_slice::<f32>();
        for i in 0..n {
            data[i * n + i] = 1.0;
        }
        tensor
    }

    /// Create a tensor with evenly spaced values
    pub fn linspace(start: f32, end: f32, steps: usize, device: Device) -> Self {
        let shape = Shape::d1(steps);
        let mut tensor = Self::zeros(shape, DataType::Float32, device);
        let data = tensor.storage.as_mut_slice::<f32>();

        if steps == 1 {
            data[0] = start;
        } else {
            let step = (end - start) / (steps - 1) as f32;
            for i in 0..steps {
                data[i] = start + i as f32 * step;
            }
        }
        tensor
    }

    /// Create a tensor with values from start to end with step
    pub fn arange(start: f32, end: f32, step: f32, device: Device) -> Self {
        let steps = ((end - start) / step).ceil() as usize;
        let shape = Shape::d1(steps);
        let mut tensor = Self::zeros(shape, DataType::Float32, device);
        let data = tensor.storage.as_mut_slice::<f32>();

        for i in 0..steps {
            data[i] = start + i as f32 * step;
        }
        tensor
    }

    /// Get the shape
    pub fn shape(&self) -> &Shape {
        &self.shape
    }

    /// Get the data type
    pub fn dtype(&self) -> DataType {
        self.dtype
    }

    /// Get the device
    pub fn device(&self) -> Device {
        self.storage.device
    }

    /// Get number of elements
    pub fn numel(&self) -> usize {
        self.shape.numel()
    }

    /// Get number of dimensions
    pub fn ndim(&self) -> usize {
        self.shape.ndim()
    }

    /// Check if tensor requires gradient
    pub fn requires_grad(&self) -> bool {
        self.requires_grad
    }

    /// Set requires_grad flag
    pub fn set_requires_grad(&mut self, requires: bool) {
        self.requires_grad = requires;
    }

    /// Get gradient tensor
    pub fn grad(&self) -> Option<&Tensor> {
        self.grad.as_ref().map(|b| b.as_ref())
    }

    /// Set gradient tensor
    pub fn set_grad(&mut self, grad: Tensor) {
        self.grad = Some(Box::new(grad));
    }

    /// Get tensor name
    pub fn name(&self) -> Option<&str> {
        self.name.as_deref()
    }

    /// Set tensor name
    pub fn set_name(&mut self, name: impl Into<String>) {
        self.name = Some(name.into());
    }

    /// Fill tensor with a scalar value
    pub fn fill_scalar(&mut self, value: f32) {
        match self.dtype {
            DataType::Float32 => {
                let data = self.storage.as_mut_slice::<f32>();
                for val in data.iter_mut() {
                    *val = value;
                }
            }
            DataType::Float16 => {
                let data = self.storage.as_mut_slice::<u16>();
                let half = Float16::from_f32(value);
                for val in data.iter_mut() {
                    *val = half.to_bits();
                }
            }
            _ => {
                // Other types
            }
        }
    }

    /// Get data as f32 slice (only for Float32 tensors)
    pub fn as_f32_slice(&self) -> Option<&[f32]> {
        if self.dtype == DataType::Float32 {
            Some(self.storage.as_slice())
        } else {
            None
        }
    }

    /// Get data as mutable f32 slice
    pub fn as_f32_slice_mut(&mut self) -> Option<&mut [f32]> {
        if self.dtype == DataType::Float32 {
            Some(self.storage.as_mut_slice())
        } else {
            None
        }
    }

    /// Reshape tensor
    pub fn reshape(&self, new_shape: Shape) -> Option<Tensor> {
        if self.shape.numel() != new_shape.numel() {
            return None;
        }

        let strides = new_shape.contiguous_strides();
        let size_bytes = new_shape.numel() * self.dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, self.dtype, self.storage.device);
        storage.copy_from(&self.storage);

        Some(Tensor {
            storage,
            shape: new_shape,
            strides,
            offset: 0,
            dtype: self.dtype,
            requires_grad: self.requires_grad,
            grad: None,
            name: self.name.clone(),
        })
    }

    /// Squeeze tensor (remove dimensions of size 1)
    pub fn squeeze(&self) -> Tensor {
        let new_shape = self.shape.squeeze();
        self.reshape(new_shape).unwrap()
    }

    /// Unsqueeze tensor (add dimension of size 1)
    pub fn unsqueeze(&self, dim: usize) -> Tensor {
        let new_shape = self.shape.unsqueeze(dim);
        self.reshape(new_shape).unwrap()
    }

    /// Transpose two dimensions
    pub fn transpose(&self, dim0: usize, dim1: usize) -> Tensor {
        let new_shape = self.shape.transpose(dim0, dim1);
        let mut new_strides = self.strides;
        new_strides.swap(dim0, dim1);

        let size_bytes = new_shape.numel() * self.dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, self.dtype, self.storage.device);

        // Copy with new strides
        // This is simplified - real implementation would handle strided copies
        storage.copy_from(&self.storage);

        Tensor {
            storage,
            shape: new_shape,
            strides: new_shape.contiguous_strides(),
            offset: 0,
            dtype: self.dtype,
            requires_grad: self.requires_grad,
            grad: None,
            name: self.name.clone(),
        }
    }

    /// Permute dimensions
    pub fn permute(&self, dims: &[usize]) -> Tensor {
        let new_shape = self.shape.permute(dims);
        let mut new_strides = [0; MAX_DIMS];
        for (i, &d) in dims.iter().enumerate() {
            new_strides[i] = self.strides[d];
        }

        let size_bytes = new_shape.numel() * self.dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, self.dtype, self.storage.device);
        storage.copy_from(&self.storage);

        Tensor {
            storage,
            shape: new_shape,
            strides: new_shape.contiguous_strides(),
            offset: 0,
            dtype: self.dtype,
            requires_grad: self.requires_grad,
            grad: None,
            name: self.name.clone(),
        }
    }

    /// Clone tensor to a new device
    pub fn to_device(&self, device: Device) -> Tensor {
        let size_bytes = self.shape.numel() * self.dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, self.dtype, device);
        storage.copy_from(&self.storage);

        Tensor {
            storage,
            shape: self.shape,
            strides: self.strides,
            offset: 0,
            dtype: self.dtype,
            requires_grad: self.requires_grad,
            grad: None,
            name: self.name.clone(),
        }
    }

    /// Cast tensor to a new data type
    pub fn cast(&self, dtype: DataType) -> Tensor {
        if self.dtype == dtype {
            return self.clone();
        }

        let size_bytes = self.shape.numel() * dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, dtype, self.storage.device);

        // Perform type conversion
        match (self.dtype, dtype) {
            (DataType::Float32, DataType::Float16) => {
                let src = self.storage.as_slice::<f32>();
                let dst = storage.as_mut_slice::<u16>();
                for (i, &val) in src.iter().enumerate() {
                    dst[i] = Float16::from_f32(val).to_bits();
                }
            }
            (DataType::Float16, DataType::Float32) => {
                let src = self.storage.as_slice::<u16>();
                let dst = storage.as_mut_slice::<f32>();
                for (i, &val) in src.iter().enumerate() {
                    dst[i] = Float16::from_bits(val).to_f32();
                }
            }
            _ => {
                // Other conversions
            }
        }

        Tensor {
            storage,
            shape: self.shape,
            strides: self.shape.contiguous_strides(),
            offset: 0,
            dtype,
            requires_grad: self.requires_grad,
            grad: None,
            name: self.name.clone(),
        }
    }

    /// Contiguous copy
    pub fn contiguous(&self) -> Tensor {
        let size_bytes = self.shape.numel() * self.dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, self.dtype, self.storage.device);
        storage.copy_from(&self.storage);

        Tensor {
            storage,
            shape: self.shape,
            strides: self.shape.contiguous_strides(),
            offset: 0,
            dtype: self.dtype,
            requires_grad: self.requires_grad,
            grad: None,
            name: self.name.clone(),
        }
    }

    /// Check if tensor is contiguous
    pub fn is_contiguous(&self) -> bool {
        let expected = self.shape.contiguous_strides();
        self.strides[..self.shape.ndim()] == expected[..self.shape.ndim()]
    }
}

impl Clone for Tensor {
    fn clone(&self) -> Self {
        let size_bytes = self.shape.numel() * self.dtype.size_bytes();
        let mut storage = TensorStorage::allocate(size_bytes, self.dtype, self.storage.device);
        storage.copy_from(&self.storage);

        Tensor {
            storage,
            shape: self.shape,
            strides: self.strides,
            offset: self.offset,
            dtype: self.dtype,
            requires_grad: self.requires_grad,
            grad: self.grad.clone(),
            name: self.name.clone(),
        }
    }
}

// ============================================================================
// REGION: Tensor Operations
// ============================================================================

impl Tensor {
    /// Element-wise addition
    pub fn add(&self, other: &Tensor) -> Tensor {
        assert_eq!(self.shape, other.shape, "Shapes must match for addition");
        assert_eq!(self.dtype, other.dtype, "Data types must match");

        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let b = other.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                // SIMD-optimized addition
                let chunks = a.len() / 8;
                for i in 0..chunks {
                    let idx = i * 8;
                    let va = f32x8::from_slice(&a[idx..]);
                    let vb = f32x8::from_slice(&b[idx..]);
                    let vc = va + vb;
                    vc.copy_to_slice(&mut c[idx..]);
                }
                // Handle remainder
                for i in (chunks * 8)..a.len() {
                    c[i] = a[i] + b[i];
                }
            }
            _ => {
                // Scalar fallback
            }
        }

        result
    }

    /// Element-wise subtraction
    pub fn sub(&self, other: &Tensor) -> Tensor {
        assert_eq!(self.shape, other.shape, "Shapes must match for subtraction");
        assert_eq!(self.dtype, other.dtype, "Data types must match");

        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let b = other.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                let chunks = a.len() / 8;
                for i in 0..chunks {
                    let idx = i * 8;
                    let va = f32x8::from_slice(&a[idx..]);
                    let vb = f32x8::from_slice(&b[idx..]);
                    let vc = va - vb;
                    vc.copy_to_slice(&mut c[idx..]);
                }
                for i in (chunks * 8)..a.len() {
                    c[i] = a[i] - b[i];
                }
            }
            _ => {}
        }

        result
    }

    /// Element-wise multiplication
    pub fn mul(&self, other: &Tensor) -> Tensor {
        assert_eq!(self.shape, other.shape, "Shapes must match for multiplication");
        assert_eq!(self.dtype, other.dtype, "Data types must match");

        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let b = other.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                let chunks = a.len() / 8;
                for i in 0..chunks {
                    let idx = i * 8;
                    let va = f32x8::from_slice(&a[idx..]);
                    let vb = f32x8::from_slice(&b[idx..]);
                    let vc = va * vb;
                    vc.copy_to_slice(&mut c[idx..]);
                }
                for i in (chunks * 8)..a.len() {
                    c[i] = a[i] * b[i];
                }
            }
            _ => {}
        }

        result
    }

    /// Element-wise division
    pub fn div(&self, other: &Tensor) -> Tensor {
        assert_eq!(self.shape, other.shape, "Shapes must match for division");
        assert_eq!(self.dtype, other.dtype, "Data types must match");

        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let b = other.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                let chunks = a.len() / 8;
                for i in 0..chunks {
                    let idx = i * 8;
                    let va = f32x8::from_slice(&a[idx..]);
                    let vb = f32x8::from_slice(&b[idx..]);
                    let vc = va / vb;
                    vc.copy_to_slice(&mut c[idx..]);
                }
                for i in (chunks * 8)..a.len() {
                    c[i] = a[i] / b[i];
                }
            }
            _ => {}
        }

        result
    }

    /// Scalar addition
    pub fn add_scalar(&self, scalar: f32) -> Tensor {
        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();
                let vs = f32x8::splat(scalar);

                let chunks = a.len() / 8;
                for i in 0..chunks {
                    let idx = i * 8;
                    let va = f32x8::from_slice(&a[idx..]);
                    let vc = va + vs;
                    vc.copy_to_slice(&mut c[idx..]);
                }
                for i in (chunks * 8)..a.len() {
                    c[i] = a[i] + scalar;
                }
            }
            _ => {}
        }

        result
    }

    /// Scalar multiplication
    pub fn mul_scalar(&self, scalar: f32) -> Tensor {
        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();
                let vs = f32x8::splat(scalar);

                let chunks = a.len() / 8;
                for i in 0..chunks {
                    let idx = i * 8;
                    let va = f32x8::from_slice(&a[idx..]);
                    let vc = va * vs;
                    vc.copy_to_slice(&mut c[idx..]);
                }
                for i in (chunks * 8)..a.len() {
                    c[i] = a[i] * scalar;
                }
            }
            _ => {}
        }

        result
    }

    /// Matrix multiplication (2D tensors)
    pub fn matmul(&self, other: &Tensor) -> Tensor {
        assert_eq!(self.ndim(), 2, "First tensor must be 2D");
        assert_eq!(other.ndim(), 2, "Second tensor must be 2D");
        assert_eq!(self.shape.dim(1), other.shape.dim(0), "Inner dimensions must match");

        let m = self.shape.dim(0);
        let k = self.shape.dim(1);
        let n = other.shape.dim(1);

        let result_shape = Shape::d2(m, n);
        let mut result = Tensor::zeros(result_shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let b = other.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                // Naive matrix multiplication (real implementation would use BLAS)
                for i in 0..m {
                    for j in 0..n {
                        let mut sum = 0.0f32;
                        for l in 0..k {
                            sum += a[i * k + l] * b[l * n + j];
                        }
                        c[i * n + j] = sum;
                    }
                }
            }
            _ => {}
        }

        result
    }

    /// Batch matrix multiplication
    pub fn bmm(&self, other: &Tensor) -> Tensor {
        assert_eq!(self.ndim(), 3, "First tensor must be 3D");
        assert_eq!(other.ndim(), 3, "Second tensor must be 3D");
        assert_eq!(self.shape.dim(0), other.shape.dim(0), "Batch dimensions must match");
        assert_eq!(self.shape.dim(2), other.shape.dim(1), "Inner dimensions must match");

        let batch = self.shape.dim(0);
        let m = self.shape.dim(1);
        let k = self.shape.dim(2);
        let n = other.shape.dim(2);

        let result_shape = Shape::d3(batch, m, n);
        let mut result = Tensor::zeros(result_shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let b = other.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                for batch_idx in 0..batch {
                    let a_offset = batch_idx * m * k;
                    let b_offset = batch_idx * k * n;
                    let c_offset = batch_idx * m * n;

                    for i in 0..m {
                        for j in 0..n {
                            let mut sum = 0.0f32;
                            for l in 0..k {
                                sum += a[a_offset + i * k + l] * b[b_offset + l * n + j];
                            }
                            c[c_offset + i * n + j] = sum;
                        }
                    }
                }
            }
            _ => {}
        }

        result
    }

    /// Sum all elements
    pub fn sum(&self) -> f32 {
        match self.dtype {
            DataType::Float32 => {
                let data = self.storage.as_slice::<f32>();
                let mut sum = 0.0f32;

                // SIMD reduction
                let chunks = data.len() / 8;
                let mut vec_sum = f32x8::splat(0.0);
                for i in 0..chunks {
                    let idx = i * 8;
                    let v = f32x8::from_slice(&data[idx..]);
                    vec_sum = vec_sum + v;
                }

                // Reduce vector to scalar
                for i in 0..8 {
                    sum += vec_sum[i];
                }

                // Handle remainder
                for i in (chunks * 8)..data.len() {
                    sum += data[i];
                }

                sum
            }
            _ => 0.0
        }
    }

    /// Sum along dimension
    pub fn sum_dim(&self, dim: usize, keepdim: bool) -> Tensor {
        assert!(dim < self.ndim(), "Dimension out of range");

        let mut new_dims: Vec<usize> = self.shape.as_slice().to_vec();
        if keepdim {
            new_dims[dim] = 1;
        } else {
            new_dims.remove(dim);
        }
        let new_shape = Shape::from_slice(&new_dims);
        let mut result = Tensor::zeros(new_shape, self.dtype, self.storage.device);

        // Implementation simplified - would need proper strided iteration
        match self.dtype {
            DataType::Float32 => {
                let src = self.storage.as_slice::<f32>();
                let dst = result.storage.as_mut_slice::<f32>();

                // For 2D case along dim 0 (sum rows)
                if self.ndim() == 2 && dim == 0 {
                    let rows = self.shape.dim(0);
                    let cols = self.shape.dim(1);
                    for j in 0..cols {
                        let mut sum = 0.0f32;
                        for i in 0..rows {
                            sum += src[i * cols + j];
                        }
                        dst[j] = sum;
                    }
                }
            }
            _ => {}
        }

        result
    }

    /// Mean of all elements
    pub fn mean(&self) -> f32 {
        self.sum() / self.numel() as f32
    }

    /// Mean along dimension
    pub fn mean_dim(&self, dim: usize, keepdim: bool) -> Tensor {
        let sum = self.sum_dim(dim, keepdim);
        let divisor = self.shape.dim(dim) as f32;
        sum.mul_scalar(1.0 / divisor)
    }

    /// Variance of all elements
    pub fn var(&self) -> f32 {
        let mean = self.mean();
        let diff = self.add_scalar(-mean);
        let sq = diff.mul(&diff);
        sq.mean()
    }

    /// Standard deviation of all elements
    pub fn std(&self) -> f32 {
        self.var().sqrt()
    }

    /// Maximum element
    pub fn max(&self) -> f32 {
        match self.dtype {
            DataType::Float32 => {
                let data = self.storage.as_slice::<f32>();
                data.iter().cloned().fold(f32::NEG_INFINITY, f32::max)
            }
            _ => 0.0
        }
    }

    /// Minimum element
    pub fn min(&self) -> f32 {
        match self.dtype {
            DataType::Float32 => {
                let data = self.storage.as_slice::<f32>();
                data.iter().cloned().fold(f32::INFINITY, f32::min)
            }
            _ => 0.0
        }
    }

    /// Argmax along dimension
    pub fn argmax(&self, dim: usize) -> Tensor {
        assert!(dim < self.ndim(), "Dimension out of range");

        let mut new_dims: Vec<usize> = self.shape.as_slice().to_vec();
        new_dims[dim] = 1;
        let new_shape = Shape::from_slice(&new_dims);
        let mut result = Tensor::zeros(new_shape, DataType::Int64, self.storage.device);

        // Simplified implementation
        result
    }

    /// Element-wise clamp
    pub fn clamp(&self, min_val: f32, max_val: f32) -> Tensor {
        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                for i in 0..a.len() {
                    c[i] = a[i].clamp(min_val, max_val);
                }
            }
            _ => {}
        }

        result
    }

    /// Element-wise absolute value
    pub fn abs(&self) -> Tensor {
        let mut result = Tensor::zeros(self.shape, self.dtype, self.storage.device);

        match self.dtype {
            DataType::Float32 => {
                let a = self.storage.as_slice::<f32>();
                let c = result.storage.as_mut_slice::<f32>();

                for i in 0..a.len() {
                    c[i] = a[i].abs();
                }
            }
            _ => {}
        }

        result
    }

