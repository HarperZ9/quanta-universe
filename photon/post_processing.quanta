/// Complete post-processing preset
struct PostProcessingPreset {
    name: String,
    dof_config: Option<DoFConfig>,
    lens_flare_config: Option<LensFlareConfig>,
    lens_distortion_config: Option<LensDistortionConfig>,
    fog_config: Option<FogConfig>,
    sharpening_config: Option<SharpeningConfig>,
    aa_technique: Option<AATechnique>,
    fsr_config: Option<FSRConfig>,
}

impl PostProcessingPreset {
    fn cinematic() -> Self {
        Self {
            name: "Cinematic".to_string(),
            dof_config: Some(DoFConfig::cinematic()),
            lens_flare_config: Some(LensFlareConfig::default()),
            lens_distortion_config: Some(LensDistortionConfig::default()),
            fog_config: None,
            sharpening_config: Some(SharpeningConfig::default()),
            aa_technique: Some(AATechnique::TAA),
            fsr_config: None,
        }
    }

    fn performance() -> Self {
        Self {
            name: "Performance".to_string(),
            dof_config: None,
            lens_flare_config: None,
            lens_distortion_config: None,
            fog_config: None,
            sharpening_config: Some(SharpeningConfig::default()),
            aa_technique: Some(AATechnique::FXAA),
            fsr_config: Some(FSRConfig {
                sharpness: 0.2,
                quality: FSRQuality::Performance,
            }),
        }
    }

    fn quality() -> Self {
        Self {
            name: "Quality".to_string(),
            dof_config: Some(DoFConfig::default()),
            lens_flare_config: Some(LensFlareConfig::default()),
            lens_distortion_config: Some(LensDistortionConfig::default()),
            fog_config: Some(FogConfig::default()),
            sharpening_config: Some(SharpeningConfig {
                technique: SharpeningTechnique::RCAS,
                amount: 0.3,
                threshold: 0.03,
                radius: 1.0,
            }),
            aa_technique: Some(AATechnique::TAA),
            fsr_config: None,
        }
    }
}

// =============================================================================
// TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_coc_calculation() {
        let dof = DepthOfFieldEffect::new(
            &mock_ctx(),
            1920, 1080,
            DoFConfig::default(),
        );

        // At focus distance, CoC should be ~0
        let coc_at_focus = dof.calculate_coc(dof.config.focus_distance);
        assert!(coc_at_focus.abs() < 0.001);

        // Far from focus, CoC should be larger
        let coc_far = dof.calculate_coc(dof.config.focus_distance * 10.0);
        assert!(coc_far.abs() > 0.0);
    }

    #[test]
    fn test_lens_distortion_center() {
        let distortion = LensDistortionEffect::new(&mock_ctx(), LensDistortionConfig::default());

        // Center should not be distorted
        let center = Vec2::new(0.5, 0.5);
        let distorted = distortion.distort_uv(center);

        assert!((distorted.x - 0.5).abs() < 0.001);
        assert!((distorted.y - 0.5).abs() < 0.001);
    }

    #[test]
    fn test_fog_factor() {
        let fog = FogEffect::new(&mock_ctx(), FogConfig::default());

        // Close distance = no fog
        let fog_close = fog.calculate_fog_factor(1.0, 0.0);
        assert!(fog_close < 0.1);

        // Far distance = more fog
        let fog_far = fog.calculate_fog_factor(100.0, 0.0);
        assert!(fog_far > fog_close);
    }

    #[test]
    fn test_fxaa_quality_thresholds() {
        assert!(FXAAQuality::Low.edge_threshold() > FXAAQuality::Ultra.edge_threshold());
    }

    #[test]
    fn test_fsr_quality_scales() {
        assert!(FSRQuality::Quality.scale_factor() > FSRQuality::UltraPerformance.scale_factor());
    }

    #[test]
    fn test_effect_priority() {
        let dof = DepthOfFieldEffect::new(&mock_ctx(), 1920, 1080, DoFConfig::default());
        let fxaa = FXAAEffect::new(&mock_ctx(), FXAAQuality::High);

        // DoF should come before AA
        assert!(dof.priority() < fxaa.priority());
    }

    #[test]
    fn test_rgb_to_luma() {
        // White should have luma close to 1
        let white_luma = FXAAEffect::rgb_to_luma(Vec3::new(1.0, 1.0, 1.0));
        assert!((white_luma - 1.0).abs() < 0.01);

        // Black should have luma 0
        let black_luma = FXAAEffect::rgb_to_luma(Vec3::new(0.0, 0.0, 0.0));
        assert!(black_luma < 0.01);
    }

    fn mock_ctx() -> RenderContext {
        // Mock render context for tests
        RenderContext::mock()
    }
}
