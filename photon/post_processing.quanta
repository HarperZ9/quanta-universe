/// Screen-space outline configuration
struct OutlineConfig {
    /// Outline color
    color: Vec3<f32>,
    /// Outline thickness
    thickness: f32,
    /// Depth threshold
    depth_threshold: f32,
    /// Normal threshold
    normal_threshold: f32,
    /// Color threshold
    color_threshold: f32,
}

impl OutlineConfig {
    fn default() -> Self {
        Self {
            color: Vec3::new(0.0, 0.0, 0.0),
            thickness: 1.0,
            depth_threshold: 0.1,
            normal_threshold: 0.5,
            color_threshold: 0.1,
        }
    }
}

/// Screen-space outline effect
struct OutlineEffect {
    enabled: bool,
    config: OutlineConfig,
    pipeline: Pipeline,
}

impl OutlineEffect {
    fn new(ctx: &RenderContext, config: OutlineConfig) -> Self {
        Self {
            enabled: false, // Disabled by default
            config,
            pipeline: Pipeline::new_outline(ctx),
        }
    }
}

impl PostEffect for OutlineEffect {
    fn name(&self) -> &str { "Outline" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 50 }
    fn requires_depth(&self) -> bool { true }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        cmd.bind_compute_pipeline(&self.pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_texture(1, depth);
        cmd.bind_storage_texture(2, output);

        let params = OutlineParams {
            color: self.config.color,
            thickness: self.config.thickness,
            depth_threshold: self.config.depth_threshold,
            normal_threshold: self.config.normal_threshold,
            screen_size: Vec2::new(frame_data.screen_size.x as f32, frame_data.screen_size.y as f32),
        };
        cmd.push_constants(&params);

        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct OutlineParams {
    color: Vec3<f32>,
    thickness: f32,
    depth_threshold: f32,
    normal_threshold: f32,
    screen_size: Vec2<f32>,
}

/// Screen-space fog configuration
struct FogConfig {
    /// Fog color
    color: Vec3<f32>,
    /// Fog density
    density: f32,
    /// Fog start distance
    start: f32,
    /// Fog end distance
    end: f32,
    /// Height fog density
    height_density: f32,
    /// Height falloff
    height_falloff: f32,
    /// Base height
    base_height: f32,
}

impl FogConfig {
    fn default() -> Self {
        Self {
            color: Vec3::new(0.7, 0.8, 0.9),
            density: 0.01,
            start: 10.0,
            end: 500.0,
            height_density: 0.05,
            height_falloff: 0.1,
            base_height: 0.0,
        }
    }
}

/// Screen-space fog effect
struct FogEffect {
    enabled: bool,
    config: FogConfig,
    pipeline: Pipeline,
}

impl FogEffect {
    fn new(ctx: &RenderContext, config: FogConfig) -> Self {
        Self {
            enabled: true,
            config,
            pipeline: Pipeline::new_fog(ctx),
        }
    }

    fn calculate_fog_factor(&self, distance: f32, height: f32) -> f32 {
        // Distance fog (exponential)
        let distance_fog = 1.0 - (-distance * self.config.density).exp();

        // Height fog
        let height_diff = height - self.config.base_height;
        let height_fog = if height_diff > 0.0 {
            (-height_diff * self.config.height_falloff).exp() * self.config.height_density
        } else {
            self.config.height_density
        };

        (distance_fog + height_fog).clamp(0.0, 1.0)
    }
}

impl PostEffect for FogEffect {
    fn name(&self) -> &str { "Fog" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 200 }
    fn requires_depth(&self) -> bool { true }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        cmd.bind_compute_pipeline(&self.pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_texture(1, depth);
        cmd.bind_storage_texture(2, output);

        let params = FogParams {
            color: self.config.color,
            density: self.config.density,
            start: self.config.start,
            end: self.config.end,
            height_density: self.config.height_density,
            height_falloff: self.config.height_falloff,
            base_height: self.config.base_height,
            inv_proj: frame_data.inv_proj_matrix,
            camera_pos: frame_data.camera_position,
        };
        cmd.push_constants(&params);

        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct FogParams {
    color: Vec3<f32>,
    density: f32,
    start: f32,
    end: f32,
    height_density: f32,
    height_falloff: f32,
    base_height: f32,
    inv_proj: Mat4x4<f32>,
    camera_pos: Vec3<f32>,
}

// =============================================================================
// IMAGE SHARPENING (WP-100)
// =============================================================================

/// Sharpening technique
#[derive(Clone, Copy, PartialEq, Eq)]
enum SharpeningTechnique {
    /// Unsharp mask
    UnsharpMask,
    /// CAS (Contrast Adaptive Sharpening)
    CAS,
    /// RCAS (Robust CAS from FSR)
    RCAS,
    /// High-pass
    HighPass,
}

/// Sharpening configuration
struct SharpeningConfig {
    technique: SharpeningTechnique,
    /// Sharpening amount
    amount: f32,
    /// Threshold (to avoid sharpening noise)
    threshold: f32,
    /// Radius for blur (unsharp mask)
    radius: f32,
}

impl SharpeningConfig {
    fn default() -> Self {
        Self {
            technique: SharpeningTechnique::CAS,
            amount: 0.5,
            threshold: 0.05,
            radius: 1.0,
        }
    }
}

/// Sharpening effect
struct SharpeningEffect {
    enabled: bool,
    config: SharpeningConfig,
    pipeline: Pipeline,
}

impl SharpeningEffect {
    fn new(ctx: &RenderContext, config: SharpeningConfig) -> Self {
        Self {
            enabled: true,
            config,
            pipeline: Pipeline::new_sharpen(ctx),
        }
    }

    /// Apply CAS sharpening
    fn apply_cas(
        &self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
    ) {
        // AMD FidelityFX CAS algorithm
        // Uses local contrast to adaptively sharpen
    }

    /// Apply unsharp mask
    fn apply_unsharp_mask(
        &self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
    ) {
        // Blur original, subtract from original, add scaled difference
    }
}

impl PostEffect for SharpeningEffect {
    fn name(&self) -> &str { "Sharpening" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 450 }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        cmd.bind_compute_pipeline(&self.pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_storage_texture(1, output);

        let params = SharpenParams {
            amount: self.config.amount,
            threshold: self.config.threshold,
            screen_size: Vec2::new(frame_data.screen_size.x as f32, frame_data.screen_size.y as f32),
        };
        cmd.push_constants(&params);

        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct SharpenParams {
    amount: f32,
    threshold: f32,
    screen_size: Vec2<f32>,
}

// =============================================================================
// ANTI-ALIASING (WP-101)
// =============================================================================

/// AA technique
#[derive(Clone, Copy, PartialEq, Eq)]
enum AATechnique {
    /// Fast Approximate AA (FXAA)
    FXAA,
    /// Subpixel Morphological AA (SMAA)
    SMAA,
    /// Temporal AA (TAA) - see temporal.quanta
    TAA,
}

/// FXAA quality preset
#[derive(Clone, Copy)]
enum FXAAQuality {
    Low,
    Medium,
    High,
    Ultra,
}

impl FXAAQuality {
    fn edge_threshold(&self) -> f32 {
        match self {
            FXAAQuality::Low => 0.25,
            FXAAQuality::Medium => 0.166,
            FXAAQuality::High => 0.125,
            FXAAQuality::Ultra => 0.063,
        }
    }

    fn edge_threshold_min(&self) -> f32 {
        match self {
            FXAAQuality::Low => 0.0833,
            FXAAQuality::Medium => 0.0625,
            FXAAQuality::High => 0.0312,
            FXAAQuality::Ultra => 0.0156,
        }
    }
}

/// FXAA effect
struct FXAAEffect {
    enabled: bool,
    quality: FXAAQuality,
    pipeline: Pipeline,
}

impl FXAAEffect {
    fn new(ctx: &RenderContext, quality: FXAAQuality) -> Self {
        Self {
            enabled: true,
            quality,
            pipeline: Pipeline::new_fxaa(ctx),
        }
    }

    fn rgb_to_luma(color: Vec3<f32>) -> f32 {
        color.dot(Vec3::new(0.299, 0.587, 0.114))
    }
}

impl PostEffect for FXAAEffect {
    fn name(&self) -> &str { "FXAA" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 500 }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        cmd.bind_compute_pipeline(&self.pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_storage_texture(1, output);

        let params = FXAAParams {
            edge_threshold: self.quality.edge_threshold(),
            edge_threshold_min: self.quality.edge_threshold_min(),
            screen_size: Vec2::new(frame_data.screen_size.x as f32, frame_data.screen_size.y as f32),
            inverse_screen_size: Vec2::new(
                1.0 / frame_data.screen_size.x as f32,
                1.0 / frame_data.screen_size.y as f32,
            ),
        };
        cmd.push_constants(&params);

        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct FXAAParams {
    edge_threshold: f32,
    edge_threshold_min: f32,
    screen_size: Vec2<f32>,
    inverse_screen_size: Vec2<f32>,
}

/// SMAA effect
struct SMAAEffect {
    enabled: bool,
    /// Edge detection texture
    edge_texture: Texture,
    /// Blend weight texture
    blend_texture: Texture,
    /// Area lookup texture
    area_texture: Texture,
    /// Search lookup texture
    search_texture: Texture,
    /// Edge detection pipeline
    edge_pipeline: Pipeline,
    /// Blend weight pipeline
    blend_pipeline: Pipeline,
    /// Neighborhood blending pipeline
    neighborhood_pipeline: Pipeline,
}

impl SMAAEffect {
    fn new(ctx: &RenderContext, width: u32, height: u32) -> Self {
        Self {
            enabled: false,
            edge_texture: Texture::new_2d(ctx, width, height, TextureFormat::RG8),
            blend_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA8),
            area_texture: Self::create_area_texture(ctx),
            search_texture: Self::create_search_texture(ctx),
            edge_pipeline: Pipeline::new_smaa_edge(ctx),
            blend_pipeline: Pipeline::new_smaa_blend(ctx),
            neighborhood_pipeline: Pipeline::new_smaa_neighborhood(ctx),
        }
    }

    fn create_area_texture(ctx: &RenderContext) -> Texture {
        // SMAA area texture (precomputed lookup table)
        Texture::new_2d(ctx, 160, 560, TextureFormat::RG8)
    }

    fn create_search_texture(ctx: &RenderContext) -> Texture {
        // SMAA search texture
        Texture::new_2d(ctx, 64, 16, TextureFormat::R8)
    }
}

impl PostEffect for SMAAEffect {
    fn name(&self) -> &str { "SMAA" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 500 }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        // Pass 1: Edge detection
        cmd.bind_compute_pipeline(&self.edge_pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_storage_texture(1, &self.edge_texture);
        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);

        // Pass 2: Blend weight calculation
        cmd.bind_compute_pipeline(&self.blend_pipeline);
        cmd.bind_texture(0, &self.edge_texture);
        cmd.bind_texture(1, &self.area_texture);
        cmd.bind_texture(2, &self.search_texture);
        cmd.bind_storage_texture(3, &self.blend_texture);
        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);

        // Pass 3: Neighborhood blending
        cmd.bind_compute_pipeline(&self.neighborhood_pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_texture(1, &self.blend_texture);
        cmd.bind_storage_texture(2, output);
        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

// =============================================================================
// UPSCALING (WP-102)
// =============================================================================

/// Upscaling technique
#[derive(Clone, Copy, PartialEq, Eq)]
enum UpscaleTechnique {
    /// Bilinear
    Bilinear,
    /// Bicubic
    Bicubic,
    /// Lanczos
    Lanczos,
    /// AMD FSR 1.0
    FSR1,
    /// AMD FSR 2.0
    FSR2,
    /// NVIDIA DLSS-like temporal upscale
    TemporalUpscale,
}

/// FSR configuration
struct FSRConfig {
    /// Sharpness (0.0 to 2.0)
    sharpness: f32,
    /// Quality mode (affects render scale)
    quality: FSRQuality,
}

#[derive(Clone, Copy)]
enum FSRQuality {
    /// 77% scale
    Quality,
    /// 67% scale
    Balanced,
    /// 59% scale
    Performance,
    /// 50% scale
    UltraPerformance,
}

impl FSRQuality {
    fn scale_factor(&self) -> f32 {
        match self {
            FSRQuality::Quality => 0.77,
            FSRQuality::Balanced => 0.67,
            FSRQuality::Performance => 0.59,
            FSRQuality::UltraPerformance => 0.50,
        }
    }
}

impl FSRConfig {
    fn default() -> Self {
        Self {
            sharpness: 0.2,
            quality: FSRQuality::Quality,
        }
    }
}

/// FSR upscaler
struct FSRUpscaler {
    enabled: bool,
    config: FSRConfig,
    /// EASU (Edge Adaptive Spatial Upsampling) pipeline
    easu_pipeline: Pipeline,
    /// RCAS (Robust Contrast Adaptive Sharpening) pipeline
    rcas_pipeline: Pipeline,
    /// Intermediate texture
    upscaled_texture: Texture,
}

impl FSRUpscaler {
    fn new(ctx: &RenderContext, width: u32, height: u32, config: FSRConfig) -> Self {
        Self {
            enabled: true,
            config,
            easu_pipeline: Pipeline::new_fsr_easu(ctx),
            rcas_pipeline: Pipeline::new_fsr_rcas(ctx),
            upscaled_texture: Texture::new_2d(ctx, width, height, DEFAULT_HDR_FORMAT),
        }
    }

    fn get_render_resolution(&self, target_width: u32, target_height: u32) -> (u32, u32) {
        let scale = self.config.quality.scale_factor();
        (
            (target_width as f32 * scale) as u32,
            (target_height as f32 * scale) as u32,
        )
    }
}

impl PostEffect for FSRUpscaler {
    fn name(&self) -> &str { "FSR" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 600 }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        // Pass 1: EASU (upscaling)
        cmd.bind_compute_pipeline(&self.easu_pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_storage_texture(1, &self.upscaled_texture);

        let easu_params = EASUParams {
            input_size: Vec2::new(input.width() as f32, input.height() as f32),
            output_size: Vec2::new(frame_data.screen_size.x as f32, frame_data.screen_size.y as f32),
        };
        cmd.push_constants(&easu_params);
        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);

        // Pass 2: RCAS (sharpening)
        cmd.bind_compute_pipeline(&self.rcas_pipeline);
        cmd.bind_texture(0, &self.upscaled_texture);
        cmd.bind_storage_texture(1, output);

        let rcas_params = RCASParams {
            sharpness: self.config.sharpness,
        };
        cmd.push_constants(&rcas_params);
        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct EASUParams {
    input_size: Vec2<f32>,
    output_size: Vec2<f32>,
}

struct RCASParams {
    sharpness: f32,
}

// =============================================================================
// ADDITIONAL EFFECTS
// =============================================================================

/// Panini projection for ultra-wide FOV
struct PaniniProjectionEffect {
    enabled: bool,
    /// Panini distance parameter (0 = rectilinear, 1 = full panini)
    distance: f32,
    /// Vertical compression
    vertical_compression: f32,
    pipeline: Pipeline,
}

impl PaniniProjectionEffect {
    fn new(ctx: &RenderContext) -> Self {
        Self {
            enabled: false,
            distance: 0.5,
            vertical_compression: 0.0,
            pipeline: Pipeline::new_panini(ctx),
        }
    }
}

impl PostEffect for PaniniProjectionEffect {
    fn name(&self) -> &str { "Panini Projection" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 25 }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        cmd.bind_compute_pipeline(&self.pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_storage_texture(1, output);

        let params = PaniniParams {
            distance: self.distance,
            vertical_compression: self.vertical_compression,
            fov: 90.0, // Would come from camera
            screen_size: Vec2::new(frame_data.screen_size.x as f32, frame_data.screen_size.y as f32),
        };
        cmd.push_constants(&params);

        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct PaniniParams {
    distance: f32,
    vertical_compression: f32,
    fov: f32,
    screen_size: Vec2<f32>,
}

/// Pixelation effect (for stylized rendering)
struct PixelationEffect {
    enabled: bool,
    /// Pixel size
    pixel_size: u32,
    /// Color depth (bits per channel)
    color_depth: u32,
    pipeline: Pipeline,
}

impl PixelationEffect {
    fn new(ctx: &RenderContext) -> Self {
        Self {
            enabled: false,
            pixel_size: 4,
            color_depth: 8,
            pipeline: Pipeline::new_pixelation(ctx),
        }
    }
}

impl PostEffect for PixelationEffect {
    fn name(&self) -> &str { "Pixelation" }
    fn is_enabled(&self) -> bool { self.enabled }
    fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }
    fn priority(&self) -> i32 { 550 }

    fn execute(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        output: &Texture,
        depth: &Texture,
        frame_data: &FrameData,
    ) {
        cmd.bind_compute_pipeline(&self.pipeline);
        cmd.bind_texture(0, input);
        cmd.bind_storage_texture(1, output);

        let params = PixelationParams {
            pixel_size: self.pixel_size,
            color_levels: 1 << self.color_depth,
            screen_size: Vec2::new(frame_data.screen_size.x as f32, frame_data.screen_size.y as f32),
        };
        cmd.push_constants(&params);

        cmd.dispatch_compute_2d(frame_data.screen_size.x, frame_data.screen_size.y);
    }
}

struct PixelationParams {
    pixel_size: u32,
    color_levels: u32,
    screen_size: Vec2<f32>,
}

// =============================================================================
// POST-PROCESSING PRESETS
