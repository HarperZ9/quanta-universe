// - WP-080: Multi-Bounce Path Tracing
// =============================================================================

use core::mem;
use core::simd;
use crate::photon::{RenderContext, Pipeline, Buffer, Texture};
use crate::photon::path_tracing::{Ray, HitInfo, Material, BSDF};

// =============================================================================
// RAY TRACING CONSTANTS (WP-072)
// =============================================================================

/// Maximum ray recursion depth
const MAX_RAY_RECURSION: u32 = 8;

/// Maximum primitives per BLAS
const MAX_PRIMITIVES_PER_BLAS: u32 = 1_000_000;

/// Maximum instances in TLAS
const MAX_TLAS_INSTANCES: u32 = 100_000;

/// Default ray TMin to avoid self-intersection
const DEFAULT_RAY_TMIN: f32 = 0.001;

/// Default ray TMax
const DEFAULT_RAY_TMAX: f32 = 10000.0;

/// Shader table alignment requirement
const SHADER_TABLE_ALIGNMENT: u32 = 64;

/// Shader record size (padded)
const SHADER_RECORD_SIZE: u32 = 64;

// =============================================================================
// RAY FLAGS (WP-072)
// =============================================================================

/// Ray flags for controlling intersection behavior
#[repr(u32)]
#[derive(Clone, Copy, PartialEq, Eq)]
enum RayFlags {
    /// No special behavior
    None = 0,
    /// Force opaque (ignore any-hit shaders)
    ForceOpaque = 0x01,
    /// Force non-opaque (invoke any-hit shaders)
    ForceNonOpaque = 0x02,
    /// Accept first hit (shadow rays)
    AcceptFirstHit = 0x04,
    /// Skip closest hit shader
    SkipClosestHit = 0x08,
    /// Cull back-facing triangles
    CullBackFacing = 0x10,
    /// Cull front-facing triangles
    CullFrontFacing = 0x20,
    /// Cull opaque geometry
    CullOpaque = 0x40,
    /// Cull non-opaque geometry
    CullNonOpaque = 0x80,
    /// Skip triangles
    SkipTriangles = 0x100,
    /// Skip procedural primitives
    SkipProceduralPrimitives = 0x200,
}

impl RayFlags {
    fn shadow() -> u32 {
        RayFlags::ForceOpaque as u32
            | RayFlags::AcceptFirstHit as u32
            | RayFlags::SkipClosestHit as u32
    }

    fn reflection() -> u32 {
        RayFlags::CullBackFacing as u32
    }

    fn ao() -> u32 {
        RayFlags::ForceOpaque as u32
            | RayFlags::AcceptFirstHit as u32
    }
}

// =============================================================================
// ACCELERATION STRUCTURES (WP-073)
// =============================================================================

/// Geometry type for BLAS
#[derive(Clone, Copy, PartialEq, Eq)]
enum GeometryType {
    Triangles,
    AABBs,
}

/// Geometry flags
#[repr(u32)]
#[derive(Clone, Copy)]
enum GeometryFlags {
    None = 0,
    Opaque = 0x01,
    NoDuplicateAnyHit = 0x02,
}

/// Geometry description for BLAS building
struct GeometryDesc {
    geometry_type: GeometryType,
    flags: GeometryFlags,
    /// Vertex buffer (for triangles)
    vertex_buffer: Option<Buffer<Vec3<f32>>>,
    vertex_stride: u32,
    vertex_count: u32,
    /// Index buffer (for triangles)
    index_buffer: Option<Buffer<u32>>,
    index_count: u32,
    /// Transform (optional)
    transform: Option<Mat3x4<f32>>,
    /// AABB buffer (for procedural geometry)
    aabb_buffer: Option<Buffer<AABB>>,
    aabb_count: u32,
}

/// Axis-aligned bounding box
@align(16)
struct AABB {
    min: Vec3<f32>,
    _pad0: f32,
    max: Vec3<f32>,
    _pad1: f32,
}

impl AABB {
    fn new(min: Vec3<f32>, max: Vec3<f32>) -> Self {
        Self {
            min,
            _pad0: 0.0,
            max,
            _pad1: 0.0,
        }
    }

    fn center(&self) -> Vec3<f32> {
        (self.min + self.max) * 0.5
    }

    fn extent(&self) -> Vec3<f32> {
        self.max - self.min
    }

    fn surface_area(&self) -> f32 {
        let e = self.extent();
        2.0 * (e.x * e.y + e.y * e.z + e.z * e.x)
    }

    fn merge(&self, other: &AABB) -> AABB {
        AABB::new(
            Vec3::new(
                self.min.x.min(other.min.x),
                self.min.y.min(other.min.y),
                self.min.z.min(other.min.z),
            ),
            Vec3::new(
                self.max.x.max(other.max.x),
                self.max.y.max(other.max.y),
                self.max.z.max(other.max.z),
            ),
        )
    }
}

/// Bottom-level acceleration structure (BLAS)
struct BLAS {
    /// GPU handle
    handle: u64,
    /// Geometries in this BLAS
    geometries: Vec<GeometryDesc>,
    /// Scratch buffer for building
    scratch_buffer: Buffer<u8>,
    /// Result buffer
    result_buffer: Buffer<u8>,
    /// Build flags
    flags: BLASBuildFlags,
    /// Is built
    is_built: bool,
    /// Bounding box
    bounds: AABB,
}

/// BLAS build flags
#[repr(u32)]
#[derive(Clone, Copy)]
enum BLASBuildFlags {
    None = 0,
    AllowUpdate = 0x01,
    AllowCompaction = 0x02,
    PreferFastTrace = 0x04,
    PreferFastBuild = 0x08,
    MinimizeMemory = 0x10,
}

impl BLAS {
    fn new(ctx: &RenderContext, geometries: Vec<GeometryDesc>, flags: BLASBuildFlags) -> Self {
        // Calculate required buffer sizes
        let (scratch_size, result_size) = Self::calculate_sizes(ctx, &geometries, flags);

        Self {
            handle: 0,
            geometries,
            scratch_buffer: Buffer::new_sized(ctx, scratch_size, BufferUsage::STORAGE),
            result_buffer: Buffer::new_sized(ctx, result_size, BufferUsage::ACCELERATION_STRUCTURE),
            flags,
            is_built: false,
            bounds: AABB::new(Vec3::splat(f32::MAX), Vec3::splat(f32::MIN)),
        }
    }

    fn calculate_sizes(
        ctx: &RenderContext,
        geometries: &[GeometryDesc],
        flags: BLASBuildFlags,
    ) -> (usize, usize) {
        // Query sizes from API (simulated)
        let total_primitives: u32 = geometries.iter()
            .map(|g| match g.geometry_type {
                GeometryType::Triangles => g.index_count / 3,
                GeometryType::AABBs => g.aabb_count,
            })
            .sum();

        // Estimate sizes based on primitive count
        let scratch_size = (total_primitives as usize * 64 + 256).max(4096);
        let result_size = (total_primitives as usize * 80 + 128).max(4096);

        (scratch_size, result_size)
    }

    /// Build the BLAS
    fn build(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        // Calculate bounding box
        for geom in &self.geometries {
            if let Some(ref vb) = geom.vertex_buffer {
                // Compute bounds from vertices
                // In practice, this would read from GPU buffer
            }
        }

        // Dispatch build command
        cmd.build_acceleration_structure(
            &self.result_buffer,
            &self.scratch_buffer,
            &self.geometries,
            self.flags,
        );

        self.is_built = true;
        self.handle = self.result_buffer.device_address();
    }

    /// Update the BLAS (for dynamic geometry)
    fn update(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        if !self.is_built {
            self.build(ctx, cmd);
            return;
        }

        if (self.flags as u32 & BLASBuildFlags::AllowUpdate as u32) == 0 {
            // Rebuild if update not allowed
            self.build(ctx, cmd);
            return;
        }

        cmd.update_acceleration_structure(
            &self.result_buffer,
            &self.scratch_buffer,
            &self.geometries,
        );
    }

    /// Compact BLAS to reduce memory
    fn compact(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        if (self.flags as u32 & BLASBuildFlags::AllowCompaction as u32) == 0 {
            return;
        }

        // Query compacted size
        let compacted_size = cmd.query_acceleration_structure_size(&self.result_buffer);

        // Create compacted buffer
        let compacted_buffer = Buffer::new_sized(
            ctx,
            compacted_size,
            BufferUsage::ACCELERATION_STRUCTURE,
        );

        // Copy and compact
        cmd.compact_acceleration_structure(&self.result_buffer, &compacted_buffer);

        self.result_buffer = compacted_buffer;
        self.handle = self.result_buffer.device_address();
    }
}

/// Instance description for TLAS
@align(64)
struct InstanceDesc {
    /// 3x4 row-major transform matrix
    transform: Mat3x4<f32>,
    /// Instance ID (24 bits) and mask (8 bits)
    instance_id_and_mask: u32,
    /// SBT offset (24 bits) and flags (8 bits)
    sbt_offset_and_flags: u32,
    /// BLAS device address
    blas_address: u64,
}

impl InstanceDesc {
    fn new(
        transform: Mat3x4<f32>,
        instance_id: u32,
        mask: u8,
        sbt_offset: u32,
        flags: u8,
        blas: &BLAS,
    ) -> Self {
        Self {
            transform,
            instance_id_and_mask: (instance_id & 0xFFFFFF) | ((mask as u32) << 24),
            sbt_offset_and_flags: (sbt_offset & 0xFFFFFF) | ((flags as u32) << 24),
            blas_address: blas.handle,
        }
    }
}

/// Instance flags
#[repr(u8)]
#[derive(Clone, Copy)]
enum InstanceFlags {
    None = 0,
    TriangleCullDisable = 0x01,
    TriangleFrontCCW = 0x02,
    ForceOpaque = 0x04,
    ForceNonOpaque = 0x08,
}

/// Top-level acceleration structure (TLAS)
struct TLAS {
    /// GPU handle
    handle: u64,
    /// Instances buffer
    instances_buffer: Buffer<InstanceDesc>,
    /// Instance count
    instance_count: u32,
    /// Scratch buffer
    scratch_buffer: Buffer<u8>,
    /// Result buffer
    result_buffer: Buffer<u8>,
    /// Build flags
    flags: TLASBuildFlags,
    /// Is built
    is_built: bool,
}

/// TLAS build flags
#[repr(u32)]
#[derive(Clone, Copy)]
enum TLASBuildFlags {
    None = 0,
    AllowUpdate = 0x01,
    PreferFastTrace = 0x02,
    PreferFastBuild = 0x04,
}

impl TLAS {
    fn new(ctx: &RenderContext, max_instances: u32, flags: TLASBuildFlags) -> Self {
        let scratch_size = (max_instances as usize * 128 + 256).max(4096);
        let result_size = (max_instances as usize * 64 + 256).max(4096);

        Self {
            handle: 0,
            instances_buffer: Buffer::new_capacity(ctx, max_instances as usize, BufferUsage::STORAGE),
            instance_count: 0,
            scratch_buffer: Buffer::new_sized(ctx, scratch_size, BufferUsage::STORAGE),
            result_buffer: Buffer::new_sized(ctx, result_size, BufferUsage::ACCELERATION_STRUCTURE),
            flags,
            is_built: false,
        }
    }

    /// Update instances
    fn update_instances(&mut self, ctx: &RenderContext, instances: &[InstanceDesc]) {
        self.instances_buffer.upload(ctx, instances);
        self.instance_count = instances.len() as u32;
    }

    /// Build the TLAS
    fn build(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        cmd.build_tlas(
            &self.result_buffer,
            &self.scratch_buffer,
            &self.instances_buffer,
            self.instance_count,
            self.flags,
        );

        self.is_built = true;
        self.handle = self.result_buffer.device_address();
    }

    /// Update the TLAS (for dynamic instances)
    fn update(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        if !self.is_built || (self.flags as u32 & TLASBuildFlags::AllowUpdate as u32) == 0 {
            self.build(ctx, cmd);
            return;
        }

        cmd.update_tlas(
            &self.result_buffer,
            &self.scratch_buffer,
            &self.instances_buffer,
            self.instance_count,
        );
    }
}

// =============================================================================
// SHADER BINDING TABLE (WP-074)
// =============================================================================

/// Shader record in shader binding table
@align(64)
struct ShaderRecord {
    /// Shader identifier (32 bytes for DXR)
    shader_identifier: [u8; 32],
    /// Local root arguments (32 bytes)
    local_arguments: [u8; 32],
}

/// Shader binding table
struct ShaderBindingTable {
    /// Ray generation records
    ray_gen_buffer: Buffer<ShaderRecord>,
    ray_gen_count: u32,
    ray_gen_stride: u32,

    /// Miss shader records
    miss_buffer: Buffer<ShaderRecord>,
    miss_count: u32,
    miss_stride: u32,

    /// Hit group records
    hit_group_buffer: Buffer<ShaderRecord>,
    hit_group_count: u32,
    hit_group_stride: u32,

    /// Callable shader records
    callable_buffer: Buffer<ShaderRecord>,
    callable_count: u32,
    callable_stride: u32,
}

impl ShaderBindingTable {
    fn new(ctx: &RenderContext) -> Self {
        Self {
            ray_gen_buffer: Buffer::new(ctx, BufferUsage::SHADER_BINDING_TABLE),
            ray_gen_count: 0,
            ray_gen_stride: SHADER_RECORD_SIZE,
            miss_buffer: Buffer::new(ctx, BufferUsage::SHADER_BINDING_TABLE),
            miss_count: 0,
            miss_stride: SHADER_RECORD_SIZE,
            hit_group_buffer: Buffer::new(ctx, BufferUsage::SHADER_BINDING_TABLE),
            hit_group_count: 0,
            hit_group_stride: SHADER_RECORD_SIZE,
            callable_buffer: Buffer::new(ctx, BufferUsage::SHADER_BINDING_TABLE),
            callable_count: 0,
            callable_stride: SHADER_RECORD_SIZE,
        }
    }

    /// Set ray generation shader
    fn set_ray_gen(&mut self, ctx: &RenderContext, shader_id: &[u8; 32], args: &[u8]) {
        let mut record = ShaderRecord {
            shader_identifier: *shader_id,
            local_arguments: [0; 32],
        };

        let copy_len = args.len().min(32);
        record.local_arguments[..copy_len].copy_from_slice(&args[..copy_len]);

        self.ray_gen_buffer.upload(ctx, &[record]);
        self.ray_gen_count = 1;
    }

    /// Add miss shader
    fn add_miss_shader(&mut self, ctx: &RenderContext, shader_id: &[u8; 32]) {
        let record = ShaderRecord {
            shader_identifier: *shader_id,
            local_arguments: [0; 32],
        };

        // Would append to buffer in practice
        self.miss_count += 1;
    }

    /// Add hit group
    fn add_hit_group(
        &mut self,
        ctx: &RenderContext,
        closest_hit_id: &[u8; 32],
        any_hit_id: Option<&[u8; 32]>,
        intersection_id: Option<&[u8; 32]>,
    ) {
        // Create hit group record
        let record = ShaderRecord {
            shader_identifier: *closest_hit_id,
            local_arguments: [0; 32],
        };

        self.hit_group_count += 1;
    }

    /// Get dispatch parameters
    fn get_dispatch_params(&self) -> SBTDispatchParams {
        SBTDispatchParams {
            ray_gen_address: self.ray_gen_buffer.device_address(),
            ray_gen_size: self.ray_gen_stride as u64,

            miss_address: self.miss_buffer.device_address(),
            miss_stride: self.miss_stride as u64,
            miss_size: (self.miss_count * self.miss_stride) as u64,

            hit_address: self.hit_group_buffer.device_address(),
            hit_stride: self.hit_group_stride as u64,
            hit_size: (self.hit_group_count * self.hit_group_stride) as u64,

            callable_address: self.callable_buffer.device_address(),
            callable_stride: self.callable_stride as u64,
            callable_size: (self.callable_count * self.callable_stride) as u64,
        }
    }
}

/// SBT dispatch parameters
struct SBTDispatchParams {
    ray_gen_address: u64,
    ray_gen_size: u64,

    miss_address: u64,
    miss_stride: u64,
    miss_size: u64,

    hit_address: u64,
    hit_stride: u64,
    hit_size: u64,

    callable_address: u64,
    callable_stride: u64,
    callable_size: u64,
}

// =============================================================================
// RT SHADOWS (WP-075)
// =============================================================================

/// RT shadow configuration
struct RTShadowConfig {
    /// Enable soft shadows
    soft_shadows: bool,
    /// Number of shadow rays for soft shadows
    shadow_rays: u32,
    /// Penumbra angle (for soft shadows)
    penumbra_angle: f32,
    /// Maximum shadow distance
    max_distance: f32,
    /// Shadow bias
    bias: f32,
    /// Use denoiser
    denoise: bool,
}

impl RTShadowConfig {
    fn default() -> Self {
        Self {
            soft_shadows: true,
            shadow_rays: 4,
            penumbra_angle: 0.02,
            max_distance: 1000.0,
            bias: 0.001,
            denoise: true,
        }
    }

    fn hard_shadows() -> Self {
        Self {
            soft_shadows: false,
            shadow_rays: 1,
            penumbra_angle: 0.0,
            max_distance: 1000.0,
            bias: 0.001,
            denoise: false,
        }
    }
}

/// RT shadow renderer
struct RTShadowRenderer {
    config: RTShadowConfig,
    /// Shadow output texture
    shadow_texture: Texture,
    /// Denoised shadow texture
    denoised_texture: Texture,
    /// Ray generation shader
    pipeline: RTPipeline,
}

impl RTShadowRenderer {
    fn new(ctx: &RenderContext, width: u32, height: u32, config: RTShadowConfig) -> Self {
        Self {
            config,
            shadow_texture: Texture::new_2d(ctx, width, height, TextureFormat::R8Unorm),
            denoised_texture: Texture::new_2d(ctx, width, height, TextureFormat::R8Unorm),
            pipeline: RTPipeline::new_shadow(ctx),
        }
    }

    /// Trace shadow rays
    fn trace(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        tlas: &TLAS,
        gbuffer: &GBuffer,
        light: &Light,
    ) {
        // Bind resources
        cmd.bind_rt_pipeline(&self.pipeline);
        cmd.bind_acceleration_structure(0, tlas);
        cmd.bind_texture(1, &gbuffer.position);
        cmd.bind_texture(2, &gbuffer.normal);
        cmd.bind_storage_texture(3, &self.shadow_texture);

        // Set light data
        let light_data = LightData {
            position: light.position,
            direction: light.direction,
            color: light.color,
            radius: light.radius,
            shadow_config: self.config.clone(),
        };
        cmd.push_constants(&light_data);

        // Dispatch rays
        let width = self.shadow_texture.width();
        let height = self.shadow_texture.height();
        cmd.trace_rays(width, height, 1);

        // Denoise if enabled
        if self.config.denoise {
            self.denoise(ctx, cmd);
        }
    }

    /// Denoise shadow map
    fn denoise(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        // Apply spatio-temporal denoising
        // Uses A-SVGF or similar technique
    }

    /// Get shadow texture
    fn get_shadow_texture(&self) -> &Texture {
        if self.config.denoise {
            &self.denoised_texture
        } else {
            &self.shadow_texture
        }
    }
}

/// Light data for shadow tracing
struct LightData {
    position: Vec3<f32>,
    direction: Vec3<f32>,
    color: Vec3<f32>,
    radius: f32,
    shadow_config: RTShadowConfig,
}

// =============================================================================
// RT AMBIENT OCCLUSION (WP-075)
// =============================================================================

/// RT ambient occlusion configuration
struct RTAOConfig {
    /// Number of AO rays per pixel
    ray_count: u32,
    /// AO radius (world units)
    radius: f32,
    /// AO falloff power
    falloff: f32,
    /// Use cosine-weighted hemisphere sampling
    cosine_weighted: bool,
    /// Apply temporal filtering
    temporal_filter: bool,
    /// Use denoiser
    denoise: bool,
}

impl RTAOConfig {
    fn default() -> Self {
        Self {
            ray_count: 4,
            radius: 2.0,
            falloff: 1.0,
            cosine_weighted: true,
            temporal_filter: true,
            denoise: true,
        }
    }

    fn high_quality() -> Self {
        Self {
            ray_count: 16,
            radius: 3.0,
            falloff: 1.5,
            cosine_weighted: true,
            temporal_filter: true,
            denoise: true,
        }
    }
}

/// RT ambient occlusion renderer
struct RTAORenderer {
    config: RTAOConfig,
    /// AO output texture
    ao_texture: Texture,
    /// History texture for temporal filtering
    history_texture: Texture,
    /// Denoised texture
    denoised_texture: Texture,
    /// Frame index for temporal jitter
    frame_index: u32,
}

impl RTAORenderer {
    fn new(ctx: &RenderContext, width: u32, height: u32, config: RTAOConfig) -> Self {
        Self {
            config,
            ao_texture: Texture::new_2d(ctx, width, height, TextureFormat::R8Unorm),
            history_texture: Texture::new_2d(ctx, width, height, TextureFormat::R8Unorm),
            denoised_texture: Texture::new_2d(ctx, width, height, TextureFormat::R8Unorm),
            frame_index: 0,
        }
    }

    /// Trace AO rays
    fn trace(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        tlas: &TLAS,
        gbuffer: &GBuffer,
    ) {
        // Generate random directions for AO
        let ao_data = RTAOData {
            ray_count: self.config.ray_count,
            radius: self.config.radius,
            falloff: self.config.falloff,
            frame_index: self.frame_index,
        };

        cmd.push_constants(&ao_data);

        // Dispatch AO rays
        let width = self.ao_texture.width();
        let height = self.ao_texture.height();
        cmd.trace_rays(width, height, 1);

        // Temporal accumulation
        if self.config.temporal_filter {
            self.temporal_filter(ctx, cmd, gbuffer);
        }

        // Denoise
        if self.config.denoise {
            self.denoise(ctx, cmd);
        }

        self.frame_index += 1;
    }

    /// Apply temporal filtering
    fn temporal_filter(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer, gbuffer: &GBuffer) {
        // Reproject using motion vectors
        // Blend with history
    }

    /// Denoise AO
    fn denoise(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        // Spatial denoising pass
    }
}

/// RTAO shader data
struct RTAOData {
    ray_count: u32,
    radius: f32,
    falloff: f32,
    frame_index: u32,
}

// =============================================================================
// RT REFLECTIONS (WP-076)
// =============================================================================

/// RT reflection configuration
struct RTReflectionConfig {
    /// Maximum reflection bounces
    max_bounces: u32,
    /// Use roughness-based ray cone
    roughness_cone: bool,
    /// Roughness threshold for RT (below uses SSR)
    roughness_threshold: f32,
    /// Number of rays per pixel
    rays_per_pixel: u32,
    /// Use importance sampling
    importance_sampling: bool,
    /// Apply denoiser
    denoise: bool,
    /// Fallback to SSR for secondary bounces
    ssr_fallback: bool,
}

impl RTReflectionConfig {
    fn default() -> Self {
        Self {
            max_bounces: 2,
            roughness_cone: true,
            roughness_threshold: 0.3,
            rays_per_pixel: 1,
            importance_sampling: true,
            denoise: true,
            ssr_fallback: true,
        }
    }
}

/// RT reflection renderer
struct RTReflectionRenderer {
    config: RTReflectionConfig,
    /// Reflection color texture
    reflection_texture: Texture,
    /// Hit distance texture
    distance_texture: Texture,
    /// Denoised reflection
    denoised_texture: Texture,
    /// History for temporal filtering
    history_texture: Texture,
}

impl RTReflectionRenderer {
    fn new(ctx: &RenderContext, width: u32, height: u32, config: RTReflectionConfig) -> Self {
        Self {
            config,
            reflection_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
            distance_texture: Texture::new_2d(ctx, width, height, TextureFormat::R32F),
            denoised_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
            history_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
        }
    }

    /// Trace reflection rays
    fn trace(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        tlas: &TLAS,
        gbuffer: &GBuffer,
        scene_color: &Texture,
    ) {
        let reflection_data = RTReflectionData {
            max_bounces: self.config.max_bounces,
            roughness_threshold: self.config.roughness_threshold,
            rays_per_pixel: self.config.rays_per_pixel,
            use_importance_sampling: self.config.importance_sampling as u32,
        };

        cmd.push_constants(&reflection_data);

        let width = self.reflection_texture.width();
        let height = self.reflection_texture.height();
        cmd.trace_rays(width, height, 1);

        if self.config.denoise {
            self.denoise(ctx, cmd);
        }
    }

    /// Denoise reflections
    fn denoise(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        // Apply reflection-aware denoising
        // Uses hit distance for filtering kernel size
    }
}

/// RT reflection shader data
struct RTReflectionData {
    max_bounces: u32,
    roughness_threshold: f32,
    rays_per_pixel: u32,
    use_importance_sampling: u32,
}

// =============================================================================
// RT REFRACTIONS (WP-076)
// =============================================================================

/// RT refraction configuration
struct RTRefractionConfig {
    /// Maximum refraction depth
    max_depth: u32,
    /// Enable dispersion (chromatic aberration)
    dispersion: bool,
    /// Dispersion amount
    dispersion_amount: f32,
    /// Enable caustics
    caustics: bool,
    /// Absorption color for volumetric materials
    absorption: Vec3<f32>,
    /// Absorption density
    absorption_density: f32,
}

impl RTRefractionConfig {
    fn default() -> Self {
        Self {
            max_depth: 4,
            dispersion: false,
            dispersion_amount: 0.01,
            caustics: false,
            absorption: Vec3::new(0.0, 0.0, 0.0),
            absorption_density: 0.0,
        }
    }
}

/// RT refraction renderer
struct RTRefractionRenderer {
    config: RTRefractionConfig,
    /// Refraction output texture
    refraction_texture: Texture,
}

impl RTRefractionRenderer {
    fn new(ctx: &RenderContext, width: u32, height: u32, config: RTRefractionConfig) -> Self {
        Self {
            config,
            refraction_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
        }
    }

    /// Trace refraction rays
    fn trace(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        tlas: &TLAS,
        gbuffer: &GBuffer,
        ior_buffer: &Texture, // Index of refraction per pixel
    ) {
        let refraction_data = RTRefractionData {
            max_depth: self.config.max_depth,
            dispersion: self.config.dispersion as u32,
            dispersion_amount: self.config.dispersion_amount,
            absorption: self.config.absorption,
            absorption_density: self.config.absorption_density,
        };

        cmd.push_constants(&refraction_data);

        let width = self.refraction_texture.width();
        let height = self.refraction_texture.height();
        cmd.trace_rays(width, height, 1);
    }

    /// Calculate refraction direction using Snell's law
    fn refract(incident: Vec3<f32>, normal: Vec3<f32>, eta: f32) -> Option<Vec3<f32>> {
        let cos_i = (-incident).dot(normal);
        let sin2_t = eta * eta * (1.0 - cos_i * cos_i);

        if sin2_t > 1.0 {
            // Total internal reflection
            return None;
        }

        let cos_t = (1.0 - sin2_t).sqrt();
        Some(incident * eta + normal * (eta * cos_i - cos_t))
    }
}

/// RT refraction shader data
struct RTRefractionData {
    max_depth: u32,
    dispersion: u32,
    dispersion_amount: f32,
    absorption: Vec3<f32>,
    absorption_density: f32,
}

// =============================================================================
// RT GLOBAL ILLUMINATION (WP-077)
// =============================================================================

/// RT GI configuration
struct RTGIConfig {
    /// Maximum path depth
    max_bounces: u32,
    /// Samples per pixel
    spp: u32,
    /// Use ReSTIR for importance resampling
    use_restir: bool,
    /// Use world-space irradiance cache
    irradiance_cache: bool,
    /// Cache grid resolution
    cache_resolution: u32,
    /// Enable infinite bounces (approximated)
    infinite_bounces: bool,
    /// GI intensity multiplier
    intensity: f32,
}

impl RTGIConfig {
    fn default() -> Self {
        Self {
            max_bounces: 3,
            spp: 1,
            use_restir: true,
            irradiance_cache: true,
            cache_resolution: 64,
            infinite_bounces: true,
            intensity: 1.0,
        }
    }

    fn high_quality() -> Self {
        Self {
            max_bounces: 5,
            spp: 4,
            use_restir: true,
            irradiance_cache: true,
            cache_resolution: 128,
            infinite_bounces: true,
            intensity: 1.0,
        }
    }
}

/// RT global illumination renderer
struct RTGIRenderer {
    config: RTGIConfig,
    /// Indirect lighting texture
    gi_texture: Texture,
    /// Denoised GI
    denoised_texture: Texture,
    /// Irradiance cache
    irradiance_cache: Option<IrradianceCache>,
    /// ReSTIR reservoirs
    restir_reservoirs: Option<ReSTIRReservoirs>,
    /// History buffer
    history_texture: Texture,
    /// Frame index
    frame_index: u32,
}

/// Irradiance cache for world-space caching
struct IrradianceCache {
    /// Irradiance probe data
    probes: Buffer<IrradianceProbe>,
    /// Probe grid dimensions
    grid_size: Vec3<u32>,
    /// World-space bounds
    bounds: AABB,
    /// Probe spacing
    spacing: Vec3<f32>,
}

/// Single irradiance probe
@align(32)
struct IrradianceProbe {
    /// SH coefficients for irradiance (L0, L1)
    sh_coeffs: [Vec4<f32>; 4],
    /// Visibility distance
    visibility_distance: f32,
    /// Last update frame
    last_update: u32,
    /// Validity flag
    valid: u32,
    _padding: u32,
}

/// ReSTIR reservoirs for temporal resampling
struct ReSTIRReservoirs {
    /// Current frame reservoirs
    current: Buffer<Reservoir>,
    /// Previous frame reservoirs
    previous: Buffer<Reservoir>,
    /// Reservoir count
    count: u32,
}

/// ReSTIR reservoir
@align(32)
struct Reservoir {
    /// Selected sample
    sample: RTGISample,
    /// Weight sum
    weight_sum: f32,
    /// Number of seen samples
    m: u32,
    /// Target PDF
    target_pdf: f32,
    /// UCW (unbiased contribution weight)
    ucw: f32,
}

/// GI sample for ReSTIR
@align(16)
struct RTGISample {
    /// Light sample direction
    direction: Vec3<f32>,
    /// Sample distance
    distance: f32,
    /// Incoming radiance
    radiance: Vec3<f32>,
    /// PDF of this sample
    pdf: f32,
}

impl RTGIRenderer {
    fn new(ctx: &RenderContext, width: u32, height: u32, config: RTGIConfig) -> Self {
        let irradiance_cache = if config.irradiance_cache {
            Some(IrradianceCache::new(ctx, config.cache_resolution))
        } else {
            None
        };

        let restir = if config.use_restir {
            Some(ReSTIRReservoirs::new(ctx, width * height))
        } else {
            None
        };

        Self {
            config,
            gi_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
            denoised_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
            irradiance_cache,
            restir_reservoirs: restir,
            history_texture: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
            frame_index: 0,
        }
    }

    /// Trace GI rays
    fn trace(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        tlas: &TLAS,
        gbuffer: &GBuffer,
    ) {
        // Update irradiance cache if enabled
        if let Some(ref mut cache) = self.irradiance_cache {
            self.update_irradiance_cache(ctx, cmd, tlas, cache);
        }

        // Initial candidate generation
        let gi_data = RTGIData {
            max_bounces: self.config.max_bounces,
            spp: self.config.spp,
            intensity: self.config.intensity,
            frame_index: self.frame_index,
            use_cache: self.irradiance_cache.is_some() as u32,
        };

        cmd.push_constants(&gi_data);

        let width = self.gi_texture.width();
        let height = self.gi_texture.height();

        // ReSTIR temporal resampling
        if let Some(ref mut restir) = self.restir_reservoirs {
            self.restir_temporal(ctx, cmd, restir);
            self.restir_spatial(ctx, cmd, restir);
        }

        // Final shading
        cmd.trace_rays(width, height, 1);

        // Denoise
        self.denoise(ctx, cmd);

        self.frame_index += 1;
    }

    /// Update irradiance cache probes
    fn update_irradiance_cache(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        tlas: &TLAS,
        cache: &mut IrradianceCache,
    ) {
        // Update subset of probes each frame
        let probes_per_frame = (cache.grid_size.x * cache.grid_size.y * cache.grid_size.z) / 16;

        // Trace rays for probe update
        cmd.trace_rays(probes_per_frame, 64, 1); // 64 directions per probe
    }

    /// ReSTIR temporal resampling pass
    fn restir_temporal(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        restir: &mut ReSTIRReservoirs,
    ) {
        // Combine current samples with temporal history
    }

    /// ReSTIR spatial resampling pass
    fn restir_spatial(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        restir: &mut ReSTIRReservoirs,
    ) {
        // Spatial reservoir exchange
    }

    /// Denoise GI result
    fn denoise(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        // Apply SVGF or similar denoiser
    }
}

impl IrradianceCache {
    fn new(ctx: &RenderContext, resolution: u32) -> Self {
        let grid_size = Vec3::new(resolution, resolution / 2, resolution);
        let probe_count = (grid_size.x * grid_size.y * grid_size.z) as usize;

        Self {
            probes: Buffer::new_capacity(ctx, probe_count, BufferUsage::STORAGE),
            grid_size,
            bounds: AABB::new(Vec3::splat(-50.0), Vec3::splat(50.0)),
            spacing: Vec3::new(
                100.0 / resolution as f32,
                50.0 / (resolution / 2) as f32,
                100.0 / resolution as f32,
            ),
        }
    }
}

impl ReSTIRReservoirs {
    fn new(ctx: &RenderContext, count: u32) -> Self {
        Self {
            current: Buffer::new_capacity(ctx, count as usize, BufferUsage::STORAGE),
            previous: Buffer::new_capacity(ctx, count as usize, BufferUsage::STORAGE),
            count,
        }
    }

    fn swap(&mut self) {
        std::mem::swap(&mut self.current, &mut self.previous);
    }
}

/// RTGI shader data
struct RTGIData {
    max_bounces: u32,
    spp: u32,
    intensity: f32,
    frame_index: u32,
    use_cache: u32,
}

// =============================================================================
// HYBRID PIPELINE (WP-078)
// =============================================================================

/// Hybrid rendering mode
#[derive(Clone, Copy, PartialEq, Eq)]
enum HybridMode {
    /// Rasterization only
    RasterOnly,
    /// RT shadows only
    RTShadows,
    /// RT shadows + AO
    RTShadowsAO,
    /// RT shadows + reflections
    RTShadowsReflections,
    /// Full RT (shadows, AO, reflections, GI)
    FullRT,
    /// Path tracing
    PathTracing,
}

/// Hybrid RT-Raster pipeline
struct HybridPipeline {
    mode: HybridMode,
    /// RT shadow renderer
    shadows: RTShadowRenderer,
    /// RT AO renderer
    ao: RTAORenderer,
    /// RT reflection renderer
    reflections: RTReflectionRenderer,
    /// RT GI renderer
    gi: RTGIRenderer,
    /// TLAS for scene
    tlas: TLAS,
    /// BLAS collection
    blas_collection: Vec<BLAS>,
    /// Instance descriptions
    instances: Vec<InstanceDesc>,
}

impl HybridPipeline {
    fn new(ctx: &RenderContext, width: u32, height: u32, mode: HybridMode) -> Self {
        Self {
            mode,
            shadows: RTShadowRenderer::new(ctx, width, height, RTShadowConfig::default()),
            ao: RTAORenderer::new(ctx, width, height, RTAOConfig::default()),
            reflections: RTReflectionRenderer::new(ctx, width, height, RTReflectionConfig::default()),
            gi: RTGIRenderer::new(ctx, width, height, RTGIConfig::default()),
            tlas: TLAS::new(ctx, MAX_TLAS_INSTANCES, TLASBuildFlags::AllowUpdate),
            blas_collection: Vec::new(),
            instances: Vec::new(),
        }
    }

    /// Add mesh to scene
    fn add_mesh(&mut self, ctx: &RenderContext, mesh: &Mesh) -> usize {
        let geom = GeometryDesc {
            geometry_type: GeometryType::Triangles,
            flags: GeometryFlags::Opaque,
            vertex_buffer: Some(mesh.vertex_buffer.clone()),
            vertex_stride: std::mem::size_of::<Vertex>() as u32,
            vertex_count: mesh.vertex_count,
            index_buffer: Some(mesh.index_buffer.clone()),
            index_count: mesh.index_count,
            transform: None,
            aabb_buffer: None,
            aabb_count: 0,
        };

        let blas = BLAS::new(ctx, vec![geom], BLASBuildFlags::PreferFastTrace);
        let idx = self.blas_collection.len();
        self.blas_collection.push(blas);
        idx
    }

    /// Add instance
    fn add_instance(
        &mut self,
        blas_index: usize,
        transform: Mat3x4<f32>,
        material_id: u32,
    ) {
        let blas = &self.blas_collection[blas_index];
        let instance = InstanceDesc::new(
            transform,
            self.instances.len() as u32,
            0xFF,
            material_id,
            InstanceFlags::None as u8,
            blas,
        );
        self.instances.push(instance);
    }

    /// Build acceleration structures
    fn build(&mut self, ctx: &RenderContext, cmd: &mut CommandBuffer) {
        // Build all BLAS
        for blas in &mut self.blas_collection {
            blas.build(ctx, cmd);
        }

        // Update instance buffer
        self.tlas.update_instances(ctx, &self.instances);

        // Build TLAS
        self.tlas.build(ctx, cmd);
    }

    /// Render frame
    fn render(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        gbuffer: &GBuffer,
        lights: &[Light],
        camera: &Camera,
    ) -> HybridOutput {
        let mut output = HybridOutput::default();

        match self.mode {
            HybridMode::RasterOnly => {
                // No RT effects
            }
            HybridMode::RTShadows => {
                for light in lights {
                    self.shadows.trace(ctx, cmd, &self.tlas, gbuffer, light);
                }
                output.shadow_texture = Some(self.shadows.get_shadow_texture().clone());
            }
            HybridMode::RTShadowsAO => {
                for light in lights {
                    self.shadows.trace(ctx, cmd, &self.tlas, gbuffer, light);
                }
                self.ao.trace(ctx, cmd, &self.tlas, gbuffer);
                output.shadow_texture = Some(self.shadows.get_shadow_texture().clone());
                output.ao_texture = Some(self.ao.ao_texture.clone());
            }
            HybridMode::RTShadowsReflections => {
                for light in lights {
                    self.shadows.trace(ctx, cmd, &self.tlas, gbuffer, light);
                }
                self.reflections.trace(ctx, cmd, &self.tlas, gbuffer, &gbuffer.color);
                output.shadow_texture = Some(self.shadows.get_shadow_texture().clone());
                output.reflection_texture = Some(self.reflections.reflection_texture.clone());
            }
            HybridMode::FullRT => {
                for light in lights {
                    self.shadows.trace(ctx, cmd, &self.tlas, gbuffer, light);
                }
                self.ao.trace(ctx, cmd, &self.tlas, gbuffer);
                self.reflections.trace(ctx, cmd, &self.tlas, gbuffer, &gbuffer.color);
                self.gi.trace(ctx, cmd, &self.tlas, gbuffer);

                output.shadow_texture = Some(self.shadows.get_shadow_texture().clone());
                output.ao_texture = Some(self.ao.ao_texture.clone());
                output.reflection_texture = Some(self.reflections.reflection_texture.clone());
                output.gi_texture = Some(self.gi.gi_texture.clone());
            }
            HybridMode::PathTracing => {
                // Full path tracing - handled by path_tracing.quanta
            }
        }

        output
    }
}

/// Hybrid pipeline output
struct HybridOutput {
    shadow_texture: Option<Texture>,
    ao_texture: Option<Texture>,
    reflection_texture: Option<Texture>,
    gi_texture: Option<Texture>,
}

impl HybridOutput {
    fn default() -> Self {
        Self {
            shadow_texture: None,
            ao_texture: None,
            reflection_texture: None,
            gi_texture: None,
        }
    }
}

