/// Denoiser type
#[derive(Clone, Copy, PartialEq, Eq)]
enum DenoiserType {
    /// NVIDIA NRD
    NRD,
    /// A-SVGF
    ASVGF,
    /// BMFR
    BMFR,
    /// Custom bilateral
    Bilateral,
}

/// Ray tracing denoiser
struct RTDenoiser {
    denoiser_type: DenoiserType,
    /// History buffer for temporal accumulation
    history: Texture,
    /// Moments buffer for variance estimation
    moments: Texture,
    /// Temporal weight
    temporal_weight: f32,
}

impl RTDenoiser {
    fn new(ctx: &RenderContext, width: u32, height: u32, denoiser_type: DenoiserType) -> Self {
        Self {
            denoiser_type,
            history: Texture::new_2d(ctx, width, height, TextureFormat::RGBA16F),
            moments: Texture::new_2d(ctx, width, height, TextureFormat::RG16F),
            temporal_weight: 0.95,
        }
    }

    /// Denoise input texture
    fn denoise(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        gbuffer: &GBuffer,
        output: &Texture,
    ) {
        match self.denoiser_type {
            DenoiserType::NRD => self.denoise_nrd(ctx, cmd, input, gbuffer, output),
            DenoiserType::ASVGF => self.denoise_asvgf(ctx, cmd, input, gbuffer, output),
            DenoiserType::BMFR => self.denoise_bmfr(ctx, cmd, input, gbuffer, output),
            DenoiserType::Bilateral => self.denoise_bilateral(ctx, cmd, input, gbuffer, output),
        }
    }

    fn denoise_nrd(
        &mut self,
        ctx: &RenderContext,
        cmd: &mut CommandBuffer,
        input: &Texture,
        gbuffer: &GBuffer,
        output: &Texture,
    ) {
