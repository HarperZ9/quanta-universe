// =============================================================================
// RT PERFORMANCE METRICS
// =============================================================================

/// RT performance statistics
struct RTStats {
    /// Total rays traced
    rays_traced: u64,
    /// TLAS traversal time (ns)
    tlas_time_ns: u64,
    /// BLAS traversal time (ns)
    blas_time_ns: u64,
    /// Intersection time (ns)
    intersection_time_ns: u64,
    /// Shading time (ns)
    shading_time_ns: u64,
    /// Denoising time (ns)
    denoise_time_ns: u64,
    /// Total frame time (ms)
    frame_time_ms: f32,
    /// Rays per second
    rays_per_second: f64,
}

impl RTStats {
    fn default() -> Self {
        Self {
            rays_traced: 0,
            tlas_time_ns: 0,
            blas_time_ns: 0,
            intersection_time_ns: 0,
            shading_time_ns: 0,
            denoise_time_ns: 0,
            frame_time_ms: 0.0,
            rays_per_second: 0.0,
        }
    }

    fn update(&mut self, rays: u64, frame_time: f32) {
        self.rays_traced = rays;
        self.frame_time_ms = frame_time;
        self.rays_per_second = (rays as f64 / frame_time as f64) * 1000.0;
    }
}

// =============================================================================
// MULTI-BOUNCE PATH TRACING (WP-080)
// =============================================================================

/// Multi-bounce configuration
struct MultiBounceConfig {
    /// Maximum path length
    max_bounces: u32,
    /// Russian roulette start depth
    rr_start_depth: u32,
    /// Russian roulette survival probability
    rr_survival_prob: f32,
    /// Use next event estimation
    nee: bool,
    /// Use multiple importance sampling
    mis: bool,
    /// Use path regularization
    path_regularization: bool,
    /// Regularization roughness
    regularization_roughness: f32,
}

impl MultiBounceConfig {
    fn default() -> Self {
        Self {
            max_bounces: 8,
            rr_start_depth: 3,
            rr_survival_prob: 0.95,
            nee: true,
            mis: true,
            path_regularization: true,
            regularization_roughness: 0.3,
        }
    }
}

/// Multi-bounce path state
struct PathState {
    /// Current ray
    ray: Ray,
    /// Path throughput
    throughput: Vec3<f32>,
    /// Accumulated radiance
    radiance: Vec3<f32>,
    /// Current bounce
    bounce: u32,
    /// Is specular path
    specular: bool,
    /// Previous hit PDF
    prev_pdf: f32,
    /// Previous hit normal
    prev_normal: Vec3<f32>,
}

impl PathState {
    fn new(ray: Ray) -> Self {
        Self {
            ray,
            throughput: Vec3::splat(1.0),
            radiance: Vec3::zero(),
            bounce: 0,
            specular: true,
            prev_pdf: 1.0,
            prev_normal: Vec3::zero(),
        }
    }

    /// Apply Russian roulette
    fn russian_roulette(&mut self, config: &MultiBounceConfig, rng: &mut RNG) -> bool {
        if self.bounce < config.rr_start_depth {
            return true;
        }

        let survival = self.throughput.max_component().min(config.rr_survival_prob);

        if rng.next_f32() > survival {
            return false;
        }

        self.throughput = self.throughput / survival;
        true
    }
}

/// Multi-bounce path tracer
struct MultiBounceTracer {
    config: MultiBounceConfig,
}

impl MultiBounceTracer {
    fn new(config: MultiBounceConfig) -> Self {
        Self { config }
    }

    /// Trace a complete path
    fn trace_path(
        &self,
        initial_ray: Ray,
        tlas: &TLAS,
        scene: &Scene,
        rng: &mut RNG,
    ) -> Vec3<f32> {
        let mut state = PathState::new(initial_ray);

        while state.bounce < self.config.max_bounces {
            // Intersect ray with scene
            let hit = self.intersect(&state.ray, tlas);

            if hit.is_none() {
                // Miss - add environment contribution
                if state.specular || !self.config.nee {
                    state.radiance = state.radiance + state.throughput * scene.environment_radiance(state.ray.direction);
                }
                break;
            }

            let hit = hit.unwrap();
            let material = scene.get_material(hit.material_id);

            // Add emission
            if state.specular || !self.config.nee {
                state.radiance = state.radiance + state.throughput * material.emission;
            }

            // Next event estimation (direct light sampling)
            if self.config.nee && !material.is_specular() {
                let direct = self.sample_direct_light(
                    &hit, material, scene, tlas, rng,
                );
                state.radiance = state.radiance + state.throughput * direct;
            }

            // Sample BSDF for next direction
            let (bsdf_dir, bsdf_pdf, bsdf_value, is_specular) = material.sample(
                hit.wo, hit.normal, rng,
            );

            if bsdf_pdf <= 0.0 || bsdf_value.is_zero() {
                break;
            }

            // Update throughput
            let cos_theta = bsdf_dir.dot(hit.normal).abs();
            state.throughput = state.throughput * bsdf_value * cos_theta / bsdf_pdf;

            // Update path state
            state.ray = Ray::new(hit.position + hit.normal * 0.001, bsdf_dir);
            state.specular = is_specular;
            state.prev_pdf = bsdf_pdf;
            state.prev_normal = hit.normal;
            state.bounce += 1;

            // Russian roulette
            if !state.russian_roulette(&self.config, rng) {
                break;
            }

            // Path regularization (reduce fireflies)
            if self.config.path_regularization && state.bounce > 1 {
                self.apply_regularization(&mut state);
            }
        }

        state.radiance
    }

    /// Intersect ray with TLAS
    fn intersect(&self, ray: &Ray, tlas: &TLAS) -> Option<PathHit> {
        // Would dispatch TraceRay in actual implementation
        None
    }

    /// Sample direct lighting with MIS
    fn sample_direct_light(
        &self,
        hit: &PathHit,
        material: &Material,
        scene: &Scene,
        tlas: &TLAS,
        rng: &mut RNG,
    ) -> Vec3<f32> {
        let mut result = Vec3::zero();

        // Sample a light
        let (light, light_pdf) = scene.sample_light(rng);

        // Sample point on light
        let (light_pos, light_normal, light_radiance, light_sample_pdf) = light.sample(hit.position, rng);

        let to_light = light_pos - hit.position;
        let dist = to_light.length();
        let light_dir = to_light / dist;

        // Visibility check
        let shadow_ray = Ray::new(hit.position + hit.normal * 0.001, light_dir);
        if self.trace_shadow(shadow_ray, dist - 0.001, tlas) {
            return result;
        }

        // Evaluate BSDF
        let bsdf_value = material.evaluate(hit.wo, light_dir, hit.normal);
        let bsdf_pdf = material.pdf(hit.wo, light_dir, hit.normal);

        // Geometry term
        let cos_theta_hit = light_dir.dot(hit.normal).abs();
        let cos_theta_light = (-light_dir).dot(light_normal).abs();
        let geometry = cos_theta_hit * cos_theta_light / (dist * dist);

        // MIS weight
        let pdf_light = light_pdf * light_sample_pdf;
        let pdf_bsdf = bsdf_pdf;
        let mis_weight = if self.config.mis {
            power_heuristic(pdf_light, pdf_bsdf)
        } else {
            1.0
        };

        result = bsdf_value * light_radiance * geometry * mis_weight / pdf_light;

        result
    }

    /// Trace shadow ray
    fn trace_shadow(&self, ray: Ray, max_dist: f32, tlas: &TLAS) -> bool {
        // Would use TraceRay with shadow flags
        false
    }

    /// Apply path regularization to reduce fireflies
    fn apply_regularization(&self, state: &mut PathState) {
        // Clamp throughput to prevent fireflies
        let max_throughput = 10.0;
        let current_max = state.throughput.max_component();
        if current_max > max_throughput {
            state.throughput = state.throughput * (max_throughput / current_max);
        }
    }
}

/// Path hit information
struct PathHit {
    position: Vec3<f32>,
    normal: Vec3<f32>,
    wo: Vec3<f32>,
    uv: Vec2<f32>,
    material_id: u32,
}

/// Power heuristic for MIS
fn power_heuristic(pdf_a: f32, pdf_b: f32) -> f32 {
    let a2 = pdf_a * pdf_a;
    let b2 = pdf_b * pdf_b;
    a2 / (a2 + b2)
}

// =============================================================================
// TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_ray_flags() {
        let shadow_flags = RayFlags::shadow();
        assert!((shadow_flags & RayFlags::ForceOpaque as u32) != 0);
        assert!((shadow_flags & RayFlags::AcceptFirstHit as u32) != 0);
    }

    #[test]
    fn test_aabb() {
        let aabb = AABB::new(Vec3::splat(-1.0), Vec3::splat(1.0));

        assert_eq!(aabb.center(), Vec3::zero());
        assert_eq!(aabb.extent(), Vec3::splat(2.0));
        assert!((aabb.surface_area() - 24.0).abs() < 0.001);
    }

    #[test]
    fn test_aabb_merge() {
        let a = AABB::new(Vec3::splat(-1.0), Vec3::splat(0.0));
        let b = AABB::new(Vec3::splat(0.0), Vec3::splat(1.0));

        let merged = a.merge(&b);
        assert_eq!(merged.min, Vec3::splat(-1.0));
        assert_eq!(merged.max, Vec3::splat(1.0));
    }

    #[test]
    fn test_instance_desc() {
        let transform = Mat3x4::identity();
        let instance = InstanceDesc {
            transform,
            instance_id_and_mask: 0x00FFFFFF | (0xFF << 24),
            sbt_offset_and_flags: 0,
            blas_address: 0x12345678,
        };

        let id = instance.instance_id_and_mask & 0xFFFFFF;
        let mask = (instance.instance_id_and_mask >> 24) as u8;

        assert_eq!(id, 0xFFFFFF);
        assert_eq!(mask, 0xFF);
    }

    #[test]
    fn test_refract_snells_law() {
        let incident = Vec3::new(0.0, -1.0, 0.0).normalize();
        let normal = Vec3::new(0.0, 1.0, 0.0);
        let eta = 1.0 / 1.5; // Air to glass

        let refracted = RTRefractionRenderer::refract(incident, normal, eta);
        assert!(refracted.is_some());
    }

    #[test]
    fn test_total_internal_reflection() {
        let incident = Vec3::new(0.707, -0.707, 0.0).normalize();
        let normal = Vec3::new(0.0, 1.0, 0.0);
        let eta = 1.5; // Glass to air, high angle

        // This angle should cause TIR
        let refracted = RTRefractionRenderer::refract(incident, normal, eta);
        // May or may not be TIR depending on exact angle
    }

    #[test]
    fn test_power_heuristic() {
        assert!((power_heuristic(1.0, 1.0) - 0.5).abs() < 0.001);
        assert!((power_heuristic(1.0, 0.0) - 1.0).abs() < 0.001);
        assert!((power_heuristic(0.0, 1.0) - 0.0).abs() < 0.001);
    }

    #[test]
    fn test_rt_stats() {
        let mut stats = RTStats::default();
        stats.update(1_000_000, 16.67);

        assert_eq!(stats.rays_traced, 1_000_000);
        assert!(stats.rays_per_second > 50_000_000.0);
    }

    #[test]
    fn test_path_state() {
        let ray = Ray::new(Vec3::zero(), Vec3::new(0.0, 0.0, 1.0));
        let state = PathState::new(ray);

        assert_eq!(state.bounce, 0);
        assert_eq!(state.throughput, Vec3::splat(1.0));
        assert!(state.specular);
    }

    #[test]
    fn test_hybrid_mode() {
        assert_ne!(HybridMode::RasterOnly, HybridMode::FullRT);
        assert_eq!(HybridMode::RTShadows, HybridMode::RTShadows);
    }

    #[test]
    fn test_denoiser_types() {
        assert_ne!(DenoiserType::NRD, DenoiserType::ASVGF);
    }

    #[test]
    fn test_multi_bounce_config() {
        let config = MultiBounceConfig::default();
        assert_eq!(config.max_bounces, 8);
        assert!(config.nee);
        assert!(config.mis);
    }

    #[test]
    fn test_geometry_flags() {
        let opaque = GeometryFlags::Opaque as u32;
        let no_dup = GeometryFlags::NoDuplicateAnyHit as u32;

        assert_eq!(opaque, 0x01);
        assert_eq!(no_dup, 0x02);
    }
}
