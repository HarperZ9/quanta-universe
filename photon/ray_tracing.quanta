    sbt: ShaderBindingTable,
    /// Max ray recursion depth
    max_recursion: u32,
    /// Max payload size
    max_payload_size: u32,
    /// Max attribute size
    max_attribute_size: u32,
}

impl RTPipeline {
    fn new_shadow(ctx: &RenderContext) -> Self {
        let mut sbt = ShaderBindingTable::new(ctx);
        // Setup shadow ray gen, miss, and hit shaders

        Self {
            handle: 0,
            sbt,
            max_recursion: 1,
            max_payload_size: 32,
            max_attribute_size: 8,
        }
    }

    fn new_reflection(ctx: &RenderContext, max_bounces: u32) -> Self {
        let sbt = ShaderBindingTable::new(ctx);

        Self {
            handle: 0,
            sbt,
            max_recursion: max_bounces,
            max_payload_size: 64,
            max_attribute_size: 8,
        }
    }

    fn new_gi(ctx: &RenderContext, max_bounces: u32) -> Self {
        let sbt = ShaderBindingTable::new(ctx);

        Self {
            handle: 0,
            sbt,
            max_recursion: max_bounces,
            max_payload_size: 96,
            max_attribute_size: 8,
        }
    }
}

