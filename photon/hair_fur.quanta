// hair_fur.quanta - Hair and Fur Rendering System
// Part of the Photon Rendering Module
// Implements strand-based hair rendering, fur shells, Marschner scattering, and real-time strand simulation

import std::collections::{HashMap, Vec, VecDeque}
import std::math::{Vec2, Vec3, Vec4, Mat3, Mat4, Quaternion, sqrt, pow, exp, sin, cos, tan, acos, atan2, PI, floor, ceil, clamp, lerp, min, max, abs, dot, cross, normalize, length}
import std::memory::{Arena, Pool, Box, Arc, Rc}
import std::sync::{Mutex, RwLock, Atomic}
import std::simd::{f32x4, f32x8, i32x4, i32x8}

// ============================================================================
// HAIR STRAND REPRESENTATION
// ============================================================================

/// Hair strand segment representation
struct HairSegment {
    position: Vec3,
    tangent: Vec3,
    thickness: f32,
    texcoord: f32,      // Normalized position along strand (0-1)
}

/// Complete hair strand (multiple segments)
struct HairStrand {
    segments: Vec<HairSegment>,
    root_position: Vec3,
    root_normal: Vec3,
    root_uv: Vec2,
    strand_id: u32,
    group_id: u32,
    length: f32,
}

impl HairStrand {
    fn new(root: Vec3, normal: Vec3, uv: Vec2, strand_id: u32, group_id: u32) -> Self {
        Self {
            segments: Vec::new(),
            root_position: root,
            root_normal: normal,
            root_uv: uv,
            strand_id,
            group_id,
            length: 0.0,
        }
    }

    fn add_segment(&mut self, position: Vec3, thickness: f32) {
        let tangent = if self.segments.is_empty() {
            self.root_normal
        } else {
            let prev_pos = self.segments.last().unwrap().position;
            normalize(position - prev_pos)
        };

        let texcoord = self.segments.len() as f32;

        self.segments.push(HairSegment {
            position,
            tangent,
            thickness,
            texcoord,
        });
    }

    fn finalize(&mut self) {
        // Calculate total length and normalize texcoords
        let mut accumulated_length = 0.0;
        let mut lengths = Vec::with_capacity(self.segments.len());

        for i in 1..self.segments.len() {
            let dist = length(self.segments[i].position - self.segments[i-1].position);
            accumulated_length += dist;
            lengths.push(accumulated_length);
        }

        self.length = accumulated_length;

        // Normalize texcoords
        if self.length > 0.0 {
            for i in 0..self.segments.len() {
                self.segments[i].texcoord = if i == 0 {
                    0.0
                } else {
                    lengths[i - 1] / self.length
                };
            }
        }

        // Recalculate tangents using Catmull-Rom
        for i in 1..self.segments.len() - 1 {
            let p0 = self.segments[i - 1].position;
            let p2 = self.segments[i + 1].position;
            self.segments[i].tangent = normalize(p2 - p0);
        }
    }

    fn get_position_at(&self, t: f32) -> Vec3 {
        if self.segments.is_empty() {
            return self.root_position;
        }

        let t = clamp(t, 0.0, 1.0);

        // Find segment pair
        for i in 0..self.segments.len() - 1 {
            let t0 = self.segments[i].texcoord;
            let t1 = self.segments[i + 1].texcoord;

            if t >= t0 && t <= t1 {
                let local_t = (t - t0) / (t1 - t0);
                return self.segments[i].position * (1.0 - local_t) +
                       self.segments[i + 1].position * local_t;
            }
        }

        self.segments.last().unwrap().position
    }

    fn get_tangent_at(&self, t: f32) -> Vec3 {
        if self.segments.is_empty() {
            return self.root_normal;
        }

        let t = clamp(t, 0.0, 1.0);

        for i in 0..self.segments.len() - 1 {
            let t0 = self.segments[i].texcoord;
            let t1 = self.segments[i + 1].texcoord;

            if t >= t0 && t <= t1 {
                let local_t = (t - t0) / (t1 - t0);
                return normalize(
                    self.segments[i].tangent * (1.0 - local_t) +
                    self.segments[i + 1].tangent * local_t
                );
            }
        }

        self.segments.last().unwrap().tangent
    }
}

/// GPU-packed hair vertex data
struct GpuHairVertex {
    position: Vec3,
    tangent_thickness: Vec4,  // xyz = tangent, w = thickness
    texcoord_strand_id: Vec4, // x = texcoord, y = strand_id, z = group_id, w = reserved
}

/// Hair strand group (groom)
struct HairGroup {
    name: String,
    strands: Vec<HairStrand>,
    material_id: u32,

    // Group properties
    base_color: Vec3,
    tip_color: Vec3,
    root_thickness: f32,
    tip_thickness: f32,
    randomize_length: f32,
    randomize_thickness: f32,

    // Clumping
    clump_scale: f32,
    clump_noise: f32,
    clump_power: f32,

    // GPU data
    vertex_buffer: Option<BufferHandle>,
    index_buffer: Option<BufferHandle>,
    strand_count: u32,
    segment_count: u32,
}

impl HairGroup {
    fn new(name: String, material_id: u32) -> Self {
        Self {
            name,
            strands: Vec::new(),
            material_id,
            base_color: Vec3::new(0.3, 0.2, 0.1),
            tip_color: Vec3::new(0.4, 0.3, 0.2),
            root_thickness: 0.01,
            tip_thickness: 0.005,
            randomize_length: 0.1,
            randomize_thickness: 0.2,
            clump_scale: 0.5,
            clump_noise: 0.2,
            clump_power: 0.7,
            vertex_buffer: None,
            index_buffer: None,
            strand_count: 0,
            segment_count: 0,
        }
    }

    fn add_strand(&mut self, strand: HairStrand) {
        self.strands.push(strand);
    }

    fn build_gpu_buffers(&mut self, device: &Device) {
        let mut vertices = Vec::new();
        let mut indices = Vec::new();

        let mut vertex_offset = 0u32;

        for strand in &self.strands {
            for segment in &strand.segments {
                vertices.push(GpuHairVertex {
                    position: segment.position,
                    tangent_thickness: Vec4::new(
                        segment.tangent.x,
                        segment.tangent.y,
                        segment.tangent.z,
                        segment.thickness
                    ),
                    texcoord_strand_id: Vec4::new(
                        segment.texcoord,
                        strand.strand_id as f32,
                        strand.group_id as f32,
                        0.0
                    ),
                });
            }

            // Create line strip indices for this strand
            for i in 0..strand.segments.len() as u32 - 1 {
                indices.push(vertex_offset + i);
                indices.push(vertex_offset + i + 1);
            }

            vertex_offset += strand.segments.len() as u32;
        }

        self.vertex_buffer = Some(device.create_buffer_with_data(
            &BufferDescriptor {
                size: vertices.len() * std::mem::size_of::<GpuHairVertex>(),
                usage: BufferUsage::VERTEX | BufferUsage::STORAGE,
                ..Default::default()
            },
            bytemuck::cast_slice(&vertices)
        ));

        self.index_buffer = Some(device.create_buffer_with_data(
            &BufferDescriptor {
                size: indices.len() * std::mem::size_of::<u32>(),
                usage: BufferUsage::INDEX,
                ..Default::default()
            },
            bytemuck::cast_slice(&indices)
        ));

        self.strand_count = self.strands.len() as u32;
        self.segment_count = vertex_offset;
    }
}

// ============================================================================
// MARSCHNER HAIR SCATTERING MODEL
// ============================================================================

/// Hair scattering lobe types
enum HairLobe {
    R,    // Reflection
    TT,   // Transmission-Transmission
    TRT,  // Transmission-Reflection-Transmission
    TRRT, // Double internal reflection
}

/// Marschner hair BSDF parameters
struct MarschnerParams {
    // Melanin-based color
    melanin: f32,
    melanin_redness: f32,
    melanin_randomize: f32,

    // Cuticle angles
    cuticle_angle: f32,       // Degrees, typically 2-3
    cuticle_angle_randomize: f32,

    // Roughness
    roughness: f32,
    roughness_radial: f32,
    roughness_azimuthal: f32,

    // Index of refraction
    ior: f32,

    // Direct vs indirect lighting split
    direct_intensity: f32,
    indirect_intensity: f32,
}

impl MarschnerParams {
    fn default() -> Self {
        Self {
            melanin: 0.5,
            melanin_redness: 0.0,
            melanin_randomize: 0.1,
            cuticle_angle: 2.0,
            cuticle_angle_randomize: 0.5,
            roughness: 0.3,
            roughness_radial: 0.3,
            roughness_azimuthal: 0.5,
            ior: 1.55,
            direct_intensity: 1.0,
            indirect_intensity: 0.5,
        }
    }

    fn blonde() -> Self {
        Self {
            melanin: 0.2,
            melanin_redness: 0.2,
            ..Self::default()
        }
    }

    fn brunette() -> Self {
        Self {
            melanin: 0.6,
            melanin_redness: 0.0,
            ..Self::default()
        }
    }

    fn red() -> Self {
        Self {
            melanin: 0.4,
            melanin_redness: 0.8,
            ..Self::default()
        }
    }

    fn black() -> Self {
        Self {
            melanin: 1.0,
            melanin_redness: 0.0,
            ..Self::default()
        }
    }

    fn white() -> Self {
        Self {
            melanin: 0.0,
            melanin_redness: 0.0,
            ..Self::default()
        }
    }
}

/// Marschner hair BSDF evaluation
struct MarschnerBsdf {
    params: MarschnerParams,
}

impl MarschnerBsdf {
    fn new(params: MarschnerParams) -> Self {
        Self { params }
    }

    /// Calculate absorption coefficient from melanin
    fn absorption_coefficient(&self) -> Vec3 {
        // Eumelanin (brown/black) absorption
        let eumelanin = Vec3::new(0.419, 0.697, 1.37);
        // Pheomelanin (red/blonde) absorption
        let pheomelanin = Vec3::new(0.187, 0.4, 1.05);

        let melanin = self.params.melanin;
        let redness = self.params.melanin_redness;

        eumelanin * melanin * (1.0 - redness) + pheomelanin * melanin * redness
    }

    /// Fresnel for dielectric
    fn fresnel_dielectric(&self, cos_theta: f32, eta: f32) -> f32 {
        let c = cos_theta;
        let g_squared = eta * eta - 1.0 + c * c;

        if g_squared < 0.0 {
            return 1.0; // Total internal reflection
        }

        let g = sqrt(g_squared);
        let a = (g - c) / (g + c);
        let b = (c * (g + c) - 1.0) / (c * (g - c) + 1.0);

        0.5 * a * a * (1.0 + b * b)
    }

    /// Longitudinal scattering function M
    fn m_function(&self, theta_h: f32, alpha: f32, beta: f32) -> f32 {
        let gaussian = |x: f32, variance: f32| -> f32 {
            exp(-x * x / (2.0 * variance * variance)) / (sqrt(2.0 * PI) * variance)
        };

        gaussian(theta_h - alpha, beta)
    }

    /// Azimuthal scattering function N
    fn n_function(&self, phi: f32, p: i32, gamma_t: f32, sigma_a: Vec3) -> Vec3 {
        let h = sin(gamma_t);
        let gamma_i = asin(clamp(h, -1.0, 1.0));

        // Fresnel term
        let f = self.fresnel_dielectric(cos(gamma_i), self.params.ior);

        match p {
            0 => {
                // R lobe
                Vec3::splat(f * 0.25 * cos(phi / 2.0))
            }
            1 => {
                // TT lobe
                let t = (1.0 - f) * (1.0 - f);
                let a = (-2.0 * sigma_a * (1.0 + cos(2.0 * gamma_t))).exp();
                a * t * 0.25 * cos(phi / 2.0)
            }
            2 => {
                // TRT lobe
                let t = (1.0 - f) * (1.0 - f) * f;
                let a = (-2.0 * sigma_a * (1.0 + cos(2.0 * gamma_t))).exp();
                a * a * t * 0.25 * cos(phi / 2.0)
            }
            _ => Vec3::ZERO,
        }
    }

    /// Evaluate full Marschner BSDF
    fn evaluate(
        &self,
        wi: Vec3,       // Incoming light direction
        wo: Vec3,       // Outgoing view direction
        tangent: Vec3,  // Hair tangent
        normal: Vec3,   // Surface normal (for azimuthal calculation)
    ) -> Vec3 {
        // Convert to hair coordinate system
        let sin_theta_i = dot(wi, tangent);
        let sin_theta_o = dot(wo, tangent);
        let cos_theta_i = sqrt(max(0.0, 1.0 - sin_theta_i * sin_theta_i));
        let cos_theta_o = sqrt(max(0.0, 1.0 - sin_theta_o * sin_theta_o));

        // Half angle
        let theta_h = (sin_theta_i + sin_theta_o) / 2.0;

        // Difference angle
        let theta_d = (sin_theta_i - sin_theta_o) / 2.0;

        // Azimuthal angle
        let wi_perp = normalize(wi - tangent * sin_theta_i);
        let wo_perp = normalize(wo - tangent * sin_theta_o);
        let phi = acos(clamp(dot(wi_perp, wo_perp), -1.0, 1.0));

        // Cuticle scale tilt
        let alpha = self.params.cuticle_angle.to_radians();

        // Roughness
        let beta_r = self.params.roughness_radial.to_radians();
        let beta_tt = beta_r / 2.0;
        let beta_trt = beta_r * 2.0;

        // Absorption
        let sigma_a = self.absorption_coefficient();

        // Calculate each lobe
        let mut result = Vec3::ZERO;

        // R lobe (p=0)
        let m_r = self.m_function(theta_h, -alpha, beta_r);
        let n_r = self.n_function(phi, 0, 0.0, sigma_a);
        result = result + n_r * m_r;

        // TT lobe (p=1)
        let m_tt = self.m_function(theta_h, -alpha / 2.0, beta_tt);
        let gamma_t = asin(sin_theta_i / self.params.ior);
        let n_tt = self.n_function(phi, 1, gamma_t, sigma_a);
        result = result + n_tt * m_tt;

        // TRT lobe (p=2)
        let m_trt = self.m_function(theta_h, -3.0 * alpha / 2.0, beta_trt);
        let n_trt = self.n_function(phi, 2, gamma_t, sigma_a);
        result = result + n_trt * m_trt;

        // Normalize by cosine term
        result / max(cos_theta_i * cos_theta_o, 0.001)
    }
}

// ============================================================================
// HAIR RENDERING PIPELINE
// ============================================================================

/// Hair rendering quality
enum HairQuality {
    Low,      // Simple Kajiya-Kay, no shadows
    Medium,   // Marschner R lobe, shadow maps
    High,     // Full Marschner, deep opacity maps
    Ultra,    // Full Marschner, ray-traced shadows
}

/// Hair render mode
enum HairRenderMode {
    Lines,        // GPU line primitives
    TessellatedQuads,  // Tessellation + geometry expansion
    MeshShader,   // Mesh shader strand generation
    RayTraced,    // Ray-traced curve primitives
}

/// Hair rendering configuration
struct HairRenderConfig {
    quality: HairQuality,
    render_mode: HairRenderMode,
    max_strands: u32,
    segments_per_strand: u32,

    // Multi-strand AA
    msaa_samples: u32,
    use_alpha_to_coverage: bool,

    // Shadow
    use_deep_opacity_maps: bool,
    shadow_layers: u32,

    // LOD
    enable_lod: bool,
    lod_distances: [f32; 4],
    lod_strand_counts: [f32; 4],
}

impl HairRenderConfig {
    fn default() -> Self {
        Self {
            quality: HairQuality::High,
            render_mode: HairRenderMode::TessellatedQuads,
            max_strands: 100000,
            segments_per_strand: 16,
            msaa_samples: 4,
            use_alpha_to_coverage: true,
            use_deep_opacity_maps: true,
            shadow_layers: 4,
            enable_lod: true,
            lod_distances: [10.0, 25.0, 50.0, 100.0],
            lod_strand_counts: [1.0, 0.5, 0.25, 0.1],
        }
    }
}

/// GPU uniforms for hair rendering
struct HairUniforms {
    view_proj: Mat4,
    view: Mat4,
    proj: Mat4,
    camera_position: Vec3,
    strand_width_scale: f32,
    light_direction: Vec3,
    light_intensity: f32,
    light_color: Vec3,
    ao_intensity: f32,
    base_color: Vec3,
    melanin: f32,
    tip_color: Vec3,
    melanin_redness: f32,
    roughness: f32,
    ior: f32,
    cuticle_angle: f32,
    _padding: f32,
}

/// Deep opacity map for hair shadows
struct DeepOpacityMap {
    texture: TextureHandle,
    layers: u32,
    near_plane: f32,
    far_plane: f32,
    light_view_proj: Mat4,
}

impl DeepOpacityMap {
    fn new(device: &Device, resolution: u32, layers: u32, near: f32, far: f32) -> Self {
        let texture = device.create_texture(&TextureDescriptor {
            size: (resolution, resolution, layers),
            format: TextureFormat::R32Float,
            usage: TextureUsage::RENDER_TARGET | TextureUsage::SAMPLED,
            dimension: TextureDimension::D2Array,
            ..Default::default()
        });

        Self {
            texture,
            layers,
            near_plane: near,
            far_plane: far,
            light_view_proj: Mat4::IDENTITY,
        }
    }

    fn layer_depth(&self, layer: u32) -> f32 {
        let t = layer as f32 / (self.layers - 1) as f32;
        // Exponential distribution for better near-surface detail
        self.near_plane + (self.far_plane - self.near_plane) * (exp(t * 2.0) - 1.0) / (exp(2.0) - 1.0)
    }
}

/// Hair strand renderer
struct HairRenderer {
    config: HairRenderConfig,
    groups: Vec<HairGroup>,

    // Pipelines
    depth_prepass_pipeline: RenderPipelineHandle,
    main_pipeline: RenderPipelineHandle,
    shadow_pipeline: RenderPipelineHandle,
    deep_opacity_pipeline: RenderPipelineHandle,

    // Shadow resources
    deep_opacity_map: Option<DeepOpacityMap>,
    shadow_map: TextureHandle,

    // Screen-space resources
    velocity_buffer: TextureHandle,

    // BSDF
    marschner: MarschnerBsdf,
}

impl HairRenderer {
    fn new(device: &Device, config: HairRenderConfig) -> Self {
        let depth_prepass_pipeline = device.create_render_pipeline(&RenderPipelineDescriptor {
            vertex_shader: include_str!("shaders/hair_vertex.wgsl"),
            fragment_shader: include_str!("shaders/hair_depth.wgsl"),
            primitive: PrimitiveState {
                topology: PrimitiveTopology::LineList,
                ..Default::default()
            },
            depth_stencil: Some(DepthStencilState {
                format: TextureFormat::Depth32Float,
                depth_write_enabled: true,
                depth_compare: CompareFunction::Less,
                ..Default::default()
            }),
            ..Default::default()
        });

        let main_pipeline = device.create_render_pipeline(&RenderPipelineDescriptor {
            vertex_shader: include_str!("shaders/hair_vertex.wgsl"),
            fragment_shader: include_str!("shaders/hair_marschner.wgsl"),
            primitive: PrimitiveState {
                topology: PrimitiveTopology::LineList,
                ..Default::default()
            },
            targets: vec![
                ColorTargetState {
                    format: TextureFormat::Rgba16Float,
                    blend: Some(BlendState::ALPHA_BLENDING),
                    write_mask: ColorWrites::ALL,
                }
            ],
            depth_stencil: Some(DepthStencilState {
                format: TextureFormat::Depth32Float,
                depth_write_enabled: false,
                depth_compare: CompareFunction::LessEqual,
                ..Default::default()
            }),
            multisample: MultisampleState {
                count: config.msaa_samples,
                alpha_to_coverage_enabled: config.use_alpha_to_coverage,
                ..Default::default()
            },
            ..Default::default()
        });

        let shadow_pipeline = device.create_render_pipeline(&RenderPipelineDescriptor {
            vertex_shader: include_str!("shaders/hair_shadow.wgsl"),
            fragment_shader: "",
            primitive: PrimitiveState {
                topology: PrimitiveTopology::LineList,
                ..Default::default()
            },
            depth_stencil: Some(DepthStencilState {
                format: TextureFormat::Depth32Float,
                depth_write_enabled: true,
                depth_compare: CompareFunction::Less,
                ..Default::default()
            }),
            ..Default::default()
        });

        let deep_opacity_pipeline = device.create_render_pipeline(&RenderPipelineDescriptor {
            vertex_shader: include_str!("shaders/hair_shadow.wgsl"),
            fragment_shader: include_str!("shaders/hair_deep_opacity.wgsl"),
            ..Default::default()
        });

        let deep_opacity_map = if config.use_deep_opacity_maps {
            Some(DeepOpacityMap::new(device, 2048, config.shadow_layers, 0.1, 100.0))
        } else {
            None
        };

        let shadow_map = device.create_texture(&TextureDescriptor {
            size: (2048, 2048, 1),
            format: TextureFormat::Depth32Float,
            usage: TextureUsage::RENDER_TARGET | TextureUsage::SAMPLED,
            ..Default::default()
        });

        let velocity_buffer = device.create_texture(&TextureDescriptor {
            size: (1920, 1080, 1),
            format: TextureFormat::Rg16Float,
            usage: TextureUsage::RENDER_TARGET | TextureUsage::SAMPLED,
            ..Default::default()
        });

        Self {
            config,
            groups: Vec::new(),
            depth_prepass_pipeline,
            main_pipeline,
            shadow_pipeline,
            deep_opacity_pipeline,
            deep_opacity_map,
            shadow_map,
            velocity_buffer,
            marschner: MarschnerBsdf::new(MarschnerParams::default()),
        }
    }

    fn add_group(&mut self, group: HairGroup) {
        self.groups.push(group);
    }

    fn render_shadow_pass(
        &self,
        encoder: &mut CommandEncoder,
        light_view_proj: &Mat4,
    ) {
        // Regular shadow map
        {
            let mut pass = encoder.begin_render_pass(&RenderPassDescriptor {
                depth_attachment: Some(RenderPassDepthAttachment {
                    texture: &self.shadow_map,
                    load_op: LoadOp::Clear(1.0),
                    store_op: StoreOp::Store,
                }),
                ..Default::default()
            });

            pass.set_pipeline(&self.shadow_pipeline);
            pass.set_uniform(0, &ShadowUniforms {
                light_view_proj: *light_view_proj,
            });

            for group in &self.groups {
                if let (Some(vb), Some(ib)) = (&group.vertex_buffer, &group.index_buffer) {
                    pass.set_vertex_buffer(0, vb);
                    pass.set_index_buffer(ib, IndexFormat::Uint32);
                    pass.draw_indexed(group.segment_count * 2, 1, 0, 0, 0);
                }
            }
        }

        // Deep opacity maps
        if let Some(ref dom) = self.deep_opacity_map {
            for layer in 0..dom.layers {
                let layer_depth = dom.layer_depth(layer);

                let mut pass = encoder.begin_render_pass(&RenderPassDescriptor {
                    color_attachments: vec![RenderPassColorAttachment {
                        texture: &dom.texture,
                        layer: layer,
                        load_op: if layer == 0 { LoadOp::Clear(Vec4::ZERO) } else { LoadOp::Load },
                        store_op: StoreOp::Store,
                    }],
                    ..Default::default()
                });

                pass.set_pipeline(&self.deep_opacity_pipeline);
                pass.set_uniform(0, &DeepOpacityUniforms {
                    light_view_proj: *light_view_proj,
                    layer_depth,
                    layer_index: layer,
                });

                for group in &self.groups {
                    if let (Some(vb), Some(ib)) = (&group.vertex_buffer, &group.index_buffer) {
                        pass.set_vertex_buffer(0, vb);
                        pass.set_index_buffer(ib, IndexFormat::Uint32);
                        pass.draw_indexed(group.segment_count * 2, 1, 0, 0, 0);
                    }
                }
            }
        }
    }

    fn render_depth_prepass(
        &self,
        encoder: &mut CommandEncoder,
        depth_texture: &TextureHandle,
        uniforms: &HairUniforms,
    ) {
        let mut pass = encoder.begin_render_pass(&RenderPassDescriptor {
            depth_attachment: Some(RenderPassDepthAttachment {
                texture: depth_texture,
                load_op: LoadOp::Load,
                store_op: StoreOp::Store,
            }),
            ..Default::default()
        });

        pass.set_pipeline(&self.depth_prepass_pipeline);
        pass.set_uniform(0, uniforms);

        for group in &self.groups {
            if let (Some(vb), Some(ib)) = (&group.vertex_buffer, &group.index_buffer) {
                pass.set_vertex_buffer(0, vb);
                pass.set_index_buffer(ib, IndexFormat::Uint32);
                pass.draw_indexed(group.segment_count * 2, 1, 0, 0, 0);
            }
        }
    }

    fn render(
        &self,
        encoder: &mut CommandEncoder,
        color_texture: &TextureHandle,
        depth_texture: &TextureHandle,
        uniforms: &HairUniforms,
        light_view_proj: &Mat4,
    ) {
        let mut pass = encoder.begin_render_pass(&RenderPassDescriptor {
            color_attachments: vec![RenderPassColorAttachment {
                texture: color_texture,
                load_op: LoadOp::Load,
                store_op: StoreOp::Store,
            }],
            depth_attachment: Some(RenderPassDepthAttachment {
                texture: depth_texture,
                load_op: LoadOp::Load,
                store_op: StoreOp::Store,
            }),
            ..Default::default()
        });

        pass.set_pipeline(&self.main_pipeline);
        pass.set_uniform(0, uniforms);
        pass.set_texture(1, &self.shadow_map);

        if let Some(ref dom) = self.deep_opacity_map {
            pass.set_texture(2, &dom.texture);
        }

        for group in &self.groups {
            if let (Some(vb), Some(ib)) = (&group.vertex_buffer, &group.index_buffer) {
                pass.set_vertex_buffer(0, vb);
                pass.set_index_buffer(ib, IndexFormat::Uint32);
                pass.draw_indexed(group.segment_count * 2, 1, 0, 0, 0);
            }
        }
    }
}

