/// Decal spawner for common effects
pub struct DecalSpawner {
    /// Decal manager reference
    manager_id: u64,

    /// Default lifetime
    pub default_lifetime: f32,

    /// Default fade out duration
    pub default_fade_duration: f32,

    /// Random rotation enabled
    pub random_rotation: bool,

    /// Random scale range
    pub random_scale_range: (f32, f32),
}

impl DecalSpawner {
    /// Create decal spawner
    pub fn new() -> Self {
        Self {
            manager_id: 0,
            default_lifetime: 30.0,
            default_fade_duration: 2.0,
            random_rotation: true,
            random_scale_range: (0.8, 1.2),
        }
    }

    /// Spawn bullet hole decal
    pub fn spawn_bullet_hole(
        &self,
        manager: &mut DecalManager,
        position: Vec3,
        normal: Vec3,
        surface_type: SurfaceType,
    ) -> u64 {
        let rotation = Quaternion::from_rotation_arc(Vec3::unit_z(), normal);
        let size = Vec3::new(0.05, 0.05, 0.02); // 5cm bullet hole

        let mut decal = Decal::new(position + normal * 0.001, rotation, size);
        decal.sort_layer = DecalSortLayer::Foreground;
        decal.lifetime = self.default_lifetime;
        decal.fade_out_duration = self.default_fade_duration;
        decal.channel_mask = DecalChannelMask::visual();

        // Set atlas rect based on surface type
        // decal.atlas_rect = ...

        manager.add(decal)
    }

    /// Spawn blood splatter decal
    pub fn spawn_blood_splatter(
        &self,
        manager: &mut DecalManager,
        position: Vec3,
        normal: Vec3,
        size: f32,
    ) -> u64 {
        let rotation = Quaternion::from_rotation_arc(Vec3::unit_z(), normal);
        let decal_size = Vec3::new(size, size, 0.01);

        let mut decal = Decal::new(position + normal * 0.001, rotation, decal_size);
        decal.sort_layer = DecalSortLayer::Foreground;
        decal.lifetime = 60.0; // Blood stays longer
        decal.fade_out_duration = 5.0;
        decal.channel_mask = DecalChannelMask::all();

        manager.add(decal)
    }

    /// Spawn tire track decal
    pub fn spawn_tire_track(
        &self,
        manager: &mut DecalManager,
        start: Vec3,
        end: Vec3,
        normal: Vec3,
        width: f32,
    ) -> u64 {
        let direction = (end - start).normalize();
        let center = (start + end) * 0.5;
        let length = (end - start).length();

        let rotation = Quaternion::from_rotation_arc(Vec3::unit_y(), direction);
        let size = Vec3::new(width, length, 0.01);

        let mut decal = Decal::new(center + normal * 0.001, rotation, size);
        decal.sort_layer = DecalSortLayer::Background;
        decal.lifetime = 120.0; // Tire tracks fade slowly
        decal.fade_out_duration = 30.0;
        decal.channel_mask.roughness = true;
        decal.channel_mask.normal = true;
        decal.channel_mask.albedo = true;

        manager.add(decal)
    }

    /// Spawn explosion scorch decal
    pub fn spawn_scorch_mark(
        &self,
        manager: &mut DecalManager,
        position: Vec3,
        normal: Vec3,
        radius: f32,
    ) -> u64 {
        let rotation = Quaternion::from_rotation_arc(Vec3::unit_z(), normal);
        let size = Vec3::new(radius * 2.0, radius * 2.0, 0.02);

        let mut decal = Decal::new(position + normal * 0.001, rotation, size);
        decal.sort_layer = DecalSortLayer::Default;
        decal.lifetime = 300.0; // Scorch marks are persistent
        decal.fade_out_duration = 60.0;
        decal.channel_mask = DecalChannelMask::all();
        decal.blend_modes.albedo = DecalBlendMode::Multiply;

        manager.add(decal)
    }

    /// Spawn footprint decal
    pub fn spawn_footprint(
        &self,
        manager: &mut DecalManager,
        position: Vec3,
        normal: Vec3,
        direction: Vec3,
        is_left_foot: bool,
    ) -> u64 {
        let forward = direction.normalize();
        let right = normal.cross(forward).normalize();
        let rotation = Quaternion::from_axes(right, normal, forward);

        let size = Vec3::new(0.1, 0.3, 0.01); // Footprint size

        let offset = if is_left_foot { -right * 0.1 } else { right * 0.1 };

        let mut decal = Decal::new(position + offset + normal * 0.001, rotation, size);
        decal.sort_layer = DecalSortLayer::Background;
        decal.lifetime = 20.0;
        decal.fade_out_duration = 5.0;
        decal.channel_mask = DecalChannelMask::visual();

        manager.add(decal)
    }

    /// Spawn graffiti decal
    pub fn spawn_graffiti(
        &self,
        manager: &mut DecalManager,
        position: Vec3,
        normal: Vec3,
        rotation: Quaternion,
        size: Vec2,
    ) -> u64 {
        let final_rotation = Quaternion::from_rotation_arc(Vec3::unit_z(), normal) * rotation;
        let decal_size = Vec3::new(size.x, size.y, 0.01);

        let mut decal = Decal::new(position + normal * 0.001, final_rotation, decal_size);
        decal.sort_layer = DecalSortLayer::Default;
        decal.lifetime = 0.0; // Permanent
        decal.channel_mask = DecalChannelMask::albedo_only();

        manager.add(decal)
    }
}

/// Surface type for decal variation
pub enum SurfaceType {
    Concrete,
    Metal,
    Wood,
    Dirt,
    Flesh,
    Glass,
    Fabric,
    Plastic,
}

// =============================================================================
// REGION: DECAL POOLING
// =============================================================================

/// Decal pool for efficient allocation
pub struct DecalPool {
    /// Pool of pre-allocated decals
    pool: Vec<Decal>,

    /// Free list
    free_list: Vec<usize>,

    /// Active count
    active_count: usize,
}

impl DecalPool {
    /// Create decal pool
    pub fn new(capacity: usize) -> Self {
        let mut pool = Vec::with_capacity(capacity);
        let mut free_list = Vec::with_capacity(capacity);

        for i in 0..capacity {
            pool.push(Decal::new(Vec3::zero(), Quaternion::identity(), Vec3::one()));
            free_list.push(capacity - 1 - i);
        }

        Self {
            pool,
            free_list,
            active_count: 0,
        }
    }

    /// Allocate decal from pool
    pub fn allocate(&mut self) -> Option<&mut Decal> {
        if let Some(index) = self.free_list.pop() {
            self.active_count += 1;
            self.pool[index].enabled = true;
            Some(&mut self.pool[index])
        } else {
            None
        }
    }

    /// Free decal back to pool
    pub fn free(&mut self, index: usize) {
        if index < self.pool.len() && self.pool[index].enabled {
            self.pool[index].enabled = false;
            self.free_list.push(index);
            self.active_count -= 1;
        }
    }

    /// Get active decals
    pub fn active_decals(&self) -> impl Iterator<Item = &Decal> {
        self.pool.iter().filter(|d| d.enabled)
    }

    /// Get active decals mutably
    pub fn active_decals_mut(&mut self) -> impl Iterator<Item = &mut Decal> {
        self.pool.iter_mut().filter(|d| d.enabled)
    }
}

// =============================================================================
// REGION: TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_decal_creation() {
        let decal = Decal::new(
            Vec3::new(1.0, 2.0, 3.0),
            Quaternion::identity(),
            Vec3::new(0.5, 0.5, 0.1),
        );

        assert!(decal.enabled);
        assert!((decal.opacity - 1.0).abs() < 1e-6);
        assert!(!decal.is_expired());
    }

    #[test]
    fn test_decal_lifetime() {
        let mut decal = Decal::new(Vec3::zero(), Quaternion::identity(), Vec3::one());
        decal.lifetime = 5.0;
        decal.fade_out_duration = 2.0;

        // Before fade
        decal.age = 2.0;
        assert!(!decal.is_expired());
        assert!((decal.get_current_opacity() - 1.0).abs() < 1e-6);

        // During fade
        decal.age = 4.0;
        assert!(!decal.is_expired());
        assert!(decal.get_current_opacity() < 1.0);
        assert!(decal.get_current_opacity() > 0.0);

        // After lifetime
        decal.age = 6.0;
        assert!(decal.is_expired());
    }

    #[test]
    fn test_decal_channel_mask() {
        let all = DecalChannelMask::all();
        assert!(all.albedo);
        assert!(all.normal);
        assert!(all.roughness);
        assert!(all.metallic);
        assert!(all.ao);
        assert!(all.emission);

        let albedo_only = DecalChannelMask::albedo_only();
        assert!(albedo_only.albedo);
        assert!(!albedo_only.normal);
        assert!(!albedo_only.roughness);
    }

    #[test]
    fn test_decal_sort_layer() {
        assert!(DecalSortLayer::Background.sort_order() < DecalSortLayer::Default.sort_order());
        assert!(DecalSortLayer::Default.sort_order() < DecalSortLayer::Foreground.sort_order());
        assert!(DecalSortLayer::Foreground.sort_order() < DecalSortLayer::Overlay.sort_order());

        assert_eq!(DecalSortLayer::Custom(50).sort_order(), 50);
    }

    #[test]
    fn test_atlas_allocation() {
        let mut atlas = DecalAtlas::new(1024, 4);

        // Allocate first texture
        let rect1 = atlas.allocate(128, 128);
        assert!(rect1.is_some());

        let r1 = rect1.unwrap();
        assert!(r1.offset.x >= 0.0);
        assert!(r1.offset.y >= 0.0);
        assert!(r1.scale.x > 0.0);
        assert!(r1.scale.y > 0.0);

        // Allocate second texture
        let rect2 = atlas.allocate(256, 256);
        assert!(rect2.is_some());

        // Allocate many small textures
        for _ in 0..50 {
            let rect = atlas.allocate(64, 64);
            assert!(rect.is_some());
        }
    }

    #[test]
    fn test_decal_manager() {
        let mut manager = DecalManager::new(100, 1024, 4);

        // Add decals
        let id1 = manager.add(Decal::new(Vec3::zero(), Quaternion::identity(), Vec3::one()));
        let id2 = manager.add(Decal::new(Vec3::unit_x(), Quaternion::identity(), Vec3::one()));

        assert_eq!(manager.total_count(), 2);
        assert!(manager.get(id1).is_some());
        assert!(manager.get(id2).is_some());

        // Remove decal
        assert!(manager.remove(id1));
        assert_eq!(manager.total_count(), 1);
        assert!(manager.get(id1).is_none());
        assert!(manager.get(id2).is_some());
    }

    #[test]
    fn test_decal_manager_update() {
        let mut manager = DecalManager::new(100, 1024, 4);

        // Add decal with short lifetime
        let mut decal = Decal::new(Vec3::zero(), Quaternion::identity(), Vec3::one());
        decal.lifetime = 1.0;
        decal.fade_out_duration = 0.5;

        let id = manager.add(decal);
        assert_eq!(manager.total_count(), 1);

        // Update past lifetime
        manager.update(2.0);

        // Decal should be removed
        assert_eq!(manager.total_count(), 0);
        assert!(manager.get(id).is_none());
    }

    #[test]
    fn test_decal_pool() {
        let mut pool = DecalPool::new(10);

        assert_eq!(pool.active_count, 0);

        // Allocate decals
        let decal1 = pool.allocate();
        assert!(decal1.is_some());
        assert_eq!(pool.active_count, 1);

        let decal2 = pool.allocate();
        assert!(decal2.is_some());
        assert_eq!(pool.active_count, 2);

        // Free a decal
        pool.free(0);
        assert_eq!(pool.active_count, 1);

        // Allocate again - should reuse freed slot
        let decal3 = pool.allocate();
        assert!(decal3.is_some());
        assert_eq!(pool.active_count, 2);
    }

    #[test]
    fn test_decal_pool_exhaustion() {
        let mut pool = DecalPool::new(3);

        // Allocate all
        assert!(pool.allocate().is_some());
        assert!(pool.allocate().is_some());
        assert!(pool.allocate().is_some());

        // Pool should be exhausted
        assert!(pool.allocate().is_none());

        // Free one
        pool.free(1);

        // Should be able to allocate again
        assert!(pool.allocate().is_some());
        assert!(pool.allocate().is_none());
    }

    #[test]
    fn test_gpu_decal_data() {
        let decal = Decal::new(
            Vec3::new(1.0, 2.0, 3.0),
            Quaternion::identity(),
            Vec3::new(0.5, 0.5, 0.1),
        );

        let gpu_data = GpuDecalData::from_decal(&decal);

        // Check size is correct
        assert!((gpu_data.size[0] - 0.5).abs() < 1e-6);
        assert!((gpu_data.size[1] - 0.5).abs() < 1e-6);
        assert!((gpu_data.size[2] - 0.1).abs() < 1e-6);

        // Check opacity
        assert!((gpu_data.params0[0] - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_decal_spawner() {
        let mut manager = DecalManager::new(100, 1024, 4);
        let spawner = DecalSpawner::new();

        // Spawn bullet hole
        let id = spawner.spawn_bullet_hole(
            &mut manager,
            Vec3::zero(),
            Vec3::unit_y(),
            SurfaceType::Concrete,
        );

        assert!(id > 0);
        assert_eq!(manager.total_count(), 1);

        let decal = manager.get(id).unwrap();
        assert!(matches!(decal.sort_layer, DecalSortLayer::Foreground));
        assert!(decal.lifetime > 0.0);
    }

    #[test]
    fn test_blend_modes_default() {
        let modes = DecalBlendModes::default();

        assert!(matches!(modes.albedo, DecalBlendMode::AlphaBlend));
        assert!(matches!(modes.normal, DecalBlendMode::NormalBlend));
        assert!(matches!(modes.ao, DecalBlendMode::Multiply));
        assert!(matches!(modes.emission, DecalBlendMode::Add));
    }

    #[test]
    fn test_atlas_rect_full() {
        let rect = DecalAtlasRect::full();

        assert!((rect.offset.x - 0.0).abs() < 1e-6);
        assert!((rect.offset.y - 0.0).abs() < 1e-6);
        assert!((rect.scale.x - 1.0).abs() < 1e-6);
        assert!((rect.scale.y - 1.0).abs() < 1e-6);
        assert_eq!(rect.page, 0);
    }
}
