// =============================================================================
// REGION: CLUSTERED DECAL RENDERER
// =============================================================================

/// Clustered decal renderer (efficient for many decals)
pub struct ClusteredDecalRenderer {
    /// Cluster dimensions
    pub cluster_dims: (u32, u32, u32),

    /// Cluster buffer
    cluster_buffer: GpuBuffer,

    /// Decal indices buffer
    decal_indices: GpuBuffer,

    /// Cluster build shader
    build_shader: ComputeShader,

    /// Render shader
    render_shader: RenderPipeline,
}

impl ClusteredDecalRenderer {
    /// Create clustered decal renderer
    pub fn new(screen_width: u32, screen_height: u32) -> Self {
        // 16x8 tiles, 24 depth slices
        let tile_size_x = 16;
        let tile_size_y = 8;
        let depth_slices = 24;

        let cluster_dims = (
            (screen_width + tile_size_x - 1) / tile_size_x,
            (screen_height + tile_size_y - 1) / tile_size_y,
            depth_slices,
        );

        let num_clusters = cluster_dims.0 * cluster_dims.1 * cluster_dims.2;

        // Each cluster has offset and count
        let cluster_buffer = GpuBuffer::new(
            (num_clusters * 2) as usize * 4, // 2 u32s per cluster
            BufferUsage::Storage,
        );

        // Max 1024 decal indices per cluster
        let decal_indices = GpuBuffer::new(
            num_clusters as usize * 1024 * 4,
            BufferUsage::Storage,
        );

        Self {
            cluster_dims,
            cluster_buffer,
            decal_indices,
            build_shader: ComputeShader::new(CLUSTER_BUILD_SHADER),
            render_shader: RenderPipeline::new(
                CLUSTER_RENDER_VERTEX_SHADER,
                CLUSTER_RENDER_PIXEL_SHADER,
            ),
        }
    }

    /// Build clusters
    pub fn build_clusters(
        &mut self,
        decal_manager: &DecalManager,
        view_proj: Mat4,
        near: f32,
        far: f32,
    ) {
        self.build_shader.set_storage_buffer(0, &self.cluster_buffer);
        self.build_shader.set_storage_buffer(1, &self.decal_indices);
        self.build_shader.set_storage_buffer(2, decal_manager.get_gpu_buffer());

        self.build_shader.set_uniform("u_view_proj", view_proj);
        self.build_shader.set_uniform("u_near", near);
        self.build_shader.set_uniform("u_far", far);
        self.build_shader.set_uniform("u_cluster_dims", Vec3::new(
            self.cluster_dims.0 as f32,
            self.cluster_dims.1 as f32,
            self.cluster_dims.2 as f32,
        ));
        self.build_shader.set_uniform("u_decal_count", decal_manager.visible_count() as i32);

        self.build_shader.dispatch(
            self.cluster_dims.0,
            self.cluster_dims.1,
            self.cluster_dims.2,
        );
    }

    /// Render clustered decals
    pub fn render(
        &self,
        decal_manager: &DecalManager,
        gbuffer: &mut GBuffer,
        depth_texture: &Texture,
        inv_view_proj: Mat4,
    ) {
        self.render_shader.set_texture(0, depth_texture);
        self.render_shader.set_texture(1, &decal_manager.atlas.texture_array);
        self.render_shader.set_storage_buffer(0, decal_manager.get_gpu_buffer());
        self.render_shader.set_storage_buffer(1, &self.cluster_buffer);
        self.render_shader.set_storage_buffer(2, &self.decal_indices);

        self.render_shader.set_uniform("u_inv_view_proj", inv_view_proj);
        self.render_shader.set_uniform("u_cluster_dims", Vec3::new(
            self.cluster_dims.0 as f32,
            self.cluster_dims.1 as f32,
            self.cluster_dims.2 as f32,
        ));

        // Render full-screen quad
        self.render_shader.draw_fullscreen();
    }
}

