/// Screen-space decal renderer (faster but less accurate)
pub struct ScreenSpaceDecalRenderer {
    /// Full-screen shader
    pub shader: ComputeShader,

    /// Decal list texture
    decal_tiles: Texture,

    /// Tile size
    tile_size: u32,
}

impl ScreenSpaceDecalRenderer {
    /// Create screen-space decal renderer
    pub fn new(screen_width: u32, screen_height: u32) -> Self {
        let tile_size = 16;
        let tiles_x = (screen_width + tile_size - 1) / tile_size;
        let tiles_y = (screen_height + tile_size - 1) / tile_size;

        let decal_tiles = Texture::create_2d(
            tiles_x,
            tiles_y,
            TextureFormat::RGBA16Float,
            TextureUsage::Storage | TextureUsage::Sampled,
        );

        Self {
            shader: ComputeShader::new(SCREEN_SPACE_DECAL_SHADER),
            decal_tiles,
            tile_size,
        }
    }

    /// Build tile list
    pub fn build_tiles(
        &mut self,
        decal_manager: &DecalManager,
        view_proj: Mat4,
    ) {
        // Assign decals to tiles based on screen-space bounds
        // ...
    }

    /// Render screen-space decals
    pub fn render(
        &self,
        decal_manager: &DecalManager,
        gbuffer: &mut GBuffer,
        depth_texture: &Texture,
        inv_view_proj: Mat4,
    ) {
        self.shader.set_texture(0, depth_texture);
        self.shader.set_texture(1, &self.decal_tiles);
        self.shader.set_texture(2, &decal_manager.atlas.texture_array);
        self.shader.set_storage_buffer(0, decal_manager.get_gpu_buffer());
        self.shader.set_uniform("u_inv_view_proj", inv_view_proj);

        // Bind GBuffer outputs
        // ...

        self.shader.dispatch(
            (gbuffer.width() + 7) / 8,
            (gbuffer.height() + 7) / 8,
            1,
        );
    }
}

