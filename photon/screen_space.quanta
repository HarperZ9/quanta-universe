// G-BUFFER STRUCTURES
// ═══════════════════════════════════════════════════════════════════════════════

/// G-buffer data for screen-space techniques
#[derive(Debug, Clone)]
pub struct GBuffer {
    pub depth: Vec<f32>,
    pub normal: Vec<Vec3>,
    pub albedo: Vec<Vec3>,
    pub metallic: Vec<f32>,
    pub roughness: Vec<f32>,
    pub velocity: Vec<Vec2>,
    pub material_id: Vec<u32>,
    pub width: u32,
    pub height: u32,
}

impl GBuffer {
    pub fn new(width: u32, height: u32) -> Self {
        let size = (width * height) as usize;
        GBuffer {
            depth: vec![1.0; size],
            normal: vec![Vec3::Z; size],
            albedo: vec![Vec3::ZERO; size],
            metallic: vec![0.0; size],
            roughness: vec![0.5; size],
            velocity: vec![Vec2::ZERO; size],
            material_id: vec![0; size],
            width,
            height,
        }
    }

    pub fn sample_depth(&self, x: u32, y: u32) -> f32 {
        let idx = (y.min(self.height - 1) * self.width + x.min(self.width - 1)) as usize;
        self.depth[idx]
    }

    pub fn sample_normal(&self, x: u32, y: u32) -> Vec3 {
        let idx = (y.min(self.height - 1) * self.width + x.min(self.width - 1)) as usize;
        self.normal[idx]
    }

    pub fn sample_depth_bilinear(&self, uv: Vec2) -> f32 {
        let x = uv.x * self.width as f32 - 0.5;
        let y = uv.y * self.height as f32 - 0.5;

        let x0 = x.floor() as i32;
        let y0 = y.floor() as i32;
        let fx = x - x0 as f32;
        let fy = y - y0 as f32;

        let sample = |px: i32, py: i32| -> f32 {
            let px = px.clamp(0, self.width as i32 - 1) as u32;
            let py = py.clamp(0, self.height as i32 - 1) as u32;
            self.depth[(py * self.width + px) as usize]
        };

        let d00 = sample(x0, y0);
        let d10 = sample(x0 + 1, y0);
        let d01 = sample(x0, y0 + 1);
        let d11 = sample(x0 + 1, y0 + 1);

        let d0 = d00 * (1.0 - fx) + d10 * fx;
        let d1 = d01 * (1.0 - fx) + d11 * fx;

        d0 * (1.0 - fy) + d1 * fy
    }
}

/// Hierarchical Z-buffer for occlusion culling (WP-008)
pub struct HiZBuffer {
    levels: Vec<Vec<f32>>,
    widths: Vec<u32>,
    heights: Vec<u32>,
}

impl HiZBuffer {
    pub fn build(depth: &[f32], width: u32, height: u32) -> Self {
        let num_levels = (width.max(height) as f32).log2().ceil() as usize + 1;
        let mut levels = Vec::with_capacity(num_levels);
        let mut widths = Vec::with_capacity(num_levels);
        let mut heights = Vec::with_capacity(num_levels);

        // Level 0 is original depth
        levels.push(depth.to_vec());
        widths.push(width);
        heights.push(height);

        // Build mip chain with min filter
        for level in 1..num_levels {
            let prev_width = widths[level - 1];
            let prev_height = heights[level - 1];
            let prev_level = &levels[level - 1];

            let new_width = (prev_width / 2).max(1);
            let new_height = (prev_height / 2).max(1);

            let mut new_level = vec![0.0; (new_width * new_height) as usize];

            for y in 0..new_height {
                for x in 0..new_width {
                    let src_x = x * 2;
                    let src_y = y * 2;

                    // 2x2 min filter for conservative depth
                    let mut min_depth = f32::MAX;

                    for dy in 0..2 {
                        for dx in 0..2 {
                            let sx = (src_x + dx).min(prev_width - 1);
                            let sy = (src_y + dy).min(prev_height - 1);
                            let d = prev_level[(sy * prev_width + sx) as usize];
                            min_depth = min_depth.min(d);
                        }
                    }

                    new_level[(y * new_width + x) as usize] = min_depth;
                }
            }

            levels.push(new_level);
            widths.push(new_width);
            heights.push(new_height);
        }

        HiZBuffer { levels, widths, heights }
    }

    /// Sample depth at mip level
    pub fn sample(&self, level: usize, uv: Vec2) -> f32 {
        let level = level.min(self.levels.len() - 1);
        let width = self.widths[level] as f32;
        let height = self.heights[level] as f32;

        let x = (uv.x * width).clamp(0.0, width - 1.0) as u32;
        let y = (uv.y * height).clamp(0.0, height - 1.0) as u32;

        self.levels[level][(y * self.widths[level] + x) as usize]
    }

    /// Check if point is occluded
    pub fn is_occluded(&self, uv: Vec2, depth: f32, level: usize) -> bool {
        let hi_z = self.sample(level, uv);
        depth > hi_z
    }

    /// Find appropriate mip level for ray step size
    pub fn get_level_for_step(&self, step_size: f32) -> usize {
        let base_width = self.widths[0] as f32;
        let level = (step_size * base_width).log2().ceil() as usize;
        level.clamp(0, self.levels.len() - 1)
    }
}

