/// Voxel for cone tracing
struct Voxel {
    radiance: Vec3,
    opacity: f32,
    normal: Vec3,
}

/// Voxel-based global illumination (VXGI)
struct VoxelGI {
    resolution: u32,
    bounds_min: Vec3,
    bounds_max: Vec3,
    voxel_size: f32,

    // Clipmap levels for multi-resolution
    clipmap_levels: u32,
    clipmaps: Vec<TextureHandle>,

    // GPU resources
    voxel_texture: TextureHandle,
    radiance_texture: TextureHandle,
    opacity_texture: TextureHandle,
}

impl VoxelGI {
    fn new(device: &Device, resolution: u32, bounds_min: Vec3, bounds_max: Vec3, clipmap_levels: u32) -> Self {
        let extent = bounds_max - bounds_min;
        let voxel_size = extent.x / resolution as f32;

        let voxel_texture = device.create_texture(&TextureDescriptor {
            size: (resolution, resolution, resolution),
            format: TextureFormat::Rgba8Unorm,
            usage: TextureUsage::STORAGE | TextureUsage::SAMPLED,
            dimension: TextureDimension::D3,
            ..Default::default()
        });

        let radiance_texture = device.create_texture(&TextureDescriptor {
            size: (resolution, resolution, resolution),
            format: TextureFormat::Rgba16Float,
            usage: TextureUsage::STORAGE | TextureUsage::SAMPLED,
            dimension: TextureDimension::D3,
            mip_level_count: (resolution as f32).log2() as u32,
            ..Default::default()
        });

        let opacity_texture = device.create_texture(&TextureDescriptor {
            size: (resolution, resolution, resolution),
            format: TextureFormat::R8Unorm,
            usage: TextureUsage::STORAGE | TextureUsage::SAMPLED,
            dimension: TextureDimension::D3,
            mip_level_count: (resolution as f32).log2() as u32,
            ..Default::default()
        });

        let mut clipmaps = Vec::with_capacity(clipmap_levels as usize);
        for level in 0..clipmap_levels {
            let level_res = resolution >> level;
            clipmaps.push(device.create_texture(&TextureDescriptor {
                size: (level_res, level_res, level_res),
                format: TextureFormat::Rgba16Float,
                usage: TextureUsage::STORAGE | TextureUsage::SAMPLED,
                dimension: TextureDimension::D3,
                ..Default::default()
            }));
        }

        Self {
            resolution,
            bounds_min,
            bounds_max,
            voxel_size,
            clipmap_levels,
            clipmaps,
            voxel_texture,
            radiance_texture,
            opacity_texture,
        }
    }

    /// Voxelize the scene
    fn voxelize(
        &mut self,
        encoder: &mut CommandEncoder,
        scene: &Scene,
        voxelize_pipeline: &ComputePipelineHandle,
    ) {
        // Clear voxel grids
        encoder.clear_texture(&self.voxel_texture, Vec4::ZERO);
        encoder.clear_texture(&self.opacity_texture, Vec4::ZERO);

        // Conservative rasterization to voxel grid
        // Implementation uses geometry shader or compute voxelization
    }

    /// Inject direct lighting into voxel grid
    fn inject_lighting(
        &mut self,
        encoder: &mut CommandEncoder,
        lights: &[Light],
        shadow_maps: &[TextureHandle],
        inject_pipeline: &ComputePipelineHandle,
    ) {
        // Inject light into voxels visible from each light
    }

    /// Generate mip chain for cone tracing
    fn generate_mips(&self, encoder: &mut CommandEncoder, mip_pipeline: &ComputePipelineHandle) {
        let mut current_res = self.resolution;

        for level in 1..(self.resolution as f32).log2() as u32 {
            current_res /= 2;

            let mut pass = encoder.begin_compute_pass(&format!("Voxel Mip Level {}", level));
            pass.set_pipeline(mip_pipeline);
            pass.set_texture(0, &self.radiance_texture);
            pass.set_storage_texture_mip(1, &self.radiance_texture, level);
            pass.set_uniform(2, &MipUniforms { src_level: level - 1 });
            pass.dispatch((current_res + 3) / 4, (current_res + 3) / 4, (current_res + 3) / 4);
        }
    }

    /// Cone trace for indirect lighting
    fn cone_trace(
        &self,
        origin: Vec3,
        direction: Vec3,
        cone_angle: f32,
        max_distance: f32,
    ) -> Vec3 {
        let mut accumulated_radiance = Vec3::ZERO;
        let mut accumulated_opacity = 0.0;

        let step_size = self.voxel_size * 0.5;
        let mut t = step_size;

        while t < max_distance && accumulated_opacity < 0.99 {
            let position = origin + direction * t;

            // Determine mip level from cone width
            let cone_width = t * cone_angle;
            let mip = (cone_width / self.voxel_size).log2().max(0.0);

            // Sample voxel grid with trilinear + mip filtering
            let (radiance, opacity) = self.sample_voxel(position, mip);

            // Front-to-back compositing
            let alpha = 1.0 - accumulated_opacity;
            accumulated_radiance = accumulated_radiance + radiance * alpha * opacity;
            accumulated_opacity += opacity * alpha;

            // Adaptive step size based on cone width
            t += max(step_size, cone_width);
        }

        accumulated_radiance
    }

    fn sample_voxel(&self, position: Vec3, mip: f32) -> (Vec3, f32) {
        // Transform to UV coordinates
        let uv = (position - self.bounds_min) / (self.bounds_max - self.bounds_min);

        if uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0 || uv.z < 0.0 || uv.z > 1.0 {
            return (Vec3::ZERO, 0.0);
        }

        // Sample would use hardware trilinear filtering
        // This is placeholder for CPU reference
        (Vec3::new(0.1, 0.1, 0.1), 0.1)
    }

    /// Sample diffuse indirect from multiple cones
    fn sample_diffuse_indirect(&self, position: Vec3, normal: Vec3) -> Vec3 {
        let tangent = if abs(normal.y) < 0.999 {
            normalize(cross(Vec3::Y, normal))
        } else {
            Vec3::X
        };
        let bitangent = cross(normal, tangent);

        // 6 cones in a hemisphere
        let cones = [
            (normal, 60.0_f32.to_radians(), 0.25),                    // Main cone
            (normalize(normal + tangent * 0.5), 60.0_f32.to_radians(), 0.15),
            (normalize(normal - tangent * 0.5), 60.0_f32.to_radians(), 0.15),
            (normalize(normal + bitangent * 0.5), 60.0_f32.to_radians(), 0.15),
            (normalize(normal - bitangent * 0.5), 60.0_f32.to_radians(), 0.15),
            (normalize(normal + tangent * 0.3 + bitangent * 0.3), 60.0_f32.to_radians(), 0.15),
        ];

        let mut result = Vec3::ZERO;

        for (dir, angle, weight) in cones {
            result = result + self.cone_trace(position + normal * self.voxel_size, dir, angle, 50.0) * weight;
        }

        result
    }
}

// ============================================================================
// INDIRECT LIGHTING MANAGER
// ============================================================================

/// Indirect lighting technique
enum IndirectTechnique {
    ProbeGrid,
    Ddgi,
    Ssgi,
    Surfel,
    VoxelGI,
    Hybrid,
}

/// Indirect lighting quality
enum IndirectQuality {
    Low,
    Medium,
    High,
    Ultra,
}

/// Configuration for indirect lighting system
struct IndirectLightingConfig {
    technique: IndirectTechnique,
    quality: IndirectQuality,

    // Probe settings
    probe_grid_resolution: (u32, u32, u32),
    probes_updated_per_frame: u32,

    // SSGI settings
    ssgi_config: SsgiConfig,

    // Voxel settings
    voxel_resolution: u32,
    voxel_clipmap_levels: u32,

    // Caching
    use_radiance_cache: bool,
    cache_cell_size: f32,

    // Temporal
    temporal_weight: f32,

    // Intensity
    indirect_intensity: f32,
}

impl IndirectLightingConfig {
    fn default() -> Self {
        Self {
            technique: IndirectTechnique::Hybrid,
            quality: IndirectQuality::Medium,
            probe_grid_resolution: (16, 8, 16),
            probes_updated_per_frame: 16,
            ssgi_config: SsgiConfig::default(),
            voxel_resolution: 128,
            voxel_clipmap_levels: 4,
            use_radiance_cache: true,
            cache_cell_size: 2.0,
            temporal_weight: 0.95,
            indirect_intensity: 1.0,
        }
    }
}

/// Main indirect lighting manager
struct IndirectLightingManager {
    config: IndirectLightingConfig,

    // Sub-systems
    probe_grid: Option<LightProbeGrid>,
    ddgi_volume: Option<DdgiVolume>,
    ssgi_renderer: Option<SsgiRenderer>,
    surfel_gi: Option<SurfelGI>,
    voxel_gi: Option<VoxelGI>,
    radiance_cache: Option<RadianceCache>,

    // Output
    indirect_texture: TextureHandle,
    history_texture: TextureHandle,

    // Statistics
    frame_count: u64,
}

impl IndirectLightingManager {
    fn new(device: &Device, config: IndirectLightingConfig, scene_bounds: (Vec3, Vec3)) -> Self {
        let (bounds_min, bounds_max) = scene_bounds;

        let probe_grid = match config.technique {
            IndirectTechnique::ProbeGrid | IndirectTechnique::Hybrid => {
                Some(LightProbeGrid::new(
                    bounds_min,
                    bounds_max,
                    config.probe_grid_resolution
                ))
            }
            _ => None,
        };

        let ddgi_volume = match config.technique {
            IndirectTechnique::Ddgi | IndirectTechnique::Hybrid => {
                Some(DdgiVolume::new(
                    device,
                    bounds_min,
                    bounds_max,
                    config.probe_grid_resolution,
                    8,  // Irradiance resolution
                    16, // Visibility resolution
                ))
            }
            _ => None,
        };

        let ssgi_renderer = match config.technique {
            IndirectTechnique::Ssgi | IndirectTechnique::Hybrid => {
                Some(SsgiRenderer::new(device, 1920, 1080, config.ssgi_config.clone()))
            }
            _ => None,
        };

        let surfel_gi = match config.technique {
            IndirectTechnique::Surfel => {
                Some(SurfelGI::new(device, 100000, 0.5))
            }
            _ => None,
        };

        let voxel_gi = match config.technique {
            IndirectTechnique::VoxelGI | IndirectTechnique::Hybrid => {
                Some(VoxelGI::new(
                    device,
                    config.voxel_resolution,
                    bounds_min,
                    bounds_max,
                    config.voxel_clipmap_levels
                ))
            }
            _ => None,
        };

        let radiance_cache = if config.use_radiance_cache {
            Some(RadianceCache::new(config.cache_cell_size, 256))
        } else {
            None
        };

        let indirect_texture = device.create_texture(&TextureDescriptor {
            size: (1920, 1080, 1),
            format: TextureFormat::Rgba16Float,
            usage: TextureUsage::STORAGE | TextureUsage::SAMPLED,
            ..Default::default()
        });

        let history_texture = device.create_texture(&TextureDescriptor {
            size: (1920, 1080, 1),
            format: TextureFormat::Rgba16Float,
            usage: TextureUsage::STORAGE | TextureUsage::SAMPLED,
            ..Default::default()
        });

        Self {
            config,
            probe_grid,
            ddgi_volume,
            ssgi_renderer,
            surfel_gi,
            voxel_gi,
            radiance_cache,
            indirect_texture,
            history_texture,
            frame_count: 0,
        }
    }

    /// Update indirect lighting systems
    fn update(
        &mut self,
        encoder: &mut CommandEncoder,
        scene: &Scene,
        ray_tracer: &RayTracer,
        g_buffer: &GBuffer,
        view_info: &ViewInfo,
    ) {
        // Update DDGI probes
        if let Some(ref mut ddgi) = self.ddgi_volume {
            ddgi.update_probes(encoder, ray_tracer, scene, self.frame_count as u32);
        }

        // Update voxel GI
        if let Some(ref mut voxel) = self.voxel_gi {
            // Re-voxelize dynamic objects
            // voxel.voxelize(encoder, scene, &voxelize_pipeline);
            voxel.generate_mips(encoder, &ComputePipelineHandle::default());
        }

        // Run SSGI
        if let Some(ref mut ssgi) = self.ssgi_renderer {
            ssgi.render(
                encoder,
                &g_buffer.depth,
                &g_buffer.normal,
                &g_buffer.albedo,
                &g_buffer.motion,
                view_info,
                self.frame_count as u32,
            );
        }

        // Evict old radiance cache entries
        if let Some(ref mut cache) = self.radiance_cache {
            if self.frame_count % 60 == 0 {
                cache.evict(self.frame_count);
            }
        }

        self.frame_count += 1;
    }

    /// Sample indirect lighting at a world position
    fn sample_indirect(&mut self, position: Vec3, normal: Vec3, view_dir: Vec3) -> Vec3 {
        let mut result = Vec3::ZERO;
        let mut weight_sum = 0.0;

        // Try radiance cache first
        if let Some(ref mut cache) = self.radiance_cache {
            if let Some(cached) = cache.query(position, normal, self.config.cache_cell_size * 2.0) {
                return cached * self.config.indirect_intensity;
            }
        }

        // Sample from probe grid
        if let Some(ref grid) = self.probe_grid {
            let probe_indirect = grid.sample_irradiance_visibility_aware(position, normal, 0.1);
            result = result + probe_indirect;
            weight_sum += 1.0;
        }

        // Sample from DDGI
        if let Some(ref ddgi) = self.ddgi_volume {
            let ddgi_indirect = ddgi.sample_irradiance(position, normal, view_dir);
            result = result + ddgi_indirect;
            weight_sum += 1.0;
        }

        // Sample from voxel GI
        if let Some(ref voxel) = self.voxel_gi {
            let voxel_indirect = voxel.sample_diffuse_indirect(position, normal);
            result = result + voxel_indirect;
            weight_sum += 1.0;
        }

        if weight_sum > 0.0 {
            result = result * (1.0 / weight_sum);
        }

        // Store in cache
        if let Some(ref mut cache) = self.radiance_cache {
            cache.insert(position, normal, result, 1.0, self.frame_count);
        }

        result * self.config.indirect_intensity
    }

    /// Invalidate indirect lighting in a region (for dynamic updates)
    fn invalidate_region(&mut self, center: Vec3, radius: f32) {
        if let Some(ref mut grid) = self.probe_grid {
            grid.invalidate_region(center, radius);
        }

        if let Some(ref mut cache) = self.radiance_cache {
            // Could implement spatial invalidation for cache
        }
    }

    fn get_indirect_texture(&self) -> &TextureHandle {
        &self.indirect_texture
    }

    fn debug_info(&self) -> IndirectLightingDebugInfo {
        IndirectLightingDebugInfo {
            cache_hit_rate: self.radiance_cache.as_ref().map(|c| c.hit_rate()).unwrap_or(0.0),
            cache_entries: self.radiance_cache.as_ref().map(|c| c.total_entries).unwrap_or(0),
            probe_count: self.probe_grid.as_ref().map(|g| g.probes.len()).unwrap_or(0),
            surfel_count: self.surfel_gi.as_ref().map(|s| s.surfels.len()).unwrap_or(0),
        }
    }
}

struct IndirectLightingDebugInfo {
    cache_hit_rate: f32,
    cache_entries: usize,
    probe_count: usize,
    surfel_count: usize,
}

// ============================================================================
// WGSL SHADERS
// ============================================================================

const INDIRECT_LIGHTING_WGSL: &str = r#"
// Spherical harmonics evaluation
struct SH_L2 {
    coefficients: array<vec3<f32>, 9>,
}

fn sh_basis_l2(direction: vec3<f32>) -> array<f32, 9> {
    let x = direction.x;
    let y = direction.y;
    let z = direction.z;

    let k0 = 0.282095;
    let k1 = 0.488603;
    let k2 = 1.092548;
    let k3 = 0.315392;
    let k4 = 0.546274;

    return array<f32, 9>(
        k0,
        k1 * y,
        k1 * z,
        k1 * x,
        k2 * x * y,
        k2 * y * z,
        k3 * (3.0 * z * z - 1.0),
        k2 * x * z,
        k4 * (x * x - y * y)
    );
}

fn evaluate_sh_irradiance(sh: SH_L2, direction: vec3<f32>) -> vec3<f32> {
    let basis = sh_basis_l2(normalize(direction));

    let PI = 3.14159265359;
    let zh = array<f32, 3>(PI, (2.0 * PI) / 3.0, PI / 4.0);

    var result = sh.coefficients[0] * basis[0] * zh[0];

    for (var i = 1; i < 4; i++) {
        result += sh.coefficients[i] * basis[i] * zh[1];
    }

    for (var i = 4; i < 9; i++) {
        result += sh.coefficients[i] * basis[i] * zh[2];
    }

    return max(result / PI, vec3<f32>(0.0));
}

// Probe sampling
struct ProbeData {
    position: vec3<f32>,
    mean_distance: f32,
    sh: array<vec4<f32>, 7>,
}

@group(0) @binding(0) var<storage, read> probes: array<ProbeData>;
@group(0) @binding(1) var<uniform> grid_params: GridParams;

struct GridParams {
    bounds_min: vec3<f32>,
    _pad0: f32,
    bounds_max: vec3<f32>,
    _pad1: f32,
    resolution: vec3<u32>,
    _pad2: u32,
    inv_spacing: vec3<f32>,
    _pad3: f32,
}

fn world_to_grid(position: vec3<f32>) -> vec3<f32> {
    return (position - grid_params.bounds_min) * grid_params.inv_spacing - vec3<f32>(0.5);
}

fn probe_index(x: u32, y: u32, z: u32) -> u32 {
    return z * grid_params.resolution.y * grid_params.resolution.x +
           y * grid_params.resolution.x + x;
}

fn sample_probe_grid(position: vec3<f32>, normal: vec3<f32>, surface_bias: f32) -> vec3<f32> {
    let biased_pos = position + normal * surface_bias;
    let grid_pos = world_to_grid(biased_pos);

    let x0 = u32(floor(grid_pos.x));
    let y0 = u32(floor(grid_pos.y));
    let z0 = u32(floor(grid_pos.z));

    let fx = fract(grid_pos.x);
    let fy = fract(grid_pos.y);
    let fz = fract(grid_pos.z);

    var result = vec3<f32>(0.0);
    var total_weight = 0.0;

    for (var dz = 0u; dz < 2u; dz++) {
        for (var dy = 0u; dy < 2u; dy++) {
            for (var dx = 0u; dx < 2u; dx++) {
                let x = x0 + dx;
                let y = y0 + dy;
                let z = z0 + dz;

                if (x < grid_params.resolution.x &&
                    y < grid_params.resolution.y &&
                    z < grid_params.resolution.z) {

                    let idx = probe_index(x, y, z);
                    let probe = probes[idx];

                    // Trilinear weight
                    let wx = select(1.0 - fx, fx, dx == 1u);
                    let wy = select(1.0 - fy, fy, dy == 1u);
                    let wz = select(1.0 - fz, fz, dz == 1u);
                    let trilinear = wx * wy * wz;

                    // Backface weight
                    let to_probe = normalize(probe.position - position);
                    let backface = (dot(to_probe, normal) + 1.0) * 0.5;
                    let smooth_backface = backface * backface + 0.2;

                    let weight = trilinear * smooth_backface;

                    if (weight > 0.0001) {
                        // Unpack SH and evaluate
                        var sh: SH_L2;
                        sh.coefficients[0] = probe.sh[0].xyz;
                        sh.coefficients[1] = vec3<f32>(probe.sh[0].w, probe.sh[1].xy);
                        sh.coefficients[2] = vec3<f32>(probe.sh[1].zw, probe.sh[2].x);
                        sh.coefficients[3] = probe.sh[2].yzw;
                        sh.coefficients[4] = probe.sh[3].xyz;
                        sh.coefficients[5] = vec3<f32>(probe.sh[3].w, probe.sh[4].xy);
                        sh.coefficients[6] = vec3<f32>(probe.sh[4].zw, probe.sh[5].x);
                        sh.coefficients[7] = probe.sh[5].yzw;
                        sh.coefficients[8] = probe.sh[6].xyz;

                        let irradiance = evaluate_sh_irradiance(sh, normal);
                        result += irradiance * weight;
                        total_weight += weight;
                    }
                }
            }
        }
    }

    if (total_weight > 0.0001) {
        return result / total_weight;
    }
    return vec3<f32>(0.0);
}

// SSGI ray marching
@group(0) @binding(0) var depth_texture: texture_2d<f32>;
@group(0) @binding(1) var normal_texture: texture_2d<f32>;
@group(0) @binding(2) var color_texture: texture_2d<f32>;
@group(0) @binding(3) var noise_texture: texture_2d<f32>;
@group(0) @binding(4) var output_texture: texture_storage_2d<rgba16float, write>;

struct SsgiParams {
    view_proj: mat4x4<f32>,
    inv_view_proj: mat4x4<f32>,
    camera_pos: vec3<f32>,
    ray_count: u32,
    max_steps: u32,
    max_distance: f32,
    thickness: f32,
    intensity: f32,
    frame_index: u32,
}

@group(0) @binding(5) var<uniform> params: SsgiParams;

fn reconstruct_position(uv: vec2<f32>, depth: f32) -> vec3<f32> {
    let ndc = vec4<f32>(uv * 2.0 - 1.0, depth, 1.0);
    let world = params.inv_view_proj * ndc;
    return world.xyz / world.w;
}

fn project_position(position: vec3<f32>) -> vec3<f32> {
    let clip = params.view_proj * vec4<f32>(position, 1.0);
    let ndc = clip.xyz / clip.w;
    return vec3<f32>(ndc.xy * 0.5 + 0.5, ndc.z);
}

@compute @workgroup_size(8, 8, 1)
fn ssgi_main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(depth_texture);
    if (id.x >= dims.x || id.y >= dims.y) {
        return;
    }

    let uv = (vec2<f32>(id.xy) + 0.5) / vec2<f32>(dims);
    let depth = textureLoad(depth_texture, vec2<i32>(id.xy), 0).r;

    if (depth >= 1.0) {
        textureStore(output_texture, vec2<i32>(id.xy), vec4<f32>(0.0));
        return;
    }

    let position = reconstruct_position(uv, depth);
    let normal = textureLoad(normal_texture, vec2<i32>(id.xy), 0).xyz * 2.0 - 1.0;

    // Generate hemisphere samples using noise
    let noise_uv = vec2<f32>(id.xy % 64u) / 64.0;
    let noise = textureLoad(noise_texture, vec2<i32>(id.xy % 64u), 0).r;

    var accumulated = vec3<f32>(0.0);
    var ao = 0.0;

    for (var i = 0u; i < params.ray_count; i++) {
        // Fibonacci hemisphere sampling with temporal jitter
        let phi = 2.4 * f32(i) + noise * 6.28318530718;
        let cos_theta = 1.0 - (f32(i) + 0.5) / f32(params.ray_count);
        let sin_theta = sqrt(1.0 - cos_theta * cos_theta);

        let local_dir = vec3<f32>(
            sin_theta * cos(phi),
            sin_theta * sin(phi),
            cos_theta
        );

        // Transform to world space
        let up = select(vec3<f32>(0.0, 1.0, 0.0), vec3<f32>(1.0, 0.0, 0.0), abs(normal.y) > 0.99);
        let tangent = normalize(cross(up, normal));
        let bitangent = cross(normal, tangent);

        let ray_dir = tangent * local_dir.x + bitangent * local_dir.y + normal * local_dir.z;

        // Screen-space ray march
        var ray_pos = position + normal * 0.01;
        let step_size = params.max_distance / f32(params.max_steps);
        var hit = false;
        var hit_color = vec3<f32>(0.0);

        for (var step = 0u; step < params.max_steps; step++) {
            ray_pos += ray_dir * step_size;

            let projected = project_position(ray_pos);
            if (projected.x < 0.0 || projected.x > 1.0 ||
                projected.y < 0.0 || projected.y > 1.0) {
                break;
            }

            let sample_coord = vec2<i32>(projected.xy * vec2<f32>(dims));
            let sample_depth = textureLoad(depth_texture, sample_coord, 0).r;
            let sample_pos = reconstruct_position(projected.xy, sample_depth);

            let depth_diff = ray_pos.z - sample_pos.z;
            if (depth_diff > 0.0 && depth_diff < params.thickness) {
                hit = true;
                hit_color = textureLoad(color_texture, sample_coord, 0).rgb;
                ao += 1.0;
                break;
            }
        }

        if (hit) {
            accumulated += hit_color * cos_theta;
        }
    }

    let indirect = accumulated / f32(params.ray_count) * params.intensity;
    let occlusion = 1.0 - (ao / f32(params.ray_count));

    textureStore(output_texture, vec2<i32>(id.xy), vec4<f32>(indirect, occlusion));
}

// Temporal accumulation
@group(0) @binding(0) var current_texture: texture_2d<f32>;
@group(0) @binding(1) var motion_texture: texture_2d<f32>;
@group(0) @binding(2) var depth_current: texture_2d<f32>;
@group(0) @binding(3) var history_texture: texture_storage_2d<rgba16float, read_write>;

struct TemporalParams {
    temporal_weight: f32,
    frame_index: u32,
}

@group(0) @binding(4) var<uniform> temporal_params: TemporalParams;

@compute @workgroup_size(8, 8, 1)
fn ssgi_temporal(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(current_texture);
    if (id.x >= dims.x || id.y >= dims.y) {
        return;
    }

    let uv = (vec2<f32>(id.xy) + 0.5) / vec2<f32>(dims);
    let motion = textureLoad(motion_texture, vec2<i32>(id.xy), 0).xy;
    let prev_uv = uv - motion;

    let current = textureLoad(current_texture, vec2<i32>(id.xy), 0);

    var weight = temporal_params.temporal_weight;

    // Reject history if outside screen
    if (prev_uv.x < 0.0 || prev_uv.x > 1.0 || prev_uv.y < 0.0 || prev_uv.y > 1.0) {
        weight = 0.0;
    }

    let prev_coord = vec2<i32>(prev_uv * vec2<f32>(dims));
    let history = textureLoad(history_texture, prev_coord);

    // Neighborhood clamping
    var min_color = current.rgb;
    var max_color = current.rgb;

    for (var dy = -1; dy <= 1; dy++) {
        for (var dx = -1; dx <= 1; dx++) {
            let neighbor = textureLoad(current_texture, vec2<i32>(id.xy) + vec2<i32>(dx, dy), 0).rgb;
            min_color = min(min_color, neighbor);
            max_color = max(max_color, neighbor);
        }
    }

    let clamped_history = clamp(history.rgb, min_color, max_color);
    let blended = mix(current.rgb, clamped_history, weight);

    textureStore(history_texture, vec2<i32>(id.xy), vec4<f32>(blended, current.a));
}

// Octahedral encoding for DDGI
fn oct_encode(direction: vec3<f32>) -> vec2<f32> {
    let d = direction / (abs(direction.x) + abs(direction.y) + abs(direction.z));
    var oct = vec2<f32>(d.x, d.y);

    if (d.z < 0.0) {
        oct = (1.0 - abs(oct.yx)) * select(vec2<f32>(-1.0), vec2<f32>(1.0), oct >= vec2<f32>(0.0));
    }

    return oct * 0.5 + 0.5;
}

fn oct_decode(oct: vec2<f32>) -> vec3<f32> {
    var o = oct * 2.0 - 1.0;
    let z = 1.0 - abs(o.x) - abs(o.y);

    let t = max(-z, 0.0);
    o.x += select(t, -t, o.x >= 0.0);
    o.y += select(t, -t, o.y >= 0.0);

    return normalize(vec3<f32>(o.x, o.y, z));
}

// Voxel cone tracing
@group(0) @binding(0) var voxel_radiance: texture_3d<f32>;
@group(0) @binding(1) var voxel_sampler: sampler;

struct VoxelParams {
    bounds_min: vec3<f32>,
    _pad0: f32,
    bounds_max: vec3<f32>,
    _pad1: f32,
    voxel_size: f32,
    max_distance: f32,
    cone_angle: f32,
    _pad2: f32,
}

@group(0) @binding(2) var<uniform> voxel_params: VoxelParams;

fn cone_trace(origin: vec3<f32>, direction: vec3<f32>) -> vec4<f32> {
    var accumulated_radiance = vec3<f32>(0.0);
    var accumulated_opacity = 0.0;

    let step_size = voxel_params.voxel_size * 0.5;
    var t = step_size;

    while (t < voxel_params.max_distance && accumulated_opacity < 0.99) {
        let pos = origin + direction * t;

        // Transform to voxel UV
        let uv = (pos - voxel_params.bounds_min) / (voxel_params.bounds_max - voxel_params.bounds_min);

        if (any(uv < vec3<f32>(0.0)) || any(uv > vec3<f32>(1.0))) {
            break;
        }

        // Determine mip level from cone width
        let cone_width = t * voxel_params.cone_angle;
        let mip = max(0.0, log2(cone_width / voxel_params.voxel_size));

        let sample = textureSampleLevel(voxel_radiance, voxel_sampler, uv, mip);
        let radiance = sample.rgb;
        let opacity = sample.a;

        // Front-to-back compositing
        let alpha = 1.0 - accumulated_opacity;
        accumulated_radiance += radiance * alpha * opacity;
        accumulated_opacity += opacity * alpha;

        t += max(step_size, cone_width);
    }

    return vec4<f32>(accumulated_radiance, accumulated_opacity);
}

fn diffuse_cone_trace(position: vec3<f32>, normal: vec3<f32>) -> vec3<f32> {
    let up = select(vec3<f32>(0.0, 1.0, 0.0), vec3<f32>(1.0, 0.0, 0.0), abs(normal.y) > 0.99);
    let tangent = normalize(cross(up, normal));
    let bitangent = cross(normal, tangent);

    // 5 cones covering hemisphere
    var result = vec3<f32>(0.0);

    // Main cone
    result += cone_trace(position + normal * voxel_params.voxel_size, normal).rgb * 0.25;

    // Side cones
    let side_angle = 0.57735; // tan(30 degrees)
    let directions = array<vec3<f32>, 4>(
        normalize(normal + tangent * side_angle),
        normalize(normal - tangent * side_angle),
        normalize(normal + bitangent * side_angle),
        normalize(normal - bitangent * side_angle)
    );

    for (var i = 0; i < 4; i++) {
        result += cone_trace(position + normal * voxel_params.voxel_size, directions[i]).rgb * 0.1875;
    }

    return result;
}
"#;

// ============================================================================
// UNIT TESTS
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_spherical_harmonics_l2() {
        let mut sh = SphericalHarmonicsL2::new();

        // Add light from above
        sh.add_directional_light(Vec3::new(0.0, 1.0, 0.0), Vec3::new(1.0, 1.0, 1.0));

        // Evaluate in the light direction should be bright
        let up_irradiance = sh.evaluate(Vec3::new(0.0, 1.0, 0.0));
        assert!(up_irradiance.y > 0.1);

        // Evaluate in opposite direction should be darker
        let down_irradiance = sh.evaluate(Vec3::new(0.0, -1.0, 0.0));
        assert!(down_irradiance.y < up_irradiance.y);
    }

    #[test]
    fn test_sh_basis_orthogonality() {
        // Test that basis functions are approximately orthonormal
        let directions = [
            Vec3::new(1.0, 0.0, 0.0),
            Vec3::new(0.0, 1.0, 0.0),
            Vec3::new(0.0, 0.0, 1.0),
            Vec3::new(-1.0, 0.0, 0.0),
            Vec3::new(0.0, -1.0, 0.0),
            Vec3::new(0.0, 0.0, -1.0),
        ];

        for dir in &directions {
            let basis = SphericalHarmonicsL2::evaluate_basis(*dir);
            assert!(basis.len() == 9);

            // L0 should be constant
            assert!((basis[0] - 0.282095).abs() < 0.001);
        }
    }

    #[test]
    fn test_sh_lerp() {
        let mut sh1 = SphericalHarmonicsL2::new();
        sh1.add_ambient(Vec3::new(1.0, 0.0, 0.0));

        let mut sh2 = SphericalHarmonicsL2::new();
        sh2.add_ambient(Vec3::new(0.0, 1.0, 0.0));

        let blended = SphericalHarmonicsL2::lerp(&sh1, &sh2, 0.5);
        let result = blended.evaluate(Vec3::new(0.0, 1.0, 0.0));

        // Should have equal red and green
        assert!((result.x - result.y).abs() < 0.1);
    }

    #[test]
    fn test_octahedral_encoding() {
        let test_directions = [
            Vec3::new(1.0, 0.0, 0.0),
            Vec3::new(0.0, 1.0, 0.0),
            Vec3::new(0.0, 0.0, 1.0),
            Vec3::new(0.577, 0.577, 0.577),
            Vec3::new(-0.577, 0.577, -0.577),
        ];

        for &dir in &test_directions {
            let normalized = normalize(dir);
            let uv = OctahedralMap::direction_to_uv(normalized);
            let decoded = OctahedralMap::uv_to_direction(uv);

            let error = length(decoded - normalized);
            assert!(error < 0.001, "Octahedral encode/decode error: {}", error);
        }
    }

    #[test]
    fn test_octahedral_map() {
        let mut oct = OctahedralMap::new(16);

        let test_dir = Vec3::new(0.0, 1.0, 0.0);
        let test_value = Vec3::new(1.0, 0.5, 0.25);

        oct.set(test_dir, test_value);
        let sampled = oct.sample(test_dir);

        assert!((sampled.x - test_value.x).abs() < 0.1);
    }

    #[test]
    fn test_light_probe_grid() {
        let grid = LightProbeGrid::new(
            Vec3::new(-10.0, -10.0, -10.0),
            Vec3::new(10.0, 10.0, 10.0),
            (4, 4, 4)
        );

        assert_eq!(grid.probes.len(), 64);

        // Test world to grid conversion
        let (gx, gy, gz) = grid.world_to_grid(Vec3::ZERO);
        assert!((gx - 1.5).abs() < 0.1);
        assert!((gy - 1.5).abs() < 0.1);
        assert!((gz - 1.5).abs() < 0.1);
    }

    #[test]
    fn test_trilinear_weights() {
        let grid = LightProbeGrid::new(
            Vec3::new(0.0, 0.0, 0.0),
            Vec3::new(4.0, 4.0, 4.0),
            (4, 4, 4)
        );

        // Weights at cell center should sum to 1
        let weights = grid.trilinear_weights(Vec3::new(0.5, 0.5, 0.5));
        let sum: f32 = weights.iter().sum();
        assert!((sum - 1.0).abs() < 0.001);

        // At corner, one weight should be 1, others 0
        let corner_weights = grid.trilinear_weights(Vec3::new(0.0, 0.0, 0.0));
        assert!(corner_weights[0] > 0.99);
    }

    #[test]
    fn test_radiance_cache() {
        let mut cache = RadianceCache::new(2.0, 100);

        let position = Vec3::new(1.0, 1.0, 1.0);
        let normal = Vec3::new(0.0, 1.0, 0.0);
        let radiance = Vec3::new(0.5, 0.5, 0.5);

        cache.insert(position, normal, radiance, 1.0, 0);

        let result = cache.query(position, normal, 3.0);
        assert!(result.is_some());

        let queried = result.unwrap();
        assert!((queried.x - radiance.x).abs() < 0.1);
    }

    #[test]
    fn test_radiance_cache_eviction() {
        let mut cache = RadianceCache::new(1.0, 10);
        cache.max_age_frames = 10;

        // Insert entries at frame 0
        cache.insert(Vec3::new(0.0, 0.0, 0.0), Vec3::Y, Vec3::ONE, 1.0, 0);
        cache.insert(Vec3::new(5.0, 5.0, 5.0), Vec3::Y, Vec3::ONE, 1.0, 0);

        assert_eq!(cache.total_entries, 2);

        // Evict at frame 15 (beyond max_age)
        cache.evict(15);
        assert_eq!(cache.total_entries, 0);
    }

    #[test]
    fn test_irradiance_probe() {
        let mut probe = IrradianceProbe::new(Vec3::ZERO);

        assert!(!probe.is_valid());
        probe.state = ProbeState::Valid;
        assert!(probe.is_valid());

        probe.irradiance_sh.add_ambient(Vec3::new(0.2, 0.2, 0.2));
        let sampled = probe.sample(Vec3::new(0.0, 1.0, 0.0));
        assert!(sampled.x > 0.0);
    }

    #[test]
    fn test_surfel_coverage() {
        let surfel = Surfel::new(
            Vec3::ZERO,
            Vec3::Y,
            Vec3::ONE,
            1.0
        );

        // At center, coverage should be 1
        let coverage_center = surfel.coverage_at(Vec3::ZERO);
        assert!((coverage_center - 1.0).abs() < 0.001);

        // At edge, coverage should be 0
        let coverage_edge = surfel.coverage_at(Vec3::new(1.0, 0.0, 0.0));
        assert!(coverage_edge < 0.001);

        // At half radius, some coverage
        let coverage_half = surfel.coverage_at(Vec3::new(0.5, 0.0, 0.0));
        assert!(coverage_half > 0.0 && coverage_half < 1.0);
    }

    #[test]
    fn test_ssgi_config() {
        let config = SsgiConfig::default();

        assert_eq!(config.quality.ray_count(), 8);
        assert_eq!(config.quality.resolution_scale(), 0.5);
    }

    #[test]
    fn test_indirect_lighting_config() {
        let config = IndirectLightingConfig::default();

        assert!(matches!(config.technique, IndirectTechnique::Hybrid));
        assert!(matches!(config.quality, IndirectQuality::Medium));
        assert!(config.use_radiance_cache);
    }

    #[test]
    fn test_sh_pack_for_gpu() {
        let mut sh = SphericalHarmonicsL2::new();
        sh.add_directional_light(Vec3::new(1.0, 1.0, 0.0).normalize(), Vec3::ONE);

        let packed = sh.pack_for_gpu();
        assert_eq!(packed.len(), 7);

        // Verify first coefficient is packed correctly
        assert!((packed[0].x - sh.coefficients[0].x).abs() < 0.001);
        assert!((packed[0].y - sh.coefficients[0].y).abs() < 0.001);
        assert!((packed[0].z - sh.coefficients[0].z).abs() < 0.001);
    }

    #[test]
    fn test_probe_grid_invalidation() {
        let mut grid = LightProbeGrid::new(
            Vec3::new(-10.0, -10.0, -10.0),
            Vec3::new(10.0, 10.0, 10.0),
            (4, 4, 4)
        );

        // Set all probes to valid
        for probe in &mut grid.probes {
            probe.state = ProbeState::Valid;
        }

        // Invalidate region around origin
        grid.invalidate_region(Vec3::ZERO, 5.0);

        // Some probes should now need update
        let needs_update = grid.probes.iter()
            .filter(|p| matches!(p.state, ProbeState::NeedsUpdate))
            .count();

        assert!(needs_update > 0);
    }

    #[test]
    fn test_ddgi_probe() {
        let probe = DdgiProbe::new(Vec3::ZERO, 8, 16);

        assert!(!matches!(probe.state, ProbeState::Valid));
        assert_eq!(probe.irradiance_map.resolution, 8);
        assert_eq!(probe.visibility_map.resolution, 16);
    }

    #[test]
    fn test_voxel_cone_trace_bounds() {
        // Test that cone tracing respects bounds
        let bounds_min = Vec3::new(-5.0, -5.0, -5.0);
        let bounds_max = Vec3::new(5.0, 5.0, 5.0);

        // Position outside bounds
        let outside_pos = Vec3::new(10.0, 10.0, 10.0);
        let uv = (outside_pos - bounds_min) / (bounds_max - bounds_min);

        assert!(uv.x > 1.0 || uv.y > 1.0 || uv.z > 1.0);
    }

    #[test]
    fn test_sh_ambient_symmetry() {
        let mut sh = SphericalHarmonicsL2::new();
        sh.add_ambient(Vec3::new(1.0, 1.0, 1.0));

        // Ambient light should be uniform in all directions
        let up = sh.evaluate(Vec3::new(0.0, 1.0, 0.0));
        let down = sh.evaluate(Vec3::new(0.0, -1.0, 0.0));
        let side = sh.evaluate(Vec3::new(1.0, 0.0, 0.0));

        assert!((up.x - down.x).abs() < 0.01);
        assert!((up.x - side.x).abs() < 0.01);
    }

    #[test]
    fn test_radiance_cache_hit_rate() {
        let mut cache = RadianceCache::new(2.0, 100);

        // Initially no hits or misses
        assert_eq!(cache.hit_rate(), 0.0);

        // Insert and query
        let pos = Vec3::new(1.0, 1.0, 1.0);
        cache.insert(pos, Vec3::Y, Vec3::ONE, 1.0, 0);

        // First query should hit
        let _ = cache.query(pos, Vec3::Y, 3.0);

        // Query miss in different location
        let _ = cache.query(Vec3::new(100.0, 100.0, 100.0), Vec3::Y, 1.0);

        // Should have 50% hit rate
        assert!((cache.hit_rate() - 0.5).abs() < 0.01);
    }
}
