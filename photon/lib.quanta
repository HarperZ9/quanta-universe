    /// Draw call interceptor for DX11
    pub struct DrawCallInterceptor {
        draw_count: u64,
        indexed_draw_count: u64,
        filters: Vec<DrawFilter>,
        skip_list: Vec<u64>,
    }

    #[derive(Debug, Clone)]
    pub struct DrawFilter {
        pub name: String,
        pub vertex_count_min: Option<u32>,
        pub vertex_count_max: Option<u32>,
        pub index_count_min: Option<u32>,
        pub index_count_max: Option<u32>,
        pub shader_hash: Option<u64>,
        pub action: DrawFilterAction,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum DrawFilterAction {
        Skip,
        Wireframe,
        Highlight,
        Log,
        Replace { shader: u64 },
    }

    impl DrawCallInterceptor {
        pub fn new() -> Self {
            DrawCallInterceptor {
                draw_count: 0,
                indexed_draw_count: 0,
                filters: Vec::new(),
                skip_list: Vec::new(),
            }
        }

        pub fn add_filter(&mut self, filter: DrawFilter) {
            self.filters.push(filter);
        }

        pub fn on_draw(&mut self, vertex_count: u32, start_vertex: u32) -> DrawFilterAction {
            self.draw_count += 1;

            for filter in &self.filters {
                if let Some(min) = filter.vertex_count_min {
                    if vertex_count < min { continue; }
                }
                if let Some(max) = filter.vertex_count_max {
                    if vertex_count > max { continue; }
                }
                return filter.action;
            }

            DrawFilterAction::Log // Default: pass through
        }

        pub fn on_draw_indexed(&mut self, index_count: u32, start_index: u32, base_vertex: i32) -> DrawFilterAction {
            self.indexed_draw_count += 1;

            for filter in &self.filters {
                if let Some(min) = filter.index_count_min {
                    if index_count < min { continue; }
                }
                if let Some(max) = filter.index_count_max {
                    if index_count > max { continue; }
                }
                return filter.action;
            }

            DrawFilterAction::Log
        }

        pub fn stats(&self) -> (u64, u64) {
            (self.draw_count, self.indexed_draw_count)
        }
    }

    #[derive(Debug)]
    pub enum DX11Error {
        NotInitialized,
        DeviceCreationFailed,
        HookFailed,
        VtableAccessFailed,
    }
}

