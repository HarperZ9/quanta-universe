            self.context_vtable = vec![0u64; 150];
            self.swapchain_vtable = vec![0u64; 20];

            Ok(())
        }

        /// Hook Present function
        pub fn hook_present(&mut self, hook_fn: u64) -> Result<u64, DX11Error> {
            if self.swapchain_vtable.is_empty() {
                return Err(DX11Error::NotInitialized);
            }

            let present_addr = self.swapchain_vtable[dxgi_vtable::PRESENT];
            self.original_present = Some(present_addr);

            // Would write hook to vtable
            // self.swapchain_vtable[dxgi_vtable::PRESENT] = hook_fn;

            Ok(present_addr)
        }

        /// Hook Draw functions
        pub fn hook_draw(&mut self, draw_hook: u64, draw_indexed_hook: u64) -> Result<(), DX11Error> {
            if self.context_vtable.is_empty() {
                return Err(DX11Error::NotInitialized);
            }

            self.original_draw = Some(self.context_vtable[vtable_indices::DRAW]);
            self.original_draw_indexed = Some(self.context_vtable[vtable_indices::DRAWINDEXED]);

            // Would write hooks to vtable

            Ok(())
        }

        /// Get render target from device context
        pub fn get_render_target(&self) -> Option<u64> {
