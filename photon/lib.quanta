    /// Resource state tracker for DX12
    pub struct ResourceStateTracker {
        states: HashMap<u64, ResourceState>,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum ResourceState {
        Common,
        VertexBuffer,
        IndexBuffer,
        ConstantBuffer,
        RenderTarget,
        UnorderedAccess,
        DepthWrite,
        DepthRead,
        ShaderResource,
        CopyDest,
        CopySource,
        Present,
    }

    impl ResourceStateTracker {
        pub fn new() -> Self {
            ResourceStateTracker {
                states: HashMap::new(),
            }
        }

        pub fn set_state(&mut self, resource: u64, state: ResourceState) {
            self.states.insert(resource, state);
        }

        pub fn get_state(&self, resource: u64) -> ResourceState {
            self.states.get(&resource).copied().unwrap_or(ResourceState::Common)
        }

        /// Generate barrier for state transition
        pub fn transition(&mut self, resource: u64, new_state: ResourceState) -> Option<ResourceBarrier> {
            let current = self.get_state(resource);
            if std::mem::discriminant(&current) == std::mem::discriminant(&new_state) {
                return None;
            }

            self.set_state(resource, new_state);
            Some(ResourceBarrier {
                resource,
                before: current,
                after: new_state,
            })
        }
    }

    pub struct ResourceBarrier {
        pub resource: u64,
        pub before: ResourceState,
        pub after: ResourceState,
    }

    #[derive(Debug)]
    pub enum DX12Error {
        NotInitialized,
        DeviceCreationFailed,
        CommandListError,
        FenceError,
    }
}

