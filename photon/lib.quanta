pub mod effects {
    use super::*;

    /// FXAA anti-aliasing effect
    pub struct FXAAEffect {
        enabled: bool,
        quality: FXAAQuality,
        subpixel_quality: f32,
        edge_threshold: f32,
        edge_threshold_min: f32,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum FXAAQuality {
        Low,
        Medium,
        High,
        Ultra,
    }

    impl FXAAEffect {
        pub fn new(quality: FXAAQuality) -> Self {
            let (subpixel, threshold, threshold_min) = match quality {
                FXAAQuality::Low => (0.25, 0.25, 0.0833),
                FXAAQuality::Medium => (0.50, 0.166, 0.0625),
                FXAAQuality::High => (0.75, 0.125, 0.0312),
                FXAAQuality::Ultra => (1.00, 0.063, 0.0156),
            };

            FXAAEffect {
                enabled: true,
                quality,
                subpixel_quality: subpixel,
                edge_threshold: threshold,
                edge_threshold_min: threshold_min,
            }
        }
    }

    impl PostProcessEffect for FXAAEffect {
        fn name(&self) -> &str { "FXAA" }
        fn enabled(&self) -> bool { self.enabled }
        fn set_enabled(&mut self, enabled: bool) { self.enabled = enabled; }

        fn render(&self, ctx: &PostProcessContext, input: &RenderTarget) -> RenderTarget {
            // Would run FXAA shader
            RenderTarget { ..*input }
        }
    }

