        mat
    }

    /// Brick
    pub fn brick() -> DisneyMaterial {
        let mut mat = DisneyMaterial::default();
        mat.base_color = Vec3::new(0.6, 0.25, 0.15);
        mat.metallic = 0.0;
        mat.roughness = 0.85;
        mat
    }

    /// Asphalt
    pub fn asphalt() -> DisneyMaterial {
        let mut mat = DisneyMaterial::default();
        mat.base_color = Vec3::new(0.15, 0.15, 0.15);
        mat.metallic = 0.0;
        mat.roughness = 0.95;
        mat
    }

    /// Snow
    pub fn snow() -> DisneyMaterial {
        let mut mat = DisneyMaterial::default();
        mat.base_color = Vec3::new(0.98, 0.98, 1.0);
        mat.metallic = 0.0;
        mat.roughness = 0.8;
        mat.subsurface = 0.5;
        mat
    }

    /// Sand
    pub fn sand() -> DisneyMaterial {
        let mut mat = DisneyMaterial::default();
        mat.base_color = Vec3::new(0.76, 0.70, 0.50);
        mat.metallic = 0.0;
        mat.roughness = 0.9;
        mat
    }

    /// Grass
    pub fn grass() -> DisneyMaterial {
        let mut mat = DisneyMaterial::default();
        mat.base_color = Vec3::new(0.2, 0.4, 0.1);
        mat.metallic = 0.0;
        mat.roughness = 0.7;
        mat.subsurface = 0.1;
        mat
    }

    /// Wax
    pub fn wax(color: Vec3) -> DisneyMaterial {
        let mut mat = DisneyMaterial::default();
        mat.base_color = color;
        mat.metallic = 0.0;
        mat.roughness = 0.3;
        mat.subsurface = 0.8;
        mat
    }
}

// =============================================================================
// REGION: GPU MATERIAL BUFFER
// =============================================================================

/// GPU-compatible material data
#[repr(C)]
pub struct GpuMaterialData {
    pub base_color: [f32; 4],
    pub emission: [f32; 4],
    pub metallic_roughness_ao_alpha: [f32; 4],
    pub specular_sheen_clearcoat_flags: [f32; 4],
    pub subsurface_ior_transmission_aniso: [f32; 4],
    pub texture_indices: [i32; 8],
}

impl GpuMaterialData {
    /// Create from Disney material
    pub fn from_disney(mat: &DisneyMaterial, texture_indices: [i32; 8]) -> Self {
        Self {
            base_color: [mat.base_color.x, mat.base_color.y, mat.base_color.z, 1.0],
            emission: [mat.emission.x * mat.emission_intensity,
                      mat.emission.y * mat.emission_intensity,
                      mat.emission.z * mat.emission_intensity, 0.0],
            metallic_roughness_ao_alpha: [mat.metallic, mat.roughness, 1.0, mat.alpha],
            specular_sheen_clearcoat_flags: [mat.specular, mat.sheen, mat.clearcoat, 0.0],
            subsurface_ior_transmission_aniso: [mat.subsurface, mat.ior, mat.transmission, mat.anisotropic],
            texture_indices,
        }
    }
}

/// GPU material buffer
pub struct MaterialBuffer {
    /// GPU buffer
    buffer: GpuBuffer,

    /// Material data
    materials: Vec<GpuMaterialData>,

    /// Dirty flag
    dirty: bool,

    /// Max materials
    capacity: usize,
}

impl MaterialBuffer {
    /// Create new material buffer
    pub fn new(capacity: usize) -> Self {
        let buffer = GpuBuffer::new(
            capacity * std::mem::size_of::<GpuMaterialData>(),
            BufferUsage::Storage | BufferUsage::Uniform,
        );

        Self {
            buffer,
            materials: Vec::with_capacity(capacity),
            dirty: false,
            capacity,
        }
    }

    /// Add material, returns index
    pub fn add(&mut self, material: GpuMaterialData) -> usize {
        let index = self.materials.len();
        self.materials.push(material);
        self.dirty = true;
        index
    }

    /// Update material at index
    pub fn update(&mut self, index: usize, material: GpuMaterialData) {
        if index < self.materials.len() {
            self.materials[index] = material;
            self.dirty = true;
        }
    }

    /// Upload to GPU
    pub fn upload(&mut self) {
        if self.dirty && !self.materials.is_empty() {
            self.buffer.write(&self.materials);
            self.dirty = false;
        }
    }

    /// Get GPU buffer
    pub fn gpu_buffer(&self) -> &GpuBuffer {
        &self.buffer
    }
}

// Buffer usage flags
bitflags::bitflags! {
    pub struct BufferUsage: u32 {
        const Storage = 1;
        const Uniform = 2;
    }
}

// =============================================================================
// REGION: SHADER GENERATION
// =============================================================================

/// Generate HLSL/GLSL code for material evaluation
pub fn generate_material_shader() -> String {
    r#"
// Material evaluation shader code
struct MaterialInput {
    float3 base_color;
    float metallic;
    float roughness;
    float3 normal;
    float3 view;
    float3 light;
    float3 tangent;
    float ao;
    float3 emission;
};

float3 evaluate_material(MaterialInput input) {
    float3 n = input.normal;
    float3 v = input.view;
    float3 l = input.light;
    float3 h = normalize(v + l);

    float n_dot_l = max(dot(n, l), 0.0001);
    float n_dot_v = max(dot(n, v), 0.0001);
    float n_dot_h = max(dot(n, h), 0.0001);
    float l_dot_h = max(dot(l, h), 0.0001);

    // Compute F0
    float3 f0 = lerp(float3(0.04, 0.04, 0.04), input.base_color, input.metallic);

    // Diffuse
    float3 diffuse = input.base_color * (1.0 - input.metallic) * (1.0 / 3.14159);

    // Specular D (GGX)
    float alpha = input.roughness * input.roughness;
    float alpha_sq = alpha * alpha;
    float d_denom = n_dot_h * n_dot_h * (alpha_sq - 1.0) + 1.0;
    float D = alpha_sq / (3.14159 * d_denom * d_denom);

    // Specular G (Smith GGX correlated)
    float ggx_v = n_dot_l * sqrt(n_dot_v * n_dot_v * (1.0 - alpha_sq) + alpha_sq);
    float ggx_l = n_dot_v * sqrt(n_dot_l * n_dot_l * (1.0 - alpha_sq) + alpha_sq);
    float G = 0.5 / max(ggx_v + ggx_l, 0.0001);

    // Specular F (Schlick)
    float3 F = f0 + (1.0 - f0) * pow(1.0 - l_dot_h, 5.0);

    float3 specular = F * D * G;

    return (diffuse + specular) * n_dot_l * input.ao + input.emission;
}
"#.to_string()
}

// =============================================================================
// REGION: TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_roughness_conversion() {
        assert!((MaterialUtils::roughness_to_alpha(0.5) - 0.25).abs() < 1e-6);
        assert!((MaterialUtils::alpha_to_roughness(0.25) - 0.5).abs() < 1e-6);

        // Round-trip
        let r = 0.7;
        let alpha = MaterialUtils::roughness_to_alpha(r);
        let r2 = MaterialUtils::alpha_to_roughness(alpha);
        assert!((r - r2).abs() < 1e-6);
    }

    #[test]
    fn test_ior_f0_conversion() {
        // Glass IOR ~1.5 should give F0 ~0.04
        let f0 = MaterialUtils::ior_to_f0(1.5);
        assert!((f0 - 0.04).abs() < 0.01);

        // Round-trip
        let ior = 1.45;
        let f0 = MaterialUtils::ior_to_f0(ior);
        let ior2 = MaterialUtils::f0_to_ior(f0);
        assert!((ior - ior2).abs() < 0.01);
    }

    #[test]
    fn test_fresnel_schlick() {
        let f0 = Vec3::splat(0.04);

        // At normal incidence, F should equal F0
        let f_normal = Fresnel::schlick(1.0, f0);
        assert!((f_normal.x - f0.x).abs() < 1e-6);

        // At grazing angle, F should approach 1
        let f_grazing = Fresnel::schlick(0.0, f0);
        assert!(f_grazing.x > 0.99);
    }

    #[test]
    fn test_fresnel_dielectric() {
        // At normal incidence with IOR 1.5
        let f = Fresnel::dielectric(1.0, 1.5);
        let expected = MaterialUtils::ior_to_f0(1.5);
        assert!((f - expected).abs() < 0.01);

        // Total internal reflection
        let f_tir = Fresnel::dielectric(0.1, 0.5); // Going from dense to light
        assert!((f_tir - 1.0).abs() < 0.01);
    }

    #[test]
    fn test_ndf_ggx() {
        let ndf = NDF::GGX;

        // At n_dot_h = 1 (perfect alignment), NDF should be maximum
        let d_aligned = ndf.evaluate(1.0, 0.5);
        let d_45deg = ndf.evaluate(0.707, 0.5);

        assert!(d_aligned > d_45deg);
        assert!(d_aligned > 0.0);
    }

    #[test]
    fn test_ndf_roughness_effect() {
        let ndf = NDF::GGX;

        // Smoother surfaces have sharper peaks
        let d_smooth = ndf.evaluate(1.0, 0.1);
        let d_rough = ndf.evaluate(1.0, 0.9);

        assert!(d_smooth > d_rough);
    }

    #[test]
    fn test_geometry_function() {
        let g = GeometryFunction::SmithGGX;

        // At normal incidence (n_dot_v = n_dot_l = 1), G should be near 1
        let g_normal = g.evaluate(1.0, 1.0, 0.5);
        assert!(g_normal > 0.9);

        // At grazing angles, G should decrease
        let g_grazing = g.evaluate(0.1, 0.1, 0.5);
        assert!(g_grazing < g_normal);
    }

    #[test]
    fn test_disney_material_default() {
        let mat = DisneyMaterial::default();

        assert!((mat.metallic - 0.0).abs() < 1e-6);
        assert!((mat.roughness - 0.5).abs() < 1e-6);
        assert!((mat.alpha - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_disney_material_presets() {
        let metal = DisneyMaterial::metal(Vec3::splat(0.8), 0.3);
        assert!((metal.metallic - 1.0).abs() < 1e-6);

        let dielectric = DisneyMaterial::dielectric(Vec3::splat(0.5), 0.4);
        assert!((dielectric.metallic - 0.0).abs() < 1e-6);

        let glass = DisneyMaterial::glass(Vec3::splat(1.0), 0.1, 1.5);
        assert!((glass.transmission - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_disney_brdf_energy_conservation() {
        let mat = DisneyMaterial::default();
        let n = Vec3::new(0.0, 1.0, 0.0);
        let v = Vec3::new(0.0, 1.0, 0.0);
        let l = Vec3::new(0.0, 1.0, 0.0);
        let t = Vec3::new(1.0, 0.0, 0.0);

        let brdf = DisneyBRDF::evaluate(&mat, n, v, l, t);

        // BRDF should be positive
        assert!(brdf.x >= 0.0);
        assert!(brdf.y >= 0.0);
        assert!(brdf.z >= 0.0);
    }

    #[test]
    fn test_hair_brdf_colors() {
        let brown = HairBRDF::brown_hair();
        let blonde = HairBRDF::blonde_hair();
        let black = HairBRDF::black_hair();

        // Brown has more melanin than blonde
        assert!(brown.melanin > blonde.melanin);
        // Black has most melanin
        assert!(black.melanin > brown.melanin);
    }

    #[test]
    fn test_hair_absorption() {
        let brown = HairBRDF::brown_hair();
        let absorption = brown.compute_absorption();

        // Absorption should be positive
        assert!(absorption.x > 0.0);
        assert!(absorption.y > 0.0);
        assert!(absorption.z > 0.0);
    }

    #[test]
    fn test_cloth_presets() {
        let cotton = ClothBRDF::cotton(Vec3::splat(0.8));
        let velvet = ClothBRDF::velvet(Vec3::new(0.2, 0.0, 0.1));
        let silk = ClothBRDF::silk(Vec3::splat(0.9));

        // Velvet has more sheen
        assert!(velvet.sheen > cotton.sheen);
        // Silk has anisotropy
        assert!(silk.anisotropy > 0.0);
    }

    #[test]
    fn test_skin_presets() {
        let caucasian = SkinBRDF::caucasian();
        let asian = SkinBRDF::asian();
        let african = SkinBRDF::african();

        // Melanin increases from caucasian to african
        assert!(caucasian.melanin < asian.melanin);
        assert!(asian.melanin < african.melanin);
    }

    #[test]
    fn test_eye_colors() {
        let blue = EyeBRDF::blue_eye();
        let brown = EyeBRDF::brown_eye();

        // Blue eye has higher blue component
        assert!(blue.iris_color.z > blue.iris_color.x);
        // Brown eye has higher red component
        assert!(brown.iris_color.x > brown.iris_color.z);
    }

    #[test]
    fn test_multi_layer_material() {
        let car_paint = MultiLayerMaterial::car_paint(
            Vec3::new(0.8, 0.0, 0.0),
            Vec3::new(1.0, 1.0, 1.0),
            0.3,
        );

        // Should have 3 layers (base, flakes, clearcoat)
        assert_eq!(car_paint.layers.len(), 3);
    }

    #[test]
    fn test_iridescent_material() {
        let bubble = IridescentMaterial::soap_bubble();
        let oil = IridescentMaterial::oil_slick();

        // Both should have thin film effects
        assert!(bubble.film_thickness > 0.0);
        assert!(oil.film_thickness > 0.0);
    }

    #[test]
    fn test_iridescent_color_variation() {
        let bubble = IridescentMaterial::soap_bubble();

        // Color should change with viewing angle
        let color_normal = bubble.compute_iridescent_color(1.0, bubble.film_thickness);
        let color_grazing = bubble.compute_iridescent_color(0.3, bubble.film_thickness);

        // Colors should be different
        assert!((color_normal.x - color_grazing.x).abs() > 0.01 ||
                (color_normal.y - color_grazing.y).abs() > 0.01 ||
                (color_normal.z - color_grazing.z).abs() > 0.01);
    }

    #[test]
    fn test_material_library() {
        let gold = MaterialLibrary::gold();
        assert!((gold.metallic - 1.0).abs() < 1e-6);

        let plastic = MaterialLibrary::plastic(Vec3::splat(0.5));
        assert!((plastic.metallic - 0.0).abs() < 1e-6);

        let glass = MaterialLibrary::glass();
        assert!(glass.transmission > 0.9);
    }

    #[test]
    fn test_material_blending() {
        let a = MaterialLibrary::gold();
        let b = MaterialLibrary::silver();

        let blended = blend_materials(&a, &b, 0.5, BlendMode::Linear);

        // Blended color should be between gold and silver
        assert!(blended.base_color.x < a.base_color.x);
        assert!(blended.base_color.x > b.base_color.x);
    }

    #[test]
    fn test_pbr_texture_set() {
        let textures = PBRTextureSet::new();

        // All textures should be None by default
        assert!(textures.albedo.is_none());
        assert!(textures.normal.is_none());
        assert!(textures.roughness.is_none());
    }

    #[test]
    fn test_gpu_material_data() {
        let mat = MaterialLibrary::gold();
        let gpu_data = GpuMaterialData::from_disney(&mat, [-1; 8]);

        assert!((gpu_data.metallic_roughness_ao_alpha[0] - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_material_buffer() {
        let mut buffer = MaterialBuffer::new(100);

        let mat = MaterialLibrary::copper();
        let gpu_data = GpuMaterialData::from_disney(&mat, [-1; 8]);

        let index = buffer.add(gpu_data);
        assert_eq!(index, 0);

        let index2 = buffer.add(GpuMaterialData::from_disney(&MaterialLibrary::iron(), [-1; 8]));
        assert_eq!(index2, 1);
    }

    #[test]
    fn test_shader_generation() {
        let shader = generate_material_shader();

        // Shader should contain key functions
        assert!(shader.contains("evaluate_material"));
        assert!(shader.contains("MaterialInput"));
    }
}
