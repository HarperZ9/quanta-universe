// =============================================================================
// PHOTON ENGINE - ATMOSPHERIC SCATTERING SYSTEM
// =============================================================================
// Comprehensive physically-based atmospheric rendering with Rayleigh/Mie
// scattering, aerial perspective, sky rendering, and celestial bodies.
// Based on Harper Engine WP-009, WP-126-142 atmospheric rendering papers.
// =============================================================================

import core::memory::{Arena, Pool, Buffer, GpuBuffer};
import core::math::{Vec2, Vec3, Vec4, Mat4, Quaternion, Transform};
import core::simd::{f32x4, f32x8, SimdMath};
import photon::gpu::{ComputeShader, RenderPipeline, Texture, Sampler};
import photon::color::{Color, ColorSpace, Spectrum};

// =============================================================================
// REGION: PHYSICAL CONSTANTS
// =============================================================================

/// Physical constants for atmospheric scattering
module AtmosphereConstants {
    /// Earth radius in meters
    pub const EARTH_RADIUS: f64 = 6_371_000.0;

    /// Atmosphere thickness in meters
    pub const ATMOSPHERE_THICKNESS: f64 = 100_000.0;

    /// Rayleigh scale height in meters
    pub const RAYLEIGH_SCALE_HEIGHT: f64 = 8_500.0;

    /// Mie scale height in meters
    pub const MIE_SCALE_HEIGHT: f64 = 1_200.0;

    /// Ozone layer center altitude in meters
    pub const OZONE_CENTER_ALTITUDE: f64 = 25_000.0;

    /// Ozone layer width in meters
    pub const OZONE_WIDTH: f64 = 15_000.0;

    /// Rayleigh scattering coefficients at sea level (per meter)
    /// Wavelengths: R=680nm, G=550nm, B=440nm
    pub const RAYLEIGH_COEFFICIENTS: Vec3 = Vec3::new(
        5.802e-6,   // Red
        13.558e-6,  // Green
        33.1e-6     // Blue
    );

    /// Mie scattering coefficient at sea level (per meter)
    pub const MIE_COEFFICIENT: f64 = 21e-6;

    /// Mie absorption coefficient at sea level
    pub const MIE_ABSORPTION: f64 = 4.4e-6;

    /// Ozone absorption cross-section (per meter)
    pub const OZONE_ABSORPTION: Vec3 = Vec3::new(
        0.650e-6,   // Red
        1.881e-6,   // Green
        0.085e-6    // Blue
    );

    /// Mie asymmetry factor (Henyey-Greenstein g parameter)
    pub const MIE_ASYMMETRY: f64 = 0.8;

    /// Solar irradiance at top of atmosphere (W/m^2/nm)
    pub const SOLAR_IRRADIANCE: Vec3 = Vec3::new(1.474, 1.850, 1.911);

    /// Speed of light in vacuum (m/s)
    pub const SPEED_OF_LIGHT: f64 = 299_792_458.0;

    /// Planck constant (J·s)
    pub const PLANCK_CONSTANT: f64 = 6.62607015e-34;

    /// Boltzmann constant (J/K)
    pub const BOLTZMANN_CONSTANT: f64 = 1.380649e-23;
}

// =============================================================================
// REGION: ATMOSPHERE PARAMETERS
// =============================================================================

/// Atmosphere type presets
pub enum AtmospherePreset {
    /// Earth-like atmosphere
    Earth,
    /// Mars-like thin atmosphere
    Mars,
    /// Venus-like dense atmosphere
    Venus,
    /// Titan-like hazy atmosphere
    Titan,
    /// Alien world with custom colors
    Alien {
        primary_color: Color,
        secondary_color: Color,
        haze_density: f32,
    },
    /// Pure artistic sky (non-physical)
    Stylized {
        zenith_color: Color,
        horizon_color: Color,
        ground_color: Color,
    },
    /// Custom physical parameters
    Custom(AtmosphereParams),
}

/// Complete atmosphere parameters
pub struct AtmosphereParams {
    /// Planet radius in meters
    pub planet_radius: f64,

    /// Atmosphere thickness in meters
    pub atmosphere_height: f64,

    /// Rayleigh scattering coefficients
    pub rayleigh_coefficients: Vec3,

    /// Rayleigh scale height
    pub rayleigh_scale_height: f32,

    /// Mie scattering coefficient
    pub mie_coefficient: f32,

    /// Mie absorption coefficient
    pub mie_absorption: f32,

    /// Mie scale height
    pub mie_scale_height: f32,

    /// Mie asymmetry factor (g)
    pub mie_asymmetry: f32,

    /// Ozone absorption coefficients
    pub ozone_absorption: Vec3,

    /// Ozone layer center altitude
    pub ozone_center_altitude: f32,

    /// Ozone layer width
    pub ozone_width: f32,

    /// Ground albedo
    pub ground_albedo: Vec3,

    /// Enable multiple scattering
    pub enable_multiple_scattering: bool,

    /// Number of scattering orders
    pub scattering_orders: u32,
}

impl AtmosphereParams {
    /// Create Earth atmosphere parameters
    pub fn earth() -> Self {
        Self {
            planet_radius: AtmosphereConstants::EARTH_RADIUS,
            atmosphere_height: AtmosphereConstants::ATMOSPHERE_THICKNESS,
            rayleigh_coefficients: AtmosphereConstants::RAYLEIGH_COEFFICIENTS,
            rayleigh_scale_height: AtmosphereConstants::RAYLEIGH_SCALE_HEIGHT as f32,
            mie_coefficient: AtmosphereConstants::MIE_COEFFICIENT as f32,
            mie_absorption: AtmosphereConstants::MIE_ABSORPTION as f32,
            mie_scale_height: AtmosphereConstants::MIE_SCALE_HEIGHT as f32,
            mie_asymmetry: AtmosphereConstants::MIE_ASYMMETRY as f32,
            ozone_absorption: AtmosphereConstants::OZONE_ABSORPTION,
            ozone_center_altitude: AtmosphereConstants::OZONE_CENTER_ALTITUDE as f32,
            ozone_width: AtmosphereConstants::OZONE_WIDTH as f32,
            ground_albedo: Vec3::new(0.3, 0.3, 0.3),
            enable_multiple_scattering: true,
            scattering_orders: 4,
        }
    }

    /// Create Mars atmosphere parameters
    pub fn mars() -> Self {
        Self {
            planet_radius: 3_389_500.0,
            atmosphere_height: 200_000.0,
            rayleigh_coefficients: Vec3::new(19.918e-6, 13.57e-6, 5.75e-6), // Reddish
            rayleigh_scale_height: 11_100.0,
            mie_coefficient: 3e-5,  // More dust
            mie_absorption: 4.4e-6,
            mie_scale_height: 11_000.0,
            mie_asymmetry: 0.76,
            ozone_absorption: Vec3::zero(),  // No ozone on Mars
            ozone_center_altitude: 0.0,
            ozone_width: 0.0,
            ground_albedo: Vec3::new(0.5, 0.3, 0.2),
            enable_multiple_scattering: true,
            scattering_orders: 3,
        }
    }

    /// Create Venus atmosphere parameters
    pub fn venus() -> Self {
        Self {
            planet_radius: 6_051_800.0,
            atmosphere_height: 250_000.0,
            rayleigh_coefficients: Vec3::new(10e-6, 15e-6, 8e-6), // Yellow-orange
            rayleigh_scale_height: 15_900.0,
            mie_coefficient: 1e-4,  // Dense clouds
            mie_absorption: 1e-5,
            mie_scale_height: 6_000.0,
            mie_asymmetry: 0.85,
            ozone_absorption: Vec3::zero(),
            ozone_center_altitude: 0.0,
            ozone_width: 0.0,
            ground_albedo: Vec3::new(0.4, 0.35, 0.25),
            enable_multiple_scattering: true,
            scattering_orders: 5,
        }
    }

    /// Create Titan atmosphere parameters
    pub fn titan() -> Self {
        Self {
            planet_radius: 2_574_730.0,
            atmosphere_height: 600_000.0,
            rayleigh_coefficients: Vec3::new(2e-5, 1.5e-5, 1e-5), // Orange-brown
            rayleigh_scale_height: 21_000.0,
            mie_coefficient: 5e-4,  // Very hazy
            mie_absorption: 2e-5,
            mie_scale_height: 50_000.0,
            mie_asymmetry: 0.78,
            ozone_absorption: Vec3::zero(),
            ozone_center_altitude: 0.0,
            ozone_width: 0.0,
            ground_albedo: Vec3::new(0.3, 0.25, 0.15),
            enable_multiple_scattering: true,
            scattering_orders: 6,
        }
    }
}

// =============================================================================
// REGION: SCATTERING PHASE FUNCTIONS
// =============================================================================

/// Phase function types for scattering
pub enum PhaseFunction {
    /// Rayleigh phase function for molecular scattering
    Rayleigh,
    /// Henyey-Greenstein phase function for aerosols
    HenyeyGreenstein { g: f32 },
    /// Cornette-Shanks phase function (improved HG)
    CornetteShanks { g: f32 },
    /// Double Henyey-Greenstein for complex aerosols
    DoubleHenyeyGreenstein {
        g_forward: f32,
        g_backward: f32,
        weight: f32,
    },
    /// Mie phase function computed from particle size distribution
    Mie {
        particle_radius: f32,
        refractive_index: f32,
    },
    /// Schlick approximation (fast)
    Schlick { k: f32 },
    /// Draine phase function for dust
    Draine { g: f32, alpha: f32 },
}

impl PhaseFunction {
    /// Evaluate phase function for given cosine of scattering angle
    pub fn evaluate(&self, cos_theta: f32) -> f32 {
        match self {
            Self::Rayleigh => {
                // P(θ) = 3/(16π) * (1 + cos²θ)
                let inv_16pi = 0.0596831;
                3.0 * inv_16pi * (1.0 + cos_theta * cos_theta)
            }

            Self::HenyeyGreenstein { g } => {
                // P(θ) = (1 - g²) / (4π * (1 + g² - 2g*cos(θ))^1.5)
                let g2 = g * g;
                let denom = 1.0 + g2 - 2.0 * g * cos_theta;
                let inv_4pi = 0.07957747;
                inv_4pi * (1.0 - g2) / (denom * denom.sqrt())
            }

            Self::CornetteShanks { g } => {
                // Cornette-Shanks modification
                let g2 = g * g;
                let denom = 1.0 + g2 - 2.0 * g * cos_theta;
                let inv_8pi = 0.03978874;
                let num = 3.0 * (1.0 - g2) * (1.0 + cos_theta * cos_theta);
                let denom_full = 2.0 * (2.0 + g2) * denom * denom.sqrt();
                inv_8pi * num / denom_full
            }

            Self::DoubleHenyeyGreenstein { g_forward, g_backward, weight } => {
                let hg_forward = Self::HenyeyGreenstein { g: *g_forward }.evaluate(cos_theta);
                let hg_backward = Self::HenyeyGreenstein { g: *g_backward }.evaluate(cos_theta);
                weight * hg_forward + (1.0 - weight) * hg_backward
            }

            Self::Mie { particle_radius, refractive_index } => {
                // Simplified Mie phase function approximation
                Self::compute_mie_phase(cos_theta, *particle_radius, *refractive_index)
            }

            Self::Schlick { k } => {
                // Schlick approximation: faster than HG
                let inv_4pi = 0.07957747;
                let denom = 1.0 + k * cos_theta;
                inv_4pi * (1.0 - k * k) / (denom * denom)
            }

            Self::Draine { g, alpha } => {
                // Draine phase function for dust grains
                let hg = Self::HenyeyGreenstein { g: *g }.evaluate(cos_theta);
                let rayleigh = Self::Rayleigh.evaluate(cos_theta);
                alpha * hg + (1.0 - alpha) * rayleigh
            }
        }
    }

    /// Compute Mie phase function from particle parameters
    fn compute_mie_phase(cos_theta: f32, radius: f32, n: f32) -> f32 {
        // Size parameter
        let x = 2.0 * std::f32::consts::PI * radius / 0.55e-6; // At 550nm

        // Use HG approximation with computed g
        let g = Self::compute_mie_asymmetry(x, n);
        Self::HenyeyGreenstein { g }.evaluate(cos_theta)
    }

    /// Compute Mie asymmetry factor from size parameter
    fn compute_mie_asymmetry(x: f32, n: f32) -> f32 {
        // Empirical formula for g based on size parameter and refractive index
        let x_clamped = x.clamp(0.1, 50.0);
        let g = (x_clamped / (x_clamped + 4.0)) * (0.7 + 0.15 * (n - 1.33));
        g.clamp(-0.999, 0.999)
    }
}

// =============================================================================
// REGION: TRANSMITTANCE LUT
// =============================================================================

/// Transmittance lookup table generator
pub struct TransmittanceLUT {
    /// Texture resolution
    pub resolution: (u32, u32),

    /// GPU texture
    pub texture: Texture,

    /// Atmosphere parameters
    pub params: AtmosphereParams,

    /// Compute shader for generation
    compute_shader: ComputeShader,
}

impl TransmittanceLUT {
    /// Create new transmittance LUT
    pub fn new(params: &AtmosphereParams, resolution: (u32, u32)) -> Self {
        let texture = Texture::create_2d(
            resolution.0,
            resolution.1,
            TextureFormat::RGBA32Float,
            TextureUsage::Storage | TextureUsage::Sampled,
        );

        let compute_shader = ComputeShader::new(TRANSMITTANCE_LUT_SHADER);

        Self {
            resolution,
            texture,
            params: params.clone(),
            compute_shader,
        }
    }

    /// Generate the transmittance LUT
    pub fn generate(&mut self) {
        // Set up compute shader uniforms
        self.compute_shader.set_uniform("u_planet_radius", self.params.planet_radius as f32);
        self.compute_shader.set_uniform("u_atmosphere_height", self.params.atmosphere_height as f32);
        self.compute_shader.set_uniform("u_rayleigh_coefficients", self.params.rayleigh_coefficients);
        self.compute_shader.set_uniform("u_rayleigh_scale_height", self.params.rayleigh_scale_height);
        self.compute_shader.set_uniform("u_mie_coefficient", self.params.mie_coefficient);
        self.compute_shader.set_uniform("u_mie_absorption", self.params.mie_absorption);
        self.compute_shader.set_uniform("u_mie_scale_height", self.params.mie_scale_height);
        self.compute_shader.set_uniform("u_ozone_absorption", self.params.ozone_absorption);
        self.compute_shader.set_uniform("u_ozone_center_altitude", self.params.ozone_center_altitude);
        self.compute_shader.set_uniform("u_ozone_width", self.params.ozone_width);
        self.compute_shader.set_uniform("u_resolution", Vec2::new(
            self.resolution.0 as f32,
            self.resolution.1 as f32,
        ));

        self.compute_shader.set_storage_image(0, &self.texture);

        // Dispatch compute shader
        let group_size = 8;
        self.compute_shader.dispatch(
            (self.resolution.0 + group_size - 1) / group_size,
            (self.resolution.1 + group_size - 1) / group_size,
            1,
        );
    }

    /// Sample transmittance for given altitude and view-zenith cosine
    pub fn sample(&self, altitude: f32, mu: f32) -> Vec3 {
        // Map to UV coordinates
        let r = self.params.planet_radius as f32 + altitude;
        let r_min = self.params.planet_radius as f32;
        let r_max = r_min + self.params.atmosphere_height as f32;

        let rho = (r * r - r_min * r_min).sqrt();
        let h = (r_max * r_max - r_min * r_min).sqrt();

        let u = rho / h;

        // Map mu from [-1, 1] to [0, 1]
        let d_min = r_max - r;
        let d_max = rho + h;
        let d = -r * mu + (r * r * (mu * mu - 1.0) + r_max * r_max).sqrt();
        let v = (d - d_min) / (d_max - d_min);

        self.texture.sample_bilinear(u, v).xyz()
    }
}

const TRANSMITTANCE_LUT_SHADER: &str = r#"
    #version 460

    layout(local_size_x = 8, local_size_y = 8) in;

    layout(rgba32f, binding = 0) uniform image2D u_transmittance_lut;

    uniform float u_planet_radius;
    uniform float u_atmosphere_height;
    uniform vec3 u_rayleigh_coefficients;
    uniform float u_rayleigh_scale_height;
    uniform float u_mie_coefficient;
    uniform float u_mie_absorption;
    uniform float u_mie_scale_height;
    uniform vec3 u_ozone_absorption;
    uniform float u_ozone_center_altitude;
    uniform float u_ozone_width;
    uniform vec2 u_resolution;

    const int SAMPLE_COUNT = 256;

    float get_density_rayleigh(float h) {
        return exp(-h / u_rayleigh_scale_height);
    }

    float get_density_mie(float h) {
        return exp(-h / u_mie_scale_height);
    }

    float get_density_ozone(float h) {
        return max(0.0, 1.0 - abs(h - u_ozone_center_altitude) / u_ozone_width);
    }

    float ray_sphere_intersect(vec3 origin, vec3 dir, float radius) {
        float b = 2.0 * dot(origin, dir);
        float c = dot(origin, origin) - radius * radius;
        float d = b * b - 4.0 * c;
        if (d < 0.0) return -1.0;
        return (-b + sqrt(d)) * 0.5;
    }

    vec3 compute_transmittance(float r, float mu) {
        float r_top = u_planet_radius + u_atmosphere_height;

        // Distance to atmosphere boundary
        float discriminant = r * r * (mu * mu - 1.0) + r_top * r_top;
        if (discriminant < 0.0) return vec3(1.0);

        float d = -r * mu + sqrt(discriminant);

        // Integration step
        float dx = d / float(SAMPLE_COUNT);

        vec3 optical_depth = vec3(0.0);

        for (int i = 0; i < SAMPLE_COUNT; i++) {
            float t = (float(i) + 0.5) * dx;

            // Position along ray
            float height = sqrt(r * r + t * t + 2.0 * r * t * mu) - u_planet_radius;

            // Accumulate optical depth
            float density_rayleigh = get_density_rayleigh(height);
            float density_mie = get_density_mie(height);
            float density_ozone = get_density_ozone(height);

            optical_depth += u_rayleigh_coefficients * density_rayleigh * dx;
            optical_depth += vec3(u_mie_coefficient + u_mie_absorption) * density_mie * dx;
            optical_depth += u_ozone_absorption * density_ozone * dx;
        }

        return exp(-optical_depth);
    }

    void main() {
        ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
        if (pixel.x >= int(u_resolution.x) || pixel.y >= int(u_resolution.y)) return;

        // UV to atmosphere coordinates
        vec2 uv = (vec2(pixel) + 0.5) / u_resolution;

        float r_min = u_planet_radius;
        float r_max = u_planet_radius + u_atmosphere_height;
        float h = sqrt(r_max * r_max - r_min * r_min);

        float rho = h * uv.x;
        float r = sqrt(rho * rho + r_min * r_min);

        float d_min = r_max - r;
        float d_max = rho + h;
        float d = d_min + (d_max - d_min) * uv.y;

        float mu = (d == 0.0) ? 1.0 : (r_max * r_max - r * r - d * d) / (2.0 * r * d);
        mu = clamp(mu, -1.0, 1.0);

        vec3 transmittance = compute_transmittance(r, mu);

        imageStore(u_transmittance_lut, pixel, vec4(transmittance, 1.0));
    }
"#;

// =============================================================================
// REGION: SINGLE SCATTERING LUT
// =============================================================================

/// Single scattering lookup table
pub struct SingleScatteringLUT {
    /// Texture resolution (altitude, sun_zenith, view_zenith, azimuth)
    pub resolution: (u32, u32, u32, u32),

    /// Rayleigh scattering texture
    pub rayleigh_texture: Texture,

    /// Mie scattering texture
    pub mie_texture: Texture,

    /// Atmosphere parameters
    pub params: AtmosphereParams,

    /// Transmittance LUT reference
    transmittance_lut: *const TransmittanceLUT,

    /// Compute shader
    compute_shader: ComputeShader,
}

impl SingleScatteringLUT {
    /// Create single scattering LUT
    pub fn new(
        params: &AtmosphereParams,
        transmittance_lut: &TransmittanceLUT,
        resolution: (u32, u32, u32, u32),
    ) -> Self {
        // Use 3D textures with 4th dimension packed
        let rayleigh_texture = Texture::create_3d(
            resolution.0 * resolution.3,
            resolution.1,
            resolution.2,
            TextureFormat::RGBA16Float,
            TextureUsage::Storage | TextureUsage::Sampled,
        );

        let mie_texture = Texture::create_3d(
            resolution.0 * resolution.3,
            resolution.1,
            resolution.2,
            TextureFormat::RGBA16Float,
            TextureUsage::Storage | TextureUsage::Sampled,
        );

        let compute_shader = ComputeShader::new(SINGLE_SCATTERING_SHADER);

        Self {
            resolution,
            rayleigh_texture,
            mie_texture,
            params: params.clone(),
            transmittance_lut,
            compute_shader,
        }
    }

    /// Generate single scattering LUTs
    pub fn generate(&mut self) {
        self.compute_shader.set_uniform("u_planet_radius", self.params.planet_radius as f32);
        self.compute_shader.set_uniform("u_atmosphere_height", self.params.atmosphere_height as f32);
        self.compute_shader.set_uniform("u_rayleigh_coefficients", self.params.rayleigh_coefficients);
        self.compute_shader.set_uniform("u_rayleigh_scale_height", self.params.rayleigh_scale_height);
        self.compute_shader.set_uniform("u_mie_coefficient", self.params.mie_coefficient);
        self.compute_shader.set_uniform("u_mie_scale_height", self.params.mie_scale_height);
        self.compute_shader.set_uniform("u_resolution", Vec4::new(
            self.resolution.0 as f32,
            self.resolution.1 as f32,
            self.resolution.2 as f32,
            self.resolution.3 as f32,
        ));

        unsafe {
            self.compute_shader.set_texture(0, &(*self.transmittance_lut).texture);
        }
        self.compute_shader.set_storage_image(1, &self.rayleigh_texture);
        self.compute_shader.set_storage_image(2, &self.mie_texture);

        let group_size = 4;
        self.compute_shader.dispatch(
            (self.resolution.0 * self.resolution.3 + group_size - 1) / group_size,
            (self.resolution.1 + group_size - 1) / group_size,
            (self.resolution.2 + group_size - 1) / group_size,
        );
    }
}

const SINGLE_SCATTERING_SHADER: &str = r#"
    #version 460

    layout(local_size_x = 4, local_size_y = 4, local_size_z = 4) in;

    layout(binding = 0) uniform sampler2D u_transmittance_lut;
    layout(rgba16f, binding = 1) uniform image3D u_rayleigh_lut;
    layout(rgba16f, binding = 2) uniform image3D u_mie_lut;

    uniform float u_planet_radius;
    uniform float u_atmosphere_height;
    uniform vec3 u_rayleigh_coefficients;
    uniform float u_rayleigh_scale_height;
    uniform float u_mie_coefficient;
    uniform float u_mie_scale_height;
    uniform vec4 u_resolution;

    const int SAMPLE_COUNT = 64;
    const float PI = 3.14159265359;

    // Transmittance sampling helper
    vec3 sample_transmittance(float r, float mu) {
        float r_min = u_planet_radius;
        float r_max = u_planet_radius + u_atmosphere_height;
        float h = sqrt(r_max * r_max - r_min * r_min);
        float rho = sqrt(max(0.0, r * r - r_min * r_min));

        float u = rho / h;

        float d_min = r_max - r;
        float d_max = rho + h;
        float d = -r * mu + sqrt(max(0.0, r * r * (mu * mu - 1.0) + r_max * r_max));
        float v = (d - d_min) / (d_max - d_min);

        return texture(u_transmittance_lut, vec2(u, v)).rgb;
    }

    void compute_single_scattering(
        float r, float mu, float mu_s, float nu,
        out vec3 rayleigh, out vec3 mie
    ) {
        float r_top = u_planet_radius + u_atmosphere_height;

        // Ray-sphere intersection
        float discriminant = r * r * (mu * mu - 1.0) + r_top * r_top;
        if (discriminant < 0.0) {
            rayleigh = vec3(0.0);
            mie = vec3(0.0);
            return;
        }

        float d = -r * mu + sqrt(discriminant);
        float dx = d / float(SAMPLE_COUNT);

        rayleigh = vec3(0.0);
        mie = vec3(0.0);

        for (int i = 0; i < SAMPLE_COUNT; i++) {
            float t = (float(i) + 0.5) * dx;

            // Current position
            float r_i = sqrt(r * r + t * t + 2.0 * r * t * mu);
            float h_i = r_i - u_planet_radius;

            // Densities at current point
            float density_r = exp(-h_i / u_rayleigh_scale_height);
            float density_m = exp(-h_i / u_mie_scale_height);

            // Sun direction cosine at current point
            float mu_s_i = (r * mu_s + t * nu) / r_i;

            // Check if sun is below horizon
            if (mu_s_i < -sqrt(1.0 - (u_planet_radius * u_planet_radius) / (r_i * r_i))) {
                continue;
            }

            // Transmittances
            vec3 trans_view = sample_transmittance(r, mu);
            vec3 trans_point = sample_transmittance(r_i, mu);
            vec3 trans_sun = sample_transmittance(r_i, mu_s_i);

            vec3 trans_full = trans_sun * (trans_view / max(trans_point, vec3(1e-6)));

            rayleigh += u_rayleigh_coefficients * density_r * trans_full * dx;
            mie += vec3(u_mie_coefficient) * density_m * trans_full * dx;
        }
    }

    void main() {
        ivec3 pixel = ivec3(gl_GlobalInvocationID.xyz);

        int size_x = int(u_resolution.x * u_resolution.w);
        int size_y = int(u_resolution.y);
        int size_z = int(u_resolution.z);

        if (pixel.x >= size_x || pixel.y >= size_y || pixel.z >= size_z) return;

        // Unpack 4D coordinates
        int idx_altitude = pixel.x % int(u_resolution.x);
        int idx_azimuth = pixel.x / int(u_resolution.x);
        int idx_sun_zenith = pixel.y;
        int idx_view_zenith = pixel.z;

        // Map to physical parameters
        float u_r = (float(idx_altitude) + 0.5) / u_resolution.x;
        float u_mu_s = (float(idx_sun_zenith) + 0.5) / u_resolution.y;
        float u_mu = (float(idx_view_zenith) + 0.5) / u_resolution.z;
        float u_nu = (float(idx_azimuth) + 0.5) / u_resolution.w;

        float r_min = u_planet_radius;
        float r_max = u_planet_radius + u_atmosphere_height;

        // Altitude
        float h = sqrt(r_max * r_max - r_min * r_min);
        float rho = h * u_r;
        float r = sqrt(rho * rho + r_min * r_min);

        // View zenith cosine
        float mu = 2.0 * u_mu - 1.0;

        // Sun zenith cosine
        float mu_s = 2.0 * u_mu_s - 1.0;

        // Azimuth angle (between sun and view)
        float nu_angle = u_nu * 2.0 * PI;
        float sin_view = sqrt(1.0 - mu * mu);
        float sin_sun = sqrt(1.0 - mu_s * mu_s);
        float nu = mu * mu_s + sin_view * sin_sun * cos(nu_angle);

        vec3 rayleigh, mie;
        compute_single_scattering(r, mu, mu_s, nu, rayleigh, mie);

        imageStore(u_rayleigh_lut, pixel, vec4(rayleigh, 1.0));
        imageStore(u_mie_lut, pixel, vec4(mie, 1.0));
    }
"#;

