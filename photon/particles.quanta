/// Particle render vertex for billboard rendering
@repr(C, align(16))
pub struct ParticleRenderVertex {
    position: Vec3,
    size: Vec2,
    rotation: f32,
    color: Vec4,
    uv_offset_scale: Vec4,
    custom: Vec4,
}

/// Billboard type for particle rendering
pub enum BillboardMode {
    ViewAligned,        // Face camera
    VelocityAligned,    // Stretch along velocity
    AxisAligned(Vec3),  // Align to specific axis
    FreeRotation,       // Full 3D rotation
}

/// Sprite sheet configuration for animated particles
pub struct SpriteSheet {
    rows: u32,
    columns: u32,
    frame_count: u32,
    frame_rate: f32,
    start_frame: u32,
    animation_mode: AnimationMode,
}

pub enum AnimationMode {
    Linear,
    RandomStart,
    RandomFrame,
    PingPong,
    Lifetime,
}

/// Soft particles configuration for depth fading
pub struct SoftParticleConfig {
    enabled: bool,
    fade_distance: f32,
    contrast: f32,
}

/// Particle material
pub struct ParticleMaterial {
    base_texture: Option<TextureHandle>,
    normal_map: Option<TextureHandle>,
    emission_map: Option<TextureHandle>,
    base_color: Vec4,
    emission_color: Vec3,
    emission_intensity: f32,
    blend_mode: BlendMode,
    lighting_mode: LightingMode,
    sprite_sheet: Option<SpriteSheet>,
    soft_particles: SoftParticleConfig,
    distance_fade: Option<DistanceFade>,
    shadow_receive: bool,
    shadow_cast: bool,
}

pub enum BlendMode {
    Alpha,
    Additive,
    Multiply,
    Premultiplied,
    Subtractive,
}

pub enum LightingMode {
    Unlit,
    Lambert,
    Blinn,
    PBR,
}

pub struct DistanceFade {
    start_distance: f32,
    end_distance: f32,
    mode: FadeMode,
}

pub enum FadeMode {
    Linear,
    Quadratic,
    Exponential,
}

/// Main particle renderer
pub struct ParticleRenderer {
    // Pipelines
    billboard_pipeline: Pipeline,
    mesh_pipeline: Pipeline,
    trail_pipeline: Pipeline,

    // Shaders
    vertex_shader: Shader,
    fragment_shader: Shader,

    // Buffers
    vertex_buffer: Buffer<ParticleRenderVertex>,
    index_buffer: Buffer<u32>,
    instance_buffer: Buffer<ParticleInstanceData>,

    // Default resources
    default_texture: Texture,
    default_normal: Texture,
    quad_mesh: MeshHandle,

    // Stats
    particles_rendered: u32,
    draw_calls: u32,
}

@repr(C, align(16))
pub struct ParticleInstanceData {
    world_matrix: Mat4,
    color: Vec4,
    uv_offset_scale: Vec4,
    custom: Vec4,
}

impl ParticleRenderer {
    pub fn new(context: &RenderContext, max_particles: u32) -> Self {
        let vertex_shader = context.load_shader("particle.vert");
        let fragment_shader = context.load_shader("particle.frag");

        let billboard_pipeline = context.create_pipeline(PipelineDesc {
            vertex_shader: &vertex_shader,
            fragment_shader: &fragment_shader,
            blend_state: BlendState::alpha_blend(),
            depth_state: DepthState::read_only(),
            cull_mode: CullMode::None,
            ..Default::default()
        });

        let mesh_pipeline = context.create_pipeline(PipelineDesc {
            vertex_shader: context.load_shader("particle_mesh.vert"),
            fragment_shader: &fragment_shader,
            blend_state: BlendState::alpha_blend(),
            depth_state: DepthState::read_only(),
            cull_mode: CullMode::Back,
            ..Default::default()
        });

        let trail_pipeline = context.create_pipeline(PipelineDesc {
            vertex_shader: context.load_shader("particle_trail.vert"),
            fragment_shader: context.load_shader("particle_trail.frag"),
            blend_state: BlendState::alpha_blend(),
            depth_state: DepthState::read_only(),
            cull_mode: CullMode::None,
            ..Default::default()
        });

        Self {
            billboard_pipeline,
            mesh_pipeline,
            trail_pipeline,
            vertex_shader,
            fragment_shader,
            vertex_buffer: context.create_buffer::<ParticleRenderVertex>(max_particles as usize * 4),
            index_buffer: context.create_buffer::<u32>(max_particles as usize * 6),
            instance_buffer: context.create_buffer::<ParticleInstanceData>(max_particles as usize),
            default_texture: context.create_white_texture(),
            default_normal: context.create_default_normal_texture(),
            quad_mesh: context.create_quad_mesh(),
            particles_rendered: 0,
            draw_calls: 0,
        }
    }

    pub fn render(&mut self, context: &RenderContext,
                  particle_pool: &ParticlePool,
                  material: &ParticleMaterial,
                  camera: &Camera) {
        self.particles_rendered = 0;
        self.draw_calls = 0;

        // Set pipeline based on material blend mode
        let pipeline = match material.blend_mode {
            BlendMode::Alpha => &self.billboard_pipeline,
            BlendMode::Additive => &self.billboard_pipeline,  // Different blend state
            _ => &self.billboard_pipeline,
        };

        context.bind_pipeline(pipeline);

        // Bind textures
        context.bind_texture(0, material.base_texture.as_ref()
            .map(|t| context.get_texture(t))
            .unwrap_or(&self.default_texture));

        if let Some(sprite_sheet) = &material.sprite_sheet {
            // Set sprite sheet uniforms
            context.set_uniform("u_sprite_rows", sprite_sheet.rows as f32);
            context.set_uniform("u_sprite_cols", sprite_sheet.columns as f32);
        }

        // Draw particles using indirect draw
        context.draw_indirect(particle_pool.get_draw_args());

        self.draw_calls += 1;
    }

    pub fn render_trails(&mut self, context: &RenderContext,
                         trail_renderer: &TrailRenderer,
                         material: &ParticleMaterial,
                         camera: &Camera) {
        let (vertices, indices) = trail_renderer.build_mesh(camera.position);

        if vertices.is_empty() {
            return;
        }

        context.bind_pipeline(&self.trail_pipeline);
        context.update_buffer(&self.vertex_buffer, &vertices);
        context.update_buffer(&self.index_buffer, &indices);

        context.draw_indexed(indices.len() as u32, 0, 0);
        self.draw_calls += 1;
    }
}

// =============================================================================
// REGION: VFX Graph (WP-111)
// =============================================================================

/// Node types in the VFX graph
pub enum VFXNodeType {
    // Context nodes
    SpawnContext { rate: f32, burst: Option<BurstConfig> },
    UpdateContext,
    OutputContext { output_type: VFXOutputType },

    // Attribute nodes
    GetAttribute { attribute: ParticleAttribute },
    SetAttribute { attribute: ParticleAttribute },

    // Math nodes
    Add, Subtract, Multiply, Divide,
    Lerp, Clamp, Remap,
    Sin, Cos, Tan,
    Sqrt, Pow, Abs,
    Min, Max,
    Dot, Cross, Normalize, Length,

    // Vector nodes
    Compose { component_count: u32 },
    Decompose { component_count: u32 },
    Transform { space: TransformSpace },

    // Random nodes
    Random { mode: RandomMode },
    PerlinNoise { octaves: u32 },
    SimplexNoise { octaves: u32 },
    CurlNoise { octaves: u32 },

    // Sampling nodes
    SampleTexture { texture: TextureHandle },
    SampleCurve { curve: CurveOverLifetime<f32> },
    SampleGradient { gradient: Gradient },

    // Logic nodes
    Compare { op: CompareOp },
    Branch,

    // Force nodes
    AddForce,
    SetVelocity,
    ConformToSphere,
    ConformToSDF,

    // Kill nodes
    Kill,
    KillByAge,
    KillByBounds,
}

pub struct BurstConfig {
    count: u32,
    cycles: i32,
    interval: f32,
    probability: f32,
}

pub enum VFXOutputType {
    Particle,
    Mesh,
    DecalProjector,
    PointLight,
    SpotLight,
}

pub enum TransformSpace {
    Local,
    World,
    Camera,
    Simulation,
}

pub enum RandomMode {
    PerParticle,
    PerComponent,
    Constant,
    AnimatedUniform,
    AnimatedPerParticle,
}

pub enum CompareOp {
    Equal,
    NotEqual,
    Less,
    LessEqual,
    Greater,
    GreaterEqual,
}

/// VFX Graph node
pub struct VFXNode {
    id: u64,
    node_type: VFXNodeType,
    position: Vec2,
    inputs: Vec<VFXSlot>,
    outputs: Vec<VFXSlot>,
    properties: HashMap<String, VFXProperty>,
}

pub struct VFXSlot {
    name: String,
    slot_type: VFXSlotType,
    connected_to: Option<(u64, u32)>,  // (node_id, slot_index)
}

pub enum VFXSlotType {
    Float,
    Vec2,
    Vec3,
    Vec4,
    Int,
    Bool,
    Texture,
    Curve,
    Gradient,
    Any,
}

pub enum VFXProperty {
    Float(f32),
    Vec2(Vec2),
    Vec3(Vec3),
    Vec4(Vec4),
    Int(i32),
    Bool(bool),
    Texture(TextureHandle),
    Curve(CurveOverLifetime<f32>),
    Gradient(Gradient),
}

/// VFX Graph system
pub struct VFXGraph {
    nodes: HashMap<u64, VFXNode>,
    connections: Vec<VFXConnection>,
    spawn_context: Option<u64>,
    update_context: Option<u64>,
    output_context: Option<u64>,

    // Compiled graph
    compiled: Option<CompiledVFXGraph>,

    // Runtime
    next_node_id: u64,
}

pub struct VFXConnection {
    from_node: u64,
    from_slot: u32,
    to_node: u64,
    to_slot: u32,
}

/// Compiled VFX graph for efficient execution
pub struct CompiledVFXGraph {
    spawn_ops: Vec<VFXOp>,
    update_ops: Vec<VFXOp>,
    output_ops: Vec<VFXOp>,

    // GPU compute shader code
    spawn_shader: ComputeShader,
    update_shader: ComputeShader,

    // Constant buffer
    constants: Buffer<Vec4>,
}

/// Low-level VFX operation
pub enum VFXOp {
    LoadConstant { dst: u32, value: Vec4 },
    LoadAttribute { dst: u32, attribute: ParticleAttribute },
    StoreAttribute { src: u32, attribute: ParticleAttribute },
    Add { dst: u32, a: u32, b: u32 },
    Mul { dst: u32, a: u32, b: u32 },
    Lerp { dst: u32, a: u32, b: u32, t: u32 },
    Noise { dst: u32, pos: u32, octaves: u32 },
    SampleTexture { dst: u32, tex: u32, uv: u32 },
    SampleCurve { dst: u32, curve: u32, t: u32 },
    Compare { dst: u32, a: u32, b: u32, op: CompareOp },
    Branch { condition: u32, true_ops: Vec<VFXOp>, false_ops: Vec<VFXOp> },
    Kill,
}

impl VFXGraph {
    pub fn new() -> Self {
        Self {
            nodes: HashMap::new(),
            connections: Vec::new(),
            spawn_context: None,
            update_context: None,
            output_context: None,
            compiled: None,
            next_node_id: 1,
        }
    }

    pub fn add_node(&mut self, node_type: VFXNodeType) -> u64 {
        let id = self.next_node_id;
        self.next_node_id += 1;

        let node = VFXNode {
            id,
            node_type,
            position: Vec2::ZERO,
            inputs: Vec::new(),
            outputs: Vec::new(),
            properties: HashMap::new(),
        };

        self.nodes.insert(id, node);
        id
    }

    pub fn connect(&mut self, from_node: u64, from_slot: u32, to_node: u64, to_slot: u32) {
        self.connections.push(VFXConnection {
            from_node,
            from_slot,
            to_node,
            to_slot,
        });

        // Mark graph as needing recompilation
        self.compiled = None;
    }

    pub fn compile(&mut self, context: &RenderContext) -> Result<(), String> {
        // Topological sort of nodes
        let spawn_nodes = self.collect_context_nodes(self.spawn_context)?;
        let update_nodes = self.collect_context_nodes(self.update_context)?;
        let output_nodes = self.collect_context_nodes(self.output_context)?;

        // Generate operations
        let spawn_ops = self.generate_ops(&spawn_nodes)?;
        let update_ops = self.generate_ops(&update_nodes)?;
        let output_ops = self.generate_ops(&output_nodes)?;

        // Generate compute shaders
        let spawn_code = self.generate_shader_code(&spawn_ops, "spawn");
        let update_code = self.generate_shader_code(&update_ops, "update");

        let spawn_shader = context.compile_compute_shader(&spawn_code)?;
        let update_shader = context.compile_compute_shader(&update_code)?;

        self.compiled = Some(CompiledVFXGraph {
            spawn_ops,
            update_ops,
            output_ops,
            spawn_shader,
            update_shader,
            constants: context.create_buffer::<Vec4>(256),
        });

        Ok(())
    }

    fn collect_context_nodes(&self, context_id: Option<u64>) -> Result<Vec<u64>, String> {
        let context_id = context_id.ok_or("Context node not found")?;

        let mut nodes = Vec::new();
        let mut visited = HashSet::new();
        self.collect_nodes_recursive(context_id, &mut nodes, &mut visited);

        Ok(nodes)
    }

    fn collect_nodes_recursive(&self, node_id: u64, nodes: &mut Vec<u64>, visited: &mut HashSet<u64>) {
        if visited.contains(&node_id) {
            return;
        }
        visited.insert(node_id);

        // First collect dependencies
        for conn in &self.connections {
            if conn.to_node == node_id {
                self.collect_nodes_recursive(conn.from_node, nodes, visited);
            }
        }

        nodes.push(node_id);
    }

    fn generate_ops(&self, nodes: &[u64]) -> Result<Vec<VFXOp>, String> {
        let mut ops = Vec::new();

        for &node_id in nodes {
            let node = self.nodes.get(&node_id).ok_or("Node not found")?;

            match &node.node_type {
                VFXNodeType::GetAttribute { attribute } => {
                    ops.push(VFXOp::LoadAttribute {
                        dst: node_id as u32,
                        attribute: *attribute,
                    });
                }
                VFXNodeType::SetAttribute { attribute } => {
                    let src = self.get_input_register(node_id, 0)?;
                    ops.push(VFXOp::StoreAttribute {
                        src,
                        attribute: *attribute,
                    });
                }
                VFXNodeType::Add => {
                    let a = self.get_input_register(node_id, 0)?;
                    let b = self.get_input_register(node_id, 1)?;
                    ops.push(VFXOp::Add {
                        dst: node_id as u32,
                        a,
                        b,
                    });
                }
                VFXNodeType::Multiply => {
                    let a = self.get_input_register(node_id, 0)?;
                    let b = self.get_input_register(node_id, 1)?;
                    ops.push(VFXOp::Mul {
                        dst: node_id as u32,
                        a,
                        b,
                    });
                }
                VFXNodeType::Kill => {
                    ops.push(VFXOp::Kill);
                }
                _ => {}
            }
        }

        Ok(ops)
    }

    fn get_input_register(&self, node_id: u64, slot: u32) -> Result<u32, String> {
        for conn in &self.connections {
            if conn.to_node == node_id && conn.to_slot == slot {
                return Ok(conn.from_node as u32);
            }
        }
        Err(format!("Input slot {} not connected on node {}", slot, node_id))
    }

    fn generate_shader_code(&self, ops: &[VFXOp], context: &str) -> String {
        let mut code = String::new();
        code.push_str("#version 450\n\n");
        code.push_str("layout(local_size_x = 64) in;\n\n");

        // Generate code for each operation
        for op in ops {
            match op {
                VFXOp::LoadAttribute { dst, attribute } => {
                    let attr_name = attribute_name(*attribute);
                    code.push_str(&format!("    vec4 r{} = particles[id].{};\n", dst, attr_name));
                }
                VFXOp::StoreAttribute { src, attribute } => {
                    let attr_name = attribute_name(*attribute);
                    code.push_str(&format!("    particles[id].{} = r{};\n", attr_name, src));
                }
                VFXOp::Add { dst, a, b } => {
                    code.push_str(&format!("    vec4 r{} = r{} + r{};\n", dst, a, b));
                }
                VFXOp::Mul { dst, a, b } => {
                    code.push_str(&format!("    vec4 r{} = r{} * r{};\n", dst, a, b));
                }
                VFXOp::Kill => {
                    code.push_str("    particles[id].state = 0u; // Dead\n");
                }
                _ => {}
            }
        }

        code
    }
}

fn attribute_name(attr: ParticleAttribute) -> &'static str {
    match attr {
        ParticleAttribute::Position => "position",
        ParticleAttribute::Velocity => "velocity",
        ParticleAttribute::Acceleration => "acceleration",
        ParticleAttribute::Color => "color",
        ParticleAttribute::Size => "size",
        ParticleAttribute::Rotation => "rotation",
        ParticleAttribute::AngularVelocity => "angular_velocity",
        ParticleAttribute::Age => "age",
        ParticleAttribute::Lifetime => "lifetime",
        ParticleAttribute::Mass => "mass",
        _ => "custom",
    }
}

