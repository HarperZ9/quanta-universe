// =============================================================================
// REGION: Particle Events (WP-114)
// =============================================================================

/// Particle event types
pub enum ParticleEvent {
    Spawn { particle_id: u32 },
    Death { particle_id: u32, position: Vec3, velocity: Vec3 },
    Collision { particle_id: u32, position: Vec3, normal: Vec3 },
    Trigger { particle_id: u32, trigger_id: u32 },
    Lifetime { particle_id: u32, threshold: f32 },
    Custom { particle_id: u32, event_id: u32, data: Vec4 },
}

/// Event listener callback
pub type ParticleEventCallback = fn(event: &ParticleEvent, emitter: &mut ParticleEmitter);

/// Particle event system
pub struct ParticleEventSystem {
    events: Vec<ParticleEvent>,
    listeners: HashMap<u32, Vec<ParticleEventCallback>>,

    // GPU event buffer for compute-generated events
    gpu_event_buffer: Buffer<GPUParticleEvent>,
    event_count_buffer: Buffer<u32>,
    max_events: u32,
}

@repr(C)
pub struct GPUParticleEvent {
    event_type: u32,
    particle_id: u32,
    position: Vec3,
    velocity: Vec3,
    normal: Vec3,
    data: Vec4,
}

impl ParticleEventSystem {
    pub fn new(context: &RenderContext, max_events: u32) -> Self {
        Self {
            events: Vec::new(),
            listeners: HashMap::new(),
            gpu_event_buffer: context.create_buffer::<GPUParticleEvent>(max_events as usize),
            event_count_buffer: context.create_buffer::<u32>(1),
            max_events,
        }
    }

    pub fn register_listener(&mut self, event_type: u32, callback: ParticleEventCallback) {
        self.listeners.entry(event_type).or_default().push(callback);
    }

    pub fn push_event(&mut self, event: ParticleEvent) {
        self.events.push(event);
    }

    pub fn dispatch_events(&mut self, emitter: &mut ParticleEmitter) {
        for event in &self.events {
            let event_type = match event {
                ParticleEvent::Spawn { .. } => 0,
                ParticleEvent::Death { .. } => 1,
                ParticleEvent::Collision { .. } => 2,
                ParticleEvent::Trigger { .. } => 3,
                ParticleEvent::Lifetime { .. } => 4,
                ParticleEvent::Custom { .. } => 5,
            };

            if let Some(listeners) = self.listeners.get(&event_type) {
                for callback in listeners {
                    callback(event, emitter);
                }
            }
        }

        self.events.clear();
    }

    pub fn read_gpu_events(&mut self, context: &RenderContext) {
        let count = context.read_buffer::<u32>(&self.event_count_buffer)[0];
        let gpu_events = context.read_buffer::<GPUParticleEvent>(&self.gpu_event_buffer);

        for i in 0..count.min(self.max_events) as usize {
            let gpu_event = &gpu_events[i];

            let event = match gpu_event.event_type {
                0 => ParticleEvent::Spawn { particle_id: gpu_event.particle_id },
                1 => ParticleEvent::Death {
                    particle_id: gpu_event.particle_id,
                    position: gpu_event.position,
                    velocity: gpu_event.velocity,
                },
                2 => ParticleEvent::Collision {
                    particle_id: gpu_event.particle_id,
                    position: gpu_event.position,
                    normal: gpu_event.normal,
                },
                _ => continue,
            };

            self.events.push(event);
        }

        // Reset GPU event count
        context.update_buffer(&self.event_count_buffer, &[0u32]);
    }
}

// =============================================================================
// REGION: Particle System Manager (WP-115)
// =============================================================================

/// Complete particle system instance
pub struct ParticleSystem {
    id: u64,
    name: String,
    transform: Transform,

    // Components
    emitters: Vec<ParticleEmitter>,
    particle_pool: ParticlePool,
    gpu_simulator: GPUParticleSimulator,
    trail_renderer: Option<TrailRenderer>,
    beam_renderers: Vec<BeamRenderer>,

    // Configuration
    lod_manager: ParticleLODManager,
    force_field_system: ForceFieldSystem,
    collision_system: ParticleCollisionSystem,
    event_system: ParticleEventSystem,

    // State
    is_playing: bool,
    is_paused: bool,
    time: f32,
    playback_speed: f32,

    // Bounds
    bounds: AABB,
    bounds_mode: BoundsMode,
}

pub enum BoundsMode {
    Automatic,
    Static { bounds: AABB },
    Custom { callback: fn(&ParticlePool) -> AABB },
}

/// Particle system manager
pub struct ParticleSystemManager {
    systems: HashMap<u64, ParticleSystem>,
    next_system_id: u64,

    // Rendering
    renderer: ParticleRenderer,

    // Global settings
    global_time_scale: f32,
    max_particles_global: u32,
    current_particles: u32,

    // LOD
    global_lod_bias: f32,

    // Culling
    culler: ParticleCuller,

    // Sorting
    sorted_systems: Vec<(u64, f32)>,  // (system_id, distance)
}

impl ParticleSystemManager {
    pub fn new(context: &RenderContext) -> Self {
        Self {
            systems: HashMap::new(),
            next_system_id: 1,
            renderer: ParticleRenderer::new(context, 1_000_000),
            global_time_scale: 1.0,
            max_particles_global: 1_000_000,
            current_particles: 0,
            global_lod_bias: 1.0,
            culler: ParticleCuller::new(context),
            sorted_systems: Vec::new(),
        }
    }

    pub fn create_system(&mut self, context: &RenderContext, name: &str, max_particles: u32) -> u64 {
        let id = self.next_system_id;
        self.next_system_id += 1;

        let system = ParticleSystem {
            id,
            name: name.to_string(),
            transform: Transform::identity(),
            emitters: Vec::new(),
            particle_pool: ParticlePool::new(context, max_particles),
            gpu_simulator: GPUParticleSimulator::new(context, max_particles),
            trail_renderer: None,
            beam_renderers: Vec::new(),
            lod_manager: ParticleLODManager::new(),
            force_field_system: ForceFieldSystem::new(context, 64),
            collision_system: ParticleCollisionSystem::new(context),
            event_system: ParticleEventSystem::new(context, 1024),
            is_playing: false,
            is_paused: false,
            time: 0.0,
            playback_speed: 1.0,
            bounds: AABB::default(),
            bounds_mode: BoundsMode::Automatic,
        };

        self.systems.insert(id, system);
        id
    }

    pub fn update(&mut self, context: &RenderContext, dt: f32, camera: &Camera) {
        let dt = dt * self.global_time_scale;

        // Update frustum culler
        self.culler.update_frustum(camera.view_projection());

        // Sort systems by distance for proper blending
        self.sorted_systems.clear();
        for (id, system) in &self.systems {
            let distance = (system.transform.position - camera.position).length();
            self.sorted_systems.push((*id, distance));
        }
        self.sorted_systems.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());

        // Update each system
        self.current_particles = 0;

        for (id, _) in &self.sorted_systems {
            let system = self.systems.get_mut(id).unwrap();

            if !system.is_playing || system.is_paused {
                continue;
            }

            // Check visibility
            if !self.culler.is_visible(system.bounds) {
                continue;
            }

            // Calculate LOD
            let distance = (system.transform.position - camera.position).length();
            let (lod_level, lod_blend) = system.lod_manager.calculate_lod(
                distance,
                1.0  // Screen size placeholder
            );

            let lod = system.lod_manager.get_lod(lod_level).unwrap();

            // Apply LOD simulation rate
            let should_simulate = match lod.simulation_rate {
                SimulationRate::Full => true,
                SimulationRate::HalfRate => (system.time * 2.0) as u32 % 2 == 0,
                SimulationRate::QuarterRate => (system.time * 4.0) as u32 % 4 == 0,
                SimulationRate::Skip => false,
            };

            if should_simulate {
                let system_dt = dt * system.playback_speed;
                system.time += system_dt;

                // Update force fields
                system.force_field_system.update_gpu_buffer(context);

                // Emit particles from each emitter
                for emitter in &mut system.emitters {
                    let emit_rate = match &emitter.emission_mode {
                        EmissionMode::Continuous { rate } => *rate * lod.emission_rate_mult,
                        _ => 0.0,
                    };

                    emitter.emission_accumulator += emit_rate * system_dt;
                    let emit_count = emitter.emission_accumulator as u32;
                    emitter.emission_accumulator -= emit_count as f32;

                    if emit_count > 0 {
                        system.gpu_simulator.emit(context, emitter, emit_count, system.time);
                    }
                }

                // Simulate particles
                let sim_params = SimulationParams {
                    delta_time: system_dt,
                    time: system.time,
                    gravity: Vec3::new(0.0, -9.81, 0.0),
                    drag: 0.1,
                    force_field_count: system.force_field_system.force_fields.len() as u32,
                    collision_mode: 0,
                    view_matrix: camera.view_matrix(),
                    proj_matrix: camera.projection_matrix(),
                    inv_view_proj: camera.view_projection().inverse(),
                    camera_position: camera.position,
                    bounds_min: Vec3::splat(-1000.0),
                    bounds_max: Vec3::splat(1000.0),
                    kill_on_bounds: 1,
                };

                system.gpu_simulator.simulate(context, sim_params);

                // Update trails
                if let Some(trail_renderer) = &mut system.trail_renderer {
                    // Update trail vertices based on particle positions
                    // ...
                }

                // Read and dispatch events
                system.event_system.read_gpu_events(context);
                for emitter in &mut system.emitters {
                    system.event_system.dispatch_events(emitter);
                }
            }

            self.current_particles += system.particle_pool.alive_count;
        }
    }

    pub fn render(&mut self, context: &RenderContext, camera: &Camera) {
        // Render in sorted order (back to front for transparency)
        for (id, _) in &self.sorted_systems {
            let system = self.systems.get(id).unwrap();

            if !system.is_playing {
                continue;
            }

            // Skip invisible systems
            if !self.culler.is_visible(system.bounds) {
                continue;
            }

            // Render based on LOD render mode
            let distance = (system.transform.position - camera.position).length();
            let (lod_level, _) = system.lod_manager.calculate_lod(distance, 1.0);

            if let Some(lod) = system.lod_manager.get_lod(lod_level) {
                match lod.render_mode {
                    LODRenderMode::Disabled => continue,
                    _ => {}
                }
            }

            // Get material from first emitter
            let material = if !system.emitters.is_empty() {
                ParticleMaterial::default()  // Placeholder
            } else {
                ParticleMaterial::default()
            };

            // Render particles
            self.renderer.render(context, &system.particle_pool, &material, camera);

            // Render trails
            if let Some(trail_renderer) = &system.trail_renderer {
                self.renderer.render_trails(context, trail_renderer, &material, camera);
            }
        }
    }

    pub fn play(&mut self, system_id: u64) {
        if let Some(system) = self.systems.get_mut(&system_id) {
            system.is_playing = true;
            system.is_paused = false;
        }
    }

    pub fn pause(&mut self, system_id: u64) {
        if let Some(system) = self.systems.get_mut(&system_id) {
            system.is_paused = true;
        }
    }

    pub fn stop(&mut self, system_id: u64) {
        if let Some(system) = self.systems.get_mut(&system_id) {
            system.is_playing = false;
            system.is_paused = false;
            system.time = 0.0;
            // Reset particle pool
        }
    }

    pub fn destroy(&mut self, system_id: u64) {
        self.systems.remove(&system_id);
    }
}

impl Default for ParticleMaterial {
    fn default() -> Self {
        Self {
            base_texture: None,
            normal_map: None,
            emission_map: None,
            base_color: Vec4::ONE,
            emission_color: Vec3::ZERO,
            emission_intensity: 0.0,
            blend_mode: BlendMode::Alpha,
            lighting_mode: LightingMode::Unlit,
            sprite_sheet: None,
            soft_particles: SoftParticleConfig {
                enabled: true,
                fade_distance: 0.1,
                contrast: 1.0,
            },
            distance_fade: None,
            shadow_receive: false,
            shadow_cast: false,
        }
    }
}

// =============================================================================
// REGION: Tests
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_particle_pool_creation() {
        let context = RenderContext::mock();
        let pool = ParticlePool::new(&context, 1000);

        assert_eq!(pool.capacity, 1000);
        assert_eq!(pool.alive_count, 0);
    }

    #[test]
    fn test_emitter_shape_sampling() {
        let emitter = ParticleEmitter::new();
        let mut rng = StdRng::seed_from_u64(12345);

        for _ in 0..100 {
            let (pos, normal) = emitter.sample_emission_position(&mut rng);
            assert!(pos.length() < 1000.0);
            assert!((normal.length() - 1.0).abs() < 0.001);
        }
    }

    #[test]
    fn test_force_field_gravity() {
        let field = ForceField {
            transform: Transform::identity(),
            field_type: ForceFieldType::Gravity {
                direction: Vec3::new(0.0, -1.0, 0.0),
                strength: 9.81,
            },
            shape: ForceFieldShape::Infinite,
            enabled: true,
            priority: 0,
        };

        let force = field.calculate_force(Vec3::ZERO, Vec3::ZERO);
        assert!((force.y + 9.81).abs() < 0.001);
    }

    #[test]
    fn test_gradient_evaluation() {
        let gradient = Gradient {
            color_keys: vec![
                GradientColorKey { time: 0.0, color: Vec3::ZERO },
                GradientColorKey { time: 1.0, color: Vec3::ONE },
            ],
            alpha_keys: vec![
                GradientAlphaKey { time: 0.0, alpha: 0.0 },
                GradientAlphaKey { time: 1.0, alpha: 1.0 },
            ],
            blend_mode: GradientBlendMode::Linear,
        };

        let mid = gradient.evaluate(0.5);
        assert!((mid.x - 0.5).abs() < 0.1);
        assert!((mid.w - 0.5).abs() < 0.1);
    }

    #[test]
    fn test_trail_renderer() {
        let context = RenderContext::mock();
        let config = TrailConfig {
            max_points: 100,
            min_vertex_distance: 0.1,
            width_over_trail: CurveOverLifetime::constant(0.5),
            color_over_trail: Gradient::white(),
            texture_mode: TrailTextureMode::Stretch,
            alignment: TrailAlignment::View,
            lifetime: 1.0,
            inherit_color: true,
            emit_from_velocity: false,
        };

        let mut trail_renderer = TrailRenderer::new(&context, config, 100);
        trail_renderer.add_trail(0, Vec3::ZERO, Vec4::ONE);
        trail_renderer.update_trail(0, Vec3::new(1.0, 0.0, 0.0), Vec3::X, Vec4::ONE, 0.016);

        let (vertices, indices) = trail_renderer.build_mesh(Vec3::new(0.0, 0.0, 10.0));
        assert!(!vertices.is_empty());
    }

    #[test]
    fn test_beam_types() {
        let mut beam = Beam {
            start: Vec3::ZERO,
            end: Vec3::new(10.0, 0.0, 0.0),
            config: BeamConfig {
                beam_type: BeamType::Lightning {
                    segments: 10,
                    amplitude: 0.5,
                    frequency: 2.0,
                },
                width: 0.1,
                width_curve: CurveOverLifetime::constant(1.0),
                color_gradient: Gradient::white(),
                texture_scale: 1.0,
                noise_frequency: 1.0,
                noise_amplitude: 0.0,
                segments_per_unit: 1.0,
            },
            time: 0.0,
            vertices: Vec::new(),
        };

        beam.rebuild_vertices();
        assert!(beam.vertices.len() > 2);
    }

    #[test]
    fn test_particle_lod() {
        let lod_manager = ParticleLODManager::new();

        let (level, _) = lod_manager.calculate_lod(10.0, 1.0);
        assert_eq!(level, 0);

        let (level, _) = lod_manager.calculate_lod(75.0, 1.0);
        assert_eq!(level, 2);

        let (level, _) = lod_manager.calculate_lod(300.0, 1.0);
        assert_eq!(level, 3);
    }

    #[test]
    fn test_frustum_culling() {
        let context = RenderContext::mock();
        let culler = ParticleCuller::new(&context);

        let bounds = AABB {
            min: Vec3::new(-1.0, -1.0, -1.0),
            max: Vec3::new(1.0, 1.0, 1.0),
        };

        // With default frustum, center box should be visible
        assert!(culler.is_visible(bounds));
    }

    #[test]
    fn test_vfx_graph_creation() {
        let mut graph = VFXGraph::new();

        let spawn = graph.add_node(VFXNodeType::SpawnContext { rate: 10.0, burst: None });
        let get_pos = graph.add_node(VFXNodeType::GetAttribute { attribute: ParticleAttribute::Position });
        let set_vel = graph.add_node(VFXNodeType::SetAttribute { attribute: ParticleAttribute::Velocity });

        graph.connect(get_pos, 0, set_vel, 0);

        assert_eq!(graph.nodes.len(), 3);
        assert_eq!(graph.connections.len(), 1);
    }
}

impl<T: Copy + Default> CurveOverLifetime<T> {
    pub fn constant(value: T) -> Self {
        Self {
            curve_type: CurveType::Constant,
            keys: vec![CurveKey {
                time: 0.0,
                value,
                in_tangent: T::default(),
                out_tangent: T::default(),
            }],
            loop_mode: LoopMode::Clamp,
        }
    }
}
