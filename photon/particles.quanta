/// LOD level for particle systems
pub struct ParticleLOD {
    level: u32,
    distance: f32,
    emission_rate_mult: f32,
    max_particles_mult: f32,
    simulation_rate: SimulationRate,
    render_mode: LODRenderMode,
}

pub enum SimulationRate {
    Full,
    HalfRate,
    QuarterRate,
    Skip,
}

pub enum LODRenderMode {
    Full,
    Billboard,
    Impostor { atlas: TextureHandle },
    Disabled,
}

/// Particle LOD manager
pub struct ParticleLODManager {
    lod_levels: Vec<ParticleLOD>,
    screen_size_bias: f32,
    distance_scale: f32,
    fade_transition: f32,
}

impl ParticleLODManager {
    pub fn new() -> Self {
        Self {
            lod_levels: vec![
                ParticleLOD {
                    level: 0,
                    distance: 0.0,
                    emission_rate_mult: 1.0,
                    max_particles_mult: 1.0,
                    simulation_rate: SimulationRate::Full,
                    render_mode: LODRenderMode::Full,
                },
                ParticleLOD {
                    level: 1,
                    distance: 50.0,
                    emission_rate_mult: 0.75,
                    max_particles_mult: 0.75,
                    simulation_rate: SimulationRate::Full,
                    render_mode: LODRenderMode::Full,
                },
                ParticleLOD {
                    level: 2,
                    distance: 100.0,
                    emission_rate_mult: 0.5,
                    max_particles_mult: 0.5,
                    simulation_rate: SimulationRate::HalfRate,
                    render_mode: LODRenderMode::Billboard,
                },
                ParticleLOD {
                    level: 3,
                    distance: 200.0,
                    emission_rate_mult: 0.25,
                    max_particles_mult: 0.25,
                    simulation_rate: SimulationRate::QuarterRate,
                    render_mode: LODRenderMode::Billboard,
                },
            ],
            screen_size_bias: 1.0,
            distance_scale: 1.0,
            fade_transition: 10.0,
        }
    }

    pub fn calculate_lod(&self, distance: f32, screen_size: f32) -> (u32, f32) {
        let adjusted_distance = distance * self.distance_scale / (screen_size * self.screen_size_bias).max(0.01);

        let mut selected_level = self.lod_levels.len() - 1;
        let mut blend = 0.0;

        for (i, lod) in self.lod_levels.iter().enumerate() {
            if adjusted_distance < lod.distance {
                if i > 0 {
                    let prev_dist = self.lod_levels[i - 1].distance;
                    blend = ((adjusted_distance - prev_dist) / self.fade_transition).clamp(0.0, 1.0);
                }
                selected_level = i;
                break;
            }
        }

        (selected_level as u32, blend)
    }

    pub fn get_lod(&self, level: u32) -> Option<&ParticleLOD> {
        self.lod_levels.get(level as usize)
    }
}

/// Particle frustum culler
pub struct ParticleCuller {
    frustum_planes: [Vec4; 6],
    occlusion_buffer: Option<Buffer<u32>>,
    cull_shader: ComputeShader,
}

impl ParticleCuller {
    pub fn new(context: &RenderContext) -> Self {
        Self {
            frustum_planes: [Vec4::ZERO; 6],
            occlusion_buffer: None,
            cull_shader: context.load_compute_shader("particle_cull.comp"),
        }
    }

    pub fn update_frustum(&mut self, view_proj: Mat4) {
        // Extract frustum planes from view-projection matrix
        let m = view_proj;

        // Left plane
        self.frustum_planes[0] = Vec4::new(
            m.x.w + m.x.x,
            m.y.w + m.y.x,
            m.z.w + m.z.x,
            m.w.w + m.w.x,
        ).normalize();

        // Right plane
        self.frustum_planes[1] = Vec4::new(
            m.x.w - m.x.x,
            m.y.w - m.y.x,
            m.z.w - m.z.x,
            m.w.w - m.w.x,
        ).normalize();

        // Bottom plane
        self.frustum_planes[2] = Vec4::new(
            m.x.w + m.x.y,
            m.y.w + m.y.y,
            m.z.w + m.z.y,
            m.w.w + m.w.y,
        ).normalize();

        // Top plane
        self.frustum_planes[3] = Vec4::new(
            m.x.w - m.x.y,
            m.y.w - m.y.y,
            m.z.w - m.z.y,
            m.w.w - m.w.y,
        ).normalize();

        // Near plane
        self.frustum_planes[4] = Vec4::new(
            m.x.z,
            m.y.z,
            m.z.z,
            m.w.z,
        ).normalize();

        // Far plane
        self.frustum_planes[5] = Vec4::new(
            m.x.w - m.x.z,
            m.y.w - m.y.z,
            m.z.w - m.z.z,
            m.w.w - m.w.z,
        ).normalize();
    }

    pub fn cull_particles(&self, context: &RenderContext, particles: &ParticlePool) {
        // Set frustum planes
        context.set_uniform_array("u_frustum_planes", &self.frustum_planes);

        // Dispatch cull shader
        let groups = (particles.capacity + 255) / 256;
        context.dispatch_compute(&self.cull_shader, groups, 1, 1);
    }

    pub fn is_visible(&self, bounds: AABB) -> bool {
        for plane in &self.frustum_planes {
            let n = Vec3::new(plane.x, plane.y, plane.z);
            let d = plane.w;

            // Get positive vertex (furthest along normal)
            let p = Vec3::new(
                if n.x >= 0.0 { bounds.max.x } else { bounds.min.x },
                if n.y >= 0.0 { bounds.max.y } else { bounds.min.y },
                if n.z >= 0.0 { bounds.max.z } else { bounds.min.z },
            );

            if n.dot(p) + d < 0.0 {
                return false;
            }
        }
        true
    }
}

