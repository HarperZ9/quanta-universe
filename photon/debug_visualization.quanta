/// Render statistics
pub struct RenderStats {
    /// Frame time in milliseconds
    pub frame_time_ms: f64,
    /// Frames per second
    pub fps: f64,
    /// Draw calls
    pub draw_calls: u32,
    /// Triangles rendered
    pub triangles: u64,
    /// Vertices processed
    pub vertices: u64,
    /// Instances drawn
    pub instances: u32,
    /// Compute dispatches
    pub compute_dispatches: u32,
    /// Textures bound
    pub texture_bindings: u32,
    /// Buffer bindings
    pub buffer_bindings: u32,
    /// Render targets used
    pub render_targets: u32,
    /// GPU memory used (MB)
    pub gpu_memory_mb: f32,
    /// CPU frame time (ms)
    pub cpu_time_ms: f64,
    /// GPU frame time (ms)
    pub gpu_time_ms: f64,
    /// Culled objects
    pub culled_objects: u32,
    /// Visible objects
    pub visible_objects: u32,
    /// Shadow casters
    pub shadow_casters: u32,
    /// Active lights
    pub active_lights: u32,
    /// Particles active
    pub particles: u32,
}

impl Default for RenderStats {
    fn default() -> Self {
        Self {
            frame_time_ms: 16.67,
            fps: 60.0,
            draw_calls: 0,
            triangles: 0,
            vertices: 0,
            instances: 0,
            compute_dispatches: 0,
            texture_bindings: 0,
            buffer_bindings: 0,
            render_targets: 0,
            gpu_memory_mb: 0.0,
            cpu_time_ms: 0.0,
            gpu_time_ms: 0.0,
            culled_objects: 0,
            visible_objects: 0,
            shadow_casters: 0,
            active_lights: 0,
            particles: 0,
        }
    }
}

impl RenderStats {
    /// Reset all counters
    pub fn reset(&mut self) {
        self.draw_calls = 0;
        self.triangles = 0;
        self.vertices = 0;
        self.instances = 0;
        self.compute_dispatches = 0;
        self.texture_bindings = 0;
        self.buffer_bindings = 0;
        self.render_targets = 0;
        self.culled_objects = 0;
        self.visible_objects = 0;
        self.shadow_casters = 0;
        self.active_lights = 0;
        self.particles = 0;
    }
}

/// Statistics overlay renderer
pub struct StatsOverlay {
    /// Current stats
    stats: RenderStats,
    /// Frame time history for graph
    frame_time_history: RingBuffer<f64>,
    /// GPU profiler
    profiler: GpuProfiler,
    /// Text renderer
    text_renderer: DebugTextRenderer,
    /// Overlay visibility
    visible: bool,
    /// Overlay position
    position: Vec2,
    /// Show frame time graph
    show_graph: bool,
    /// Show GPU profiler
    show_profiler: bool,
    /// Show detailed stats
    show_details: bool,
    /// Graph texture
    graph_texture: Texture,
    /// Graph compute shader
    graph_compute: ComputeShader,
}

impl StatsOverlay {
    /// Create new stats overlay
    pub fn new() -> Self {
        Self {
            stats: RenderStats::default(),
            frame_time_history: RingBuffer::new(256),
            profiler: GpuProfiler::new(256, 8),
            text_renderer: DebugTextRenderer::new(4096),
            visible: true,
            position: Vec2::new(0.01, 0.01),
            show_graph: true,
            show_profiler: true,
            show_details: false,
            graph_texture: Texture::new_2d(256, 64, TextureFormat::Rgba8Unorm),
            graph_compute: ComputeShader::from_source(STATS_GRAPH_SHADER),
        }
    }

    /// Toggle visibility
    pub fn toggle_visibility(&mut self) {
        self.visible = !self.visible;
    }

    /// Toggle graph display
    pub fn toggle_graph(&mut self) {
        self.show_graph = !self.show_graph;
    }

    /// Toggle profiler display
    pub fn toggle_profiler(&mut self) {
        self.show_profiler = !self.show_profiler;
    }

    /// Toggle detailed stats
    pub fn toggle_details(&mut self) {
        self.show_details = !self.show_details;
    }

    /// Get mutable stats for updating
    pub fn stats_mut(&mut self) -> &mut RenderStats {
        &mut self.stats
    }

    /// Get profiler for zone timing
    pub fn profiler_mut(&mut self) -> &mut GpuProfiler {
        &mut self.profiler
    }

    /// Update stats and history
    pub fn update(&mut self, delta_time: f32) {
        // Update FPS calculation
        self.stats.frame_time_ms = delta_time as f64 * 1000.0;
        self.stats.fps = 1.0 / delta_time as f64;

        // Add to history
        self.frame_time_history.push(self.stats.frame_time_ms);
    }

    /// Render the overlay
    pub fn render(&mut self, screen_width: f32, screen_height: f32) {
        if !self.visible {
            return;
        }

        let x = self.position.x;
        let mut y = self.position.y;
        let line_height = 0.02;

        // FPS and frame time
        let fps_color = if self.stats.fps >= 55.0 {
            Color::GREEN
        } else if self.stats.fps >= 30.0 {
            Color::YELLOW
        } else {
            Color::RED
        };

        self.text_renderer.print(
            format!("FPS: {:.1} ({:.2}ms)", self.stats.fps, self.stats.frame_time_ms),
            x, y, fps_color
        );
        y += line_height;

        // Draw calls and triangles
        self.text_renderer.print(
            format!("Draw Calls: {} | Tris: {:.2}M",
                self.stats.draw_calls,
                self.stats.triangles as f64 / 1_000_000.0),
            x, y, Color::WHITE
        );
        y += line_height;

        if self.show_details {
            // Detailed stats
            self.text_renderer.print(
                format!("Vertices: {} | Instances: {}",
                    self.stats.vertices, self.stats.instances),
                x, y, Color::GRAY
            );
            y += line_height;

            self.text_renderer.print(
                format!("Visible: {} | Culled: {}",
                    self.stats.visible_objects, self.stats.culled_objects),
                x, y, Color::GRAY
            );
            y += line_height;

            self.text_renderer.print(
                format!("Lights: {} | Shadows: {}",
                    self.stats.active_lights, self.stats.shadow_casters),
                x, y, Color::GRAY
            );
            y += line_height;

            self.text_renderer.print(
                format!("GPU Memory: {:.1} MB", self.stats.gpu_memory_mb),
                x, y, Color::GRAY
            );
            y += line_height;
        }

        // GPU profiler results
        if self.show_profiler {
            y += line_height * 0.5;
            self.text_renderer.print("GPU Profiler:", x, y, Color::CYAN);
            y += line_height;

            for result in self.profiler.results() {
                let indent = "  ".repeat(result.depth as usize);
                let bar_width = (result.percentage / 100.0 * 20.0) as usize;
                let bar = "█".repeat(bar_width) + &"░".repeat(20 - bar_width);

                self.text_renderer.print(
                    format!("{}{}: {:.2}ms ({:.1}%) {}",
                        indent, result.name, result.gpu_time_ms, result.percentage, bar),
                    x, y, Color::WHITE
                );
                y += line_height;
            }
        }

        // Render graph
        if self.show_graph {
            self.update_graph();
            // Graph would be rendered as a textured quad
        }

        self.text_renderer.render(screen_width, screen_height);
    }

    fn update_graph(&self) {
        // Update frame time graph texture using compute shader
        // ...
    }
}

