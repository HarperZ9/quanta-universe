// =============================================================================
// PHOTON ENGINE - DEBUG VISUALIZATION SYSTEM
// =============================================================================
// Comprehensive debugging and visualization tools for rendering development.
// Includes wireframe, normals, bounds, heatmaps, GPU profiling, and overlays.
// Based on Harper Engine WP-168-185 debug visualization papers.
// =============================================================================

import core::memory::{Arena, Pool, Buffer, GpuBuffer, RingBuffer};
import core::math::{Vec2, Vec3, Vec4, Mat4, Quaternion, Transform, Aabb, Sphere, Frustum};
import core::simd::{f32x4, f32x8, SimdMath};
import photon::gpu::{ComputeShader, RenderPipeline, Texture, Sampler, BindGroup};
import photon::color::{Color, ColorSpace, Palette};

// =============================================================================
// REGION: DEBUG RENDER MODES
// =============================================================================

/// Debug visualization render modes
pub enum DebugRenderMode {
    /// Normal rendering (no debug)
    None,
    /// Wireframe overlay
    Wireframe,
    /// Wireframe only (no fill)
    WireframeOnly,
    /// Vertex normals
    Normals,
    /// Vertex tangents
    Tangents,
    /// Vertex bitangents
    Bitangents,
    /// UV coordinates (checkerboard)
    UvChecker,
    /// UV coordinates (gradient)
    UvGradient,
    /// Mipmap levels
    MipmapLevels,
    /// Texture density
    TextureDensity,
    /// Overdraw visualization
    Overdraw,
    /// Draw call heatmap
    DrawCallHeatmap,
    /// Triangle density
    TriangleDensity,
    /// Shader complexity
    ShaderComplexity,
    /// Depth buffer
    DepthBuffer,
    /// Stencil buffer
    StencilBuffer,
    /// Light count per pixel
    LightCount,
    /// Cascade splits (shadows)
    CascadeSplits,
    /// Motion vectors
    MotionVectors,
    /// Ambient occlusion
    AmbientOcclusion,
    /// Albedo only
    AlbedoOnly,
    /// Normal buffer (G-buffer)
    NormalBuffer,
    /// Roughness only
    RoughnessOnly,
    /// Metallic only
    MetallicOnly,
    /// Emissive only
    EmissiveOnly,
    /// Diffuse lighting only
    DiffuseOnly,
    /// Specular lighting only
    SpecularOnly,
    /// Indirect lighting only
    IndirectOnly,
    /// Shadow maps
    ShadowMaps,
    /// Reflection probes
    ReflectionProbes,
    /// Cluster visualization
    ClusterVisualization,
    /// LOD levels
    LodLevels,
    /// Nanite triangles
    NaniteTriangles,
    /// Virtual texture pages
    VirtualTexturePages,
    /// Bone weights
    BoneWeights,
    /// Vertex colors
    VertexColors,
}

impl DebugRenderMode {
    /// Get display name for UI
    pub fn display_name(&self) -> &'static str {
        match self {
            DebugRenderMode::None => "None",
            DebugRenderMode::Wireframe => "Wireframe Overlay",
            DebugRenderMode::WireframeOnly => "Wireframe Only",
            DebugRenderMode::Normals => "Vertex Normals",
            DebugRenderMode::Tangents => "Vertex Tangents",
            DebugRenderMode::Bitangents => "Vertex Bitangents",
            DebugRenderMode::UvChecker => "UV Checker",
            DebugRenderMode::UvGradient => "UV Gradient",
            DebugRenderMode::MipmapLevels => "Mipmap Levels",
            DebugRenderMode::TextureDensity => "Texture Density",
            DebugRenderMode::Overdraw => "Overdraw",
            DebugRenderMode::DrawCallHeatmap => "Draw Call Heatmap",
            DebugRenderMode::TriangleDensity => "Triangle Density",
            DebugRenderMode::ShaderComplexity => "Shader Complexity",
            DebugRenderMode::DepthBuffer => "Depth Buffer",
            DebugRenderMode::StencilBuffer => "Stencil Buffer",
            DebugRenderMode::LightCount => "Light Count",
            DebugRenderMode::CascadeSplits => "Cascade Splits",
            DebugRenderMode::MotionVectors => "Motion Vectors",
            DebugRenderMode::AmbientOcclusion => "Ambient Occlusion",
            DebugRenderMode::AlbedoOnly => "Albedo Only",
            DebugRenderMode::NormalBuffer => "Normal Buffer",
            DebugRenderMode::RoughnessOnly => "Roughness Only",
            DebugRenderMode::MetallicOnly => "Metallic Only",
            DebugRenderMode::EmissiveOnly => "Emissive Only",
            DebugRenderMode::DiffuseOnly => "Diffuse Only",
            DebugRenderMode::SpecularOnly => "Specular Only",
            DebugRenderMode::IndirectOnly => "Indirect Only",
            DebugRenderMode::ShadowMaps => "Shadow Maps",
            DebugRenderMode::ReflectionProbes => "Reflection Probes",
            DebugRenderMode::ClusterVisualization => "Cluster Viz",
            DebugRenderMode::LodLevels => "LOD Levels",
            DebugRenderMode::NaniteTriangles => "Nanite Triangles",
            DebugRenderMode::VirtualTexturePages => "VT Pages",
            DebugRenderMode::BoneWeights => "Bone Weights",
            DebugRenderMode::VertexColors => "Vertex Colors",
        }
    }

    /// Get keyboard shortcut
    pub fn shortcut(&self) -> Option<char> {
        match self {
            DebugRenderMode::Wireframe => Some('1'),
            DebugRenderMode::Normals => Some('2'),
            DebugRenderMode::UvChecker => Some('3'),
            DebugRenderMode::Overdraw => Some('4'),
            DebugRenderMode::DepthBuffer => Some('5'),
            DebugRenderMode::LightCount => Some('6'),
            DebugRenderMode::AlbedoOnly => Some('7'),
            DebugRenderMode::NormalBuffer => Some('8'),
            DebugRenderMode::LodLevels => Some('9'),
            _ => None,
        }
    }
}

// =============================================================================
// REGION: DEBUG LINE RENDERER
// =============================================================================

/// Debug line vertex
#[repr(C)]
pub struct DebugLineVertex {
    /// Position
    pub position: Vec3,
    /// Color
    pub color: Color,
}

/// Debug line segment
pub struct DebugLine {
    /// Start position
    pub start: Vec3,
    /// End position
    pub end: Vec3,
    /// Line color
    pub color: Color,
    /// Line thickness (in pixels)
    pub thickness: f32,
    /// Duration in seconds (0 = single frame)
    pub duration: f32,
    /// Depth test enabled
    pub depth_test: bool,
}

impl DebugLine {
    /// Create new debug line
    pub fn new(start: Vec3, end: Vec3, color: Color) -> Self {
        Self {
            start,
            end,
            color,
            thickness: 1.0,
            duration: 0.0,
            depth_test: true,
        }
    }

    /// Create line with duration
    pub fn with_duration(mut self, duration: f32) -> Self {
        self.duration = duration;
        self
    }

    /// Create line with thickness
    pub fn with_thickness(mut self, thickness: f32) -> Self {
        self.thickness = thickness;
        self
    }

    /// Create line without depth test
    pub fn no_depth_test(mut self) -> Self {
        self.depth_test = false;
        self
    }
}

/// Debug line batch for efficient rendering
pub struct DebugLineBatch {
    /// Lines to render
    lines: Vec<DebugLine>,
    /// Persistent lines with remaining duration
    persistent_lines: Vec<(DebugLine, f32)>,
    /// Vertex buffer
    vertex_buffer: GpuBuffer,
    /// Maximum vertices
    max_vertices: u32,
    /// Current vertex count
    vertex_count: u32,
    /// Render pipeline for depth tested lines
    pipeline_depth: RenderPipeline,
    /// Render pipeline for no depth test
    pipeline_no_depth: RenderPipeline,
}

impl DebugLineBatch {
    /// Create new debug line batch
    pub fn new(max_lines: u32) -> Self {
        let max_vertices = max_lines * 2;

        Self {
            lines: Vec::with_capacity(max_lines as usize),
            persistent_lines: Vec::new(),
            vertex_buffer: GpuBuffer::new_vertex(
                max_vertices as usize * std::mem::size_of::<DebugLineVertex>()
            ),
            max_vertices,
            vertex_count: 0,
            pipeline_depth: RenderPipeline::from_source(DEBUG_LINE_SHADER),
            pipeline_no_depth: RenderPipeline::from_source_no_depth(DEBUG_LINE_SHADER),
        }
    }

    /// Add a debug line
    pub fn add_line(&mut self, line: DebugLine) {
        if line.duration > 0.0 {
            self.persistent_lines.push((line, line.duration));
        } else {
            self.lines.push(line);
        }
    }

    /// Draw a ray from origin in direction
    pub fn draw_ray(&mut self, origin: Vec3, direction: Vec3, length: f32, color: Color) {
        self.add_line(DebugLine::new(origin, origin + direction * length, color));
    }

    /// Draw an axis-aligned bounding box
    pub fn draw_aabb(&mut self, aabb: &Aabb, color: Color) {
        let min = aabb.min;
        let max = aabb.max;

        // Bottom face
        self.add_line(DebugLine::new(Vec3::new(min.x, min.y, min.z), Vec3::new(max.x, min.y, min.z), color));
        self.add_line(DebugLine::new(Vec3::new(max.x, min.y, min.z), Vec3::new(max.x, min.y, max.z), color));
        self.add_line(DebugLine::new(Vec3::new(max.x, min.y, max.z), Vec3::new(min.x, min.y, max.z), color));
        self.add_line(DebugLine::new(Vec3::new(min.x, min.y, max.z), Vec3::new(min.x, min.y, min.z), color));

        // Top face
        self.add_line(DebugLine::new(Vec3::new(min.x, max.y, min.z), Vec3::new(max.x, max.y, min.z), color));
        self.add_line(DebugLine::new(Vec3::new(max.x, max.y, min.z), Vec3::new(max.x, max.y, max.z), color));
        self.add_line(DebugLine::new(Vec3::new(max.x, max.y, max.z), Vec3::new(min.x, max.y, max.z), color));
        self.add_line(DebugLine::new(Vec3::new(min.x, max.y, max.z), Vec3::new(min.x, max.y, min.z), color));

        // Vertical edges
        self.add_line(DebugLine::new(Vec3::new(min.x, min.y, min.z), Vec3::new(min.x, max.y, min.z), color));
        self.add_line(DebugLine::new(Vec3::new(max.x, min.y, min.z), Vec3::new(max.x, max.y, min.z), color));
        self.add_line(DebugLine::new(Vec3::new(max.x, min.y, max.z), Vec3::new(max.x, max.y, max.z), color));
        self.add_line(DebugLine::new(Vec3::new(min.x, min.y, max.z), Vec3::new(min.x, max.y, max.z), color));
    }

    /// Draw oriented bounding box
    pub fn draw_obb(&mut self, center: Vec3, half_extents: Vec3, rotation: Quaternion, color: Color) {
        let corners = [
            Vec3::new(-half_extents.x, -half_extents.y, -half_extents.z),
            Vec3::new( half_extents.x, -half_extents.y, -half_extents.z),
            Vec3::new( half_extents.x, -half_extents.y,  half_extents.z),
            Vec3::new(-half_extents.x, -half_extents.y,  half_extents.z),
            Vec3::new(-half_extents.x,  half_extents.y, -half_extents.z),
            Vec3::new( half_extents.x,  half_extents.y, -half_extents.z),
            Vec3::new( half_extents.x,  half_extents.y,  half_extents.z),
            Vec3::new(-half_extents.x,  half_extents.y,  half_extents.z),
        ];

        let transformed: Vec<Vec3> = corners.iter()
            .map(|c| center + rotation.rotate(*c))
            .collect();

        // Bottom face
        for i in 0..4 {
            self.add_line(DebugLine::new(transformed[i], transformed[(i + 1) % 4], color));
        }

        // Top face
        for i in 0..4 {
            self.add_line(DebugLine::new(transformed[i + 4], transformed[(i + 1) % 4 + 4], color));
        }

        // Vertical edges
        for i in 0..4 {
            self.add_line(DebugLine::new(transformed[i], transformed[i + 4], color));
        }
    }

    /// Draw a sphere using circles
    pub fn draw_sphere(&mut self, center: Vec3, radius: f32, color: Color, segments: u32) {
        self.draw_circle(center, radius, Vec3::new(1.0, 0.0, 0.0), color, segments);
        self.draw_circle(center, radius, Vec3::new(0.0, 1.0, 0.0), color, segments);
        self.draw_circle(center, radius, Vec3::new(0.0, 0.0, 1.0), color, segments);
    }

    /// Draw a circle
    pub fn draw_circle(&mut self, center: Vec3, radius: f32, normal: Vec3, color: Color, segments: u32) {
        let tangent = if normal.x.abs() < 0.9 {
            Vec3::new(1.0, 0.0, 0.0).cross(normal).normalize()
        } else {
            Vec3::new(0.0, 1.0, 0.0).cross(normal).normalize()
        };
        let bitangent = normal.cross(tangent);

        let step = 2.0 * std::f32::consts::PI / segments as f32;
        let mut prev = center + tangent * radius;

        for i in 1..=segments {
            let angle = step * i as f32;
            let curr = center + (tangent * angle.cos() + bitangent * angle.sin()) * radius;
            self.add_line(DebugLine::new(prev, curr, color));
            prev = curr;
        }
    }

    /// Draw a cone
    pub fn draw_cone(&mut self, apex: Vec3, direction: Vec3, length: f32, angle: f32, color: Color, segments: u32) {
        let base_center = apex + direction * length;
        let base_radius = length * angle.tan();

        // Draw base circle
        self.draw_circle(base_center, base_radius, direction, color, segments);

        // Draw lines from apex to base
        let tangent = if direction.x.abs() < 0.9 {
            Vec3::new(1.0, 0.0, 0.0).cross(direction).normalize()
        } else {
            Vec3::new(0.0, 1.0, 0.0).cross(direction).normalize()
        };
        let bitangent = direction.cross(tangent);

        let line_count = segments.min(8);
        let step = 2.0 * std::f32::consts::PI / line_count as f32;

        for i in 0..line_count {
            let angle = step * i as f32;
            let base_point = base_center + (tangent * angle.cos() + bitangent * angle.sin()) * base_radius;
            self.add_line(DebugLine::new(apex, base_point, color));
        }
    }

    /// Draw a frustum
    pub fn draw_frustum(&mut self, frustum: &Frustum, color: Color) {
        let corners = frustum.corners();

        // Near plane
        self.add_line(DebugLine::new(corners[0], corners[1], color));
        self.add_line(DebugLine::new(corners[1], corners[2], color));
        self.add_line(DebugLine::new(corners[2], corners[3], color));
        self.add_line(DebugLine::new(corners[3], corners[0], color));

        // Far plane
        self.add_line(DebugLine::new(corners[4], corners[5], color));
        self.add_line(DebugLine::new(corners[5], corners[6], color));
        self.add_line(DebugLine::new(corners[6], corners[7], color));
        self.add_line(DebugLine::new(corners[7], corners[4], color));

        // Connecting edges
        self.add_line(DebugLine::new(corners[0], corners[4], color));
        self.add_line(DebugLine::new(corners[1], corners[5], color));
        self.add_line(DebugLine::new(corners[2], corners[6], color));
        self.add_line(DebugLine::new(corners[3], corners[7], color));
    }

    /// Draw coordinate axes
    pub fn draw_axes(&mut self, origin: Vec3, size: f32) {
        self.add_line(DebugLine::new(origin, origin + Vec3::new(size, 0.0, 0.0), Color::RED));
        self.add_line(DebugLine::new(origin, origin + Vec3::new(0.0, size, 0.0), Color::GREEN));
        self.add_line(DebugLine::new(origin, origin + Vec3::new(0.0, 0.0, size), Color::BLUE));
    }

    /// Draw transform gizmo
    pub fn draw_transform(&mut self, transform: &Transform, size: f32) {
        let origin = transform.position;
        let x_axis = transform.rotation.rotate(Vec3::new(1.0, 0.0, 0.0)) * size;
        let y_axis = transform.rotation.rotate(Vec3::new(0.0, 1.0, 0.0)) * size;
        let z_axis = transform.rotation.rotate(Vec3::new(0.0, 0.0, 1.0)) * size;

        self.add_line(DebugLine::new(origin, origin + x_axis, Color::RED).with_thickness(2.0));
        self.add_line(DebugLine::new(origin, origin + y_axis, Color::GREEN).with_thickness(2.0));
        self.add_line(DebugLine::new(origin, origin + z_axis, Color::BLUE).with_thickness(2.0));
    }

    /// Draw a grid
    pub fn draw_grid(&mut self, center: Vec3, size: f32, divisions: u32, color: Color) {
        let half_size = size * 0.5;
        let step = size / divisions as f32;

        for i in 0..=divisions {
            let offset = -half_size + i as f32 * step;

            // X-aligned lines
            self.add_line(DebugLine::new(
                center + Vec3::new(-half_size, 0.0, offset),
                center + Vec3::new(half_size, 0.0, offset),
                color,
            ));

            // Z-aligned lines
            self.add_line(DebugLine::new(
                center + Vec3::new(offset, 0.0, -half_size),
                center + Vec3::new(offset, 0.0, half_size),
                color,
            ));
        }
    }

    /// Draw an arrow
    pub fn draw_arrow(&mut self, start: Vec3, end: Vec3, color: Color, head_size: f32) {
        self.add_line(DebugLine::new(start, end, color));

        let direction = (end - start).normalize();
        let length = (end - start).length();

        // Arrow head
        let head_length = head_size.min(length * 0.3);
        self.draw_cone(end, -direction, head_length, 0.3, color, 8);
    }

    /// Draw a path
    pub fn draw_path(&mut self, points: &[Vec3], color: Color, closed: bool) {
        if points.len() < 2 {
            return;
        }

        for i in 0..points.len() - 1 {
            self.add_line(DebugLine::new(points[i], points[i + 1], color));
        }

        if closed && points.len() > 2 {
            self.add_line(DebugLine::new(points[points.len() - 1], points[0], color));
        }
    }

    /// Draw a skeleton (bone hierarchy)
    pub fn draw_skeleton(&mut self, bones: &[Transform], parent_indices: &[i32], color: Color) {
        for (i, (bone, parent_idx)) in bones.iter().zip(parent_indices.iter()).enumerate() {
            // Draw bone axes
            self.draw_transform(bone, 0.1);

            // Draw connection to parent
            if *parent_idx >= 0 {
                let parent = &bones[*parent_idx as usize];
                self.add_line(DebugLine::new(parent.position, bone.position, color).with_thickness(2.0));
            }
        }
    }

    /// Update persistent lines
    pub fn update(&mut self, delta_time: f32) {
        // Update persistent line durations
        self.persistent_lines.retain_mut(|(_, remaining)| {
            *remaining -= delta_time;
            *remaining > 0.0
        });
    }

    /// Build vertex buffer for rendering
    fn build_vertex_buffer(&mut self) {
        let mut vertices = Vec::new();

        // Add frame lines
        for line in &self.lines {
            vertices.push(DebugLineVertex {
                position: line.start,
                color: line.color,
            });
            vertices.push(DebugLineVertex {
                position: line.end,
                color: line.color,
            });
        }

        // Add persistent lines
        for (line, _) in &self.persistent_lines {
            vertices.push(DebugLineVertex {
                position: line.start,
                color: line.color,
            });
            vertices.push(DebugLineVertex {
                position: line.end,
                color: line.color,
            });
        }

        self.vertex_count = vertices.len().min(self.max_vertices as usize) as u32;
        self.vertex_buffer.write(&vertices[..self.vertex_count as usize], 0);
    }

    /// Render all debug lines
    pub fn render(&mut self, view_proj: Mat4) {
        if self.lines.is_empty() && self.persistent_lines.is_empty() {
            return;
        }

        self.build_vertex_buffer();

        // Separate depth-tested and non-depth-tested lines
        let depth_test_count = self.lines.iter()
            .filter(|l| l.depth_test)
            .count() * 2;

        // Draw depth-tested lines
        if depth_test_count > 0 {
            self.pipeline_depth.set_vertex_buffer(&self.vertex_buffer);
            self.pipeline_depth.set_uniform("view_proj", view_proj);
            self.pipeline_depth.draw(0, depth_test_count as u32);
        }

        // Clear frame lines
        self.lines.clear();
    }
}

// =============================================================================
// REGION: DEBUG TEXT RENDERER
// =============================================================================

/// Debug text entry
pub struct DebugText {
    /// Text content
    pub text: String,
    /// Screen position (normalized 0-1)
    pub position: Vec2,
    /// Text color
    pub color: Color,
    /// Font scale
    pub scale: f32,
    /// Duration (0 = single frame)
    pub duration: f32,
    /// Shadow enabled
    pub shadow: bool,
}

impl DebugText {
    /// Create new debug text
    pub fn new(text: impl Into<String>, position: Vec2, color: Color) -> Self {
        Self {
            text: text.into(),
            position,
            color,
            scale: 1.0,
            duration: 0.0,
            shadow: true,
        }
    }

    /// Create 3D world space text
    pub fn world_space(text: impl Into<String>, world_pos: Vec3, view_proj: Mat4, color: Color) -> Option<Self> {
        let clip = view_proj * Vec4::new(world_pos.x, world_pos.y, world_pos.z, 1.0);
        if clip.w <= 0.0 {
            return None;
        }

        let ndc = Vec2::new(clip.x / clip.w, clip.y / clip.w);
        if ndc.x < -1.0 || ndc.x > 1.0 || ndc.y < -1.0 || ndc.y > 1.0 {
            return None;
        }

        let screen = Vec2::new(ndc.x * 0.5 + 0.5, 1.0 - (ndc.y * 0.5 + 0.5));

        Some(Self {
            text: text.into(),
            position: screen,
            color,
            scale: 1.0,
            duration: 0.0,
            shadow: true,
        })
    }
}

/// GPU font atlas character info
#[repr(C)]
pub struct FontGlyph {
    /// UV coordinates (x, y, width, height) normalized
    pub uv_rect: Vec4,
    /// Offset from baseline
    pub offset: Vec2,
    /// Advance width
    pub advance: f32,
    /// Character width
    pub width: f32,
}

/// Debug text renderer with bitmap font
pub struct DebugTextRenderer {
    /// Font texture atlas
    font_texture: Texture,
    /// Glyph data
    glyphs: [FontGlyph; 128],
    /// Text entries
    texts: Vec<DebugText>,
    /// Persistent texts
    persistent_texts: Vec<(DebugText, f32)>,
    /// Vertex buffer for quads
    vertex_buffer: GpuBuffer,
    /// Index buffer
    index_buffer: GpuBuffer,
    /// Maximum characters
    max_chars: u32,
    /// Render pipeline
    pipeline: RenderPipeline,
    /// Line height
    line_height: f32,
}

impl DebugTextRenderer {
    /// Create new debug text renderer
    pub fn new(max_chars: u32) -> Self {
        let font_texture = Self::create_default_font();
        let glyphs = Self::create_default_glyphs();

        Self {
            font_texture,
            glyphs,
            texts: Vec::new(),
            persistent_texts: Vec::new(),
            vertex_buffer: GpuBuffer::new_vertex(max_chars as usize * 4 * 32),
            index_buffer: GpuBuffer::new_index(max_chars as usize * 6 * 4),
            max_chars,
            pipeline: RenderPipeline::from_source(DEBUG_TEXT_SHADER),
            line_height: 16.0,
        }
    }

    fn create_default_font() -> Texture {
        // Create a simple 8x8 bitmap font texture
        // In production, load from file
        Texture::new_2d(256, 256, TextureFormat::R8Unorm)
    }

    fn create_default_glyphs() -> [FontGlyph; 128] {
        let mut glyphs = [FontGlyph {
            uv_rect: Vec4::zero(),
            offset: Vec2::zero(),
            advance: 8.0,
            width: 8.0,
        }; 128];

        // Set up basic ASCII character UVs
        for i in 32..127 {
            let col = (i - 32) % 16;
            let row = (i - 32) / 16;
            glyphs[i] = FontGlyph {
                uv_rect: Vec4::new(
                    col as f32 / 16.0,
                    row as f32 / 8.0,
                    1.0 / 16.0,
                    1.0 / 8.0,
                ),
                offset: Vec2::zero(),
                advance: 8.0,
                width: 8.0,
            };
        }

        glyphs
    }

    /// Add debug text
    pub fn add_text(&mut self, text: DebugText) {
        if text.duration > 0.0 {
            self.persistent_texts.push((text, text.duration));
        } else {
            self.texts.push(text);
        }
    }

    /// Add simple text at position
    pub fn print(&mut self, text: impl Into<String>, x: f32, y: f32, color: Color) {
        self.add_text(DebugText::new(text, Vec2::new(x, y), color));
    }

    /// Add formatted stats
    pub fn print_stats(&mut self, label: &str, value: f64, x: f32, y: f32) {
        let text = format!("{}: {:.2}", label, value);
        self.print(text, x, y, Color::WHITE);
    }

    /// Update persistent texts
    pub fn update(&mut self, delta_time: f32) {
        self.persistent_texts.retain_mut(|(_, remaining)| {
            *remaining -= delta_time;
            *remaining > 0.0
        });
    }

    /// Render all debug text
    pub fn render(&mut self, screen_width: f32, screen_height: f32) {
        if self.texts.is_empty() && self.persistent_texts.is_empty() {
            return;
        }

        // Build vertices for all text
        // ...implementation details...

        self.pipeline.set_texture("font", &self.font_texture);
        self.pipeline.set_uniform("screen_size", Vec2::new(screen_width, screen_height));
        self.pipeline.draw_indexed(0, 0); // Actual counts would be computed

        self.texts.clear();
    }
}

// =============================================================================
// REGION: GPU PROFILER
// =============================================================================

/// GPU profiler zone
pub struct ProfileZone {
    /// Zone name
    pub name: String,
    /// Start query index
    pub start_query: u32,
    /// End query index
    pub end_query: u32,
    /// Parent zone index
    pub parent: Option<u32>,
    /// Depth in hierarchy
    pub depth: u32,
}

/// GPU profiler timing result
pub struct ProfileResult {
    /// Zone name
    pub name: String,
    /// GPU time in milliseconds
    pub gpu_time_ms: f64,
    /// Depth in hierarchy
    pub depth: u32,
    /// Percentage of frame time
    pub percentage: f32,
}

/// GPU profiler for measuring pass times
pub struct GpuProfiler {
    /// Query pool for timestamps
    query_buffer: GpuBuffer,
    /// Maximum queries per frame
    max_queries: u32,
    /// Current query index
    current_query: u32,
    /// Active zones stack
    zone_stack: Vec<u32>,
    /// All zones this frame
    zones: Vec<ProfileZone>,
    /// Results from previous frame
    results: Vec<ProfileResult>,
    /// Frame history for averaging
    history: RingBuffer<Vec<ProfileResult>>,
    /// Number of frames to average
    history_size: u32,
    /// GPU timestamp frequency
    timestamp_frequency: f64,
    /// Enabled state
    enabled: bool,
}

impl GpuProfiler {
    /// Create new GPU profiler
    pub fn new(max_queries: u32, history_size: u32) -> Self {
        Self {
            query_buffer: GpuBuffer::new_query(max_queries as usize * 8),
            max_queries,
            current_query: 0,
            zone_stack: Vec::new(),
            zones: Vec::new(),
            results: Vec::new(),
            history: RingBuffer::new(history_size as usize),
            history_size,
            timestamp_frequency: 1_000_000_000.0, // nanoseconds
            enabled: true,
        }
    }

    /// Enable or disable profiling
    pub fn set_enabled(&mut self, enabled: bool) {
        self.enabled = enabled;
    }

    /// Begin a new frame
    pub fn begin_frame(&mut self) {
        if !self.enabled {
            return;
        }

        self.current_query = 0;
        self.zones.clear();
        self.zone_stack.clear();
    }

    /// Begin a profiled zone
    pub fn begin_zone(&mut self, name: impl Into<String>) -> u32 {
        if !self.enabled {
            return 0;
        }

        let zone_index = self.zones.len() as u32;
        let start_query = self.current_query;
        self.current_query += 1;

        let parent = self.zone_stack.last().copied();
        let depth = self.zone_stack.len() as u32;

        self.zones.push(ProfileZone {
            name: name.into(),
            start_query,
            end_query: 0,
            parent,
            depth,
        });

        self.zone_stack.push(zone_index);

        // Write timestamp query
        self.write_timestamp_query(start_query);

        zone_index
    }

    /// End a profiled zone
    pub fn end_zone(&mut self, zone_index: u32) {
        if !self.enabled {
            return;
        }

        if let Some(zone) = self.zones.get_mut(zone_index as usize) {
            zone.end_query = self.current_query;
            self.current_query += 1;
            self.write_timestamp_query(zone.end_query);
        }

        self.zone_stack.pop();
    }

    fn write_timestamp_query(&self, index: u32) {
        // GPU-specific timestamp query
    }

    /// End frame and collect results
    pub fn end_frame(&mut self) {
        if !self.enabled || self.zones.is_empty() {
            return;
        }

        // Read timestamp queries
        let timestamps = self.read_timestamps();

        // Calculate times
        let mut frame_results = Vec::new();
        let mut total_time = 0.0;

        for zone in &self.zones {
            let start_time = timestamps.get(zone.start_query as usize).copied().unwrap_or(0);
            let end_time = timestamps.get(zone.end_query as usize).copied().unwrap_or(0);
            let gpu_time_ns = (end_time - start_time) as f64;
            let gpu_time_ms = gpu_time_ns / 1_000_000.0;

            if zone.depth == 0 {
                total_time += gpu_time_ms;
            }

            frame_results.push(ProfileResult {
                name: zone.name.clone(),
                gpu_time_ms,
                depth: zone.depth,
                percentage: 0.0,
            });
        }

        // Calculate percentages
        for result in &mut frame_results {
            result.percentage = (result.gpu_time_ms / total_time * 100.0) as f32;
        }

        // Add to history and calculate averages
        self.history.push(frame_results);
        self.calculate_averaged_results();
    }

    fn read_timestamps(&self) -> Vec<u64> {
        // Read from GPU query buffer
        vec![0; self.current_query as usize]
    }

    fn calculate_averaged_results(&mut self) {
        if self.history.is_empty() {
            return;
        }

        // Average results across history
        let history_count = self.history.len() as f64;
        let first = self.history.front().unwrap();

        self.results = first.iter().enumerate().map(|(i, r)| {
            let avg_time: f64 = self.history.iter()
                .filter_map(|h| h.get(i))
                .map(|r| r.gpu_time_ms)
                .sum::<f64>() / history_count;

            let avg_pct: f32 = self.history.iter()
                .filter_map(|h| h.get(i))
                .map(|r| r.percentage)
                .sum::<f32>() / history_count as f32;

            ProfileResult {
                name: r.name.clone(),
                gpu_time_ms: avg_time,
                depth: r.depth,
                percentage: avg_pct,
            }
        }).collect();
    }

    /// Get profile results
    pub fn results(&self) -> &[ProfileResult] {
        &self.results
    }

    /// Get total frame GPU time
    pub fn total_frame_time(&self) -> f64 {
        self.results.iter()
            .filter(|r| r.depth == 0)
            .map(|r| r.gpu_time_ms)
            .sum()
    }
}

/// RAII scope guard for profiling
pub struct ProfileScope<'a> {
    profiler: &'a mut GpuProfiler,
    zone_index: u32,
}

impl<'a> ProfileScope<'a> {
    pub fn new(profiler: &'a mut GpuProfiler, name: impl Into<String>) -> Self {
        let zone_index = profiler.begin_zone(name);
        Self { profiler, zone_index }
    }
}

impl Drop for ProfileScope<'_> {
    fn drop(&mut self) {
        self.profiler.end_zone(self.zone_index);
    }
}

