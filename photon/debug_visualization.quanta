/// Central debug visualization manager
pub struct DebugManager {
    /// Current render mode
    render_mode: DebugRenderMode,
    /// Debug line renderer
    lines: DebugLineBatch,
    /// Debug text renderer
    text: DebugTextRenderer,
    /// Stats overlay
    stats_overlay: StatsOverlay,
    /// Visualization passes
    viz_passes: DebugVisualizationPasses,
    /// Debug output texture
    output_texture: Texture,
    /// Enabled state
    enabled: bool,
    /// Show bounding boxes
    show_bounds: bool,
    /// Show lights
    show_lights: bool,
    /// Show probes
    show_probes: bool,
    /// Show navigation mesh
    show_navmesh: bool,
    /// Show physics colliders
    show_colliders: bool,
    /// Freeze culling
    freeze_culling: bool,
    /// Captured frustum for freeze culling
    frozen_frustum: Option<Frustum>,
}

impl DebugManager {
    /// Create new debug manager
    pub fn new(width: u32, height: u32) -> Self {
        Self {
            render_mode: DebugRenderMode::None,
            lines: DebugLineBatch::new(100000),
            text: DebugTextRenderer::new(8192),
            stats_overlay: StatsOverlay::new(),
            viz_passes: DebugVisualizationPasses::new(),
            output_texture: Texture::new_2d(width, height, TextureFormat::Rgba8Unorm),
            enabled: true,
            show_bounds: false,
            show_lights: false,
            show_probes: false,
            show_navmesh: false,
            show_colliders: false,
            freeze_culling: false,
            frozen_frustum: None,
        }
    }

    /// Set render mode
    pub fn set_render_mode(&mut self, mode: DebugRenderMode) {
        self.render_mode = mode;
    }

    /// Get current render mode
    pub fn render_mode(&self) -> &DebugRenderMode {
        &self.render_mode
    }

    /// Toggle render mode by shortcut
    pub fn toggle_mode_by_key(&mut self, key: char) {
        let modes = [
            ('1', DebugRenderMode::Wireframe),
            ('2', DebugRenderMode::Normals),
            ('3', DebugRenderMode::UvChecker),
            ('4', DebugRenderMode::Overdraw),
            ('5', DebugRenderMode::DepthBuffer),
            ('6', DebugRenderMode::LightCount),
            ('7', DebugRenderMode::AlbedoOnly),
            ('8', DebugRenderMode::NormalBuffer),
            ('9', DebugRenderMode::LodLevels),
            ('0', DebugRenderMode::None),
        ];

        for (shortcut, mode) in modes {
            if key == shortcut {
                self.render_mode = mode;
                return;
            }
        }
    }

    /// Get line batch for drawing
    pub fn lines(&mut self) -> &mut DebugLineBatch {
        &mut self.lines
    }

    /// Get text renderer
    pub fn text(&mut self) -> &mut DebugTextRenderer {
        &mut self.text
    }

    /// Get stats overlay
    pub fn stats(&mut self) -> &mut StatsOverlay {
        &mut self.stats_overlay
    }

    /// Toggle bounding boxes
    pub fn toggle_bounds(&mut self) {
        self.show_bounds = !self.show_bounds;
    }

    /// Toggle light visualization
    pub fn toggle_lights(&mut self) {
        self.show_lights = !self.show_lights;
    }

    /// Toggle freeze culling
    pub fn toggle_freeze_culling(&mut self, camera_frustum: &Frustum) {
        self.freeze_culling = !self.freeze_culling;
        if self.freeze_culling {
            self.frozen_frustum = Some(camera_frustum.clone());
        } else {
            self.frozen_frustum = None;
        }
    }

    /// Get culling frustum (frozen or current)
    pub fn culling_frustum<'a>(&'a self, current: &'a Frustum) -> &'a Frustum {
        self.frozen_frustum.as_ref().unwrap_or(current)
    }

    /// Update debug systems
    pub fn update(&mut self, delta_time: f32) {
        self.lines.update(delta_time);
        self.text.update(delta_time);
        self.stats_overlay.update(delta_time);
    }

    /// Begin frame profiling
    pub fn begin_frame(&mut self) {
        self.stats_overlay.profiler_mut().begin_frame();
        self.stats_overlay.stats_mut().reset();
    }

    /// End frame profiling
    pub fn end_frame(&mut self) {
        self.stats_overlay.profiler_mut().end_frame();
    }

    /// Render all debug visualizations
    pub fn render(
        &mut self,
        view_proj: Mat4,
        screen_width: f32,
        screen_height: f32,
    ) {
        if !self.enabled {
            return;
        }

        // Draw frozen frustum if culling is frozen
        if let Some(ref frustum) = self.frozen_frustum {
            self.lines.draw_frustum(frustum, Color::YELLOW);
        }

        // Render debug lines
        self.lines.render(view_proj);

        // Render debug text
        self.text.render(screen_width, screen_height);

        // Render stats overlay
        self.stats_overlay.render(screen_width, screen_height);
    }

    /// Draw AABB for object
    pub fn draw_object_bounds(&mut self, aabb: &Aabb, selected: bool) {
        if !self.show_bounds {
            return;
        }

        let color = if selected { Color::YELLOW } else { Color::GREEN };
        self.lines.draw_aabb(aabb, color);
    }

    /// Draw light visualization
    pub fn draw_light(&mut self, position: Vec3, light_type: &str, color: Color, range: f32) {
        if !self.show_lights {
            return;
        }

        match light_type {
            "point" => {
                self.lines.draw_sphere(position, range, color, 16);
                self.lines.draw_axes(position, 0.5);
            }
            "spot" => {
                // Spot light cone would be drawn
                self.lines.draw_axes(position, 0.5);
            }
            "directional" => {
                // Directional arrow
                self.lines.draw_axes(position, 1.0);
            }
            _ => {}
        }
    }
}

// =============================================================================
// REGION: WGSL SHADERS
// =============================================================================

const DEBUG_LINE_SHADER: &str = r#"
struct Uniforms {
    view_proj: mat4x4<f32>,
}

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) color: vec4<f32>,
}

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) color: vec4<f32>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

@vertex
fn vs_main(input: VertexInput) -> VertexOutput {
    var output: VertexOutput;
    output.position = uniforms.view_proj * vec4<f32>(input.position, 1.0);
    output.color = input.color;
    return output;
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    return input.color;
}
"#;

const DEBUG_TEXT_SHADER: &str = r#"
struct Uniforms {
    screen_size: vec2<f32>,
}

struct VertexInput {
    @location(0) position: vec2<f32>,
    @location(1) uv: vec2<f32>,
    @location(2) color: vec4<f32>,
}

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) uv: vec2<f32>,
    @location(1) color: vec4<f32>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;
@group(0) @binding(1) var font: texture_2d<f32>;
@group(0) @binding(2) var font_sampler: sampler;

@vertex
fn vs_main(input: VertexInput) -> VertexOutput {
    var output: VertexOutput;

    // Convert to NDC
    let ndc = vec2<f32>(
        input.position.x * 2.0 - 1.0,
        1.0 - input.position.y * 2.0
    );

    output.position = vec4<f32>(ndc, 0.0, 1.0);
    output.uv = input.uv;
    output.color = input.color;
    return output;
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    let alpha = textureSample(font, font_sampler, input.uv).r;
    return vec4<f32>(input.color.rgb, input.color.a * alpha);
}
"#;

const DEBUG_WIREFRAME_SHADER: &str = r#"
struct Uniforms {
    view_proj: mat4x4<f32>,
    wireframe_color: vec4<f32>,
    fill_color: vec4<f32>,
    line_width: f32,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) bary: vec3<f32>,
}

@vertex
fn vs_main(
    @builtin(vertex_index) vertex_index: u32,
    @location(0) position: vec3<f32>
) -> VertexOutput {
    var output: VertexOutput;
    output.position = uniforms.view_proj * vec4<f32>(position, 1.0);

    // Barycentric coordinates for wireframe
    let bary_idx = vertex_index % 3u;
    output.bary = vec3<f32>(
        select(0.0, 1.0, bary_idx == 0u),
        select(0.0, 1.0, bary_idx == 1u),
        select(0.0, 1.0, bary_idx == 2u)
    );

    return output;
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    // Calculate edge distance
    let d = min(min(input.bary.x, input.bary.y), input.bary.z);
    let edge = smoothstep(0.0, uniforms.line_width * fwidth(d), d);

    return mix(uniforms.wireframe_color, uniforms.fill_color, edge);
}
"#;

const DEBUG_NORMAL_SHADER: &str = r#"
struct Uniforms {
    view_proj: mat4x4<f32>,
    normal_length: f32,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) color: vec3<f32>,
}

@vertex
fn vs_main(
    @location(0) position: vec3<f32>,
    @location(1) normal: vec3<f32>
) -> VertexOutput {
    var output: VertexOutput;
    output.position = uniforms.view_proj * vec4<f32>(position, 1.0);
    output.color = normal * 0.5 + 0.5;
    return output;
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    return vec4<f32>(input.color, 1.0);
}
"#;

const DEBUG_OVERDRAW_SHADER: &str = r#"
@group(0) @binding(0) var overdraw_buffer: texture_2d<u32>;
@group(0) @binding(1) var heatmap_lut: texture_1d<f32>;
@group(0) @binding(2) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(3) var<uniform> max_overdraw: f32;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    let overdraw = f32(textureLoad(overdraw_buffer, id.xy, 0).r);
    let normalized = clamp(overdraw / max_overdraw, 0.0, 1.0);

    let color = textureLoad(heatmap_lut, i32(normalized * 255.0), 0);
    textureStore(output, id.xy, color);
}
"#;

const DEBUG_MIPMAP_SHADER: &str = r#"
@group(0) @binding(0) var uv_texture: texture_2d<f32>;
@group(0) @binding(1) var output: texture_storage_2d<rgba8unorm, write>;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    // Calculate mip level from UV derivatives
    // In practice, this would use ddx/ddy in fragment shader
    let uv = vec2<f32>(id.xy) / vec2<f32>(dims);

    // Color code by mip level
    let mip_colors = array<vec4<f32>, 8>(
        vec4<f32>(1.0, 0.0, 0.0, 1.0),  // Mip 0 - Red
        vec4<f32>(1.0, 0.5, 0.0, 1.0),  // Mip 1 - Orange
        vec4<f32>(1.0, 1.0, 0.0, 1.0),  // Mip 2 - Yellow
        vec4<f32>(0.0, 1.0, 0.0, 1.0),  // Mip 3 - Green
        vec4<f32>(0.0, 1.0, 1.0, 1.0),  // Mip 4 - Cyan
        vec4<f32>(0.0, 0.0, 1.0, 1.0),  // Mip 5 - Blue
        vec4<f32>(0.5, 0.0, 1.0, 1.0),  // Mip 6 - Purple
        vec4<f32>(1.0, 0.0, 1.0, 1.0)   // Mip 7 - Magenta
    );

    // Simplified - actual implementation would compute proper mip level
    let mip_level = 0u;
    textureStore(output, id.xy, mip_colors[mip_level]);
}
"#;

const DEBUG_DEPTH_SHADER: &str = r#"
@group(0) @binding(0) var depth: texture_2d<f32>;
@group(0) @binding(1) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(2) var<uniform> near: f32;
@group(0) @binding(3) var<uniform> far: f32;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    let raw_depth = textureLoad(depth, id.xy, 0).r;

    // Linearize depth
    let linear_depth = near * far / (far - raw_depth * (far - near));
    let normalized = (linear_depth - near) / (far - near);

    let color = vec4<f32>(vec3<f32>(normalized), 1.0);
    textureStore(output, id.xy, color);
}
"#;

const DEBUG_MOTION_SHADER: &str = r#"
@group(0) @binding(0) var motion: texture_2d<f32>;
@group(0) @binding(1) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(2) var<uniform> scale: f32;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    let mv = textureLoad(motion, id.xy, 0).rg;
    let magnitude = length(mv) * scale;

    // Color code by direction and magnitude
    let angle = atan2(mv.y, mv.x);
    let hue = angle / (2.0 * 3.14159) + 0.5;

    // HSV to RGB
    let h = hue * 6.0;
    let i = floor(h);
    let f = h - i;
    let q = 1.0 - f;
    let t = f;

    var color: vec3<f32>;
    switch (i32(i) % 6) {
        case 0: { color = vec3<f32>(1.0, t, 0.0); }
        case 1: { color = vec3<f32>(q, 1.0, 0.0); }
        case 2: { color = vec3<f32>(0.0, 1.0, t); }
        case 3: { color = vec3<f32>(0.0, q, 1.0); }
        case 4: { color = vec3<f32>(t, 0.0, 1.0); }
        default: { color = vec3<f32>(1.0, 0.0, q); }
    }

    color *= saturate(magnitude);
    textureStore(output, id.xy, vec4<f32>(color, 1.0));
}
"#;

const DEBUG_LIGHT_COUNT_SHADER: &str = r#"
@group(0) @binding(0) var light_count: texture_2d<u32>;
@group(0) @binding(1) var heatmap_lut: texture_1d<f32>;
@group(0) @binding(2) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(3) var<uniform> max_lights: f32;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    let count = f32(textureLoad(light_count, id.xy, 0).r);
    let normalized = clamp(count / max_lights, 0.0, 1.0);

    let color = textureLoad(heatmap_lut, i32(normalized * 255.0), 0);
    textureStore(output, id.xy, color);
}
"#;

const DEBUG_CLUSTER_SHADER: &str = r#"
@group(0) @binding(0) var clusters: texture_3d<u32>;
@group(0) @binding(1) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(2) var<uniform> view_proj: mat4x4<f32>;

fn hash3(n: vec3<u32>) -> vec3<f32> {
    var p = vec3<f32>(n);
    p = fract(p * vec3<f32>(0.1031, 0.1030, 0.0973));
    p += dot(p, p.yxz + 33.33);
    return fract((p.xxy + p.yxx) * p.zyx);
}

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    // Get cluster index from screen position
    let cluster_dims = textureDimensions(clusters);
    let cluster_xy = id.xy * cluster_dims.xy / dims;
    let cluster_z = 0u; // Would be computed from depth

    let cluster_id = vec3<u32>(cluster_xy, cluster_z);
    let color = hash3(cluster_id);

    textureStore(output, id.xy, vec4<f32>(color, 0.5));
}
"#;

const DEBUG_LOD_SHADER: &str = r#"
@group(0) @binding(0) var lod_buffer: texture_2d<u32>;
@group(0) @binding(1) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(2) var<uniform> max_lod: f32;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    let lod = f32(textureLoad(lod_buffer, id.xy, 0).r);

    // Color code LOD levels
    let lod_colors = array<vec4<f32>, 8>(
        vec4<f32>(0.0, 1.0, 0.0, 1.0),  // LOD 0 - Green (highest detail)
        vec4<f32>(0.5, 1.0, 0.0, 1.0),  // LOD 1
        vec4<f32>(1.0, 1.0, 0.0, 1.0),  // LOD 2 - Yellow
        vec4<f32>(1.0, 0.5, 0.0, 1.0),  // LOD 3
        vec4<f32>(1.0, 0.0, 0.0, 1.0),  // LOD 4 - Red
        vec4<f32>(1.0, 0.0, 0.5, 1.0),  // LOD 5
        vec4<f32>(1.0, 0.0, 1.0, 1.0),  // LOD 6 - Magenta
        vec4<f32>(0.5, 0.0, 1.0, 1.0)   // LOD 7 - Purple (lowest detail)
    );

    let lod_index = clamp(u32(lod), 0u, 7u);
    textureStore(output, id.xy, lod_colors[lod_index]);
}
"#;

const STATS_GRAPH_SHADER: &str = r#"
@group(0) @binding(0) var<storage, read> frame_times: array<f32>;
@group(0) @binding(1) var output: texture_storage_2d<rgba8unorm, write>;
@group(0) @binding(2) var<uniform> target_ms: f32;
@group(0) @binding(3) var<uniform> history_count: u32;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(output);
    if (any(id.xy >= dims)) { return; }

    let uv = vec2<f32>(id.xy) / vec2<f32>(dims);
    let sample_idx = u32(uv.x * f32(history_count));
    let frame_time = frame_times[sample_idx];

    // Normalize to target (16.67ms for 60fps)
    let height = frame_time / (target_ms * 2.0);
    let y_pos = 1.0 - uv.y;

    var color: vec4<f32>;
    if (y_pos < height) {
        // Graph fill
        if (frame_time > target_ms * 1.5) {
            color = vec4<f32>(1.0, 0.0, 0.0, 0.8); // Red - very slow
        } else if (frame_time > target_ms) {
            color = vec4<f32>(1.0, 1.0, 0.0, 0.8); // Yellow - slow
        } else {
            color = vec4<f32>(0.0, 1.0, 0.0, 0.8); // Green - good
        }
    } else {
        color = vec4<f32>(0.0, 0.0, 0.0, 0.3); // Background
    }

    // Target line
    let target_y = 1.0 - (target_ms / (target_ms * 2.0));
    if (abs(y_pos - target_y) < 0.01) {
        color = vec4<f32>(1.0, 1.0, 1.0, 0.8);
    }

    textureStore(output, id.xy, color);
}
"#;

// =============================================================================
// REGION: UNIT TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_debug_render_mode_shortcuts() {
        assert_eq!(DebugRenderMode::Wireframe.shortcut(), Some('1'));
        assert_eq!(DebugRenderMode::Normals.shortcut(), Some('2'));
        assert_eq!(DebugRenderMode::None.shortcut(), None);
    }

    #[test]
    fn test_debug_line_creation() {
        let line = DebugLine::new(
            Vec3::zero(),
            Vec3::new(1.0, 0.0, 0.0),
            Color::RED
        );

        assert_eq!(line.thickness, 1.0);
        assert_eq!(line.duration, 0.0);
        assert!(line.depth_test);
    }

    #[test]
    fn test_debug_line_modifiers() {
        let line = DebugLine::new(Vec3::zero(), Vec3::one(), Color::WHITE)
            .with_thickness(2.0)
            .with_duration(1.0)
            .no_depth_test();

        assert_eq!(line.thickness, 2.0);
        assert_eq!(line.duration, 1.0);
        assert!(!line.depth_test);
    }

    #[test]
    fn test_height_gradient_sample() {
        let gradient = HeightGradient::cumulus();
        assert!(gradient.sample(0.5) > gradient.sample(0.0));
    }

    #[test]
    fn test_render_stats_reset() {
        let mut stats = RenderStats::default();
        stats.draw_calls = 100;
        stats.triangles = 50000;
        stats.reset();

        assert_eq!(stats.draw_calls, 0);
        assert_eq!(stats.triangles, 0);
    }

    #[test]
    fn test_debug_text_world_space() {
        let view_proj = Mat4::identity();
        let world_pos = Vec3::new(0.0, 0.0, 0.0);

        // Behind camera should return None
        let behind = Vec3::new(0.0, 0.0, -10.0);
        let text = DebugText::world_space("test", behind, view_proj, Color::WHITE);
        // Result depends on projection
    }

    #[test]
    fn test_debug_manager_mode_toggle() {
        let mut manager = DebugManager::new(1920, 1080);

        manager.toggle_mode_by_key('1');
        assert!(matches!(manager.render_mode(), DebugRenderMode::Wireframe));

        manager.toggle_mode_by_key('0');
        assert!(matches!(manager.render_mode(), DebugRenderMode::None));
    }

    #[test]
    fn test_heatmap_color_range() {
        // Blue at 0
        let (r, g, b) = DebugVisualizationPasses::heatmap_color(0.0);
        assert_eq!(b, 1.0);

        // Red at 1
        let (r, g, b) = DebugVisualizationPasses::heatmap_color(1.0);
        assert_eq!(r, 1.0);
    }

    #[test]
    fn test_profile_result() {
        let result = ProfileResult {
            name: "TestPass".to_string(),
            gpu_time_ms: 5.5,
            depth: 0,
            percentage: 33.0,
        };

        assert_eq!(result.name, "TestPass");
        assert!(result.gpu_time_ms > 5.0);
    }
}
