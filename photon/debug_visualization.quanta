/// Debug visualization compute shaders
pub struct DebugVisualizationPasses {
    /// Wireframe overlay pass
    wireframe_pipeline: RenderPipeline,
    /// Normal visualization pass
    normal_pipeline: RenderPipeline,
    /// Overdraw heatmap pass
    overdraw_compute: ComputeShader,
    /// Mipmap visualization pass
    mipmap_compute: ComputeShader,
    /// Depth visualization pass
    depth_compute: ComputeShader,
    /// Motion vector visualization pass
    motion_compute: ComputeShader,
    /// Light count heatmap pass
    light_count_compute: ComputeShader,
    /// Cluster visualization pass
    cluster_compute: ComputeShader,
    /// LOD visualization pass
    lod_compute: ComputeShader,
    /// Heatmap color ramp texture
    heatmap_lut: Texture,
}

impl DebugVisualizationPasses {
    /// Create all visualization passes
    pub fn new() -> Self {
        Self {
            wireframe_pipeline: RenderPipeline::from_source(DEBUG_WIREFRAME_SHADER),
            normal_pipeline: RenderPipeline::from_source(DEBUG_NORMAL_SHADER),
            overdraw_compute: ComputeShader::from_source(DEBUG_OVERDRAW_SHADER),
            mipmap_compute: ComputeShader::from_source(DEBUG_MIPMAP_SHADER),
            depth_compute: ComputeShader::from_source(DEBUG_DEPTH_SHADER),
            motion_compute: ComputeShader::from_source(DEBUG_MOTION_SHADER),
            light_count_compute: ComputeShader::from_source(DEBUG_LIGHT_COUNT_SHADER),
            cluster_compute: ComputeShader::from_source(DEBUG_CLUSTER_SHADER),
            lod_compute: ComputeShader::from_source(DEBUG_LOD_SHADER),
            heatmap_lut: Self::create_heatmap_lut(),
        }
    }

    fn create_heatmap_lut() -> Texture {
        let mut data = vec![0u8; 256 * 4];

        for i in 0..256 {
            let t = i as f32 / 255.0;
            let (r, g, b) = Self::heatmap_color(t);
            data[i * 4] = (r * 255.0) as u8;
            data[i * 4 + 1] = (g * 255.0) as u8;
            data[i * 4 + 2] = (b * 255.0) as u8;
            data[i * 4 + 3] = 255;
        }

        let texture = Texture::new_1d(256, TextureFormat::Rgba8Unorm);
        texture.write(&data, 0);
        texture
    }

    fn heatmap_color(t: f32) -> (f32, f32, f32) {
        // Blue -> Cyan -> Green -> Yellow -> Red
        if t < 0.25 {
            let s = t * 4.0;
            (0.0, s, 1.0)
        } else if t < 0.5 {
            let s = (t - 0.25) * 4.0;
            (0.0, 1.0, 1.0 - s)
        } else if t < 0.75 {
            let s = (t - 0.5) * 4.0;
            (s, 1.0, 0.0)
        } else {
            let s = (t - 0.75) * 4.0;
            (1.0, 1.0 - s, 0.0)
        }
    }

    /// Visualize overdraw
    pub fn visualize_overdraw(&self, overdraw_buffer: &Texture, output: &Texture, max_overdraw: u32) {
        self.overdraw_compute.set_texture("overdraw_buffer", overdraw_buffer);
        self.overdraw_compute.set_texture("heatmap_lut", &self.heatmap_lut);
        self.overdraw_compute.set_storage_texture("output", output);
        self.overdraw_compute.set_uniform("max_overdraw", max_overdraw as f32);

        self.overdraw_compute.dispatch_2d(output.width(), output.height());
    }

    /// Visualize mipmap levels
    pub fn visualize_mipmaps(&self, uv_texture: &Texture, output: &Texture) {
        self.mipmap_compute.set_texture("uv_texture", uv_texture);
        self.mipmap_compute.set_storage_texture("output", output);

        self.mipmap_compute.dispatch_2d(output.width(), output.height());
    }

    /// Visualize depth buffer
    pub fn visualize_depth(&self, depth_texture: &Texture, output: &Texture, near: f32, far: f32) {
        self.depth_compute.set_texture("depth", depth_texture);
        self.depth_compute.set_storage_texture("output", output);
        self.depth_compute.set_uniform("near", near);
        self.depth_compute.set_uniform("far", far);

        self.depth_compute.dispatch_2d(output.width(), output.height());
    }

    /// Visualize motion vectors
    pub fn visualize_motion(&self, motion_texture: &Texture, output: &Texture, scale: f32) {
        self.motion_compute.set_texture("motion", motion_texture);
        self.motion_compute.set_storage_texture("output", output);
        self.motion_compute.set_uniform("scale", scale);

        self.motion_compute.dispatch_2d(output.width(), output.height());
    }

    /// Visualize light count per pixel
    pub fn visualize_light_count(&self, light_count_texture: &Texture, output: &Texture, max_lights: u32) {
        self.light_count_compute.set_texture("light_count", light_count_texture);
        self.light_count_compute.set_texture("heatmap_lut", &self.heatmap_lut);
        self.light_count_compute.set_storage_texture("output", output);
        self.light_count_compute.set_uniform("max_lights", max_lights as f32);

        self.light_count_compute.dispatch_2d(output.width(), output.height());
    }

    /// Visualize light clusters
    pub fn visualize_clusters(&self, cluster_texture: &Texture, output: &Texture, view_proj: Mat4) {
        self.cluster_compute.set_texture("clusters", cluster_texture);
        self.cluster_compute.set_storage_texture("output", output);
        self.cluster_compute.set_uniform("view_proj", view_proj);

        self.cluster_compute.dispatch_2d(output.width(), output.height());
    }

    /// Visualize LOD levels
    pub fn visualize_lod(&self, lod_buffer: &Texture, output: &Texture, max_lod: u32) {
        self.lod_compute.set_texture("lod_buffer", lod_buffer);
        self.lod_compute.set_storage_texture("output", output);
        self.lod_compute.set_uniform("max_lod", max_lod as f32);

        self.lod_compute.dispatch_2d(output.width(), output.height());
    }
}

