module photon::volumetric;

use core::math::{Vec2, Vec3, Vec4, Mat4, Quat};
use core::memory::{Buffer, Texture3D, Arena};
use core::simd::{f32x4, f32x8};

// =============================================================================
// VOLUMETRIC CONFIGURATION
// =============================================================================

/// Configuration for the volumetric lighting system
pub struct VolumetricConfig {
    /// Froxel grid resolution (X, Y, Z)
    froxel_resolution: Vec3<u32>,
    /// Near plane for volumetric effects
    near_plane: f32,
    /// Far plane for volumetric effects
    far_plane: f32,
    /// Slice distribution exponent (depth distribution)
    slice_exponent: f32,
    /// Enable temporal reprojection
    temporal_enabled: bool,
    /// Temporal blend factor
    temporal_blend: f32,
    /// Number of ray march steps for shadows
    shadow_steps: u32,
    /// Enable volumetric shadows
    shadows_enabled: bool,
    /// Scattering coefficient
    scattering_coefficient: f32,
    /// Absorption coefficient
    absorption_coefficient: f32,
    /// Phase function anisotropy (g parameter)
    phase_anisotropy: f32,
    /// Enable multi-scattering approximation
    multi_scattering: bool,
    /// Noise scale for dithering
    noise_scale: f32,
}

impl VolumetricConfig {
    pub fn default() -> Self {
        Self {
            froxel_resolution: Vec3::new(160, 90, 128),
            near_plane: 0.1,
            far_plane: 500.0,
            slice_exponent: 2.0,
            temporal_enabled: true,
            temporal_blend: 0.95,
            shadow_steps: 8,
            shadows_enabled: true,
            scattering_coefficient: 0.01,
            absorption_coefficient: 0.001,
            phase_anisotropy: 0.8,
            multi_scattering: true,
            noise_scale: 1.0,
        }
    }

    pub fn high_quality() -> Self {
        Self {
            froxel_resolution: Vec3::new(320, 180, 256),
            near_plane: 0.1,
            far_plane: 1000.0,
            slice_exponent: 2.0,
            temporal_enabled: true,
            temporal_blend: 0.97,
            shadow_steps: 16,
            shadows_enabled: true,
            scattering_coefficient: 0.01,
            absorption_coefficient: 0.001,
            phase_anisotropy: 0.8,
            multi_scattering: true,
            noise_scale: 0.5,
        }
    }

    pub fn performance() -> Self {
        Self {
            froxel_resolution: Vec3::new(80, 45, 64),
            near_plane: 0.1,
            far_plane: 200.0,
            slice_exponent: 2.5,
            temporal_enabled: true,
            temporal_blend: 0.9,
            shadow_steps: 4,
            shadows_enabled: true,
            scattering_coefficient: 0.01,
            absorption_coefficient: 0.001,
            phase_anisotropy: 0.8,
            multi_scattering: false,
            noise_scale: 2.0,
        }
    }
}

// =============================================================================
// FROXEL SYSTEM (WP-015, WP-103)
// =============================================================================

/// A froxel (frustum voxel) for volumetric lighting
#[repr(C)]
pub struct Froxel {
    /// Accumulated in-scattered light (RGB) and transmittance (A)
    scattering: Vec4,
    /// Extinction coefficient for this froxel
    extinction: f32,
    /// Phase function value (precomputed)
    phase: f32,
    /// Density at this froxel
    density: f32,
    /// Temporal weight for reprojection
    temporal_weight: f32,
}

impl Froxel {
    pub fn empty() -> Self {
        Self {
            scattering: Vec4::new(0.0, 0.0, 0.0, 1.0),
            extinction: 0.0,
            phase: 0.0,
            density: 0.0,
            temporal_weight: 0.0,
        }
    }
}

/// Froxel grid for volumetric lighting
pub struct FroxelGrid {
    /// Grid dimensions
    dimensions: Vec3<u32>,
    /// Froxel data buffer (GPU)
    data: Buffer<Froxel>,
    /// Previous frame data for temporal reprojection
    prev_data: Buffer<Froxel>,
    /// Slice depth values (precomputed)
    slice_depths: Vec<f32>,
    /// View-projection matrix
    view_proj: Mat4,
    /// Inverse view-projection matrix
    inv_view_proj: Mat4,
    /// Previous frame view-projection
    prev_view_proj: Mat4,
    /// Near plane
    near: f32,
    /// Far plane
    far: f32,
    /// Slice distribution exponent
    exponent: f32,
}

impl FroxelGrid {
    pub fn new(config: &VolumetricConfig) -> Self {
        let dimensions = config.froxel_resolution;
        let total_froxels = (dimensions.x * dimensions.y * dimensions.z) as usize;

        // Precompute slice depths with exponential distribution
        let slice_depths = Self::compute_slice_depths(
            config.near_plane,
            config.far_plane,
            dimensions.z,
            config.slice_exponent
        );

        Self {
            dimensions,
            data: Buffer::new(total_froxels),
            prev_data: Buffer::new(total_froxels),
            slice_depths,
            view_proj: Mat4::identity(),
            inv_view_proj: Mat4::identity(),
            prev_view_proj: Mat4::identity(),
            near: config.near_plane,
            far: config.far_plane,
            exponent: config.slice_exponent,
        }
    }

    /// Compute exponentially distributed slice depths
    fn compute_slice_depths(near: f32, far: f32, slices: u32, exponent: f32) -> Vec<f32> {
        let mut depths = Vec::with_capacity(slices as usize + 1);

        for i in 0..=slices {
            let t = i as f32 / slices as f32;
            // Exponential depth distribution for better near-field resolution
            let depth = near * (far / near).powf(t.powf(exponent));
            depths.push(depth);
        }

        depths
    }

    /// Get world-space position for a froxel coordinate
    pub fn froxel_to_world(&self, coord: Vec3<u32>) -> Vec3 {
        let uv = Vec2::new(
            (coord.x as f32 + 0.5) / self.dimensions.x as f32,
            (coord.y as f32 + 0.5) / self.dimensions.y as f32
        );

        // Get depth from slice table
        let depth = if coord.z < self.slice_depths.len() as u32 - 1 {
            let d0 = self.slice_depths[coord.z as usize];
            let d1 = self.slice_depths[coord.z as usize + 1];
            (d0 + d1) * 0.5
        } else {
            self.far
        };

        // Convert to NDC
        let ndc = Vec4::new(
            uv.x * 2.0 - 1.0,
            1.0 - uv.y * 2.0,
            self.depth_to_ndc(depth),
            1.0
        );

        // Transform to world space
        let world = self.inv_view_proj * ndc;
        Vec3::new(world.x / world.w, world.y / world.w, world.z / world.w)
    }

    /// Convert linear depth to NDC depth
    fn depth_to_ndc(&self, depth: f32) -> f32 {
        // Assuming reversed-Z infinite perspective
        self.near / depth
    }

    /// Get the froxel index for a world position
    pub fn world_to_froxel(&self, world_pos: Vec3) -> Option<Vec3<u32>> {
        let clip = self.view_proj * Vec4::new(world_pos.x, world_pos.y, world_pos.z, 1.0);

        if clip.w <= 0.0 {
            return None;
        }

        let ndc = Vec3::new(clip.x / clip.w, clip.y / clip.w, clip.z / clip.w);

        // Check bounds
        if ndc.x < -1.0 || ndc.x > 1.0 || ndc.y < -1.0 || ndc.y > 1.0 {
            return None;
        }

        let uv = Vec2::new(
            (ndc.x + 1.0) * 0.5,
            (1.0 - ndc.y) * 0.5
        );

        // Convert NDC depth to linear depth
        let linear_depth = self.near / ndc.z.max(0.0001);

        if linear_depth < self.near || linear_depth > self.far {
            return None;
        }

        // Find slice index
        let slice = self.depth_to_slice(linear_depth);

        Some(Vec3::new(
            ((uv.x * self.dimensions.x as f32) as u32).min(self.dimensions.x - 1),
            ((uv.y * self.dimensions.y as f32) as u32).min(self.dimensions.y - 1),
            slice.min(self.dimensions.z - 1)
        ))
    }

    /// Convert linear depth to slice index
    fn depth_to_slice(&self, depth: f32) -> u32 {
        // Binary search for slice
        let mut low = 0usize;
        let mut high = self.slice_depths.len() - 1;

        while low < high {
            let mid = (low + high) / 2;
            if self.slice_depths[mid] < depth {
                low = mid + 1;
            } else {
                high = mid;
            }
        }

        low.saturating_sub(1) as u32
    }

    /// Update matrices for new frame
    pub fn update_matrices(&mut self, view_proj: Mat4, inv_view_proj: Mat4) {
        self.prev_view_proj = self.view_proj;
        self.view_proj = view_proj;
        self.inv_view_proj = inv_view_proj;
    }

    /// Swap current and previous buffers
    pub fn swap_buffers(&mut self) {
        core::mem::swap(&mut self.data, &mut self.prev_data);
    }

    /// Clear the froxel grid
    pub fn clear(&mut self) {
        for froxel in self.data.iter_mut() {
            *froxel = Froxel::empty();
        }
    }

    /// Get froxel at coordinate
    pub fn get(&self, coord: Vec3<u32>) -> &Froxel {
        let index = self.coord_to_index(coord);
        &self.data[index]
    }

    /// Get mutable froxel at coordinate
    pub fn get_mut(&mut self, coord: Vec3<u32>) -> &mut Froxel {
        let index = self.coord_to_index(coord);
        &mut self.data[index]
    }

    fn coord_to_index(&self, coord: Vec3<u32>) -> usize {
        (coord.z * self.dimensions.y * self.dimensions.x +
         coord.y * self.dimensions.x +
         coord.x) as usize
    }
}

// =============================================================================
// PHASE FUNCTIONS
// =============================================================================

/// Phase function types for volumetric scattering
pub enum PhaseFunction {
    /// Isotropic scattering (uniform in all directions)
    Isotropic,
    /// Henyey-Greenstein phase function
    HenyeyGreenstein { g: f32 },
    /// Dual-lobe Henyey-Greenstein
    DualLobe { g_forward: f32, g_back: f32, blend: f32 },
    /// Schlick approximation (faster)
    Schlick { k: f32 },
    /// Cornette-Shanks (physically accurate for spherical particles)
    CornetteShanks { g: f32 },
    /// Mie scattering for larger particles
    Mie { droplet_size: f32 },
}

impl PhaseFunction {
    /// Evaluate the phase function for given cosine of angle
    pub fn evaluate(&self, cos_theta: f32) -> f32 {
        match self {
            PhaseFunction::Isotropic => {
                // p(θ) = 1 / 4π
                0.25 / core::f32::consts::PI
            }

            PhaseFunction::HenyeyGreenstein { g } => {
                // p(θ) = (1 - g²) / (4π * (1 + g² - 2g*cos(θ))^(3/2))
                let g2 = g * g;
                let denom = 1.0 + g2 - 2.0 * g * cos_theta;
                (1.0 - g2) / (4.0 * core::f32::consts::PI * denom.powf(1.5))
            }

            PhaseFunction::DualLobe { g_forward, g_back, blend } => {
                let forward = PhaseFunction::HenyeyGreenstein { g: *g_forward }.evaluate(cos_theta);
                let back = PhaseFunction::HenyeyGreenstein { g: *g_back }.evaluate(cos_theta);
                forward * blend + back * (1.0 - blend)
            }

            PhaseFunction::Schlick { k } => {
                // Schlick approximation: p(θ) = (1 - k²) / (4π * (1 + k*cos(θ))²)
                let denom = 1.0 + k * cos_theta;
                (1.0 - k * k) / (4.0 * core::f32::consts::PI * denom * denom)
            }

            PhaseFunction::CornetteShanks { g } => {
                // Cornette-Shanks: accounts for polarization
                let g2 = g * g;
                let cos2 = cos_theta * cos_theta;
                let denom = 1.0 + g2 - 2.0 * g * cos_theta;
                (3.0 * (1.0 - g2) * (1.0 + cos2)) /
                    (8.0 * core::f32::consts::PI * (2.0 + g2) * denom.powf(1.5))
            }

            PhaseFunction::Mie { droplet_size } => {
                // Simplified Mie scattering approximation
                let x = 2.0 * core::f32::consts::PI * droplet_size / 0.55; // 550nm wavelength
                let g = 0.5 * (1.0 - (-0.1 * x).exp());
                PhaseFunction::HenyeyGreenstein { g }.evaluate(cos_theta)
            }
        }
    }

    /// Sample a direction from the phase function
    pub fn sample(&self, incoming: Vec3, u: Vec2) -> (Vec3, f32) {
        let cos_theta = match self {
            PhaseFunction::Isotropic => {
                1.0 - 2.0 * u.x
            }

            PhaseFunction::HenyeyGreenstein { g } | PhaseFunction::CornetteShanks { g } => {
                if g.abs() < 0.001 {
                    1.0 - 2.0 * u.x
                } else {
                    let g2 = g * g;
                    let sqr_term = (1.0 - g2) / (1.0 - g + 2.0 * g * u.x);
                    (1.0 + g2 - sqr_term * sqr_term) / (2.0 * g)
                }
            }

            PhaseFunction::DualLobe { g_forward, g_back, blend } => {
                let g = if u.y < *blend { *g_forward } else { *g_back };
                let g2 = g * g;
                let sqr_term = (1.0 - g2) / (1.0 - g + 2.0 * g * u.x);
                (1.0 + g2 - sqr_term * sqr_term) / (2.0 * g)
            }

            PhaseFunction::Schlick { k } => {
                let temp = 2.0 * u.x * k - k - 1.0;
                (1.0 + k * temp) / (1.0 + k * k * temp)
            }

            PhaseFunction::Mie { droplet_size } => {
                let x = 2.0 * core::f32::consts::PI * droplet_size / 0.55;
                let g = 0.5 * (1.0 - (-0.1 * x).exp());
                let g2 = g * g;
                let sqr_term = (1.0 - g2) / (1.0 - g + 2.0 * g * u.x);
                (1.0 + g2 - sqr_term * sqr_term) / (2.0 * g)
            }
        };

        let sin_theta = (1.0 - cos_theta * cos_theta).max(0.0).sqrt();
        let phi = 2.0 * core::f32::consts::PI * u.y;

        // Build local coordinate frame
        let (tangent, bitangent) = Self::build_orthonormal_basis(incoming);

        let local_dir = Vec3::new(
            sin_theta * phi.cos(),
            sin_theta * phi.sin(),
            cos_theta
        );

        let world_dir = tangent * local_dir.x + bitangent * local_dir.y + incoming * local_dir.z;
        let pdf = self.evaluate(cos_theta);

        (world_dir.normalize(), pdf)
    }

    fn build_orthonormal_basis(n: Vec3) -> (Vec3, Vec3) {
        let sign = if n.z >= 0.0 { 1.0 } else { -1.0 };
        let a = -1.0 / (sign + n.z);
        let b = n.x * n.y * a;

        let tangent = Vec3::new(1.0 + sign * n.x * n.x * a, sign * b, -sign * n.x);
        let bitangent = Vec3::new(b, sign + n.y * n.y * a, -n.y);

        (tangent, bitangent)
    }
}

// =============================================================================
// PARTICIPATING MEDIA
// =============================================================================

/// Participating media properties
pub struct ParticipatingMedium {
    /// Scattering coefficient (σs)
    scattering: Vec3,
    /// Absorption coefficient (σa)
    absorption: Vec3,
    /// Phase function for scattering
    phase_function: PhaseFunction,
    /// Emission (for fire/smoke)
    emission: Vec3,
    /// Density field (optional 3D texture)
    density_texture: Option<Texture3D>,
    /// Base density multiplier
    density_scale: f32,
    /// Height-based density falloff
    height_falloff: f32,
    /// World-space bounds
    bounds: AABB,
}

/// Axis-aligned bounding box
#[derive(Clone, Copy)]
pub struct AABB {
    pub min: Vec3,
    pub max: Vec3,
}

impl AABB {
    pub fn new(min: Vec3, max: Vec3) -> Self {
        Self { min, max }
    }

    pub fn contains(&self, point: Vec3) -> bool {
        point.x >= self.min.x && point.x <= self.max.x &&
        point.y >= self.min.y && point.y <= self.max.y &&
        point.z >= self.min.z && point.z <= self.max.z
    }

    pub fn intersect_ray(&self, origin: Vec3, dir: Vec3) -> Option<(f32, f32)> {
        let inv_dir = Vec3::new(1.0 / dir.x, 1.0 / dir.y, 1.0 / dir.z);

        let t1 = (self.min.x - origin.x) * inv_dir.x;
        let t2 = (self.max.x - origin.x) * inv_dir.x;
        let t3 = (self.min.y - origin.y) * inv_dir.y;
        let t4 = (self.max.y - origin.y) * inv_dir.y;
        let t5 = (self.min.z - origin.z) * inv_dir.z;
        let t6 = (self.max.z - origin.z) * inv_dir.z;

        let tmin = t1.min(t2).max(t3.min(t4)).max(t5.min(t6));
        let tmax = t1.max(t2).min(t3.max(t4)).min(t5.max(t6));

        if tmax < 0.0 || tmin > tmax {
            None
        } else {
            Some((tmin.max(0.0), tmax))
        }
    }
}

impl ParticipatingMedium {
    pub fn new(scattering: Vec3, absorption: Vec3, bounds: AABB) -> Self {
        Self {
            scattering,
            absorption,
            phase_function: PhaseFunction::HenyeyGreenstein { g: 0.8 },
            emission: Vec3::zero(),
            density_texture: None,
            density_scale: 1.0,
            height_falloff: 0.0,
            bounds,
        }
    }

    /// Create uniform fog
    pub fn uniform_fog(density: f32, color: Vec3, bounds: AABB) -> Self {
        let scattering = color * density;
        let absorption = color * density * 0.1;

        Self {
            scattering,
            absorption,
            phase_function: PhaseFunction::HenyeyGreenstein { g: 0.6 },
            emission: Vec3::zero(),
            density_texture: None,
            density_scale: 1.0,
            height_falloff: 0.0,
            bounds,
        }
    }

    /// Create height-based fog
    pub fn height_fog(density: f32, falloff: f32, color: Vec3, bounds: AABB) -> Self {
        let mut medium = Self::uniform_fog(density, color, bounds);
        medium.height_falloff = falloff;
        medium
    }

    /// Create smoke medium
    pub fn smoke(density: f32, bounds: AABB) -> Self {
        Self {
            scattering: Vec3::new(0.2, 0.2, 0.2) * density,
            absorption: Vec3::new(0.05, 0.05, 0.05) * density,
            phase_function: PhaseFunction::DualLobe {
                g_forward: 0.85,
                g_back: -0.3,
                blend: 0.8
            },
            emission: Vec3::zero(),
            density_texture: None,
            density_scale: 1.0,
            height_falloff: 0.0,
            bounds,
        }
    }

    /// Create fire medium (WP-077)
    pub fn fire(intensity: f32, bounds: AABB) -> Self {
        Self {
            scattering: Vec3::new(0.01, 0.005, 0.002),
            absorption: Vec3::new(0.1, 0.2, 0.3),
            phase_function: PhaseFunction::Isotropic,
            emission: Vec3::new(10.0, 4.0, 0.5) * intensity,
            density_texture: None,
            density_scale: 1.0,
            height_falloff: 0.0,
            bounds,
        }
    }

    /// Get extinction coefficient (σt = σs + σa)
    pub fn extinction(&self) -> Vec3 {
        self.scattering + self.absorption
    }

    /// Get single-scattering albedo (σs / σt)
    pub fn albedo(&self) -> Vec3 {
        let ext = self.extinction();
        Vec3::new(
            if ext.x > 0.0 { self.scattering.x / ext.x } else { 0.0 },
            if ext.y > 0.0 { self.scattering.y / ext.y } else { 0.0 },
            if ext.z > 0.0 { self.scattering.z / ext.z } else { 0.0 }
        )
    }

    /// Sample density at a point
    pub fn sample_density(&self, point: Vec3) -> f32 {
        if !self.bounds.contains(point) {
            return 0.0;
        }

        let mut density = self.density_scale;

        // Apply height falloff
        if self.height_falloff > 0.0 {
            let height = (point.y - self.bounds.min.y) / (self.bounds.max.y - self.bounds.min.y);
            density *= (-height * self.height_falloff).exp();
        }

        // Sample 3D density texture if available
        if let Some(ref texture) = self.density_texture {
            let uvw = Vec3::new(
                (point.x - self.bounds.min.x) / (self.bounds.max.x - self.bounds.min.x),
                (point.y - self.bounds.min.y) / (self.bounds.max.y - self.bounds.min.y),
                (point.z - self.bounds.min.z) / (self.bounds.max.z - self.bounds.min.z)
            );
            density *= texture.sample_trilinear(uvw);
        }

        density
    }
}

// =============================================================================
// VOLUMETRIC LIGHTING RENDERER
// =============================================================================

/// Main volumetric lighting renderer
pub struct VolumetricRenderer {
    /// Configuration
    config: VolumetricConfig,
    /// Froxel grid
    froxel_grid: FroxelGrid,
    /// Participating media in the scene
    media: Vec<ParticipatingMedium>,
    /// Global fog medium
    global_fog: Option<ParticipatingMedium>,
    /// Blue noise texture for dithering
    blue_noise: Texture3D,
    /// Temporal jitter offset
    jitter_offset: u32,
    /// Frame counter
    frame_count: u32,
}

impl VolumetricRenderer {
    pub fn new(config: VolumetricConfig) -> Self {
        let froxel_grid = FroxelGrid::new(&config);
        let blue_noise = Self::create_blue_noise_3d(64);

        Self {
            config,
            froxel_grid,
            media: Vec::new(),
            global_fog: None,
            blue_noise,
            jitter_offset: 0,
            frame_count: 0,
        }
    }

    /// Create 3D blue noise texture
    fn create_blue_noise_3d(size: u32) -> Texture3D {
        let mut data = Vec::with_capacity((size * size * size) as usize);

        // Generate blue noise using void-and-cluster algorithm
        // (simplified version - production would use precomputed textures)
        for z in 0..size {
            for y in 0..size {
                for x in 0..size {
                    let hash = Self::pcg_hash(x + y * size + z * size * size);
                    data.push((hash & 0xFF) as f32 / 255.0);
                }
            }
        }

        Texture3D::from_data(&data, size, size, size)
    }

    fn pcg_hash(input: u32) -> u32 {
        let state = input.wrapping_mul(747796405).wrapping_add(2891336453);
        let word = ((state >> ((state >> 28).wrapping_add(4))) ^ state).wrapping_mul(277803737);
        (word >> 22) ^ word
    }

    /// Add a participating medium
    pub fn add_medium(&mut self, medium: ParticipatingMedium) {
        self.media.push(medium);
    }

    /// Set global fog
    pub fn set_global_fog(&mut self, fog: ParticipatingMedium) {
        self.global_fog = Some(fog);
    }

    /// Clear all media
    pub fn clear_media(&mut self) {
        self.media.clear();
        self.global_fog = None;
    }

    /// Render volumetric lighting for a frame
    pub fn render(
        &mut self,
        view_proj: Mat4,
        inv_view_proj: Mat4,
        camera_pos: Vec3,
        lights: &[VolumetricLight],
        shadow_maps: &[ShadowMap],
    ) -> &FroxelGrid {
        self.frame_count += 1;

        // Update froxel grid matrices
        self.froxel_grid.update_matrices(view_proj, inv_view_proj);

        // Swap temporal buffers
        self.froxel_grid.swap_buffers();

        // Clear current grid
        self.froxel_grid.clear();

        // Inject density and lighting into froxels
        self.inject_density();
        self.inject_lighting(camera_pos, lights, shadow_maps);

        // Apply temporal reprojection
        if self.config.temporal_enabled {
            self.temporal_reproject();
        }

        // Integrate scattering along view rays
        self.integrate_scattering(camera_pos);

        // Update jitter for next frame
        self.jitter_offset = (self.jitter_offset + 1) % 8;

        &self.froxel_grid
    }

    /// Inject density from media into froxels
    fn inject_density(&mut self) {
        let dims = self.froxel_grid.dimensions;

        for z in 0..dims.z {
            for y in 0..dims.y {
                for x in 0..dims.x {
                    let coord = Vec3::new(x, y, z);
                    let world_pos = self.froxel_grid.froxel_to_world(coord);

                    let mut total_density = 0.0;
                    let mut total_scattering = Vec3::zero();
                    let mut total_absorption = Vec3::zero();
                    let mut total_emission = Vec3::zero();

                    // Sample global fog
                    if let Some(ref fog) = self.global_fog {
                        let density = fog.sample_density(world_pos);
                        total_density += density;
                        total_scattering = total_scattering + fog.scattering * density;
                        total_absorption = total_absorption + fog.absorption * density;
                        total_emission = total_emission + fog.emission * density;
                    }

                    // Sample local media
                    for medium in &self.media {
                        let density = medium.sample_density(world_pos);
                        if density > 0.0 {
                            total_density += density;
                            total_scattering = total_scattering + medium.scattering * density;
                            total_absorption = total_absorption + medium.absorption * density;
                            total_emission = total_emission + medium.emission * density;
                        }
                    }

                    let froxel = self.froxel_grid.get_mut(coord);
                    froxel.density = total_density;
                    froxel.extinction = (total_scattering + total_absorption).luminance();
                    froxel.scattering = Vec4::new(
                        total_emission.x,
                        total_emission.y,
                        total_emission.z,
                        1.0
                    );
                }
            }
        }
    }

    /// Inject lighting contribution into froxels
    fn inject_lighting(
        &mut self,
        camera_pos: Vec3,
        lights: &[VolumetricLight],
        shadow_maps: &[ShadowMap],
    ) {
        let dims = self.froxel_grid.dimensions;

        for z in 0..dims.z {
            for y in 0..dims.y {
                for x in 0..dims.x {
                    let coord = Vec3::new(x, y, z);
                    let world_pos = self.froxel_grid.froxel_to_world(coord);

                    let froxel = self.froxel_grid.get_mut(coord);
                    if froxel.density <= 0.0 {
                        continue;
                    }

                    // Get jittered position for temporal stability
                    let jitter = self.get_temporal_jitter(coord);
                    let jittered_pos = world_pos + jitter;

                    // View direction for phase function
                    let view_dir = (camera_pos - jittered_pos).normalize();

                    let mut in_scattered = Vec3::zero();

                    // Accumulate contribution from each light
                    for (i, light) in lights.iter().enumerate() {
                        let light_contribution = self.evaluate_light_contribution(
                            jittered_pos,
                            view_dir,
                            light,
                            shadow_maps.get(i),
                            froxel.density
                        );
                        in_scattered = in_scattered + light_contribution;
                    }

                    // Add in-scattered light to froxel (with existing emission)
                    froxel.scattering.x += in_scattered.x;
                    froxel.scattering.y += in_scattered.y;
                    froxel.scattering.z += in_scattered.z;
                }
            }
        }
    }

    /// Get temporal jitter for a froxel
    fn get_temporal_jitter(&self, coord: Vec3<u32>) -> Vec3 {
        let noise_coord = Vec3::new(
            (coord.x + self.jitter_offset) % 64,
            (coord.y + self.jitter_offset * 7) % 64,
            (coord.z + self.jitter_offset * 13) % 64
        );

        let noise = self.blue_noise.sample_point(noise_coord);

        // Convert to world-space jitter
        let froxel_size = self.estimate_froxel_size(coord);
        Vec3::new(
            (noise.x - 0.5) * froxel_size.x * self.config.noise_scale,
            (noise.y - 0.5) * froxel_size.y * self.config.noise_scale,
            (noise.z - 0.5) * froxel_size.z * self.config.noise_scale
        )
    }

    /// Estimate world-space size of a froxel
    fn estimate_froxel_size(&self, coord: Vec3<u32>) -> Vec3 {
        let p0 = self.froxel_grid.froxel_to_world(coord);
        let p1 = self.froxel_grid.froxel_to_world(Vec3::new(coord.x + 1, coord.y + 1, coord.z + 1));
        p1 - p0
    }

    /// Evaluate light contribution at a point
    fn evaluate_light_contribution(
        &self,
        pos: Vec3,
        view_dir: Vec3,
        light: &VolumetricLight,
        shadow_map: Option<&ShadowMap>,
        density: f32,
    ) -> Vec3 {
        let (light_dir, attenuation, light_color) = match light {
            VolumetricLight::Directional { direction, color, intensity } => {
                (-direction.normalize(), 1.0, *color * *intensity)
            }

            VolumetricLight::Point { position, color, intensity, radius } => {
                let to_light = *position - pos;
                let dist = to_light.length();
                let dir = to_light / dist;
                let atten = Self::point_light_attenuation(dist, *radius);
                (dir, atten, *color * *intensity)
            }

            VolumetricLight::Spot { position, direction, color, intensity, radius, inner_angle, outer_angle } => {
                let to_light = *position - pos;
                let dist = to_light.length();
                let dir = to_light / dist;

                let cos_angle = (-dir).dot(*direction);
                let spot_atten = Self::spot_attenuation(cos_angle, *inner_angle, *outer_angle);
                let dist_atten = Self::point_light_attenuation(dist, *radius);

                (dir, spot_atten * dist_atten, *color * *intensity)
            }
        };

        if attenuation <= 0.0 {
            return Vec3::zero();
        }

        // Evaluate phase function
        let cos_theta = view_dir.dot(light_dir);
        let phase = PhaseFunction::HenyeyGreenstein { g: self.config.phase_anisotropy }
            .evaluate(cos_theta);

        // Shadow visibility
        let visibility = if self.config.shadows_enabled {
            if let Some(shadow) = shadow_map {
                self.evaluate_volumetric_shadow(pos, light_dir, shadow)
            } else {
                1.0
            }
        } else {
            1.0
        };

        // Scattering contribution
        let scattering = self.config.scattering_coefficient * density;

        light_color * attenuation * phase * visibility * scattering
    }

    fn point_light_attenuation(dist: f32, radius: f32) -> f32 {
        let clamped_dist = dist.max(0.01);
        let normalized = (clamped_dist / radius).min(1.0);
        let atten = (1.0 - normalized * normalized).max(0.0);
        atten * atten / (clamped_dist * clamped_dist)
    }

    fn spot_attenuation(cos_angle: f32, inner: f32, outer: f32) -> f32 {
        let cos_inner = inner.cos();
        let cos_outer = outer.cos();
        ((cos_angle - cos_outer) / (cos_inner - cos_outer)).clamp(0.0, 1.0)
    }

    /// Evaluate volumetric shadow using ray marching
    fn evaluate_volumetric_shadow(
        &self,
        pos: Vec3,
        light_dir: Vec3,
        shadow_map: &ShadowMap,
    ) -> f32 {
        // Check shadow map for initial visibility
        let shadow_visibility = shadow_map.sample(pos);
        if shadow_visibility <= 0.0 {
            return 0.0;
        }

        // Ray march through volume for self-shadowing
        let mut transmittance = 1.0;
        let step_size = 1.0 / self.config.shadow_steps as f32;

        for i in 0..self.config.shadow_steps {
            let t = (i as f32 + 0.5) * step_size;
            let sample_pos = pos + light_dir * t * 10.0; // 10 units max march distance

            // Sample density at this position
            let density = self.sample_total_density(sample_pos);

            // Beer-Lambert law
            let extinction = self.config.scattering_coefficient + self.config.absorption_coefficient;
            transmittance *= (-density * extinction * step_size * 10.0).exp();

            if transmittance < 0.01 {
                break;
            }
        }

        shadow_visibility * transmittance
    }

    /// Sample total density at a point
    fn sample_total_density(&self, pos: Vec3) -> f32 {
        let mut total = 0.0;

        if let Some(ref fog) = self.global_fog {
            total += fog.sample_density(pos);
        }

        for medium in &self.media {
            total += medium.sample_density(pos);
        }

        total
    }

    /// Apply temporal reprojection
    fn temporal_reproject(&mut self) {
        let dims = self.froxel_grid.dimensions;
        let blend = self.config.temporal_blend;

        for z in 0..dims.z {
            for y in 0..dims.y {
                for x in 0..dims.x {
                    let coord = Vec3::new(x, y, z);
                    let world_pos = self.froxel_grid.froxel_to_world(coord);

                    // Reproject to previous frame
                    let prev_clip = self.froxel_grid.prev_view_proj *
                        Vec4::new(world_pos.x, world_pos.y, world_pos.z, 1.0);

                    if prev_clip.w <= 0.0 {
                        continue;
                    }

                    let prev_ndc = Vec3::new(
                        prev_clip.x / prev_clip.w,
                        prev_clip.y / prev_clip.w,
                        prev_clip.z / prev_clip.w
                    );

                    // Check if reprojected position is valid
                    if prev_ndc.x < -1.0 || prev_ndc.x > 1.0 ||
                       prev_ndc.y < -1.0 || prev_ndc.y > 1.0 {
                        continue;
                    }

                    // Sample previous frame (with bilinear interpolation)
                    let prev_uv = Vec2::new(
                        (prev_ndc.x + 1.0) * 0.5 * dims.x as f32,
                        (1.0 - prev_ndc.y) * 0.5 * dims.y as f32
                    );

                    if let Some(prev_froxel) = self.sample_prev_froxel(prev_uv, z) {
                        let current = self.froxel_grid.get_mut(coord);

                        // Blend with previous frame
                        current.scattering = current.scattering.lerp(prev_froxel.scattering, blend);
                        current.temporal_weight = blend;
                    }
                }
            }
        }
    }

    fn sample_prev_froxel(&self, uv: Vec2, z: u32) -> Option<Froxel> {
        let dims = self.froxel_grid.dimensions;

        let x = uv.x as u32;
        let y = uv.y as u32;

        if x >= dims.x || y >= dims.y || z >= dims.z {
            return None;
        }

        let index = (z * dims.y * dims.x + y * dims.x + x) as usize;
        Some(self.froxel_grid.prev_data[index])
    }

    /// Integrate scattering along view rays (front-to-back)
    fn integrate_scattering(&mut self, camera_pos: Vec3) {
        let dims = self.froxel_grid.dimensions;

        for y in 0..dims.y {
            for x in 0..dims.x {
                // Integrate front to back
                let mut accumulated_scattering = Vec3::zero();
                let mut accumulated_transmittance = 1.0;

                for z in 0..dims.z {
                    let coord = Vec3::new(x, y, z);
                    let froxel = self.froxel_grid.get_mut(coord);

                    if froxel.extinction > 0.0 {
                        // Get slice thickness
                        let d0 = self.froxel_grid.slice_depths[z as usize];
                        let d1 = self.froxel_grid.slice_depths[(z + 1) as usize];
                        let slice_thickness = d1 - d0;

                        // Beer-Lambert transmittance for this slice
                        let slice_transmittance = (-froxel.extinction * slice_thickness).exp();

                        // In-scattering for this slice (accounting for extinction)
                        let in_scatter = Vec3::new(
                            froxel.scattering.x,
                            froxel.scattering.y,
                            froxel.scattering.z
                        );

                        // Integrate using closed-form solution
                        let scattering_integral = if froxel.extinction > 0.001 {
                            in_scatter * (1.0 - slice_transmittance) / froxel.extinction
                        } else {
                            in_scatter * slice_thickness
                        };

                        // Accumulate
                        accumulated_scattering = accumulated_scattering +
                            scattering_integral * accumulated_transmittance;
                        accumulated_transmittance *= slice_transmittance;
                    }

                    // Store integrated result
                    froxel.scattering = Vec4::new(
                        accumulated_scattering.x,
                        accumulated_scattering.y,
                        accumulated_scattering.z,
                        accumulated_transmittance
                    );
                }
            }
        }
    }

    /// Sample the integrated volumetric lighting at a screen position
    pub fn sample(&self, uv: Vec2, depth: f32) -> Vec4 {
        if let Some(coord) = self.screen_to_froxel(uv, depth) {
            // Trilinear interpolation between froxels
            self.sample_trilinear(coord)
        } else {
            Vec4::new(0.0, 0.0, 0.0, 1.0)
        }
    }

    fn screen_to_froxel(&self, uv: Vec2, depth: f32) -> Option<Vec3<f32>> {
        let dims = self.froxel_grid.dimensions;

        if depth < self.config.near_plane || depth > self.config.far_plane {
            return None;
        }

        let x = uv.x * dims.x as f32;
        let y = uv.y * dims.y as f32;
        let z = self.froxel_grid.depth_to_slice(depth) as f32;

        Some(Vec3::new(x, y, z))
    }

    fn sample_trilinear(&self, coord: Vec3<f32>) -> Vec4 {
        let dims = self.froxel_grid.dimensions;

        let x0 = (coord.x as u32).min(dims.x - 1);
        let y0 = (coord.y as u32).min(dims.y - 1);
        let z0 = (coord.z as u32).min(dims.z - 1);
        let x1 = (x0 + 1).min(dims.x - 1);
        let y1 = (y0 + 1).min(dims.y - 1);
        let z1 = (z0 + 1).min(dims.z - 1);

        let fx = coord.x.fract();
        let fy = coord.y.fract();
        let fz = coord.z.fract();

        // Sample 8 corners
        let c000 = self.froxel_grid.get(Vec3::new(x0, y0, z0)).scattering;
        let c100 = self.froxel_grid.get(Vec3::new(x1, y0, z0)).scattering;
        let c010 = self.froxel_grid.get(Vec3::new(x0, y1, z0)).scattering;
        let c110 = self.froxel_grid.get(Vec3::new(x1, y1, z0)).scattering;
        let c001 = self.froxel_grid.get(Vec3::new(x0, y0, z1)).scattering;
        let c101 = self.froxel_grid.get(Vec3::new(x1, y0, z1)).scattering;
        let c011 = self.froxel_grid.get(Vec3::new(x0, y1, z1)).scattering;
        let c111 = self.froxel_grid.get(Vec3::new(x1, y1, z1)).scattering;

        // Trilinear interpolation
        let c00 = c000.lerp(c100, fx);
        let c10 = c010.lerp(c110, fx);
        let c01 = c001.lerp(c101, fx);
        let c11 = c011.lerp(c111, fx);

        let c0 = c00.lerp(c10, fy);
        let c1 = c01.lerp(c11, fy);

        c0.lerp(c1, fz)
    }
}

// =============================================================================
// VOLUMETRIC LIGHT TYPES
// =============================================================================

/// Volumetric light source
pub enum VolumetricLight {
    Directional {
        direction: Vec3,
        color: Vec3,
        intensity: f32,
    },
    Point {
        position: Vec3,
        color: Vec3,
        intensity: f32,
        radius: f32,
    },
    Spot {
        position: Vec3,
        direction: Vec3,
        color: Vec3,
        intensity: f32,
        radius: f32,
        inner_angle: f32,
        outer_angle: f32,
    },
}

/// Shadow map reference
pub struct ShadowMap {
    texture: Texture3D,
    view_proj: Mat4,
    cascade_splits: Vec<f32>,
}

impl ShadowMap {
    pub fn sample(&self, world_pos: Vec3) -> f32 {
        let clip = self.view_proj * Vec4::new(world_pos.x, world_pos.y, world_pos.z, 1.0);
        let ndc = Vec3::new(clip.x / clip.w, clip.y / clip.w, clip.z / clip.w);

        let uv = Vec2::new(
            (ndc.x + 1.0) * 0.5,
            (1.0 - ndc.y) * 0.5
        );

        if uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0 {
            return 1.0;
        }

        let shadow_depth = self.texture.sample_2d(uv);
        if ndc.z > shadow_depth + 0.001 {
            0.0
        } else {
            1.0
        }
    }
}

// =============================================================================
// ATMOSPHERIC SCATTERING (RAYLEIGH/MIE)
// =============================================================================

/// Atmospheric scattering parameters
pub struct AtmosphereParams {
    /// Planet radius in km
    planet_radius: f32,
    /// Atmosphere height in km
    atmosphere_height: f32,
    /// Rayleigh scattering coefficients (wavelength-dependent)
    rayleigh_scattering: Vec3,
    /// Rayleigh scale height (altitude where density is 1/e)
    rayleigh_scale_height: f32,
    /// Mie scattering coefficient
    mie_scattering: f32,
    /// Mie scale height
    mie_scale_height: f32,
    /// Mie phase function anisotropy (g)
    mie_anisotropy: f32,
    /// Ozone absorption coefficient
    ozone_absorption: Vec3,
    /// Sun disk angular diameter (radians)
    sun_angular_diameter: f32,
    /// Sun intensity multiplier
    sun_intensity: f32,
}

impl AtmosphereParams {
    /// Earth-like atmosphere
    pub fn earth() -> Self {
        Self {
            planet_radius: 6371.0,
            atmosphere_height: 100.0,
            // Rayleigh coefficients at sea level (per km)
            rayleigh_scattering: Vec3::new(5.802e-3, 13.558e-3, 33.1e-3),
            rayleigh_scale_height: 8.0,
            mie_scattering: 3.996e-3,
            mie_scale_height: 1.2,
            mie_anisotropy: 0.8,
            ozone_absorption: Vec3::new(0.65e-3, 1.881e-3, 0.085e-3),
            sun_angular_diameter: 0.00935, // ~0.536 degrees
            sun_intensity: 20.0,
        }
    }

    /// Mars-like atmosphere
    pub fn mars() -> Self {
        Self {
            planet_radius: 3389.5,
            atmosphere_height: 60.0,
            rayleigh_scattering: Vec3::new(19.918e-3, 13.57e-3, 5.75e-3),
            rayleigh_scale_height: 11.1,
            mie_scattering: 4.0e-3,
            mie_scale_height: 1.0,
            mie_anisotropy: 0.76,
            ozone_absorption: Vec3::zero(),
            sun_angular_diameter: 0.00611,
            sun_intensity: 8.0,
        }
    }
}

/// Atmospheric scattering renderer
pub struct AtmosphericScattering {
    params: AtmosphereParams,
    /// Precomputed transmittance LUT
    transmittance_lut: Texture3D,
    /// Precomputed multiscatter LUT
    multiscatter_lut: Texture3D,
    /// Sky view LUT (for fast sky rendering)
    skyview_lut: Texture3D,
}

impl AtmosphericScattering {
    pub fn new(params: AtmosphereParams) -> Self {
        let transmittance_lut = Self::compute_transmittance_lut(&params);
        let multiscatter_lut = Self::compute_multiscatter_lut(&params, &transmittance_lut);
        let skyview_lut = Texture3D::new(256, 128, 1);

        Self {
            params,
            transmittance_lut,
            multiscatter_lut,
            skyview_lut,
        }
    }

    /// Compute transmittance lookup table
    fn compute_transmittance_lut(params: &AtmosphereParams) -> Texture3D {
        let width = 256;
        let height = 64;
        let mut data = Vec::with_capacity(width * height * 4);

        for y in 0..height {
            for x in 0..width {
                // Height (0 to atmosphere height)
                let h = (y as f32 / height as f32) * params.atmosphere_height;
                // Cosine of zenith angle (-1 to 1)
                let mu = 2.0 * (x as f32 / width as f32) - 1.0;

                let transmittance = Self::compute_transmittance_to_sun(params, h, mu);

                data.push(transmittance.x);
                data.push(transmittance.y);
                data.push(transmittance.z);
                data.push(1.0);
            }
        }

        Texture3D::from_rgba(&data, width as u32, height as u32, 1)
    }

    /// Compute transmittance from a point to the sun
    fn compute_transmittance_to_sun(params: &AtmosphereParams, height: f32, cos_zenith: f32) -> Vec3 {
        let r = params.planet_radius + height;
        let r_top = params.planet_radius + params.atmosphere_height;

        // Ray-sphere intersection with top of atmosphere
        let mu = cos_zenith;
        let discriminant = r * r * (mu * mu - 1.0) + r_top * r_top;

        if discriminant < 0.0 {
            return Vec3::one(); // Outside atmosphere
        }

        let d = (-r * mu + discriminant.sqrt()).max(0.0);

        // Numerical integration using 32 samples
        let num_samples = 32;
        let step = d / num_samples as f32;

        let mut optical_depth_rayleigh = 0.0;
        let mut optical_depth_mie = 0.0;
        let mut optical_depth_ozone = 0.0;

        for i in 0..num_samples {
            let t = (i as f32 + 0.5) * step;
            let sample_height = ((r + t * mu).powi(2) +
                                t * t * (1.0 - mu * mu)).sqrt() - params.planet_radius;

            if sample_height > 0.0 {
                let rayleigh_density = (-sample_height / params.rayleigh_scale_height).exp();
                let mie_density = (-sample_height / params.mie_scale_height).exp();

                // Ozone layer peaks around 25km
                let ozone_density = (-(sample_height - 25.0).abs() / 5.0).exp() *
                    (-sample_height / params.rayleigh_scale_height).exp();

                optical_depth_rayleigh += rayleigh_density * step;
                optical_depth_mie += mie_density * step;
                optical_depth_ozone += ozone_density * step;
            }
        }

        let extinction_rayleigh = params.rayleigh_scattering * optical_depth_rayleigh;
        let extinction_mie = Vec3::splat(params.mie_scattering * 1.1) * optical_depth_mie;
        let extinction_ozone = params.ozone_absorption * optical_depth_ozone;

        let total_extinction = extinction_rayleigh + extinction_mie + extinction_ozone;

        Vec3::new(
            (-total_extinction.x).exp(),
            (-total_extinction.y).exp(),
            (-total_extinction.z).exp()
        )
    }

    /// Compute multiple scattering LUT
    fn compute_multiscatter_lut(params: &AtmosphereParams, transmittance: &Texture3D) -> Texture3D {
        // Simplified multi-scattering approximation based on Hillaire 2020
        let size = 32;
        let mut data = Vec::with_capacity(size * size * 4);

        for y in 0..size {
            for x in 0..size {
                let height = (y as f32 / size as f32) * params.atmosphere_height;
                let cos_sun = 2.0 * (x as f32 / size as f32) - 1.0;

                // Approximate multi-scatter contribution
                let multi = Self::compute_multiscatter_single(params, height, cos_sun);

                data.push(multi.x);
                data.push(multi.y);
                data.push(multi.z);
                data.push(1.0);
            }
        }

        Texture3D::from_rgba(&data, size as u32, size as u32, 1)
    }

    fn compute_multiscatter_single(params: &AtmosphereParams, height: f32, cos_sun: f32) -> Vec3 {
        // Isotropic multi-scatter approximation
        let r = params.planet_radius + height;
        let mu_s = cos_sun;

        let rayleigh_density = (-height / params.rayleigh_scale_height).exp();
        let mie_density = (-height / params.mie_scale_height).exp();

        let scattering = params.rayleigh_scattering * rayleigh_density +
                        Vec3::splat(params.mie_scattering) * mie_density;

        // Approximate energy from higher-order scattering
        let albedo = scattering / (scattering + Vec3::splat(0.0001));
        let multi_factor = albedo / (Vec3::one() - albedo * 0.5);

        scattering * multi_factor * 0.25
    }

    /// Render sky color for a view direction
    pub fn render_sky(&self, view_dir: Vec3, sun_dir: Vec3, camera_height: f32) -> Vec3 {
        let cos_sun_zenith = sun_dir.y;
        let cos_view_zenith = view_dir.y;
        let cos_sun_view = view_dir.dot(sun_dir);

        // Raymarch through atmosphere
        let height = self.params.planet_radius + camera_height;
        let num_samples = 32;

        let mut inscattered_rayleigh = Vec3::zero();
        let mut inscattered_mie = Vec3::zero();
        let mut transmittance = Vec3::one();

        // Ray-atmosphere intersection
        let ray_length = self.ray_atmosphere_intersection(camera_height, cos_view_zenith);
        let step = ray_length / num_samples as f32;

        for i in 0..num_samples {
            let t = (i as f32 + 0.5) * step;
            let sample_height = self.get_height_at_distance(camera_height, cos_view_zenith, t);

            if sample_height < 0.0 {
                break; // Hit ground
            }

            // Density at sample point
            let rayleigh_density = (-sample_height / self.params.rayleigh_scale_height).exp();
            let mie_density = (-sample_height / self.params.mie_scale_height).exp();

            // Extinction for this segment
            let extinction = self.params.rayleigh_scattering * rayleigh_density +
                           Vec3::splat(self.params.mie_scattering * 1.1) * mie_density;
            let segment_transmittance = Vec3::new(
                (-extinction.x * step).exp(),
                (-extinction.y * step).exp(),
                (-extinction.z * step).exp()
            );

            // Inscattering contribution
            let sun_transmittance = self.sample_transmittance_lut(sample_height, cos_sun_zenith);

            let scattering_rayleigh = self.params.rayleigh_scattering * rayleigh_density;
            let scattering_mie = Vec3::splat(self.params.mie_scattering) * mie_density;

            inscattered_rayleigh = inscattered_rayleigh +
                transmittance * scattering_rayleigh * sun_transmittance * step;
            inscattered_mie = inscattered_mie +
                transmittance * scattering_mie * sun_transmittance * step;

            transmittance = transmittance * segment_transmittance;
        }

        // Apply phase functions
        let rayleigh_phase = Self::rayleigh_phase(cos_sun_view);
        let mie_phase = PhaseFunction::HenyeyGreenstein { g: self.params.mie_anisotropy }
            .evaluate(cos_sun_view) * 4.0 * core::f32::consts::PI;

        let sky = inscattered_rayleigh * rayleigh_phase + inscattered_mie * mie_phase;

        // Add sun disk
        let sun = self.render_sun_disk(view_dir, sun_dir, transmittance);

        sky * self.params.sun_intensity + sun
    }

    fn rayleigh_phase(cos_theta: f32) -> f32 {
        // p(θ) = 3/(16π) * (1 + cos²θ)
        (3.0 / (16.0 * core::f32::consts::PI)) * (1.0 + cos_theta * cos_theta)
    }

    fn ray_atmosphere_intersection(&self, height: f32, cos_zenith: f32) -> f32 {
        let r = self.params.planet_radius + height;
        let r_top = self.params.planet_radius + self.params.atmosphere_height;

        let mu = cos_zenith;
        let discriminant = r * r * (mu * mu - 1.0) + r_top * r_top;

        if discriminant < 0.0 {
            return 0.0;
        }

        (-r * mu + discriminant.sqrt()).max(0.0)
    }

    fn get_height_at_distance(&self, start_height: f32, cos_zenith: f32, distance: f32) -> f32 {
        let r = self.params.planet_radius + start_height;
        let mu = cos_zenith;

        ((r + distance * mu).powi(2) + distance * distance * (1.0 - mu * mu)).sqrt()
            - self.params.planet_radius
    }

    fn sample_transmittance_lut(&self, height: f32, cos_zenith: f32) -> Vec3 {
        let u = (cos_zenith + 1.0) * 0.5;
        let v = height / self.params.atmosphere_height;

        let color = self.transmittance_lut.sample_2d(Vec2::new(u.clamp(0.0, 1.0), v.clamp(0.0, 1.0)));
        Vec3::new(color, color, color)
    }

    fn render_sun_disk(&self, view_dir: Vec3, sun_dir: Vec3, transmittance: Vec3) -> Vec3 {
        let cos_angle = view_dir.dot(sun_dir);
        let cos_sun_radius = (self.params.sun_angular_diameter * 0.5).cos();

        if cos_angle >= cos_sun_radius {
            // Inside sun disk - apply limb darkening
            let center_dist = ((1.0 - cos_angle) / (1.0 - cos_sun_radius)).sqrt();
            let limb_darkening = 1.0 - 0.6 * (1.0 - (1.0 - center_dist * center_dist).sqrt());

            transmittance * self.params.sun_intensity * limb_darkening * 1000.0
        } else {
            Vec3::zero()
        }
    }
}

// =============================================================================
// GOD RAYS / LIGHT SHAFTS
// =============================================================================

/// God rays renderer (screen-space light shafts)
pub struct GodRaysRenderer {
    /// Light source position (screen space or world)
    light_position: Vec3,
    /// Number of samples along ray
    num_samples: u32,
    /// Decay factor per sample
    decay: f32,
    /// Exposure/brightness
    exposure: f32,
    /// Weight of effect
    weight: f32,
    /// Density of rays
    density: f32,
}

impl GodRaysRenderer {
    pub fn new() -> Self {
        Self {
            light_position: Vec3::zero(),
            num_samples: 100,
            decay: 0.96,
            exposure: 0.3,
            weight: 0.5,
            density: 0.97,
        }
    }

    /// Render god rays (screen-space radial blur toward light)
    pub fn render(
        &self,
        input_texture: &Texture3D,
        occlusion_texture: &Texture3D,
        light_screen_pos: Vec2,
        output_size: Vec2<u32>,
    ) -> Texture3D {
        let mut output = Texture3D::new(output_size.x, output_size.y, 1);

        for y in 0..output_size.y {
            for x in 0..output_size.x {
                let uv = Vec2::new(
                    x as f32 / output_size.x as f32,
                    y as f32 / output_size.y as f32
                );

                let color = self.sample_ray(uv, light_screen_pos, occlusion_texture);
                output.set_pixel(x, y, 0, color);
            }
        }

        output
    }

    fn sample_ray(&self, uv: Vec2, light_pos: Vec2, occlusion: &Texture3D) -> Vec4 {
        let delta = (uv - light_pos) * (1.0 / self.num_samples as f32) * self.density;

        let mut sample_pos = uv;
        let mut illumination_decay = 1.0;
        let mut accumulated = Vec3::zero();

        for _ in 0..self.num_samples {
            sample_pos = sample_pos - delta;

            // Sample occlusion (where light is visible through gaps)
            let sample = occlusion.sample_2d(sample_pos);

            // Accumulate weighted sample
            accumulated = accumulated + Vec3::splat(sample) * illumination_decay * self.weight;

            // Decay for next sample
            illumination_decay *= self.decay;
        }

        accumulated = accumulated * self.exposure;

        Vec4::new(accumulated.x, accumulated.y, accumulated.z, 1.0)
    }
}

// =============================================================================
// SPARSE VOXEL FOG (WP-084)
// =============================================================================

/// Sparse voxel fog using octree structure
pub struct SparseVoxelFog {
    /// Octree root
    root: OctreeNode,
    /// World-space bounds
    bounds: AABB,
    /// Maximum depth of octree
    max_depth: u32,
    /// Minimum fog density threshold for subdivision
    density_threshold: f32,
    /// Base fog parameters
    fog_params: FogParams,
}

/// Octree node for sparse fog
pub enum OctreeNode {
    /// Leaf node with fog density
    Leaf {
        density: f32,
        color: Vec3,
    },
    /// Internal node with 8 children
    Internal {
        children: Box<[OctreeNode; 8]>,
        avg_density: f32,
    },
    /// Empty node (no fog)
    Empty,
}

/// Fog parameters
pub struct FogParams {
    /// Fog color
    pub color: Vec3,
    /// Global density
    pub density: f32,
    /// Height-based falloff start
    pub height_start: f32,
    /// Height-based falloff end
    pub height_end: f32,
    /// Distance falloff start
    pub distance_start: f32,
    /// Distance falloff end
    pub distance_end: f32,
    /// Inscattering coefficient
    pub inscattering: f32,
}

impl SparseVoxelFog {
    pub fn new(bounds: AABB, max_depth: u32, fog_params: FogParams) -> Self {
        Self {
            root: OctreeNode::Empty,
            bounds,
            max_depth,
            density_threshold: 0.001,
            fog_params,
        }
    }

    /// Build octree from density function
    pub fn build_from_density<F>(&mut self, density_fn: F)
    where
        F: Fn(Vec3) -> f32,
    {
        self.root = self.build_node(&density_fn, self.bounds, 0);
    }

    fn build_node<F>(&self, density_fn: &F, bounds: AABB, depth: u32) -> OctreeNode
    where
        F: Fn(Vec3) -> f32,
    {
        let center = (bounds.min + bounds.max) * 0.5;
        let density = density_fn(center);

        if depth >= self.max_depth || density < self.density_threshold {
            if density < self.density_threshold {
                OctreeNode::Empty
            } else {
                OctreeNode::Leaf {
                    density,
                    color: self.fog_params.color,
                }
            }
        } else {
            // Subdivide
            let children = self.create_children(density_fn, bounds, depth);

            // Check if all children are similar enough to merge
            if self.should_merge(&children) {
                OctreeNode::Leaf {
                    density,
                    color: self.fog_params.color,
                }
            } else {
                let avg = self.compute_average_density(&children);
                OctreeNode::Internal {
                    children: Box::new(children),
                    avg_density: avg,
                }
            }
        }
    }

    fn create_children<F>(&self, density_fn: &F, bounds: AABB, depth: u32) -> [OctreeNode; 8]
    where
        F: Fn(Vec3) -> f32,
    {
        let center = (bounds.min + bounds.max) * 0.5;

        let child_bounds = [
            AABB::new(bounds.min, center),
            AABB::new(Vec3::new(center.x, bounds.min.y, bounds.min.z),
                     Vec3::new(bounds.max.x, center.y, center.z)),
            AABB::new(Vec3::new(bounds.min.x, center.y, bounds.min.z),
                     Vec3::new(center.x, bounds.max.y, center.z)),
            AABB::new(Vec3::new(center.x, center.y, bounds.min.z),
                     Vec3::new(bounds.max.x, bounds.max.y, center.z)),
            AABB::new(Vec3::new(bounds.min.x, bounds.min.y, center.z),
                     Vec3::new(center.x, center.y, bounds.max.z)),
            AABB::new(Vec3::new(center.x, bounds.min.y, center.z),
                     Vec3::new(bounds.max.x, center.y, bounds.max.z)),
            AABB::new(Vec3::new(bounds.min.x, center.y, center.z),
                     Vec3::new(center.x, bounds.max.y, bounds.max.z)),
            AABB::new(center, bounds.max),
        ];

        [
            self.build_node(density_fn, child_bounds[0], depth + 1),
            self.build_node(density_fn, child_bounds[1], depth + 1),
            self.build_node(density_fn, child_bounds[2], depth + 1),
            self.build_node(density_fn, child_bounds[3], depth + 1),
            self.build_node(density_fn, child_bounds[4], depth + 1),
            self.build_node(density_fn, child_bounds[5], depth + 1),
            self.build_node(density_fn, child_bounds[6], depth + 1),
            self.build_node(density_fn, child_bounds[7], depth + 1),
        ]
    }

    fn should_merge(&self, children: &[OctreeNode; 8]) -> bool {
        let mut all_leaves = true;
        let mut densities = Vec::new();

        for child in children {
            match child {
                OctreeNode::Leaf { density, .. } => densities.push(*density),
                OctreeNode::Empty => densities.push(0.0),
                OctreeNode::Internal { .. } => all_leaves = false,
            }
        }

        if !all_leaves {
            return false;
        }

        // Check variance
        let mean: f32 = densities.iter().sum::<f32>() / 8.0;
        let variance: f32 = densities.iter().map(|d| (d - mean).powi(2)).sum::<f32>() / 8.0;

        variance < 0.01 * mean * mean
    }

    fn compute_average_density(&self, children: &[OctreeNode; 8]) -> f32 {
        let mut sum = 0.0;
        let mut count = 0;

        for child in children {
            match child {
                OctreeNode::Leaf { density, .. } => {
                    sum += density;
                    count += 1;
                }
                OctreeNode::Internal { avg_density, .. } => {
                    sum += avg_density;
                    count += 1;
                }
                OctreeNode::Empty => {}
            }
        }

        if count > 0 { sum / count as f32 } else { 0.0 }
    }

    /// Sample fog at a world position
    pub fn sample(&self, position: Vec3) -> (f32, Vec3) {
        if !self.bounds.contains(position) {
            return (0.0, Vec3::zero());
        }

        self.sample_node(&self.root, position, self.bounds)
    }

    fn sample_node(&self, node: &OctreeNode, position: Vec3, bounds: AABB) -> (f32, Vec3) {
        match node {
            OctreeNode::Empty => (0.0, Vec3::zero()),
            OctreeNode::Leaf { density, color } => (*density, *color),
            OctreeNode::Internal { children, .. } => {
                let center = (bounds.min + bounds.max) * 0.5;

                // Determine which child contains the position
                let child_index =
                    ((position.x >= center.x) as usize) |
                    (((position.y >= center.y) as usize) << 1) |
                    (((position.z >= center.z) as usize) << 2);

                let child_bounds = self.get_child_bounds(bounds, child_index);
                self.sample_node(&children[child_index], position, child_bounds)
            }
        }
    }

    fn get_child_bounds(&self, parent: AABB, index: usize) -> AABB {
        let center = (parent.min + parent.max) * 0.5;

        let min = Vec3::new(
            if index & 1 == 0 { parent.min.x } else { center.x },
            if index & 2 == 0 { parent.min.y } else { center.y },
            if index & 4 == 0 { parent.min.z } else { center.z },
        );

        let max = Vec3::new(
            if index & 1 == 0 { center.x } else { parent.max.x },
            if index & 2 == 0 { center.y } else { parent.max.y },
            if index & 4 == 0 { center.z } else { parent.max.z },
        );

        AABB::new(min, max)
    }

    /// Ray march through sparse voxel fog
    pub fn raymarch(
        &self,
        origin: Vec3,
        direction: Vec3,
        max_distance: f32,
        num_steps: u32,
    ) -> (Vec3, f32) {
        let step_size = max_distance / num_steps as f32;

        let mut accumulated_color = Vec3::zero();
        let mut transmittance = 1.0;

        for i in 0..num_steps {
            let t = (i as f32 + 0.5) * step_size;
            let pos = origin + direction * t;

            let (density, color) = self.sample(pos);

            if density > 0.0 {
                let extinction = density * self.fog_params.inscattering;
                let segment_transmittance = (-extinction * step_size).exp();

                // Integrate in-scattering
                let inscattered = color * density * (1.0 - segment_transmittance);
                accumulated_color = accumulated_color + inscattered * transmittance;

                transmittance *= segment_transmittance;

                if transmittance < 0.01 {
                    break;
                }
            }
        }

        (accumulated_color, transmittance)
    }
}

// =============================================================================
// VOLUMETRIC FIRE AND SMOKE (WP-077)
// =============================================================================

/// Volumetric fire and smoke simulation
pub struct VolumetricFire {
    /// Temperature field (3D)
    temperature: Texture3D,
    /// Density field (3D)
    density: Texture3D,
    /// Velocity field for advection
    velocity: Texture3D,
    /// World-space bounds
    bounds: AABB,
    /// Grid resolution
    resolution: Vec3<u32>,
    /// Simulation parameters
    params: FireParams,
}

/// Fire simulation parameters
pub struct FireParams {
    /// Combustion temperature threshold
    ignition_temperature: f32,
    /// Maximum temperature
    max_temperature: f32,
    /// Cooling rate
    cooling_rate: f32,
    /// Fuel consumption rate
    burn_rate: f32,
    /// Smoke generation rate
    smoke_rate: f32,
    /// Buoyancy coefficient
    buoyancy: f32,
    /// Turbulence strength
    turbulence: f32,
    /// Emission color ramp (temperature -> color)
    emission_ramp: Vec<(f32, Vec3)>,
}

impl VolumetricFire {
    pub fn new(bounds: AABB, resolution: Vec3<u32>, params: FireParams) -> Self {
        let size = (resolution.x * resolution.y * resolution.z) as usize;

        Self {
            temperature: Texture3D::new(resolution.x, resolution.y, resolution.z),
            density: Texture3D::new(resolution.x, resolution.y, resolution.z),
            velocity: Texture3D::new(resolution.x, resolution.y, resolution.z),
            bounds,
            resolution,
            params,
        }
    }

    /// Set initial fire source
    pub fn ignite(&mut self, position: Vec3, radius: f32, temperature: f32) {
        let local_pos = self.world_to_local(position);
        let local_radius = radius / self.voxel_size();

        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let voxel_pos = Vec3::new(x as f32, y as f32, z as f32);
                    let dist = (voxel_pos - local_pos).length();

                    if dist < local_radius {
                        let falloff = 1.0 - (dist / local_radius);
                        let temp = temperature * falloff * falloff;

                        self.temperature.set_pixel(x, y, z, Vec4::splat(temp));
                        self.density.set_pixel(x, y, z, Vec4::splat(1.0));
                    }
                }
            }
        }
    }

    fn world_to_local(&self, world: Vec3) -> Vec3 {
        let size = self.bounds.max - self.bounds.min;
        Vec3::new(
            (world.x - self.bounds.min.x) / size.x * self.resolution.x as f32,
            (world.y - self.bounds.min.y) / size.y * self.resolution.y as f32,
            (world.z - self.bounds.min.z) / size.z * self.resolution.z as f32
        )
    }

    fn local_to_world(&self, local: Vec3) -> Vec3 {
        let size = self.bounds.max - self.bounds.min;
        Vec3::new(
            local.x / self.resolution.x as f32 * size.x + self.bounds.min.x,
            local.y / self.resolution.y as f32 * size.y + self.bounds.min.y,
            local.z / self.resolution.z as f32 * size.z + self.bounds.min.z
        )
    }

    fn voxel_size(&self) -> f32 {
        let size = self.bounds.max - self.bounds.min;
        size.x / self.resolution.x as f32
    }

    /// Step the simulation forward
    pub fn simulate(&mut self, dt: f32) {
        // 1. Advect density and temperature by velocity
        self.advect(dt);

        // 2. Add buoyancy force
        self.apply_buoyancy(dt);

        // 3. Add turbulence
        self.apply_turbulence(dt);

        // 4. Combustion (convert fuel to temperature and smoke)
        self.combust(dt);

        // 5. Cooling
        self.cool(dt);

        // 6. Dissipate smoke
        self.dissipate(dt);
    }

    fn advect(&mut self, dt: f32) {
        let mut new_temperature = Texture3D::new(
            self.resolution.x, self.resolution.y, self.resolution.z
        );
        let mut new_density = Texture3D::new(
            self.resolution.x, self.resolution.y, self.resolution.z
        );

        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let pos = Vec3::new(x as f32, y as f32, z as f32);
                    let vel = self.sample_velocity(pos);

                    // Trace back
                    let prev_pos = pos - vel * dt;

                    let temp = self.sample_temperature(prev_pos);
                    let dens = self.sample_density_field(prev_pos);

                    new_temperature.set_pixel(x, y, z, Vec4::splat(temp));
                    new_density.set_pixel(x, y, z, Vec4::splat(dens));
                }
            }
        }

        self.temperature = new_temperature;
        self.density = new_density;
    }

    fn apply_buoyancy(&mut self, dt: f32) {
        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let temp = self.temperature.sample_point(Vec3::new(x, y, z)).x;
                    let dens = self.density.sample_point(Vec3::new(x, y, z)).x;

                    // Buoyancy: hot air rises, dense smoke sinks
                    let buoyancy_force = (temp / self.params.max_temperature) * self.params.buoyancy
                                        - dens * 0.1;

                    let current_vel = self.velocity.sample_point(Vec3::new(x, y, z));
                    let new_vel = Vec4::new(
                        current_vel.x,
                        current_vel.y + buoyancy_force * dt,
                        current_vel.z,
                        0.0
                    );

                    self.velocity.set_pixel(x, y, z, new_vel);
                }
            }
        }
    }

    fn apply_turbulence(&mut self, dt: f32) {
        let time = self.params.turbulence; // Use as time seed

        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let pos = Vec3::new(x as f32, y as f32, z as f32);

                    // Curl noise for turbulence
                    let noise = self.curl_noise(pos * 0.1, time);

                    let current_vel = self.velocity.sample_point(Vec3::new(x, y, z));
                    let new_vel = Vec4::new(
                        current_vel.x + noise.x * self.params.turbulence * dt,
                        current_vel.y + noise.y * self.params.turbulence * dt,
                        current_vel.z + noise.z * self.params.turbulence * dt,
                        0.0
                    );

                    self.velocity.set_pixel(x, y, z, new_vel);
                }
            }
        }
    }

    fn curl_noise(&self, pos: Vec3, time: f32) -> Vec3 {
        // Simplified curl noise using gradient of noise field
        let eps = 0.01;

        let n_x0 = self.noise3d(Vec3::new(pos.x - eps, pos.y, pos.z), time);
        let n_x1 = self.noise3d(Vec3::new(pos.x + eps, pos.y, pos.z), time);
        let n_y0 = self.noise3d(Vec3::new(pos.x, pos.y - eps, pos.z), time);
        let n_y1 = self.noise3d(Vec3::new(pos.x, pos.y + eps, pos.z), time);
        let n_z0 = self.noise3d(Vec3::new(pos.x, pos.y, pos.z - eps), time);
        let n_z1 = self.noise3d(Vec3::new(pos.x, pos.y, pos.z + eps), time);

        Vec3::new(
            (n_y1 - n_y0) - (n_z1 - n_z0),
            (n_z1 - n_z0) - (n_x1 - n_x0),
            (n_x1 - n_x0) - (n_y1 - n_y0)
        ) / (2.0 * eps)
    }

    fn noise3d(&self, pos: Vec3, time: f32) -> f32 {
        // Simple hash-based noise
        let p = pos + Vec3::splat(time);
        let hash = (p.x * 12.9898 + p.y * 78.233 + p.z * 45.164).sin() * 43758.5453;
        hash.fract()
    }

    fn combust(&mut self, dt: f32) {
        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let temp = self.temperature.sample_point(Vec3::new(x, y, z)).x;
                    let dens = self.density.sample_point(Vec3::new(x, y, z)).x;

                    if temp > self.params.ignition_temperature && dens > 0.0 {
                        // Burn fuel
                        let burn_amount = self.params.burn_rate * dt;
                        let new_dens = (dens - burn_amount).max(0.0);

                        // Generate heat
                        let heat_generated = burn_amount *
                            (self.params.max_temperature - temp);
                        let new_temp = (temp + heat_generated)
                            .min(self.params.max_temperature);

                        self.temperature.set_pixel(x, y, z, Vec4::splat(new_temp));
                        self.density.set_pixel(x, y, z, Vec4::splat(new_dens));
                    }
                }
            }
        }
    }

    fn cool(&mut self, dt: f32) {
        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let temp = self.temperature.sample_point(Vec3::new(x, y, z)).x;
                    let new_temp = temp * (1.0 - self.params.cooling_rate * dt);
                    self.temperature.set_pixel(x, y, z, Vec4::splat(new_temp.max(0.0)));
                }
            }
        }
    }

    fn dissipate(&mut self, dt: f32) {
        for z in 0..self.resolution.z {
            for y in 0..self.resolution.y {
                for x in 0..self.resolution.x {
                    let dens = self.density.sample_point(Vec3::new(x, y, z)).x;
                    let new_dens = dens * (1.0 - self.params.smoke_rate * dt);
                    self.density.set_pixel(x, y, z, Vec4::splat(new_dens.max(0.0)));
                }
            }
        }
    }

    fn sample_velocity(&self, pos: Vec3) -> Vec3 {
        let v = self.velocity.sample_trilinear(pos /
            Vec3::new(self.resolution.x as f32, self.resolution.y as f32, self.resolution.z as f32));
        Vec3::new(v.x, v.y, v.z)
    }

    fn sample_temperature(&self, pos: Vec3) -> f32 {
        let normalized = pos /
            Vec3::new(self.resolution.x as f32, self.resolution.y as f32, self.resolution.z as f32);
        self.temperature.sample_trilinear(normalized).x
    }

    fn sample_density_field(&self, pos: Vec3) -> f32 {
        let normalized = pos /
            Vec3::new(self.resolution.x as f32, self.resolution.y as f32, self.resolution.z as f32);
        self.density.sample_trilinear(normalized).x
    }

    /// Get emission color for a temperature
    pub fn temperature_to_emission(&self, temp: f32) -> Vec3 {
        // Interpolate through color ramp
        let normalized_temp = (temp / self.params.max_temperature).clamp(0.0, 1.0);

        for i in 0..self.params.emission_ramp.len() - 1 {
            let (t0, c0) = self.params.emission_ramp[i];
            let (t1, c1) = self.params.emission_ramp[i + 1];

            if normalized_temp >= t0 && normalized_temp <= t1 {
                let blend = (normalized_temp - t0) / (t1 - t0);
                return c0.lerp(c1, blend);
            }
        }

        self.params.emission_ramp.last().map(|(_, c)| *c).unwrap_or(Vec3::zero())
    }

    /// Ray march through fire volume for rendering
    pub fn raymarch(
        &self,
        origin: Vec3,
        direction: Vec3,
        max_distance: f32,
        num_steps: u32,
    ) -> (Vec3, Vec3, f32) {
        let step_size = max_distance / num_steps as f32;

        let mut emission = Vec3::zero();
        let mut inscattered = Vec3::zero();
        let mut transmittance = 1.0;

        for i in 0..num_steps {
            let t = (i as f32 + 0.5) * step_size;
            let world_pos = origin + direction * t;

            if !self.bounds.contains(world_pos) {
                continue;
            }

            let local_pos = self.world_to_local(world_pos);
            let temp = self.sample_temperature(local_pos);
            let dens = self.sample_density_field(local_pos);

            if dens > 0.001 || temp > 0.001 {
                // Smoke extinction
                let extinction = dens * 2.0;
                let segment_transmittance = (-extinction * step_size).exp();

                // Fire emission
                if temp > self.params.ignition_temperature * 0.5 {
                    let emit_color = self.temperature_to_emission(temp);
                    let emit_intensity = (temp / self.params.max_temperature).powi(2);
                    emission = emission + emit_color * emit_intensity * transmittance * step_size;
                }

                // Smoke inscattering (ambient light contribution)
                let smoke_color = Vec3::new(0.1, 0.1, 0.1);
                inscattered = inscattered +
                    smoke_color * dens * (1.0 - segment_transmittance) * transmittance;

                transmittance *= segment_transmittance;

                if transmittance < 0.01 {
                    break;
                }
            }
        }

        (emission, inscattered, transmittance)
    }
}

impl FireParams {
    pub fn default_fire() -> Self {
        Self {
            ignition_temperature: 500.0,
            max_temperature: 2000.0,
            cooling_rate: 0.5,
            burn_rate: 0.2,
            smoke_rate: 0.1,
            buoyancy: 10.0,
            turbulence: 2.0,
            emission_ramp: vec![
                (0.0, Vec3::zero()),
                (0.2, Vec3::new(0.5, 0.0, 0.0)),    // Dark red
                (0.4, Vec3::new(1.0, 0.2, 0.0)),    // Orange-red
                (0.6, Vec3::new(1.0, 0.6, 0.0)),    // Orange
                (0.8, Vec3::new(1.0, 0.9, 0.3)),    // Yellow
                (1.0, Vec3::new(1.0, 1.0, 0.8)),    // White-hot
            ],
        }
    }

    pub fn campfire() -> Self {
        let mut params = Self::default_fire();
        params.max_temperature = 1500.0;
        params.turbulence = 1.0;
        params
    }

    pub fn explosion() -> Self {
        Self {
            ignition_temperature: 300.0,
            max_temperature: 3000.0,
            cooling_rate: 2.0,
            burn_rate: 1.0,
            smoke_rate: 0.3,
            buoyancy: 20.0,
            turbulence: 5.0,
            emission_ramp: vec![
                (0.0, Vec3::zero()),
                (0.1, Vec3::new(0.3, 0.0, 0.0)),
                (0.3, Vec3::new(1.0, 0.3, 0.0)),
                (0.5, Vec3::new(1.0, 0.7, 0.2)),
                (0.7, Vec3::new(1.0, 1.0, 0.5)),
                (1.0, Vec3::new(1.0, 1.0, 1.0)),
            ],
        }
    }
}

// =============================================================================
// HELPER TRAIT IMPLEMENTATIONS
// =============================================================================

impl Vec3 {
    pub fn zero() -> Self {
        Vec3::new(0.0, 0.0, 0.0)
    }

    pub fn one() -> Self {
        Vec3::new(1.0, 1.0, 1.0)
    }

    pub fn splat(v: f32) -> Self {
        Vec3::new(v, v, v)
    }

    pub fn luminance(&self) -> f32 {
        self.x * 0.2126 + self.y * 0.7152 + self.z * 0.0722
    }

    pub fn lerp(&self, other: Self, t: f32) -> Self {
        Vec3::new(
            self.x + (other.x - self.x) * t,
            self.y + (other.y - self.y) * t,
            self.z + (other.z - self.z) * t
        )
    }
}

impl Vec4 {
    pub fn splat(v: f32) -> Self {
        Vec4::new(v, v, v, v)
    }

    pub fn lerp(&self, other: Self, t: f32) -> Self {
        Vec4::new(
            self.x + (other.x - self.x) * t,
            self.y + (other.y - self.y) * t,
            self.z + (other.z - self.z) * t,
            self.w + (other.w - self.w) * t
        )
    }
}

// =============================================================================
// TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_froxel_grid_creation() {
        let config = VolumetricConfig::default();
        let grid = FroxelGrid::new(&config);

        assert_eq!(grid.dimensions.x, 160);
        assert_eq!(grid.dimensions.y, 90);
        assert_eq!(grid.dimensions.z, 128);
        assert_eq!(grid.slice_depths.len(), 129);
    }

    #[test]
    fn test_phase_functions() {
        let hg = PhaseFunction::HenyeyGreenstein { g: 0.8 };

        // Forward scattering should be high
        let forward = hg.evaluate(1.0);
        let backward = hg.evaluate(-1.0);
        assert!(forward > backward);

        // Isotropic should be constant
        let iso = PhaseFunction::Isotropic;
        let p1 = iso.evaluate(0.5);
        let p2 = iso.evaluate(-0.5);
        assert!((p1 - p2).abs() < 0.0001);
    }

    #[test]
    fn test_aabb_intersection() {
        let aabb = AABB::new(Vec3::new(-1.0, -1.0, -1.0), Vec3::new(1.0, 1.0, 1.0));

        // Ray through center
        let origin = Vec3::new(0.0, 0.0, -5.0);
        let dir = Vec3::new(0.0, 0.0, 1.0);

        let hit = aabb.intersect_ray(origin, dir);
        assert!(hit.is_some());

        let (tmin, tmax) = hit.unwrap();
        assert!((tmin - 4.0).abs() < 0.0001);
        assert!((tmax - 6.0).abs() < 0.0001);
    }

    #[test]
    fn test_atmospheric_scattering() {
        let params = AtmosphereParams::earth();
        let atmosphere = AtmosphericScattering::new(params);

        // Sky should be blue at zenith during day
        let view_up = Vec3::new(0.0, 1.0, 0.0);
        let sun_high = Vec3::new(0.0, 1.0, 0.0);

        let sky_color = atmosphere.render_sky(view_up, sun_high, 0.0);

        // Blue channel should dominate for overhead sun
        assert!(sky_color.z > sky_color.x);
    }

    #[test]
    fn test_sparse_voxel_fog() {
        let bounds = AABB::new(Vec3::new(-10.0, -10.0, -10.0), Vec3::new(10.0, 10.0, 10.0));
        let fog_params = FogParams {
            color: Vec3::new(0.8, 0.85, 0.9),
            density: 0.1,
            height_start: 0.0,
            height_end: 5.0,
            distance_start: 0.0,
            distance_end: 100.0,
            inscattering: 0.5,
        };

        let mut fog = SparseVoxelFog::new(bounds, 4, fog_params);

        // Build with uniform density
        fog.build_from_density(|_| 0.5);

        let (density, _) = fog.sample(Vec3::zero());
        assert!(density > 0.0);
    }

    #[test]
    fn test_fire_ignition() {
        let bounds = AABB::new(Vec3::new(-5.0, 0.0, -5.0), Vec3::new(5.0, 10.0, 5.0));
        let params = FireParams::default_fire();
        let mut fire = VolumetricFire::new(bounds, Vec3::new(32, 64, 32), params);

        // Ignite at center
        fire.ignite(Vec3::new(0.0, 1.0, 0.0), 1.0, 1000.0);

        // Check temperature was set
        let temp = fire.sample_temperature(
            fire.world_to_local(Vec3::new(0.0, 1.0, 0.0))
        );
        assert!(temp > 0.0);
    }
}
