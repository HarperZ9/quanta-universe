/// Configuration for a single cloud layer
pub struct CloudLayerConfig {
    /// Cloud layer type
    pub layer_type: CloudLayerType,
    /// Layer bottom altitude in meters
    pub altitude_bottom: f32,
    /// Layer top altitude in meters
    pub altitude_top: f32,
    /// Cloud coverage (0-1)
    pub coverage: f32,
    /// Cloud density multiplier
    pub density: f32,
    /// Absorption coefficient
    pub absorption: f32,
    /// Scattering albedo
    pub scatter_albedo: f32,
    /// Forward scattering (HG phase function g)
    pub eccentricity: f32,
    /// Base shape scale
    pub shape_scale: f32,
    /// Detail noise scale
    pub detail_scale: f32,
    /// Detail noise strength
    pub detail_strength: f32,
    /// Wind direction and speed (XY direction, Z speed)
    pub wind: Vec3,
    /// Curl noise strength for detail displacement
    pub curl_strength: f32,
    /// Height gradient remap curve
    pub height_gradient: HeightGradient,
    /// Anvil deformation for cumulonimbus
    pub anvil_bias: f32,
    /// Enable precipitation darkening
    pub precipitation_darkening: bool,
}

impl CloudLayerConfig {
    /// Create configuration for cumulus clouds
    pub fn cumulus() -> Self {
        Self {
            layer_type: CloudLayerType::Cumulus,
            altitude_bottom: 1500.0,
            altitude_top: 3500.0,
            coverage: 0.5,
            density: 0.3,
            absorption: 0.04,
            scatter_albedo: 0.99,
            eccentricity: 0.6,
            shape_scale: 0.0003,
            detail_scale: 0.002,
            detail_strength: 0.35,
            wind: Vec3::new(1.0, 0.0, 20.0),
            curl_strength: 0.1,
            height_gradient: HeightGradient::cumulus(),
            anvil_bias: 0.0,
            precipitation_darkening: false,
        }
    }

    /// Create configuration for stratocumulus clouds
    pub fn stratocumulus() -> Self {
        Self {
            layer_type: CloudLayerType::Stratocumulus,
            altitude_bottom: 800.0,
            altitude_top: 2000.0,
            coverage: 0.7,
            density: 0.4,
            absorption: 0.05,
            scatter_albedo: 0.98,
            eccentricity: 0.5,
            shape_scale: 0.0002,
            detail_scale: 0.0015,
            detail_strength: 0.4,
            wind: Vec3::new(1.0, 0.2, 15.0),
            curl_strength: 0.08,
            height_gradient: HeightGradient::stratocumulus(),
            anvil_bias: 0.0,
            precipitation_darkening: false,
        }
    }

    /// Create configuration for stratus clouds
    pub fn stratus() -> Self {
        Self {
            layer_type: CloudLayerType::Stratus,
            altitude_bottom: 200.0,
            altitude_top: 1500.0,
            coverage: 0.9,
            density: 0.5,
            absorption: 0.06,
            scatter_albedo: 0.97,
            eccentricity: 0.4,
            shape_scale: 0.00015,
            detail_scale: 0.001,
            detail_strength: 0.2,
            wind: Vec3::new(1.0, 0.0, 10.0),
            curl_strength: 0.05,
            height_gradient: HeightGradient::stratus(),
            anvil_bias: 0.0,
            precipitation_darkening: true,
        }
    }

    /// Create configuration for cirrus clouds
    pub fn cirrus() -> Self {
        Self {
            layer_type: CloudLayerType::Cirrus,
            altitude_bottom: 8000.0,
            altitude_top: 12000.0,
            coverage: 0.3,
            density: 0.05,
            absorption: 0.01,
            scatter_albedo: 0.995,
            eccentricity: 0.8,
            shape_scale: 0.00005,
            detail_scale: 0.0005,
            detail_strength: 0.6,
            wind: Vec3::new(1.0, 0.5, 50.0),
            curl_strength: 0.2,
            height_gradient: HeightGradient::cirrus(),
            anvil_bias: 0.0,
            precipitation_darkening: false,
        }
    }

    /// Create configuration for cumulonimbus (storm) clouds
    pub fn cumulonimbus() -> Self {
        Self {
            layer_type: CloudLayerType::Cumulonimbus,
            altitude_bottom: 500.0,
            altitude_top: 12000.0,
            coverage: 0.3,
            density: 0.6,
            absorption: 0.08,
            scatter_albedo: 0.96,
            eccentricity: 0.5,
            shape_scale: 0.0002,
            detail_scale: 0.0012,
            detail_strength: 0.3,
            wind: Vec3::new(1.0, 0.0, 30.0),
            curl_strength: 0.15,
            height_gradient: HeightGradient::cumulonimbus(),
            anvil_bias: 0.3,
            precipitation_darkening: true,
        }
    }
}

/// Height gradient curve for cloud density falloff
pub struct HeightGradient {
    /// Gradient points (normalized height -> density multiplier)
    pub points: [(f32, f32); 8],
    /// Number of active points
    pub point_count: u32,
}

impl HeightGradient {
    /// Create cumulus height gradient (rounded bottom, fluffy top)
    pub fn cumulus() -> Self {
        Self {
            points: [
                (0.0, 0.0),
                (0.1, 0.6),
                (0.2, 1.0),
                (0.4, 1.0),
                (0.7, 0.6),
                (0.9, 0.2),
                (1.0, 0.0),
                (1.0, 0.0),
            ],
            point_count: 7,
        }
    }

    /// Create stratocumulus height gradient
    pub fn stratocumulus() -> Self {
        Self {
            points: [
                (0.0, 0.0),
                (0.1, 0.8),
                (0.3, 1.0),
                (0.6, 1.0),
                (0.8, 0.6),
                (1.0, 0.0),
                (1.0, 0.0),
                (1.0, 0.0),
            ],
            point_count: 6,
        }
    }

    /// Create stratus height gradient (uniform layer)
    pub fn stratus() -> Self {
        Self {
            points: [
                (0.0, 0.2),
                (0.1, 0.9),
                (0.2, 1.0),
                (0.8, 1.0),
                (0.9, 0.9),
                (1.0, 0.2),
                (1.0, 0.0),
                (1.0, 0.0),
            ],
            point_count: 6,
        }
    }

    /// Create cirrus height gradient (wispy)
    pub fn cirrus() -> Self {
        Self {
            points: [
                (0.0, 0.0),
                (0.2, 0.5),
                (0.4, 1.0),
                (0.6, 1.0),
                (0.8, 0.5),
                (1.0, 0.0),
                (1.0, 0.0),
                (1.0, 0.0),
            ],
            point_count: 6,
        }
    }

    /// Create cumulonimbus height gradient (tower with anvil)
    pub fn cumulonimbus() -> Self {
        Self {
            points: [
                (0.0, 0.0),
                (0.05, 0.5),
                (0.1, 1.0),
                (0.5, 1.0),
                (0.7, 0.8),
                (0.85, 0.5),
                (0.95, 0.8), // Anvil
                (1.0, 0.3),
            ],
            point_count: 8,
        }
    }

    /// Sample the gradient at normalized height
    pub fn sample(&self, height: f32) -> f32 {
        let height = height.clamp(0.0, 1.0);

        for i in 0..(self.point_count as usize - 1) {
            let (h0, v0) = self.points[i];
            let (h1, v1) = self.points[i + 1];

            if height >= h0 && height <= h1 {
                let t = (height - h0) / (h1 - h0);
                return v0 + t * (v1 - v0);
            }
        }

        0.0
    }
}

// =============================================================================
// REGION: VOLUMETRIC CLOUD RENDERER
