// TEMPORAL ANTI-ALIASING (WP-003)
// ═══════════════════════════════════════════════════════════════════════════════

/// TAA quality preset
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TAAQuality {
    Low,       // 4 samples, no variance clipping
    Medium,    // 8 samples, simple variance clip
    High,      // 16 samples, full variance clip + sharpening
    Ultra,     // 32 samples, everything + subpixel refinement
}

/// TAA configuration
#[derive(Debug, Clone)]
pub struct TAAConfig {
    pub quality: TAAQuality,
    pub feedback_min: f32,
    pub feedback_max: f32,
    pub variance_clip_gamma: f32,
    pub velocity_weight: f32,
    pub depth_weight: f32,
    pub sharpen_strength: f32,
    pub anti_flicker: bool,
    pub motion_blur_strength: f32,
}

impl Default for TAAConfig {
    fn default() -> Self {
        TAAConfig {
            quality: TAAQuality::High,
            feedback_min: 0.88,
            feedback_max: 0.97,
            variance_clip_gamma: 1.0,
            velocity_weight: 8000.0,
            depth_weight: 1000.0,
            sharpen_strength: 0.25,
            anti_flicker: true,
            motion_blur_strength: 0.0,
        }
    }
}

/// Jitter sequence for subpixel sampling
pub struct JitterSequence {
    samples: Vec<Vec2>,
    current_index: usize,
}

impl JitterSequence {
    /// Halton sequence for low-discrepancy sampling
    pub fn halton(count: usize) -> Self {
        let mut samples = Vec::with_capacity(count);

        for i in 0..count {
            let x = Self::halton_element(i + 1, 2);
            let y = Self::halton_element(i + 1, 3);
            samples.push(Vec2::new(x - 0.5, y - 0.5));
        }

        JitterSequence {
            samples,
            current_index: 0,
        }
    }

    fn halton_element(mut index: usize, base: usize) -> f32 {
        let mut result = 0.0;
        let mut f = 1.0 / base as f32;

        while index > 0 {
            result += f * (index % base) as f32;
            index /= base;
            f /= base as f32;
        }

        result
    }

    /// R2 sequence (quasi-random with golden ratio)
    pub fn r2(count: usize) -> Self {
        let mut samples = Vec::with_capacity(count);
        let phi = (1.0 + 5.0_f32.sqrt()) / 2.0;
        let phi2 = phi * phi;

        for i in 0..count {
            let x = ((0.5 + (i as f32 + 1.0) / phi) % 1.0) - 0.5;
            let y = ((0.5 + (i as f32 + 1.0) / phi2) % 1.0) - 0.5;
            samples.push(Vec2::new(x, y));
        }

        JitterSequence {
            samples,
            current_index: 0,
        }
    }

    /// Blue noise from texture
    pub fn blue_noise(width: u32, height: u32, count: usize) -> Self {
        // Simplified - would load actual blue noise texture
        Self::halton(count)
    }

    /// Get current sample and advance
    pub fn next(&mut self) -> Vec2 {
        let sample = self.samples[self.current_index];
        self.current_index = (self.current_index + 1) % self.samples.len();
        sample
    }

    /// Get sample at specific index
    pub fn get(&self, index: usize) -> Vec2 {
        self.samples[index % self.samples.len()]
    }

    /// Current index in sequence
    pub fn current_index(&self) -> usize {
        self.current_index
    }
}

/// Color space conversion for variance clipping
pub struct ColorSpace;

impl ColorSpace {
    /// RGB to YCoCg
    pub fn rgb_to_ycocg(rgb: Vec3) -> Vec3 {
        let y = 0.25 * rgb.x + 0.5 * rgb.y + 0.25 * rgb.z;
        let co = 0.5 * rgb.x - 0.5 * rgb.z;
        let cg = -0.25 * rgb.x + 0.5 * rgb.y - 0.25 * rgb.z;
        Vec3::new(y, co, cg)
    }

    /// YCoCg to RGB
    pub fn ycocg_to_rgb(ycocg: Vec3) -> Vec3 {
        let y = ycocg.x;
        let co = ycocg.y;
        let cg = ycocg.z;
        let r = y + co - cg;
        let g = y + cg;
        let b = y - co - cg;
        Vec3::new(r, g, b)
    }

    /// Tonemap for better variance clipping
    pub fn tonemap(color: Vec3) -> Vec3 {
        color / (color + Vec3::ONE)
    }

    /// Inverse tonemap
    pub fn inverse_tonemap(color: Vec3) -> Vec3 {
        color / (Vec3::ONE - color).max(Vec3::splat(0.001))
    }
}

/// Variance clipping implementation
pub struct VarianceClipper {
    pub gamma: f32,
    pub use_ycocg: bool,
    pub aabb_scale: f32,
}

impl VarianceClipper {
    pub fn new() -> Self {
        VarianceClipper {
            gamma: 1.0,
            use_ycocg: true,
            aabb_scale: 1.25,
        }
    }

    /// Compute color AABB from 3x3 neighborhood
    pub fn compute_aabb(&self, neighborhood: &[Vec3; 9]) -> (Vec3, Vec3) {
        let mut min_color = Vec3::splat(f32::MAX);
        let mut max_color = Vec3::splat(f32::MIN);

        // Convert to working space
        let samples: Vec<Vec3> = if self.use_ycocg {
            neighborhood.iter().map(|&c| ColorSpace::rgb_to_ycocg(c)).collect()
        } else {
            neighborhood.to_vec()
        };

        // Compute bounds
        for &sample in &samples {
            min_color = min_color.min(sample);
            max_color = max_color.max(sample);
        }

        // Variance-based expansion
        let center = (min_color + max_color) * 0.5;
        let half_extent = (max_color - min_color) * 0.5 * self.aabb_scale;

        (center - half_extent, center + half_extent)
    }

    /// Compute color AABB with variance weighting (better quality)
    pub fn compute_variance_aabb(&self, neighborhood: &[Vec3; 9]) -> (Vec3, Vec3) {
        // Convert to working space
        let samples: Vec<Vec3> = if self.use_ycocg {
            neighborhood.iter().map(|&c| ColorSpace::rgb_to_ycocg(c)).collect()
        } else {
            neighborhood.to_vec()
        };

        // Compute mean
        let mut mean = Vec3::ZERO;
        for &sample in &samples {
            mean += sample;
        }
        mean /= 9.0;

        // Compute variance
        let mut variance = Vec3::ZERO;
        for &sample in &samples {
            let diff = sample - mean;
            variance += Vec3::new(diff.x * diff.x, diff.y * diff.y, diff.z * diff.z);
        }
        variance /= 9.0;

        // Standard deviation with gamma
        let std_dev = Vec3::new(
            variance.x.sqrt() * self.gamma,
            variance.y.sqrt() * self.gamma,
            variance.z.sqrt() * self.gamma,
        );

        (mean - std_dev, mean + std_dev)
    }

    /// Clip history color to AABB
    pub fn clip_to_aabb(&self, history: Vec3, min_color: Vec3, max_color: Vec3) -> Vec3 {
        let working = if self.use_ycocg {
            ColorSpace::rgb_to_ycocg(history)
        } else {
            history
        };

        let center = (min_color + max_color) * 0.5;
        let half_extent = (max_color - min_color) * 0.5;

        // Ray-AABB intersection to clip
        let dir = working - center;

        let mut t_max = 1.0f32;
        for i in 0..3 {
            let dir_i = match i {
                0 => dir.x,
                1 => dir.y,
                _ => dir.z,
            };
            let extent_i = match i {
                0 => half_extent.x,
                1 => half_extent.y,
                _ => half_extent.z,
            };

            if dir_i.abs() > 1e-6 {
                let t = extent_i / dir_i.abs();
                t_max = t_max.min(t);
            }
        }

        let clipped = center + dir * t_max.min(1.0);

        if self.use_ycocg {
            ColorSpace::ycocg_to_rgb(clipped)
        } else {
            clipped
        }
    }
}

/// Main TAA implementation
pub struct TemporalAA {
    config: TAAConfig,
    history_buffer: Vec<Vec3>,
    variance_clipper: VarianceClipper,
    jitter_sequence: JitterSequence,
    width: u32,
    height: u32,
    frame_count: u32,
}

impl TemporalAA {
    pub fn new(width: u32, height: u32, config: TAAConfig) -> Self {
        let sample_count = match config.quality {
            TAAQuality::Low => 4,
            TAAQuality::Medium => 8,
            TAAQuality::High => 16,
            TAAQuality::Ultra => 32,
        };

        TemporalAA {
            config,
            history_buffer: vec![Vec3::ZERO; (width * height) as usize],
            variance_clipper: VarianceClipper::new(),
            jitter_sequence: JitterSequence::halton(sample_count),
            width,
            height,
            frame_count: 0,
        }
    }

    /// Get current jitter offset in pixels
    pub fn get_jitter(&mut self) -> Vec2 {
        self.jitter_sequence.next()
    }

    /// Get current jitter offset in clip space
    pub fn get_jitter_clip(&mut self) -> Vec2 {
        let pixel_jitter = self.jitter_sequence.next();
        Vec2::new(
            pixel_jitter.x * 2.0 / self.width as f32,
            pixel_jitter.y * 2.0 / self.height as f32,
        )
    }

    /// Sample current frame with bilinear filtering
    fn sample_bilinear(&self, buffer: &[Vec3], uv: Vec2) -> Vec3 {
        let x = uv.x * self.width as f32 - 0.5;
        let y = uv.y * self.height as f32 - 0.5;

        let x0 = x.floor() as i32;
        let y0 = y.floor() as i32;
        let x1 = x0 + 1;
        let y1 = y0 + 1;

        let fx = x - x0 as f32;
        let fy = y - y0 as f32;

        let sample = |px: i32, py: i32| -> Vec3 {
            let px = px.clamp(0, self.width as i32 - 1) as u32;
            let py = py.clamp(0, self.height as i32 - 1) as u32;
            buffer[(py * self.width + px) as usize]
        };

        let c00 = sample(x0, y0);
        let c10 = sample(x1, y0);
        let c01 = sample(x0, y1);
        let c11 = sample(x1, y1);

        let c0 = c00 * (1.0 - fx) + c10 * fx;
        let c1 = c01 * (1.0 - fx) + c11 * fx;

        c0 * (1.0 - fy) + c1 * fy
    }

    /// Sample 3x3 neighborhood for variance clipping
    fn sample_neighborhood(&self, current: &[Vec3], x: u32, y: u32) -> [Vec3; 9] {
        let mut samples = [Vec3::ZERO; 9];
        let mut i = 0;

        for dy in -1i32..=1 {
            for dx in -1i32..=1 {
                let px = (x as i32 + dx).clamp(0, self.width as i32 - 1) as u32;
                let py = (y as i32 + dy).clamp(0, self.height as i32 - 1) as u32;
                samples[i] = current[(py * self.width + px) as usize];
                i += 1;
            }
        }

        samples
    }

    /// Resolve TAA for single pixel
    pub fn resolve_pixel(
        &self,
        x: u32,
        y: u32,
        current: &[Vec3],
        motion: MotionVector,
        depth: f32,
        prev_depth: f32,
    ) -> Vec3 {
        let idx = (y * self.width + x) as usize;
        let current_color = current[idx];

        // Reproject to previous frame
        let prev_uv = Vec2::new(
            (x as f32 - motion.dx) / self.width as f32,
            (y as f32 - motion.dy) / self.height as f32,
        );

        // Check if reprojection is valid
        if prev_uv.x < 0.0 || prev_uv.x > 1.0 || prev_uv.y < 0.0 || prev_uv.y > 1.0 {
            return current_color;
        }

        // Sample history
        let history_color = self.sample_bilinear(&self.history_buffer, prev_uv);

        // Variance clipping
        let neighborhood = self.sample_neighborhood(current, x, y);
        let (min_color, max_color) = if self.config.quality >= TAAQuality::Medium {
            self.variance_clipper.compute_variance_aabb(&neighborhood)
        } else {
            self.variance_clipper.compute_aabb(&neighborhood)
        };

        let clipped_history = self.variance_clipper.clip_to_aabb(history_color, min_color, max_color);

        // Compute blend factor based on motion and depth
        let motion_factor = motion.length_squared() * self.config.velocity_weight;
        let depth_factor = (depth - prev_depth).abs() * self.config.depth_weight;

        let mut blend = self.config.feedback_max;
        blend = blend.min(self.config.feedback_min + motion_factor.min(1.0) * (self.config.feedback_max - self.config.feedback_min));
        blend = blend.min(self.config.feedback_min + depth_factor.min(1.0) * (self.config.feedback_max - self.config.feedback_min));

        // Anti-flicker: reduce blend when history is very different
        if self.config.anti_flicker {
            let history_diff = (current_color - clipped_history).length();
            let flicker_factor = (history_diff * 5.0).min(1.0);
            blend = blend * (1.0 - flicker_factor * 0.3);
        }

        // Blend current and history
        let result = current_color * (1.0 - blend) + clipped_history * blend;

        result
    }

    /// Resolve full frame
    pub fn resolve(
        &mut self,
        current: &[Vec3],
        motion_vectors: &[MotionVector],
        depth: &[f32],
        prev_depth: &[f32],
    ) -> Vec<Vec3> {
        let mut output = vec![Vec3::ZERO; (self.width * self.height) as usize];

        for y in 0..self.height {
            for x in 0..self.width {
                let idx = (y * self.width + x) as usize;
                output[idx] = self.resolve_pixel(
                    x, y, current,
                    motion_vectors[idx],
                    depth[idx],
                    prev_depth[idx],
                );
            }
        }

        // Apply sharpening if configured
        if self.config.sharpen_strength > 0.0 {
            self.apply_sharpening(&mut output);
        }

        // Update history
        self.history_buffer.copy_from_slice(&output);
        self.frame_count += 1;

        output
    }

    /// Apply CAS-style sharpening
    fn apply_sharpening(&self, buffer: &mut [Vec3]) {
        let strength = self.config.sharpen_strength;
        let temp = buffer.to_vec();

        for y in 1..(self.height - 1) {
            for x in 1..(self.width - 1) {
                let idx = (y * self.width + x) as usize;

                let center = temp[idx];
                let left = temp[idx - 1];
                let right = temp[idx + 1];
                let up = temp[idx - self.width as usize];
                let down = temp[idx + self.width as usize];

                // Compute min/max of neighborhood
                let min_rgb = center.min(left).min(right).min(up).min(down);
                let max_rgb = center.max(left).max(right).min(up).max(down);

                // Compute sharpening
                let sum = left + right + up + down;
                let sharpened = center + (center * 4.0 - sum) * strength;

                // Clamp to neighborhood bounds to prevent ringing
                buffer[idx] = sharpened.max(min_rgb).min(max_rgb);
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VARIANCE-GUIDED TEMPORAL ACCUMULATION (WP-097)
// ═══════════════════════════════════════════════════════════════════════════════

/// Per-pixel temporal statistics
#[derive(Debug, Clone, Copy)]
pub struct TemporalStats {
    pub mean: Vec3,
    pub variance: Vec3,
    pub sample_count: f32,
    pub confidence: f32,
}

impl TemporalStats {
    pub fn new() -> Self {
        TemporalStats {
            mean: Vec3::ZERO,
            variance: Vec3::ZERO,
            sample_count: 0.0,
            confidence: 0.0,
        }
    }

    /// Update statistics with new sample using Welford's algorithm
    pub fn update(&mut self, sample: Vec3) {
        self.sample_count += 1.0;
        let delta = sample - self.mean;
        self.mean += delta / self.sample_count;
        let delta2 = sample - self.mean;
        self.variance += Vec3::new(delta.x * delta2.x, delta.y * delta2.y, delta.z * delta2.z);
    }

    /// Get current variance estimate
    pub fn get_variance(&self) -> Vec3 {
        if self.sample_count > 1.0 {
            self.variance / (self.sample_count - 1.0)
        } else {
            Vec3::ZERO
        }
    }

    /// Get standard deviation
    pub fn get_std_dev(&self) -> Vec3 {
        let var = self.get_variance();
        Vec3::new(var.x.sqrt(), var.y.sqrt(), var.z.sqrt())
    }

    /// Compute confidence based on variance
    pub fn compute_confidence(&mut self, target_variance: f32) {
        let var = self.get_variance();
        let total_var = var.x + var.y + var.z;
        self.confidence = (target_variance / (total_var + 0.001)).min(1.0);
    }

    /// Apply temporal decay
    pub fn decay(&mut self, rate: f32) {
        self.sample_count *= rate;
        self.variance *= rate;
    }
}

/// Variance-guided temporal accumulator
pub struct VarianceGuidedAccumulator {
    stats: Vec<TemporalStats>,
    accumulated: Vec<Vec3>,
    width: u32,
    height: u32,
    target_variance: f32,
    decay_rate: f32,
    max_samples: f32,
}

impl VarianceGuidedAccumulator {
    pub fn new(width: u32, height: u32) -> Self {
        let size = (width * height) as usize;
        VarianceGuidedAccumulator {
            stats: vec![TemporalStats::new(); size],
            accumulated: vec![Vec3::ZERO; size],
            width,
            height,
            target_variance: 0.001,
            decay_rate: 0.95,
            max_samples: 64.0,
        }
    }

    /// Determine if pixel needs more samples based on variance
    pub fn needs_samples(&self, x: u32, y: u32) -> bool {
        let idx = (y * self.width + x) as usize;
        let stats = &self.stats[idx];

        stats.sample_count < 1.0 ||
        (stats.confidence < 0.9 && stats.sample_count < self.max_samples)
    }

    /// Get recommended sample count for pixel
    pub fn recommended_samples(&self, x: u32, y: u32) -> u32 {
        let idx = (y * self.width + x) as usize;
        let stats = &self.stats[idx];

        if stats.sample_count < 1.0 {
            return 8;
        }

        let var = stats.get_variance();
        let total_var = var.x + var.y + var.z;

        if total_var < self.target_variance {
            return 1;
        }

        // More variance = more samples needed
        let ratio = (total_var / self.target_variance).sqrt();
        (ratio as u32).clamp(1, 16)
    }

    /// Update pixel with new sample
    pub fn update_pixel(&mut self, x: u32, y: u32, sample: Vec3) {
        let idx = (y * self.width + x) as usize;

        // Update running statistics
        self.stats[idx].update(sample);
        self.stats[idx].compute_confidence(self.target_variance);

        // Update accumulated color
        let n = self.stats[idx].sample_count;
        self.accumulated[idx] = self.accumulated[idx] * ((n - 1.0) / n) + sample / n;
    }

    /// Get current accumulated color
    pub fn get_color(&self, x: u32, y: u32) -> Vec3 {
        let idx = (y * self.width + x) as usize;
        self.accumulated[idx]
    }

    /// Get confidence at pixel
    pub fn get_confidence(&self, x: u32, y: u32) -> f32 {
        let idx = (y * self.width + x) as usize;
        self.stats[idx].confidence
    }

    /// Apply temporal reprojection with motion
    pub fn reproject(&mut self, motion_vectors: &[MotionVector], depth: &[f32], prev_depth: &[f32]) {
        let temp_stats = self.stats.clone();
        let temp_accum = self.accumulated.clone();

        for y in 0..self.height {
            for x in 0..self.width {
                let idx = (y * self.width + x) as usize;
                let motion = motion_vectors[idx];

                let prev_x = (x as f32 - motion.dx).round() as i32;
                let prev_y = (y as f32 - motion.dy).round() as i32;

                if prev_x >= 0 && prev_x < self.width as i32 &&
                   prev_y >= 0 && prev_y < self.height as i32 {
                    let prev_idx = (prev_y as u32 * self.width + prev_x as u32) as usize;

                    // Check depth consistency
                    let depth_diff = (depth[idx] - prev_depth[prev_idx]).abs();
                    let depth_threshold = depth[idx] * 0.05;

                    if depth_diff < depth_threshold && motion.confidence > 0.5 {
                        // Valid reprojection - blend with history
                        let history_weight = self.decay_rate * motion.confidence;

                        self.stats[idx].mean = self.stats[idx].mean * (1.0 - history_weight) +
                                               temp_stats[prev_idx].mean * history_weight;
                        self.stats[idx].sample_count = (temp_stats[prev_idx].sample_count * history_weight)
                            .min(self.max_samples);
                        self.stats[idx].variance = temp_stats[prev_idx].variance * history_weight;

                        self.accumulated[idx] = self.accumulated[idx] * (1.0 - history_weight) +
                                                temp_accum[prev_idx] * history_weight;
                    } else {
                        // Disocclusion - reset
                        self.stats[idx].decay(0.5);
                    }
                } else {
                    // Out of bounds - decay
                    self.stats[idx].decay(0.5);
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEMPORAL GRADIENT-DOMAIN FILTERING (WP-057, WP-106)
// ═══════════════════════════════════════════════════════════════════════════════

/// Gradient-domain representation of image
pub struct GradientImage {
    pub dx: Vec<Vec3>,      // Horizontal gradients
    pub dy: Vec<Vec3>,      // Vertical gradients
    pub values: Vec<Vec3>,  // Pixel values (for boundary conditions)
    pub width: u32,
    pub height: u32,
}

impl GradientImage {
    pub fn from_image(image: &[Vec3], width: u32, height: u32) -> Self {
        let size = (width * height) as usize;
        let mut dx = vec![Vec3::ZERO; size];
        let mut dy = vec![Vec3::ZERO; size];

        // Compute gradients
        for y in 0..height {
            for x in 0..width {
                let idx = (y * width + x) as usize;

                // Horizontal gradient
                if x < width - 1 {
                    dx[idx] = image[idx + 1] - image[idx];
                }

                // Vertical gradient
                if y < height - 1 {
                    dy[idx] = image[idx + width as usize] - image[idx];
                }
            }
        }

        GradientImage {
            dx,
            dy,
            values: image.to_vec(),
            width,
            height,
        }
    }

    /// Reconstruct image from gradients using Poisson solver
    pub fn reconstruct(&self) -> Vec<Vec3> {
        let mut result = self.values.clone();

        // Simple iterative solver (Gauss-Seidel)
        const ITERATIONS: u32 = 50;

        for _ in 0..ITERATIONS {
            for y in 1..(self.height - 1) {
                for x in 1..(self.width - 1) {
                    let idx = (y * self.width + x) as usize;

                    // Laplacian from gradients
                    let laplacian = self.dx[idx] - self.dx[idx - 1] +
                                    self.dy[idx] - self.dy[idx - self.width as usize];

                    // Average of neighbors
                    let avg = (result[idx - 1] + result[idx + 1] +
                               result[idx - self.width as usize] +
                               result[idx + self.width as usize]) * 0.25;

                    // Update
                    result[idx] = avg - laplacian * 0.25;
                }
            }
        }

        result
    }
}

/// Temporal gradient-domain filter
pub struct TemporalGradientFilter {
    prev_gradients: Option<GradientImage>,
    width: u32,
    height: u32,
    gradient_weight: f32,
}

impl TemporalGradientFilter {
    pub fn new(width: u32, height: u32) -> Self {
        TemporalGradientFilter {
            prev_gradients: None,
            width,
            height,
            gradient_weight: 0.8,
        }
    }

    /// Filter frame using gradient-domain temporal filtering
    pub fn filter(
        &mut self,
        current: &[Vec3],
        motion_vectors: &[MotionVector],
    ) -> Vec<Vec3> {
        let current_gradients = GradientImage::from_image(current, self.width, self.height);

        let result = if let Some(ref prev) = self.prev_gradients {
            // Warp previous gradients
            let warped = self.warp_gradients(prev, motion_vectors);

            // Blend gradients
            let blended = self.blend_gradients(&current_gradients, &warped);

            // Reconstruct from blended gradients
            blended.reconstruct()
        } else {
            current.to_vec()
        };

        self.prev_gradients = Some(current_gradients);
        result
    }

    /// Warp previous gradients using motion vectors
    fn warp_gradients(&self, prev: &GradientImage, motion: &[MotionVector]) -> GradientImage {
        let size = (self.width * self.height) as usize;
        let mut warped_dx = vec![Vec3::ZERO; size];
        let mut warped_dy = vec![Vec3::ZERO; size];
        let mut warped_values = vec![Vec3::ZERO; size];

        for y in 0..self.height {
            for x in 0..self.width {
                let idx = (y * self.width + x) as usize;
                let mv = motion[idx];

                let prev_x = (x as f32 - mv.dx).round() as i32;
                let prev_y = (y as f32 - mv.dy).round() as i32;

                if prev_x >= 0 && prev_x < self.width as i32 &&
                   prev_y >= 0 && prev_y < self.height as i32 {
                    let prev_idx = (prev_y as u32 * self.width + prev_x as u32) as usize;
                    warped_dx[idx] = prev.dx[prev_idx] * mv.confidence;
                    warped_dy[idx] = prev.dy[prev_idx] * mv.confidence;
                    warped_values[idx] = prev.values[prev_idx];
                }
            }
        }

        GradientImage {
            dx: warped_dx,
            dy: warped_dy,
            values: warped_values,
            width: self.width,
            height: self.height,
        }
    }

    /// Blend current and warped gradients
    fn blend_gradients(&self, current: &GradientImage, warped: &GradientImage) -> GradientImage {
        let size = (self.width * self.height) as usize;
        let mut blended_dx = vec![Vec3::ZERO; size];
        let mut blended_dy = vec![Vec3::ZERO; size];

        let w = self.gradient_weight;

        for i in 0..size {
            // Choose gradient with larger magnitude for edge preservation
            let current_mag = current.dx[i].length_squared() + current.dy[i].length_squared();
            let warped_mag = warped.dx[i].length_squared() + warped.dy[i].length_squared();

            if current_mag > warped_mag * 1.5 {
                // Current frame has stronger edges - use current
                blended_dx[i] = current.dx[i];
                blended_dy[i] = current.dy[i];
            } else {
                // Blend
                blended_dx[i] = current.dx[i] * (1.0 - w) + warped.dx[i] * w;
                blended_dy[i] = current.dy[i] * (1.0 - w) + warped.dy[i] * w;
            }
        }

        GradientImage {
            dx: blended_dx,
            dy: blended_dy,
            values: current.values.clone(),
            width: self.width,
            height: self.height,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIERARCHICAL TEMPORAL REPROJECTION (WP-076)
// ═══════════════════════════════════════════════════════════════════════════════

/// Mipmap pyramid for hierarchical reprojection
pub struct ImagePyramid {
    levels: Vec<Vec<Vec3>>,
    widths: Vec<u32>,
    heights: Vec<u32>,
}

impl ImagePyramid {
    pub fn build(image: &[Vec3], width: u32, height: u32, num_levels: u32) -> Self {
        let mut levels = Vec::with_capacity(num_levels as usize);
        let mut widths = Vec::with_capacity(num_levels as usize);
        let mut heights = Vec::with_capacity(num_levels as usize);

        // Level 0 is original image
        levels.push(image.to_vec());
        widths.push(width);
        heights.push(height);

        // Build mip chain
        for level in 1..num_levels {
            let prev_width = widths[level as usize - 1];
            let prev_height = heights[level as usize - 1];
            let prev_level = &levels[level as usize - 1];

            let new_width = (prev_width / 2).max(1);
            let new_height = (prev_height / 2).max(1);

            let mut new_level = vec![Vec3::ZERO; (new_width * new_height) as usize];

            for y in 0..new_height {
                for x in 0..new_width {
                    let src_x = x * 2;
                    let src_y = y * 2;

                    // 2x2 box filter
                    let mut sum = Vec3::ZERO;
                    let mut count = 0;

                    for dy in 0..2 {
                        for dx in 0..2 {
                            let sx = (src_x + dx).min(prev_width - 1);
                            let sy = (src_y + dy).min(prev_height - 1);
                            sum += prev_level[(sy * prev_width + sx) as usize];
                            count += 1;
                        }
                    }

                    new_level[(y * new_width + x) as usize] = sum / count as f32;
                }
            }

            levels.push(new_level);
            widths.push(new_width);
            heights.push(new_height);
        }

        ImagePyramid { levels, widths, heights }
    }

    pub fn level_count(&self) -> usize {
        self.levels.len()
    }

    pub fn sample(&self, level: usize, uv: Vec2) -> Vec3 {
        let level = level.min(self.levels.len() - 1);
        let width = self.widths[level] as f32;
        let height = self.heights[level] as f32;

        let x = (uv.x * width).clamp(0.0, width - 1.0) as u32;
        let y = (uv.y * height).clamp(0.0, height - 1.0) as u32;

        self.levels[level][(y * self.widths[level] + x) as usize]
    }

    pub fn sample_trilinear(&self, uv: Vec2, lod: f32) -> Vec3 {
        let lod = lod.clamp(0.0, (self.levels.len() - 1) as f32);
        let level0 = lod.floor() as usize;
        let level1 = (level0 + 1).min(self.levels.len() - 1);
        let t = lod.fract();

        let c0 = self.sample(level0, uv);
        let c1 = self.sample(level1, uv);

        c0 * (1.0 - t) + c1 * t
    }
}

/// Hierarchical temporal reprojection
pub struct HierarchicalReprojection {
    prev_pyramid: Option<ImagePyramid>,
    pyramid_levels: u32,
    width: u32,
    height: u32,
}

impl HierarchicalReprojection {
    pub fn new(width: u32, height: u32, pyramid_levels: u32) -> Self {
        HierarchicalReprojection {
            prev_pyramid: None,
            pyramid_levels,
            width,
            height,
        }
    }

    /// Reproject with hierarchical motion estimation
    pub fn reproject(
        &mut self,
        current: &[Vec3],
        motion_vectors: &[MotionVector],
        confidence: &[f32],
    ) -> Vec<Vec3> {
        let current_pyramid = ImagePyramid::build(current, self.width, self.height, self.pyramid_levels);

        let result = if let Some(ref prev) = self.prev_pyramid {
            self.hierarchical_blend(&current_pyramid, prev, motion_vectors, confidence)
        } else {
            current.to_vec()
        };

        self.prev_pyramid = Some(current_pyramid);
        result
    }

    fn hierarchical_blend(
        &self,
        current: &ImagePyramid,
        prev: &ImagePyramid,
        motion: &[MotionVector],
        confidence: &[f32],
    ) -> Vec<Vec3> {
        let mut result = vec![Vec3::ZERO; (self.width * self.height) as usize];

        for y in 0..self.height {
            for x in 0..self.width {
                let idx = (y * self.width + x) as usize;
                let mv = motion[idx];
                let conf = confidence[idx];

                let uv = Vec2::new(x as f32 / self.width as f32, y as f32 / self.height as f32);
                let prev_uv = Vec2::new(
                    (x as f32 - mv.dx) / self.width as f32,
                    (y as f32 - mv.dy) / self.height as f32,
                );

                // Check bounds
                if prev_uv.x < 0.0 || prev_uv.x > 1.0 || prev_uv.y < 0.0 || prev_uv.y > 1.0 {
                    result[idx] = current.sample(0, uv);
                    continue;
                }

                // Use LOD based on motion magnitude and confidence
                let motion_mag = mv.length();
                let lod = (motion_mag * 0.5 * (1.0 - conf)).min((self.pyramid_levels - 1) as f32);

                let current_color = current.sample(0, uv);
                let prev_color = prev.sample_trilinear(prev_uv, lod);

                // Blend based on confidence
                let blend = conf * 0.9;
                result[idx] = current_color * (1.0 - blend) + prev_color * blend;
            }
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PREDICTIVE FRAME SYNTHESIS (WP-075)
// ═══════════════════════════════════════════════════════════════════════════════

/// Frame prediction for latency reduction
pub struct FramePredictor {
    history: VecDeque<Vec<Vec3>>,
    motion_history: VecDeque<Vec<MotionVector>>,
    max_history: usize,
    width: u32,
    height: u32,
}

impl FramePredictor {
    pub fn new(width: u32, height: u32, max_history: usize) -> Self {
        FramePredictor {
            history: VecDeque::with_capacity(max_history),
            motion_history: VecDeque::with_capacity(max_history),
            max_history,
            width,
            height,
        }
    }

    /// Add new frame to history
    pub fn add_frame(&mut self, frame: Vec<Vec3>, motion: Vec<MotionVector>) {
        if self.history.len() >= self.max_history {
            self.history.pop_front();
            self.motion_history.pop_front();
        }
        self.history.push_back(frame);
        self.motion_history.push_back(motion);
    }

    /// Predict future frame based on motion trends
    pub fn predict(&self, steps_ahead: u32) -> Option<Vec<Vec3>> {
        if self.history.len() < 2 {
            return None;
        }

        let last_frame = self.history.back()?;
        let last_motion = self.motion_history.back()?;

        // Extrapolate motion
        let motion_delta = if self.motion_history.len() >= 2 {
            let prev_motion = &self.motion_history[self.motion_history.len() - 2];
            self.compute_motion_delta(prev_motion, last_motion)
        } else {
            vec![MotionVector::zero(); (self.width * self.height) as usize]
        };

        // Predict motion for future frame
        let predicted_motion: Vec<MotionVector> = last_motion.iter()
            .zip(motion_delta.iter())
            .map(|(m, d)| MotionVector {
                dx: m.dx + d.dx * steps_ahead as f32,
                dy: m.dy + d.dy * steps_ahead as f32,
                confidence: m.confidence * 0.9_f32.powi(steps_ahead as i32),
                depth_delta: m.depth_delta,
            })
            .collect();

        // Warp frame using predicted motion
        Some(self.warp_frame(last_frame, &predicted_motion))
    }

    fn compute_motion_delta(&self, prev: &[MotionVector], curr: &[MotionVector]) -> Vec<MotionVector> {
        prev.iter()
            .zip(curr.iter())
            .map(|(p, c)| MotionVector {
                dx: c.dx - p.dx,
                dy: c.dy - p.dy,
                confidence: (c.confidence + p.confidence) * 0.5,
                depth_delta: 0.0,
            })
            .collect()
    }

    fn warp_frame(&self, frame: &[Vec3], motion: &[MotionVector]) -> Vec<Vec3> {
        let mut result = vec![Vec3::ZERO; (self.width * self.height) as usize];
        let mut weights = vec![0.0f32; (self.width * self.height) as usize];

        for y in 0..self.height {
            for x in 0..self.width {
                let src_idx = (y * self.width + x) as usize;
                let mv = motion[src_idx];

                let dst_x = (x as f32 + mv.dx).round() as i32;
                let dst_y = (y as f32 + mv.dy).round() as i32;

                if dst_x >= 0 && dst_x < self.width as i32 &&
                   dst_y >= 0 && dst_y < self.height as i32 {
                    let dst_idx = (dst_y as u32 * self.width + dst_x as u32) as usize;

                    let weight = mv.confidence;
                    result[dst_idx] += frame[src_idx] * weight;
                    weights[dst_idx] += weight;
                }
            }
        }

        // Normalize
        for i in 0..result.len() {
            if weights[i] > 0.0 {
                result[i] /= weights[i];
            } else {
                // Fill holes with nearest
                result[i] = frame[i];
            }
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEMPORAL SUPERSAMPLING GRID (WP-079)
// ═══════════════════════════════════════════════════════════════════════════════

/// Sample location within pixel
#[derive(Debug, Clone, Copy)]
pub struct SubpixelSample {
    pub offset: Vec2,
    pub weight: f32,
    pub frame_index: u32,
}

/// Temporal supersampling accumulator
pub struct TemporalSupersampler {
    samples: Vec<Vec<SubpixelSample>>,
    accumulated: Vec<Vec3>,
    sample_weights: Vec<f32>,
    sample_count: Vec<u32>,
    width: u32,
    height: u32,
    max_samples: u32,
    current_frame: u32,
}

impl TemporalSupersampler {
    pub fn new(width: u32, height: u32, max_samples: u32) -> Self {
        let size = (width * height) as usize;
        TemporalSupersampler {
            samples: vec![Vec::with_capacity(max_samples as usize); size],
            accumulated: vec![Vec3::ZERO; size],
            sample_weights: vec![0.0; size],
            sample_count: vec![0; size],
            width,
            height,
            max_samples,
            current_frame: 0,
        }
    }

    /// Add sample at subpixel location
    pub fn add_sample(&mut self, x: u32, y: u32, offset: Vec2, color: Vec3, weight: f32) {
        let idx = (y * self.width + x) as usize;

        let sample = SubpixelSample {
            offset,
            weight,
            frame_index: self.current_frame,
        };

        // Apply Gaussian weight based on distance from pixel center
        let dist_sq = offset.length_squared();
        let gaussian_weight = (-dist_sq * 2.0).exp() * weight;

        self.samples[idx].push(sample);
        self.accumulated[idx] += color * gaussian_weight;
        self.sample_weights[idx] += gaussian_weight;
        self.sample_count[idx] += 1;

        // Prune old samples if over limit
        if self.samples[idx].len() > self.max_samples as usize {
            // Remove oldest sample
            let removed = self.samples[idx].remove(0);

            // Note: Would need to track per-sample contribution to properly remove
            // This is simplified
        }
    }

    /// Get reconstructed color at pixel
    pub fn get_color(&self, x: u32, y: u32) -> Vec3 {
        let idx = (y * self.width + x) as usize;

        if self.sample_weights[idx] > 0.0 {
            self.accumulated[idx] / self.sample_weights[idx]
        } else {
            Vec3::ZERO
        }
    }

    /// Get effective sample count at pixel
    pub fn get_sample_count(&self, x: u32, y: u32) -> u32 {
        let idx = (y * self.width + x) as usize;
        self.sample_count[idx]
    }

    /// Invalidate samples at pixel (for disocclusion)
    pub fn invalidate(&mut self, x: u32, y: u32) {
        let idx = (y * self.width + x) as usize;
        self.samples[idx].clear();
        self.accumulated[idx] = Vec3::ZERO;
        self.sample_weights[idx] = 0.0;
        self.sample_count[idx] = 0;
    }

    /// Apply motion and age-based decay
    pub fn update(&mut self, motion_vectors: &[MotionVector]) {
        self.current_frame += 1;

        for y in 0..self.height {
            for x in 0..self.width {
                let idx = (y * self.width + x) as usize;
                let mv = motion_vectors[idx];

                // High motion = invalidate samples
                if mv.length() > 2.0 {
                    self.invalidate(x, y);
                    continue;
                }

                // Age decay
                let age_decay = 0.95;
                self.accumulated[idx] *= age_decay;
                self.sample_weights[idx] *= age_decay;

                // Remove very old samples
                self.samples[idx].retain(|s| {
                    self.current_frame - s.frame_index < 32
                });
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEMPORAL STABILITY METRICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Metrics for measuring temporal stability
pub struct TemporalStabilityMetrics {
    prev_frame: Vec<Vec3>,
    width: u32,
    height: u32,
}

impl TemporalStabilityMetrics {
    pub fn new(width: u32, height: u32) -> Self {
        TemporalStabilityMetrics {
            prev_frame: vec![Vec3::ZERO; (width * height) as usize],
            width,
            height,
        }
    }

    /// Compute per-pixel temporal difference
    pub fn compute_difference(&self, current: &[Vec3]) -> Vec<f32> {
        current.iter()
            .zip(self.prev_frame.iter())
            .map(|(c, p)| (*c - *p).length())
            .collect()
    }

    /// Compute overall stability score (0 = unstable, 1 = stable)
    pub fn compute_stability_score(&self, current: &[Vec3], motion_vectors: &[MotionVector]) -> f32 {
        let mut total_diff = 0.0f32;
        let mut count = 0;

        for y in 0..self.height {
            for x in 0..self.width {
                let idx = (y * self.width + x) as usize;
                let mv = motion_vectors[idx];

                // Only consider low-motion pixels
                if mv.length() < 1.0 {
                    let diff = (current[idx] - self.prev_frame[idx]).length();
                    total_diff += diff;
                    count += 1;
                }
            }
        }

        if count > 0 {
            let avg_diff = total_diff / count as f32;
            // Map to 0-1 range (assuming max expected diff of 0.1)
            1.0 - (avg_diff * 10.0).min(1.0)
        } else {
            1.0
        }
    }

    /// Detect flickering pixels
    pub fn detect_flicker(&self, current: &[Vec3], threshold: f32) -> Vec<bool> {
        current.iter()
            .zip(self.prev_frame.iter())
            .map(|(c, p)| {
                let diff = (*c - *p).length();
                diff > threshold
            })
            .collect()
    }

    /// Update with new frame
    pub fn update(&mut self, current: &[Vec3]) {
        self.prev_frame.copy_from_slice(current);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_halton_sequence() {
        let seq = JitterSequence::halton(16);
        assert_eq!(seq.samples.len(), 16);

        // All samples should be in [-0.5, 0.5] range
        for s in &seq.samples {
            assert!(s.x >= -0.5 && s.x <= 0.5);
            assert!(s.y >= -0.5 && s.y <= 0.5);
        }
    }

    #[test]
    fn test_ycocg_conversion() {
        let rgb = Vec3::new(0.5, 0.3, 0.7);
        let ycocg = ColorSpace::rgb_to_ycocg(rgb);
        let back = ColorSpace::ycocg_to_rgb(ycocg);

        assert!((rgb - back).length() < 0.001);
    }

    #[test]
    fn test_variance_clipper() {
        let clipper = VarianceClipper::new();

        let neighborhood = [Vec3::ONE; 9];
        let (min_c, max_c) = clipper.compute_aabb(&neighborhood);

        // All same color should give tight bounds
        assert!((min_c - max_c).length() < 0.1);
    }

    #[test]
    fn test_temporal_stats() {
        let mut stats = TemporalStats::new();

        for i in 0..100 {
            stats.update(Vec3::splat(i as f32 / 100.0));
        }

        assert!(stats.sample_count == 100.0);
        assert!(stats.get_variance().length() > 0.0);
    }

    #[test]
    fn test_motion_vector() {
        let mv = MotionVector::new(3.0, 4.0);
        assert!((mv.length() - 5.0).abs() < 0.001);
    }
}
