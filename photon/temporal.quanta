module photon::temporal

use std::collections::{HashMap, VecDeque}
use std::sync::{Arc, Mutex, RwLock}
use std::math::{Vec2, Vec3, Vec4, Mat3, Mat4}

// ═══════════════════════════════════════════════════════════════════════════════
// MOTION VECTORS
// ═══════════════════════════════════════════════════════════════════════════════

/// Motion vector encoding
#[derive(Debug, Clone, Copy)]
pub struct MotionVector {
    pub dx: f32,
    pub dy: f32,
    pub confidence: f32,
    pub depth_delta: f32,
}

impl MotionVector {
    pub fn zero() -> Self {
        MotionVector {
            dx: 0.0,
            dy: 0.0,
            confidence: 1.0,
            depth_delta: 0.0,
        }
    }

    pub fn new(dx: f32, dy: f32) -> Self {
        MotionVector {
            dx,
            dy,
            confidence: 1.0,
            depth_delta: 0.0,
        }
    }

    pub fn as_vec2(&self) -> Vec2 {
        Vec2::new(self.dx, self.dy)
    }

    pub fn length(&self) -> f32 {
        (self.dx * self.dx + self.dy * self.dy).sqrt()
    }

    pub fn length_squared(&self) -> f32 {
        self.dx * self.dx + self.dy * self.dy
    }
}

/// Motion vector generation from camera matrices
pub struct MotionVectorGenerator {
    current_view_proj: Mat4,
    prev_view_proj: Mat4,
    current_jitter: Vec2,
    prev_jitter: Vec2,
    width: u32,
    height: u32,
}

impl MotionVectorGenerator {
    pub fn new(width: u32, height: u32) -> Self {
        MotionVectorGenerator {
            current_view_proj: Mat4::IDENTITY,
            prev_view_proj: Mat4::IDENTITY,
            current_jitter: Vec2::ZERO,
            prev_jitter: Vec2::ZERO,
            width,
            height,
        }
    }

    /// Update matrices for new frame
    pub fn update(&mut self, view_proj: Mat4, jitter: Vec2) {
        self.prev_view_proj = self.current_view_proj;
        self.prev_jitter = self.current_jitter;
        self.current_view_proj = view_proj;
        self.current_jitter = jitter;
    }

    /// Compute motion vector for world position
    pub fn compute_motion(&self, world_pos: Vec3, prev_world_pos: Option<Vec3>) -> MotionVector {
        let prev_world = prev_world_pos.unwrap_or(world_pos);

        // Project current position
        let current_clip = self.current_view_proj.transform_point(world_pos);
        let current_ndc = Vec2::new(
            current_clip.x / current_clip.z,
            current_clip.y / current_clip.z,
        );
        let current_uv = (current_ndc + Vec2::ONE) * 0.5 - self.current_jitter;

        // Project previous position
        let prev_clip = self.prev_view_proj.transform_point(prev_world);
        let prev_ndc = Vec2::new(
            prev_clip.x / prev_clip.z,
            prev_clip.y / prev_clip.z,
        );
        let prev_uv = (prev_ndc + Vec2::ONE) * 0.5 - self.prev_jitter;

        // Motion in pixels
        let motion = (current_uv - prev_uv) * Vec2::new(self.width as f32, self.height as f32);

        MotionVector {
            dx: motion.x,
            dy: motion.y,
            confidence: 1.0,
            depth_delta: current_clip.z - prev_clip.z,
        }
    }

    /// Generate motion vector for pixel with depth
    pub fn compute_from_depth(&self, pixel: Vec2, depth: f32) -> MotionVector {
        // Convert to clip space
        let ndc = Vec2::new(
            (pixel.x / self.width as f32) * 2.0 - 1.0,
            (pixel.y / self.height as f32) * 2.0 - 1.0,
        );

        // Unproject to world
        let inv_view_proj = self.current_view_proj.inverse();
        let clip_pos = Vec4::new(ndc.x, ndc.y, depth, 1.0);
        let world_pos = inv_view_proj * clip_pos;
        let world_pos = Vec3::new(
            world_pos.x / world_pos.w,
            world_pos.y / world_pos.w,
            world_pos.z / world_pos.w,
        );

        self.compute_motion(world_pos, None)
    }
}

/// Optical flow estimation for motion refinement
pub struct OpticalFlow {
    prev_luma: Vec<f32>,
    width: u32,
    height: u32,
    search_radius: i32,
    pyramid_levels: u32,
}

impl OpticalFlow {
    pub fn new(width: u32, height: u32) -> Self {
        OpticalFlow {
            prev_luma: vec![0.0; (width * height) as usize],
            width,
            height,
            search_radius: 8,
            pyramid_levels: 3,
        }
    }

    /// Extract luminance from RGB
    fn rgb_to_luma(rgb: Vec3) -> f32 {
        0.299 * rgb.x + 0.587 * rgb.y + 0.114 * rgb.z
    }

    /// Update with new frame
    pub fn update(&mut self, current_luma: &[f32]) {
        self.prev_luma.copy_from_slice(current_luma);
    }

    /// Estimate motion at pixel using block matching
    pub fn estimate_motion(&self, current_luma: &[f32], x: u32, y: u32) -> MotionVector {
        let center_idx = (y * self.width + x) as usize;

        // Search for best matching block
        let block_size = 8;
        let half_block = block_size / 2;

        let mut best_sad = f32::MAX;
        let mut best_dx = 0i32;
        let mut best_dy = 0i32;

        for dy in -self.search_radius..=self.search_radius {
            for dx in -self.search_radius..=self.search_radius {
                let mut sad = 0.0f32;
                let mut count = 0;

                for by in -(half_block as i32)..(half_block as i32) {
                    for bx in -(half_block as i32)..(half_block as i32) {
                        let curr_x = x as i32 + bx;
                        let curr_y = y as i32 + by;
                        let prev_x = curr_x + dx;
                        let prev_y = curr_y + dy;

                        if curr_x >= 0 && curr_x < self.width as i32 &&
                           curr_y >= 0 && curr_y < self.height as i32 &&
                           prev_x >= 0 && prev_x < self.width as i32 &&
                           prev_y >= 0 && prev_y < self.height as i32 {
                            let curr_idx = (curr_y * self.width as i32 + curr_x) as usize;
                            let prev_idx = (prev_y * self.width as i32 + prev_x) as usize;

                            sad += (current_luma[curr_idx] - self.prev_luma[prev_idx]).abs();
                            count += 1;
                        }
                    }
                }

                if count > 0 {
                    sad /= count as f32;
                    if sad < best_sad {
                        best_sad = sad;
                        best_dx = dx;
                        best_dy = dy;
                    }
                }
            }
        }

        // Compute confidence from SAD
        let confidence = (-best_sad * 10.0).exp().min(1.0);

        MotionVector {
            dx: best_dx as f32,
            dy: best_dy as f32,
            confidence,
            depth_delta: 0.0,
        }
    }

    /// Sub-pixel refinement using Taylor expansion
    pub fn refine_subpixel(&self, current_luma: &[f32], x: u32, y: u32, initial: MotionVector) -> MotionVector {
        let px = x as i32 + initial.dx as i32;
        let py = y as i32 + initial.dy as i32;

        if px < 1 || px >= (self.width - 1) as i32 ||
           py < 1 || py >= (self.height - 1) as i32 {
            return initial;
        }

        let idx = (py * self.width as i32 + px) as usize;

        // Compute gradients
        let gx = (self.prev_luma[idx + 1] - self.prev_luma[idx - 1]) * 0.5;
        let gy = (self.prev_luma[idx + self.width as usize] - self.prev_luma[idx - self.width as usize]) * 0.5;
        let gt = current_luma[(y * self.width + x) as usize] - self.prev_luma[idx];

        // Compute Hessian
        let gxx = gx * gx;
        let gxy = gx * gy;
        let gyy = gy * gy;

        let det = gxx * gyy - gxy * gxy;
        if det.abs() < 1e-6 {
            return initial;
        }

        // Solve for sub-pixel offset
        let sub_dx = (gyy * gx * gt - gxy * gy * gt) / det;
        let sub_dy = (gxx * gy * gt - gxy * gx * gt) / det;

        MotionVector {
            dx: initial.dx + sub_dx.clamp(-0.5, 0.5),
            dy: initial.dy + sub_dy.clamp(-0.5, 0.5),
            confidence: initial.confidence,
            depth_delta: initial.depth_delta,
        }
    }
}

