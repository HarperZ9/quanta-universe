// ============================================================================
// GPU-DRIVEN RENDERING PIPELINE
// ============================================================================
// Comprehensive GPU-driven rendering system with meshlet-based geometry,
// indirect draw command generation, visibility buffer rendering, and
// GPU-side scene management for maximum throughput and minimal CPU overhead.
// ============================================================================

import core::types::*;
import core::memory::*;
import photon::gpu_culling::*;
import photon::material::*;

// ============================================================================
// MESHLET STRUCTURES
// ============================================================================

/// Maximum vertices per meshlet (optimized for GPU wave/warp size)
const MESHLET_MAX_VERTICES: u32 = 64;

/// Maximum triangles per meshlet
const MESHLET_MAX_TRIANGLES: u32 = 124;

/// Maximum meshlets per mesh (for buffer sizing)
const MAX_MESHLETS_PER_MESH: u32 = 65536;

/// Meshlet structure - compact geometry cluster for GPU processing
struct Meshlet {
    /// Offset into vertex index buffer
    vertex_offset: u32,
    /// Number of vertices in this meshlet
    vertex_count: u8,
    /// Offset into primitive index buffer
    triangle_offset: u32,
    /// Number of triangles in this meshlet
    triangle_count: u8,
    /// Bounding sphere center (local space)
    bounds_center: vec3,
    /// Bounding sphere radius
    bounds_radius: f32,
    /// Cone apex for backface culling (local space)
    cone_apex: vec3,
    /// Cone axis (normalized)
    cone_axis: vec3,
    /// Cone cutoff (cos of half-angle, negative for degenerate)
    cone_cutoff: f32,
    /// LOD level this meshlet belongs to
    lod_level: u8,
    /// Error metric for LOD selection
    lod_error: f32,
}

impl Meshlet {
    /// Create a new empty meshlet
    fn new() -> Self {
        Meshlet {
            vertex_offset: 0,
            vertex_count: 0,
            triangle_offset: 0,
            triangle_count: 0,
            bounds_center: vec3::zero(),
            bounds_radius: 0.0,
            cone_apex: vec3::zero(),
            cone_axis: vec3::new(0.0, 0.0, 1.0),
            cone_cutoff: 1.0,
            lod_level: 0,
            lod_error: 0.0,
        }
    }

    /// Check if meshlet is visible from camera position using cone culling
    fn is_cone_visible(&self, camera_pos: vec3, transform: mat4) -> bool {
        // Transform cone to world space
        let world_apex = (transform * vec4::new(self.cone_apex.x, self.cone_apex.y, self.cone_apex.z, 1.0)).xyz();
        let world_axis = (transform * vec4::new(self.cone_axis.x, self.cone_axis.y, self.cone_axis.z, 0.0)).xyz().normalize();

        // View direction from apex to camera
        let view_dir = (camera_pos - world_apex).normalize();

        // If cone cutoff is negative, meshlet is degenerate (visible from all angles)
        if self.cone_cutoff < 0.0 {
            return true;
        }

        // Check if view direction is within cone
        view_dir.dot(world_axis) >= self.cone_cutoff
    }

    /// Get world-space bounding sphere
    fn get_world_bounds(&self, transform: mat4) -> BoundingSphere {
        let world_center = (transform * vec4::new(
            self.bounds_center.x,
            self.bounds_center.y,
            self.bounds_center.z,
            1.0
        )).xyz();

        // Scale radius by maximum scale factor
        let scale = vec3::new(
            transform.col(0).xyz().length(),
            transform.col(1).xyz().length(),
            transform.col(2).xyz().length(),
        );
        let max_scale = scale.x.max(scale.y).max(scale.z);

        BoundingSphere::new(world_center, self.bounds_radius * max_scale)
    }
}

/// Meshlet mesh - collection of meshlets representing a single mesh
struct MeshletMesh {
    /// All meshlets in this mesh
    meshlets: Vec<Meshlet>,
    /// Vertex indices (local to meshlet, indexing into mesh vertices)
    vertex_indices: Vec<u32>,
    /// Primitive indices (3 bytes per triangle, indexing into meshlet vertices)
    primitive_indices: Vec<u8>,
    /// Original vertex buffer
    vertices: Vec<MeshVertex>,
    /// Mesh bounding box
    bounds: AABB,
    /// LOD level count
    lod_count: u32,
    /// Meshlet count per LOD level
    meshlets_per_lod: Vec<u32>,
}

/// Packed mesh vertex for GPU
#[repr(C)]
struct MeshVertex {
    position: vec3,
    normal: u32,      // Packed 10:10:10:2
    tangent: u32,     // Packed 10:10:10:2
    uv0: vec2,
    uv1: vec2,
}

impl MeshVertex {
    /// Pack normal vector into 10:10:10:2 format
    fn pack_normal(n: vec3) -> u32 {
        let x = ((n.x * 0.5 + 0.5) * 1023.0) as u32;
        let y = ((n.y * 0.5 + 0.5) * 1023.0) as u32;
        let z = ((n.z * 0.5 + 0.5) * 1023.0) as u32;
        x | (y << 10) | (z << 20)
    }

    /// Unpack normal from 10:10:10:2 format
    fn unpack_normal(packed: u32) -> vec3 {
        let x = (packed & 0x3FF) as f32 / 1023.0 * 2.0 - 1.0;
        let y = ((packed >> 10) & 0x3FF) as f32 / 1023.0 * 2.0 - 1.0;
        let z = ((packed >> 20) & 0x3FF) as f32 / 1023.0 * 2.0 - 1.0;
        vec3::new(x, y, z).normalize()
    }
}

// ============================================================================
// MESHLET BUILDER
// ============================================================================

/// Configuration for meshlet generation
struct MeshletConfig {
    /// Maximum vertices per meshlet
    max_vertices: u32,
    /// Maximum triangles per meshlet
    max_triangles: u32,
    /// Generate cone culling data
    generate_cones: bool,
    /// Optimize for cache efficiency
    optimize_cache: bool,
    /// Generate LOD meshlets
    generate_lods: bool,
    /// LOD reduction ratio (0.5 = half triangles per level)
    lod_ratio: f32,
    /// Maximum LOD levels
    max_lod_levels: u32,
}

impl Default for MeshletConfig {
    fn default() -> Self {
        MeshletConfig {
            max_vertices: MESHLET_MAX_VERTICES as u32,
            max_triangles: MESHLET_MAX_TRIANGLES as u32,
            generate_cones: true,
            optimize_cache: true,
            generate_lods: true,
            lod_ratio: 0.5,
            max_lod_levels: 8,
        }
    }
}

/// Meshlet builder - converts triangle meshes to meshlet format
struct MeshletBuilder {
    config: MeshletConfig,
}

impl MeshletBuilder {
    fn new(config: MeshletConfig) -> Self {
        MeshletBuilder { config }
    }

    /// Build meshlets from index and vertex data
    fn build(&self, indices: &[u32], vertices: &[MeshVertex]) -> MeshletMesh {
        let mut mesh = MeshletMesh {
            meshlets: Vec::new(),
            vertex_indices: Vec::new(),
            primitive_indices: Vec::new(),
            vertices: vertices.to_vec(),
            bounds: self.compute_bounds(vertices),
            lod_count: 1,
            meshlets_per_lod: Vec::new(),
        };

        // Generate base LOD meshlets
        let base_meshlets = self.generate_meshlets(indices, vertices, 0);
        let base_count = base_meshlets.len() as u32;
        mesh.meshlets_per_lod.push(base_count);

        for meshlet in base_meshlets {
            mesh.meshlets.push(meshlet);
        }

        // Generate LOD meshlets if enabled
        if self.config.generate_lods {
            let mut current_indices = indices.to_vec();

            for lod in 1..self.config.max_lod_levels {
                // Simplify mesh
                let target_count = (current_indices.len() as f32 * self.config.lod_ratio) as usize;
                if target_count < 12 {
                    break; // Minimum 4 triangles
                }

                current_indices = self.simplify_mesh(&current_indices, vertices, target_count);

                // Generate meshlets for this LOD
                let lod_meshlets = self.generate_meshlets(&current_indices, vertices, lod as u8);
                let lod_count = lod_meshlets.len() as u32;

                if lod_count == 0 {
                    break;
                }

                mesh.meshlets_per_lod.push(lod_count);
                mesh.lod_count += 1;

                for meshlet in lod_meshlets {
                    mesh.meshlets.push(meshlet);
                }
            }
        }

        mesh
    }

    /// Generate meshlets for a single LOD level
    fn generate_meshlets(&self, indices: &[u32], vertices: &[MeshVertex], lod_level: u8) -> Vec<Meshlet> {
        let mut meshlets = Vec::new();
        let triangle_count = indices.len() / 3;

        if triangle_count == 0 {
            return meshlets;
        }

        // Use greedy meshlet building
        let mut used_triangles = vec![false; triangle_count];
        let mut triangle_adjacency = self.build_adjacency(indices, vertices.len());

        while let Some(seed) = self.find_unused_triangle(&used_triangles) {
            let mut meshlet = Meshlet::new();
            meshlet.lod_level = lod_level;

            let mut meshlet_vertices: Vec<u32> = Vec::new();
            let mut meshlet_triangles: Vec<u32> = Vec::new();
            let mut vertex_map: HashMap<u32, u8> = HashMap::new();

            // BFS from seed triangle
            let mut frontier: Vec<u32> = vec![seed as u32];

            while let Some(tri_idx) = frontier.pop() {
                if used_triangles[tri_idx as usize] {
                    continue;
                }

                // Get triangle vertices
                let v0 = indices[tri_idx as usize * 3];
                let v1 = indices[tri_idx as usize * 3 + 1];
                let v2 = indices[tri_idx as usize * 3 + 2];

                // Count new vertices needed
                let mut new_verts = 0;
                if !vertex_map.contains_key(&v0) { new_verts += 1; }
                if !vertex_map.contains_key(&v1) { new_verts += 1; }
                if !vertex_map.contains_key(&v2) { new_verts += 1; }

                // Check limits
                if meshlet_vertices.len() + new_verts > self.config.max_vertices as usize {
                    continue;
                }
                if meshlet_triangles.len() >= self.config.max_triangles as usize {
                    break;
                }

                // Add triangle
                used_triangles[tri_idx as usize] = true;
                meshlet_triangles.push(tri_idx);

                // Add vertices
                for v in [v0, v1, v2] {
                    if !vertex_map.contains_key(&v) {
                        vertex_map.insert(v, meshlet_vertices.len() as u8);
                        meshlet_vertices.push(v);
                    }
                }

                // Add adjacent triangles to frontier
                for adj in &triangle_adjacency[tri_idx as usize] {
                    if !used_triangles[*adj as usize] {
                        frontier.push(*adj);
                    }
                }
            }

            // Finalize meshlet
            meshlet.vertex_count = meshlet_vertices.len() as u8;
            meshlet.triangle_count = meshlet_triangles.len() as u8;

            // Compute bounds
            let bounds = self.compute_meshlet_bounds(&meshlet_vertices, vertices);
            meshlet.bounds_center = bounds.center;
            meshlet.bounds_radius = bounds.radius;

            // Compute cone for backface culling
            if self.config.generate_cones {
                let (apex, axis, cutoff) = self.compute_cone(&meshlet_triangles, indices, vertices);
                meshlet.cone_apex = apex;
                meshlet.cone_axis = axis;
                meshlet.cone_cutoff = cutoff;
            }

            // Compute LOD error
            meshlet.lod_error = self.compute_lod_error(&meshlet_vertices, vertices, lod_level);

            meshlets.push(meshlet);
        }

        meshlets
    }

    /// Build triangle adjacency list
    fn build_adjacency(&self, indices: &[u32], vertex_count: usize) -> Vec<Vec<u32>> {
        let triangle_count = indices.len() / 3;
        let mut adjacency: Vec<Vec<u32>> = vec![Vec::new(); triangle_count];

        // Build edge to triangle map
        let mut edge_triangles: HashMap<(u32, u32), Vec<u32>> = HashMap::new();

        for tri in 0..triangle_count {
            let v0 = indices[tri * 3];
            let v1 = indices[tri * 3 + 1];
            let v2 = indices[tri * 3 + 2];

            // Add all three edges (sorted to ensure consistent keys)
            for (a, b) in [(v0, v1), (v1, v2), (v2, v0)] {
                let edge = if a < b { (a, b) } else { (b, a) };
                edge_triangles.entry(edge).or_default().push(tri as u32);
            }
        }

        // Build adjacency from shared edges
        for triangles in edge_triangles.values() {
            for i in 0..triangles.len() {
                for j in (i + 1)..triangles.len() {
                    adjacency[triangles[i] as usize].push(triangles[j]);
                    adjacency[triangles[j] as usize].push(triangles[i]);
                }
            }
        }

        adjacency
    }

    /// Find first unused triangle
    fn find_unused_triangle(&self, used: &[bool]) -> Option<usize> {
        used.iter().position(|&u| !u)
    }

    /// Compute bounding sphere for meshlet vertices
    fn compute_meshlet_bounds(&self, vertex_indices: &[u32], vertices: &[MeshVertex]) -> BoundingSphere {
        if vertex_indices.is_empty() {
            return BoundingSphere::new(vec3::zero(), 0.0);
        }

        // Compute centroid
        let mut center = vec3::zero();
        for &vi in vertex_indices {
            center = center + vertices[vi as usize].position;
        }
        center = center / (vertex_indices.len() as f32);

        // Find maximum distance from center
        let mut max_dist_sq = 0.0f32;
        for &vi in vertex_indices {
            let dist_sq = (vertices[vi as usize].position - center).length_squared();
            max_dist_sq = max_dist_sq.max(dist_sq);
        }

        BoundingSphere::new(center, max_dist_sq.sqrt())
    }

    /// Compute normal cone for backface culling
    fn compute_cone(&self, triangles: &[u32], indices: &[u32], vertices: &[MeshVertex]) -> (vec3, vec3, f32) {
        if triangles.is_empty() {
            return (vec3::zero(), vec3::new(0.0, 0.0, 1.0), -1.0);
        }

        // Compute average normal
        let mut avg_normal = vec3::zero();
        let mut normals: Vec<vec3> = Vec::new();

        for &tri in triangles {
            let i0 = indices[tri as usize * 3] as usize;
            let i1 = indices[tri as usize * 3 + 1] as usize;
            let i2 = indices[tri as usize * 3 + 2] as usize;

            let v0 = vertices[i0].position;
            let v1 = vertices[i1].position;
            let v2 = vertices[i2].position;

            let edge1 = v1 - v0;
            let edge2 = v2 - v0;
            let normal = edge1.cross(edge2).normalize();

            if normal.length_squared() > 0.0 {
                normals.push(normal);
                avg_normal = avg_normal + normal;
            }
        }

        if normals.is_empty() {
            return (vec3::zero(), vec3::new(0.0, 0.0, 1.0), -1.0);
        }

        let axis = avg_normal.normalize();

        // Find minimum dot product (widest angle from average)
        let mut min_dot = 1.0f32;
        for normal in &normals {
            min_dot = min_dot.min(normal.dot(axis));
        }

        // Compute apex (furthest point along -axis direction)
        let mut apex = vec3::zero();
        let mut max_proj = f32::NEG_INFINITY;

        for &tri in triangles {
            for i in 0..3 {
                let vi = indices[tri as usize * 3 + i] as usize;
                let pos = vertices[vi].position;
                let proj = -pos.dot(axis);
                if proj > max_proj {
                    max_proj = proj;
                    apex = pos;
                }
            }
        }

        (apex, axis, min_dot)
    }

    /// Compute LOD error metric
    fn compute_lod_error(&self, vertex_indices: &[u32], vertices: &[MeshVertex], lod_level: u8) -> f32 {
        // Simple error metric based on LOD level and meshlet size
        let base_error = (1 << lod_level) as f32;
        let size_factor = 1.0 / (vertex_indices.len() as f32).sqrt();
        base_error * size_factor
    }

    /// Simplify mesh for LOD generation (quadric error metrics)
    fn simplify_mesh(&self, indices: &[u32], vertices: &[MeshVertex], target_count: usize) -> Vec<u32> {
        // Simplified implementation - edge collapse with quadric error
        let mut result = indices.to_vec();

        // Build quadrics for each vertex
        let mut quadrics: Vec<[f32; 10]> = vec![[0.0; 10]; vertices.len()];

        for tri in 0..(result.len() / 3) {
            let i0 = result[tri * 3] as usize;
            let i1 = result[tri * 3 + 1] as usize;
            let i2 = result[tri * 3 + 2] as usize;

            let v0 = vertices[i0].position;
            let v1 = vertices[i1].position;
            let v2 = vertices[i2].position;

            // Compute plane equation
            let n = (v1 - v0).cross(v2 - v0).normalize();
            let d = -n.dot(v0);

            // Add plane quadric to vertices
            let q = self.plane_quadric(n, d);
            for i in [i0, i1, i2] {
                for j in 0..10 {
                    quadrics[i][j] += q[j];
                }
            }
        }

        // Iteratively collapse edges until target reached
        let mut vertex_map: Vec<u32> = (0..vertices.len() as u32).collect();

        while result.len() > target_count {
            // Find best edge to collapse
            let mut best_error = f32::INFINITY;
            let mut best_edge = (0u32, 0u32);

            for tri in 0..(result.len() / 3) {
                for e in 0..3 {
                    let v0 = self.find_root(&vertex_map, result[tri * 3 + e]);
                    let v1 = self.find_root(&vertex_map, result[tri * 3 + (e + 1) % 3]);

                    if v0 == v1 {
                        continue;
                    }

                    // Compute collapse error
                    let q = self.add_quadrics(&quadrics[v0 as usize], &quadrics[v1 as usize]);
                    let pos = vertices[v0 as usize].position;
                    let error = self.evaluate_quadric(&q, pos);

                    if error < best_error {
                        best_error = error;
                        best_edge = (v0, v1);
                    }
                }
            }

            if best_edge.0 == best_edge.1 {
                break;
            }

            // Collapse edge
            vertex_map[best_edge.1 as usize] = best_edge.0;

            // Merge quadrics
            quadrics[best_edge.0 as usize] = self.add_quadrics(
                &quadrics[best_edge.0 as usize],
                &quadrics[best_edge.1 as usize]
            );

            // Update indices and remove degenerate triangles
            let mut new_result = Vec::new();
            for tri in 0..(result.len() / 3) {
                let i0 = self.find_root(&vertex_map, result[tri * 3]);
                let i1 = self.find_root(&vertex_map, result[tri * 3 + 1]);
                let i2 = self.find_root(&vertex_map, result[tri * 3 + 2]);

                if i0 != i1 && i1 != i2 && i2 != i0 {
                    new_result.push(i0);
                    new_result.push(i1);
                    new_result.push(i2);
                }
            }

            result = new_result;
        }

        result
    }

    /// Compute quadric from plane equation
    fn plane_quadric(&self, n: vec3, d: f32) -> [f32; 10] {
        [
            n.x * n.x, n.x * n.y, n.x * n.z, n.x * d,
            n.y * n.y, n.y * n.z, n.y * d,
            n.z * n.z, n.z * d,
            d * d
        ]
    }

    /// Add two quadrics
    fn add_quadrics(&self, a: &[f32; 10], b: &[f32; 10]) -> [f32; 10] {
        let mut result = [0.0; 10];
        for i in 0..10 {
            result[i] = a[i] + b[i];
        }
        result
    }

    /// Evaluate quadric error at position
    fn evaluate_quadric(&self, q: &[f32; 10], p: vec3) -> f32 {
        let x = p.x;
        let y = p.y;
        let z = p.z;

        q[0] * x * x + 2.0 * q[1] * x * y + 2.0 * q[2] * x * z + 2.0 * q[3] * x +
        q[4] * y * y + 2.0 * q[5] * y * z + 2.0 * q[6] * y +
        q[7] * z * z + 2.0 * q[8] * z +
        q[9]
    }

    /// Find root in union-find structure
    fn find_root(&self, map: &[u32], mut v: u32) -> u32 {
        while map[v as usize] != v {
            v = map[v as usize];
        }
        v
    }

    /// Compute mesh bounding box
    fn compute_bounds(&self, vertices: &[MeshVertex]) -> AABB {
        if vertices.is_empty() {
            return AABB::new(vec3::zero(), vec3::zero());
        }

        let mut min = vertices[0].position;
        let mut max = vertices[0].position;

        for v in vertices {
            min = vec3::new(
                min.x.min(v.position.x),
                min.y.min(v.position.y),
                min.z.min(v.position.z),
            );
            max = vec3::new(
                max.x.max(v.position.x),
                max.y.max(v.position.y),
                max.z.max(v.position.z),
            );
        }

        AABB::new(min, max)
    }
}

// ============================================================================
// GPU SCENE STRUCTURES
// ============================================================================

/// Maximum instances per draw call
const MAX_INSTANCES_PER_DRAW: u32 = 65536;

/// Maximum unique meshes in scene
const MAX_MESHES: u32 = 16384;

/// Maximum materials
const MAX_MATERIALS: u32 = 4096;

/// GPU instance data for indirect rendering
#[repr(C)]
struct GpuInstance {
    /// Model matrix (row-major)
    model_matrix: [f32; 12],
    /// Previous frame model matrix for motion vectors
    prev_model_matrix: [f32; 12],
    /// Mesh ID
    mesh_id: u32,
    /// Material ID
    material_id: u32,
    /// Instance flags (visible, shadow caster, etc.)
    flags: u32,
    /// Custom data (per-instance parameters)
    custom_data: [f32; 4],
}

impl GpuInstance {
    /// Instance flag: visible in main view
    const FLAG_VISIBLE: u32 = 1 << 0;
    /// Instance flag: casts shadows
    const FLAG_CAST_SHADOW: u32 = 1 << 1;
    /// Instance flag: receives shadows
    const FLAG_RECEIVE_SHADOW: u32 = 1 << 2;
    /// Instance flag: selected (editor)
    const FLAG_SELECTED: u32 = 1 << 3;
    /// Instance flag: dynamic object
    const FLAG_DYNAMIC: u32 = 1 << 4;

    fn from_transform(transform: mat4, mesh_id: u32, material_id: u32) -> Self {
        let model = Self::pack_matrix(transform);
        GpuInstance {
            model_matrix: model,
            prev_model_matrix: model,
            mesh_id,
            material_id,
            flags: Self::FLAG_VISIBLE | Self::FLAG_CAST_SHADOW | Self::FLAG_RECEIVE_SHADOW,
            custom_data: [0.0; 4],
        }
    }

    fn pack_matrix(m: mat4) -> [f32; 12] {
        [
            m.m[0][0], m.m[0][1], m.m[0][2], m.m[0][3],
            m.m[1][0], m.m[1][1], m.m[1][2], m.m[1][3],
            m.m[2][0], m.m[2][1], m.m[2][2], m.m[2][3],
        ]
    }
}

/// GPU mesh descriptor
#[repr(C)]
struct GpuMeshDescriptor {
    /// Vertex buffer offset
    vertex_buffer_offset: u32,
    /// Vertex count
    vertex_count: u32,
    /// Index buffer offset
    index_buffer_offset: u32,
    /// Index count
    index_count: u32,
    /// Meshlet buffer offset
    meshlet_offset: u32,
    /// Meshlet count
    meshlet_count: u32,
    /// Bounding sphere center
    bounds_center: vec3,
    /// Bounding sphere radius
    bounds_radius: f32,
    /// LOD count
    lod_count: u32,
    /// LOD meshlet offsets
    lod_offsets: [u32; 8],
}

/// GPU material data
#[repr(C)]
struct GpuMaterial {
    /// Base color
    base_color: vec4,
    /// Emissive color
    emissive: vec4,
    /// Metallic factor
    metallic: f32,
    /// Roughness factor
    roughness: f32,
    /// Normal scale
    normal_scale: f32,
    /// Occlusion strength
    occlusion_strength: f32,
    /// Albedo texture index
    albedo_texture: u32,
    /// Normal texture index
    normal_texture: u32,
    /// Metallic-roughness texture index
    metallic_roughness_texture: u32,
    /// Emissive texture index
    emissive_texture: u32,
    /// Occlusion texture index
    occlusion_texture: u32,
    /// Material flags
    flags: u32,
    /// Alpha cutoff
    alpha_cutoff: f32,
    /// IOR for refraction
    ior: f32,
}

impl GpuMaterial {
    const FLAG_ALPHA_TEST: u32 = 1 << 0;
    const FLAG_ALPHA_BLEND: u32 = 1 << 1;
    const FLAG_DOUBLE_SIDED: u32 = 1 << 2;
    const FLAG_UNLIT: u32 = 1 << 3;
    const FLAG_TRANSMISSION: u32 = 1 << 4;

    fn default_pbr() -> Self {
        GpuMaterial {
            base_color: vec4::new(1.0, 1.0, 1.0, 1.0),
            emissive: vec4::zero(),
            metallic: 0.0,
            roughness: 0.5,
            normal_scale: 1.0,
            occlusion_strength: 1.0,
            albedo_texture: u32::MAX,
            normal_texture: u32::MAX,
            metallic_roughness_texture: u32::MAX,
            emissive_texture: u32::MAX,
            occlusion_texture: u32::MAX,
            flags: 0,
            alpha_cutoff: 0.5,
            ior: 1.5,
        }
    }
}

// ============================================================================
// INDIRECT DRAW COMMANDS
// ============================================================================

/// Indirect draw command for indexed geometry
#[repr(C)]
struct DrawIndexedIndirectCommand {
    /// Number of indices per instance
    index_count: u32,
    /// Number of instances to draw
    instance_count: u32,
    /// Base index within index buffer
    first_index: u32,
    /// Value added to vertex index before indexing into vertex buffer
    base_vertex: i32,
    /// First instance to draw
    first_instance: u32,
}

/// Indirect draw command with mesh shader dispatch
#[repr(C)]
struct DispatchMeshIndirectCommand {
    /// X dimension of mesh shader workgroups
    group_count_x: u32,
    /// Y dimension (usually 1 for meshlets)
    group_count_y: u32,
    /// Z dimension (usually 1)
    group_count_z: u32,
}

/// Draw call batch for multi-draw indirect
struct DrawBatch {
    /// Material ID for this batch
    material_id: u32,
    /// Mesh ID
    mesh_id: u32,
    /// LOD level
    lod_level: u32,
    /// Command buffer offset
    command_offset: u32,
    /// Number of draw commands
    command_count: u32,
    /// Instance buffer offset
    instance_offset: u32,
    /// Instance count
    instance_count: u32,
}

// ============================================================================
// GPU SCENE MANAGER
// ============================================================================

/// GPU scene buffer manager
struct GpuSceneBuffers {
    /// Instance data buffer
    instance_buffer: GpuBuffer,
    /// Mesh descriptor buffer
    mesh_buffer: GpuBuffer,
    /// Material buffer
    material_buffer: GpuBuffer,
    /// Vertex buffer (all meshes)
    vertex_buffer: GpuBuffer,
    /// Index buffer (all meshes)
    index_buffer: GpuBuffer,
    /// Meshlet buffer
    meshlet_buffer: GpuBuffer,
    /// Meshlet vertex indices
    meshlet_vertex_buffer: GpuBuffer,
    /// Meshlet primitive indices
    meshlet_primitive_buffer: GpuBuffer,
    /// Indirect draw command buffer
    draw_command_buffer: GpuBuffer,
    /// Draw count buffer (for indirect count)
    draw_count_buffer: GpuBuffer,
    /// Visible instance indices
    visible_instance_buffer: GpuBuffer,

    /// Current instance count
    instance_count: u32,
    /// Current mesh count
    mesh_count: u32,
    /// Current material count
    material_count: u32,
    /// Current vertex offset
    vertex_offset: u32,
    /// Current index offset
    index_offset: u32,
    /// Current meshlet offset
    meshlet_offset: u32,
}

impl GpuSceneBuffers {
    fn new(device: &GpuDevice) -> Self {
        let instance_buffer = device.create_buffer(&BufferDescriptor {
            size: MAX_INSTANCES_PER_DRAW as u64 * std::mem::size_of::<GpuInstance>() as u64,
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Instance Buffer"),
        });

        let mesh_buffer = device.create_buffer(&BufferDescriptor {
            size: MAX_MESHES as u64 * std::mem::size_of::<GpuMeshDescriptor>() as u64,
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Mesh Descriptor Buffer"),
        });

        let material_buffer = device.create_buffer(&BufferDescriptor {
            size: MAX_MATERIALS as u64 * std::mem::size_of::<GpuMaterial>() as u64,
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Material Buffer"),
        });

        let vertex_buffer = device.create_buffer(&BufferDescriptor {
            size: 256 * 1024 * 1024, // 256 MB vertex budget
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Global Vertex Buffer"),
        });

        let index_buffer = device.create_buffer(&BufferDescriptor {
            size: 128 * 1024 * 1024, // 128 MB index budget
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Global Index Buffer"),
        });

        let meshlet_buffer = device.create_buffer(&BufferDescriptor {
            size: 64 * 1024 * 1024, // 64 MB meshlet budget
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Meshlet Buffer"),
        });

        let meshlet_vertex_buffer = device.create_buffer(&BufferDescriptor {
            size: 128 * 1024 * 1024,
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Meshlet Vertex Index Buffer"),
        });

        let meshlet_primitive_buffer = device.create_buffer(&BufferDescriptor {
            size: 64 * 1024 * 1024,
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Meshlet Primitive Index Buffer"),
        });

        let draw_command_buffer = device.create_buffer(&BufferDescriptor {
            size: MAX_INSTANCES_PER_DRAW as u64 * std::mem::size_of::<DrawIndexedIndirectCommand>() as u64,
            usage: BufferUsage::STORAGE | BufferUsage::INDIRECT,
            label: Some("Indirect Draw Command Buffer"),
        });

        let draw_count_buffer = device.create_buffer(&BufferDescriptor {
            size: 16, // Single u32 count + padding
            usage: BufferUsage::STORAGE | BufferUsage::INDIRECT | BufferUsage::COPY_SRC,
            label: Some("Draw Count Buffer"),
        });

        let visible_instance_buffer = device.create_buffer(&BufferDescriptor {
            size: MAX_INSTANCES_PER_DRAW as u64 * 4,
            usage: BufferUsage::STORAGE,
            label: Some("Visible Instance Buffer"),
        });

        GpuSceneBuffers {
            instance_buffer,
            mesh_buffer,
            material_buffer,
            vertex_buffer,
            index_buffer,
            meshlet_buffer,
            meshlet_vertex_buffer,
            meshlet_primitive_buffer,
            draw_command_buffer,
            draw_count_buffer,
            visible_instance_buffer,
            instance_count: 0,
            mesh_count: 0,
            material_count: 0,
            vertex_offset: 0,
            index_offset: 0,
            meshlet_offset: 0,
        }
    }

    /// Upload mesh data to GPU buffers
    fn upload_mesh(&mut self, queue: &GpuQueue, mesh: &MeshletMesh) -> u32 {
        let mesh_id = self.mesh_count;

        // Upload vertices
        let vertex_data = bytemuck::cast_slice(&mesh.vertices);
        queue.write_buffer(&self.vertex_buffer, self.vertex_offset as u64, vertex_data);
        let vertex_offset = self.vertex_offset;
        self.vertex_offset += vertex_data.len() as u32;

        // Upload meshlets
        let meshlet_data = bytemuck::cast_slice(&mesh.meshlets);
        queue.write_buffer(&self.meshlet_buffer, self.meshlet_offset as u64 * std::mem::size_of::<Meshlet>() as u64, meshlet_data);
        let meshlet_offset = self.meshlet_offset;
        self.meshlet_offset += mesh.meshlets.len() as u32;

        // Create mesh descriptor
        let descriptor = GpuMeshDescriptor {
            vertex_buffer_offset: vertex_offset,
            vertex_count: mesh.vertices.len() as u32,
            index_buffer_offset: 0,
            index_count: 0,
            meshlet_offset,
            meshlet_count: mesh.meshlets.len() as u32,
            bounds_center: mesh.bounds.center(),
            bounds_radius: mesh.bounds.extents().length(),
            lod_count: mesh.lod_count,
            lod_offsets: [0; 8],
        };

        queue.write_buffer(
            &self.mesh_buffer,
            mesh_id as u64 * std::mem::size_of::<GpuMeshDescriptor>() as u64,
            bytemuck::bytes_of(&descriptor)
        );

        self.mesh_count += 1;
        mesh_id
    }

    /// Upload material to GPU buffer
    fn upload_material(&mut self, queue: &GpuQueue, material: &GpuMaterial) -> u32 {
        let material_id = self.material_count;

        queue.write_buffer(
            &self.material_buffer,
            material_id as u64 * std::mem::size_of::<GpuMaterial>() as u64,
            bytemuck::bytes_of(material)
        );

        self.material_count += 1;
        material_id
    }

    /// Add instance to scene
    fn add_instance(&mut self, queue: &GpuQueue, instance: &GpuInstance) -> u32 {
        let instance_id = self.instance_count;

        queue.write_buffer(
            &self.instance_buffer,
            instance_id as u64 * std::mem::size_of::<GpuInstance>() as u64,
            bytemuck::bytes_of(instance)
        );

        self.instance_count += 1;
        instance_id
    }
}

// ============================================================================
// GPU-DRIVEN RENDERING PIPELINE
// ============================================================================

/// Render pass type for GPU-driven rendering
enum GpuDrivenPassType {
    /// Early Z pre-pass
    DepthPrepass,
    /// Shadow map pass
    ShadowPass,
    /// G-buffer fill
    GBufferPass,
    /// Forward opaque
    ForwardOpaque,
    /// Forward transparent
    ForwardTransparent,
    /// Visibility buffer
    VisibilityBuffer,
}

/// GPU-driven renderer configuration
struct GpuDrivenConfig {
    /// Enable two-phase occlusion culling
    two_phase_culling: bool,
    /// Enable meshlet rendering (requires mesh shaders or emulation)
    meshlet_rendering: bool,
    /// Enable visibility buffer deferred
    visibility_buffer: bool,
    /// LOD selection method
    lod_selection: LodSelectionMethod,
    /// Maximum triangles per frame
    triangle_budget: u32,
    /// Enable GPU-driven shadows
    gpu_driven_shadows: bool,
    /// Shadow cascade count
    shadow_cascades: u32,
}

/// LOD selection method
enum LodSelectionMethod {
    /// Screen-space error threshold
    ScreenSpaceError,
    /// Distance-based selection
    Distance,
    /// Triangle budget based
    TriangleBudget,
}

impl Default for GpuDrivenConfig {
    fn default() -> Self {
        GpuDrivenConfig {
            two_phase_culling: true,
            meshlet_rendering: true,
            visibility_buffer: true,
            lod_selection: LodSelectionMethod::ScreenSpaceError,
            triangle_budget: 10_000_000, // 10M triangles
            gpu_driven_shadows: true,
            shadow_cascades: 4,
        }
    }
}

/// Main GPU-driven rendering pipeline
struct GpuDrivenRenderer {
    /// Scene buffers
    scene: GpuSceneBuffers,
    /// GPU culling system
    culling: GpuCullingSystem,
    /// Configuration
    config: GpuDrivenConfig,
    /// Per-frame uniform buffer
    frame_uniforms: GpuBuffer,
    /// Bindless texture manager
    bindless_textures: BindlessTextureManager,
    /// Draw batches for current frame
    draw_batches: Vec<DrawBatch>,

    // Pipelines
    /// Instance culling compute pipeline
    cull_instances_pipeline: ComputePipeline,
    /// Meshlet culling compute pipeline
    cull_meshlets_pipeline: ComputePipeline,
    /// Draw command generation pipeline
    generate_draws_pipeline: ComputePipeline,
    /// LOD selection pipeline
    lod_selection_pipeline: ComputePipeline,
    /// Visibility buffer render pipeline
    visibility_pipeline: RenderPipeline,
    /// Material resolve pipeline
    material_resolve_pipeline: ComputePipeline,

    // Bind groups
    scene_bind_group: BindGroup,
    culling_bind_group: BindGroup,
    visibility_bind_group: BindGroup,
}

impl GpuDrivenRenderer {
    fn new(device: &GpuDevice, config: GpuDrivenConfig) -> Self {
        let scene = GpuSceneBuffers::new(device);
        let culling = GpuCullingSystem::new(device, &GpuCullingConfig::default());

        let frame_uniforms = device.create_buffer(&BufferDescriptor {
            size: 256,
            usage: BufferUsage::UNIFORM | BufferUsage::COPY_DST,
            label: Some("Frame Uniforms"),
        });

        // Create compute pipelines
        let cull_instances_pipeline = Self::create_cull_instances_pipeline(device);
        let cull_meshlets_pipeline = Self::create_cull_meshlets_pipeline(device);
        let generate_draws_pipeline = Self::create_generate_draws_pipeline(device);
        let lod_selection_pipeline = Self::create_lod_selection_pipeline(device);
        let visibility_pipeline = Self::create_visibility_pipeline(device);
        let material_resolve_pipeline = Self::create_material_resolve_pipeline(device);

        // Create bind groups (placeholder)
        let scene_bind_group = Self::create_scene_bind_group(device, &scene);
        let culling_bind_group = Self::create_culling_bind_group(device, &scene, &culling);
        let visibility_bind_group = Self::create_visibility_bind_group(device, &scene);

        GpuDrivenRenderer {
            scene,
            culling,
            config,
            frame_uniforms,
            bindless_textures: BindlessTextureManager::new(device, 16384),
            draw_batches: Vec::new(),
            cull_instances_pipeline,
            cull_meshlets_pipeline,
            generate_draws_pipeline,
            lod_selection_pipeline,
            visibility_pipeline,
            material_resolve_pipeline,
            scene_bind_group,
            culling_bind_group,
            visibility_bind_group,
        }
    }

    /// Begin frame - update uniforms and reset state
    fn begin_frame(&mut self, queue: &GpuQueue, view: &CameraView) {
        // Update frame uniforms
        let uniforms = FrameUniforms {
            view_matrix: view.view_matrix,
            projection_matrix: view.projection_matrix,
            view_projection: view.projection_matrix * view.view_matrix,
            inv_view_projection: (view.projection_matrix * view.view_matrix).inverse(),
            camera_position: view.position,
            camera_forward: view.forward,
            screen_size: view.screen_size,
            near_plane: view.near,
            far_plane: view.far,
            time: view.time,
            frame_index: view.frame_index,
        };

        queue.write_buffer(&self.frame_uniforms, 0, bytemuck::bytes_of(&uniforms));

        // Clear draw batches
        self.draw_batches.clear();
    }

    /// GPU culling pass - cull instances and meshlets
    fn cull_pass(&mut self, encoder: &mut CommandEncoder, view: &CameraView) {
        // Phase 1: Instance culling
        {
            let mut pass = encoder.begin_compute_pass(&ComputePassDescriptor {
                label: Some("Instance Culling"),
            });

            pass.set_pipeline(&self.cull_instances_pipeline);
            pass.set_bind_group(0, &self.scene_bind_group, &[]);
            pass.set_bind_group(1, &self.culling_bind_group, &[]);

            let workgroups = (self.scene.instance_count + 63) / 64;
            pass.dispatch_workgroups(workgroups, 1, 1);
        }

        // Phase 2: LOD selection
        {
            let mut pass = encoder.begin_compute_pass(&ComputePassDescriptor {
                label: Some("LOD Selection"),
            });

            pass.set_pipeline(&self.lod_selection_pipeline);
            pass.set_bind_group(0, &self.scene_bind_group, &[]);
            pass.set_bind_group(1, &self.culling_bind_group, &[]);

            let workgroups = (self.scene.instance_count + 63) / 64;
            pass.dispatch_workgroups(workgroups, 1, 1);
        }

        // Phase 3: Meshlet culling (if enabled)
        if self.config.meshlet_rendering {
            let mut pass = encoder.begin_compute_pass(&ComputePassDescriptor {
                label: Some("Meshlet Culling"),
            });

            pass.set_pipeline(&self.cull_meshlets_pipeline);
            pass.set_bind_group(0, &self.scene_bind_group, &[]);
            pass.set_bind_group(1, &self.culling_bind_group, &[]);

            // Dispatch based on visible instance count
            let workgroups = (self.scene.instance_count * MAX_MESHLETS_PER_MESH + 63) / 64;
            pass.dispatch_workgroups(workgroups, 1, 1);
        }

        // Phase 4: Generate draw commands
        {
            let mut pass = encoder.begin_compute_pass(&ComputePassDescriptor {
                label: Some("Generate Draw Commands"),
            });

            pass.set_pipeline(&self.generate_draws_pipeline);
            pass.set_bind_group(0, &self.scene_bind_group, &[]);
            pass.set_bind_group(1, &self.culling_bind_group, &[]);

            pass.dispatch_workgroups(1, 1, 1);
        }
    }

    /// Render visibility buffer
    fn render_visibility_buffer(&self, encoder: &mut CommandEncoder, depth_target: &TextureView, visibility_target: &TextureView) {
        let mut pass = encoder.begin_render_pass(&RenderPassDescriptor {
            label: Some("Visibility Buffer"),
            color_attachments: &[RenderPassColorAttachment {
                view: visibility_target,
                resolve_target: None,
                ops: Operations {
                    load: LoadOp::Clear(Color::TRANSPARENT),
                    store: true,
                },
            }],
            depth_stencil_attachment: Some(RenderPassDepthStencilAttachment {
                view: depth_target,
                depth_ops: Some(Operations {
                    load: LoadOp::Clear(1.0),
                    store: true,
                }),
                stencil_ops: None,
            }),
        });

        pass.set_pipeline(&self.visibility_pipeline);
        pass.set_bind_group(0, &self.scene_bind_group, &[]);
        pass.set_bind_group(1, &self.visibility_bind_group, &[]);

        // Multi-draw indirect with count
        pass.multi_draw_indexed_indirect_count(
            &self.scene.draw_command_buffer,
            0,
            &self.scene.draw_count_buffer,
            0,
            MAX_INSTANCES_PER_DRAW,
        );
    }

    /// Resolve visibility buffer to material shading
    fn resolve_materials(&self, encoder: &mut CommandEncoder, visibility_buffer: &TextureView, output: &TextureView) {
        let mut pass = encoder.begin_compute_pass(&ComputePassDescriptor {
            label: Some("Material Resolve"),
        });

        pass.set_pipeline(&self.material_resolve_pipeline);
        pass.set_bind_group(0, &self.scene_bind_group, &[]);
        pass.set_bind_group(1, &self.visibility_bind_group, &[]);

        // Dispatch per-pixel
        let width = (self.config.triangle_budget / 1000).max(1920);
        let height = (self.config.triangle_budget / 2000).max(1080);
        pass.dispatch_workgroups((width + 7) / 8, (height + 7) / 8, 1);
    }

    // Pipeline creation helpers
    fn create_cull_instances_pipeline(device: &GpuDevice) -> ComputePipeline {
        let shader = device.create_shader_module(&ShaderModuleDescriptor {
            label: Some("Instance Culling Shader"),
            source: ShaderSource::Wgsl(INSTANCE_CULL_SHADER.into()),
        });

        device.create_compute_pipeline(&ComputePipelineDescriptor {
            label: Some("Instance Culling Pipeline"),
            layout: None,
            module: &shader,
            entry_point: "cull_instances",
        })
    }

    fn create_cull_meshlets_pipeline(device: &GpuDevice) -> ComputePipeline {
        let shader = device.create_shader_module(&ShaderModuleDescriptor {
            label: Some("Meshlet Culling Shader"),
            source: ShaderSource::Wgsl(MESHLET_CULL_SHADER.into()),
        });

        device.create_compute_pipeline(&ComputePipelineDescriptor {
            label: Some("Meshlet Culling Pipeline"),
            layout: None,
            module: &shader,
            entry_point: "cull_meshlets",
        })
    }

    fn create_generate_draws_pipeline(device: &GpuDevice) -> ComputePipeline {
        let shader = device.create_shader_module(&ShaderModuleDescriptor {
            label: Some("Generate Draws Shader"),
            source: ShaderSource::Wgsl(GENERATE_DRAWS_SHADER.into()),
        });

        device.create_compute_pipeline(&ComputePipelineDescriptor {
            label: Some("Generate Draws Pipeline"),
            layout: None,
            module: &shader,
            entry_point: "generate_draws",
        })
    }

    fn create_lod_selection_pipeline(device: &GpuDevice) -> ComputePipeline {
        let shader = device.create_shader_module(&ShaderModuleDescriptor {
            label: Some("LOD Selection Shader"),
            source: ShaderSource::Wgsl(LOD_SELECTION_SHADER.into()),
        });

        device.create_compute_pipeline(&ComputePipelineDescriptor {
            label: Some("LOD Selection Pipeline"),
            layout: None,
            module: &shader,
            entry_point: "select_lod",
        })
    }

    fn create_visibility_pipeline(device: &GpuDevice) -> RenderPipeline {
        let shader = device.create_shader_module(&ShaderModuleDescriptor {
            label: Some("Visibility Buffer Shader"),
            source: ShaderSource::Wgsl(VISIBILITY_BUFFER_SHADER.into()),
        });

        device.create_render_pipeline(&RenderPipelineDescriptor {
            label: Some("Visibility Buffer Pipeline"),
            layout: None,
            vertex: VertexState {
                module: &shader,
                entry_point: "vs_main",
                buffers: &[],
            },
            fragment: Some(FragmentState {
                module: &shader,
                entry_point: "fs_main",
                targets: &[ColorTargetState {
                    format: TextureFormat::Rg32Uint,
                    blend: None,
                    write_mask: ColorWrites::ALL,
                }],
            }),
            primitive: PrimitiveState {
                topology: PrimitiveTopology::TriangleList,
                front_face: FrontFace::Ccw,
                cull_mode: Some(Face::Back),
                ..Default::default()
            },
            depth_stencil: Some(DepthStencilState {
                format: TextureFormat::Depth32Float,
                depth_write_enabled: true,
                depth_compare: CompareFunction::Less,
                stencil: StencilState::default(),
                bias: DepthBiasState::default(),
            }),
            multisample: MultisampleState::default(),
            multiview: None,
        })
    }

    fn create_material_resolve_pipeline(device: &GpuDevice) -> ComputePipeline {
        let shader = device.create_shader_module(&ShaderModuleDescriptor {
            label: Some("Material Resolve Shader"),
            source: ShaderSource::Wgsl(MATERIAL_RESOLVE_SHADER.into()),
        });

        device.create_compute_pipeline(&ComputePipelineDescriptor {
            label: Some("Material Resolve Pipeline"),
            layout: None,
            module: &shader,
            entry_point: "resolve_material",
        })
    }

    fn create_scene_bind_group(device: &GpuDevice, scene: &GpuSceneBuffers) -> BindGroup {
        // Placeholder - actual implementation would create proper bind group
        BindGroup::default()
    }

    fn create_culling_bind_group(device: &GpuDevice, scene: &GpuSceneBuffers, culling: &GpuCullingSystem) -> BindGroup {
        BindGroup::default()
    }

    fn create_visibility_bind_group(device: &GpuDevice, scene: &GpuSceneBuffers) -> BindGroup {
        BindGroup::default()
    }
}

/// Frame uniform data
#[repr(C)]
struct FrameUniforms {
    view_matrix: mat4,
    projection_matrix: mat4,
    view_projection: mat4,
    inv_view_projection: mat4,
    camera_position: vec3,
    camera_forward: vec3,
    screen_size: vec2,
    near_plane: f32,
    far_plane: f32,
    time: f32,
    frame_index: u32,
}

/// Camera view data
struct CameraView {
    view_matrix: mat4,
    projection_matrix: mat4,
    position: vec3,
    forward: vec3,
    screen_size: vec2,
    near: f32,
    far: f32,
    time: f32,
    frame_index: u32,
}

// ============================================================================
// BINDLESS TEXTURE MANAGER
// ============================================================================

/// Bindless texture manager for GPU-driven rendering
struct BindlessTextureManager {
    /// Texture descriptor heap
    texture_heap: Vec<TextureView>,
    /// Sampler descriptor heap
    sampler_heap: Vec<Sampler>,
    /// Free texture slots
    free_texture_slots: Vec<u32>,
    /// Free sampler slots
    free_sampler_slots: Vec<u32>,
    /// Maximum texture count
    max_textures: u32,
    /// Bind group for texture array
    bind_group: Option<BindGroup>,
}

impl BindlessTextureManager {
    fn new(device: &GpuDevice, max_textures: u32) -> Self {
        BindlessTextureManager {
            texture_heap: Vec::with_capacity(max_textures as usize),
            sampler_heap: Vec::new(),
            free_texture_slots: (0..max_textures).rev().collect(),
            free_sampler_slots: Vec::new(),
            max_textures,
            bind_group: None,
        }
    }

    /// Allocate a texture slot
    fn allocate_texture(&mut self, view: TextureView) -> Option<u32> {
        let slot = self.free_texture_slots.pop()?;

        if slot as usize >= self.texture_heap.len() {
            self.texture_heap.resize_with(slot as usize + 1, || TextureView::default());
        }

        self.texture_heap[slot as usize] = view;
        Some(slot)
    }

    /// Free a texture slot
    fn free_texture(&mut self, slot: u32) {
        self.free_texture_slots.push(slot);
    }

    /// Rebuild bind group after texture changes
    fn rebuild_bind_group(&mut self, device: &GpuDevice) {
        // Create bind group with all textures
        // Implementation depends on specific GPU API
    }
}

// ============================================================================
// GPU SHADERS
// ============================================================================

/// Instance culling compute shader
const INSTANCE_CULL_SHADER: &str = r#"
struct FrameUniforms {
    view_matrix: mat4x4<f32>,
    projection_matrix: mat4x4<f32>,
    view_projection: mat4x4<f32>,
    inv_view_projection: mat4x4<f32>,
    camera_position: vec3<f32>,
    _pad0: f32,
    camera_forward: vec3<f32>,
    _pad1: f32,
    screen_size: vec2<f32>,
    near_plane: f32,
    far_plane: f32,
    time: f32,
    frame_index: u32,
    _pad2: vec2<f32>,
}

struct GpuInstance {
    model_matrix: mat3x4<f32>,
    prev_model_matrix: mat3x4<f32>,
    mesh_id: u32,
    material_id: u32,
    flags: u32,
    custom_data: vec4<f32>,
}

struct GpuMeshDescriptor {
    vertex_buffer_offset: u32,
    vertex_count: u32,
    index_buffer_offset: u32,
    index_count: u32,
    meshlet_offset: u32,
    meshlet_count: u32,
    bounds_center: vec3<f32>,
    bounds_radius: f32,
    lod_count: u32,
    lod_offsets: array<u32, 8>,
}

struct Frustum {
    planes: array<vec4<f32>, 6>,
}

struct CullingOutput {
    visible_count: atomic<u32>,
}

@group(0) @binding(0) var<uniform> frame: FrameUniforms;
@group(0) @binding(1) var<storage, read> instances: array<GpuInstance>;
@group(0) @binding(2) var<storage, read> meshes: array<GpuMeshDescriptor>;

@group(1) @binding(0) var<storage, read_write> visible_instances: array<u32>;
@group(1) @binding(1) var<storage, read_write> output: CullingOutput;
@group(1) @binding(2) var<uniform> frustum: Frustum;
@group(1) @binding(3) var depth_pyramid: texture_2d<f32>;

const FLAG_VISIBLE: u32 = 1u;
const FLAG_CAST_SHADOW: u32 = 2u;

fn extract_frustum_planes(vp: mat4x4<f32>) -> array<vec4<f32>, 6> {
    var planes: array<vec4<f32>, 6>;

    // Left
    planes[0] = vec4<f32>(
        vp[0][3] + vp[0][0],
        vp[1][3] + vp[1][0],
        vp[2][3] + vp[2][0],
        vp[3][3] + vp[3][0]
    );

    // Right
    planes[1] = vec4<f32>(
        vp[0][3] - vp[0][0],
        vp[1][3] - vp[1][0],
        vp[2][3] - vp[2][0],
        vp[3][3] - vp[3][0]
    );

    // Bottom
    planes[2] = vec4<f32>(
        vp[0][3] + vp[0][1],
        vp[1][3] + vp[1][1],
        vp[2][3] + vp[2][1],
        vp[3][3] + vp[3][1]
    );

    // Top
    planes[3] = vec4<f32>(
        vp[0][3] - vp[0][1],
        vp[1][3] - vp[1][1],
        vp[2][3] - vp[2][1],
        vp[3][3] - vp[3][1]
    );

    // Near
    planes[4] = vec4<f32>(
        vp[0][2],
        vp[1][2],
        vp[2][2],
        vp[3][2]
    );

    // Far
    planes[5] = vec4<f32>(
        vp[0][3] - vp[0][2],
        vp[1][3] - vp[1][2],
        vp[2][3] - vp[2][2],
        vp[3][3] - vp[3][2]
    );

    // Normalize planes
    for (var i = 0u; i < 6u; i = i + 1u) {
        let len = length(planes[i].xyz);
        planes[i] = planes[i] / len;
    }

    return planes;
}

fn is_sphere_visible(center: vec3<f32>, radius: f32, planes: array<vec4<f32>, 6>) -> bool {
    for (var i = 0u; i < 6u; i = i + 1u) {
        let dist = dot(planes[i].xyz, center) + planes[i].w;
        if (dist < -radius) {
            return false;
        }
    }
    return true;
}

fn transform_sphere(center: vec3<f32>, radius: f32, model: mat3x4<f32>) -> vec4<f32> {
    let model_4x4 = mat4x4<f32>(
        vec4<f32>(model[0][0], model[1][0], model[2][0], 0.0),
        vec4<f32>(model[0][1], model[1][1], model[2][1], 0.0),
        vec4<f32>(model[0][2], model[1][2], model[2][2], 0.0),
        vec4<f32>(model[0][3], model[1][3], model[2][3], 1.0)
    );

    let world_center = (model_4x4 * vec4<f32>(center, 1.0)).xyz;

    // Compute maximum scale for radius
    let scale_x = length(vec3<f32>(model[0][0], model[1][0], model[2][0]));
    let scale_y = length(vec3<f32>(model[0][1], model[1][1], model[2][1]));
    let scale_z = length(vec3<f32>(model[0][2], model[1][2], model[2][2]));
    let max_scale = max(max(scale_x, scale_y), scale_z);

    return vec4<f32>(world_center, radius * max_scale);
}

fn occlusion_cull(center: vec3<f32>, radius: f32) -> bool {
    // Project sphere to screen space
    let clip = frame.view_projection * vec4<f32>(center, 1.0);

    if (clip.w <= 0.0) {
        return true; // Behind camera, visible (conservative)
    }

    let ndc = clip.xyz / clip.w;

    if (ndc.x < -1.0 || ndc.x > 1.0 || ndc.y < -1.0 || ndc.y > 1.0) {
        return true; // Off screen, skip HiZ test
    }

    // Compute screen-space bounding box
    let screen_radius = radius / clip.w * frame.screen_size.y * 0.5;
    let pixel_radius = max(1.0, screen_radius);

    // Compute HiZ mip level
    let mip_level = log2(pixel_radius * 2.0);
    let mip = u32(max(0.0, mip_level));

    // Sample HiZ pyramid
    let uv = (ndc.xy * 0.5 + 0.5);
    let hiz_size = vec2<f32>(textureDimensions(depth_pyramid, i32(mip)));
    let texel = vec2<i32>(uv * hiz_size);

    let hiz_depth = textureLoad(depth_pyramid, texel, i32(mip)).r;

    // Conservative depth test
    let sphere_depth = ndc.z - (radius / clip.w);

    return sphere_depth <= hiz_depth;
}

@compute @workgroup_size(64)
fn cull_instances(@builtin(global_invocation_id) global_id: vec3<u32>) {
    let instance_id = global_id.x;

    if (instance_id >= arrayLength(&instances)) {
        return;
    }

    let instance = instances[instance_id];

    // Skip if instance flag not visible
    if ((instance.flags & FLAG_VISIBLE) == 0u) {
        return;
    }

    let mesh = meshes[instance.mesh_id];

    // Transform bounding sphere to world space
    let world_bounds = transform_sphere(mesh.bounds_center, mesh.bounds_radius, instance.model_matrix);

    // Frustum culling
    let planes = extract_frustum_planes(frame.view_projection);
    if (!is_sphere_visible(world_bounds.xyz, world_bounds.w, planes)) {
        return;
    }

    // Occlusion culling
    if (!occlusion_cull(world_bounds.xyz, world_bounds.w)) {
        return;
    }

    // Instance is visible - add to output
    let output_index = atomicAdd(&output.visible_count, 1u);
    visible_instances[output_index] = instance_id;
}
"#;

/// Meshlet culling compute shader
const MESHLET_CULL_SHADER: &str = r#"
struct Meshlet {
    vertex_offset: u32,
    vertex_count: u32, // Actually u8 but padded
    triangle_offset: u32,
    triangle_count: u32, // Actually u8 but padded
    bounds_center: vec3<f32>,
    bounds_radius: f32,
    cone_apex: vec3<f32>,
    _pad0: f32,
    cone_axis: vec3<f32>,
    cone_cutoff: f32,
    lod_level: u32,
    lod_error: f32,
    _pad1: vec2<f32>,
}

struct FrameUniforms {
    view_matrix: mat4x4<f32>,
    projection_matrix: mat4x4<f32>,
    view_projection: mat4x4<f32>,
    inv_view_projection: mat4x4<f32>,
    camera_position: vec3<f32>,
    _pad0: f32,
    camera_forward: vec3<f32>,
    _pad1: f32,
    screen_size: vec2<f32>,
    near_plane: f32,
    far_plane: f32,
    time: f32,
    frame_index: u32,
    _pad2: vec2<f32>,
}

struct GpuInstance {
    model_matrix: mat3x4<f32>,
    prev_model_matrix: mat3x4<f32>,
    mesh_id: u32,
    material_id: u32,
    flags: u32,
    custom_data: vec4<f32>,
}

struct CullingOutput {
    visible_meshlet_count: atomic<u32>,
}

struct VisibleMeshlet {
    instance_id: u32,
    meshlet_id: u32,
}

@group(0) @binding(0) var<uniform> frame: FrameUniforms;
@group(0) @binding(1) var<storage, read> instances: array<GpuInstance>;
@group(0) @binding(2) var<storage, read> meshlets: array<Meshlet>;
@group(0) @binding(3) var<storage, read> visible_instances: array<u32>;
@group(0) @binding(4) var<storage, read> instance_meshlet_counts: array<u32>;

@group(1) @binding(0) var<storage, read_write> visible_meshlets: array<VisibleMeshlet>;
@group(1) @binding(1) var<storage, read_write> output: CullingOutput;
@group(1) @binding(2) var depth_pyramid: texture_2d<f32>;

fn transform_to_world(pos: vec3<f32>, model: mat3x4<f32>) -> vec3<f32> {
    return vec3<f32>(
        dot(model[0], vec4<f32>(pos, 1.0)),
        dot(model[1], vec4<f32>(pos, 1.0)),
        dot(model[2], vec4<f32>(pos, 1.0))
    );
}

fn cone_cull(cone_apex: vec3<f32>, cone_axis: vec3<f32>, cone_cutoff: f32, camera_pos: vec3<f32>) -> bool {
    if (cone_cutoff < 0.0) {
        return true; // Degenerate cone, always visible
    }

    let view_dir = normalize(camera_pos - cone_apex);
    return dot(view_dir, cone_axis) >= cone_cutoff;
}

fn is_sphere_visible_frustum(center: vec3<f32>, radius: f32, vp: mat4x4<f32>) -> bool {
    let clip = vp * vec4<f32>(center, 1.0);

    // Check all 6 frustum planes in clip space
    let visible =
        clip.x >= -clip.w - radius &&
        clip.x <= clip.w + radius &&
        clip.y >= -clip.w - radius &&
        clip.y <= clip.w + radius &&
        clip.z >= 0.0 - radius &&
        clip.z <= clip.w + radius;

    return visible;
}

@compute @workgroup_size(64)
fn cull_meshlets(@builtin(global_invocation_id) global_id: vec3<u32>) {
    let work_id = global_id.x;

    // Decode instance and meshlet index from linear work ID
    // This assumes meshlets are packed sequentially per instance
    var accumulated = 0u;
    var instance_index = 0u;
    var meshlet_index = 0u;

    for (var i = 0u; i < arrayLength(&visible_instances); i = i + 1u) {
        let inst_id = visible_instances[i];
        let meshlet_count = instance_meshlet_counts[inst_id];

        if (work_id < accumulated + meshlet_count) {
            instance_index = i;
            meshlet_index = work_id - accumulated;
            break;
        }

        accumulated = accumulated + meshlet_count;
    }

    if (instance_index >= arrayLength(&visible_instances)) {
        return;
    }

    let instance_id = visible_instances[instance_index];
    let instance = instances[instance_id];
    let meshlet = meshlets[meshlet_index];

    // Transform bounds to world space
    let world_center = transform_to_world(meshlet.bounds_center, instance.model_matrix);
    let scale = length(vec3<f32>(instance.model_matrix[0][0], instance.model_matrix[1][0], instance.model_matrix[2][0]));
    let world_radius = meshlet.bounds_radius * scale;

    // Frustum cull
    if (!is_sphere_visible_frustum(world_center, world_radius, frame.view_projection)) {
        return;
    }

    // Cone cull (backface)
    let world_apex = transform_to_world(meshlet.cone_apex, instance.model_matrix);
    let world_axis = normalize(transform_to_world(meshlet.cone_axis, instance.model_matrix) - transform_to_world(vec3<f32>(0.0), instance.model_matrix));

    if (!cone_cull(world_apex, world_axis, meshlet.cone_cutoff, frame.camera_position)) {
        return;
    }

    // Add to visible list
    let output_index = atomicAdd(&output.visible_meshlet_count, 1u);
    visible_meshlets[output_index] = VisibleMeshlet(instance_id, meshlet_index);
}
"#;

/// Draw command generation shader
const GENERATE_DRAWS_SHADER: &str = r#"
struct DrawIndexedIndirectCommand {
    index_count: u32,
    instance_count: u32,
    first_index: u32,
    base_vertex: i32,
    first_instance: u32,
}

struct VisibleMeshlet {
    instance_id: u32,
    meshlet_id: u32,
}

struct Meshlet {
    vertex_offset: u32,
    vertex_count: u32,
    triangle_offset: u32,
    triangle_count: u32,
    bounds_center: vec3<f32>,
    bounds_radius: f32,
    cone_apex: vec3<f32>,
    _pad0: f32,
    cone_axis: vec3<f32>,
    cone_cutoff: f32,
    lod_level: u32,
    lod_error: f32,
    _pad1: vec2<f32>,
}

struct DrawCountOutput {
    count: atomic<u32>,
}

@group(0) @binding(0) var<storage, read> visible_meshlets: array<VisibleMeshlet>;
@group(0) @binding(1) var<storage, read> meshlets: array<Meshlet>;
@group(0) @binding(2) var<uniform> visible_count: u32;

@group(1) @binding(0) var<storage, read_write> draw_commands: array<DrawIndexedIndirectCommand>;
@group(1) @binding(1) var<storage, read_write> draw_count: DrawCountOutput;

@compute @workgroup_size(64)
fn generate_draws(@builtin(global_invocation_id) global_id: vec3<u32>) {
    let idx = global_id.x;

    if (idx >= visible_count) {
        return;
    }

    let visible = visible_meshlets[idx];
    let meshlet = meshlets[visible.meshlet_id];

    // Generate draw command for this meshlet
    let draw_idx = atomicAdd(&draw_count.count, 1u);

    draw_commands[draw_idx] = DrawIndexedIndirectCommand(
        meshlet.triangle_count * 3u,  // index_count
        1u,                            // instance_count
        meshlet.triangle_offset,       // first_index
        i32(meshlet.vertex_offset),    // base_vertex
        visible.instance_id            // first_instance (for instancing)
    );
}
"#;

/// LOD selection compute shader
const LOD_SELECTION_SHADER: &str = r#"
struct FrameUniforms {
    view_matrix: mat4x4<f32>,
    projection_matrix: mat4x4<f32>,
    view_projection: mat4x4<f32>,
    inv_view_projection: mat4x4<f32>,
    camera_position: vec3<f32>,
    _pad0: f32,
    camera_forward: vec3<f32>,
    _pad1: f32,
    screen_size: vec2<f32>,
    near_plane: f32,
    far_plane: f32,
    time: f32,
    frame_index: u32,
    _pad2: vec2<f32>,
}

struct GpuInstance {
    model_matrix: mat3x4<f32>,
    prev_model_matrix: mat3x4<f32>,
    mesh_id: u32,
    material_id: u32,
    flags: u32,
    custom_data: vec4<f32>,
}

struct GpuMeshDescriptor {
    vertex_buffer_offset: u32,
    vertex_count: u32,
    index_buffer_offset: u32,
    index_count: u32,
    meshlet_offset: u32,
    meshlet_count: u32,
    bounds_center: vec3<f32>,
    bounds_radius: f32,
    lod_count: u32,
    lod_offsets: array<u32, 8>,
}

struct LodConfig {
    screen_error_threshold: f32,
    lod_bias: f32,
    max_lod: u32,
    force_lod: i32, // -1 for automatic
}

struct InstanceLodOutput {
    selected_lod: u32,
    meshlet_offset: u32,
    meshlet_count: u32,
}

@group(0) @binding(0) var<uniform> frame: FrameUniforms;
@group(0) @binding(1) var<storage, read> instances: array<GpuInstance>;
@group(0) @binding(2) var<storage, read> meshes: array<GpuMeshDescriptor>;
@group(0) @binding(3) var<storage, read> visible_instances: array<u32>;
@group(0) @binding(4) var<uniform> lod_config: LodConfig;

@group(1) @binding(0) var<storage, read_write> instance_lods: array<InstanceLodOutput>;

fn compute_screen_size(center: vec3<f32>, radius: f32, vp: mat4x4<f32>, screen_height: f32) -> f32 {
    let clip = vp * vec4<f32>(center, 1.0);

    if (clip.w <= 0.0) {
        return screen_height; // Very close, use highest LOD
    }

    // Screen-space radius in pixels
    return (radius / clip.w) * screen_height;
}

@compute @workgroup_size(64)
fn select_lod(@builtin(global_invocation_id) global_id: vec3<u32>) {
    let idx = global_id.x;

    if (idx >= arrayLength(&visible_instances)) {
        return;
    }

    let instance_id = visible_instances[idx];
    let instance = instances[instance_id];
    let mesh = meshes[instance.mesh_id];

    // Force LOD if configured
    if (lod_config.force_lod >= 0) {
        let lod = u32(min(lod_config.force_lod, i32(mesh.lod_count - 1u)));
        instance_lods[idx] = InstanceLodOutput(
            lod,
            mesh.lod_offsets[lod],
            mesh.lod_offsets[lod + 1u] - mesh.lod_offsets[lod]
        );
        return;
    }

    // Transform bounds center to world space
    let world_center = vec3<f32>(
        dot(instance.model_matrix[0], vec4<f32>(mesh.bounds_center, 1.0)),
        dot(instance.model_matrix[1], vec4<f32>(mesh.bounds_center, 1.0)),
        dot(instance.model_matrix[2], vec4<f32>(mesh.bounds_center, 1.0))
    );

    // Get maximum scale
    let scale = max(
        length(vec3<f32>(instance.model_matrix[0][0], instance.model_matrix[1][0], instance.model_matrix[2][0])),
        max(
            length(vec3<f32>(instance.model_matrix[0][1], instance.model_matrix[1][1], instance.model_matrix[2][1])),
            length(vec3<f32>(instance.model_matrix[0][2], instance.model_matrix[1][2], instance.model_matrix[2][2]))
        )
    );

    let world_radius = mesh.bounds_radius * scale;

    // Compute screen-space size
    let screen_size = compute_screen_size(world_center, world_radius, frame.view_projection, frame.screen_size.y);

    // Select LOD based on screen error threshold
    var selected_lod = 0u;
    let threshold = lod_config.screen_error_threshold;

    // Each LOD halves the detail, so screen size thresholds double
    var lod_threshold = threshold;
    for (var lod = 0u; lod < mesh.lod_count; lod = lod + 1u) {
        if (screen_size > lod_threshold) {
            selected_lod = lod;
            break;
        }
        lod_threshold = lod_threshold * 2.0;
        selected_lod = lod;
    }

    // Apply LOD bias
    selected_lod = u32(max(0, min(i32(mesh.lod_count - 1u), i32(selected_lod) + i32(lod_config.lod_bias))));

    // Clamp to max LOD
    selected_lod = min(selected_lod, min(lod_config.max_lod, mesh.lod_count - 1u));

    // Output selected LOD info
    let meshlet_offset = mesh.lod_offsets[selected_lod];
    let next_offset = select(mesh.meshlet_count, mesh.lod_offsets[selected_lod + 1u], selected_lod + 1u < mesh.lod_count);

    instance_lods[idx] = InstanceLodOutput(
        selected_lod,
        meshlet_offset,
        next_offset - meshlet_offset
    );
}
"#;

/// Visibility buffer rendering shader
const VISIBILITY_BUFFER_SHADER: &str = r#"
struct FrameUniforms {
    view_matrix: mat4x4<f32>,
    projection_matrix: mat4x4<f32>,
    view_projection: mat4x4<f32>,
    inv_view_projection: mat4x4<f32>,
    camera_position: vec3<f32>,
    _pad0: f32,
    camera_forward: vec3<f32>,
    _pad1: f32,
    screen_size: vec2<f32>,
    near_plane: f32,
    far_plane: f32,
    time: f32,
    frame_index: u32,
    _pad2: vec2<f32>,
}

struct GpuInstance {
    model_matrix: mat3x4<f32>,
    prev_model_matrix: mat3x4<f32>,
    mesh_id: u32,
    material_id: u32,
    flags: u32,
    custom_data: vec4<f32>,
}

struct MeshVertex {
    position: vec3<f32>,
    normal: u32,
    tangent: u32,
    uv0: vec2<f32>,
    uv1: vec2<f32>,
}

struct VisibleMeshlet {
    instance_id: u32,
    meshlet_id: u32,
}

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) @interpolate(flat) instance_id: u32,
    @location(1) @interpolate(flat) triangle_id: u32,
    @location(2) barycentrics: vec2<f32>,
}

@group(0) @binding(0) var<uniform> frame: FrameUniforms;
@group(0) @binding(1) var<storage, read> instances: array<GpuInstance>;
@group(0) @binding(2) var<storage, read> vertices: array<MeshVertex>;
@group(0) @binding(3) var<storage, read> meshlet_vertices: array<u32>;
@group(0) @binding(4) var<storage, read> meshlet_primitives: array<u32>;
@group(0) @binding(5) var<storage, read> visible_meshlets: array<VisibleMeshlet>;

fn get_model_matrix(inst: GpuInstance) -> mat4x4<f32> {
    return mat4x4<f32>(
        vec4<f32>(inst.model_matrix[0][0], inst.model_matrix[1][0], inst.model_matrix[2][0], 0.0),
        vec4<f32>(inst.model_matrix[0][1], inst.model_matrix[1][1], inst.model_matrix[2][1], 0.0),
        vec4<f32>(inst.model_matrix[0][2], inst.model_matrix[1][2], inst.model_matrix[2][2], 0.0),
        vec4<f32>(inst.model_matrix[0][3], inst.model_matrix[1][3], inst.model_matrix[2][3], 1.0)
    );
}

@vertex
fn vs_main(
    @builtin(vertex_index) vertex_index: u32,
    @builtin(instance_index) instance_index: u32
) -> VertexOutput {
    let visible = visible_meshlets[instance_index];
    let instance = instances[visible.instance_id];

    // Fetch vertex from meshlet
    let local_vertex_index = meshlet_vertices[vertex_index];
    let vertex = vertices[local_vertex_index];

    let model = get_model_matrix(instance);
    let world_pos = model * vec4<f32>(vertex.position, 1.0);
    let clip_pos = frame.view_projection * world_pos;

    // Compute barycentrics for gradient calculation
    let tri_vertex = vertex_index % 3u;
    var bary = vec2<f32>(0.0, 0.0);
    if (tri_vertex == 0u) {
        bary = vec2<f32>(1.0, 0.0);
    } else if (tri_vertex == 1u) {
        bary = vec2<f32>(0.0, 1.0);
    }

    var output: VertexOutput;
    output.position = clip_pos;
    output.instance_id = visible.instance_id;
    output.triangle_id = vertex_index / 3u;
    output.barycentrics = bary;

    return output;
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec2<u32> {
    // Pack visibility data: instance_id in R, triangle_id in G
    return vec2<u32>(input.instance_id, input.triangle_id);
}
"#;

/// Material resolve compute shader
const MATERIAL_RESOLVE_SHADER: &str = r#"
struct FrameUniforms {
    view_matrix: mat4x4<f32>,
    projection_matrix: mat4x4<f32>,
    view_projection: mat4x4<f32>,
    inv_view_projection: mat4x4<f32>,
    camera_position: vec3<f32>,
    _pad0: f32,
    camera_forward: vec3<f32>,
    _pad1: f32,
    screen_size: vec2<f32>,
    near_plane: f32,
    far_plane: f32,
    time: f32,
    frame_index: u32,
    _pad2: vec2<f32>,
}

struct GpuInstance {
    model_matrix: mat3x4<f32>,
    prev_model_matrix: mat3x4<f32>,
    mesh_id: u32,
    material_id: u32,
    flags: u32,
    custom_data: vec4<f32>,
}

struct GpuMaterial {
    base_color: vec4<f32>,
    emissive: vec4<f32>,
    metallic: f32,
    roughness: f32,
    normal_scale: f32,
    occlusion_strength: f32,
    albedo_texture: u32,
    normal_texture: u32,
    metallic_roughness_texture: u32,
    emissive_texture: u32,
    occlusion_texture: u32,
    flags: u32,
    alpha_cutoff: f32,
    ior: f32,
}

struct MeshVertex {
    position: vec3<f32>,
    normal: u32,
    tangent: u32,
    uv0: vec2<f32>,
    uv1: vec2<f32>,
}

@group(0) @binding(0) var<uniform> frame: FrameUniforms;
@group(0) @binding(1) var<storage, read> instances: array<GpuInstance>;
@group(0) @binding(2) var<storage, read> materials: array<GpuMaterial>;
@group(0) @binding(3) var<storage, read> vertices: array<MeshVertex>;
@group(0) @binding(4) var<storage, read> meshlet_vertices: array<u32>;
@group(0) @binding(5) var<storage, read> meshlet_primitives: array<u32>;

@group(1) @binding(0) var visibility_buffer: texture_2d<u32>;
@group(1) @binding(1) var depth_buffer: texture_2d<f32>;
@group(1) @binding(2) var output_color: texture_storage_2d<rgba16float, write>;
@group(1) @binding(3) var bindless_textures: binding_array<texture_2d<f32>>;
@group(1) @binding(4) var texture_sampler: sampler;

const PI: f32 = 3.14159265359;
const INVALID_ID: u32 = 0xFFFFFFFFu;

fn unpack_normal(packed: u32) -> vec3<f32> {
    let x = f32(packed & 0x3FFu) / 1023.0 * 2.0 - 1.0;
    let y = f32((packed >> 10u) & 0x3FFu) / 1023.0 * 2.0 - 1.0;
    let z = f32((packed >> 20u) & 0x3FFu) / 1023.0 * 2.0 - 1.0;
    return normalize(vec3<f32>(x, y, z));
}

fn get_model_matrix(inst: GpuInstance) -> mat4x4<f32> {
    return mat4x4<f32>(
        vec4<f32>(inst.model_matrix[0][0], inst.model_matrix[1][0], inst.model_matrix[2][0], 0.0),
        vec4<f32>(inst.model_matrix[0][1], inst.model_matrix[1][1], inst.model_matrix[2][1], 0.0),
        vec4<f32>(inst.model_matrix[0][2], inst.model_matrix[1][2], inst.model_matrix[2][2], 0.0),
        vec4<f32>(inst.model_matrix[0][3], inst.model_matrix[1][3], inst.model_matrix[2][3], 1.0)
    );
}

fn sample_texture(tex_id: u32, uv: vec2<f32>) -> vec4<f32> {
    if (tex_id == INVALID_ID) {
        return vec4<f32>(1.0);
    }
    return textureSampleLevel(bindless_textures[tex_id], texture_sampler, uv, 0.0);
}

// GGX/Trowbridge-Reitz NDF
fn distribution_ggx(n_dot_h: f32, roughness: f32) -> f32 {
    let a = roughness * roughness;
    let a2 = a * a;
    let n_dot_h2 = n_dot_h * n_dot_h;
    let denom = n_dot_h2 * (a2 - 1.0) + 1.0;
    return a2 / (PI * denom * denom);
}

// Schlick-GGX geometry function
fn geometry_schlick_ggx(n_dot_v: f32, roughness: f32) -> f32 {
    let r = roughness + 1.0;
    let k = (r * r) / 8.0;
    return n_dot_v / (n_dot_v * (1.0 - k) + k);
}

fn geometry_smith(n_dot_v: f32, n_dot_l: f32, roughness: f32) -> f32 {
    return geometry_schlick_ggx(n_dot_v, roughness) * geometry_schlick_ggx(n_dot_l, roughness);
}

// Fresnel-Schlick
fn fresnel_schlick(cos_theta: f32, f0: vec3<f32>) -> vec3<f32> {
    return f0 + (1.0 - f0) * pow(1.0 - cos_theta, 5.0);
}

@compute @workgroup_size(8, 8)
fn resolve_material(@builtin(global_invocation_id) global_id: vec3<u32>) {
    let pixel = vec2<i32>(global_id.xy);
    let screen_size = vec2<i32>(frame.screen_size);

    if (pixel.x >= screen_size.x || pixel.y >= screen_size.y) {
        return;
    }

    // Read visibility buffer
    let visibility = textureLoad(visibility_buffer, pixel, 0);
    let instance_id = visibility.r;
    let triangle_id = visibility.g;

    // Check for sky/background
    if (instance_id == INVALID_ID) {
        textureStore(output_color, pixel, vec4<f32>(0.0, 0.0, 0.0, 0.0));
        return;
    }

    let instance = instances[instance_id];
    let material = materials[instance.material_id];
    let model = get_model_matrix(instance);

    // Reconstruct position from depth
    let depth = textureLoad(depth_buffer, pixel, 0).r;
    let uv = (vec2<f32>(pixel) + 0.5) / frame.screen_size;
    let ndc = vec3<f32>(uv.x * 2.0 - 1.0, (1.0 - uv.y) * 2.0 - 1.0, depth);
    let world_pos_h = frame.inv_view_projection * vec4<f32>(ndc, 1.0);
    let world_pos = world_pos_h.xyz / world_pos_h.w;

    // Fetch triangle vertices (simplified - actual impl would use meshlet data)
    let base_idx = triangle_id * 3u;
    let v0 = vertices[meshlet_vertices[base_idx]];
    let v1 = vertices[meshlet_vertices[base_idx + 1u]];
    let v2 = vertices[meshlet_vertices[base_idx + 2u]];

    // Compute barycentrics from screen position (simplified)
    let bary = vec3<f32>(0.33, 0.33, 0.34);

    // Interpolate attributes
    let local_normal = normalize(
        unpack_normal(v0.normal) * bary.x +
        unpack_normal(v1.normal) * bary.y +
        unpack_normal(v2.normal) * bary.z
    );
    let tex_coord = v0.uv0 * bary.x + v1.uv0 * bary.y + v2.uv0 * bary.z;

    // Transform normal to world space
    let normal_matrix = mat3x3<f32>(
        model[0].xyz,
        model[1].xyz,
        model[2].xyz
    );
    var world_normal = normalize(normal_matrix * local_normal);

    // Sample textures
    let albedo = material.base_color * sample_texture(material.albedo_texture, tex_coord);
    let mr = sample_texture(material.metallic_roughness_texture, tex_coord);
    let metallic = material.metallic * mr.b;
    let roughness = material.roughness * mr.g;
    let emissive = material.emissive.rgb * sample_texture(material.emissive_texture, tex_coord).rgb;

    // Normal mapping
    if (material.normal_texture != INVALID_ID) {
        let tangent = unpack_normal(v0.tangent);
        let bitangent = cross(world_normal, tangent);
        let tbn = mat3x3<f32>(tangent, bitangent, world_normal);
        let sampled_normal = sample_texture(material.normal_texture, tex_coord).xyz * 2.0 - 1.0;
        world_normal = normalize(tbn * (sampled_normal * vec3<f32>(material.normal_scale, material.normal_scale, 1.0)));
    }

    // PBR shading (simplified single directional light)
    let light_dir = normalize(vec3<f32>(0.5, 1.0, 0.3));
    let light_color = vec3<f32>(1.0, 0.98, 0.95);
    let view_dir = normalize(frame.camera_position - world_pos);
    let half_vec = normalize(light_dir + view_dir);

    let n_dot_l = max(dot(world_normal, light_dir), 0.0);
    let n_dot_v = max(dot(world_normal, view_dir), 0.0);
    let n_dot_h = max(dot(world_normal, half_vec), 0.0);
    let h_dot_v = max(dot(half_vec, view_dir), 0.0);

    // Cook-Torrance BRDF
    let f0 = mix(vec3<f32>(0.04), albedo.rgb, metallic);
    let d = distribution_ggx(n_dot_h, roughness);
    let g = geometry_smith(n_dot_v, n_dot_l, roughness);
    let f = fresnel_schlick(h_dot_v, f0);

    let numerator = d * g * f;
    let denominator = 4.0 * n_dot_v * n_dot_l + 0.0001;
    let specular = numerator / denominator;

    let k_d = (vec3<f32>(1.0) - f) * (1.0 - metallic);
    let diffuse = k_d * albedo.rgb / PI;

    var color = (diffuse + specular) * light_color * n_dot_l;

    // Ambient
    let ambient = vec3<f32>(0.03) * albedo.rgb;
    color = color + ambient + emissive;

    // Occlusion
    if (material.occlusion_texture != INVALID_ID) {
        let ao = sample_texture(material.occlusion_texture, tex_coord).r;
        color = color * mix(1.0, ao, material.occlusion_strength);
    }

    textureStore(output_color, pixel, vec4<f32>(color, albedo.a));
}
"#;

// ============================================================================
// SCENE SUBMISSION
// ============================================================================

/// Scene submission for GPU-driven rendering
struct SceneSubmission {
    /// Render objects to submit
    render_objects: Vec<RenderObject>,
    /// Dirty instance flags
    dirty_instances: BitSet,
    /// Instance transforms needing update
    transform_updates: Vec<(u32, mat4)>,
}

/// Render object for scene submission
struct RenderObject {
    /// Object identifier
    id: u64,
    /// Mesh asset handle
    mesh: Handle<MeshletMesh>,
    /// Material asset handle
    material: Handle<GpuMaterial>,
    /// World transform
    transform: mat4,
    /// Previous frame transform
    prev_transform: mat4,
    /// Render flags
    flags: u32,
    /// Custom shader data
    custom_data: [f32; 4],
    /// GPU instance ID (assigned after upload)
    gpu_instance_id: Option<u32>,
}

impl SceneSubmission {
    fn new() -> Self {
        SceneSubmission {
            render_objects: Vec::new(),
            dirty_instances: BitSet::new(),
            transform_updates: Vec::new(),
        }
    }

    /// Add render object to submission
    fn add_object(&mut self, object: RenderObject) -> usize {
        let index = self.render_objects.len();
        self.dirty_instances.set(index);
        self.render_objects.push(object);
        index
    }

    /// Update object transform
    fn update_transform(&mut self, index: usize, transform: mat4) {
        if index < self.render_objects.len() {
            self.render_objects[index].prev_transform = self.render_objects[index].transform;
            self.render_objects[index].transform = transform;
            self.dirty_instances.set(index);

            if let Some(gpu_id) = self.render_objects[index].gpu_instance_id {
                self.transform_updates.push((gpu_id, transform));
            }
        }
    }

    /// Flush dirty instances to GPU
    fn flush(&mut self, renderer: &mut GpuDrivenRenderer, queue: &GpuQueue) {
        // Upload new instances
        for (index, dirty) in self.dirty_instances.iter().enumerate() {
            if !dirty || index >= self.render_objects.len() {
                continue;
            }

            let obj = &mut self.render_objects[index];

            let instance = GpuInstance::from_transform(
                obj.transform,
                obj.mesh.id() as u32,
                obj.material.id() as u32,
            );

            if let Some(gpu_id) = obj.gpu_instance_id {
                // Update existing instance
                queue.write_buffer(
                    &renderer.scene.instance_buffer,
                    gpu_id as u64 * std::mem::size_of::<GpuInstance>() as u64,
                    bytemuck::bytes_of(&instance)
                );
            } else {
                // Upload new instance
                let gpu_id = renderer.scene.add_instance(queue, &instance);
                obj.gpu_instance_id = Some(gpu_id);
            }
        }

        self.dirty_instances.clear();
        self.transform_updates.clear();
    }
}

// ============================================================================
// MULTI-VIEW RENDERING
// ============================================================================

/// View for multi-view rendering (main camera, shadow cascades, reflections)
struct RenderView {
    /// View identifier
    id: u32,
    /// View type
    view_type: RenderViewType,
    /// View matrix
    view_matrix: mat4,
    /// Projection matrix
    projection_matrix: mat4,
    /// Viewport
    viewport: Rect,
    /// Render target
    target: RenderTarget,
    /// Culling mask
    culling_mask: u32,
}

/// Type of render view
enum RenderViewType {
    /// Main camera view
    MainCamera,
    /// Shadow cascade
    ShadowCascade { cascade_index: u32 },
    /// Reflection probe
    ReflectionProbe { probe_index: u32, face: u32 },
    /// Custom view
    Custom,
}

/// Render target for a view
struct RenderTarget {
    color: Option<TextureView>,
    depth: Option<TextureView>,
    visibility: Option<TextureView>,
}

/// Multi-view renderer for GPU-driven shadows and reflections
struct MultiViewRenderer {
    /// All active views
    views: Vec<RenderView>,
    /// Per-view uniform buffer
    view_uniforms: GpuBuffer,
    /// View frustum buffer for GPU culling
    view_frustums: GpuBuffer,
    /// Maximum views
    max_views: u32,
}

impl MultiViewRenderer {
    fn new(device: &GpuDevice, max_views: u32) -> Self {
        let view_uniforms = device.create_buffer(&BufferDescriptor {
            size: max_views as u64 * 256, // 256 bytes per view
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("Multi-View Uniforms"),
        });

        let view_frustums = device.create_buffer(&BufferDescriptor {
            size: max_views as u64 * 96, // 6 planes * 4 floats * 4 bytes
            usage: BufferUsage::STORAGE | BufferUsage::COPY_DST,
            label: Some("View Frustums"),
        });

        MultiViewRenderer {
            views: Vec::new(),
            view_uniforms,
            view_frustums,
            max_views,
        }
    }

    /// Setup shadow cascade views
    fn setup_shadow_cascades(&mut self, camera: &CameraView, light_dir: vec3, cascade_count: u32) {
        // Clear existing shadow views
        self.views.retain(|v| !matches!(v.view_type, RenderViewType::ShadowCascade { .. }));

        // Compute cascade splits
        let lambda = 0.95; // Logarithmic/linear blend factor
        let mut cascade_splits = Vec::new();

        for i in 0..=cascade_count {
            let p = i as f32 / cascade_count as f32;
            let log_split = camera.near * (camera.far / camera.near).powf(p);
            let lin_split = camera.near + (camera.far - camera.near) * p;
            cascade_splits.push(lambda * log_split + (1.0 - lambda) * lin_split);
        }

        // Create view for each cascade
        for i in 0..cascade_count {
            let near = cascade_splits[i as usize];
            let far = cascade_splits[i as usize + 1];

            // Compute cascade frustum corners in world space
            let frustum_corners = self.compute_frustum_corners(camera, near, far);

            // Compute light space bounding box
            let (view, proj, viewport) = self.compute_cascade_matrices(
                &frustum_corners,
                light_dir,
            );

            self.views.push(RenderView {
                id: 100 + i,
                view_type: RenderViewType::ShadowCascade { cascade_index: i },
                view_matrix: view,
                projection_matrix: proj,
                viewport,
                target: RenderTarget {
                    color: None,
                    depth: None,
                    visibility: None,
                },
                culling_mask: GpuInstance::FLAG_CAST_SHADOW,
            });
        }
    }

    fn compute_frustum_corners(&self, camera: &CameraView, near: f32, far: f32) -> [vec3; 8] {
        let inv_vp = (camera.projection_matrix * camera.view_matrix).inverse();

        let ndc_corners = [
            vec3::new(-1.0, -1.0, 0.0), // near bottom-left
            vec3::new( 1.0, -1.0, 0.0), // near bottom-right
            vec3::new(-1.0,  1.0, 0.0), // near top-left
            vec3::new( 1.0,  1.0, 0.0), // near top-right
            vec3::new(-1.0, -1.0, 1.0), // far bottom-left
            vec3::new( 1.0, -1.0, 1.0), // far bottom-right
            vec3::new(-1.0,  1.0, 1.0), // far top-left
            vec3::new( 1.0,  1.0, 1.0), // far top-right
        ];

        let mut world_corners = [vec3::zero(); 8];
        for (i, ndc) in ndc_corners.iter().enumerate() {
            let clip = vec4::new(ndc.x, ndc.y, ndc.z, 1.0);
            let world = inv_vp * clip;
            world_corners[i] = world.xyz() / world.w;
        }

        world_corners
    }

    fn compute_cascade_matrices(&self, corners: &[vec3; 8], light_dir: vec3) -> (mat4, mat4, Rect) {
        // Compute center of frustum
        let mut center = vec3::zero();
        for c in corners {
            center = center + *c;
        }
        center = center / 8.0;

        // Light view matrix
        let light_up = if light_dir.y.abs() > 0.99 {
            vec3::new(1.0, 0.0, 0.0)
        } else {
            vec3::new(0.0, 1.0, 0.0)
        };

        let view = mat4::look_at(center - light_dir * 100.0, center, light_up);

        // Transform corners to light space and compute bounds
        let mut min = vec3::new(f32::MAX, f32::MAX, f32::MAX);
        let mut max = vec3::new(f32::MIN, f32::MIN, f32::MIN);

        for c in corners {
            let light_space = (view * vec4::new(c.x, c.y, c.z, 1.0)).xyz();
            min = vec3::new(
                min.x.min(light_space.x),
                min.y.min(light_space.y),
                min.z.min(light_space.z),
            );
            max = vec3::new(
                max.x.max(light_space.x),
                max.y.max(light_space.y),
                max.z.max(light_space.z),
            );
        }

        // Add some padding
        let padding = 10.0;
        min = min - vec3::new(padding, padding, padding);
        max = max + vec3::new(padding, padding, padding);

        // Orthographic projection
        let proj = mat4::orthographic(min.x, max.x, min.y, max.y, min.z, max.z);

        let viewport = Rect {
            x: 0.0,
            y: 0.0,
            width: 2048.0,
            height: 2048.0,
        };

        (view, proj, viewport)
    }
}

/// Rectangle for viewports
struct Rect {
    x: f32,
    y: f32,
    width: f32,
    height: f32,
}

// ============================================================================
// STATISTICS AND PROFILING
// ============================================================================

/// GPU-driven rendering statistics
struct GpuDrivenStats {
    /// Total instances submitted
    instances_submitted: u32,
    /// Instances after frustum culling
    instances_after_frustum: u32,
    /// Instances after occlusion culling
    instances_after_occlusion: u32,
    /// Meshlets submitted
    meshlets_submitted: u32,
    /// Meshlets after culling
    meshlets_visible: u32,
    /// Triangles rendered
    triangles_rendered: u64,
    /// Draw calls issued
    draw_calls: u32,
    /// GPU culling time (ms)
    culling_time_ms: f32,
    /// Visibility buffer time (ms)
    visibility_time_ms: f32,
    /// Material resolve time (ms)
    material_time_ms: f32,
}

impl GpuDrivenStats {
    fn new() -> Self {
        GpuDrivenStats {
            instances_submitted: 0,
            instances_after_frustum: 0,
            instances_after_occlusion: 0,
            meshlets_submitted: 0,
            meshlets_visible: 0,
            triangles_rendered: 0,
            draw_calls: 0,
            culling_time_ms: 0.0,
            visibility_time_ms: 0.0,
            material_time_ms: 0.0,
        }
    }

    fn reset(&mut self) {
        *self = Self::new();
    }

    /// Compute culling efficiency
    fn culling_efficiency(&self) -> f32 {
        if self.instances_submitted == 0 {
            return 0.0;
        }
        1.0 - (self.instances_after_occlusion as f32 / self.instances_submitted as f32)
    }
}

// ============================================================================
// UNIT TESTS
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_meshlet_creation() {
        let meshlet = Meshlet::new();
        assert_eq!(meshlet.vertex_count, 0);
        assert_eq!(meshlet.triangle_count, 0);
        assert_eq!(meshlet.lod_level, 0);
    }

    #[test]
    fn test_meshlet_cone_visibility() {
        let mut meshlet = Meshlet::new();
        meshlet.cone_apex = vec3::new(0.0, 0.0, 0.0);
        meshlet.cone_axis = vec3::new(0.0, 0.0, 1.0);
        meshlet.cone_cutoff = 0.5; // ~60 degree half-angle

        let transform = mat4::identity();

        // Camera in front - should be visible
        let camera_front = vec3::new(0.0, 0.0, 5.0);
        assert!(meshlet.is_cone_visible(camera_front, transform));

        // Camera behind - should not be visible
        let camera_behind = vec3::new(0.0, 0.0, -5.0);
        assert!(!meshlet.is_cone_visible(camera_behind, transform));
    }

    #[test]
    fn test_meshlet_world_bounds() {
        let mut meshlet = Meshlet::new();
        meshlet.bounds_center = vec3::new(1.0, 2.0, 3.0);
        meshlet.bounds_radius = 1.0;

        // Identity transform
        let bounds = meshlet.get_world_bounds(mat4::identity());
        assert_eq!(bounds.center.x, 1.0);
        assert_eq!(bounds.center.y, 2.0);
        assert_eq!(bounds.center.z, 3.0);
        assert_eq!(bounds.radius, 1.0);

        // Scale transform
        let scale = mat4::scale(2.0, 2.0, 2.0);
        let scaled_bounds = meshlet.get_world_bounds(scale);
        assert!((scaled_bounds.radius - 2.0).abs() < 0.001);
    }

    #[test]
    fn test_vertex_normal_packing() {
        let normal = vec3::new(0.577, 0.577, 0.577).normalize();
        let packed = MeshVertex::pack_normal(normal);
        let unpacked = MeshVertex::unpack_normal(packed);

        assert!((unpacked.x - normal.x).abs() < 0.01);
        assert!((unpacked.y - normal.y).abs() < 0.01);
        assert!((unpacked.z - normal.z).abs() < 0.01);
    }

    #[test]
    fn test_meshlet_config_default() {
        let config = MeshletConfig::default();
        assert_eq!(config.max_vertices, MESHLET_MAX_VERTICES as u32);
        assert_eq!(config.max_triangles, MESHLET_MAX_TRIANGLES as u32);
        assert!(config.generate_cones);
        assert!(config.generate_lods);
    }

    #[test]
    fn test_gpu_instance_flags() {
        let mut instance = GpuInstance::from_transform(
            mat4::identity(),
            0,
            0,
        );

        assert!(instance.flags & GpuInstance::FLAG_VISIBLE != 0);
        assert!(instance.flags & GpuInstance::FLAG_CAST_SHADOW != 0);
        assert!(instance.flags & GpuInstance::FLAG_RECEIVE_SHADOW != 0);
    }

    #[test]
    fn test_gpu_material_default() {
        let material = GpuMaterial::default_pbr();

        assert_eq!(material.base_color.x, 1.0);
        assert_eq!(material.metallic, 0.0);
        assert_eq!(material.roughness, 0.5);
        assert_eq!(material.albedo_texture, u32::MAX);
    }

    #[test]
    fn test_draw_indexed_indirect_command_size() {
        assert_eq!(std::mem::size_of::<DrawIndexedIndirectCommand>(), 20);
    }

    #[test]
    fn test_lod_selection_method() {
        let config = GpuDrivenConfig::default();
        assert!(matches!(config.lod_selection, LodSelectionMethod::ScreenSpaceError));
    }

    #[test]
    fn test_stats_culling_efficiency() {
        let mut stats = GpuDrivenStats::new();
        stats.instances_submitted = 1000;
        stats.instances_after_occlusion = 250;

        let efficiency = stats.culling_efficiency();
        assert!((efficiency - 0.75).abs() < 0.001);
    }

    #[test]
    fn test_render_view_types() {
        let view = RenderView {
            id: 0,
            view_type: RenderViewType::ShadowCascade { cascade_index: 2 },
            view_matrix: mat4::identity(),
            projection_matrix: mat4::identity(),
            viewport: Rect { x: 0.0, y: 0.0, width: 1024.0, height: 1024.0 },
            target: RenderTarget {
                color: None,
                depth: None,
                visibility: None,
            },
            culling_mask: GpuInstance::FLAG_CAST_SHADOW,
        };

        if let RenderViewType::ShadowCascade { cascade_index } = view.view_type {
            assert_eq!(cascade_index, 2);
        } else {
            panic!("Expected ShadowCascade view type");
        }
    }

    #[test]
    fn test_scene_submission() {
        let mut submission = SceneSubmission::new();

        let obj = RenderObject {
            id: 1,
            mesh: Handle::invalid(),
            material: Handle::invalid(),
            transform: mat4::identity(),
            prev_transform: mat4::identity(),
            flags: GpuInstance::FLAG_VISIBLE,
            custom_data: [0.0; 4],
            gpu_instance_id: None,
        };

        let index = submission.add_object(obj);
        assert_eq!(index, 0);
        assert!(submission.dirty_instances.get(0));
    }

    #[test]
    fn test_quadric_operations() {
        let builder = MeshletBuilder::new(MeshletConfig::default());

        let n = vec3::new(0.0, 1.0, 0.0);
        let d = -5.0;
        let q = builder.plane_quadric(n, d);

        // Point on plane should have zero error
        let p = vec3::new(0.0, 5.0, 0.0);
        let error = builder.evaluate_quadric(&q, p);
        assert!(error.abs() < 0.001);
    }
}
