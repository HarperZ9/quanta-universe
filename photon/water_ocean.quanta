// =============================================================================
// QUANTA Photon - Water and Ocean Rendering
// =============================================================================
// Production-ready water and ocean simulation including FFT ocean waves,
// underwater rendering, caustics, foam, and shoreline effects.

module photon::water_ocean {
    use core::mem;
    use core::simd;
    use math::{Vec2, Vec3, Vec4, Mat4, Complex, Frustum};
    use gpu::{Buffer, Texture, Sampler, Pipeline, ComputePipeline, BindGroup, CommandEncoder};

    // =========================================================================
    // Ocean Spectrum Configuration
    // =========================================================================

    /// Ocean spectrum parameters
    pub struct OceanSpectrum {
        pub scale: f32,
        pub wind_speed: f32,
        pub wind_direction: Vec2,
        pub fetch: f32,               // Distance wind has traveled
        pub depth: f32,               // Water depth
        pub spread_blend: f32,
        pub swell: f32,
        pub peak_enhancement: f32,    // JONSWAP peak enhancement (gamma)
        pub short_waves_fade: f32,
    }

    impl OceanSpectrum {
        pub fn calm() -> Self {
            Self {
                scale: 1.0,
                wind_speed: 3.0,
                wind_direction: Vec2::new(1.0, 0.0),
                fetch: 100000.0,
                depth: 100.0,
                spread_blend: 0.5,
                swell: 0.2,
                peak_enhancement: 3.3,
                short_waves_fade: 0.01,
            }
        }

        pub fn moderate() -> Self {
            Self {
                scale: 1.0,
                wind_speed: 10.0,
                wind_direction: Vec2::new(0.707, 0.707),
                fetch: 500000.0,
                depth: 500.0,
                spread_blend: 0.6,
                swell: 0.5,
                peak_enhancement: 3.3,
                short_waves_fade: 0.01,
            }
        }

        pub fn stormy() -> Self {
            Self {
                scale: 1.0,
                wind_speed: 25.0,
                wind_direction: Vec2::new(1.0, 0.0),
                fetch: 1000000.0,
                depth: 1000.0,
                spread_blend: 0.8,
                swell: 0.8,
                peak_enhancement: 3.3,
                short_waves_fade: 0.005,
            }
        }

        /// Calculate Phillips spectrum amplitude
        pub fn phillips_amplitude(&self, k: Vec2) -> f32 {
            let k_len = k.length();
            if k_len < 0.0001 {
                return 0.0;
            }

            let k_unit = k / k_len;

            // Phillips spectrum
            let g = 9.81;
            let l = self.wind_speed * self.wind_speed / g;

            let k_dot_w = k_unit.dot(self.wind_direction.normalize());
            let phillips = ((-1.0 / (k_len * l).powi(2)).exp() / k_len.powi(4)) *
                          k_dot_w.powi(2).abs();

            // Dampen very small waves
            let l_small = l / 1000.0;
            let damping = (-k_len * k_len * l_small * l_small).exp();

            (phillips * damping).sqrt() * self.scale
        }

        /// Calculate JONSWAP spectrum (more realistic than Phillips)
        pub fn jonswap_amplitude(&self, omega: f32) -> f32 {
            let g = 9.81;

            // Peak frequency
            let omega_p = 22.0 * (g * g / (self.wind_speed * self.fetch)).powf(1.0 / 3.0);

            // Alpha parameter
            let alpha = 0.076 * (self.wind_speed * self.wind_speed / (self.fetch * g)).powf(0.22);

            // Sigma
            let sigma = if omega <= omega_p { 0.07 } else { 0.09 };

            // Peak enhancement factor
            let r = (-(omega - omega_p).powi(2) / (2.0 * sigma * sigma * omega_p * omega_p)).exp();
            let gamma_factor = self.peak_enhancement.powf(r);

            // JONSWAP spectrum
            let pm = alpha * g * g / omega.powi(5) *
                    (-1.25 * (omega_p / omega).powi(4)).exp();

            pm * gamma_factor
        }

        /// Calculate TMA spectrum (finite depth modification of JONSWAP)
        pub fn tma_amplitude(&self, omega: f32) -> f32 {
            let g = 9.81;
            let k = omega * omega / g;  // Deep water approximation
            let omega_h = omega * (self.depth / g).sqrt();

            // TMA correction for finite depth
            let phi = if omega_h <= 1.0 {
                0.5 * omega_h * omega_h
            } else if omega_h < 2.0 {
                1.0 - 0.5 * (2.0 - omega_h).powi(2)
            } else {
                1.0
            };

            self.jonswap_amplitude(omega) * phi
        }
    }

    // =========================================================================
    // FFT Ocean Simulation
    // =========================================================================

    /// FFT Ocean configuration
    pub struct FftOceanConfig {
        pub resolution: u32,          // Must be power of 2 (256, 512, 1024)
        pub patch_size: f32,          // Size of ocean patch in meters
        pub num_cascades: u32,        // Number of detail cascades (1-4)
        pub time_scale: f32,
        pub choppiness: f32,
        pub foam_threshold: f32,
        pub foam_decay: f32,
    }

    impl Default for FftOceanConfig {
        fn default() -> Self {
            Self {
                resolution: 512,
                patch_size: 1000.0,
                num_cascades: 3,
                time_scale: 1.0,
                choppiness: 1.2,
                foam_threshold: 0.5,
                foam_decay: 0.95,
            }
        }
    }

    /// GPU ocean cascade
    pub struct OceanCascade {
        patch_size: f32,
        h0_texture: Texture,          // Initial spectrum (complex)
        ht_texture: Texture,          // Time-evolved spectrum (complex)
        dx_texture: Texture,          // X displacement spectrum
        dz_texture: Texture,          // Z displacement spectrum
        displacement_map: Texture,    // Final displacement (RGB = XYZ)
        normal_map: Texture,          // Normal map from displacement
        foam_map: Texture,            // Foam/whitecap intensity
        jacobian_map: Texture,        // For foam detection
    }

    /// FFT Ocean simulation
    pub struct FftOcean {
        config: FftOceanConfig,
        spectrum: OceanSpectrum,
        cascades: Vec<OceanCascade>,

        // Compute pipelines
        spectrum_init_pipeline: ComputePipeline,
        time_evolve_pipeline: ComputePipeline,
        fft_horizontal_pipeline: ComputePipeline,
        fft_vertical_pipeline: ComputePipeline,
        combine_pipeline: ComputePipeline,
        normal_foam_pipeline: ComputePipeline,

        // Gaussian random noise texture
        gaussian_noise: Texture,

        // Uniform buffer
        params_buffer: Buffer,

        time: f32,
    }

    impl FftOcean {
        pub fn new(device: &gpu::Device, config: FftOceanConfig, spectrum: OceanSpectrum) -> Self {
            let resolution = config.resolution;

            // Create cascades with different patch sizes
            let mut cascades = Vec::new();
            for i in 0..config.num_cascades {
                let cascade_scale = 2.0_f32.powi(i as i32);
                let cascade = Self::create_cascade(device, resolution,
                    config.patch_size / cascade_scale);
                cascades.push(cascade);
            }

            // Create pipelines
            let spectrum_init_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/ocean_spectrum_init.wgsl"),
                entry_point: "init_spectrum",
            });

            let time_evolve_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/ocean_time_evolve.wgsl"),
                entry_point: "evolve_spectrum",
            });

            let fft_horizontal_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/ocean_fft.wgsl"),
                entry_point: "fft_horizontal",
            });

            let fft_vertical_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/ocean_fft.wgsl"),
                entry_point: "fft_vertical",
            });

            let combine_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/ocean_combine.wgsl"),
                entry_point: "combine_displacements",
            });

            let normal_foam_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/ocean_normal_foam.wgsl"),
                entry_point: "compute_normals_foam",
            });

            // Create Gaussian noise texture
            let gaussian_noise = Self::create_gaussian_noise_texture(device, resolution);

            // Create uniform buffer
            let params_buffer = device.create_buffer(&gpu::BufferDesc {
                size: 256,
                usage: gpu::BufferUsage::UNIFORM | gpu::BufferUsage::COPY_DST,
                ..Default::default()
            });

            Self {
                config,
                spectrum,
                cascades,
                spectrum_init_pipeline,
                time_evolve_pipeline,
                fft_horizontal_pipeline,
                fft_vertical_pipeline,
                combine_pipeline,
                normal_foam_pipeline,
                gaussian_noise,
                params_buffer,
                time: 0.0,
            }
        }

        fn create_cascade(device: &gpu::Device, resolution: u32, patch_size: f32) -> OceanCascade {
            let create_complex_texture = |name: &str| {
                device.create_texture(&gpu::TextureDesc {
                    width: resolution,
                    height: resolution,
                    format: gpu::TextureFormat::Rg32Float,
                    usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                    ..Default::default()
                })
            };

            let create_rgba_texture = |name: &str| {
                device.create_texture(&gpu::TextureDesc {
                    width: resolution,
                    height: resolution,
                    format: gpu::TextureFormat::Rgba16Float,
                    usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                    ..Default::default()
                })
            };

            OceanCascade {
                patch_size,
                h0_texture: create_complex_texture("H0"),
                ht_texture: create_complex_texture("Ht"),
                dx_texture: create_complex_texture("Dx"),
                dz_texture: create_complex_texture("Dz"),
                displacement_map: create_rgba_texture("Displacement"),
                normal_map: create_rgba_texture("Normal"),
                foam_map: device.create_texture(&gpu::TextureDesc {
                    width: resolution,
                    height: resolution,
                    format: gpu::TextureFormat::R16Float,
                    usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                    ..Default::default()
                }),
                jacobian_map: device.create_texture(&gpu::TextureDesc {
                    width: resolution,
                    height: resolution,
                    format: gpu::TextureFormat::R16Float,
                    usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                    ..Default::default()
                }),
            }
        }

        fn create_gaussian_noise_texture(device: &gpu::Device, resolution: u32) -> Texture {
            // Generate Box-Muller Gaussian random pairs
            let mut data = Vec::with_capacity((resolution * resolution * 4) as usize);

            for _ in 0..(resolution * resolution) {
                let u1 = rand::random::<f32>().max(0.0001);
                let u2 = rand::random::<f32>();

                let r = (-2.0 * u1.ln()).sqrt();
                let theta = 2.0 * std::f32::consts::PI * u2;

                // Two independent Gaussian samples
                data.push(r * theta.cos());
                data.push(r * theta.sin());

                // Second pair
                let u1 = rand::random::<f32>().max(0.0001);
                let u2 = rand::random::<f32>();
                let r = (-2.0 * u1.ln()).sqrt();
                let theta = 2.0 * std::f32::consts::PI * u2;

                data.push(r * theta.cos());
                data.push(r * theta.sin());
            }

            let texture = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                format: gpu::TextureFormat::Rgba32Float,
                usage: gpu::TextureUsage::SAMPLED | gpu::TextureUsage::COPY_DST,
                ..Default::default()
            });

            // Upload noise data
            device.queue().write_texture(&texture, bytemuck::cast_slice(&data));

            texture
        }

        /// Initialize the ocean spectrum (call once)
        pub fn initialize_spectrum(&self, encoder: &mut CommandEncoder) {
            let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
            pass.set_pipeline(&self.spectrum_init_pipeline);

            let workgroups = (self.config.resolution + 15) / 16;

            for cascade in &self.cascades {
                // Set bindings for this cascade
                pass.dispatch(workgroups, workgroups, 1);
            }
        }

        /// Update ocean simulation for current frame
        pub fn update(&mut self, encoder: &mut CommandEncoder, delta_time: f32) {
            self.time += delta_time * self.config.time_scale;

            // 1. Time evolution of spectrum
            {
                let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
                pass.set_pipeline(&self.time_evolve_pipeline);

                let workgroups = (self.config.resolution + 15) / 16;
                for cascade in &self.cascades {
                    pass.dispatch(workgroups, workgroups, 1);
                }
            }

            encoder.pipeline_barrier();

            // 2. FFT to get displacement
            let log2_n = (self.config.resolution as f32).log2() as u32;

            for _stage in 0..log2_n {
                // Horizontal FFT
                {
                    let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
                    pass.set_pipeline(&self.fft_horizontal_pipeline);

                    for cascade in &self.cascades {
                        pass.dispatch(self.config.resolution, 1, 1);
                    }
                }

                encoder.pipeline_barrier();
            }

            for _stage in 0..log2_n {
                // Vertical FFT
                {
                    let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
                    pass.set_pipeline(&self.fft_vertical_pipeline);

                    for cascade in &self.cascades {
                        pass.dispatch(1, self.config.resolution, 1);
                    }
                }

                encoder.pipeline_barrier();
            }

            // 3. Combine displacement components
            {
                let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
                pass.set_pipeline(&self.combine_pipeline);

                let workgroups = (self.config.resolution + 15) / 16;
                for cascade in &self.cascades {
                    pass.dispatch(workgroups, workgroups, 1);
                }
            }

            encoder.pipeline_barrier();

            // 4. Compute normals and foam
            {
                let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
                pass.set_pipeline(&self.normal_foam_pipeline);

                let workgroups = (self.config.resolution + 15) / 16;
                for cascade in &self.cascades {
                    pass.dispatch(workgroups, workgroups, 1);
                }
            }
        }

        /// Get displacement map for cascade
        pub fn get_displacement_map(&self, cascade: usize) -> Option<&Texture> {
            self.cascades.get(cascade).map(|c| &c.displacement_map)
        }

        /// Get normal map for cascade
        pub fn get_normal_map(&self, cascade: usize) -> Option<&Texture> {
            self.cascades.get(cascade).map(|c| &c.normal_map)
        }

        /// Get foam map for cascade
        pub fn get_foam_map(&self, cascade: usize) -> Option<&Texture> {
            self.cascades.get(cascade).map(|c| &c.foam_map)
        }

        /// Sample wave height at a world position (CPU, for physics)
        pub fn sample_height(&self, world_pos: Vec2) -> f32 {
            // Would sample from displacement maps
            // For now, return 0
            0.0
        }
    }

    // =========================================================================
    // Water Rendering (Rivers, Lakes, Pools)
