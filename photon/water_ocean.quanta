    /// Water surface material
    pub struct WaterMaterial {
        pub color_shallow: Vec3,
        pub color_deep: Vec3,
        pub depth_max: f32,
        pub transparency: f32,
        pub refraction_strength: f32,
        pub fresnel_power: f32,
        pub specular_intensity: f32,
        pub roughness: f32,
        pub normal_strength: f32,
        pub foam_color: Vec3,
        pub foam_intensity: f32,
        pub sss_intensity: f32,       // Subsurface scattering
        pub sss_color: Vec3,
    }

    impl Default for WaterMaterial {
        fn default() -> Self {
            Self {
                color_shallow: Vec3::new(0.3, 0.6, 0.7),
                color_deep: Vec3::new(0.02, 0.1, 0.2),
                depth_max: 20.0,
                transparency: 0.8,
                refraction_strength: 0.3,
                fresnel_power: 5.0,
                specular_intensity: 1.0,
                roughness: 0.05,
                normal_strength: 1.0,
                foam_color: Vec3::new(1.0, 1.0, 1.0),
                foam_intensity: 1.0,
                sss_intensity: 0.5,
                sss_color: Vec3::new(0.2, 0.7, 0.4),
            }
        }
    }

    /// Gerstner wave for stylized water
    pub struct GerstnerWave {
        pub direction: Vec2,
        pub steepness: f32,
        pub wavelength: f32,
        pub speed: f32,
    }

    impl GerstnerWave {
        pub fn new(direction: Vec2, steepness: f32, wavelength: f32, speed: f32) -> Self {
            Self {
                direction: direction.normalize(),
                steepness,
                wavelength,
                speed,
            }
        }

        /// Calculate displacement for this wave
        pub fn displacement(&self, position: Vec2, time: f32) -> Vec3 {
            let k = 2.0 * std::f32::consts::PI / self.wavelength;
            let c = (9.81 / k).sqrt() * self.speed;
            let a = self.steepness / k;

            let phase = k * position.dot(self.direction) - c * time;

            Vec3::new(
                self.direction.x * a * phase.cos(),
                a * phase.sin(),
                self.direction.y * a * phase.cos()
            )
        }

        /// Calculate normal contribution from this wave
        pub fn normal(&self, position: Vec2, time: f32) -> Vec3 {
            let k = 2.0 * std::f32::consts::PI / self.wavelength;
            let c = (9.81 / k).sqrt() * self.speed;
            let a = self.steepness / k;

            let phase = k * position.dot(self.direction) - c * time;

            Vec3::new(
                -self.direction.x * self.steepness * phase.sin(),
                1.0 - self.steepness * phase.cos(),
                -self.direction.y * self.steepness * phase.sin()
            ).normalize()
        }
    }

    /// Gerstner wave collection for water surface
    pub struct GerstnerWaveCollection {
        waves: Vec<GerstnerWave>,
    }

    impl GerstnerWaveCollection {
        pub fn new() -> Self {
            Self { waves: Vec::new() }
        }

        pub fn add_wave(&mut self, wave: GerstnerWave) {
            self.waves.push(wave);
        }

        /// Create a preset calm water surface
        pub fn calm_preset() -> Self {
            let mut collection = Self::new();
            collection.add_wave(GerstnerWave::new(Vec2::new(1.0, 0.0), 0.1, 20.0, 1.0));
            collection.add_wave(GerstnerWave::new(Vec2::new(0.7, 0.7), 0.08, 15.0, 1.2));
            collection.add_wave(GerstnerWave::new(Vec2::new(0.0, 1.0), 0.06, 10.0, 0.8));
            collection.add_wave(GerstnerWave::new(Vec2::new(-0.5, 0.5), 0.04, 5.0, 1.5));
            collection
        }

        /// Calculate total displacement
        pub fn displacement(&self, position: Vec2, time: f32) -> Vec3 {
            self.waves.iter()
                .fold(Vec3::zero(), |acc, wave| acc + wave.displacement(position, time))
        }

        /// Calculate combined normal
        pub fn normal(&self, position: Vec2, time: f32) -> Vec3 {
            let tangent_x = self.waves.iter()
                .fold(Vec3::new(1.0, 0.0, 0.0), |acc, wave| {
                    let n = wave.normal(position, time);
                    acc + Vec3::new(-n.x, n.y - 1.0, 0.0)
                });

            let tangent_z = self.waves.iter()
                .fold(Vec3::new(0.0, 0.0, 1.0), |acc, wave| {
                    let n = wave.normal(position, time);
                    acc + Vec3::new(0.0, n.y - 1.0, -n.z)
                });

            tangent_z.cross(tangent_x).normalize()
        }
    }

    // =========================================================================
    // Caustics
    // =========================================================================

    /// Caustics renderer
    pub struct CausticsRenderer {
        caustics_texture: Texture,
        caustics_volume: Texture,     // 3D texture for depth-varying caustics
        generation_pipeline: ComputePipeline,
        projection_pipeline: ComputePipeline,
        resolution: u32,
        intensity: f32,
        scale: f32,
    }

    impl CausticsRenderer {
        pub fn new(device: &gpu::Device, resolution: u32) -> Self {
            let caustics_texture = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                format: gpu::TextureFormat::R16Float,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            let caustics_volume = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                depth: 32,
                dimension: gpu::TextureDimension::D3,
                format: gpu::TextureFormat::R16Float,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            let generation_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/caustics_generate.wgsl"),
                entry_point: "generate_caustics",
            });

            let projection_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/caustics_project.wgsl"),
                entry_point: "project_caustics",
            });

            Self {
                caustics_texture,
                caustics_volume,
                generation_pipeline,
                projection_pipeline,
                resolution,
                intensity: 1.0,
                scale: 10.0,
            }
        }

        /// Generate caustics from water normal map
        pub fn generate(&self, encoder: &mut CommandEncoder, water_normal_map: &Texture) {
            let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
            pass.set_pipeline(&self.generation_pipeline);

            let workgroups = (self.resolution + 15) / 16;
            pass.dispatch(workgroups, workgroups, 1);
        }

        pub fn get_caustics_texture(&self) -> &Texture {
            &self.caustics_texture
        }
    }

    // =========================================================================
    // Underwater Rendering
    // =========================================================================

    /// Underwater fog parameters
    pub struct UnderwaterFog {
        pub color: Vec3,
        pub density: f32,
        pub start_distance: f32,
        pub light_extinction: Vec3,    // Per-channel absorption
        pub inscatter: f32,
    }

    impl Default for UnderwaterFog {
        fn default() -> Self {
            Self {
                color: Vec3::new(0.05, 0.2, 0.3),
                density: 0.1,
                start_distance: 0.0,
                light_extinction: Vec3::new(0.45, 0.08, 0.02),  // Red absorbed most
                inscatter: 0.02,
            }
        }
    }

    /// Underwater rendering effects
    pub struct UnderwaterRenderer {
        fog: UnderwaterFog,
        distortion_texture: Texture,
        god_rays_texture: Texture,
        composite_pipeline: Pipeline,
        god_rays_pipeline: ComputePipeline,
    }

    impl UnderwaterRenderer {
        pub fn new(device: &gpu::Device, width: u32, height: u32) -> Self {
            let distortion_texture = device.create_texture(&gpu::TextureDesc {
                width,
                height,
                format: gpu::TextureFormat::Rg16Float,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            let god_rays_texture = device.create_texture(&gpu::TextureDesc {
                width: width / 2,
                height: height / 2,
                format: gpu::TextureFormat::R16Float,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            let composite_pipeline = device.create_render_pipeline(&gpu::RenderPipelineDesc {
                vertex_shader: include_str!("shaders/fullscreen_quad.wgsl"),
                fragment_shader: Some(include_str!("shaders/underwater_composite.wgsl")),
                ..Default::default()
            });

            let god_rays_pipeline = device.create_compute_pipeline(&gpu::ComputePipelineDesc {
                shader: include_str!("shaders/underwater_god_rays.wgsl"),
                entry_point: "compute_god_rays",
            });

            Self {
                fog: UnderwaterFog::default(),
                distortion_texture,
                god_rays_texture,
                composite_pipeline,
                god_rays_pipeline,
            }
        }

        /// Calculate underwater light extinction
        pub fn extinction(&self, distance: f32) -> Vec3 {
            Vec3::new(
                (-self.fog.light_extinction.x * distance).exp(),
                (-self.fog.light_extinction.y * distance).exp(),
                (-self.fog.light_extinction.z * distance).exp()
            )
        }

        /// Apply underwater effects
        pub fn render(&self, encoder: &mut CommandEncoder, scene_color: &Texture,
                      scene_depth: &Texture, camera_depth: f32) {
            if camera_depth <= 0.0 {
                return; // Not underwater
            }

            // Compute god rays
            {
                let mut pass = encoder.begin_compute_pass(&gpu::ComputePassDesc::default());
                pass.set_pipeline(&self.god_rays_pipeline);
                // dispatch...
            }

            // Composite underwater effects
            {
                let mut pass = encoder.begin_render_pass(&gpu::RenderPassDesc::default());
                pass.set_pipeline(&self.composite_pipeline);
                pass.draw(0, 3, 0, 1);
            }
        }
    }

    // =========================================================================
    // Shoreline / Beach Effects
    // =========================================================================

    /// Shoreline wave simulation
    pub struct ShorelineWaves {
        wave_foam_texture: Texture,
        shore_distance_texture: Texture, // Distance to shore SDF
        wave_height: f32,
        wave_frequency: f32,
        foam_width: f32,
        wet_sand_width: f32,
    }

    impl ShorelineWaves {
        pub fn new(device: &gpu::Device, resolution: u32) -> Self {
            let wave_foam_texture = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                format: gpu::TextureFormat::Rgba8Unorm,
                usage: gpu::TextureUsage::RENDER_TARGET | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            let shore_distance_texture = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                format: gpu::TextureFormat::R16Float,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            Self {
                wave_foam_texture,
                shore_distance_texture,
                wave_height: 0.5,
                wave_frequency: 0.5,
                foam_width: 2.0,
                wet_sand_width: 5.0,
            }
        }

        /// Calculate wave position on beach
        pub fn wave_position(&self, shore_distance: f32, time: f32) -> f32 {
            let wave_period = 5.0 / self.wave_frequency;
            let phase = (time / wave_period).fract();

            // Wave advances and recedes
            let advance = (phase * std::f32::consts::PI).sin();
            let max_reach = self.wave_height * 10.0;

            let wave_edge = advance * max_reach;

            if shore_distance < wave_edge {
                // Under water
                1.0
            } else if shore_distance < wave_edge + self.foam_width {
                // Foam zone
                1.0 - (shore_distance - wave_edge) / self.foam_width
            } else if shore_distance < wave_edge + self.wet_sand_width {
                // Wet sand
                0.0
            } else {
                0.0
            }
        }
    }

    // =========================================================================
    // River Flow
    // =========================================================================

    /// River flow map for directional water movement
    pub struct RiverFlowMap {
        flow_texture: Texture,        // RG = flow direction, B = speed
        foam_texture: Texture,
        resolution: u32,
        world_bounds: (Vec2, Vec2),   // Min/max world coordinates
    }

    impl RiverFlowMap {
        pub fn new(device: &gpu::Device, resolution: u32, bounds: (Vec2, Vec2)) -> Self {
            let flow_texture = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                format: gpu::TextureFormat::Rgba8Snorm,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED | gpu::TextureUsage::COPY_DST,
                ..Default::default()
            });

            let foam_texture = device.create_texture(&gpu::TextureDesc {
                width: resolution,
                height: resolution,
                format: gpu::TextureFormat::R8Unorm,
                usage: gpu::TextureUsage::STORAGE | gpu::TextureUsage::SAMPLED,
                ..Default::default()
            });

            Self {
                flow_texture,
                foam_texture,
                resolution,
                world_bounds: bounds,
            }
        }

        /// Sample flow direction at world position
        pub fn sample_flow(&self, world_pos: Vec2) -> Vec2 {
            // Would sample from flow_texture
            Vec2::new(1.0, 0.0)
        }

        /// Apply flow map to UV animation
        pub fn animate_uv(&self, uv: Vec2, time: f32, flow: Vec2) -> Vec2 {
            let phase0 = (time * 0.5).fract();
            let phase1 = (time * 0.5 + 0.5).fract();

            let blend = (phase0 * 2.0 * std::f32::consts::PI).cos().abs();

            let uv0 = uv - flow * phase0;
            let uv1 = uv - flow * phase1;

            // Blend between two phases to hide texture jumping
            Vec2::lerp(uv0, uv1, blend)
        }
    }

    // =========================================================================
    // GPU Shaders
    // =========================================================================

    pub const OCEAN_SPECTRUM_INIT_SHADER: &str = r#"
struct SpectrumParams {
    resolution: u32,
    patch_size: f32,
    wind_speed: f32,
    wind_direction: vec2<f32>,
    gravity: f32,
    scale: f32,
    padding: vec2<f32>,
}

@group(0) @binding(0) var<uniform> params: SpectrumParams;
@group(0) @binding(1) var gaussian_noise: texture_2d<f32>;
@group(0) @binding(2) var h0_texture: texture_storage_2d<rg32float, write>;

fn phillips_spectrum(k: vec2<f32>) -> f32 {
    let k_len = length(k);
    if (k_len < 0.0001) {
        return 0.0;
    }

    let k_unit = k / k_len;
    let l = params.wind_speed * params.wind_speed / params.gravity;

    let k_dot_w = dot(k_unit, normalize(params.wind_direction));
    let phillips = exp(-1.0 / pow(k_len * l, 2.0)) / pow(k_len, 4.0) * pow(abs(k_dot_w), 2.0);

    // Dampen small waves
    let l_small = l / 1000.0;
    let damping = exp(-k_len * k_len * l_small * l_small);

    return sqrt(phillips * damping) * params.scale;
}

@compute @workgroup_size(16, 16)
fn init_spectrum(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= params.resolution || id.y >= params.resolution) {
        return;
    }

    let coord = vec2<i32>(id.xy);

    // Wave vector
    let n = vec2<f32>(id.xy) - f32(params.resolution) / 2.0;
    let k = 2.0 * 3.14159 * n / params.patch_size;

    // Gaussian random numbers
    let noise = textureLoad(gaussian_noise, coord, 0);
    let xi = vec2<f32>(noise.r, noise.g);

    // Phillips spectrum amplitude
    let amplitude = phillips_spectrum(k);

    // H0(k) = 1/sqrt(2) * (xi_r + i*xi_i) * sqrt(P(k))
    let h0 = vec2<f32>(xi.x, xi.y) * amplitude * 0.7071067811865476;

    textureStore(h0_texture, coord, vec4<f32>(h0, 0.0, 0.0));
}
"#;

    pub const OCEAN_TIME_EVOLVE_SHADER: &str = r#"
struct TimeParams {
    resolution: u32,
    patch_size: f32,
    time: f32,
    gravity: f32,
    choppiness: f32,
    padding: vec3<f32>,
}

@group(0) @binding(0) var<uniform> params: TimeParams;
@group(0) @binding(1) var h0_texture: texture_2d<f32>;
@group(0) @binding(2) var ht_texture: texture_storage_2d<rg32float, write>;
@group(0) @binding(3) var dx_texture: texture_storage_2d<rg32float, write>;
@group(0) @binding(4) var dz_texture: texture_storage_2d<rg32float, write>;

fn complex_mul(a: vec2<f32>, b: vec2<f32>) -> vec2<f32> {
    return vec2<f32>(a.x * b.x - a.y * b.y, a.x * b.y + a.y * b.x);
}

fn complex_conj(c: vec2<f32>) -> vec2<f32> {
    return vec2<f32>(c.x, -c.y);
}

@compute @workgroup_size(16, 16)
fn evolve_spectrum(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= params.resolution || id.y >= params.resolution) {
        return;
    }

    let coord = vec2<i32>(id.xy);
    let conj_coord = vec2<i32>(
        (params.resolution - id.x) % params.resolution,
        (params.resolution - id.y) % params.resolution
    );

    // Wave vector
    let n = vec2<f32>(id.xy) - f32(params.resolution) / 2.0;
    let k = 2.0 * 3.14159 * n / params.patch_size;
    let k_len = length(k);

    // Dispersion relation (deep water)
    let omega = sqrt(params.gravity * max(k_len, 0.0001));

    // Time evolution: exp(i * omega * t)
    let phase = omega * params.time;
    let exp_iwt = vec2<f32>(cos(phase), sin(phase));
    let exp_neg_iwt = vec2<f32>(cos(phase), -sin(phase));

    // Load initial spectrum
    let h0 = textureLoad(h0_texture, coord, 0).xy;
    let h0_conj = complex_conj(textureLoad(h0_texture, conj_coord, 0).xy);

    // Evolved spectrum: h(k,t) = h0(k)*exp(i*omega*t) + conj(h0(-k))*exp(-i*omega*t)
    let ht = complex_mul(h0, exp_iwt) + complex_mul(h0_conj, exp_neg_iwt);

    textureStore(ht_texture, coord, vec4<f32>(ht, 0.0, 0.0));

    // X and Z displacement spectra
    if (k_len > 0.0001) {
        let k_unit = k / k_len;
        let dx = complex_mul(vec2<f32>(0.0, -params.choppiness * k_unit.x), ht);
        let dz = complex_mul(vec2<f32>(0.0, -params.choppiness * k_unit.y), ht);

        textureStore(dx_texture, coord, vec4<f32>(dx, 0.0, 0.0));
        textureStore(dz_texture, coord, vec4<f32>(dz, 0.0, 0.0));
    } else {
        textureStore(dx_texture, coord, vec4<f32>(0.0));
        textureStore(dz_texture, coord, vec4<f32>(0.0));
    }
}
"#;

    pub const OCEAN_FFT_SHADER: &str = r#"
struct FftParams {
    resolution: u32,
    log2_resolution: u32,
    stage: u32,
    direction: u32,  // 0 = horizontal, 1 = vertical
}

@group(0) @binding(0) var<uniform> params: FftParams;
@group(0) @binding(1) var input_texture: texture_2d<f32>;
@group(0) @binding(2) var output_texture: texture_storage_2d<rg32float, write>;

fn complex_mul(a: vec2<f32>, b: vec2<f32>) -> vec2<f32> {
    return vec2<f32>(a.x * b.x - a.y * b.y, a.x * b.y + a.y * b.x);
}

fn bit_reverse(n: u32, bits: u32) -> u32 {
    var result = 0u;
    var x = n;
    for (var i = 0u; i < bits; i++) {
        result = (result << 1u) | (x & 1u);
        x >>= 1u;
    }
    return result;
}

@compute @workgroup_size(256)
fn fft_horizontal(@builtin(global_invocation_id) id: vec3<u32>) {
    let row = id.x;
    if (row >= params.resolution) {
        return;
    }

    // Perform FFT along this row
    for (var col = 0u; col < params.resolution; col++) {
        let bit_rev = bit_reverse(col, params.log2_resolution);
        if (bit_rev > col) {
            // Swap
            let a = textureLoad(input_texture, vec2<i32>(i32(col), i32(row)), 0).xy;
            let b = textureLoad(input_texture, vec2<i32>(i32(bit_rev), i32(row)), 0).xy;
            textureStore(output_texture, vec2<i32>(i32(col), i32(row)), vec4<f32>(b, 0.0, 0.0));
            textureStore(output_texture, vec2<i32>(i32(bit_rev), i32(row)), vec4<f32>(a, 0.0, 0.0));
        }
    }

    // Butterfly operations for each stage would go here
    // (simplified - real implementation needs multiple passes)
}

@compute @workgroup_size(256)
fn fft_vertical(@builtin(global_invocation_id) id: vec3<u32>) {
    let col = id.x;
    if (col >= params.resolution) {
        return;
    }

    // Similar to horizontal but transpose indices
}
"#;

    pub const WATER_SURFACE_SHADER: &str = r#"
struct WaterMaterial {
    color_shallow: vec3<f32>,
    color_deep: vec3<f32>,
    depth_max: f32,
    transparency: f32,
    refraction_strength: f32,
    fresnel_power: f32,
    specular_intensity: f32,
    roughness: f32,
    normal_strength: f32,
    foam_color: vec3<f32>,
    foam_intensity: f32,
    sss_intensity: f32,
    sss_color: vec3<f32>,
}

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) uv: vec2<f32>,
}

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) world_position: vec3<f32>,
    @location(1) uv: vec2<f32>,
    @location(2) screen_pos: vec2<f32>,
}

@group(0) @binding(0) var<uniform> view_proj: mat4x4<f32>;
@group(0) @binding(1) var<uniform> model: mat4x4<f32>;
@group(0) @binding(2) var<uniform> camera_pos: vec3<f32>;
@group(0) @binding(3) var<uniform> material: WaterMaterial;
@group(0) @binding(4) var<uniform> time: f32;

@group(1) @binding(0) var displacement_map: texture_2d<f32>;
@group(1) @binding(1) var normal_map: texture_2d<f32>;
@group(1) @binding(2) var foam_map: texture_2d<f32>;
@group(1) @binding(3) var water_sampler: sampler;

@group(2) @binding(0) var scene_color: texture_2d<f32>;
@group(2) @binding(1) var scene_depth: texture_2d<f32>;
@group(2) @binding(2) var reflection_map: texture_cube<f32>;

fn fresnel_schlick(cos_theta: f32, f0: f32) -> f32 {
    return f0 + (1.0 - f0) * pow(1.0 - cos_theta, material.fresnel_power);
}

fn ggx_distribution(n_dot_h: f32, roughness: f32) -> f32 {
    let a = roughness * roughness;
    let a2 = a * a;
    let denom = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    return a2 / (3.14159 * denom * denom);
}

@vertex
fn vs_main(in: VertexInput) -> VertexOutput {
    var out: VertexOutput;

    // Sample displacement
    let displacement = textureSampleLevel(displacement_map, water_sampler, in.uv, 0.0).xyz;

    var world_pos = (model * vec4<f32>(in.position, 1.0)).xyz;
    world_pos += displacement;

    out.world_position = world_pos;
    out.clip_position = view_proj * vec4<f32>(world_pos, 1.0);
    out.uv = in.uv;
    out.screen_pos = (out.clip_position.xy / out.clip_position.w) * 0.5 + 0.5;

    return out;
}

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // Sample normal
    let normal_sample = textureSample(normal_map, water_sampler, in.uv).xyz;
    let normal = normalize(normal_sample * 2.0 - 1.0);

    // View direction
    let view_dir = normalize(camera_pos - in.world_position);
    let n_dot_v = max(dot(normal, view_dir), 0.001);

    // Fresnel
    let fresnel = fresnel_schlick(n_dot_v, 0.02);

    // Refraction
    var refraction_uv = in.screen_pos;
    refraction_uv += normal.xz * material.refraction_strength;
    let scene_sample = textureSample(scene_color, water_sampler, refraction_uv);
    let scene_depth_sample = textureSample(scene_depth, water_sampler, refraction_uv).r;

    // Water depth (would need proper depth calculation)
    let water_depth = 5.0; // Placeholder

    // Depth-based color
    let depth_factor = saturate(water_depth / material.depth_max);
    let water_color = mix(material.color_shallow, material.color_deep, depth_factor);

    // Refracted color with absorption
    let extinction = exp(-water_depth * vec3<f32>(0.45, 0.08, 0.02));
    let refracted = scene_sample.rgb * extinction;

    // Reflection
    let reflect_dir = reflect(-view_dir, normal);
    let reflection = textureSample(reflection_map, water_sampler, reflect_dir).rgb;

    // Combine reflection and refraction
    var final_color = mix(refracted, reflection, fresnel);

    // Add water tint
    final_color = mix(final_color, water_color, (1.0 - material.transparency) * depth_factor);

    // Foam
    let foam = textureSample(foam_map, water_sampler, in.uv).r;
    final_color = mix(final_color, material.foam_color, foam * material.foam_intensity);

    // Subsurface scattering approximation
    let sss = pow(saturate(dot(view_dir, -normal)), 3.0) * material.sss_intensity;
    final_color += material.sss_color * sss;

    // Specular
    let sun_dir = normalize(vec3<f32>(0.5, 1.0, 0.3));
    let half_vec = normalize(view_dir + sun_dir);
    let n_dot_h = max(dot(normal, half_vec), 0.0);
    let specular = ggx_distribution(n_dot_h, material.roughness) * material.specular_intensity;
    final_color += vec3<f32>(specular);

    return vec4<f32>(final_color, 1.0);
}
"#;

    pub const CAUSTICS_SHADER: &str = r#"
struct CausticsParams {
    resolution: u32,
    intensity: f32,
    scale: f32,
    time: f32,
    sun_direction: vec3<f32>,
    padding: f32,
}

@group(0) @binding(0) var<uniform> params: CausticsParams;
@group(0) @binding(1) var water_normal: texture_2d<f32>;
@group(0) @binding(2) var caustics_output: texture_storage_2d<r16float, write>;
@group(0) @binding(3) var caustics_sampler: sampler;

@compute @workgroup_size(16, 16)
fn generate_caustics(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= params.resolution || id.y >= params.resolution) {
        return;
    }

    let uv = vec2<f32>(id.xy) / f32(params.resolution);

    // Sample water surface normal
    let normal = textureSampleLevel(water_normal, caustics_sampler, uv * params.scale, 0.0).xyz;
    let n = normalize(normal * 2.0 - 1.0);

    // Refract light direction through water surface
    let refracted = refract(-params.sun_direction, n, 1.0 / 1.33);

    // Compute Jacobian of the refraction mapping
    // This approximates how much light is focused/dispersed
    let epsilon = 1.0 / f32(params.resolution);

    let normal_dx = textureSampleLevel(water_normal, caustics_sampler, (uv + vec2<f32>(epsilon, 0.0)) * params.scale, 0.0).xyz;
    let normal_dy = textureSampleLevel(water_normal, caustics_sampler, (uv + vec2<f32>(0.0, epsilon)) * params.scale, 0.0).xyz;

    let n_dx = normalize(normal_dx * 2.0 - 1.0);
    let n_dy = normalize(normal_dy * 2.0 - 1.0);

    let r_dx = refract(-params.sun_direction, n_dx, 1.0 / 1.33);
    let r_dy = refract(-params.sun_direction, n_dy, 1.0 / 1.33);

    // Approximate Jacobian determinant (caustic intensity)
    let dx = (r_dx.xz - refracted.xz) / epsilon;
    let dy = (r_dy.xz - refracted.xz) / epsilon;
    let jacobian = abs(dx.x * dy.y - dx.y * dy.x);

    // Caustic intensity (reciprocal of Jacobian, clamped)
    let caustic = clamp(1.0 / max(jacobian, 0.001), 0.0, 10.0) * params.intensity;

    textureStore(caustics_output, vec2<i32>(id.xy), vec4<f32>(caustic, 0.0, 0.0, 0.0));
}
"#;

    // =========================================================================
    // Unit Tests
    // =========================================================================

    #[test]
    fn test_ocean_spectrum_presets() {
        let calm = OceanSpectrum::calm();
        assert!(calm.wind_speed < 5.0);

        let stormy = OceanSpectrum::stormy();
        assert!(stormy.wind_speed > 20.0);
    }

    #[test]
    fn test_phillips_spectrum() {
        let spectrum = OceanSpectrum::moderate();

        // At zero wavenumber, amplitude should be zero
        let amp_zero = spectrum.phillips_amplitude(Vec2::zero());
        assert_eq!(amp_zero, 0.0);

        // With wind direction, should have positive amplitude
        let k = Vec2::new(0.1, 0.0);
        let amp = spectrum.phillips_amplitude(k);
        assert!(amp > 0.0);
    }

    #[test]
    fn test_gerstner_wave() {
        let wave = GerstnerWave::new(
            Vec2::new(1.0, 0.0),
            0.5,
            10.0,
            1.0
        );

        // At t=0, position should have displacement
        let disp0 = wave.displacement(Vec2::zero(), 0.0);

        // At different time, displacement should change
        let disp1 = wave.displacement(Vec2::zero(), 1.0);

        assert_ne!(disp0.y, disp1.y);
    }

    #[test]
    fn test_gerstner_wave_collection() {
        let waves = GerstnerWaveCollection::calm_preset();

        let disp = waves.displacement(Vec2::new(10.0, 10.0), 1.0);
        let normal = waves.normal(Vec2::new(10.0, 10.0), 1.0);

        // Normal should be roughly upward
        assert!(normal.y > 0.5);

        // Normal should be unit length
        assert!((normal.length() - 1.0).abs() < 0.001);
    }

    #[test]
    fn test_water_material() {
        let mat = WaterMaterial::default();

        assert!(mat.transparency > 0.0);
        assert!(mat.fresnel_power > 1.0);
        assert!(mat.roughness < 0.5);
    }

    #[test]
    fn test_underwater_fog_extinction() {
        let renderer = UnderwaterRenderer {
            fog: UnderwaterFog::default(),
            distortion_texture: unsafe { mem::zeroed() },
            god_rays_texture: unsafe { mem::zeroed() },
            composite_pipeline: unsafe { mem::zeroed() },
            god_rays_pipeline: unsafe { mem::zeroed() },
        };

        // At distance 0, no extinction
        let ext0 = renderer.extinction(0.0);
        assert_eq!(ext0, Vec3::new(1.0, 1.0, 1.0));

        // At large distance, significant extinction
        let ext_far = renderer.extinction(100.0);
        assert!(ext_far.x < 0.01);  // Red absorbed most
        assert!(ext_far.z > ext_far.x);  // Blue absorbed least
    }

    #[test]
    fn test_shoreline_wave_position() {
        let shore = ShorelineWaves {
            wave_foam_texture: unsafe { mem::zeroed() },
            shore_distance_texture: unsafe { mem::zeroed() },
            wave_height: 0.5,
            wave_frequency: 0.5,
            foam_width: 2.0,
            wet_sand_width: 5.0,
        };

        // Very close to shore should be underwater sometimes
        let wet = shore.wave_position(0.0, 0.0);
        assert!(wet >= 0.0 && wet <= 1.0);
    }

    #[test]
    fn test_fft_ocean_config() {
        let config = FftOceanConfig::default();

        assert!(config.resolution.is_power_of_two());
        assert!(config.num_cascades >= 1);
        assert!(config.choppiness > 0.0);
    }

    #[test]
    fn test_river_flow_uv_animation() {
        let flow_map = RiverFlowMap {
            flow_texture: unsafe { mem::zeroed() },
            foam_texture: unsafe { mem::zeroed() },
            resolution: 256,
            world_bounds: (Vec2::zero(), Vec2::new(100.0, 100.0)),
        };

        let uv = Vec2::new(0.5, 0.5);
        let flow = Vec2::new(1.0, 0.0);

        let animated0 = flow_map.animate_uv(uv, 0.0, flow);
        let animated1 = flow_map.animate_uv(uv, 1.0, flow);

        // UV should change over time
        assert_ne!(animated0, animated1);
    }
}
