// foliage.quanta - Foliage and Vegetation Rendering System
// Part of the Photon Rendering Module
// Implements GPU instancing for foliage, wind animation, grass rendering, and procedural vegetation

import std::collections::{HashMap, Vec, VecDeque, BinaryHeap}
import std::math::{Vec2, Vec3, Vec4, Mat3, Mat4, Quaternion, sqrt, pow, exp, sin, cos, tan, PI, floor, ceil, clamp, lerp, min, max, abs, dot, cross, normalize, length}
import std::memory::{Arena, Pool, Box, Arc, Rc}
import std::sync::{Mutex, RwLock, Atomic}
import std::simd::{f32x4, f32x8, i32x4, i32x8}

// ============================================================================
// FOLIAGE INSTANCE REPRESENTATION
// ============================================================================

/// Single foliage instance data
struct FoliageInstance {
    position: Vec3,
    rotation: Quaternion,
    scale: Vec3,
    color_variation: f32,
    wind_phase: f32,
    health: f32,          // For seasonal/damage variation
    lod_bias: f32,
}

impl FoliageInstance {
    fn new(position: Vec3) -> Self {
        Self {
            position,
            rotation: Quaternion::IDENTITY,
            scale: Vec3::ONE,
            color_variation: 0.0,
            wind_phase: 0.0,
            health: 1.0,
            lod_bias: 0.0,
        }
    }

    fn with_random_rotation(mut self, seed: u32) -> Self {
        let angle = hash_u32(seed) as f32 / u32::MAX as f32 * 2.0 * PI;
        self.rotation = Quaternion::from_axis_angle(Vec3::Y, angle);
        self
    }

    fn with_random_scale(mut self, seed: u32, min_scale: f32, max_scale: f32) -> Self {
        let t = hash_u32(seed.wrapping_add(1)) as f32 / u32::MAX as f32;
        let scale = lerp(min_scale, max_scale, t);
        self.scale = Vec3::splat(scale);
        self
    }

    fn with_color_variation(mut self, seed: u32, amount: f32) -> Self {
        let t = hash_u32(seed.wrapping_add(2)) as f32 / u32::MAX as f32;
        self.color_variation = (t - 0.5) * 2.0 * amount;
        self
    }

    fn transform_matrix(&self) -> Mat4 {
        Mat4::from_scale_rotation_translation(
            self.scale,
            self.rotation,
            self.position
        )
    }
}

fn hash_u32(value: u32) -> u32 {
    let mut x = value;
    x = ((x >> 16) ^ x).wrapping_mul(0x45d9f3b);
    x = ((x >> 16) ^ x).wrapping_mul(0x45d9f3b);
    x = (x >> 16) ^ x;
    x
}

/// GPU-packed foliage instance
struct GpuFoliageInstance {
    transform_row0: Vec4,  // First row of 3x4 matrix
    transform_row1: Vec4,  // Second row
    transform_row2: Vec4,  // Third row
    params: Vec4,          // x = color_variation, y = wind_phase, z = health, w = lod_bias
}

impl GpuFoliageInstance {
    fn from_instance(inst: &FoliageInstance) -> Self {
        let mat = inst.transform_matrix();

        Self {
            transform_row0: Vec4::new(mat.x_axis.x, mat.y_axis.x, mat.z_axis.x, mat.w_axis.x),
            transform_row1: Vec4::new(mat.x_axis.y, mat.y_axis.y, mat.z_axis.y, mat.w_axis.y),
            transform_row2: Vec4::new(mat.x_axis.z, mat.y_axis.z, mat.z_axis.z, mat.w_axis.z),
            params: Vec4::new(inst.color_variation, inst.wind_phase, inst.health, inst.lod_bias),
        }
    }
}

