    ("volumetric_clouds", VOLUMETRIC_CLOUD_SHADER),
    ("height_fog", HEIGHT_FOG_SHADER),
    ("godrays", GODRAY_SHADER),
    ("aerial_perspective", AERIAL_PERSPECTIVE_SHADER),
    ("sky_utilities", SKY_UTILITIES_SHADER),
    ("atmosphere_compute", ATMOSPHERE_COMPUTE_SHADERS),
];
