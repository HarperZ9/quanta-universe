// =============================================================================
// PRISM: Terrain Rendering Shaders
// =============================================================================
// GPU-based terrain with tessellation, virtual texturing, and procedural detail
// Part of the QUANTA-UNIVERSE Rendering Stack
// =============================================================================

@module prism::terrain
@version 1.0.0
@author QUANTA Team

// =============================================================================
// TERRAIN DATA STRUCTURES
// =============================================================================

/// Terrain configuration
struct TerrainConfig {
    // Size
    world_size: f32,              // Total terrain size in world units
    height_scale: f32,            // Maximum height
    base_height: f32,             // Base elevation

    // LOD
    max_lod: u32,                 // Maximum LOD levels
    lod_distance_scale: f32,      // Distance multiplier for LOD switching
    tessellation_factor: f32,
    max_tessellation: f32,
    min_tessellation: f32,

    // Detail
    detail_scale: f32,
    detail_fade_distance: f32,
    macro_variation_scale: f32,

    // Virtual texturing
    virtual_texture_size: u32,
    page_size: u32,
    border_size: u32,

    // Shadows
    shadow_cascade_count: u32,
    shadow_distance: f32,
}

impl TerrainConfig {
    pub fn default() -> Self {
        Self {
            world_size: 8192.0,
            height_scale: 512.0,
            base_height: 0.0,

            max_lod: 8,
            lod_distance_scale: 2.0,
            tessellation_factor: 32.0,
            max_tessellation: 64.0,
            min_tessellation: 1.0,

            detail_scale: 0.1,
            detail_fade_distance: 200.0,
            macro_variation_scale: 0.001,

            virtual_texture_size: 16384,
            page_size: 256,
            border_size: 4,

            shadow_cascade_count: 4,
            shadow_distance: 1000.0,
        }
    }
}

/// Terrain layer for splatting
struct TerrainLayer {
    name: String,

    // Textures
    albedo_texture: TextureHandle,
    normal_texture: TextureHandle,
    mask_texture: TextureHandle,   // R=roughness, G=metallic, B=AO, A=height

    // Tiling
    uv_scale: f32,
    uv_offset: vec2,

    // Triplanar
    triplanar_sharpness: f32,

    // Blending
    height_blend_sharpness: f32,
    slope_bias: f32,               // Prefer on slopes
    height_bias: f32,              // Prefer at heights

    // Properties
    roughness_adjust: f32,
    metallic_adjust: f32,
    normal_strength: f32,

    // Parallax
    parallax_scale: f32,
    parallax_steps: i32,

    // Detail
    detail_albedo: TextureHandle,
    detail_normal: TextureHandle,
    detail_scale: f32,
    detail_blend: f32,
}

impl TerrainLayer {
    pub fn grass() -> Self {
        Self {
            name: "Grass".to_string(),
            albedo_texture: 0,
            normal_texture: 0,
            mask_texture: 0,
            uv_scale: 4.0,
            uv_offset: [0.0, 0.0],
            triplanar_sharpness: 4.0,
            height_blend_sharpness: 8.0,
            slope_bias: -0.5,        // Avoid steep slopes
            height_bias: 0.0,
            roughness_adjust: 0.0,
            metallic_adjust: 0.0,
            normal_strength: 1.0,
            parallax_scale: 0.02,
            parallax_steps: 8,
            detail_albedo: 0,
            detail_normal: 0,
            detail_scale: 32.0,
            detail_blend: 0.3,
        }
    }

    pub fn rock() -> Self {
        Self {
            name: "Rock".to_string(),
            slope_bias: 0.8,         // Prefer steep slopes
            uv_scale: 2.0,
            triplanar_sharpness: 8.0,
            roughness_adjust: 0.1,
            parallax_scale: 0.05,
            parallax_steps: 16,
            ..Self::grass()
        }
    }

    pub fn sand() -> Self {
        Self {
            name: "Sand".to_string(),
            slope_bias: -0.3,
            height_bias: -0.5,       // Low elevations
            uv_scale: 8.0,
            roughness_adjust: -0.1,
            parallax_scale: 0.01,
            ..Self::grass()
        }
    }

    pub fn snow() -> Self {
        Self {
            name: "Snow".to_string(),
            slope_bias: -0.2,
            height_bias: 0.8,        // High elevations
            uv_scale: 6.0,
            roughness_adjust: -0.2,
            ..Self::grass()
        }
    }
}

/// Terrain splat control
struct TerrainSplat {
    layer_index: u32,
    weight: f32,
}

// =============================================================================
// TERRAIN VERTEX SHADER
// =============================================================================

const TERRAIN_VERTEX_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Terrain Vertex Shader
//-----------------------------------------------------------------------------

cbuffer TerrainParams : register(b0) {
    float4x4 world;
    float4x4 view_projection;

    float3 camera_position;
    float world_size;

    float height_scale;
    float base_height;
    float tessellation_factor;
    float max_tessellation;

    float min_tessellation;
    float lod_distance_scale;
    float detail_scale;
    float detail_fade_distance;

    float4 lod_ranges;  // Distance thresholds for each LOD
}

Texture2D<float> heightmap : register(t0);
SamplerState height_sampler : register(s0);

struct VSInput {
    float3 position : POSITION;
    float2 texcoord : TEXCOORD0;
};

struct HSInput {
    float3 position : POSITION;
    float2 texcoord : TEXCOORD0;
    float tessellation : TESSELLATION;
};

HSInput TerrainVS(VSInput input) {
    HSInput output;

    // Sample heightmap
    float height = heightmap.SampleLevel(height_sampler, input.texcoord, 0).r;
    float3 position = input.position;
    position.y = height * height_scale + base_height;

    output.position = position;
    output.texcoord = input.texcoord;

    // Calculate tessellation based on distance
    float3 world_pos = mul(world, float4(position, 1.0)).xyz;
    float distance = length(world_pos - camera_position);

    float tess = tessellation_factor / (1.0 + distance * 0.01 * lod_distance_scale);
    output.tessellation = clamp(tess, min_tessellation, max_tessellation);

    return output;
}
"#;

// =============================================================================
// TERRAIN HULL SHADER
// =============================================================================

const TERRAIN_HULL_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Terrain Hull Shader
//-----------------------------------------------------------------------------

struct HSInput {
    float3 position : POSITION;
    float2 texcoord : TEXCOORD0;
    float tessellation : TESSELLATION;
};

struct HSConstOutput {
    float edges[4] : SV_TessFactor;
    float inside[2] : SV_InsideTessFactor;
};

// Calculate edge tessellation based on endpoint tessellation factors
float EdgeTessellation(float tess0, float tess1) {
    return max(tess0, tess1);
}

HSConstOutput TerrainHSConst(InputPatch<HSInput, 4> patch, uint patchID : SV_PrimitiveID) {
    HSConstOutput output;

    // Edge tessellation factors
    output.edges[0] = EdgeTessellation(patch[0].tessellation, patch[3].tessellation);
    output.edges[1] = EdgeTessellation(patch[0].tessellation, patch[1].tessellation);
    output.edges[2] = EdgeTessellation(patch[1].tessellation, patch[2].tessellation);
    output.edges[3] = EdgeTessellation(patch[2].tessellation, patch[3].tessellation);

    // Inside tessellation
    float avgTess = (patch[0].tessellation + patch[1].tessellation +
                     patch[2].tessellation + patch[3].tessellation) * 0.25;
    output.inside[0] = avgTess;
    output.inside[1] = avgTess;

    return output;
}

[domain("quad")]
[partitioning("fractional_even")]
[outputtopology("triangle_cw")]
[outputcontrolpoints(4)]
[patchconstantfunc("TerrainHSConst")]
HSInput TerrainHS(InputPatch<HSInput, 4> patch, uint id : SV_OutputControlPointID) {
    return patch[id];
}
"#;

// =============================================================================
// TERRAIN DOMAIN SHADER
// =============================================================================

const TERRAIN_DOMAIN_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Terrain Domain Shader
//-----------------------------------------------------------------------------

cbuffer TerrainParams : register(b0) {
    float4x4 world;
    float4x4 view_projection;
    float3 camera_position;
    float world_size;
    float height_scale;
    float base_height;
    float2 _padding;
}

Texture2D<float> heightmap : register(t0);
Texture2D<float4> normalmap : register(t1);
SamplerState terrain_sampler : register(s0);

struct HSConstOutput {
    float edges[4] : SV_TessFactor;
    float inside[2] : SV_InsideTessFactor;
};

struct HSInput {
    float3 position : POSITION;
    float2 texcoord : TEXCOORD0;
    float tessellation : TESSELLATION;
};

struct DSOutput {
    float4 position : SV_POSITION;
    float3 world_pos : TEXCOORD0;
    float2 texcoord : TEXCOORD1;
    float3 normal : TEXCOORD2;
    float3 tangent : TEXCOORD3;
    float3 bitangent : TEXCOORD4;
    float distance : TEXCOORD5;
};

[domain("quad")]
DSOutput TerrainDS(HSConstOutput constants, float2 uv : SV_DomainLocation,
                   OutputPatch<HSInput, 4> patch) {
    DSOutput output;

    // Bilinear interpolation of position and texcoord
    float3 p0 = lerp(patch[0].position, patch[1].position, uv.x);
    float3 p1 = lerp(patch[3].position, patch[2].position, uv.x);
    float3 position = lerp(p0, p1, uv.y);

    float2 t0 = lerp(patch[0].texcoord, patch[1].texcoord, uv.x);
    float2 t1 = lerp(patch[3].texcoord, patch[2].texcoord, uv.x);
    float2 texcoord = lerp(t0, t1, uv.y);

    // Sample height at tessellated position
    float height = heightmap.SampleLevel(terrain_sampler, texcoord, 0).r;
    position.y = height * height_scale + base_height;

    // Transform to world space
    float3 world_pos = mul(world, float4(position, 1.0)).xyz;

    // Calculate normal from heightmap
    float texel_size = 1.0 / 2048.0;  // Heightmap resolution
    float h_left = heightmap.SampleLevel(terrain_sampler, texcoord + float2(-texel_size, 0), 0).r;
    float h_right = heightmap.SampleLevel(terrain_sampler, texcoord + float2(texel_size, 0), 0).r;
    float h_down = heightmap.SampleLevel(terrain_sampler, texcoord + float2(0, -texel_size), 0).r;
    float h_up = heightmap.SampleLevel(terrain_sampler, texcoord + float2(0, texel_size), 0).r;

    float3 normal = normalize(float3(
        (h_left - h_right) * height_scale,
        2.0 * texel_size * world_size,
        (h_down - h_up) * height_scale
    ));

    // Calculate tangent frame
    float3 tangent = normalize(float3(1, (h_right - h_left) * height_scale * 0.5, 0));
    float3 bitangent = normalize(cross(normal, tangent));

    output.position = mul(view_projection, float4(world_pos, 1.0));
    output.world_pos = world_pos;
    output.texcoord = texcoord;
    output.normal = normal;
    output.tangent = tangent;
    output.bitangent = bitangent;
    output.distance = length(world_pos - camera_position);

    return output;
}
"#;

// =============================================================================
// TERRAIN PIXEL SHADER - SPLATMAP BASED
// =============================================================================

const TERRAIN_PIXEL_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Terrain Pixel Shader with Layer Splatting
//-----------------------------------------------------------------------------

#define MAX_LAYERS 8
#define PI 3.14159265359

cbuffer TerrainParams : register(b0) {
    float4x4 view_projection;
    float3 camera_position;
    float world_size;

    float3 sun_direction;
    float sun_intensity;

    float3 sun_color;
    float ambient_intensity;

    float detail_fade_distance;
    float macro_variation_scale;
    float2 _padding;
}

cbuffer LayerParams : register(b1) {
    float4 layer_uv_scale[MAX_LAYERS];           // xy = scale, zw = offset
    float4 layer_properties[MAX_LAYERS];          // x = roughness adj, y = metallic adj, z = normal strength, w = parallax scale
    float4 layer_blend[MAX_LAYERS];               // x = height blend sharp, y = slope bias, z = height bias, w = triplanar sharp
}

// Textures
Texture2D<float4> splatmap : register(t0);        // Up to 4 layer weights per map
Texture2D<float4> splatmap2 : register(t1);       // Additional layers

Texture2DArray<float4> albedo_array : register(t2);
Texture2DArray<float4> normal_array : register(t3);
Texture2DArray<float4> mask_array : register(t4);  // R=rough, G=metal, B=AO, A=height

Texture2D<float4> detail_normal : register(t5);
Texture2D<float> macro_variation : register(t6);
TextureCube<float4> environment_map : register(t7);
Texture2D<float> shadow_map : register(t8);

SamplerState trilinear_wrap : register(s0);
SamplerState trilinear_clamp : register(s1);
SamplerState aniso_wrap : register(s2);

struct PSInput {
    float4 position : SV_POSITION;
    float3 world_pos : TEXCOORD0;
    float2 texcoord : TEXCOORD1;
    float3 normal : TEXCOORD2;
    float3 tangent : TEXCOORD3;
    float3 bitangent : TEXCOORD4;
    float distance : TEXCOORD5;
};

// Triplanar mapping
float3 TriplanarWeights(float3 normal, float sharpness) {
    float3 weights = pow(abs(normal), sharpness);
    return weights / (weights.x + weights.y + weights.z);
}

float4 SampleTriplanar(Texture2DArray<float4> tex, SamplerState samp,
                       float3 world_pos, float3 weights, float scale, int layer) {
    float4 x = tex.Sample(samp, float3(world_pos.yz * scale, layer));
    float4 y = tex.Sample(samp, float3(world_pos.xz * scale, layer));
    float4 z = tex.Sample(samp, float3(world_pos.xy * scale, layer));

    return x * weights.x + y * weights.y + z * weights.z;
}

// Height-based blending
float HeightBlend(float h1, float h2, float blend, float sharpness) {
    float depth = 0.2;
    float ma = max(h1 + blend, h2 + (1.0 - blend)) - depth;

    float b1 = max(h1 + blend - ma, 0);
    float b2 = max(h2 + (1.0 - blend) - ma, 0);

    return b1 / (b1 + b2 + 0.0001);
}

// Sample single layer
void SampleLayer(int layer, float3 world_pos, float3 tri_weights,
                 out float4 albedo, out float3 normal, out float4 mask) {
    float scale = layer_uv_scale[layer].x;
    float2 offset = layer_uv_scale[layer].zw;

    albedo = SampleTriplanar(albedo_array, aniso_wrap, world_pos + float3(offset, 0), tri_weights, scale, layer);

    float4 normal_sample = SampleTriplanar(normal_array, trilinear_wrap, world_pos + float3(offset, 0), tri_weights, scale, layer);
    normal = normal_sample.xyz * 2.0 - 1.0;
    normal.xy *= layer_properties[layer].z;  // Normal strength

    mask = SampleTriplanar(mask_array, trilinear_wrap, world_pos + float3(offset, 0), tri_weights, scale, layer);
}

// PBR lighting
float3 FresnelSchlick(float cosTheta, float3 F0) {
    return F0 + (1.0 - F0) * pow(1.0 - cosTheta, 5.0);
}

float DistributionGGX(float3 N, float3 H, float roughness) {
    float a = roughness * roughness;
    float a2 = a * a;
    float NdotH = max(dot(N, H), 0.0);
    float NdotH2 = NdotH * NdotH;

    float nom = a2;
    float denom = (NdotH2 * (a2 - 1.0) + 1.0);
    denom = PI * denom * denom;

    return nom / denom;
}

float GeometrySmith(float NdotV, float NdotL, float roughness) {
    float r = roughness + 1.0;
    float k = (r * r) / 8.0;

    float ggx1 = NdotV / (NdotV * (1.0 - k) + k);
    float ggx2 = NdotL / (NdotL * (1.0 - k) + k);

    return ggx1 * ggx2;
}

float4 TerrainPS(PSInput input) : SV_TARGET {
    // Get splat weights
    float4 splat1 = splatmap.Sample(trilinear_clamp, input.texcoord);
    float4 splat2 = splatmap2.Sample(trilinear_clamp, input.texcoord);

    float weights[MAX_LAYERS];
    weights[0] = splat1.r;
    weights[1] = splat1.g;
    weights[2] = splat1.b;
    weights[3] = splat1.a;
    weights[4] = splat2.r;
    weights[5] = splat2.g;
    weights[6] = splat2.b;
    weights[7] = splat2.a;

    // Apply slope/height biases
    float slope = 1.0 - input.normal.y;
    float height = input.world_pos.y / 512.0;  // Normalized height

    for (int i = 0; i < MAX_LAYERS; i++) {
        weights[i] += layer_blend[i].y * slope;
        weights[i] += layer_blend[i].z * height;
        weights[i] = max(weights[i], 0.0);
    }

    // Normalize weights
    float totalWeight = 0.0;
    for (int i = 0; i < MAX_LAYERS; i++) {
        totalWeight += weights[i];
    }
    for (int i = 0; i < MAX_LAYERS; i++) {
        weights[i] /= max(totalWeight, 0.0001);
    }

    // Triplanar weights based on normal
    float avgTriSharp = 4.0;
    float3 tri_weights = TriplanarWeights(input.normal, avgTriSharp);

    // Sample and blend layers with height-based blending
    float4 final_albedo = float4(0, 0, 0, 0);
    float3 final_normal = float3(0, 0, 0);
    float4 final_mask = float4(0, 0, 0, 0);

    float4 layer_albedos[MAX_LAYERS];
    float3 layer_normals[MAX_LAYERS];
    float4 layer_masks[MAX_LAYERS];

    // First pass: sample all layers
    for (int i = 0; i < MAX_LAYERS; i++) {
        if (weights[i] > 0.01) {
            SampleLayer(i, input.world_pos, tri_weights,
                       layer_albedos[i], layer_normals[i], layer_masks[i]);
        } else {
            layer_albedos[i] = float4(0, 0, 0, 0);
            layer_normals[i] = float3(0, 0, 1);
            layer_masks[i] = float4(0, 0, 0, 0);
        }
    }

    // Height-based blending between layers
    for (int i = 0; i < MAX_LAYERS; i++) {
        float height = layer_masks[i].a;
        float adjusted_weight = weights[i] * (1.0 + height * layer_blend[i].x);

        final_albedo += layer_albedos[i] * adjusted_weight;
        final_normal += layer_normals[i] * adjusted_weight;
        final_mask += layer_masks[i] * adjusted_weight;
    }

    // Renormalize
    float total_adjusted = 0.0;
    for (int i = 0; i < MAX_LAYERS; i++) {
        float height = layer_masks[i].a;
        total_adjusted += weights[i] * (1.0 + height * layer_blend[i].x);
    }
    final_albedo /= max(total_adjusted, 0.0001);
    final_normal = normalize(final_normal);
    final_mask /= max(total_adjusted, 0.0001);

    // Apply detail normal
    float detail_blend = saturate(1.0 - input.distance / detail_fade_distance);
    if (detail_blend > 0.01) {
        float2 detail_uv = input.world_pos.xz * 0.5;
        float3 detail_n = detail_normal.Sample(trilinear_wrap, detail_uv).xyz * 2.0 - 1.0;
        final_normal = normalize(final_normal + detail_n * detail_blend * 0.3);
    }

    // Apply macro variation
    float macro = macro_variation.Sample(trilinear_wrap, input.world_pos.xz * macro_variation_scale).r;
    final_albedo.rgb *= lerp(0.7, 1.0, macro);

    // Transform normal to world space
    float3x3 TBN = float3x3(
        normalize(input.tangent),
        normalize(input.bitangent),
        normalize(input.normal)
    );
    float3 world_normal = normalize(mul(final_normal, TBN));

    // Material properties
    float roughness = saturate(final_mask.r);
    float metallic = saturate(final_mask.g);
    float ao = final_mask.b;

    // PBR lighting
    float3 V = normalize(camera_position - input.world_pos);
    float3 N = world_normal;
    float3 L = normalize(sun_direction);
    float3 H = normalize(V + L);

    float NdotV = max(dot(N, V), 0.0);
    float NdotL = max(dot(N, L), 0.0);

    float3 F0 = lerp(float3(0.04, 0.04, 0.04), final_albedo.rgb, metallic);

    // Cook-Torrance BRDF
    float NDF = DistributionGGX(N, H, roughness);
    float G = GeometrySmith(NdotV, NdotL, roughness);
    float3 F = FresnelSchlick(max(dot(H, V), 0.0), F0);

    float3 numerator = NDF * G * F;
    float denominator = 4.0 * NdotV * NdotL + 0.0001;
    float3 specular = numerator / denominator;

    float3 kS = F;
    float3 kD = (1.0 - kS) * (1.0 - metallic);

    float3 diffuse = kD * final_albedo.rgb / PI;

    // Shadow
    float shadow = 1.0;  // Would sample shadow map here

    // Final color
    float3 Lo = (diffuse + specular) * sun_color * sun_intensity * NdotL * shadow;

    // Ambient
    float3 ambient = final_albedo.rgb * ambient_intensity * ao;

    // Environment reflection
    float3 R = reflect(-V, N);
    float3 env = environment_map.SampleLevel(trilinear_wrap, R, roughness * 8.0).rgb;
    float3 env_contribution = env * F * (1.0 - roughness) * 0.3;

    float3 color = Lo + ambient + env_contribution;

    return float4(color, 1.0);
}
"#;

// =============================================================================
// TERRAIN CLIPMAP SHADER
// =============================================================================

const TERRAIN_CLIPMAP_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Geometry Clipmap Terrain (GPU Gems 2)
//-----------------------------------------------------------------------------

cbuffer ClipmapParams : register(b0) {
    float4x4 view_projection;

    float3 camera_position;
    float grid_size;

    float4 clipmap_scales[8];      // Scale for each clipmap level
    float4 clipmap_offsets[8];     // World offset for each clipmap level

    int num_levels;
    float blend_width;
    float2 _padding;
}

Texture2D<float> heightmap : register(t0);
SamplerState height_sampler : register(s0);

struct ClipmapVertex {
    float2 local_pos : POSITION;   // Position within clipmap grid
    uint level : LEVEL;            // Clipmap level
};

struct VSOutput {
    float4 position : SV_POSITION;
    float3 world_pos : TEXCOORD0;
    float2 texcoord : TEXCOORD1;
    float3 normal : TEXCOORD2;
    float blend : TEXCOORD3;
};

// Get world position for clipmap vertex
float3 GetClipmapWorldPos(float2 local, uint level) {
    float scale = clipmap_scales[level].x;
    float2 offset = clipmap_offsets[level].xy;

    // Snap to grid
    float2 world_xz = floor((local + offset) / scale) * scale;

    // Sample height
    float2 uv = world_xz / 8192.0 + 0.5;  // Assuming 8192 world size
    float height = heightmap.SampleLevel(height_sampler, uv, 0).r * 512.0;

    return float3(world_xz.x, height, world_xz.y);
}

VSOutput ClipmapVS(ClipmapVertex input) {
    VSOutput output;

    float3 world_pos = GetClipmapWorldPos(input.local_pos, input.level);

    // Calculate blend factor at level transitions
    float2 to_camera = camera_position.xz - world_pos.xz;
    float dist = length(to_camera);
    float inner_radius = clipmap_scales[input.level].x * 32.0;
    float outer_radius = clipmap_scales[input.level].x * 64.0;

    output.blend = saturate((dist - inner_radius) / blend_width);

    // Blend with coarser level if at boundary
    if (output.blend > 0.01 && input.level < num_levels - 1) {
        float3 coarse_pos = GetClipmapWorldPos(input.local_pos, input.level + 1);
        world_pos = lerp(world_pos, coarse_pos, output.blend);
    }

    output.position = mul(view_projection, float4(world_pos, 1.0));
    output.world_pos = world_pos;
    output.texcoord = world_pos.xz / 8192.0 + 0.5;

    // Calculate normal from neighboring samples
    float texel = 1.0 / 2048.0;
    float h_l = heightmap.SampleLevel(height_sampler, output.texcoord + float2(-texel, 0), 0).r * 512.0;
    float h_r = heightmap.SampleLevel(height_sampler, output.texcoord + float2(texel, 0), 0).r * 512.0;
    float h_d = heightmap.SampleLevel(height_sampler, output.texcoord + float2(0, -texel), 0).r * 512.0;
    float h_u = heightmap.SampleLevel(height_sampler, output.texcoord + float2(0, texel), 0).r * 512.0;

    output.normal = normalize(float3(h_l - h_r, 2.0, h_d - h_u));

    return output;
}
"#;

// =============================================================================
// VIRTUAL TEXTURING SHADER
// =============================================================================

const VIRTUAL_TEXTURE_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Virtual Texturing for Terrain (Megatexture)
//-----------------------------------------------------------------------------

cbuffer VirtualTextureParams : register(b0) {
    float virtual_texture_size;    // Full virtual texture size
    float page_size;               // Size of each page
    float border_size;             // Border for filtering
    float physical_texture_size;   // Size of physical texture cache

    float mip_bias;
    float feedback_scale;
    float2 _padding;
}

Texture2D<float4> page_table : register(t0);      // Indirection table
Texture2D<float4> physical_cache : register(t1);  // Physical texture pages
Texture2D<float4> fallback_texture : register(t2); // Low-res fallback

SamplerState page_sampler : register(s0);
SamplerState cache_sampler : register(s1);

struct VTInput {
    float4 position : SV_POSITION;
    float2 texcoord : TEXCOORD0;   // Virtual texture coords [0,1]
};

// Calculate mip level
float CalculateMipLevel(float2 texcoord, float2 texelSize) {
    float2 dx = ddx(texcoord * virtual_texture_size);
    float2 dy = ddy(texcoord * virtual_texture_size);
    float d = max(dot(dx, dx), dot(dy, dy));
    return 0.5 * log2(d) + mip_bias;
}

// Sample virtual texture
float4 SampleVirtualTexture(float2 vt_uv) {
    // Calculate mip level
    float mip = CalculateMipLevel(vt_uv, 1.0 / virtual_texture_size);
    mip = clamp(mip, 0.0, 10.0);
    int mip_int = int(mip);

    // Virtual texture coordinates at this mip
    float mip_scale = pow(2.0, -mip_int);
    float2 mip_uv = vt_uv * mip_scale;

    // Page coordinates
    float pages_per_row = virtual_texture_size / page_size * mip_scale;
    float2 page_coord = floor(mip_uv * pages_per_row);

    // Sample page table
    float2 page_table_uv = (page_coord + 0.5) / pages_per_row;
    float4 page_info = page_table.SampleLevel(page_sampler, page_table_uv, 0);

    // Check if page is resident
    if (page_info.w < 0.5) {
        // Page not resident - use fallback
        return fallback_texture.Sample(cache_sampler, vt_uv);
    }

    // Physical texture coordinates
    float2 physical_page = page_info.xy;  // Page location in physical cache
    float physical_mip = page_info.z;      // Mip stored in physical page

    // UV within page (with border handling)
    float2 in_page_uv = frac(mip_uv * pages_per_row);
    float usable_size = (page_size - 2.0 * border_size) / page_size;
    float2 bordered_uv = in_page_uv * usable_size + border_size / page_size;

    // Final physical texture coordinate
    float2 physical_uv = (physical_page + bordered_uv) / (physical_texture_size / page_size);

    return physical_cache.Sample(cache_sampler, physical_uv);
}

float4 VirtualTexturePS(VTInput input) : SV_TARGET {
    return SampleVirtualTexture(input.texcoord);
}

// Feedback buffer shader for page requests
RWTexture2D<uint> feedback_buffer : register(u0);

[numthreads(8, 8, 1)]
void VirtualTextureFeedbackCS(uint3 id : SV_DispatchThreadID,
                               float2 texcoord : TEXCOORD0) {
    float mip = CalculateMipLevel(texcoord, 1.0 / virtual_texture_size);
    mip = clamp(mip, 0.0, 10.0);
    int mip_int = int(mip);

    float mip_scale = pow(2.0, -mip_int);
    float2 mip_uv = texcoord * mip_scale;

    float pages_per_row = virtual_texture_size / page_size * mip_scale;
    int2 page_coord = int2(floor(mip_uv * pages_per_row));

    // Pack page request: x | y << 12 | mip << 24
    uint request = (page_coord.x & 0xFFF) |
                   ((page_coord.y & 0xFFF) << 12) |
                   ((mip_int & 0xFF) << 24);

    // Write to feedback buffer
    feedback_buffer[id.xy] = request;
}
"#;

// =============================================================================
// PROCEDURAL TERRAIN DETAIL SHADER
// =============================================================================

const PROCEDURAL_DETAIL_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Procedural Terrain Detail (Noise-Based Enhancement)
//-----------------------------------------------------------------------------

cbuffer ProceduralParams : register(b0) {
    float detail_scale;
    float detail_strength;
    float erosion_strength;
    float sediment_strength;

    int noise_octaves;
    float noise_persistence;
    float noise_lacunarity;
    float _padding;
}

// Simplex noise
float3 mod289(float3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
float4 mod289(float4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
float4 permute(float4 x) { return mod289(((x * 34.0) + 1.0) * x); }
float4 taylorInvSqrt(float4 r) { return 1.79284291400159 - 0.85373472095314 * r; }

float SimplexNoise(float3 v) {
    const float2 C = float2(1.0 / 6.0, 1.0 / 3.0);
    const float4 D = float4(0.0, 0.5, 1.0, 2.0);

    float3 i = floor(v + dot(v, C.yyy));
    float3 x0 = v - i + dot(i, C.xxx);

    float3 g = step(x0.yzx, x0.xyz);
    float3 l = 1.0 - g;
    float3 i1 = min(g.xyz, l.zxy);
    float3 i2 = max(g.xyz, l.zxy);

    float3 x1 = x0 - i1 + C.xxx;
    float3 x2 = x0 - i2 + C.yyy;
    float3 x3 = x0 - D.yyy;

    i = mod289(i);
    float4 p = permute(permute(permute(
        i.z + float4(0.0, i1.z, i2.z, 1.0))
        + i.y + float4(0.0, i1.y, i2.y, 1.0))
        + i.x + float4(0.0, i1.x, i2.x, 1.0));

    float n_ = 0.142857142857;
    float3 ns = n_ * D.wyz - D.xzx;

    float4 j = p - 49.0 * floor(p * ns.z * ns.z);
    float4 x_ = floor(j * ns.z);
    float4 y_ = floor(j - 7.0 * x_);

    float4 x = x_ * ns.x + ns.yyyy;
    float4 y = y_ * ns.x + ns.yyyy;
    float4 h = 1.0 - abs(x) - abs(y);

    float4 b0 = float4(x.xy, y.xy);
    float4 b1 = float4(x.zw, y.zw);

    float4 s0 = floor(b0) * 2.0 + 1.0;
    float4 s1 = floor(b1) * 2.0 + 1.0;
    float4 sh = -step(h, float4(0, 0, 0, 0));

    float4 a0 = b0.xzyw + s0.xzyw * sh.xxyy;
    float4 a1 = b1.xzyw + s1.xzyw * sh.zzww;

    float3 p0 = float3(a0.xy, h.x);
    float3 p1 = float3(a0.zw, h.y);
    float3 p2 = float3(a1.xy, h.z);
    float3 p3 = float3(a1.zw, h.w);

    float4 norm = taylorInvSqrt(float4(dot(p0, p0), dot(p1, p1), dot(p2, p2), dot(p3, p3)));
    p0 *= norm.x;
    p1 *= norm.y;
    p2 *= norm.z;
    p3 *= norm.w;

    float4 m = max(0.6 - float4(dot(x0, x0), dot(x1, x1), dot(x2, x2), dot(x3, x3)), 0.0);
    m = m * m;
    return 42.0 * dot(m * m, float4(dot(p0, x0), dot(p1, x1), dot(p2, x2), dot(p3, x3)));
}

// Fractal Brownian Motion
float FBM(float3 pos, int octaves, float persistence, float lacunarity) {
    float total = 0.0;
    float frequency = 1.0;
    float amplitude = 1.0;
    float maxValue = 0.0;

    for (int i = 0; i < octaves; i++) {
        total += SimplexNoise(pos * frequency) * amplitude;
        maxValue += amplitude;
        amplitude *= persistence;
        frequency *= lacunarity;
    }

    return total / maxValue;
}

// Domain warping for more natural patterns
float WarpedNoise(float3 pos) {
    float3 q = float3(
        FBM(pos, 4, 0.5, 2.0),
        FBM(pos + float3(5.2, 1.3, 2.5), 4, 0.5, 2.0),
        FBM(pos + float3(1.7, 9.2, 3.1), 4, 0.5, 2.0)
    );

    return FBM(pos + 4.0 * q, 4, 0.5, 2.0);
}

// Hydraulic erosion simulation (simplified)
float HydraulicErosion(float3 pos, float base_height) {
    // Calculate gradient
    float eps = 0.1;
    float h_c = base_height;
    float h_x = FBM(pos + float3(eps, 0, 0), 6, 0.5, 2.0);
    float h_z = FBM(pos + float3(0, 0, eps), 6, 0.5, 2.0);

    float2 gradient = float2(h_x - h_c, h_z - h_c) / eps;
    float slope = length(gradient);

    // Erosion increases with slope
    float erosion = slope * erosion_strength;

    // Sediment deposits in valleys
    float sediment = (1.0 - slope) * sediment_strength;

    return base_height - erosion + sediment;
}

// Apply procedural detail to heightmap
RWTexture2D<float> heightmap_out : register(u0);
Texture2D<float> heightmap_in : register(t0);

[numthreads(16, 16, 1)]
void ProceduralDetailCS(uint3 id : SV_DispatchThreadID) {
    uint2 dims;
    heightmap_in.GetDimensions(dims.x, dims.y);

    float2 uv = (float2(id.xy) + 0.5) / float2(dims);
    float base_height = heightmap_in[id.xy];

    // Add multi-scale detail
    float3 world_pos = float3(uv.x * 8192.0, base_height * 512.0, uv.y * 8192.0);

    float detail = 0.0;
    detail += FBM(world_pos * detail_scale * 0.1, noise_octaves, noise_persistence, noise_lacunarity) * 0.5;
    detail += FBM(world_pos * detail_scale * 0.5, noise_octaves, noise_persistence, noise_lacunarity) * 0.25;
    detail += WarpedNoise(world_pos * detail_scale * 2.0) * 0.125;

    // Apply erosion
    float eroded = HydraulicErosion(world_pos * 0.01, base_height + detail * detail_strength);

    heightmap_out[id.xy] = eroded;
}
"#;

// =============================================================================
// TERRAIN DECALS SHADER
// =============================================================================

const TERRAIN_DECAL_SHADER: &str = r#"
//-----------------------------------------------------------------------------
// Terrain Decal Projection
//-----------------------------------------------------------------------------

cbuffer DecalParams : register(b0) {
    float4x4 decal_matrix;         // World to decal space
    float4x4 inv_view_projection;

    float3 decal_position;
    float decal_radius;

    float3 decal_normal;
    float blend_factor;

    float4 decal_color;

    float normal_strength;
    float roughness_mod;
    float metallic_mod;
    float opacity;
}

Texture2D<float4> decal_albedo : register(t0);
Texture2D<float4> decal_normal : register(t1);
Texture2D<float4> decal_mask : register(t2);
Texture2D<float> scene_depth : register(t3);
Texture2D<float4> scene_normal : register(t4);

SamplerState decal_sampler : register(s0);

struct VSOutput {
    float4 position : SV_POSITION;
    float4 screen_pos : TEXCOORD0;
};

float3 ReconstructWorldPosition(float2 uv, float depth) {
    float4 clip = float4(uv * 2.0 - 1.0, depth, 1.0);
    clip.y = -clip.y;
    float4 world = mul(inv_view_projection, clip);
    return world.xyz / world.w;
}

struct DecalOutput {
    float4 albedo : SV_TARGET0;
    float4 normal : SV_TARGET1;
    float4 material : SV_TARGET2;
};

DecalOutput TerrainDecalPS(VSOutput input) {
    DecalOutput output;

    float2 screen_uv = (input.screen_pos.xy / input.screen_pos.w) * 0.5 + 0.5;
    screen_uv.y = 1.0 - screen_uv.y;

    // Reconstruct world position
    float depth = scene_depth.Sample(decal_sampler, screen_uv).r;
    float3 world_pos = ReconstructWorldPosition(screen_uv, depth);

    // Transform to decal space
    float3 decal_pos = mul(decal_matrix, float4(world_pos, 1.0)).xyz;

    // Check if within decal bounds [-0.5, 0.5]
    if (any(abs(decal_pos) > 0.5)) {
        discard;
    }

    // Decal UVs
    float2 decal_uv = decal_pos.xz + 0.5;

    // Check surface normal alignment
    float3 surface_normal = scene_normal.Sample(decal_sampler, screen_uv).xyz * 2.0 - 1.0;
    float alignment = dot(surface_normal, decal_normal);
    if (alignment < 0.3) {
        discard;
    }

    // Sample decal textures
    float4 albedo = decal_albedo.Sample(decal_sampler, decal_uv);
    float4 normal_sample = decal_normal.Sample(decal_sampler, decal_uv);
    float4 mask = decal_mask.Sample(decal_sampler, decal_uv);

    // Calculate opacity
    float edge_fade = 1.0 - smoothstep(0.4, 0.5, max(abs(decal_pos.x), abs(decal_pos.z)));
    float final_opacity = albedo.a * opacity * edge_fade * alignment;

    // Output
    output.albedo = float4(albedo.rgb * decal_color.rgb, final_opacity);

    float3 decal_n = normal_sample.xyz * 2.0 - 1.0;
    decal_n.xy *= normal_strength;
    output.normal = float4(decal_n * 0.5 + 0.5, final_opacity);

    output.material = float4(
        mask.r + roughness_mod,
        mask.g + metallic_mod,
        mask.b,
        final_opacity
    );

    return output;
}
"#;

// =============================================================================
// TERRAIN SYSTEM
// =============================================================================

/// Complete terrain rendering system
struct TerrainSystem {
    config: TerrainConfig,
    layers: Vec<TerrainLayer>,

    // Textures
    heightmap: TextureHandle,
    normalmap: TextureHandle,
    splatmaps: Vec<TextureHandle>,

    // Virtual texturing
    page_table: TextureHandle,
    physical_cache: TextureHandle,
    fallback_texture: TextureHandle,
    feedback_buffer: TextureHandle,

    // Clipmap
    clipmap_meshes: Vec<MeshHandle>,
    clipmap_levels: u32,

    // State
    camera_position: vec3,
    needs_update: bool,
}

impl TerrainSystem {
    pub fn new(device: &RenderDevice, config: TerrainConfig) -> Self {
        // Create heightmap
        let heightmap = device.create_texture_2d(
            2048, 2048,
            TextureFormat::R16,
            TextureUsage::ShaderResource | TextureUsage::UnorderedAccess
        );

        let normalmap = device.create_texture_2d(
            2048, 2048,
            TextureFormat::RGBA8,
            TextureUsage::ShaderResource
        );

        // Splatmaps (2 for 8 layers)
        let splatmaps = vec![
            device.create_texture_2d(1024, 1024, TextureFormat::RGBA8, TextureUsage::ShaderResource),
            device.create_texture_2d(1024, 1024, TextureFormat::RGBA8, TextureUsage::ShaderResource),
        ];

        // Virtual texturing
        let vt_size = config.virtual_texture_size;
        let page_size = config.page_size;
        let page_table = device.create_texture_2d(
            vt_size / page_size,
            vt_size / page_size,
            TextureFormat::RGBA8,
            TextureUsage::ShaderResource | TextureUsage::UnorderedAccess
        );

        let physical_cache = device.create_texture_2d(
            4096, 4096,
            TextureFormat::RGBA8_SRGB,
            TextureUsage::ShaderResource | TextureUsage::UnorderedAccess
        );

        let fallback_texture = device.create_texture_2d(
            512, 512,
            TextureFormat::RGBA8_SRGB,
            TextureUsage::ShaderResource
        );

        let feedback_buffer = device.create_texture_2d(
            256, 256,
            TextureFormat::R32U,
            TextureUsage::UnorderedAccess
        );

        // Create clipmap meshes
        let clipmap_meshes = Self::create_clipmap_meshes(device, config.max_lod);

        Self {
            config,
            layers: Vec::new(),
            heightmap,
            normalmap,
            splatmaps,
            page_table,
            physical_cache,
            fallback_texture,
            feedback_buffer,
            clipmap_meshes,
            clipmap_levels: config.max_lod,
            camera_position: [0.0, 0.0, 0.0],
            needs_update: true,
        }
    }

    fn create_clipmap_meshes(device: &RenderDevice, levels: u32) -> Vec<MeshHandle> {
        let mut meshes = Vec::new();

        for level in 0..levels {
            // Each level has a ring of geometry
            // Inner = finer level, outer = coarser
            let grid_size = 64; // Grid cells per ring side
            // Create mesh vertices and indices...
            meshes.push(0); // placeholder
        }

        meshes
    }

    pub fn add_layer(&mut self, layer: TerrainLayer) {
        self.layers.push(layer);
    }

    pub fn update(&mut self, camera_position: vec3) {
        self.camera_position = camera_position;

        // Update clipmap center
        // Process virtual texture feedback
        // Load/unload pages as needed
    }

    pub fn render(&self, context: &RenderContext, camera: &Camera) {
        // Bind terrain shader
        context.bind_shader("terrain");

        // Set textures
        context.set_srv(0, &self.heightmap);
        context.set_srv(1, &self.normalmap);
        context.set_srv(2, &self.splatmaps[0]);
        context.set_srv(3, &self.splatmaps[1]);

        // Set layer textures (arrays)
        // context.set_srv(4, &self.layer_albedo_array);
        // context.set_srv(5, &self.layer_normal_array);
        // context.set_srv(6, &self.layer_mask_array);

        // Set parameters
        context.set_constant_buffer(0, &self.create_params(camera));

        // Draw clipmap levels
        for (level, mesh) in self.clipmap_meshes.iter().enumerate() {
            context.set_vertex_buffer(mesh);
            context.draw_indexed(0, 0);
        }
    }

    fn create_params(&self, camera: &Camera) -> TerrainParamsBuffer {
        TerrainParamsBuffer {
            camera_position: camera.position,
            world_size: self.config.world_size,
            height_scale: self.config.height_scale,
            base_height: self.config.base_height,
            tessellation_factor: self.config.tessellation_factor,
            max_tessellation: self.config.max_tessellation,
            min_tessellation: self.config.min_tessellation,
            lod_distance_scale: self.config.lod_distance_scale,
        }
    }

    pub fn get_height_at(&self, x: f32, z: f32) -> f32 {
        // Sample heightmap (would need CPU readback or cached data)
        0.0
    }

    pub fn raycast(&self, origin: vec3, direction: vec3) -> Option<TerrainHit> {
        // Raycast against terrain for picking
        None
    }
}

struct TerrainHit {
    position: vec3,
    normal: vec3,
    texcoord: vec2,
    distance: f32,
}

#[repr(C)]
struct TerrainParamsBuffer {
    camera_position: vec3,
    world_size: f32,
    height_scale: f32,
    base_height: f32,
    tessellation_factor: f32,
    max_tessellation: f32,
    min_tessellation: f32,
    lod_distance_scale: f32,
}

// Placeholder types
type TextureHandle = u64;
type MeshHandle = u64;
type vec2 = [f32; 2];
type vec3 = [f32; 3];

struct RenderDevice;
impl RenderDevice {
    fn create_texture_2d(&self, _w: u32, _h: u32, _fmt: TextureFormat, _usage: TextureUsage) -> TextureHandle { 0 }
}

struct RenderContext;
impl RenderContext {
    fn bind_shader(&self, _name: &str) {}
    fn set_srv(&self, _slot: u32, _tex: &TextureHandle) {}
    fn set_vertex_buffer(&self, _mesh: &MeshHandle) {}
    fn set_constant_buffer<T>(&self, _slot: u32, _data: &T) {}
    fn draw_indexed(&self, _start: u32, _count: u32) {}
}

struct Camera {
    position: vec3,
}

enum TextureFormat { R16, RGBA8, RGBA8_SRGB, R32U }
enum TextureUsage { ShaderResource, UnorderedAccess }

