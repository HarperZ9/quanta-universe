// MODULE EXPORTS
// =============================================================================

pub use ParticleEmitterConfig;
pub use ParticleSystem;
pub use DecalSystem;

pub const SHADERS: &[(&str, &str)] = &[
    ("particle_compute", PARTICLE_COMPUTE_SHADERS),
    ("particle_render", PARTICLE_RENDER_SHADER),
    ("decal", DECAL_SHADER),
    ("distortion", DISTORTION_SHADER),
    ("lens_effects", LENS_EFFECTS_SHADER),
    ("volumetric_effects", VOLUMETRIC_EFFECTS_SHADER),
];
