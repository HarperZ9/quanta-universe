// RISK MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Value at Risk calculator
pub struct VaRCalculator {
    confidence: f64,
    horizon_days: u32,
    method: VaRMethod,
}

#[derive(Clone, Copy)]
pub enum VaRMethod {
    Historical,
    Parametric,
    MonteCarlo(usize),  // Number of simulations
}

impl VaRCalculator {
    pub fn new(confidence: f64, horizon_days: u32, method: VaRMethod) -> Self {
        VaRCalculator { confidence, horizon_days, method }
    }

    /// Calculate VaR for a portfolio of options
    pub fn calculate(
        &self,
        positions: &[OptionLeg],
        market: &MarketData,
        current_time: u64,
        historical_returns: Option<&[f64]>,
    ) -> f64 {
        match self.method {
            VaRMethod::Historical => {
                self.historical_var(positions, market, current_time, historical_returns.unwrap_or(&[]))
            }
            VaRMethod::Parametric => {
                self.parametric_var(positions, market, current_time)
            }
            VaRMethod::MonteCarlo(sims) => {
                self.monte_carlo_var(positions, market, current_time, sims)
            }
        }
    }

    fn historical_var(
        &self,
        positions: &[OptionLeg],
        market: &MarketData,
        current_time: u64,
        returns: &[f64],
    ) -> f64 {
        if returns.is_empty() {
            return 0.0;
        }

        let mut pnls = Vec::with_capacity(returns.len());

        for &r in returns {
            let shocked_spot = market.spot * exp(r);
            let shocked_market = MarketData { spot: shocked_spot, ..*market };

            let mut pnl = 0.0;
            for leg in positions {
                let t = leg.contract.time_to_expiry(current_time);
                let current_price = BlackScholes::price(&leg.contract, market, t);
                let shocked_price = BlackScholes::price(&leg.contract, &shocked_market, t);
                pnl += leg.quantity as f64 * leg.contract.multiplier * (shocked_price - current_price);
            }

            pnls.push(pnl);
        }

        pnls.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let index = ((1.0 - self.confidence) * pnls.len() as f64) as usize;
        -pnls[index] * sqrt(self.horizon_days as f64)
    }

    fn parametric_var(
        &self,
        positions: &[OptionLeg],
        market: &MarketData,
        current_time: u64,
    ) -> f64 {
        // Delta-Gamma-Vega VaR
        let mut total_delta = 0.0;
        let mut total_gamma = 0.0;
        let mut total_vega = 0.0;
        let mut total_theta = 0.0;

        for leg in positions {
            let t = leg.contract.time_to_expiry(current_time);
            let greeks = BlackScholes::greeks(&leg.contract, market, t);
            let mult = leg.quantity as f64 * leg.contract.multiplier;

            total_delta += greeks.delta * mult;
            total_gamma += greeks.gamma * mult;
            total_vega += greeks.vega * mult;
            total_theta += greeks.theta * mult;
        }

        // Daily spot move at confidence level
        let z = Self::norm_inv(self.confidence);
        let daily_spot_move = market.spot * market.volatility / sqrt(252.0) * z;

        // Delta-Gamma approximation
        let delta_pnl = total_delta * daily_spot_move;
        let gamma_pnl = 0.5 * total_gamma * daily_spot_move.powi(2);

        let var = (delta_pnl + gamma_pnl).abs() * sqrt(self.horizon_days as f64);
        var
    }

    fn monte_carlo_var(
        &self,
        positions: &[OptionLeg],
        market: &MarketData,
        current_time: u64,
        sims: usize,
    ) -> f64 {
        let mut rng = std::random::Random::new();
        let mut pnls = Vec::with_capacity(sims);

        let dt = self.horizon_days as f64 / 252.0;
        let drift = (market.risk_free_rate - 0.5 * market.volatility.powi(2)) * dt;
        let vol_sqrt_dt = market.volatility * sqrt(dt);

        for _ in 0..sims {
            let z = rng.gaussian(0.0, 1.0);
            let future_spot = market.spot * exp(drift + vol_sqrt_dt * z);
            let future_market = MarketData { spot: future_spot, ..*market };

            let mut pnl = 0.0;
            for leg in positions {
                let t = leg.contract.time_to_expiry(current_time);
                let t_future = t - dt;

                let current_price = BlackScholes::price(&leg.contract, market, t);
                let future_price = if t_future > 0.0 {
                    BlackScholes::price(&leg.contract, &future_market, t_future)
                } else {
                    leg.contract.intrinsic_value(future_spot)
                };

                pnl += leg.quantity as f64 * leg.contract.multiplier * (future_price - current_price);
            }

            pnls.push(pnl);
        }

        pnls.sort_by(|a, b| a.partial_cmp(b).unwrap());
        let index = ((1.0 - self.confidence) * pnls.len() as f64) as usize;
        -pnls[index]
    }

    fn norm_inv(p: f64) -> f64 {
        // Inverse normal CDF approximation (Abramowitz & Stegun)
        let a = [
            -3.969683028665376e+01,
             2.209460984245205e+02,
            -2.759285104469687e+02,
             1.383577518672690e+02,
            -3.066479806614716e+01,
             2.506628277459239e+00,
        ];
        let b = [
            -5.447609879822406e+01,
             1.615858368580409e+02,
            -1.556989798598866e+02,
             6.680131188771972e+01,
            -1.328068155288572e+01,
        ];
        let c = [
            -7.784894002430293e-03,
            -3.223964580411365e-01,
            -2.400758277161838e+00,
            -2.549732539343734e+00,
             4.374664141464968e+00,
             2.938163982698783e+00,
        ];
        let d = [
             7.784695709041462e-03,
             3.224671290700398e-01,
             2.445134137142996e+00,
             3.754408661907416e+00,
        ];

        let p_low = 0.02425;
        let p_high = 1.0 - p_low;

        if p < p_low {
            let q = sqrt(-2.0 * log(p));
            (((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) /
            ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1.0)
        } else if p <= p_high {
            let q = p - 0.5;
            let r = q * q;
            (((((a[0]*r+a[1])*r+a[2])*r+a[3])*r+a[4])*r+a[5])*q /
            (((((b[0]*r+b[1])*r+b[2])*r+b[3])*r+b[4])*r+1.0)
        } else {
            let q = sqrt(-2.0 * log(1.0 - p));
            -(((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) /
            ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1.0)
        }
    }
}

/// Expected Shortfall (CVaR) calculator
pub struct ExpectedShortfall {
    confidence: f64,
    horizon_days: u32,
}

impl ExpectedShortfall {
    pub fn new(confidence: f64, horizon_days: u32) -> Self {
        ExpectedShortfall { confidence, horizon_days }
    }

    /// Calculate ES from simulated P&Ls
    pub fn calculate(&self, pnls: &[f64]) -> f64 {
        if pnls.is_empty() {
            return 0.0;
        }

        let mut sorted = pnls.to_vec();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let cutoff = ((1.0 - self.confidence) * pnls.len() as f64) as usize;
        let tail: f64 = sorted[..=cutoff].iter().sum();

        -tail / (cutoff + 1) as f64 * sqrt(self.horizon_days as f64)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PORTFOLIO ANALYTICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Options portfolio with full analytics
pub struct OptionsPortfolio {
    pub name: String,
    pub positions: Vec<OptionLeg>,
    pub underlying_positions: HashMap<String, f64>,  // Shares held
    pub cash: f64,
}

impl OptionsPortfolio {
    pub fn new(name: &str) -> Self {
        OptionsPortfolio {
            name: name.to_string(),
            positions: Vec::new(),
            underlying_positions: HashMap::new(),
            cash: 0.0,
        }
    }

    /// Add option position
    pub fn add_option(&mut self, leg: OptionLeg) {
        let cost = leg.entry_price * leg.quantity.abs() as f64 * leg.contract.multiplier;
        if leg.quantity > 0 {
            self.cash -= cost;  // Buying
        } else {
            self.cash += cost;  // Selling (premium received)
        }
        self.positions.push(leg);
    }

    /// Add stock position
    pub fn add_stock(&mut self, underlying: &str, shares: f64, price: f64) {
        *self.underlying_positions.entry(underlying.to_string()).or_insert(0.0) += shares;
        self.cash -= shares * price;
    }

    /// Calculate total portfolio Greeks
    pub fn total_greeks(&self, markets: &HashMap<String, MarketData>, current_time: u64) -> PortfolioGreeks {
        let mut result = PortfolioGreeks::default();

        for leg in &self.positions {
            if let Some(market) = markets.get(&leg.contract.underlying) {
                let t = leg.contract.time_to_expiry(current_time);
                let greeks = BlackScholes::greeks(&leg.contract, market, t);
                let mult = leg.quantity as f64 * leg.contract.multiplier;

                result.delta += greeks.delta * mult;
                result.gamma += greeks.gamma * mult;
                result.theta += greeks.theta * mult;
                result.vega += greeks.vega * mult;
                result.rho += greeks.rho * mult;
            }
        }

        // Add delta from underlying positions
        for (underlying, &shares) in &self.underlying_positions {
            result.delta += shares;
        }

        result
    }

    /// Calculate dollar Greeks (sensitivity in dollar terms)
    pub fn dollar_greeks(&self, markets: &HashMap<String, MarketData>, current_time: u64) -> PortfolioDollarGreeks {
        let greeks = self.total_greeks(markets, current_time);

        let mut total_spot = 0.0;
        for leg in &self.positions {
            if let Some(market) = markets.get(&leg.contract.underlying) {
                total_spot = market.spot; // Simplified - would aggregate
            }
        }

        PortfolioDollarGreeks {
            delta_dollars: greeks.delta * total_spot,
            gamma_dollars: greeks.gamma * total_spot.powi(2) / 100.0,
            theta_dollars: greeks.theta,
            vega_dollars: greeks.vega,
        }
    }

    /// Portfolio market value
    pub fn market_value(&self, markets: &HashMap<String, MarketData>, current_time: u64) -> f64 {
        let mut value = self.cash;

        // Option positions
        for leg in &self.positions {
            if let Some(market) = markets.get(&leg.contract.underlying) {
                let t = leg.contract.time_to_expiry(current_time);
                let price = BlackScholes::price(&leg.contract, market, t);
                value += leg.quantity as f64 * leg.contract.multiplier * price;
            }
        }

        // Stock positions
        for (underlying, &shares) in &self.underlying_positions {
            if let Some(market) = markets.get(underlying) {
                value += shares * market.spot;
            }
        }

        value
    }

    /// Calculate P&L
    pub fn pnl(&self, markets: &HashMap<String, MarketData>, current_time: u64) -> f64 {
        self.market_value(markets, current_time)
    }

    /// Beta-weighted delta (SPY equivalent delta)
    pub fn beta_weighted_delta(
        &self,
        markets: &HashMap<String, MarketData>,
        betas: &HashMap<String, f64>,
        current_time: u64,
    ) -> f64 {
        let mut bw_delta = 0.0;

        for leg in &self.positions {
            if let Some(market) = markets.get(&leg.contract.underlying) {
                let beta = betas.get(&leg.contract.underlying).unwrap_or(&1.0);
                let t = leg.contract.time_to_expiry(current_time);
                let greeks = BlackScholes::greeks(&leg.contract, market, t);
                let mult = leg.quantity as f64 * leg.contract.multiplier;

                bw_delta += greeks.delta * mult * beta * market.spot;
            }
        }

        for (underlying, &shares) in &self.underlying_positions {
            let beta = betas.get(underlying).unwrap_or(&1.0);
            if let Some(market) = markets.get(underlying) {
                bw_delta += shares * beta * market.spot;
            }
        }

        bw_delta
    }
}

#[derive(Debug, Clone, Copy, Default)]
pub struct PortfolioGreeks {
    pub delta: f64,
    pub gamma: f64,
    pub theta: f64,
    pub vega: f64,
    pub rho: f64,
}

#[derive(Debug, Clone, Copy, Default)]
pub struct PortfolioDollarGreeks {
    pub delta_dollars: f64,
    pub gamma_dollars: f64,
    pub theta_dollars: f64,
    pub vega_dollars: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// HISTORICAL VOLATILITY MODELS
// ═══════════════════════════════════════════════════════════════════════════════

/// Close-to-close volatility estimator
pub fn historical_volatility(prices: &[f64], window: usize) -> Vec<f64> {
    if prices.len() < window + 1 {
        return Vec::new();
    }

    let returns: Vec<f64> = prices.windows(2)
        .map(|w| log(w[1] / w[0]))
        .collect();

    returns.windows(window)
        .map(|w| {
            let mean: f64 = w.iter().sum::<f64>() / window as f64;
            let variance: f64 = w.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / (window - 1) as f64;
            sqrt(variance * 252.0)
        })
        .collect()
}

/// Parkinson volatility (high-low range based)
pub fn parkinson_volatility(highs: &[f64], lows: &[f64], window: usize) -> Vec<f64> {
    if highs.len() != lows.len() || highs.len() < window {
        return Vec::new();
    }

    let hl_ratios: Vec<f64> = highs.iter().zip(lows.iter())
        .map(|(h, l)| log(h / l).powi(2))
        .collect();

    let factor = 1.0 / (4.0 * log(2.0));

    hl_ratios.windows(window)
        .map(|w| {
            let sum: f64 = w.iter().sum();
            sqrt(factor * sum / window as f64 * 252.0)
        })
        .collect()
}

/// Garman-Klass volatility (OHLC based)
pub fn garman_klass_volatility(
    opens: &[f64],
    highs: &[f64],
    lows: &[f64],
    closes: &[f64],
    window: usize,
) -> Vec<f64> {
    if opens.len() != highs.len() || highs.len() != lows.len() || lows.len() != closes.len() {
        return Vec::new();
    }

    let gk_vars: Vec<f64> = opens.iter().zip(highs.iter()).zip(lows.iter()).zip(closes.iter())
        .map(|(((o, h), l), c)| {
            0.5 * log(h / l).powi(2) - (2.0 * log(2.0) - 1.0) * log(c / o).powi(2)
        })
        .collect();

    gk_vars.windows(window)
        .map(|w| {
            let sum: f64 = w.iter().sum();
            sqrt(sum / window as f64 * 252.0)
        })
        .collect()
}

/// Yang-Zhang volatility (most robust OHLC estimator)
pub fn yang_zhang_volatility(
    opens: &[f64],
    highs: &[f64],
    lows: &[f64],
    closes: &[f64],
    window: usize,
) -> Vec<f64> {
    if opens.len() < window + 1 {
        return Vec::new();
    }

    let k = 0.34 / (1.0 + (window as f64 + 1.0) / (window as f64 - 1.0));

    // Overnight variance
    let overnight_rets: Vec<f64> = opens.windows(2)
        .zip(closes.iter())
        .map(|(o_pair, c)| log(o_pair[1] / c))
        .collect();

    // Open-to-close variance
    let oc_rets: Vec<f64> = opens.iter().zip(closes.iter())
        .map(|(o, c)| log(c / o))
        .collect();

    // Rogers-Satchell variance (no drift)
    let rs_vars: Vec<f64> = opens.iter().zip(highs.iter()).zip(lows.iter()).zip(closes.iter())
        .map(|(((o, h), l), c)| {
            log(h / c) * log(h / o) + log(l / c) * log(l / o)
        })
        .collect();

    // Combine components
    overnight_rets.windows(window)
        .zip(oc_rets.windows(window))
        .zip(rs_vars.windows(window))
        .map(|((on_w, oc_w), rs_w)| {
            let on_mean: f64 = on_w.iter().sum::<f64>() / window as f64;
            let on_var: f64 = on_w.iter().map(|r| (r - on_mean).powi(2)).sum::<f64>() / (window - 1) as f64;

            let oc_mean: f64 = oc_w.iter().sum::<f64>() / window as f64;
            let oc_var: f64 = oc_w.iter().map(|r| (r - oc_mean).powi(2)).sum::<f64>() / (window - 1) as f64;

            let rs_mean: f64 = rs_w.iter().sum::<f64>() / window as f64;

            let yz_var = on_var + k * oc_var + (1.0 - k) * rs_mean;
            sqrt(yz_var * 252.0)
        })
        .collect()
}

/// EWMA volatility (Exponentially Weighted Moving Average)
pub fn ewma_volatility(returns: &[f64], lambda: f64) -> Vec<f64> {
    if returns.is_empty() {
        return Vec::new();
    }

    let mut result = Vec::with_capacity(returns.len());
    let mut variance = returns[0].powi(2);
    result.push(sqrt(variance * 252.0));

    for &r in &returns[1..] {
        variance = lambda * variance + (1.0 - lambda) * r.powi(2);
        result.push(sqrt(variance * 252.0));
    }

    result
}

/// GARCH(1,1) volatility model
pub struct GARCH {
    omega: f64,
    alpha: f64,
    beta: f64,
}

impl GARCH {
    pub fn new(omega: f64, alpha: f64, beta: f64) -> Self {
        GARCH { omega, alpha, beta }
    }

    /// Long-run variance
    pub fn long_run_variance(&self) -> f64 {
        self.omega / (1.0 - self.alpha - self.beta)
    }

    /// Half-life of variance shocks (in periods)
    pub fn half_life(&self) -> f64 {
        log(0.5) / log(self.alpha + self.beta)
    }

    /// Estimate volatility series
    pub fn estimate(&self, returns: &[f64]) -> Vec<f64> {
        if returns.is_empty() {
            return Vec::new();
        }

        let mut result = Vec::with_capacity(returns.len());
        let mut variance = self.long_run_variance();
        result.push(sqrt(variance * 252.0));

        for &r in returns {
            variance = self.omega + self.alpha * r.powi(2) + self.beta * variance;
            result.push(sqrt(variance * 252.0));
        }

        result
    }

    /// Calibrate GARCH parameters using MLE
    pub fn calibrate(returns: &[f64]) -> Self {
        // Simplified calibration using moment matching
        let n = returns.len() as f64;
        let mean_sq: f64 = returns.iter().map(|r| r.powi(2)).sum::<f64>() / n;
        let fourth_moment: f64 = returns.iter().map(|r| r.powi(4)).sum::<f64>() / n;

        let kurtosis = fourth_moment / mean_sq.powi(2) - 3.0;

        // Approximate parameter estimates
        let alpha = 0.1;
        let beta = 0.85;
        let omega = mean_sq * (1.0 - alpha - beta);

        GARCH::new(omega, alpha, beta)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OPTIONS SCANNER & SCREENING
// ═══════════════════════════════════════════════════════════════════════════════

/// Options scanner for finding opportunities
pub struct OptionsScanner {
    criteria: Vec<ScanCriterion>,
}

#[derive(Clone)]
pub enum ScanCriterion {
    MinIV(f64),
    MaxIV(f64),
    MinDelta(f64),
    MaxDelta(f64),
    MinVolume(u32),
    MinOpenInterest(u32),
    Moneyness(f64, f64),  // (min, max) as percentage from ATM
    DaysToExpiry(u32, u32),  // (min, max)
    BidAskSpread(f64),  // Max spread as percentage
}

#[derive(Clone)]
pub struct ScanResult {
    pub contract: OptionContract,
    pub quote: OptionQuote,
    pub score: f64,
}

impl OptionsScanner {
    pub fn new() -> Self {
        OptionsScanner { criteria: Vec::new() }
    }

    pub fn add_criterion(&mut self, criterion: ScanCriterion) -> &mut Self {
        self.criteria.push(criterion);
        self
    }

    /// Scan options chain for matches
    pub fn scan(&self, chain: &OptionsChain, spot: f64, current_time: u64) -> Vec<ScanResult> {
        let mut results = Vec::new();

        for ((exp, strike_cents), quote) in &chain.calls {
            let strike = *strike_cents as f64 / 100.0;
            let contract = OptionContract::new(
                &format!("{}_C{}", chain.underlying, strike),
                &chain.underlying,
                OptionType::Call,
                strike,
                *exp,
            );

            if self.matches(&contract, quote, spot, current_time) {
                results.push(ScanResult {
                    contract,
                    quote: *quote,
                    score: self.score(quote),
                });
            }
        }

        for ((exp, strike_cents), quote) in &chain.puts {
            let strike = *strike_cents as f64 / 100.0;
            let contract = OptionContract::new(
                &format!("{}_P{}", chain.underlying, strike),
                &chain.underlying,
                OptionType::Put,
                strike,
                *exp,
            );

            if self.matches(&contract, quote, spot, current_time) {
                results.push(ScanResult {
                    contract,
                    quote: *quote,
                    score: self.score(quote),
                });
            }
        }

        results.sort_by(|a, b| b.score.partial_cmp(&a.score).unwrap());
        results
    }

    fn matches(&self, contract: &OptionContract, quote: &OptionQuote, spot: f64, current_time: u64) -> bool {
        for criterion in &self.criteria {
            let matched = match criterion {
                ScanCriterion::MinIV(min) => quote.implied_vol >= *min,
                ScanCriterion::MaxIV(max) => quote.implied_vol <= *max,
                ScanCriterion::MinDelta(min) => quote.delta.abs() >= *min,
                ScanCriterion::MaxDelta(max) => quote.delta.abs() <= *max,
                ScanCriterion::MinVolume(min) => quote.volume >= *min,
                ScanCriterion::MinOpenInterest(min) => quote.open_interest >= *min,
                ScanCriterion::Moneyness(min_pct, max_pct) => {
                    let moneyness = (contract.strike / spot - 1.0) * 100.0;
                    moneyness >= *min_pct && moneyness <= *max_pct
                }
                ScanCriterion::DaysToExpiry(min, max) => {
                    let days = ((contract.expiration - current_time) / 86400) as u32;
                    days >= *min && days <= *max
                }
                ScanCriterion::BidAskSpread(max_pct) => {
                    if quote.bid > 0.0 {
                        (quote.ask - quote.bid) / quote.bid * 100.0 <= *max_pct
                    } else {
                        false
                    }
                }
            };

            if !matched {
                return false;
            }
        }

        true
    }

    fn score(&self, quote: &OptionQuote) -> f64 {
        // Composite score based on liquidity and value
        let liquidity_score = log(1.0 + quote.volume as f64) + log(1.0 + quote.open_interest as f64);
        let spread_score = if quote.bid > 0.0 {
            1.0 / (1.0 + (quote.ask - quote.bid) / quote.bid)
        } else {
            0.0
        };

        liquidity_score * spread_score
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// POSITION SIZING & KELLY CRITERION
// ═══════════════════════════════════════════════════════════════════════════════

/// Position sizing calculator
pub struct PositionSizer {
    method: SizingMethod,
    max_position_pct: f64,
    max_portfolio_risk: f64,
}

#[derive(Clone, Copy)]
pub enum SizingMethod {
    Kelly,
    HalfKelly,
    FixedFractional(f64),
    OptimalF,
    VaRBased(f64),  // VaR as % of capital
}

impl PositionSizer {
    pub fn new(method: SizingMethod) -> Self {
        PositionSizer {
            method,
            max_position_pct: 0.10,  // 10% max position
            max_portfolio_risk: 0.20,  // 20% max portfolio risk
        }
    }

    /// Calculate position size for an option trade
    pub fn size(
        &self,
        portfolio_value: f64,
        win_prob: f64,
        win_amount: f64,
        loss_amount: f64,
    ) -> f64 {
        let raw_size = match self.method {
            SizingMethod::Kelly => {
                // Kelly: f* = (bp - q) / b
                // where b = win/loss ratio, p = win prob, q = loss prob
                let b = win_amount / loss_amount;
                let p = win_prob;
                let q = 1.0 - p;
                (b * p - q) / b
            }
            SizingMethod::HalfKelly => {
                let b = win_amount / loss_amount;
                let p = win_prob;
                let q = 1.0 - p;
                (b * p - q) / b * 0.5
            }
            SizingMethod::FixedFractional(f) => f,
            SizingMethod::OptimalF => {
                // Optimal F using HPR (holding period return)
                // Simplified - would use actual trade history
                0.25
            }
            SizingMethod::VaRBased(target_var_pct) => {
                // Size such that loss at VaR level = target_var_pct of portfolio
                target_var_pct * portfolio_value / loss_amount
            }
        };

        // Apply constraints
        raw_size.max(0.0).min(self.max_position_pct) * portfolio_value
    }

    /// Calculate contracts to trade
    pub fn contracts(
        &self,
        portfolio_value: f64,
        win_prob: f64,
        win_amount: f64,
        loss_amount: f64,
        contract_cost: f64,
        multiplier: f64,
    ) -> i32 {
        let position_value = self.size(portfolio_value, win_prob, win_amount, loss_amount);
        (position_value / (contract_cost * multiplier)).floor() as i32
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PUT-CALL SKEW ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Skew analytics
pub struct SkewAnalyzer;

impl SkewAnalyzer {
    /// Calculate skew metrics for an expiration
    pub fn analyze(surface: &VolatilitySurface, expiration: u64, forward: f64, t: f64) -> SkewMetrics {
        let atm_vol = surface.get_iv(expiration, forward);

        // 25-delta skew
        let d25_put = forward * exp(-0.675 * atm_vol * sqrt(t));
        let d25_call = forward * exp(0.675 * atm_vol * sqrt(t));
        let skew_25d = surface.get_iv(expiration, d25_put) - surface.get_iv(expiration, d25_call);

        // 10-delta skew (deeper OTM)
        let d10_put = forward * exp(-1.28 * atm_vol * sqrt(t));
        let d10_call = forward * exp(1.28 * atm_vol * sqrt(t));
        let skew_10d = surface.get_iv(expiration, d10_put) - surface.get_iv(expiration, d10_call);

        // Butterfly (convexity)
        let butterfly = (surface.get_iv(expiration, d25_put) + surface.get_iv(expiration, d25_call)) / 2.0 - atm_vol;

        // Risk reversal (25 delta)
        let risk_reversal = surface.get_iv(expiration, d25_call) - surface.get_iv(expiration, d25_put);

        SkewMetrics {
            atm_vol,
            skew_25d,
            skew_10d,
            butterfly,
            risk_reversal,
        }
    }

    /// Skew percentile vs historical
    pub fn skew_percentile(current_skew: f64, historical_skews: &[f64]) -> f64 {
        if historical_skews.is_empty() {
            return 50.0;
        }

        let count_below = historical_skews.iter().filter(|&&s| s < current_skew).count();
        (count_below as f64 / historical_skews.len() as f64) * 100.0
    }
}

#[derive(Debug, Clone, Copy)]
pub struct SkewMetrics {
    pub atm_vol: f64,
    pub skew_25d: f64,
    pub skew_10d: f64,
    pub butterfly: f64,
    pub risk_reversal: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TERM STRUCTURE ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Term structure analyzer
pub struct TermStructureAnalyzer;

impl TermStructureAnalyzer {
    /// Analyze term structure shape
    pub fn analyze(surface: &VolatilitySurface) -> TermStructureShape {
        let terms = surface.term_structure();

        if terms.len() < 2 {
            return TermStructureShape::Flat;
        }

        let first_vol = terms[0].1;
        let last_vol = terms[terms.len() - 1].1;
        let slope = last_vol - first_vol;

        // Check for humped structure
        let max_idx = terms.iter()
            .enumerate()
            .max_by(|(_, a), (_, b)| a.1.partial_cmp(&b.1).unwrap())
            .map(|(i, _)| i)
            .unwrap_or(0);

        if max_idx > 0 && max_idx < terms.len() - 1 {
            return TermStructureShape::Humped(max_idx);
        }

        if slope > 0.02 {
            TermStructureShape::Contango
        } else if slope < -0.02 {
            TermStructureShape::Backwardation
        } else {
            TermStructureShape::Flat
        }
    }

    /// Calculate forward volatility between two expirations
    pub fn forward_vol(vol1: f64, t1: f64, vol2: f64, t2: f64) -> f64 {
        if t2 <= t1 {
            return vol2;
        }

        sqrt((vol2.powi(2) * t2 - vol1.powi(2) * t1) / (t2 - t1))
    }

    /// Term structure percentile
    pub fn term_spread_percentile(current_spread: f64, historical_spreads: &[f64]) -> f64 {
        if historical_spreads.is_empty() {
            return 50.0;
        }

        let count_below = historical_spreads.iter().filter(|&&s| s < current_spread).count();
        (count_below as f64 / historical_spreads.len() as f64) * 100.0
    }
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TermStructureShape {
    Contango,       // Upward sloping (long-dated > short-dated)
    Backwardation,  // Downward sloping
    Flat,
    Humped(usize),  // Peak at index
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIVIDEND MODELING
// ═══════════════════════════════════════════════════════════════════════════════

/// Discrete dividend for options pricing
#[derive(Debug, Clone)]
pub struct DiscreteDividend {
    pub ex_date: u64,
    pub amount: f64,
}

/// Option pricer with discrete dividends
pub struct DividendAdjustedPricer;

impl DividendAdjustedPricer {
    /// Price option with discrete dividends
    pub fn price(
        option: &OptionContract,
        market: &MarketData,
        t: f64,
        dividends: &[DiscreteDividend],
        current_time: u64,
    ) -> f64 {
        // Calculate PV of dividends before expiration
        let mut div_pv = 0.0;
        for div in dividends {
            if div.ex_date > current_time && div.ex_date < option.expiration {
                let t_div = (div.ex_date - current_time) as f64 / (365.25 * 24.0 * 3600.0);
                div_pv += div.amount * exp(-market.risk_free_rate * t_div);
            }
        }

        // Adjust spot price
        let adjusted_spot = market.spot - div_pv;
        let adjusted_market = MarketData {
            spot: adjusted_spot,
            ..*market
        };

        BlackScholes::price(option, &adjusted_market, t)
    }

    /// Estimate forward price with dividends
    pub fn forward_price(
        spot: f64,
        r: f64,
        t: f64,
        dividends: &[DiscreteDividend],
        current_time: u64,
        expiration: u64,
    ) -> f64 {
        let mut div_fv = 0.0;
        for div in dividends {
            if div.ex_date > current_time && div.ex_date < expiration {
                let t_to_exp = (expiration - div.ex_date) as f64 / (365.25 * 24.0 * 3600.0);
                div_fv += div.amount * exp(r * t_to_exp);
            }
        }

        spot * exp(r * t) - div_fv
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REAL-TIME GREEKS DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════════

/// Real-time Greeks monitor
pub struct GreeksMonitor {
    positions: Vec<OptionLeg>,
    thresholds: GreeksThresholds,
}

#[derive(Debug, Clone, Copy)]
pub struct GreeksThresholds {
    pub max_delta: f64,
    pub max_gamma: f64,
    pub max_vega: f64,
    pub min_theta: f64,
}

impl Default for GreeksThresholds {
    fn default() -> Self {
        GreeksThresholds {
            max_delta: 100.0,
            max_gamma: 50.0,
            max_vega: 1000.0,
            min_theta: -500.0,
        }
    }
}

#[derive(Debug, Clone)]
pub struct GreeksAlert {
    pub greek: String,
    pub current_value: f64,
    pub threshold: f64,
    pub severity: AlertSeverity,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum AlertSeverity {
    Warning,
    Critical,
}

impl GreeksMonitor {
    pub fn new(thresholds: GreeksThresholds) -> Self {
        GreeksMonitor {
            positions: Vec::new(),
            thresholds,
        }
    }

    pub fn update_positions(&mut self, positions: Vec<OptionLeg>) {
        self.positions = positions;
    }

    /// Check for threshold violations
    pub fn check_thresholds(&self, market: &MarketData, current_time: u64) -> Vec<GreeksAlert> {
        let mut alerts = Vec::new();

        let mut total = PortfolioGreeks::default();
        for leg in &self.positions {
            let t = leg.contract.time_to_expiry(current_time);
            let greeks = BlackScholes::greeks(&leg.contract, market, t);
            let mult = leg.quantity as f64 * leg.contract.multiplier;

            total.delta += greeks.delta * mult;
            total.gamma += greeks.gamma * mult;
            total.vega += greeks.vega * mult;
            total.theta += greeks.theta * mult;
        }

        if total.delta.abs() > self.thresholds.max_delta {
            let severity = if total.delta.abs() > self.thresholds.max_delta * 1.5 {
                AlertSeverity::Critical
            } else {
                AlertSeverity::Warning
            };
            alerts.push(GreeksAlert {
                greek: "Delta".to_string(),
                current_value: total.delta,
                threshold: self.thresholds.max_delta,
                severity,
            });
        }

        if total.gamma.abs() > self.thresholds.max_gamma {
            let severity = if total.gamma.abs() > self.thresholds.max_gamma * 1.5 {
                AlertSeverity::Critical
            } else {
                AlertSeverity::Warning
            };
            alerts.push(GreeksAlert {
                greek: "Gamma".to_string(),
                current_value: total.gamma,
                threshold: self.thresholds.max_gamma,
                severity,
            });
        }

        if total.vega.abs() > self.thresholds.max_vega {
            alerts.push(GreeksAlert {
                greek: "Vega".to_string(),
                current_value: total.vega,
                threshold: self.thresholds.max_vega,
                severity: AlertSeverity::Warning,
            });
        }

        if total.theta < self.thresholds.min_theta {
            alerts.push(GreeksAlert {
                greek: "Theta".to_string(),
                current_value: total.theta,
                threshold: self.thresholds.min_theta,
                severity: AlertSeverity::Warning,
            });
        }

        alerts
    }

    /// Generate summary report
    pub fn summary(&self, market: &MarketData, current_time: u64) -> GreeksSummary {
        let mut total = PortfolioGreeks::default();
        let mut position_count = 0;

        for leg in &self.positions {
            let t = leg.contract.time_to_expiry(current_time);
            let greeks = BlackScholes::greeks(&leg.contract, market, t);
            let mult = leg.quantity as f64 * leg.contract.multiplier;

            total.delta += greeks.delta * mult;
            total.gamma += greeks.gamma * mult;
            total.vega += greeks.vega * mult;
            total.theta += greeks.theta * mult;
            total.rho += greeks.rho * mult;

            position_count += 1;
        }

        GreeksSummary {
            total_greeks: total,
            position_count,
            delta_dollars: total.delta * market.spot,
            gamma_pct: total.gamma * market.spot / 100.0,
            theta_daily: total.theta,
            vega_pct: total.vega,
        }
    }
}

#[derive(Debug, Clone)]
pub struct GreeksSummary {
    pub total_greeks: PortfolioGreeks,
    pub position_count: usize,
    pub delta_dollars: f64,
    pub gamma_pct: f64,
    pub theta_daily: f64,
    pub vega_pct: f64,
}
