// VARIANCE SWAPS
// ═══════════════════════════════════════════════════════════════════════════════

/// Variance swap pricing
pub struct VarianceSwap {
    pub underlying: String,
    pub strike_variance: f64,  // K_var
    pub notional: f64,
    pub expiration: u64,
    pub annualization_factor: f64,
}

impl VarianceSwap {
    pub fn new(underlying: &str, strike_vol: f64, notional: f64, expiration: u64) -> Self {
        VarianceSwap {
            underlying: underlying.to_string(),
            strike_variance: strike_vol.powi(2),
            notional,
            expiration,
            annualization_factor: 252.0,
        }
    }

    /// Fair variance from replicating portfolio
    pub fn fair_variance(surface: &VolatilitySurface, forward: f64, r: f64, t: f64) -> f64 {
        // Replicate using log-contract (strip of puts and calls)
        // Fair variance = 2/T * [r*T - S/F + 1 + integral of OTM options]

        let mut variance = 0.0;
        let dk = forward * 0.01;  // 1% strike spacing

        // OTM puts (K < F)
        let mut k = forward - dk;
        while k > forward * 0.5 {
            let iv = surface.get_iv(0, k);  // Simplified - should use proper expiration
            let put_price = BlackScholes::price(
                &OptionContract::new("", "", OptionType::Put, k, 0),
                &MarketData::new(forward, iv, r),
                t,
            );
            variance += put_price / k.powi(2) * dk;
            k -= dk;
        }

        // OTM calls (K > F)
        let mut k = forward + dk;
        while k < forward * 1.5 {
            let iv = surface.get_iv(0, k);
            let call_price = BlackScholes::price(
                &OptionContract::new("", "", OptionType::Call, k, 0),
                &MarketData::new(forward, iv, r),
                t,
            );
            variance += call_price / k.powi(2) * dk;
            k += dk;
        }

        2.0 * exp(r * t) / t * variance
    }

    /// Mark-to-market value
    pub fn mtm(&self, realized_var: f64, t_remaining: f64, r: f64) -> f64 {
        // PnL = Notional * (Realized Variance - Strike Variance)
        let fair_var = realized_var; // Simplified - should use forward-starting fair var
        self.notional * exp(-r * t_remaining) * (fair_var - self.strike_variance)
    }

    /// Calculate realized variance from returns
    pub fn realized_variance(returns: &[f64]) -> f64 {
        let n = returns.len() as f64;
        let mean = returns.iter().sum::<f64>() / n;
        let variance: f64 = returns.iter()
            .map(|r| (r - mean).powi(2))
            .sum::<f64>() / (n - 1.0);

        variance * 252.0  // Annualized
    }
}

