        }
    }
    
    fn default_performance() -> PerformanceSettings {
        PerformanceSettings {
            target_fps: 60,
            resolution_scale: 1.0,
            dynamic_resolution: false,
            async_compute: true,
            half_res_effects: false,
            temporal_upscaling: false,
