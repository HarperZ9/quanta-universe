    fn default_effects() -> EffectsSettings {
        EffectsSettings {
            ssr_enabled: true,
            ssr_quality: SSRQuality::Medium,
            ssr_max_distance: 100.0,
            lens_flare_enabled: false,
            lens_flare_intensity: 0.5,
            lens_dirt_enabled: false,
