module project_nova

use std::collections::{HashMap, BTreeMap}
use std::math::{min, max, clamp, lerp}
use titan_color::{RGB, ToneMapper, PrecisionTier}
use visual_systems::{PostProcessPipeline, SSAO, Bloom, DepthOfField, MotionBlur}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET CATEGORIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Preset category for organization
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum PresetCategory {
    Cinematic,
    Photorealistic,
    Stylized,
    Retro,
    Performance,
    Accessibility,
    GameSpecific,
    UserCreated,
}

/// Target display type
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DisplayType {
    SDR,
    HDR10,
    HDR10Plus,
    DolbyVision,
    HLG,
}

/// Performance tier
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum PerformanceTier {
    Potato,      // Integrated graphics
    Low,         // Entry-level discrete
    Medium,      // Mid-range
    High,        // High-end
    Ultra,       // Enthusiast
    Unlimited,   // No limits
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET PARAMETERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Complete rendering preset
#[derive(Debug, Clone)]
pub struct NovaPreset {
    pub metadata: PresetMetadata,
    pub color: ColorSettings,
    pub post_process: PostProcessSettings,
    pub lighting: LightingSettings,
    pub effects: EffectsSettings,
    pub performance: PerformanceSettings,
    pub accessibility: AccessibilitySettings,
}

/// Preset metadata
#[derive(Debug, Clone)]
pub struct PresetMetadata {
    pub id: String,
    pub name: String,
    pub description: String,
    pub author: String,
    pub version: String,
    pub category: PresetCategory,
    pub tags: Vec<String>,
    pub target_games: Vec<String>,  // Empty = universal
    pub min_performance_tier: PerformanceTier,
    pub display_types: Vec<DisplayType>,
    pub created_at: u64,
    pub updated_at: u64,
    pub downloads: u64,
    pub rating: f32,
}

/// Color grading settings
#[derive(Debug, Clone)]
pub struct ColorSettings {
    // Tonemapping
    pub tonemapper: ToneMapperType,
    pub exposure: f32,
    pub contrast: f32,
    pub saturation: f32,
    pub vibrance: f32,
    
    // Color balance
    pub temperature: f32,      // -100 (cool) to +100 (warm)
    pub tint: f32,             // -100 (green) to +100 (magenta)
    
    // Lift/Gamma/Gain
    pub shadows_lift: RGB,
    pub midtones_gamma: RGB,
    pub highlights_gain: RGB,
    
    // Split toning
    pub shadows_tint: RGB,
    pub highlights_tint: RGB,
    pub split_balance: f32,
    
    // Color wheels
    pub hue_shift: f32,
    pub selective_color: HashMap<String, HSLAdjustment>,
    
    // LUT
    pub lut_enabled: bool,
    pub lut_intensity: f32,
    pub lut_data: Option<Vec<u8>>,
    
    // TITAN precision tier
    pub precision_tier: PrecisionTier,
}

#[derive(Debug, Clone, Copy)]
pub enum ToneMapperType {
    Linear,
    Reinhard,
    ReinhardExtended,
    ACES,
    ACESFitted,
    AgX,
    Filmic,
    Uncharted2,
    Lottes,
    Uchimura,
    KhronosPBR,
    QuantaAdaptive,
    TonyMcMapface,
}

#[derive(Debug, Clone, Copy)]
pub struct HSLAdjustment {
    pub hue: f32,
    pub saturation: f32,
    pub lightness: f32,
}

/// Post-processing settings
#[derive(Debug, Clone)]
pub struct PostProcessSettings {
    // Ambient Occlusion
    pub ssao_enabled: bool,
    pub ssao_radius: f32,
    pub ssao_intensity: f32,
    pub ssao_samples: u32,
    
    // Global Illumination
    pub ssgi_enabled: bool,
    pub ssgi_intensity: f32,
    pub ssgi_ray_count: u32,
    
    // Bloom
    pub bloom_enabled: bool,
    pub bloom_threshold: f32,
    pub bloom_intensity: f32,
    pub bloom_radius: f32,
    
    // Depth of Field
    pub dof_enabled: bool,
    pub dof_focus_distance: f32,
    pub dof_aperture: f32,
    pub dof_bokeh_shape: BokehShape,
    
    // Motion Blur
    pub motion_blur_enabled: bool,
    pub motion_blur_intensity: f32,
    pub motion_blur_samples: u32,
    
    // Sharpening
    pub sharpening_enabled: bool,
    pub sharpening_intensity: f32,
    pub sharpening_method: SharpeningMethod,
    
    // Anti-aliasing
    pub aa_method: AAMethod,
    pub aa_quality: AAQuality,
    
    // Chromatic Aberration
    pub ca_enabled: bool,
    pub ca_intensity: f32,
    
    // Film Grain
    pub grain_enabled: bool,
    pub grain_intensity: f32,
    pub grain_size: f32,
    
    // Vignette
    pub vignette_enabled: bool,
    pub vignette_intensity: f32,
    pub vignette_roundness: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum BokehShape {
    Circle,
    Hexagon,
    Octagon,
    Anamorphic,
}

#[derive(Debug, Clone, Copy)]
pub enum SharpeningMethod {
    CAS,        // Contrast Adaptive Sharpening
    RCAS,       // Robust CAS
    USM,        // Unsharp Mask
    Clarity,    // Local contrast
}

#[derive(Debug, Clone, Copy)]
pub enum AAMethod {
    None,
    FXAA,
    SMAA,
    TAA,
    DLSS,
    FSR,
    XeSS,
}

#[derive(Debug, Clone, Copy)]
pub enum AAQuality {
    Low,
    Medium,
    High,
    Ultra,
}

/// Lighting settings
#[derive(Debug, Clone)]
pub struct LightingSettings {
    pub ambient_intensity: f32,
    pub sun_intensity: f32,
    pub shadow_intensity: f32,
    pub shadow_softness: f32,
    pub volumetric_enabled: bool,
    pub volumetric_intensity: f32,
    pub volumetric_samples: u32,
    pub god_rays_enabled: bool,
    pub god_rays_intensity: f32,
    pub reflection_intensity: f32,
    pub specular_intensity: f32,
}

/// Special effects settings
#[derive(Debug, Clone)]
pub struct EffectsSettings {
    // Screen Space Reflections
    pub ssr_enabled: bool,
    pub ssr_quality: SSRQuality,
    pub ssr_max_distance: f32,
    
    // Lens effects
    pub lens_flare_enabled: bool,
    pub lens_flare_intensity: f32,
    pub lens_dirt_enabled: bool,
    pub lens_dirt_intensity: f32,
    
    // Weather effects
    pub rain_enabled: bool,
    pub rain_intensity: f32,
    pub fog_enabled: bool,
    pub fog_density: f32,
    pub fog_color: RGB,
    
    // Stylization
    pub outline_enabled: bool,
    pub outline_thickness: f32,
    pub outline_color: RGB,
    pub posterize_enabled: bool,
    pub posterize_levels: u32,
}

#[derive(Debug, Clone, Copy)]
pub enum SSRQuality {
    Low,
    Medium,
    High,
    Ultra,
    RayTraced,
}

/// Performance settings
#[derive(Debug, Clone)]
pub struct PerformanceSettings {
    pub target_fps: u32,
    pub resolution_scale: f32,
    pub dynamic_resolution: bool,
    pub async_compute: bool,
    pub half_res_effects: bool,
    pub temporal_upscaling: bool,
    pub frame_generation: bool,
}

/// Accessibility settings
#[derive(Debug, Clone)]
pub struct AccessibilitySettings {
    // Color blindness support
    pub color_blind_mode: ColorBlindMode,
    pub color_blind_strength: f32,
    
    // Visual aids
    pub high_contrast: bool,
    pub reduced_motion: bool,
    pub screen_shake_reduction: f32,
    pub flash_reduction: bool,
    
    // UI scaling
    pub ui_scale: f32,
    pub subtitle_size: f32,
    pub subtitle_background: bool,
    
    // Photosensitivity
    pub photosensitivity_mode: bool,
    pub max_brightness: f32,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ColorBlindMode {
    None,
    Protanopia,     // Red-blind
    Deuteranopia,   // Green-blind
    Tritanopia,     // Blue-blind
    Achromatopsia,  // Complete color blindness
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET LIBRARY
// ═══════════════════════════════════════════════════════════════════════════════

/// NOVA Preset Library
pub struct NovaLibrary {
    presets: HashMap<String, NovaPreset>,
    categories: HashMap<PresetCategory, Vec<String>>,
    game_presets: HashMap<String, Vec<String>>,
    user_presets: Vec<String>,
}

impl NovaLibrary {
    pub fn new() -> Self {
        let mut library = NovaLibrary {
            presets: HashMap::new(),
            categories: HashMap::new(),
            game_presets: HashMap::new(),
            user_presets: Vec::new(),
        };
        
        library.load_builtin_presets();
        library
    }
    
    /// Load all built-in presets
    fn load_builtin_presets(&mut self) {
        // CINEMATIC PRESETS
        self.add_preset(presets::cinematic_default());
        self.add_preset(presets::cinematic_warm());
        self.add_preset(presets::cinematic_cool());
        self.add_preset(presets::cinematic_noir());
        self.add_preset(presets::cinematic_blockbuster());
        self.add_preset(presets::cinematic_indie());
        self.add_preset(presets::cinematic_horror());
        self.add_preset(presets::cinematic_scifi());
        self.add_preset(presets::cinematic_western());
        self.add_preset(presets::cinematic_fantasy());
        
        // PHOTOREALISTIC PRESETS
        self.add_preset(presets::photorealistic_natural());
        self.add_preset(presets::photorealistic_vivid());
        self.add_preset(presets::photorealistic_neutral());
        self.add_preset(presets::photorealistic_hdr());
        
        // STYLIZED PRESETS
        self.add_preset(presets::stylized_anime());
        self.add_preset(presets::stylized_comic());
        self.add_preset(presets::stylized_watercolor());
        self.add_preset(presets::stylized_oil_painting());
        self.add_preset(presets::stylized_cyberpunk());
        self.add_preset(presets::stylized_vaporwave());
        
        // RETRO PRESETS
        self.add_preset(presets::retro_vhs());
        self.add_preset(presets::retro_crt());
        self.add_preset(presets::retro_film_grain());
        self.add_preset(presets::retro_sepia());
        self.add_preset(presets::retro_polaroid());
        
        // PERFORMANCE PRESETS
        self.add_preset(presets::performance_balanced());
        self.add_preset(presets::performance_quality());
        self.add_preset(presets::performance_potato());
        
        // ACCESSIBILITY PRESETS
        self.add_preset(presets::accessibility_protanopia());
        self.add_preset(presets::accessibility_deuteranopia());
        self.add_preset(presets::accessibility_tritanopia());
        self.add_preset(presets::accessibility_high_contrast());
        self.add_preset(presets::accessibility_reduced_motion());
        self.add_preset(presets::accessibility_photosensitive());
    }
    
    /// Add a preset to the library
    pub fn add_preset(&mut self, preset: NovaPreset) {
        let id = preset.metadata.id.clone();
        let category = preset.metadata.category;
        
        // Add to category index
        self.categories.entry(category)
            .or_insert_with(Vec::new)
            .push(id.clone());
        
        // Add to game index
        for game in &preset.metadata.target_games {
            self.game_presets.entry(game.clone())
                .or_insert_with(Vec::new)
                .push(id.clone());
        }
        
        // Track user presets
        if category == PresetCategory::UserCreated {
            self.user_presets.push(id.clone());
        }
        
        self.presets.insert(id, preset);
    }
    
    /// Get preset by ID
    pub fn get(&self, id: &str) -> Option<&NovaPreset> {
        self.presets.get(id)
    }
    
    /// Get all presets in a category
    pub fn by_category(&self, category: PresetCategory) -> Vec<&NovaPreset> {
        self.categories.get(&category)
            .map(|ids| ids.iter().filter_map(|id| self.presets.get(id)).collect())
            .unwrap_or_default()
    }
    
    /// Get presets for a specific game
    pub fn for_game(&self, game: &str) -> Vec<&NovaPreset> {
        self.game_presets.get(game)
            .map(|ids| ids.iter().filter_map(|id| self.presets.get(id)).collect())
            .unwrap_or_default()
    }
    
    /// Search presets by name or tags
    pub fn search(&self, query: &str) -> Vec<&NovaPreset> {
        let query = query.to_lowercase();
        self.presets.values()
            .filter(|p| {
                p.metadata.name.to_lowercase().contains(&query) ||
                p.metadata.description.to_lowercase().contains(&query) ||
                p.metadata.tags.iter().any(|t| t.to_lowercase().contains(&query))
            })
            .collect()
    }
    
    /// Get presets compatible with performance tier
    pub fn for_performance(&self, tier: PerformanceTier) -> Vec<&NovaPreset> {
        self.presets.values()
            .filter(|p| p.metadata.min_performance_tier <= tier)
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRESET INTERPOLATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Blend between two presets
pub fn blend_presets(a: &NovaPreset, b: &NovaPreset, t: f32) -> NovaPreset {
    let t = t.clamp(0.0, 1.0);
    
    NovaPreset {
        metadata: PresetMetadata {
            id: format!("blend_{}_{}", a.metadata.id, b.metadata.id),
            name: format!("Blend: {} + {}", a.metadata.name, b.metadata.name),
            description: "Interpolated preset".to_string(),
            author: "NOVA Blend".to_string(),
            version: "1.0.0".to_string(),
            category: PresetCategory::UserCreated,
            tags: vec!["blend".to_string()],
            target_games: vec![],
            min_performance_tier: a.metadata.min_performance_tier.max(b.metadata.min_performance_tier),
            display_types: vec![DisplayType::SDR, DisplayType::HDR10],
            created_at: 0,
            updated_at: 0,
            downloads: 0,
            rating: 0.0,
        },
        color: blend_color(&a.color, &b.color, t),
        post_process: blend_post_process(&a.post_process, &b.post_process, t),
        lighting: blend_lighting(&a.lighting, &b.lighting, t),
        effects: blend_effects(&a.effects, &b.effects, t),
        performance: if t < 0.5 { a.performance.clone() } else { b.performance.clone() },
        accessibility: if t < 0.5 { a.accessibility.clone() } else { b.accessibility.clone() },
    }
}

fn blend_color(a: &ColorSettings, b: &ColorSettings, t: f32) -> ColorSettings {
    ColorSettings {
        tonemapper: if t < 0.5 { a.tonemapper } else { b.tonemapper },
        exposure: lerp(a.exposure, b.exposure, t),
        contrast: lerp(a.contrast, b.contrast, t),
        saturation: lerp(a.saturation, b.saturation, t),
        vibrance: lerp(a.vibrance, b.vibrance, t),
        temperature: lerp(a.temperature, b.temperature, t),
        tint: lerp(a.tint, b.tint, t),
        shadows_lift: blend_rgb(&a.shadows_lift, &b.shadows_lift, t),
        midtones_gamma: blend_rgb(&a.midtones_gamma, &b.midtones_gamma, t),
        highlights_gain: blend_rgb(&a.highlights_gain, &b.highlights_gain, t),
        shadows_tint: blend_rgb(&a.shadows_tint, &b.shadows_tint, t),
        highlights_tint: blend_rgb(&a.highlights_tint, &b.highlights_tint, t),
        split_balance: lerp(a.split_balance, b.split_balance, t),
        hue_shift: lerp(a.hue_shift, b.hue_shift, t),
        selective_color: a.selective_color.clone(),
        lut_enabled: if t < 0.5 { a.lut_enabled } else { b.lut_enabled },
        lut_intensity: lerp(a.lut_intensity, b.lut_intensity, t),
        lut_data: if t < 0.5 { a.lut_data.clone() } else { b.lut_data.clone() },
        precision_tier: if t < 0.5 { a.precision_tier } else { b.precision_tier },
    }
}

fn blend_rgb(a: &RGB, b: &RGB, t: f32) -> RGB {
    RGB::new(
        lerp(a.r, b.r, t),
        lerp(a.g, b.g, t),
        lerp(a.b, b.b, t),
    )
}

fn blend_post_process(a: &PostProcessSettings, b: &PostProcessSettings, t: f32) -> PostProcessSettings {
    PostProcessSettings {
        ssao_enabled: if t < 0.5 { a.ssao_enabled } else { b.ssao_enabled },
        ssao_radius: lerp(a.ssao_radius, b.ssao_radius, t),
        ssao_intensity: lerp(a.ssao_intensity, b.ssao_intensity, t),
        ssao_samples: ((1.0 - t) * a.ssao_samples as f32 + t * b.ssao_samples as f32) as u32,
        ssgi_enabled: if t < 0.5 { a.ssgi_enabled } else { b.ssgi_enabled },
        ssgi_intensity: lerp(a.ssgi_intensity, b.ssgi_intensity, t),
        ssgi_ray_count: ((1.0 - t) * a.ssgi_ray_count as f32 + t * b.ssgi_ray_count as f32) as u32,
        bloom_enabled: if t < 0.5 { a.bloom_enabled } else { b.bloom_enabled },
        bloom_threshold: lerp(a.bloom_threshold, b.bloom_threshold, t),
        bloom_intensity: lerp(a.bloom_intensity, b.bloom_intensity, t),
        bloom_radius: lerp(a.bloom_radius, b.bloom_radius, t),
        dof_enabled: if t < 0.5 { a.dof_enabled } else { b.dof_enabled },
        dof_focus_distance: lerp(a.dof_focus_distance, b.dof_focus_distance, t),
        dof_aperture: lerp(a.dof_aperture, b.dof_aperture, t),
        dof_bokeh_shape: if t < 0.5 { a.dof_bokeh_shape } else { b.dof_bokeh_shape },
        motion_blur_enabled: if t < 0.5 { a.motion_blur_enabled } else { b.motion_blur_enabled },
        motion_blur_intensity: lerp(a.motion_blur_intensity, b.motion_blur_intensity, t),
        motion_blur_samples: ((1.0 - t) * a.motion_blur_samples as f32 + t * b.motion_blur_samples as f32) as u32,
        sharpening_enabled: if t < 0.5 { a.sharpening_enabled } else { b.sharpening_enabled },
        sharpening_intensity: lerp(a.sharpening_intensity, b.sharpening_intensity, t),
        sharpening_method: if t < 0.5 { a.sharpening_method } else { b.sharpening_method },
        aa_method: if t < 0.5 { a.aa_method } else { b.aa_method },
        aa_quality: if t < 0.5 { a.aa_quality } else { b.aa_quality },
        ca_enabled: if t < 0.5 { a.ca_enabled } else { b.ca_enabled },
        ca_intensity: lerp(a.ca_intensity, b.ca_intensity, t),
        grain_enabled: if t < 0.5 { a.grain_enabled } else { b.grain_enabled },
        grain_intensity: lerp(a.grain_intensity, b.grain_intensity, t),
        grain_size: lerp(a.grain_size, b.grain_size, t),
        vignette_enabled: if t < 0.5 { a.vignette_enabled } else { b.vignette_enabled },
        vignette_intensity: lerp(a.vignette_intensity, b.vignette_intensity, t),
        vignette_roundness: lerp(a.vignette_roundness, b.vignette_roundness, t),
    }
}

fn blend_lighting(a: &LightingSettings, b: &LightingSettings, t: f32) -> LightingSettings {
    LightingSettings {
        ambient_intensity: lerp(a.ambient_intensity, b.ambient_intensity, t),
        sun_intensity: lerp(a.sun_intensity, b.sun_intensity, t),
        shadow_intensity: lerp(a.shadow_intensity, b.shadow_intensity, t),
        shadow_softness: lerp(a.shadow_softness, b.shadow_softness, t),
        volumetric_enabled: if t < 0.5 { a.volumetric_enabled } else { b.volumetric_enabled },
        volumetric_intensity: lerp(a.volumetric_intensity, b.volumetric_intensity, t),
        volumetric_samples: ((1.0 - t) * a.volumetric_samples as f32 + t * b.volumetric_samples as f32) as u32,
        god_rays_enabled: if t < 0.5 { a.god_rays_enabled } else { b.god_rays_enabled },
        god_rays_intensity: lerp(a.god_rays_intensity, b.god_rays_intensity, t),
        reflection_intensity: lerp(a.reflection_intensity, b.reflection_intensity, t),
        specular_intensity: lerp(a.specular_intensity, b.specular_intensity, t),
    }
}

fn blend_effects(a: &EffectsSettings, b: &EffectsSettings, t: f32) -> EffectsSettings {
    EffectsSettings {
        ssr_enabled: if t < 0.5 { a.ssr_enabled } else { b.ssr_enabled },
        ssr_quality: if t < 0.5 { a.ssr_quality } else { b.ssr_quality },
        ssr_max_distance: lerp(a.ssr_max_distance, b.ssr_max_distance, t),
        lens_flare_enabled: if t < 0.5 { a.lens_flare_enabled } else { b.lens_flare_enabled },
        lens_flare_intensity: lerp(a.lens_flare_intensity, b.lens_flare_intensity, t),
        lens_dirt_enabled: if t < 0.5 { a.lens_dirt_enabled } else { b.lens_dirt_enabled },
        lens_dirt_intensity: lerp(a.lens_dirt_intensity, b.lens_dirt_intensity, t),
        rain_enabled: if t < 0.5 { a.rain_enabled } else { b.rain_enabled },
        rain_intensity: lerp(a.rain_intensity, b.rain_intensity, t),
        fog_enabled: if t < 0.5 { a.fog_enabled } else { b.fog_enabled },
        fog_density: lerp(a.fog_density, b.fog_density, t),
        fog_color: blend_rgb(&a.fog_color, &b.fog_color, t),
        outline_enabled: if t < 0.5 { a.outline_enabled } else { b.outline_enabled },
        outline_thickness: lerp(a.outline_thickness, b.outline_thickness, t),
        outline_color: blend_rgb(&a.outline_color, &b.outline_color, t),
        posterize_enabled: if t < 0.5 { a.posterize_enabled } else { b.posterize_enabled },
        posterize_levels: ((1.0 - t) * a.posterize_levels as f32 + t * b.posterize_levels as f32) as u32,
    }
}

fn lerp(a: f32, b: f32, t: f32) -> f32 {
    a + (b - a) * t
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILT-IN PRESETS
// ═══════════════════════════════════════════════════════════════════════════════

mod presets {
    use super::*;
    
    fn default_metadata(id: &str, name: &str, desc: &str, category: PresetCategory) -> PresetMetadata {
        PresetMetadata {
            id: id.to_string(),
            name: name.to_string(),
            description: desc.to_string(),
            author: "Quanta Studios".to_string(),
            version: "1.0.0".to_string(),
            category,
            tags: vec![],
            target_games: vec![],
            min_performance_tier: PerformanceTier::Medium,
            display_types: vec![DisplayType::SDR, DisplayType::HDR10],
            created_at: 0,
            updated_at: 0,
            downloads: 0,
            rating: 5.0,
        }
    }
    
    fn default_color() -> ColorSettings {
        ColorSettings {
            tonemapper: ToneMapperType::ACES,
            exposure: 0.0,
            contrast: 1.0,
            saturation: 1.0,
            vibrance: 0.0,
            temperature: 0.0,
            tint: 0.0,
            shadows_lift: RGB::new(0.0, 0.0, 0.0),
            midtones_gamma: RGB::new(1.0, 1.0, 1.0),
            highlights_gain: RGB::new(1.0, 1.0, 1.0),
            shadows_tint: RGB::new(0.5, 0.5, 0.5),
            highlights_tint: RGB::new(0.5, 0.5, 0.5),
            split_balance: 0.0,
            hue_shift: 0.0,
            selective_color: HashMap::new(),
            lut_enabled: false,
            lut_intensity: 1.0,
            lut_data: None,
            precision_tier: PrecisionTier::Professional,
        }
    }
    
    fn default_post_process() -> PostProcessSettings {
        PostProcessSettings {
            ssao_enabled: true,
            ssao_radius: 0.5,
            ssao_intensity: 1.0,
            ssao_samples: 32,
            ssgi_enabled: false,
            ssgi_intensity: 1.0,
            ssgi_ray_count: 4,
            bloom_enabled: true,
            bloom_threshold: 1.0,
            bloom_intensity: 0.5,
            bloom_radius: 1.0,
            dof_enabled: false,
            dof_focus_distance: 5.0,
            dof_aperture: 2.8,
            dof_bokeh_shape: BokehShape::Circle,
            motion_blur_enabled: false,
            motion_blur_intensity: 0.5,
            motion_blur_samples: 16,
            sharpening_enabled: true,
            sharpening_intensity: 0.5,
            sharpening_method: SharpeningMethod::CAS,
            aa_method: AAMethod::TAA,
            aa_quality: AAQuality::High,
            ca_enabled: false,
            ca_intensity: 0.005,
            grain_enabled: false,
            grain_intensity: 0.05,
            grain_size: 1.0,
            vignette_enabled: false,
            vignette_intensity: 0.3,
            vignette_roundness: 1.0,
        }
    }
    
    fn default_lighting() -> LightingSettings {
        LightingSettings {
            ambient_intensity: 1.0,
            sun_intensity: 1.0,
            shadow_intensity: 1.0,
            shadow_softness: 0.5,
