    // CINEMATIC PRESETS
    
    pub fn cinematic_default() -> NovaPreset {
        let mut preset = NovaPreset {
            metadata: default_metadata("cinematic_default", "NOVA Cinematic", "Professional cinematic color grading", PresetCategory::Cinematic),
            color: default_color(),
            post_process: default_post_process(),
            lighting: default_lighting(),
            effects: default_effects(),
            performance: default_performance(),
            accessibility: default_accessibility(),
        };
        preset.color.tonemapper = ToneMapperType::ACES;
        preset.color.contrast = 1.1;
        preset.color.saturation = 0.95;
        preset.post_process.vignette_enabled = true;
        preset.post_process.vignette_intensity = 0.25;
        preset
    }
    
