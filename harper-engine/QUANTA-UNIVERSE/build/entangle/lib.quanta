#[derive(Debug)]
pub enum GenesisError {
    DeviceNotFound,
    NotConnected,
    NoAgentAvailable,
    CostLimitExceeded,
    ProviderNotImplemented,
    PlatformNotConnected,
    ConversationNotFound,
    NoPhoneConnected,
    InvalidCallState,
    NoActiveCall,
    EncryptionError,
    NetworkError(String),
}

