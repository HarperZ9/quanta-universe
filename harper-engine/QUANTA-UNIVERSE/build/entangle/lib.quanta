/// Device type classification
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum DeviceType {
    Desktop,
    Laptop,
    Phone,
    Tablet,
    Watch,
    TV,
    IoT,
    Server,
}

/// Device operating system
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum DeviceOS {
    Windows,
    MacOS,
    Linux,
    Android,
    iOS,
    WatchOS,
    TizenOS,
    Custom(u32),
}

/// Connection status
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ConnectionStatus {
    Connected,
    Connecting,
    Disconnected,
    Pairing,
    Error,
}

/// Device capability flags
#[derive(Debug, Clone)]
pub struct DeviceCapabilities {
    pub can_send_sms: bool,
    pub can_make_calls: bool,
    pub has_camera: bool,
    pub has_microphone: bool,
    pub has_speakers: bool,
    pub has_display: bool,
    pub has_keyboard: bool,
    pub has_mouse: bool,
    pub has_touch: bool,
    pub has_gps: bool,
    pub has_biometrics: bool,
    pub has_nfc: bool,
    pub storage_gb: f32,
    pub ram_gb: f32,
    pub battery_percent: Option<u8>,
}

/// Connected device representation
#[derive(Debug, Clone)]
pub struct Device {
    pub id: String,
    pub name: String,
    pub device_type: DeviceType,
    pub os: DeviceOS,
    pub os_version: String,
    pub model: String,
    pub capabilities: DeviceCapabilities,
    pub status: ConnectionStatus,
    pub last_seen: DateTime,
    pub ip_address: Option<String>,
    pub public_key: Vec<u8>,
}

impl Device {
    pub fn is_mobile(&self) -> bool {
        matches!(self.device_type, DeviceType::Phone | DeviceType::Tablet | DeviceType::Watch)
    }
    
    pub fn is_primary_compute(&self) -> bool {
        matches!(self.device_type, DeviceType::Desktop | DeviceType::Laptop | DeviceType::Server)
    }
}

/// Device mesh network manager
pub struct DeviceMesh {
    local_device: Device,
    devices: RwLock<HashMap<String, Device>>,
    connections: RwLock<HashMap<String, DeviceConnection>>,
    discovery_active: bool,
}

struct DeviceConnection {
    device_id: String,
    stream: Option<TcpStream>,
    session_key: Vec<u8>,
    established_at: DateTime,
    bytes_sent: u64,
    bytes_received: u64,
}

impl DeviceMesh {
    pub fn new(local_device: Device) -> Self {
        DeviceMesh {
            local_device,
            devices: RwLock::new(HashMap::new()),
            connections: RwLock::new(HashMap::new()),
            discovery_active: false,
        }
    }
    
    /// Start device discovery (mDNS/Bonjour)
    pub fn start_discovery(&mut self) -> Result<(), GenesisError> {
        self.discovery_active = true;
        // Broadcast presence on local network
        // Listen for other Genesis devices
        Ok(())
    }
    
    /// Connect to a specific device
    pub fn connect(&self, device_id: &str) -> Result<(), GenesisError> {
        let devices = self.devices.read().unwrap();
        let device = devices.get(device_id)
            .ok_or(GenesisError::DeviceNotFound)?;
        
        // Perform X25519 key exchange
        let (public_key, private_key) = X25519::generate_keypair();
        let shared_secret = X25519::diffie_hellman(&private_key, &device.public_key);
        
        // Derive session key
        let session_key = derive_session_key(&shared_secret);
        
        // Establish encrypted connection
        let conn = DeviceConnection {
            device_id: device_id.to_string(),
            stream: None, // Would be actual TCP stream
            session_key,
            established_at: DateTime::now(),
            bytes_sent: 0,
            bytes_received: 0,
        };
        
        self.connections.write().unwrap().insert(device_id.to_string(), conn);
        Ok(())
    }
    
    /// Send data to device
    pub fn send(&self, device_id: &str, data: &[u8]) -> Result<(), GenesisError> {
        let connections = self.connections.read().unwrap();
        let conn = connections.get(device_id)
            .ok_or(GenesisError::NotConnected)?;
        
        // Encrypt with AES-256-GCM
        let nonce = generate_nonce();
        let ciphertext = Aes256Gcm::encrypt(&conn.session_key, &nonce, data)?;
        
        // Send over connection
        // conn.stream.write(&nonce)?;
        // conn.stream.write(&ciphertext)?;
        
        Ok(())
    }
    
    /// Get all connected devices
    pub fn connected_devices(&self) -> Vec<Device> {
        let devices = self.devices.read().unwrap();
        let connections = self.connections.read().unwrap();
        
        devices.values()
            .filter(|d| connections.contains_key(&d.id))
            .cloned()
            .collect()
    }
}

