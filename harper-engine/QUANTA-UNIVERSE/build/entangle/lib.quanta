/// Phone call state
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum CallState {
    Idle,
    Ringing,
    Dialing,
    Connected,
    OnHold,
    Ended,
}

/// Phone call representation
#[derive(Debug, Clone)]
pub struct PhoneCall {
    pub id: String,
    pub phone_number: String,
    pub contact: Option<Contact>,
    pub direction: CallDirection,
    pub state: CallState,
    pub started_at: Option<DateTime>,
    pub ended_at: Option<DateTime>,
    pub duration_secs: u32,
    pub audio_device: String,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum CallDirection {
    Incoming,
    Outgoing,
}

/// Phone call manager
pub struct PhoneCallManager {
    active_call: RwLock<Option<PhoneCall>>,
    call_history: RwLock<Vec<PhoneCall>>,
    device_mesh: Arc<DeviceMesh>,
    audio_stream: Option<AudioStream>,
}

struct AudioStream {
    sample_rate: u32,
    channels: u8,
    // Audio routing handles
}

impl PhoneCallManager {
    pub fn new(mesh: Arc<DeviceMesh>) -> Self {
        PhoneCallManager {
            active_call: RwLock::new(None),
            call_history: RwLock::new(Vec::new()),
            device_mesh: mesh,
            audio_stream: None,
        }
    }
    
    /// Initiate outgoing call
    pub fn dial(&self, phone_number: &str) -> Result<String, GenesisError> {
        // Find a phone device
        let devices = self.device_mesh.connected_devices();
        let phone = devices.iter()
            .find(|d| d.capabilities.can_make_calls)
            .ok_or(GenesisError::NoPhoneConnected)?;
        
        let call = PhoneCall {
            id: uuid::Uuid::new_v4().to_string(),
            phone_number: phone_number.to_string(),
            contact: None,
            direction: CallDirection::Outgoing,
            state: CallState::Dialing,
            started_at: Some(DateTime::now()),
            ended_at: None,
            duration_secs: 0,
            audio_device: "default".to_string(),
        };
        
        let id = call.id.clone();
        *self.active_call.write().unwrap() = Some(call);
        
        // Send dial command to phone
        self.device_mesh.send(&phone.id, &format!("DIAL:{}", phone_number).into_bytes())?;
        
        Ok(id)
    }
    
    /// Answer incoming call
    pub fn answer(&self) -> Result<(), GenesisError> {
        let mut call = self.active_call.write().unwrap();
        if let Some(c) = call.as_mut() {
            if c.state == CallState::Ringing {
                c.state = CallState::Connected;
                // Route audio
                Ok(())
            } else {
                Err(GenesisError::InvalidCallState)
            }
        } else {
            Err(GenesisError::NoActiveCall)
        }
    }
    
    /// End call
    pub fn hangup(&self) -> Result<(), GenesisError> {
        let mut call = self.active_call.write().unwrap();
        if let Some(c) = call.as_mut() {
            c.state = CallState::Ended;
            c.ended_at = Some(DateTime::now());
            
            if let (Some(start), Some(end)) = (c.started_at, c.ended_at) {
                c.duration_secs = (end - start).num_seconds() as u32;
            }
            
            // Add to history
            let finished = c.clone();
            self.call_history.write().unwrap().push(finished);
            
            *call = None;
            Ok(())
        } else {
            Err(GenesisError::NoActiveCall)
        }
    }
    
    /// Handle incoming call notification from phone
    pub fn on_incoming_call(&self, phone_number: &str, contact: Option<Contact>) {
        let call = PhoneCall {
            id: uuid::Uuid::new_v4().to_string(),
            phone_number: phone_number.to_string(),
            contact,
            direction: CallDirection::Incoming,
            state: CallState::Ringing,
            started_at: None,
            ended_at: None,
            duration_secs: 0,
            audio_device: "default".to_string(),
        };
        
        *self.active_call.write().unwrap() = Some(call);
        
        // Show notification on PC
        // play_ringtone();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// 2FA CODE SYNC
// ═══════════════════════════════════════════════════════════════════════════════

/// 2FA code type
#[derive(Debug, Clone)]
pub struct TwoFactorCode {
    pub code: String,
    pub service: String,  // Detected service name
    pub received_at: DateTime,
    pub expires_at: DateTime,
    pub source_device: String,
    pub used: bool,
}

/// 2FA code manager
pub struct TwoFactorManager {
    codes: RwLock<VecDeque<TwoFactorCode>>,
    auto_copy: bool,
    device_mesh: Arc<DeviceMesh>,
}

impl TwoFactorManager {
    pub fn new(mesh: Arc<DeviceMesh>) -> Self {
        TwoFactorManager {
            codes: RwLock::new(VecDeque::with_capacity(50)),
            auto_copy: true,
            device_mesh: mesh,
        }
    }
    
    /// Process incoming SMS and extract 2FA codes
    pub fn on_sms(&self, sender: &str, body: &str) {
        // Pattern matching for common 2FA formats
        let patterns = [
            r"(?i)(?:code|código|otp|pin|verification)[\s:]*(\d{4,8})",
            r"(?i)(\d{4,8})[\s]*(?:is your|est votre|es tu)",
            r"(?i)G-(\d{6})",  // Google
            r"(?i)(\d{6})[\s]*is your.*(?:Facebook|Instagram|Twitter|WhatsApp)",
        ];
        
        for pattern in patterns {
            if let Some(captures) = regex::Regex::new(pattern).unwrap().captures(body) {
                if let Some(code_match) = captures.get(1) {
                    let code = TwoFactorCode {
                        code: code_match.as_str().to_string(),
                        service: self.detect_service(sender, body),
                        received_at: DateTime::now(),
                        expires_at: DateTime::now() + Duration::minutes(5),
                        source_device: "phone".to_string(),
                        used: false,
                    };
                    
                    let mut codes = self.codes.write().unwrap();
                    codes.push_front(code.clone());
                    
                    if self.auto_copy {
                        // Auto-copy to clipboard
                        // clipboard.copy(code.code);
                    }
                    
                    // Notify all devices
                    // self.sync_to_devices(&code);
                    
                    break;
                }
            }
        }
    }
    
    fn detect_service(&self, sender: &str, body: &str) -> String {
        let services = [
            ("Google", &["Google", "G-"]),
            ("Facebook", &["Facebook", "FB"]),
            ("Instagram", &["Instagram"]),
            ("Twitter", &["Twitter", "X"]),
            ("Microsoft", &["Microsoft", "Outlook"]),
            ("Amazon", &["Amazon", "AWS"]),
            ("Apple", &["Apple", "iCloud"]),
            ("WhatsApp", &["WhatsApp"]),
            ("Telegram", &["Telegram"]),
            ("LinkedIn", &["LinkedIn"]),
            ("GitHub", &["GitHub"]),
            ("Slack", &["Slack"]),
            ("Discord", &["Discord"]),
        ];
        
        for (service, keywords) in services {
            for keyword in keywords {
                if body.contains(keyword) || sender.contains(keyword) {
                    return service.to_string();
                }
            }
        }
        
        "Unknown".to_string()
    }
    
    /// Get most recent unused code
    pub fn get_latest_code(&self) -> Option<TwoFactorCode> {
        let codes = self.codes.read().unwrap();
        codes.iter()
            .find(|c| !c.used && c.expires_at > DateTime::now())
            .cloned()
    }
    
    /// Mark code as used
    pub fn mark_used(&self, code: &str) {
        let mut codes = self.codes.write().unwrap();
        if let Some(c) = codes.iter_mut().find(|c| c.code == code) {
            c.used = true;
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN GENESIS CONTROLLER
// ═══════════════════════════════════════════════════════════════════════════════

/// Main Genesis Symmetric controller
pub struct GenesisController {
    pub device_mesh: Arc<DeviceMesh>,
    pub ai_orchestrator: Arc<Mutex<AIOrchestrator>>,
    pub message_hub: Arc<MessageHub>,
    pub clipboard: Arc<ClipboardManager>,
    pub phone_calls: Arc<PhoneCallManager>,
    pub two_factor: Arc<TwoFactorManager>,
}

impl GenesisController {
    pub fn new(local_device: Device) -> Self {
        let mesh = Arc::new(DeviceMesh::new(local_device));
        let ai = Arc::new(Mutex::new(AIOrchestrator::new()));
        
        GenesisController {
            device_mesh: Arc::clone(&mesh),
            ai_orchestrator: Arc::clone(&ai),
            message_hub: Arc::new(MessageHub::new(Arc::clone(&ai))),
            clipboard: Arc::new(ClipboardManager::new(Arc::clone(&mesh), Arc::clone(&ai))),
            phone_calls: Arc::new(PhoneCallManager::new(Arc::clone(&mesh))),
            two_factor: Arc::new(TwoFactorManager::new(Arc::clone(&mesh))),
        }
    }
    
    /// Start all services
    pub fn start(&mut self) -> Result<(), GenesisError> {
        // Auto-detect AI agents
        self.ai_orchestrator.lock().unwrap().auto_detect_agents();
        
        // Start device discovery
        // mesh.start_discovery()?;
        
        // Start message sync
        // spawn message_hub.sync_loop()
        
        Ok(())
    }
    
    /// Get system status
    pub fn status(&self) -> GenesisStatus {
        GenesisStatus {
            connected_devices: self.device_mesh.connected_devices().len(),
            ai_agents_available: self.ai_orchestrator.lock().unwrap().agents.len(),
            active_call: self.phone_calls.active_call.read().unwrap().is_some(),
            unread_messages: 0, // Would count from message_hub
            pending_2fa_codes: self.two_factor.codes.read().unwrap()
                .iter()
                .filter(|c| !c.used && c.expires_at > DateTime::now())
                .count(),
        }
    }
}

#[derive(Debug, Clone)]
pub struct GenesisStatus {
    pub connected_devices: usize,
    pub ai_agents_available: usize,
    pub active_call: bool,
    pub unread_messages: usize,
    pub pending_2fa_codes: usize,
}

