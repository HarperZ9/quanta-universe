module quanta_reshade

// ═══════════════════════════════════════════════════════════════════════════════
// SHADER EFFECT DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// ReShade effect metadata
#[derive(Debug, Clone)]
pub struct EffectInfo {
    pub name: String,
    pub category: EffectCategory,
    pub description: String,
    pub author: String,
    pub version: String,
    pub techniques: Vec<String>,
    pub uniforms: Vec<UniformDef>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum EffectCategory {
    ColorProcessing,
    Tonemapping,
    LightingShadows,
    PostProcessing,
    FilmCinematic,
    UtilityDebug,
}

#[derive(Debug, Clone)]
pub struct UniformDef {
    pub name: String,
    pub ui_type: UIType,
    pub ui_label: String,
    pub default_value: f32,
    pub min_value: f32,
    pub max_value: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum UIType {
    Slider,
    Drag,
    Combo,
    Color,
    Bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// EFFECT 1: TITAN Tonemapper (Primary)
// ═══════════════════════════════════════════════════════════════════════════════

pub const TITAN_TONEMAPPER_FX: &str = r#"
/*═══════════════════════════════════════════════════════════════════════════════
 * TITAN™ Tonemapper v2.0
 * Part of Quanta Prism
 * Copyright © 2024-2025 Zain Dana Quanta
 *═══════════════════════════════════════════════════════════════════════════════*/

#include "ReShade.fxh"

// ─── UNIFORMS ─────────────────────────────────────────────────────────────────

uniform int TonemapOperator <
    ui_type = "combo";
    ui_label = "Tonemap Operator";
    ui_items = "Linear\0Reinhard\0Reinhard Extended\0ACES\0ACES Fitted\0AgX\0Filmic\0Uncharted 2\0Lottes\0Uchimura\0Khronos PBR\0Quanta Adaptive\0Tony McMapface\0";
    ui_tooltip = "Select tonemapping algorithm";
> = 11; // Default: Quanta Adaptive

uniform float Exposure <
    ui_type = "slider";
    ui_label = "Exposure";
    ui_min = -5.0; ui_max = 5.0;
    ui_tooltip = "Exposure adjustment in stops";
> = 0.0;

uniform float Contrast <
    ui_type = "slider";
    ui_label = "Contrast";
    ui_min = 0.5; ui_max = 2.0;
> = 1.0;

uniform float Saturation <
    ui_type = "slider";
    ui_label = "Saturation";
    ui_min = 0.0; ui_max = 2.0;
> = 1.0;

uniform float WhitePoint <
    ui_type = "slider";
    ui_label = "White Point";
    ui_min = 1.0; ui_max = 20.0;
> = 11.2;

uniform float Shadows <
    ui_type = "slider";
    ui_label = "Shadows";
    ui_min = -1.0; ui_max = 1.0;
> = 0.0;

uniform float Highlights <
    ui_type = "slider";
    ui_label = "Highlights";
    ui_min = -1.0; ui_max = 1.0;
> = 0.0;

// ─── TONEMAPPING FUNCTIONS ────────────────────────────────────────────────────

float3 Reinhard(float3 color) {
    return color / (1.0 + color);
}

float3 ReinhardExtended(float3 color, float white) {
    float3 numerator = color * (1.0 + color / (white * white));
    return numerator / (1.0 + color);
}

float3 ACES(float3 color) {
    const float a = 2.51;
    const float b = 0.03;
    const float c = 2.43;
    const float d = 0.59;
    const float e = 0.14;
    return saturate((color * (a * color + b)) / (color * (c * color + d) + e));
}

float3 ACESFitted(float3 color) {
    // Input transform
    const float3x3 ACESInputMat = float3x3(
        0.59719, 0.35458, 0.04823,
        0.07600, 0.90834, 0.01566,
        0.02840, 0.13383, 0.83777
    );
    
    // Output transform
    const float3x3 ACESOutputMat = float3x3(
         1.60475, -0.53108, -0.07367,
        -0.10208,  1.10813, -0.00605,
        -0.00327, -0.07276,  1.07602
    );
    
    color = mul(ACESInputMat, color);
    
    // RRT and ODT fit
    float3 a = color * (color + 0.0245786) - 0.000090537;
    float3 b = color * (0.983729 * color + 0.4329510) + 0.238081;
    color = a / b;
    
    return saturate(mul(ACESOutputMat, color));
}

float3 AgX(float3 color) {
    // AgX Log encoding
    float3 log_color = log2(max(color, 1e-10));
    
    // Compress to AgX range
    const float minEv = -12.47393;
    const float maxEv = 4.026069;
    
    float3 compressed = (log_color - minEv) / (maxEv - minEv);
    compressed = saturate(compressed);
    
    // Sigmoid curve
    float3 x = compressed;
    float3 x2 = x * x;
    float3 x4 = x2 * x2;
    
    return 15.5 * x4 * x2 - 40.14 * x4 * x + 31.96 * x4 - 6.868 * x2 * x + 0.4298 * x2 + 0.1191 * x - 0.00232;
}

float3 Filmic(float3 color) {
    const float A = 0.22; // Shoulder Strength
    const float B = 0.30; // Linear Strength
    const float C = 0.10; // Linear Angle
    const float D = 0.20; // Toe Strength
    const float E = 0.01; // Toe Numerator
    const float F = 0.30; // Toe Denominator
    
    float3 result = ((color * (A * color + C * B) + D * E) / (color * (A * color + B) + D * F)) - E / F;
    
    const float W = 11.2;
    float whiteScale = 1.0 / (((W * (A * W + C * B) + D * E) / (W * (A * W + B) + D * F)) - E / F);
    
    return result * whiteScale;
}

float3 Uncharted2(float3 color) {
    const float A = 0.15;
    const float B = 0.50;
    const float C = 0.10;
    const float D = 0.20;
    const float E = 0.02;
    const float F = 0.30;
    
    float3 result = ((color * (A * color + C * B) + D * E) / (color * (A * color + B) + D * F)) - E / F;
    
    const float W = 11.2;
    float whiteScale = 1.0 / (((W * (A * W + C * B) + D * E) / (W * (A * W + B) + D * F)) - E / F);
    
    return result * whiteScale;
}

float3 Lottes(float3 color) {
    const float a = 1.6;
    const float d = 0.977;
    const float hdrMax = 8.0;
    const float midIn = 0.18;
    const float midOut = 0.267;
    
    float b = (-pow(midIn, a) + pow(hdrMax, a) * midOut) / 
              ((pow(hdrMax, a * d) - pow(midIn, a * d)) * midOut);
    float c = (pow(hdrMax, a * d) * pow(midIn, a) - pow(hdrMax, a) * pow(midIn, a * d) * midOut) /
              ((pow(hdrMax, a * d) - pow(midIn, a * d)) * midOut);
    
    return pow(color, a) / (pow(color, a * d) * b + c);
}

float3 Uchimura(float3 color) {
    const float P = 1.0;   // Max brightness
    const float a = 1.0;   // Contrast
    const float m = 0.22;  // Linear section start
    const float l = 0.4;   // Linear section length
    const float c = 1.33;  // Black tightness
    const float b = 0.0;   // Pedestal
    
    float l0 = ((P - m) * l) / a;
    float S0 = m + l0;
    float S1 = m + a * l0;
    float C2 = (a * P) / (P - S1);
    float CP = -C2 / P;
    
    float3 w0 = 1.0 - smoothstep(0.0, m, color);
    float3 w2 = step(m + l0, color);
    float3 w1 = 1.0 - w0 - w2;
    
    float3 T = m * pow(color / m, c) + b;
    float3 S = P - (P - S1) * exp(CP * (color - S0));
    float3 L = m + a * (color - m);
    
    return T * w0 + L * w1 + S * w2;
}

float3 KhronosPBR(float3 color) {
    const float startCompression = 0.8 - 0.04;
    const float desaturation = 0.15;
    
    float x = min(color.r, min(color.g, color.b));
    float offset = x < 0.08 ? x - 6.25 * x * x : 0.04;
    color -= offset;
    
    float peak = max(color.r, max(color.g, color.b));
    if (peak < startCompression) return color;
    
    float d = 1.0 - startCompression;
    float newPeak = 1.0 - d * d / (peak + d - startCompression);
    color *= newPeak / peak;
    
    float g = 1.0 - 1.0 / (desaturation * (peak - newPeak) + 1.0);
    return lerp(color, newPeak.xxx, g);
}

float3 QuantaAdaptive(float3 color, float exposure, float contrast) {
    // Proprietary Quanta Adaptive™ tonemapper
    float luminance = dot(color, float3(0.2126, 0.7152, 0.0722));
    
    // Dynamic parameter selection based on luminance
    float adaptiveContrast = luminance < 0.1 ? 1.2 * contrast : 
                             luminance > 0.9 ? 0.8 * contrast : contrast;
    float satBoost = luminance < 0.5 ? 1.1 : 0.95;
    
    // Modified ACES with adaptive parameters
    const float a = 2.51 * adaptiveContrast;
    const float b = 0.03;
    const float c = 2.43;
    const float d = 0.59;
    const float e = 0.14;
    
    float3 tonemapped = saturate((color * (a * color + b)) / (color * (c * color + d) + e));
    
    // Preserve saturation in shadows
    float gray = dot(tonemapped, float3(0.2126, 0.7152, 0.0722));
    return saturate(gray + (tonemapped - gray) * satBoost);
}

float3 TonyMcMapface(float3 color) {
    float luma = dot(color, float3(0.2126, 0.7152, 0.0722));
    float peak = max(color.r, max(color.g, color.b));
    float scale = peak > 1.0 ? 1.0 / peak : 1.0;
    float compressed = saturate(luma);
    compressed = compressed * compressed * (3.0 - 2.0 * compressed);
    return saturate(color * scale * (1.0 + compressed * 0.2));
}

// ─── MAIN SHADER ──────────────────────────────────────────────────────────────

float3 ApplyTonemap(float3 color) {
    // Apply exposure
    color *= exp2(Exposure);
    
    // Apply shadows/highlights
    float luma = dot(color, float3(0.2126, 0.7152, 0.0722));
    float shadowMask = 1.0 - smoothstep(0.0, 0.5, luma);
    float highlightMask = smoothstep(0.5, 1.0, luma);
    
    color *= 1.0 + Shadows * shadowMask;
    color *= 1.0 - Highlights * highlightMask * 0.5;
    
    // Select tonemapper
    switch (TonemapOperator) {
        case 0:  break; // Linear
        case 1:  color = Reinhard(color); break;
        case 2:  color = ReinhardExtended(color, WhitePoint); break;
        case 3:  color = ACES(color); break;
        case 4:  color = ACESFitted(color); break;
        case 5:  color = AgX(color); break;
        case 6:  color = Filmic(color); break;
        case 7:  color = Uncharted2(color); break;
        case 8:  color = Lottes(color); break;
        case 9:  color = Uchimura(color); break;
        case 10: color = KhronosPBR(color); break;
        case 11: color = QuantaAdaptive(color, Exposure, Contrast); break;
        case 12: color = TonyMcMapface(color); break;
    }
    
    // Apply contrast
    float gray = dot(color, float3(0.2126, 0.7152, 0.0722));
    color = lerp(gray.xxx, color, Contrast);
    
    // Apply saturation
    color = lerp(gray.xxx, color, Saturation);
    
    return saturate(color);
}

float4 PS_TITANTonemap(float4 pos : SV_Position, float2 texcoord : TEXCOORD) : SV_Target {
    float3 color = tex2D(ReShade::BackBuffer, texcoord).rgb;
    color = ApplyTonemap(color);
    return float4(color, 1.0);
}

technique TITANTonemap <
    ui_label = "TITAN Tonemap";
    ui_tooltip = "Quanta TITAN™ Tonemapper with 13 operators";
> {
    pass {
        VertexShader = PostProcessVS;
        PixelShader = PS_TITANTonemap;
    }
}
"#;

// ═══════════════════════════════════════════════════════════════════════════════
// EFFECT 2: Spectrum Grading
// ═══════════════════════════════════════════════════════════════════════════════

pub const TITAN_COLOR_GRADING_FX: &str = r#"
/*═══════════════════════════════════════════════════════════════════════════════
 * TITAN™ Color Grading v2.0
 * Part of Quanta Prism
 * Copyright © 2024-2025 Zain Dana Quanta
 *═══════════════════════════════════════════════════════════════════════════════*/

#include "ReShade.fxh"

// ─── LIFT GAMMA GAIN ──────────────────────────────────────────────────────────

uniform float3 Lift <
    ui_type = "color";
    ui_label = "Lift (Shadows)";
> = float3(0.0, 0.0, 0.0);

uniform float3 Gamma <
    ui_type = "color";
    ui_label = "Gamma (Midtones)";
> = float3(1.0, 1.0, 1.0);

uniform float3 Gain <
    ui_type = "color";
    ui_label = "Gain (Highlights)";
> = float3(1.0, 1.0, 1.0);

// ─── COLOR WHEELS ─────────────────────────────────────────────────────────────

uniform float3 ShadowTint <
    ui_type = "color";
    ui_label = "Shadow Tint";
> = float3(0.5, 0.5, 0.5);

uniform float3 MidtoneTint <
    ui_type = "color";
    ui_label = "Midtone Tint";
> = float3(0.5, 0.5, 0.5);

uniform float3 HighlightTint <
    ui_type = "color";
    ui_label = "Highlight Tint";
> = float3(0.5, 0.5, 0.5);

uniform float TintStrength <
    ui_type = "slider";
    ui_label = "Tint Strength";
    ui_min = 0.0; ui_max = 1.0;
> = 0.2;

// ─── ASC CDL ──────────────────────────────────────────────────────────────────

uniform float3 Slope <
    ui_type = "drag";
    ui_label = "Slope";
    ui_min = 0.0; ui_max = 2.0;
> = float3(1.0, 1.0, 1.0);

uniform float3 Offset <
    ui_type = "drag";
    ui_label = "Offset";
    ui_min = -0.5; ui_max = 0.5;
> = float3(0.0, 0.0, 0.0);

uniform float3 Power <
    ui_type = "drag";
    ui_label = "Power";
    ui_min = 0.5; ui_max = 2.0;
> = float3(1.0, 1.0, 1.0);

uniform float CDLSaturation <
    ui_type = "slider";
    ui_label = "CDL Saturation";
    ui_min = 0.0; ui_max = 2.0;
> = 1.0;

// ─── WHITE BALANCE ────────────────────────────────────────────────────────────

uniform float Temperature <
    ui_type = "slider";
    ui_label = "Temperature";
    ui_min = -1.0; ui_max = 1.0;
    ui_tooltip = "Negative = cooler, Positive = warmer";
> = 0.0;

uniform float Tint <
    ui_type = "slider";
    ui_label = "Tint";
    ui_min = -1.0; ui_max = 1.0;
    ui_tooltip = "Negative = green, Positive = magenta";
> = 0.0;

// ─── FUNCTIONS ────────────────────────────────────────────────────────────────

float3 ApplyLiftGammaGain(float3 color) {
    // Lift
    color = color + Lift * (1.0 - color);
    
    // Gamma
    color = pow(max(color, 0.0), 1.0 / max(Gamma, 0.001));
    
    // Gain
    color = color * Gain;
    
    return color;
}

float3 ApplyCDL(float3 color) {
    // Slope, Offset, Power
    color = pow(max(color * Slope + Offset, 0.0), Power);
    
    // Saturation
    float luma = dot(color, float3(0.2126, 0.7152, 0.0722));
    color = luma + (color - luma) * CDLSaturation;
    
    return color;
}

float3 ApplyColorWheels(float3 color) {
    float luma = dot(color, float3(0.2126, 0.7152, 0.0722));
    
    // Shadow/Midtone/Highlight weights
    float shadowWeight = 1.0 - smoothstep(0.0, 0.33, luma);
    float highlightWeight = smoothstep(0.66, 1.0, luma);
    float midtoneWeight = 1.0 - shadowWeight - highlightWeight;
    
    // Apply tints
    float3 tint = (ShadowTint - 0.5) * shadowWeight +
                  (MidtoneTint - 0.5) * midtoneWeight +
                  (HighlightTint - 0.5) * highlightWeight;
    
    return color + tint * TintStrength;
}

float3 ApplyWhiteBalance(float3 color) {
    float tempOffset = Temperature * 0.1;
    float tintOffset = Tint * 0.05;
    
    color.r += tempOffset;
    color.g -= tempOffset * 0.5 + tintOffset;
    color.b -= tempOffset - tintOffset;
    
    return color;
}

// ─── MAIN SHADER ──────────────────────────────────────────────────────────────

float4 PS_TITANColorGrade(float4 pos : SV_Position, float2 texcoord : TEXCOORD) : SV_Target {
    float3 color = tex2D(ReShade::BackBuffer, texcoord).rgb;
    
    color = ApplyWhiteBalance(color);
    color = ApplyLiftGammaGain(color);
    color = ApplyCDL(color);
    color = ApplyColorWheels(color);
    
    return float4(saturate(color), 1.0);
}

technique TITANColorGrade <
    ui_label = "Spectrum Grade";
    ui_tooltip = "Professional color grading with LGG, CDL, and color wheels";
> {
    pass {
        VertexShader = PostProcessVS;
        PixelShader = PS_TITANColorGrade;
    }
}
"#;

// ═══════════════════════════════════════════════════════════════════════════════
// EFFECT 3: Quanta SSAO
// ═══════════════════════════════════════════════════════════════════════════════

pub const HARPER_SSAO_FX: &str = r#"
/*═══════════════════════════════════════════════════════════════════════════════
 * Quanta™ SSAO v1.5
 * Screen Space Ambient Occlusion
 * Part of Quanta Prism
 * Copyright © 2024-2025 Zain Dana Quanta
 *═══════════════════════════════════════════════════════════════════════════════*/

#include "ReShade.fxh"

uniform float AORadius <
    ui_type = "slider";
    ui_label = "AO Radius";
    ui_min = 0.1; ui_max = 5.0;
> = 1.0;

uniform float AOIntensity <
    ui_type = "slider";
    ui_label = "AO Intensity";
    ui_min = 0.0; ui_max = 2.0;
> = 1.0;

uniform int AOSamples <
    ui_type = "slider";
    ui_label = "Sample Count";
    ui_min = 4; ui_max = 64;
> = 16;

uniform float AOBias <
    ui_type = "slider";
    ui_label = "Depth Bias";
    ui_min = 0.0; ui_max = 0.5;
> = 0.025;

uniform float AOFalloff <
    ui_type = "slider";
    ui_label = "Distance Falloff";
    ui_min = 0.1; ui_max = 10.0;
> = 2.0;

uniform bool AODebug <
    ui_label = "Debug View";
> = false;

texture2D AOTex { Width = BUFFER_WIDTH; Height = BUFFER_HEIGHT; Format = R8; };
sampler2D AOSampler { Texture = AOTex; };

// Poisson disk samples
static const float2 poissonDisk[64] = {
    float2(-0.613392, 0.617481), float2(0.170019, -0.040254),
    float2(-0.299417, 0.791925), float2(0.645680, 0.493210),
    float2(-0.651784, 0.717887), float2(0.421003, 0.027070),
    float2(-0.817194, -0.271096), float2(-0.705374, -0.668203),
    float2(0.977050, -0.108615), float2(0.063326, 0.142369),
    float2(0.203528, 0.214331), float2(-0.667531, 0.326090),
    float2(-0.098422, -0.295755), float2(-0.885922, 0.215369),
    float2(0.566637, 0.605213), float2(0.039766, -0.396100),
    // ... more samples
};

float GetLinearDepth(float2 texcoord) {
    return ReShade::GetLinearizedDepth(texcoord);
}

float3 GetNormalFromDepth(float2 texcoord) {
    float2 offset = ReShade::PixelSize;
    
    float depthC = GetLinearDepth(texcoord);
    float depthL = GetLinearDepth(texcoord - float2(offset.x, 0));
    float depthR = GetLinearDepth(texcoord + float2(offset.x, 0));
    float depthU = GetLinearDepth(texcoord - float2(0, offset.y));
    float depthD = GetLinearDepth(texcoord + float2(0, offset.y));
    
    float3 normal;
    normal.x = depthL - depthR;
    normal.y = depthU - depthD;
    normal.z = 2.0 * offset.x;
    
    return normalize(normal);
}

float ComputeAO(float2 texcoord) {
    float depth = GetLinearDepth(texcoord);
    float3 normal = GetNormalFromDepth(texcoord);
    
    float occlusion = 0.0;
    float radius = AORadius * 0.01 / depth;
    
    for (int i = 0; i < AOSamples; i++) {
        float2 sampleOffset = poissonDisk[i % 64] * radius;
        float2 sampleCoord = texcoord + sampleOffset;
        
        float sampleDepth = GetLinearDepth(sampleCoord);
        float depthDiff = depth - sampleDepth;
        
        float rangeCheck = smoothstep(0.0, 1.0, AORadius / abs(depthDiff * AOFalloff));
        occlusion += step(AOBias, depthDiff) * rangeCheck;
    }
    
    occlusion = 1.0 - (occlusion / AOSamples);
    return pow(occlusion, AOIntensity);
}

float4 PS_SSAO(float4 pos : SV_Position, float2 texcoord : TEXCOORD) : SV_Target {
    float ao = ComputeAO(texcoord);
    return float4(ao, ao, ao, 1.0);
}

float4 PS_Combine(float4 pos : SV_Position, float2 texcoord : TEXCOORD) : SV_Target {
    float3 color = tex2D(ReShade::BackBuffer, texcoord).rgb;
    float ao = tex2D(AOSampler, texcoord).r;
    
    if (AODebug) {
        return float4(ao.xxx, 1.0);
    }
    
    return float4(color * ao, 1.0);
}

technique QuantaSSAO <
    ui_label = "Quanta SSAO";
    ui_tooltip = "High-quality screen space ambient occlusion";
> {
    pass AO {
        VertexShader = PostProcessVS;
        PixelShader = PS_SSAO;
        RenderTarget = AOTex;
    }
    pass Combine {
        VertexShader = PostProcessVS;
        PixelShader = PS_Combine;
    }
}
"#;

// ═══════════════════════════════════════════════════════════════════════════════
// EFFECT 4: Quanta Bloom
// ═══════════════════════════════════════════════════════════════════════════════

pub const HARPER_BLOOM_FX: &str = r#"
/*═══════════════════════════════════════════════════════════════════════════════
 * Quanta™ Bloom v2.0
 * Physically-Based Bloom Effect
 * Part of Quanta Prism
 * Copyright © 2024-2025 Zain Dana Quanta
 *═══════════════════════════════════════════════════════════════════════════════*/

#include "ReShade.fxh"

uniform float BloomThreshold <
    ui_type = "slider";
    ui_label = "Threshold";
    ui_min = 0.0; ui_max = 2.0;
> = 0.8;

uniform float BloomIntensity <
    ui_type = "slider";
    ui_label = "Intensity";
    ui_min = 0.0; ui_max = 2.0;
> = 0.5;

uniform float BloomRadius <
    ui_type = "slider";
    ui_label = "Radius";
    ui_min = 1.0; ui_max = 10.0;
> = 4.0;

uniform float3 BloomTint <
    ui_type = "color";
    ui_label = "Bloom Tint";
> = float3(1.0, 1.0, 1.0);

uniform bool LensDirt <
    ui_label = "Lens Dirt";
> = false;

uniform float LensDirtIntensity <
    ui_type = "slider";
    ui_label = "Dirt Intensity";
    ui_min = 0.0; ui_max = 2.0;
> = 0.5;

// Bloom textures at multiple resolutions
texture2D BloomTex1 { Width = BUFFER_WIDTH / 2; Height = BUFFER_HEIGHT / 2; Format = RGBA16F; };
texture2D BloomTex2 { Width = BUFFER_WIDTH / 4; Height = BUFFER_HEIGHT / 4; Format = RGBA16F; };
texture2D BloomTex3 { Width = BUFFER_WIDTH / 8; Height = BUFFER_HEIGHT / 8; Format = RGBA16F; };
texture2D BloomTex4 { Width = BUFFER_WIDTH / 16; Height = BUFFER_HEIGHT / 16; Format = RGBA16F; };

sampler2D BloomSamp1 { Texture = BloomTex1; };
sampler2D BloomSamp2 { Texture = BloomTex2; };
sampler2D BloomSamp3 { Texture = BloomTex3; };
sampler2D BloomSamp4 { Texture = BloomTex4; };

float3 SoftThreshold(float3 color, float threshold) {
    float brightness = max(color.r, max(color.g, color.b));
    float soft = brightness - threshold + 0.5;
    soft = clamp(soft, 0.0, 1.0);
    soft = soft * soft;
    return color * max(soft, brightness - threshold) / max(brightness, 0.00001);
}

float4 PS_Threshold(float4 pos : SV_Position, float2 texcoord : TEXCOORD) : SV_Target {
    float3 color = tex2D(ReShade::BackBuffer, texcoord).rgb;
    float3 bloom = SoftThreshold(color, BloomThreshold);
    return float4(bloom, 1.0);
}

// Gaussian blur passes would go here...

float4 PS_Combine(float4 pos : SV_Position, float2 texcoord : TEXCOORD) : SV_Target {
    float3 color = tex2D(ReShade::BackBuffer, texcoord).rgb;
    
    float3 bloom = tex2D(BloomSamp1, texcoord).rgb * 0.5 +
                   tex2D(BloomSamp2, texcoord).rgb * 0.3 +
                   tex2D(BloomSamp3, texcoord).rgb * 0.15 +
                   tex2D(BloomSamp4, texcoord).rgb * 0.05;
    
    bloom *= BloomTint * BloomIntensity;
    
    // Add lens dirt if enabled
    if (LensDirt) {
        float dirtMask = length(texcoord - 0.5) * 2.0;
        dirtMask = 1.0 - smoothstep(0.3, 1.0, dirtMask);
        bloom += bloom * dirtMask * LensDirtIntensity;
    }
    
    return float4(color + bloom, 1.0);
}

technique QuantaBloom <
    ui_label = "Quanta Bloom";
    ui_tooltip = "Physically-based bloom with lens dirt";
> {
    pass Threshold {
        VertexShader = PostProcessVS;
        PixelShader = PS_Threshold;
        RenderTarget = BloomTex1;
    }
    // Additional blur passes...
    pass Combine {
        VertexShader = PostProcessVS;
        PixelShader = PS_Combine;
    }
}
"#;

// ═══════════════════════════════════════════════════════════════════════════════
