/// Get effect count by category
pub fn count_effects() -> HashMap<EffectCategory, usize> {
    let effects = get_all_effects();
    let mut counts = HashMap::new();
    
    for effect in effects {
        *counts.entry(effect.category).or_insert(0) += 1;
    }
    
    counts
}
