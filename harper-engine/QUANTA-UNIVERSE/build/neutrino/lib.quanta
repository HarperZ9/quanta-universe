// TENSOR OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// 4D Tensor for neural network operations [N, C, H, W]
#[derive(Clone)]
pub struct Tensor4D {
    data: Vec<f32>,
    shape: [usize; 4],
}

impl Tensor4D {
    pub fn new(batch: usize, channels: usize, height: usize, width: usize) -> Self {
        Tensor4D {
            data: vec![0.0; batch * channels * height * width],
            shape: [batch, channels, height, width],
        }
    }
    
    pub fn from_image(pixels: &[f32], width: usize, height: usize, channels: usize) -> Self {
        let mut tensor = Tensor4D::new(1, channels, height, width);
        tensor.data = pixels.to_vec();
        tensor
    }
    
    fn index(&self, n: usize, c: usize, h: usize, w: usize) -> usize {
        n * self.shape[1] * self.shape[2] * self.shape[3] +
        c * self.shape[2] * self.shape[3] +
        h * self.shape[3] + w
    }
    
    pub fn get(&self, n: usize, c: usize, h: usize, w: usize) -> f32 {
        self.data[self.index(n, c, h, w)]
    }
    
    pub fn set(&mut self, n: usize, c: usize, h: usize, w: usize, value: f32) {
        let idx = self.index(n, c, h, w);
        self.data[idx] = value;
    }
    
    pub fn shape(&self) -> [usize; 4] { self.shape }
    
    /// Apply ReLU activation
    pub fn relu(&self) -> Tensor4D {
        let data: Vec<f32> = self.data.iter()
            .map(|&x| if x > 0.0 { x } else { 0.0 })
            .collect();
        Tensor4D { data, shape: self.shape }
    }
    
    /// Apply Leaky ReLU
    pub fn leaky_relu(&self, alpha: f32) -> Tensor4D {
        let data: Vec<f32> = self.data.iter()
            .map(|&x| if x > 0.0 { x } else { x * alpha })
            .collect();
        Tensor4D { data, shape: self.shape }
    }
    
    /// Apply sigmoid activation
    pub fn sigmoid(&self) -> Tensor4D {
        let data: Vec<f32> = self.data.iter()
            .map(|&x| 1.0 / (1.0 + exp(-x)))
            .collect();
        Tensor4D { data, shape: self.shape }
    }
    
    /// Element-wise addition
    pub fn add(&self, other: &Tensor4D) -> Tensor4D {
        let data: Vec<f32> = self.data.iter()
            .zip(&other.data)
            .map(|(a, b)| a + b)
            .collect();
        Tensor4D { data, shape: self.shape }
    }
    
    /// Element-wise multiplication
    pub fn mul(&self, other: &Tensor4D) -> Tensor4D {
        let data: Vec<f32> = self.data.iter()
            .zip(&other.data)
            .map(|(a, b)| a * b)
            .collect();
        Tensor4D { data, shape: self.shape }
    }
    
    /// Scale by constant
    pub fn scale(&self, s: f32) -> Tensor4D {
        let data: Vec<f32> = self.data.iter().map(|&x| x * s).collect();
        Tensor4D { data, shape: self.shape }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL NETWORK LAYERS
// ═══════════════════════════════════════════════════════════════════════════════

/// 2D Convolution layer
pub struct Conv2D {
    weights: Tensor4D,  // [out_channels, in_channels, kH, kW]
    bias: Vec<f32>,
    stride: usize,
    padding: usize,
}

impl Conv2D {
    pub fn new(in_channels: usize, out_channels: usize, kernel_size: usize, stride: usize, padding: usize) -> Self {
        let mut rng = std::random::Random::new();
        let fan_in = in_channels * kernel_size * kernel_size;
        let std = sqrt(2.0 / fan_in as f32);
        
        let weights_data: Vec<f32> = (0..out_channels * in_channels * kernel_size * kernel_size)
            .map(|_| rng.gaussian(0.0, std as f64) as f32)
            .collect();
        
        Conv2D {
            weights: Tensor4D {
                data: weights_data,
                shape: [out_channels, in_channels, kernel_size, kernel_size],
            },
            bias: vec![0.0; out_channels],
            stride,
            padding,
        }
    }
    
    pub fn forward(&self, input: &Tensor4D) -> Tensor4D {
        let [n, in_c, in_h, in_w] = input.shape;
        let [out_c, _, k_h, k_w] = self.weights.shape;
        
        let out_h = (in_h + 2 * self.padding - k_h) / self.stride + 1;
        let out_w = (in_w + 2 * self.padding - k_w) / self.stride + 1;
        
        let mut output = Tensor4D::new(n, out_c, out_h, out_w);
        
        for batch in 0..n {
            for oc in 0..out_c {
                for oh in 0..out_h {
                    for ow in 0..out_w {
                        let mut sum = self.bias[oc];
                        
                        for ic in 0..in_c {
                            for kh in 0..k_h {
                                for kw in 0..k_w {
                                    let ih = oh * self.stride + kh;
                                    let iw = ow * self.stride + kw;
                                    
                                    let ih = ih as i32 - self.padding as i32;
                                    let iw = iw as i32 - self.padding as i32;
                                    
                                    if ih >= 0 && ih < in_h as i32 && iw >= 0 && iw < in_w as i32 {
                                        let pixel = input.get(batch, ic, ih as usize, iw as usize);
                                        let weight = self.weights.get(oc, ic, kh, kw);
                                        sum += pixel * weight;
                                    }
                                }
                            }
                        }
                        
                        output.set(batch, oc, oh, ow, sum);
                    }
                }
            }
        }
        
        output
    }
}

/// Pixel Shuffle for upsampling (Sub-pixel convolution)
pub struct PixelShuffle {
    upscale_factor: usize,
}

impl PixelShuffle {
    pub fn new(upscale_factor: usize) -> Self {
        PixelShuffle { upscale_factor }
    }
    
    pub fn forward(&self, input: &Tensor4D) -> Tensor4D {
        let [n, c, h, w] = input.shape;
        let r = self.upscale_factor;
        
        let new_c = c / (r * r);
        let new_h = h * r;
        let new_w = w * r;
        
        let mut output = Tensor4D::new(n, new_c, new_h, new_w);
        
        for batch in 0..n {
            for oc in 0..new_c {
                for oh in 0..new_h {
                    for ow in 0..new_w {
                        let ih = oh / r;
                        let iw = ow / r;
                        let ic = oc * r * r + (oh % r) * r + (ow % r);
                        
                        let value = input.get(batch, ic, ih, iw);
                        output.set(batch, oc, oh, ow, value);
                    }
                }
            }
        }
        
        output
    }
}

/// Batch Normalization
pub struct BatchNorm2D {
    gamma: Vec<f32>,
    beta: Vec<f32>,
    running_mean: Vec<f32>,
    running_var: Vec<f32>,
    epsilon: f32,
}

impl BatchNorm2D {
    pub fn new(channels: usize) -> Self {
        BatchNorm2D {
            gamma: vec![1.0; channels],
            beta: vec![0.0; channels],
            running_mean: vec![0.0; channels],
            running_var: vec![1.0; channels],
            epsilon: 1e-5,
        }
    }
    
    pub fn forward(&self, input: &Tensor4D) -> Tensor4D {
        let [n, c, h, w] = input.shape;
        let mut output = Tensor4D::new(n, c, h, w);
        
        for batch in 0..n {
            for ch in 0..c {
                let mean = self.running_mean[ch];
                let var = self.running_var[ch];
                let gamma = self.gamma[ch];
                let beta = self.beta[ch];
                let std = sqrt(var + self.epsilon);
                
                for y in 0..h {
                    for x in 0..w {
                        let val = input.get(batch, ch, y, x);
                        let normalized = (val - mean) / std;
                        let scaled = gamma * normalized + beta;
                        output.set(batch, ch, y, x, scaled);
                    }
                }
            }
        }
        
        output
    }
}

