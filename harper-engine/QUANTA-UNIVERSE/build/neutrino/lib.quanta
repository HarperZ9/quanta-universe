// NEURAL STYLE TRANSFER
// ═══════════════════════════════════════════════════════════════════════════════

/// Fast Neural Style Transfer
pub struct StyleTransfer {
    encoder: StyleEncoder,
    decoder: StyleDecoder,
    style_features: Option<Vec<Tensor4D>>,
}

struct StyleEncoder {
    conv1: Conv2D,
    conv2: Conv2D,
    conv3: Conv2D,
}

struct StyleDecoder {
    deconv1: Conv2D,
    deconv2: Conv2D,
    deconv3: Conv2D,
}

impl StyleTransfer {
    pub fn new() -> Self {
        StyleTransfer {
            encoder: StyleEncoder {
                conv1: Conv2D::new(3, 32, 9, 1, 4),
                conv2: Conv2D::new(32, 64, 3, 2, 1),
                conv3: Conv2D::new(64, 128, 3, 2, 1),
            },
            decoder: StyleDecoder {
                deconv1: Conv2D::new(128, 64, 3, 1, 1),
                deconv2: Conv2D::new(64, 32, 3, 1, 1),
                deconv3: Conv2D::new(32, 3, 9, 1, 4),
            },
            style_features: None,
        }
    }
    
    /// Set style image
    pub fn set_style(&mut self, style_image: &Tensor4D) {
        // Extract style features (Gram matrices)
        let features = self.extract_features(style_image);
        self.style_features = Some(features);
    }
    
    fn extract_features(&self, input: &Tensor4D) -> Vec<Tensor4D> {
        let f1 = self.encoder.conv1.forward(input).relu();
        let f2 = self.encoder.conv2.forward(&f1).relu();
        let f3 = self.encoder.conv3.forward(&f2).relu();
        vec![f1, f2, f3]
    }
    
    /// Apply style to content image
    pub fn transfer(&self, content: &Tensor4D, strength: f32) -> Tensor4D {
        // Encode
        let x = self.encoder.conv1.forward(content).relu();
        let x = self.encoder.conv2.forward(&x).relu();
        let x = self.encoder.conv3.forward(&x).relu();
        
        // Apply style (simplified - would use AdaIN or similar)
        let styled = if let Some(style_feats) = &self.style_features {
            let style = &style_feats[2];
            self.adaptive_instance_norm(&x, style, strength)
        } else {
            x
        };
        
        // Decode
        let x = self.decoder.deconv1.forward(&styled).relu();
        let x = self.upsample_2x(&x);
        let x = self.decoder.deconv2.forward(&x).relu();
        let x = self.upsample_2x(&x);
        self.decoder.deconv3.forward(&x).sigmoid()
    }
    
    fn adaptive_instance_norm(&self, content: &Tensor4D, style: &Tensor4D, strength: f32) -> Tensor4D {
        let [n, c, h, w] = content.shape;
        let mut output = Tensor4D::new(n, c, h, w);
        
        for batch in 0..n {
            for ch in 0..c {
                // Compute content statistics
                let mut content_mean = 0.0;
                let mut content_var = 0.0;
                let count = (h * w) as f32;
                
                for y in 0..h {
                    for x in 0..w {
                        content_mean += content.get(batch, ch, y, x);
                    }
                }
                content_mean /= count;
                
                for y in 0..h {
                    for x in 0..w {
                        let diff = content.get(batch, ch, y, x) - content_mean;
                        content_var += diff * diff;
                    }
                }
                content_var = sqrt(content_var / count + 1e-5);
                
                // Compute style statistics
                let [_, _, sh, sw] = style.shape;
                let mut style_mean = 0.0;
                let mut style_var = 0.0;
                let style_count = (sh * sw) as f32;
                
                for y in 0..sh {
                    for x in 0..sw {
                        style_mean += style.get(batch.min(style.shape[0] - 1), ch.min(style.shape[1] - 1), y, x);
                    }
                }
                style_mean /= style_count;
                
                for y in 0..sh {
                    for x in 0..sw {
                        let diff = style.get(batch.min(style.shape[0] - 1), ch.min(style.shape[1] - 1), y, x) - style_mean;
                        style_var += diff * diff;
                    }
                }
                style_var = sqrt(style_var / style_count + 1e-5);
                
                // Apply AdaIN
                for y in 0..h {
                    for x in 0..w {
                        let normalized = (content.get(batch, ch, y, x) - content_mean) / content_var;
                        let styled = normalized * style_var + style_mean;
                        let blended = content.get(batch, ch, y, x) * (1.0 - strength) + styled * strength;
                        output.set(batch, ch, y, x, blended);
                    }
                }
            }
        }
        
        output
    }
    
    fn upsample_2x(&self, input: &Tensor4D) -> Tensor4D {
        let [n, c, h, w] = input.shape;
        let mut output = Tensor4D::new(n, c, h * 2, w * 2);
        
        for batch in 0..n {
            for ch in 0..c {
                for y in 0..h {
                    for x in 0..w {
                        let val = input.get(batch, ch, y, x);
                        output.set(batch, ch, y * 2, x * 2, val);
                        output.set(batch, ch, y * 2 + 1, x * 2, val);
                        output.set(batch, ch, y * 2, x * 2 + 1, val);
                        output.set(batch, ch, y * 2 + 1, x * 2 + 1, val);
                    }
                }
            }
        }
        
        output
    }
}

