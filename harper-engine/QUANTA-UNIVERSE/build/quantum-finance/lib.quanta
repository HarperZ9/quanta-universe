// FINANCIAL SCHRÖDINGER EQUATION™
// ═══════════════════════════════════════════════════════════════════════════════

/// Quantum-inspired price prediction using wave functions
pub struct FinancialSchrodinger {
    /// Wave function amplitude (probability density)
    psi: Vec<Complex>,
    /// Price grid
    price_grid: Vec<f64>,
    /// Time step
    dt: f64,
    /// Volatility (analogous to ℏ/m)
    volatility: f64,
    /// Potential function (market forces)
    potential: Vec<f64>,
}

#[derive(Debug, Clone, Copy)]
pub struct Complex {
    pub re: f64,
    pub im: f64,
}

impl Complex {
    pub fn new(re: f64, im: f64) -> Self {
        Complex { re, im }
    }
    
    pub fn from_polar(r: f64, theta: f64) -> Self {
        Complex::new(r * cos(theta), r * sin(theta))
    }
    
    pub fn abs(&self) -> f64 {
        sqrt(self.re * self.re + self.im * self.im)
    }
    
    pub fn abs_sq(&self) -> f64 {
        self.re * self.re + self.im * self.im
    }
    
    pub fn conj(&self) -> Self {
        Complex::new(self.re, -self.im)
    }
    
    pub fn add(&self, other: &Complex) -> Self {
        Complex::new(self.re + other.re, self.im + other.im)
    }
    
    pub fn mul(&self, other: &Complex) -> Self {
        Complex::new(
            self.re * other.re - self.im * other.im,
            self.re * other.im + self.im * other.re,
        )
    }
    
    pub fn scale(&self, s: f64) -> Self {
        Complex::new(self.re * s, self.im * s)
    }
}

impl FinancialSchrodinger {
    pub fn new(center_price: f64, volatility: f64, grid_points: usize) -> Self {
        let price_range = center_price * 0.5; // ±50% price range
        let price_grid: Vec<f64> = (0..grid_points)
            .map(|i| center_price - price_range + 2.0 * price_range * (i as f64) / (grid_points as f64 - 1.0))
            .collect();
        
        // Initialize wave function as Gaussian packet centered at current price
        let sigma = volatility * center_price * 0.1;
        let psi: Vec<Complex> = price_grid.iter()
            .map(|&p| {
                let x = p - center_price;
                let amp = exp(-x * x / (4.0 * sigma * sigma));
                Complex::new(amp, 0.0)
            })
            .collect();
        
        // Normalize
        let norm: f64 = psi.iter().map(|c| c.abs_sq()).sum();
        let psi: Vec<Complex> = psi.iter().map(|c| c.scale(1.0 / sqrt(norm))).collect();
        
        // Initialize potential (can be modified based on support/resistance)
        let potential = vec![0.0; grid_points];
        
        FinancialSchrodinger {
            psi,
            price_grid,
            dt: 0.01,
            volatility,
            potential,
        }
    }
    
    /// Set potential barrier (resistance/support level)
    pub fn set_barrier(&mut self, price: f64, strength: f64, width: f64) {
        for (i, &p) in self.price_grid.iter().enumerate() {
            let dist = (p - price).abs();
            if dist < width {
                self.potential[i] += strength * (1.0 - dist / width);
            }
        }
    }
    
    /// Evolve wave function using split-operator method
    pub fn evolve(&mut self, steps: usize) {
        let n = self.psi.len();
        let dp = self.price_grid[1] - self.price_grid[0];
        
        for _ in 0..steps {
            // Apply potential (V) evolution: e^(-iVdt/ℏ)
            for i in 0..n {
                let phase = -self.potential[i] * self.dt / self.volatility;
                let rotation = Complex::from_polar(1.0, phase);
                self.psi[i] = self.psi[i].mul(&rotation);
            }
            
            // Apply kinetic (T) evolution via FFT
            // Simplified: use finite difference approximation
            let mut new_psi = self.psi.clone();
            for i in 1..n-1 {
                let d2psi = self.psi[i+1].add(&self.psi[i-1].scale(-2.0).add(&self.psi[i]));
                let kinetic = d2psi.scale(self.volatility * self.dt / (dp * dp));
                new_psi[i] = self.psi[i].add(&Complex::new(-kinetic.im, kinetic.re));
            }
            self.psi = new_psi;
            
            // Renormalize
            let norm: f64 = self.psi.iter().map(|c| c.abs_sq()).sum();
            if norm > 0.0 {
                for c in &mut self.psi {
                    *c = c.scale(1.0 / sqrt(norm));
                }
            }
        }
    }
    
    /// Get probability distribution of future prices
    pub fn probability_distribution(&self) -> Vec<(f64, f64)> {
        self.price_grid.iter()
            .zip(self.psi.iter())
            .map(|(&p, c)| (p, c.abs_sq()))
            .collect()
    }
    
    /// Expected price
    pub fn expected_price(&self) -> f64 {
        let mut sum = 0.0;
        for (i, c) in self.psi.iter().enumerate() {
            sum += self.price_grid[i] * c.abs_sq();
        }
        sum
    }
    
    /// Price uncertainty (standard deviation)
    pub fn price_uncertainty(&self) -> f64 {
        let mean = self.expected_price();
        let mut var = 0.0;
        for (i, c) in self.psi.iter().enumerate() {
            let diff = self.price_grid[i] - mean;
            var += diff * diff * c.abs_sq();
        }
        sqrt(var)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TECHNICAL INDICATORS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod indicators {
    use super::*;
    
    /// Simple Moving Average
    pub fn sma(data: &[f64], period: usize) -> Vec<f64> {
        if data.len() < period {
            return vec![];
        }
        
        let mut result = Vec::with_capacity(data.len() - period + 1);
        let mut sum: f64 = data[..period].iter().sum();
        result.push(sum / period as f64);
        
        for i in period..data.len() {
            sum += data[i] - data[i - period];
            result.push(sum / period as f64);
        }
        
        result
    }
    
    /// Exponential Moving Average
    pub fn ema(data: &[f64], period: usize) -> Vec<f64> {
        if data.is_empty() {
            return vec![];
        }
        
        let alpha = 2.0 / (period as f64 + 1.0);
        let mut result = Vec::with_capacity(data.len());
        result.push(data[0]);
        
        for i in 1..data.len() {
            let prev = result[i - 1];
            result.push(alpha * data[i] + (1.0 - alpha) * prev);
        }
        
        result
    }
    
    /// Relative Strength Index
    pub fn rsi(data: &[f64], period: usize) -> Vec<f64> {
        if data.len() < period + 1 {
            return vec![];
        }
        
        let mut gains = Vec::new();
        let mut losses = Vec::new();
        
        for i in 1..data.len() {
            let change = data[i] - data[i - 1];
            gains.push(if change > 0.0 { change } else { 0.0 });
            losses.push(if change < 0.0 { -change } else { 0.0 });
        }
        
        let avg_gains = ema(&gains, period);
        let avg_losses = ema(&losses, period);
        
        avg_gains.iter()
            .zip(avg_losses.iter())
            .map(|(&g, &l)| {
                if l == 0.0 {
                    100.0
                } else {
                    100.0 - 100.0 / (1.0 + g / l)
                }
            })
            .collect()
    }
    
    /// Moving Average Convergence Divergence
    pub fn macd(data: &[f64], fast: usize, slow: usize, signal: usize) -> (Vec<f64>, Vec<f64>, Vec<f64>) {
        let fast_ema = ema(data, fast);
        let slow_ema = ema(data, slow);
        
        let macd_line: Vec<f64> = fast_ema.iter()
            .zip(slow_ema.iter())
            .map(|(&f, &s)| f - s)
            .collect();
        
        let signal_line = ema(&macd_line, signal);
        
        let histogram: Vec<f64> = macd_line.iter()
            .zip(signal_line.iter())
            .map(|(&m, &s)| m - s)
            .collect();
        
        (macd_line, signal_line, histogram)
    }
    
    /// Bollinger Bands
    pub fn bollinger_bands(data: &[f64], period: usize, std_dev: f64) -> (Vec<f64>, Vec<f64>, Vec<f64>) {
        let middle = sma(data, period);
        
        let mut upper = Vec::with_capacity(middle.len());
        let mut lower = Vec::with_capacity(middle.len());
        
        for i in 0..middle.len() {
            let start = i;
            let end = i + period;
            let slice = &data[start..end];
            
            let mean = middle[i];
            let variance: f64 = slice.iter().map(|&x| (x - mean).powi(2)).sum::<f64>() / period as f64;
            let std = sqrt(variance);
            
            upper.push(mean + std_dev * std);
            lower.push(mean - std_dev * std);
        }
        
        (upper, middle, lower)
    }
    
    /// Average True Range
    pub fn atr(candles: &[Candle], period: usize) -> Vec<f64> {
        if candles.len() < 2 {
            return vec![];
        }
        
        let mut tr = Vec::with_capacity(candles.len() - 1);
        for i in 1..candles.len() {
            tr.push(candles[i].true_range(candles[i-1].close));
        }
        
        ema(&tr, period)
    }
    
    /// Stochastic Oscillator
    pub fn stochastic(candles: &[Candle], k_period: usize, d_period: usize) -> (Vec<f64>, Vec<f64>) {
        if candles.len() < k_period {
            return (vec![], vec![]);
        }
        
        let mut k_values = Vec::new();
        
        for i in k_period-1..candles.len() {
            let window = &candles[i+1-k_period..=i];
            let highest: f64 = window.iter().map(|c| c.high).fold(f64::NEG_INFINITY, f64::max);
            let lowest: f64 = window.iter().map(|c| c.low).fold(f64::INFINITY, f64::min);
            
            let k = if highest != lowest {
                100.0 * (candles[i].close - lowest) / (highest - lowest)
            } else {
                50.0
            };
            k_values.push(k);
        }
        
        let d_values = sma(&k_values, d_period);
        
        (k_values, d_values)
    }
    
    /// Volume Weighted Average Price
    pub fn vwap(candles: &[Candle]) -> Vec<f64> {
        let mut cum_tp_vol = 0.0;
        let mut cum_vol = 0.0;
        
        candles.iter()
            .map(|c| {
                let tp = c.typical_price();
                cum_tp_vol += tp * c.volume;
                cum_vol += c.volume;
                if cum_vol > 0.0 { cum_tp_vol / cum_vol } else { tp }
            })
            .collect()
    }
}

