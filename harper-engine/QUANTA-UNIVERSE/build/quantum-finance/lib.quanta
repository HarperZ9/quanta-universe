/// Strategy trait - implement for custom strategies
pub trait Strategy {
    fn name(&self) -> &str;
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal>;
}

/// Trading signal
#[derive(Debug, Clone)]
pub struct Signal {
    pub symbol: String,
    pub side: Side,
    pub strength: f64,      // [-1, 1] confidence
    pub target_price: Option<f64>,
    pub stop_loss: Option<f64>,
    pub take_profit: Option<f64>,
    pub timestamp: DateTime,
}

/// Momentum Strategy
pub struct MomentumStrategy {
    pub fast_period: usize,
    pub slow_period: usize,
    pub rsi_period: usize,
    pub rsi_overbought: f64,
    pub rsi_oversold: f64,
}

impl MomentumStrategy {
    pub fn new() -> Self {
        MomentumStrategy {
            fast_period: 12,
            slow_period: 26,
            rsi_period: 14,
            rsi_overbought: 70.0,
            rsi_oversold: 30.0,
        }
    }
}

impl Strategy for MomentumStrategy {
    fn name(&self) -> &str { "Momentum" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.slow_period + 1 {
            return signals;
        }
        
        let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
        let fast_ema = indicators::ema(&closes, self.fast_period);
        let slow_ema = indicators::ema(&closes, self.slow_period);
        let rsi = indicators::rsi(&closes, self.rsi_period);
        
        let last = candles.last().unwrap();
        let fast = *fast_ema.last().unwrap_or(&0.0);
        let slow = *slow_ema.last().unwrap_or(&0.0);
        let rsi_val = *rsi.last().unwrap_or(&50.0);
        
        // Bullish: Fast > Slow and RSI not overbought
        if fast > slow && rsi_val < self.rsi_overbought {
            let strength = (fast - slow) / slow * 10.0; // Normalize
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: strength.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 0.98),
                take_profit: Some(last.close * 1.05),
                timestamp: last.timestamp,
            });
        }
        
        // Bearish: Fast < Slow and RSI not oversold
        if fast < slow && rsi_val > self.rsi_oversold {
            let strength = (slow - fast) / slow * 10.0;
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: strength.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 1.02),
                take_profit: Some(last.close * 0.95),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Mean Reversion Strategy
pub struct MeanReversionStrategy {
    pub period: usize,
    pub std_dev_entry: f64,
    pub std_dev_exit: f64,
}

impl MeanReversionStrategy {
    pub fn new() -> Self {
        MeanReversionStrategy {
            period: 20,
            std_dev_entry: 2.0,
            std_dev_exit: 0.5,
        }
    }
}

impl Strategy for MeanReversionStrategy {
    fn name(&self) -> &str { "Mean Reversion" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.period {
            return signals;
        }
        
        let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
        let (upper, middle, lower) = indicators::bollinger_bands(&closes, self.period, self.std_dev_entry);
        
        let last = candles.last().unwrap();
        let price = last.close;
        let upper_band = *upper.last().unwrap_or(&price);
        let lower_band = *lower.last().unwrap_or(&price);
        let mean = *middle.last().unwrap_or(&price);
        
        // Buy when price touches lower band
        if price <= lower_band {
            let distance = (mean - price) / (mean - lower_band);
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: distance.min(1.0),
                target_price: Some(mean),
                stop_loss: Some(lower_band * 0.98),
                take_profit: Some(mean + (mean - lower_band) * 0.5),
                timestamp: last.timestamp,
            });
        }
        
        // Sell when price touches upper band
        if price >= upper_band {
            let distance = (price - mean) / (upper_band - mean);
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: distance.min(1.0),
                target_price: Some(mean),
                stop_loss: Some(upper_band * 1.02),
                take_profit: Some(mean - (upper_band - mean) * 0.5),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Trend Following Strategy
pub struct TrendFollowingStrategy {
    pub fast_period: usize,
    pub slow_period: usize,
    pub atr_period: usize,
    pub atr_multiplier: f64,
}

impl TrendFollowingStrategy {
    pub fn new() -> Self {
        TrendFollowingStrategy {
            fast_period: 20,
            slow_period: 50,
            atr_period: 14,
            atr_multiplier: 2.0,
        }
    }
}

impl Strategy for TrendFollowingStrategy {
    fn name(&self) -> &str { "Trend Following" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.slow_period {
            return signals;
        }
        
        let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
        let fast_ma = indicators::sma(&closes, self.fast_period);
        let slow_ma = indicators::sma(&closes, self.slow_period);
        let atr = indicators::atr(candles, self.atr_period);
        
        let last = candles.last().unwrap();
        let fast = *fast_ma.last().unwrap_or(&0.0);
        let slow = *slow_ma.last().unwrap_or(&0.0);
        let atr_val = *atr.last().unwrap_or(&0.0);
        
        // Golden cross - buy
        if fast > slow {
            let trend_strength = (fast - slow) / slow * 100.0;
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: (trend_strength / 5.0).min(1.0),
                target_price: None,
                stop_loss: Some(last.close - self.atr_multiplier * atr_val),
                take_profit: Some(last.close + self.atr_multiplier * atr_val * 2.0),
                timestamp: last.timestamp,
            });
        }
        
        // Death cross - sell
        if fast < slow {
            let trend_strength = (slow - fast) / slow * 100.0;
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: (trend_strength / 5.0).min(1.0),
                target_price: None,
                stop_loss: Some(last.close + self.atr_multiplier * atr_val),
                take_profit: Some(last.close - self.atr_multiplier * atr_val * 2.0),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Breakout Strategy
pub struct BreakoutStrategy {
    pub lookback: usize,
    pub volume_threshold: f64,
}

impl BreakoutStrategy {
    pub fn new() -> Self {
        BreakoutStrategy {
            lookback: 20,
            volume_threshold: 1.5,
        }
    }
}

impl Strategy for BreakoutStrategy {
    fn name(&self) -> &str { "Breakout" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut signals = Vec::new();
        if candles.len() < self.lookback {
            return signals;
        }
        
        let window = &candles[candles.len() - self.lookback..];
        let highest: f64 = window.iter().map(|c| c.high).fold(f64::NEG_INFINITY, f64::max);
        let lowest: f64 = window.iter().map(|c| c.low).fold(f64::INFINITY, f64::min);
        let avg_volume: f64 = window.iter().map(|c| c.volume).sum::<f64>() / self.lookback as f64;
        
        let last = candles.last().unwrap();
        
        // Bullish breakout
        if last.close > highest && last.volume > avg_volume * self.volume_threshold {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: ((last.close - highest) / highest * 100.0).min(1.0),
                target_price: Some(highest + (highest - lowest)),
                stop_loss: Some(highest * 0.98),
                take_profit: Some(last.close * 1.10),
                timestamp: last.timestamp,
            });
        }
        
        // Bearish breakout
        if last.close < lowest && last.volume > avg_volume * self.volume_threshold {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: ((lowest - last.close) / lowest * 100.0).min(1.0),
                target_price: Some(lowest - (highest - lowest)),
                stop_loss: Some(lowest * 1.02),
                take_profit: Some(last.close * 0.90),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

/// Ensemble Strategy - combines multiple strategies
pub struct EnsembleStrategy {
    strategies: Vec<Box<dyn Strategy>>,
    weights: Vec<f64>,
}

impl EnsembleStrategy {
    pub fn new() -> Self {
        let strategies: Vec<Box<dyn Strategy>> = vec![
            Box::new(MomentumStrategy::new()),
            Box::new(MeanReversionStrategy::new()),
            Box::new(TrendFollowingStrategy::new()),
            Box::new(BreakoutStrategy::new()),
        ];
        let weights = vec![0.25, 0.25, 0.30, 0.20];
        
        EnsembleStrategy { strategies, weights }
    }
}

impl Strategy for EnsembleStrategy {
    fn name(&self) -> &str { "Ensemble" }
    
    fn generate_signals(&mut self, candles: &[Candle]) -> Vec<Signal> {
        let mut buy_score = 0.0;
        let mut sell_score = 0.0;
        
        for (strategy, &weight) in self.strategies.iter_mut().zip(self.weights.iter()) {
            let signals = strategy.generate_signals(candles);
            for signal in signals {
                match signal.side {
                    Side::Buy => buy_score += signal.strength * weight,
                    Side::Sell => sell_score += signal.strength * weight,
                }
            }
        }
        
        let mut signals = Vec::new();
        let last = candles.last().unwrap();
        
        if buy_score > sell_score && buy_score > 0.3 {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Buy,
                strength: buy_score.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 0.97),
                take_profit: Some(last.close * 1.06),
                timestamp: last.timestamp,
            });
        } else if sell_score > buy_score && sell_score > 0.3 {
            signals.push(Signal {
                symbol: String::new(),
                side: Side::Sell,
                strength: sell_score.min(1.0),
                target_price: None,
                stop_loss: Some(last.close * 1.03),
                take_profit: Some(last.close * 0.94),
                timestamp: last.timestamp,
            });
        }
        
        signals
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// RISK MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod risk {
    use super::*;
    
    /// Risk level classification
    #[derive(Debug, Clone, Copy, PartialEq, Ord, PartialOrd, Eq)]
    pub enum RiskLevel {
        Minimal,
        Low,
        Moderate,
        High,
        Critical,
    }
    
    /// Position sizing methods
    pub enum PositionSizing {
        Fixed(f64),
        PercentOfEquity(f64),
        Kelly(f64, f64),  // win_rate, win_loss_ratio
        VolatilityAdjusted(f64, f64),  // target_risk, atr
    }
    
    /// Calculate position size
    pub fn calculate_position_size(
        equity: f64,
        method: PositionSizing,
        price: f64,
    ) -> f64 {
        let notional = match method {
            PositionSizing::Fixed(amount) => amount,
            PositionSizing::PercentOfEquity(pct) => equity * pct,
            PositionSizing::Kelly(win_rate, ratio) => {
                let kelly = win_rate - (1.0 - win_rate) / ratio;
                equity * kelly.max(0.0).min(0.5) // Cap at 50%
            }
            PositionSizing::VolatilityAdjusted(target_risk, atr) => {
                if atr > 0.0 {
                    equity * target_risk / atr
                } else {
                    equity * 0.02
                }
            }
        };
        
        notional / price
    }
    
    /// Value at Risk (parametric)
    pub fn var_parametric(returns: &[f64], confidence: f64) -> f64 {
        let n = returns.len() as f64;
        let mean: f64 = returns.iter().sum::<f64>() / n;
        let variance: f64 = returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / n;
        let std = sqrt(variance);
        
        // Z-score for confidence level
        let z = match confidence {
            c if c >= 0.99 => 2.326,
            c if c >= 0.95 => 1.645,
            c if c >= 0.90 => 1.282,
            _ => 1.0,
        };
        
        mean - z * std
    }
    
    /// Expected Shortfall (CVaR)
    pub fn expected_shortfall(returns: &[f64], confidence: f64) -> f64 {
        let mut sorted = returns.to_vec();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
        
        let cutoff = ((1.0 - confidence) * sorted.len() as f64) as usize;
        let tail = &sorted[..cutoff.max(1)];
        
        tail.iter().sum::<f64>() / tail.len() as f64
    }
    
    /// Maximum drawdown
    pub fn max_drawdown(equity_curve: &[f64]) -> (f64, usize, usize) {
        let mut max_dd = 0.0;
        let mut peak_idx = 0;
        let mut trough_idx = 0;
        let mut peak = equity_curve[0];
        
        for (i, &equity) in equity_curve.iter().enumerate() {
            if equity > peak {
                peak = equity;
                peak_idx = i;
            }
            
            let dd = (peak - equity) / peak;
            if dd > max_dd {
                max_dd = dd;
                trough_idx = i;
            }
        }
        
        (max_dd, peak_idx, trough_idx)
    }
    
    /// Sharpe Ratio
    pub fn sharpe_ratio(returns: &[f64], risk_free_rate: f64) -> f64 {
        let n = returns.len() as f64;
        let mean: f64 = returns.iter().sum::<f64>() / n;
        let excess_return = mean - risk_free_rate / 252.0; // Daily risk-free rate
        
        let variance: f64 = returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / n;
        let std = sqrt(variance);
        
        if std > 0.0 {
            excess_return / std * sqrt(252.0) // Annualized
        } else {
            0.0
        }
    }
    
    /// Sortino Ratio (downside deviation)
    pub fn sortino_ratio(returns: &[f64], risk_free_rate: f64) -> f64 {
        let n = returns.len() as f64;
        let mean: f64 = returns.iter().sum::<f64>() / n;
        let excess_return = mean - risk_free_rate / 252.0;
        
        // Downside deviation
        let downside_var: f64 = returns.iter()
            .filter(|&&r| r < 0.0)
            .map(|r| r.powi(2))
            .sum::<f64>() / n;
        let downside_std = sqrt(downside_var);
        
        if downside_std > 0.0 {
            excess_return / downside_std * sqrt(252.0)
        } else {
            0.0
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRADING ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Main trading engine
pub struct TradingEngine {
    pub positions: HashMap<String, Position>,
    pub orders: HashMap<String, Order>,
    pub trades: Vec<Trade>,
    pub equity: f64,
    pub strategies: Vec<Box<dyn Strategy>>,
    pub risk_per_trade: f64,
}

impl TradingEngine {
    pub fn new(initial_capital: f64) -> Self {
        TradingEngine {
            positions: HashMap::new(),
            orders: HashMap::new(),
            trades: Vec::new(),
            equity: initial_capital,
            strategies: Vec::new(),
            risk_per_trade: 0.02, // 2% risk per trade
        }
    }
    
    pub fn add_strategy(&mut self, strategy: Box<dyn Strategy>) {
        self.strategies.push(strategy);
    }
    
    /// Process new market data
    pub fn on_candle(&mut self, symbol: &str, candles: &[Candle]) -> Vec<Order> {
        let mut orders = Vec::new();
        
        // Generate signals from all strategies
        for strategy in &mut self.strategies {
            let signals = strategy.generate_signals(candles);
            
            for signal in signals {
                if signal.strength > 0.5 { // Only act on strong signals
                    let order = self.create_order(symbol, &signal, candles.last().unwrap());
                    if let Some(o) = order {
                        orders.push(o);
                    }
                }
            }
        }
        
        orders
    }
    
    fn create_order(&self, symbol: &str, signal: &Signal, candle: &Candle) -> Option<Order> {
        let position_size = risk::calculate_position_size(
            self.equity,
            risk::PositionSizing::PercentOfEquity(self.risk_per_trade),
            candle.close,
        );
        
        if position_size < 0.0001 {
            return None;
        }
        
        Some(Order {
            id: format!("ORD-{}", uuid::Uuid::new_v4()),
            symbol: symbol.to_string(),
            side: signal.side,
            order_type: OrderType::Limit,
            quantity: position_size,
            limit_price: Some(candle.close),
            stop_price: signal.stop_loss,
            time_in_force: TimeInForce::Day,
            status: OrderStatus::Pending,
            filled_quantity: 0.0,
            average_fill_price: 0.0,
            created_at: signal.timestamp,
            updated_at: signal.timestamp,
        })
    }
    
    /// Process order fill
    pub fn on_fill(&mut self, trade: Trade) {
        // Update position
        let position = self.positions
            .entry(trade.symbol.clone())
            .or_insert(Position::new(&trade.symbol));
        
        match trade.side {
            Side::Buy => {
                let new_cost = position.quantity * position.average_cost + trade.quantity * trade.price;
                position.quantity += trade.quantity;
                position.average_cost = new_cost / position.quantity;
            }
            Side::Sell => {
                let realized = (trade.price - position.average_cost) * trade.quantity;
                position.realized_pnl += realized;
                position.quantity -= trade.quantity;
            }
        }
        
        // Deduct commission
        self.equity -= trade.commission;
        
        // Store trade
        self.trades.push(trade);
    }
    
    /// Get portfolio value
    pub fn portfolio_value(&self, prices: &HashMap<String, f64>) -> f64 {
        let position_value: f64 = self.positions.iter()
            .map(|(symbol, pos)| {
                prices.get(symbol).unwrap_or(&0.0) * pos.quantity
            })
            .sum();
        
        self.equity + position_value
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_market_tensor() {
        let tensor = MarketTensor::new(100, 5, 10, 4);
        assert_eq!(tensor.shape, [100, 5, 10, 4]);
    }
    
    #[test]
    fn test_financial_schrodinger() {
        let mut fs = FinancialSchrodinger::new(100.0, 0.2, 100);
        
        let initial_expected = fs.expected_price();
        assert!((initial_expected - 100.0).abs() < 1.0);
        
        fs.evolve(10);
        
        let dist = fs.probability_distribution();
        let total_prob: f64 = dist.iter().map(|(_, p)| p).sum();
        assert!((total_prob - 1.0).abs() < 0.01);
    }
    
    #[test]
    fn test_indicators() {
        let data: Vec<f64> = (0..100).map(|i| 100.0 + (i as f64 * 0.1).sin() * 10.0).collect();
        
        let sma = indicators::sma(&data, 20);
        assert_eq!(sma.len(), data.len() - 19);
        
        let ema = indicators::ema(&data, 20);
        assert_eq!(ema.len(), data.len());
        
        let rsi = indicators::rsi(&data, 14);
        assert!(!rsi.is_empty());
        for &r in &rsi {
            assert!(r >= 0.0 && r <= 100.0);
        }
    }
    
    #[test]
    fn test_risk_metrics() {
        let returns: Vec<f64> = vec![0.01, -0.02, 0.015, -0.005, 0.02, -0.01, 0.005];
        
        let sharpe = risk::sharpe_ratio(&returns, 0.02);
        assert!(!sharpe.is_nan());
        
        let var = risk::var_parametric(&returns, 0.95);
        assert!(!var.is_nan());
    }
}
