// ENB HELPER COMPATIBILITY
// ═══════════════════════════════════════════════════════════════════════════════

/// ENB Helper API compatibility layer
pub struct ENBHelper {
    version: u32,
    game_version: String,
    interior: bool,
    weather_data: WeatherData,
    time_data: TimeOfDay,
}

impl ENBHelper {
    pub fn new() -> Self {
        ENBHelper {
            version: 1,
            game_version: String::new(),
            interior: false,
            weather_data: WeatherData::clear(),
            time_data: TimeOfDay::from_hour(12.0),
        }
    }
    
    /// Check if player is in interior
    pub fn is_interior(&self) -> bool {
        self.interior
    }
    
    /// Get current weather
    pub fn get_weather(&self) -> &WeatherData {
        &self.weather_data
    }
    
    /// Get current time
    pub fn get_time(&self) -> &TimeOfDay {
        &self.time_data
    }
    
    /// Update from game data
    pub fn update(&mut self, interior: bool, weather: WeatherData, time: TimeOfDay) {
        self.interior = interior;
        self.weather_data = weather;
        self.time_data = time;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE PROFILING
// ═══════════════════════════════════════════════════════════════════════════════

/// Performance metrics for ENB effects
#[derive(Debug, Clone, Default)]
pub struct ENBPerformanceMetrics {
    pub total_frame_time_ms: f32,
    pub enb_total_ms: f32,
    pub effect_times: HashMap<String, f32>,
    pub gpu_memory_mb: u32,
    pub vram_usage_percent: f32,
}

/// Performance profiler
pub struct ENBProfiler {
    metrics: ENBPerformanceMetrics,
    history: Vec<ENBPerformanceMetrics>,
    max_history: usize,
}

impl ENBProfiler {
    pub fn new() -> Self {
        ENBProfiler {
            metrics: ENBPerformanceMetrics::default(),
            history: Vec::new(),
            max_history: 300, // 5 seconds at 60fps
        }
    }
    
    pub fn record_frame(&mut self, metrics: ENBPerformanceMetrics) {
        self.history.push(metrics.clone());
        if self.history.len() > self.max_history {
            self.history.remove(0);
        }
        self.metrics = metrics;
    }
    
    pub fn average_frame_time(&self) -> f32 {
        if self.history.is_empty() { return 0.0; }
        self.history.iter().map(|m| m.total_frame_time_ms).sum::<f32>() / self.history.len() as f32
    }
    
    pub fn average_enb_time(&self) -> f32 {
        if self.history.is_empty() { return 0.0; }
        self.history.iter().map(|m| m.enb_total_ms).sum::<f32>() / self.history.len() as f32
    }
    
    pub fn enb_overhead_percent(&self) -> f32 {
        let total = self.average_frame_time();
        let enb = self.average_enb_time();
        if total > 0.0 { enb / total * 100.0 } else { 0.0 }
    }
    
    pub fn slowest_effect(&self) -> Option<(String, f32)> {
        self.metrics.effect_times.iter()
            .max_by(|a, b| a.1.partial_cmp(b.1).unwrap())
            .map(|(k, v)| (k.clone(), *v))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN ENB MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

/// Main ENB integration manager
pub struct ENBManager {
    pub enabled: bool,
    pub preset_manager: PresetManager,
    pub helper: ENBHelper,
    pub interpolator: WeatherInterpolator,
    pub profiler: ENBProfiler,
    effects: Vec<ENBEffect>,
}

impl ENBManager {
    pub fn new(presets_dir: &str) -> Self {
        ENBManager {
            enabled: true,
            preset_manager: PresetManager::new(presets_dir),
            helper: ENBHelper::new(),
            interpolator: WeatherInterpolator::new(),
            profiler: ENBProfiler::new(),
            effects: Vec::new(),
        }
    }
    
    pub fn add_effect(&mut self, effect: ENBEffect) {
        self.effects.push(effect);
    }
    
    pub fn get_effect(&self, name: &str) -> Option<&ENBEffect> {
        self.effects.iter().find(|e| e.name == name)
    }
    
    pub fn get_effect_mut(&mut self, name: &str) -> Option<&mut ENBEffect> {
        self.effects.iter_mut().find(|e| e.name == name)
    }
    
    /// Update interpolated parameters based on current conditions
    pub fn update(&mut self) {
        let time = self.helper.get_time().clone();
        let weather = self.helper.get_weather().clone();
        
        for effect in &mut self.effects {
            for (name, param) in &mut effect.parameters {
                if let Some(value) = self.interpolator.get_interpolated(name, &time, &weather) {
                    param.value = value;
                }
            }
        }
    }
    
    pub fn toggle(&mut self) {
        self.enabled = !self.enabled;
    }
}

