// ═══════════════════════════════════════════════════════════════════════════════
// ENB API TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// ENB parameter types
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ENBParameterType {
    Bool,
    Int,
    Float,
    Float2,
    Float3,
    Float4,
    Color3,
    Color4,
}

/// ENB parameter value
#[derive(Debug, Clone)]
pub enum ENBValue {
    Bool(bool),
    Int(i32),
    Float(f32),
    Float2(f32, f32),
    Float3(f32, f32, f32),
    Float4(f32, f32, f32, f32),
    Color3(f32, f32, f32),
    Color4(f32, f32, f32, f32),
}

impl ENBValue {
    pub fn as_float(&self) -> Option<f32> {
        match self {
            ENBValue::Float(v) => Some(*v),
            ENBValue::Int(v) => Some(*v as f32),
            _ => None,
        }
    }
    
    pub fn as_bool(&self) -> Option<bool> {
        match self {
            ENBValue::Bool(v) => Some(*v),
            ENBValue::Int(v) => Some(*v != 0),
            ENBValue::Float(v) => Some(*v > 0.5),
            _ => None,
        }
    }
    
    pub fn as_vec3(&self) -> Option<Vec3> {
        match self {
            ENBValue::Float3(x, y, z) | ENBValue::Color3(x, y, z) => {
                Some(Vec3::new(*x, *y, *z))
            }
            ENBValue::Float4(x, y, z, _) | ENBValue::Color4(x, y, z, _) => {
                Some(Vec3::new(*x, *y, *z))
            }
            _ => None,
        }
    }
    
    pub fn as_vec4(&self) -> Option<Vec4> {
        match self {
            ENBValue::Float4(x, y, z, w) | ENBValue::Color4(x, y, z, w) => {
                Some(Vec4::new(*x, *y, *z, *w))
            }
            ENBValue::Float3(x, y, z) | ENBValue::Color3(x, y, z) => {
                Some(Vec4::new(*x, *y, *z, 1.0))
            }
            _ => None,
        }
    }
}

/// ENB parameter definition
#[derive(Debug, Clone)]
pub struct ENBParameter {
    pub name: String,
    pub param_type: ENBParameterType,
    pub value: ENBValue,
    pub default_value: ENBValue,
    pub min_value: Option<ENBValue>,
    pub max_value: Option<ENBValue>,
    pub step: Option<f32>,
    pub category: String,
    pub description: String,
    pub hidden: bool,
}

impl ENBParameter {
    pub fn new_float(name: &str, value: f32) -> Self {
        ENBParameter {
            name: name.to_string(),
            param_type: ENBParameterType::Float,
            value: ENBValue::Float(value),
            default_value: ENBValue::Float(value),
            min_value: Some(ENBValue::Float(0.0)),
            max_value: Some(ENBValue::Float(1.0)),
            step: Some(0.01),
            category: String::new(),
            description: String::new(),
            hidden: false,
        }
    }
    
    pub fn new_bool(name: &str, value: bool) -> Self {
        ENBParameter {
            name: name.to_string(),
            param_type: ENBParameterType::Bool,
            value: ENBValue::Bool(value),
            default_value: ENBValue::Bool(value),
            min_value: None,
            max_value: None,
            step: None,
            category: String::new(),
            description: String::new(),
            hidden: false,
        }
    }
    
    pub fn new_color(name: &str, r: f32, g: f32, b: f32) -> Self {
        ENBParameter {
            name: name.to_string(),
            param_type: ENBParameterType::Color3,
            value: ENBValue::Color3(r, g, b),
            default_value: ENBValue::Color3(r, g, b),
            min_value: Some(ENBValue::Color3(0.0, 0.0, 0.0)),
            max_value: Some(ENBValue::Color3(1.0, 1.0, 1.0)),
            step: Some(0.001),
            category: String::new(),
            description: String::new(),
            hidden: false,
        }
    }
    
    pub fn with_range(mut self, min: f32, max: f32) -> Self {
        self.min_value = Some(ENBValue::Float(min));
        self.max_value = Some(ENBValue::Float(max));
        self
    }
    
    pub fn with_category(mut self, category: &str) -> Self {
        self.category = category.to_string();
        self
    }
    
    pub fn with_description(mut self, desc: &str) -> Self {
        self.description = desc.to_string();
        self
    }
    
    pub fn reset(&mut self) {
        self.value = self.default_value.clone();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENB EFFECT FRAMEWORK
// ═══════════════════════════════════════════════════════════════════════════════

/// ENB shader technique
#[derive(Debug, Clone)]
pub struct ENBTechnique {
    pub name: String,
    pub enabled: bool,
    pub passes: Vec<ENBPass>,
}

/// ENB shader pass
#[derive(Debug, Clone)]
pub struct ENBPass {
    pub name: String,
    pub vertex_shader: String,
    pub pixel_shader: String,
    pub render_target: RenderTarget,
    pub blend_state: BlendState,
    pub depth_state: DepthState,
}

#[derive(Debug, Clone, Copy)]
pub enum RenderTarget {
    Backbuffer,
    RenderTarget0,
    RenderTarget1,
    RenderTarget2,
    RenderTargetRGBA32,
    RenderTargetRGBA64,
    RenderTargetRGBA64F,
    RenderTargetR16F,
    RenderTargetR32F,
    RenderTargetRG16F,
    RenderTargetRG32F,
}

#[derive(Debug, Clone, Copy)]
pub struct BlendState {
    pub enabled: bool,
    pub src_blend: BlendFactor,
    pub dst_blend: BlendFactor,
    pub blend_op: BlendOp,
}

#[derive(Debug, Clone, Copy)]
pub enum BlendFactor {
    Zero, One, SrcColor, InvSrcColor, SrcAlpha, InvSrcAlpha,
    DstAlpha, InvDstAlpha, DstColor, InvDstColor,
}

#[derive(Debug, Clone, Copy)]
pub enum BlendOp {
    Add, Subtract, RevSubtract, Min, Max,
}

#[derive(Debug, Clone, Copy)]
pub struct DepthState {
    pub depth_enable: bool,
    pub depth_write: bool,
}

impl BlendState {
    pub fn disabled() -> Self {
        BlendState {
            enabled: false,
            src_blend: BlendFactor::One,
            dst_blend: BlendFactor::Zero,
            blend_op: BlendOp::Add,
        }
    }
    
    pub fn alpha_blend() -> Self {
        BlendState {
            enabled: true,
            src_blend: BlendFactor::SrcAlpha,
            dst_blend: BlendFactor::InvSrcAlpha,
            blend_op: BlendOp::Add,
        }
    }
    
    pub fn additive() -> Self {
        BlendState {
            enabled: true,
            src_blend: BlendFactor::One,
            dst_blend: BlendFactor::One,
            blend_op: BlendOp::Add,
        }
    }
}

/// ENB effect file (.fx)
#[derive(Debug, Clone)]
pub struct ENBEffect {
    pub name: String,
    pub filename: String,
    pub enabled: bool,
    pub parameters: HashMap<String, ENBParameter>,
    pub techniques: Vec<ENBTechnique>,
    pub textures: Vec<ENBTexture>,
}

#[derive(Debug, Clone)]
pub struct ENBTexture {
    pub name: String,
    pub filename: String,
    pub sampler_state: SamplerState,
}

#[derive(Debug, Clone, Copy)]
pub struct SamplerState {
    pub filter: TextureFilter,
    pub address_u: TextureAddress,
    pub address_v: TextureAddress,
}

#[derive(Debug, Clone, Copy)]
pub enum TextureFilter {
    Point, Linear, Anisotropic,
}

#[derive(Debug, Clone, Copy)]
pub enum TextureAddress {
    Wrap, Mirror, Clamp, Border,
}

impl ENBEffect {
    pub fn new(name: &str, filename: &str) -> Self {
        ENBEffect {
            name: name.to_string(),
            filename: filename.to_string(),
            enabled: true,
            parameters: HashMap::new(),
            techniques: Vec::new(),
            textures: Vec::new(),
        }
    }
    
    pub fn add_parameter(&mut self, param: ENBParameter) {
        self.parameters.insert(param.name.clone(), param);
    }
    
    pub fn get_parameter(&self, name: &str) -> Option<&ENBParameter> {
        self.parameters.get(name)
    }
    
    pub fn set_parameter(&mut self, name: &str, value: ENBValue) {
        if let Some(param) = self.parameters.get_mut(name) {
            param.value = value;
        }
    }
}

