// ENB PRESET MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// ENB preset (complete configuration)
#[derive(Debug, Clone)]
pub struct ENBPreset {
    pub name: String,
    pub author: String,
    pub version: String,
    pub description: String,
    pub game: String,
    pub enb_version: String,
    pub effects: Vec<ENBEffect>,
    pub global_params: HashMap<String, ENBValue>,
    pub enbseries_ini: HashMap<String, HashMap<String, String>>,
    pub enblocal_ini: HashMap<String, HashMap<String, String>>,
}

impl ENBPreset {
    pub fn new(name: &str) -> Self {
        ENBPreset {
            name: name.to_string(),
            author: String::new(),
            version: "1.0.0".to_string(),
            description: String::new(),
            game: String::new(),
            enb_version: String::new(),
            effects: Vec::new(),
            global_params: HashMap::new(),
            enbseries_ini: HashMap::new(),
            enblocal_ini: HashMap::new(),
        }
    }
    
    /// Parse enbseries.ini content
    pub fn parse_ini(&mut self, content: &str) {
        let mut current_section = String::new();
        
        for line in content.lines() {
            let line = line.trim();
            
            if line.starts_with('[') && line.ends_with(']') {
                current_section = line[1..line.len()-1].to_string();
                self.enbseries_ini.entry(current_section.clone())
                    .or_insert_with(HashMap::new);
            } else if line.contains('=') && !current_section.is_empty() {
                let parts: Vec<&str> = line.splitn(2, '=').collect();
                if parts.len() == 2 {
                    if let Some(section) = self.enbseries_ini.get_mut(&current_section) {
                        section.insert(
                            parts[0].trim().to_string(),
                            parts[1].trim().to_string()
                        );
                    }
                }
            }
        }
    }
    
    /// Generate enbseries.ini content
    pub fn generate_ini(&self) -> String {
        let mut output = String::new();
        
        for (section, params) in &self.enbseries_ini {
            output.push_str(&format!("[{}]\n", section));
            for (key, value) in params {
                output.push_str(&format!("{}={}\n", key, value));
            }
            output.push('\n');
        }
        
        output
    }
}

/// Preset manager
pub struct PresetManager {
    presets: HashMap<String, ENBPreset>,
    active_preset: Option<String>,
    presets_directory: String,
}

impl PresetManager {
    pub fn new(directory: &str) -> Self {
        PresetManager {
            presets: HashMap::new(),
            active_preset: None,
            presets_directory: directory.to_string(),
        }
    }
    
    pub fn add_preset(&mut self, preset: ENBPreset) {
        self.presets.insert(preset.name.clone(), preset);
    }
    
    pub fn activate_preset(&mut self, name: &str) -> bool {
        if self.presets.contains_key(name) {
            self.active_preset = Some(name.to_string());
            true
        } else {
            false
        }
    }
    
    pub fn get_active(&self) -> Option<&ENBPreset> {
        self.active_preset.as_ref().and_then(|n| self.presets.get(n))
    }
    
    pub fn list_presets(&self) -> Vec<&str> {
        self.presets.keys().map(|s| s.as_str()).collect()
    }
}

