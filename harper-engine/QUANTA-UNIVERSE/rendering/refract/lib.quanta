// ENB WEATHER/TIME INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Time of day data
#[derive(Debug, Clone, Copy)]
pub struct TimeOfDay {
    pub hour: f32,           // 0-24
    pub day: u32,
    pub month: u32,
    pub year: u32,
    pub day_phase: DayPhase,
    pub sun_altitude: f32,   // -90 to 90 degrees
    pub sun_azimuth: f32,    // 0-360 degrees
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum DayPhase {
    Night,
    Dawn,
    Sunrise,
    Morning,
    Day,
    Afternoon,
    Sunset,
    Dusk,
}

impl TimeOfDay {
    pub fn from_hour(hour: f32) -> Self {
        let phase = match hour {
            h if h < 4.0 => DayPhase::Night,
            h if h < 5.5 => DayPhase::Dawn,
            h if h < 7.0 => DayPhase::Sunrise,
            h if h < 10.0 => DayPhase::Morning,
            h if h < 15.0 => DayPhase::Day,
            h if h < 18.0 => DayPhase::Afternoon,
            h if h < 19.5 => DayPhase::Sunset,
            h if h < 21.0 => DayPhase::Dusk,
            _ => DayPhase::Night,
        };
        
        TimeOfDay {
            hour,
            day: 1,
            month: 1,
            year: 2024,
            day_phase: phase,
            sun_altitude: 90.0 * (1.0 - 2.0 * (hour - 12.0).abs() / 12.0),
            sun_azimuth: hour / 24.0 * 360.0,
        }
    }
    
    /// Interpolation factor for time-based transitions
    pub fn lerp_factor(&self, from_phase: DayPhase, to_phase: DayPhase) -> f32 {
        // Would calculate proper interpolation between phases
        0.5
    }
}

/// Weather data
#[derive(Debug, Clone)]
pub struct WeatherData {
    pub weather_id: u32,
    pub weather_name: String,
    pub transition_progress: f32,  // 0-1 for weather transitions
    pub fog_distance: f32,
    pub fog_near: f32,
    pub fog_far: f32,
    pub fog_color: Vec3,
    pub sun_color: Vec3,
    pub ambient_color: Vec3,
    pub sky_color: Vec3,
    pub precipitation: PrecipitationType,
    pub precipitation_intensity: f32,
    pub wind_speed: f32,
    pub wind_direction: f32,
    pub cloudiness: f32,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum PrecipitationType {
    None,
    Rain,
    Snow,
    Sleet,
    Hail,
    Ash,
    Dust,
}

impl WeatherData {
    pub fn clear() -> Self {
        WeatherData {
            weather_id: 0,
            weather_name: "Clear".to_string(),
            transition_progress: 1.0,
            fog_distance: 100000.0,
            fog_near: 10000.0,
            fog_far: 100000.0,
            fog_color: Vec3::new(0.7, 0.8, 0.9),
            sun_color: Vec3::new(1.0, 0.98, 0.95),
            ambient_color: Vec3::new(0.3, 0.35, 0.4),
            sky_color: Vec3::new(0.5, 0.7, 1.0),
            precipitation: PrecipitationType::None,
            precipitation_intensity: 0.0,
            wind_speed: 5.0,
            wind_direction: 45.0,
            cloudiness: 0.1,
        }
    }
}

/// Weather-based parameter interpolation
pub struct WeatherInterpolator {
    weather_presets: HashMap<u32, HashMap<String, ENBValue>>,
    time_presets: HashMap<DayPhase, HashMap<String, ENBValue>>,
}

impl WeatherInterpolator {
    pub fn new() -> Self {
        WeatherInterpolator {
            weather_presets: HashMap::new(),
            time_presets: HashMap::new(),
        }
    }
    
    pub fn add_weather_preset(&mut self, weather_id: u32, params: HashMap<String, ENBValue>) {
        self.weather_presets.insert(weather_id, params);
    }
    
    pub fn add_time_preset(&mut self, phase: DayPhase, params: HashMap<String, ENBValue>) {
        self.time_presets.insert(phase, params);
    }
    
    /// Get interpolated parameter value based on current conditions
    pub fn get_interpolated(&self, param_name: &str, time: &TimeOfDay, weather: &WeatherData) -> Option<ENBValue> {
        let time_value = self.time_presets.get(&time.day_phase)
            .and_then(|p| p.get(param_name));
        
        let weather_value = self.weather_presets.get(&weather.weather_id)
            .and_then(|p| p.get(param_name));
        
        match (time_value, weather_value) {
            (Some(t), Some(w)) => {
                // Blend time and weather values
                self.blend_values(t, w, weather.cloudiness)
            }
            (Some(t), None) => Some(t.clone()),
            (None, Some(w)) => Some(w.clone()),
            (None, None) => None,
        }
    }
    
    fn blend_values(&self, a: &ENBValue, b: &ENBValue, t: f32) -> Option<ENBValue> {
        match (a, b) {
            (ENBValue::Float(va), ENBValue::Float(vb)) => {
                Some(ENBValue::Float(lerp(*va, *vb, t)))
            }
            (ENBValue::Color3(r1, g1, b1), ENBValue::Color3(r2, g2, b2)) => {
                Some(ENBValue::Color3(
                    lerp(*r1, *r2, t),
                    lerp(*g1, *g2, t),
                    lerp(*b1, *b2, t),
                ))
            }
            _ => Some(a.clone()),
        }
    }
}

fn lerp(a: f32, b: f32, t: f32) -> f32 {
    a + (b - a) * t
}

