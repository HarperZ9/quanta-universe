// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_enb_parameter() {
        let param = ENBParameter::new_float("Brightness", 1.0)
            .with_range(0.0, 2.0)
            .with_category("Color");
        
        assert_eq!(param.value.as_float(), Some(1.0));
    }
    
    #[test]
    fn test_time_of_day() {
        let noon = TimeOfDay::from_hour(12.0);
        assert_eq!(noon.day_phase, DayPhase::Day);
        
        let midnight = TimeOfDay::from_hour(0.0);
        assert_eq!(midnight.day_phase, DayPhase::Night);
    }
    
    #[test]
    fn test_preset_ini_parsing() {
        let mut preset = ENBPreset::new("Test");
        preset.parse_ini("[GLOBAL]\nUsePatchSpeedhackWithoutGraphics=false\n\n[EFFECT]\nEnableBloom=true\n");
        
        assert!(preset.enbseries_ini.contains_key("GLOBAL"));
        assert!(preset.enbseries_ini.contains_key("EFFECT"));
    }
}
