module quanta_visual_systems

use std::math::{sqrt, sin, cos, tan, exp, log, pow, abs, min, max, clamp, PI}
use titan_color::{RGB, Vec3, Mat4}

// ═══════════════════════════════════════════════════════════════════════════════
// COMMON TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// 2D vector
#[derive(Debug, Clone, Copy)]
pub struct Vec2 {
    pub x: f32,
    pub y: f32,
}

impl Vec2 {
    pub fn new(x: f32, y: f32) -> Self { Vec2 { x, y } }
    pub fn zero() -> Self { Vec2::new(0.0, 0.0) }
    pub fn one() -> Self { Vec2::new(1.0, 1.0) }
    
    pub fn dot(&self, other: &Vec2) -> f32 {
        self.x * other.x + self.y * other.y
    }
    
    pub fn length(&self) -> f32 {
        sqrt(self.dot(self))
    }
    
    pub fn normalize(&self) -> Vec2 {
        let len = self.length();
        if len > 0.0 {
            Vec2::new(self.x / len, self.y / len)
        } else {
            *self
        }
    }
    
    pub fn add(&self, other: &Vec2) -> Vec2 {
        Vec2::new(self.x + other.x, self.y + other.y)
    }
    
    pub fn sub(&self, other: &Vec2) -> Vec2 {
        Vec2::new(self.x - other.x, self.y - other.y)
    }
    
    pub fn scale(&self, s: f32) -> Vec2 {
        Vec2::new(self.x * s, self.y * s)
    }
}

/// Render target / texture reference
pub struct Texture2D {
    pub width: u32,
    pub height: u32,
    pub format: TextureFormat,
    pub data: Vec<u8>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TextureFormat {
    R8,
    RG8,
    RGB8,
    RGBA8,
    R16F,
    RG16F,
    RGB16F,
    RGBA16F,
    R32F,
    RG32F,
    RGB32F,
    RGBA32F,
    Depth24,
    Depth32F,
}

impl Texture2D {
    pub fn new(width: u32, height: u32, format: TextureFormat) -> Self {
        let bytes_per_pixel = match format {
            TextureFormat::R8 => 1,
            TextureFormat::RG8 => 2,
            TextureFormat::RGB8 => 3,
            TextureFormat::RGBA8 | TextureFormat::Depth24 => 4,
            TextureFormat::R16F => 2,
            TextureFormat::RG16F => 4,
            TextureFormat::RGB16F => 6,
            TextureFormat::RGBA16F => 8,
            TextureFormat::R32F | TextureFormat::Depth32F => 4,
            TextureFormat::RG32F => 8,
            TextureFormat::RGB32F => 12,
            TextureFormat::RGBA32F => 16,
        };
        
        let size = (width * height * bytes_per_pixel) as usize;
        
        Texture2D {
            width,
            height,
            format,
            data: vec![0; size],
        }
    }
    
    pub fn sample(&self, uv: Vec2) -> RGB {
        let x = (uv.x * self.width as f32) as u32 % self.width;
        let y = (uv.y * self.height as f32) as u32 % self.height;
        
        // Simplified - would properly decode based on format
        let idx = ((y * self.width + x) * 4) as usize;
        
        if idx + 3 < self.data.len() {
            RGB::new(
                self.data[idx] as f32 / 255.0,
                self.data[idx + 1] as f32 / 255.0,
                self.data[idx + 2] as f32 / 255.0,
            )
        } else {
            RGB::black()
        }
    }
}

/// Post-processing context
pub struct PostProcessContext {
    pub screen_width: u32,
    pub screen_height: u32,
    pub time: f32,
    pub delta_time: f32,
    pub frame_count: u32,
    pub near_plane: f32,
    pub far_plane: f32,
    pub fov: f32,
    pub view_matrix: Mat4,
    pub projection_matrix: Mat4,
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCREEN SPACE AMBIENT OCCLUSION (SSAO)
// ═══════════════════════════════════════════════════════════════════════════════

/// Quanta SSAO - High quality screen space ambient occlusion
pub struct SSAO {
    pub enabled: bool,
    pub radius: f32,
    pub bias: f32,
    pub intensity: f32,
    pub samples: u32,
    pub blur_passes: u32,
    kernel: Vec<Vec3>,
    noise: Vec<Vec3>,
}

impl SSAO {
    pub fn new() -> Self {
        let mut ssao = SSAO {
            enabled: true,
            radius: 0.5,
            bias: 0.025,
            intensity: 1.0,
            samples: 64,
            blur_passes: 2,
            kernel: Vec::new(),
            noise: Vec::new(),
        };
        
        ssao.generate_kernel();
        ssao.generate_noise();
        
        ssao
    }
    
    fn generate_kernel(&mut self) {
        let mut rng = std::random::Random::new();
        self.kernel.clear();
        
        for i in 0..self.samples {
            // Hemisphere samples
            let mut sample = Vec3::new(
                rng.uniform(-1.0, 1.0),
                rng.uniform(-1.0, 1.0),
                rng.uniform(0.0, 1.0),  // Hemisphere
            ).normalize();
            
            // Scale to distribute samples closer to origin
            let scale = i as f32 / self.samples as f32;
            let scale = 0.1 + scale * scale * 0.9;  // lerp(0.1, 1.0, scale²)
            sample = sample.scale(scale);
            
            self.kernel.push(sample);
        }
    }
    
    fn generate_noise(&mut self) {
        let mut rng = std::random::Random::new();
        self.noise.clear();
        
        // 4x4 noise texture
        for _ in 0..16 {
            self.noise.push(Vec3::new(
                rng.uniform(-1.0, 1.0),
                rng.uniform(-1.0, 1.0),
                0.0,
            ).normalize());
        }
    }
    
    /// Compute SSAO for a pixel
    pub fn compute(
        &self,
        uv: Vec2,
        position: Vec3,
        normal: Vec3,
        depth_buffer: &Texture2D,
        ctx: &PostProcessContext,
    ) -> f32 {
        if !self.enabled {
            return 1.0;
        }
        
        // Get noise vector
        let noise_uv = Vec2::new(
            (uv.x * ctx.screen_width as f32) % 4.0 / 4.0,
            (uv.y * ctx.screen_height as f32) % 4.0 / 4.0,
        );
        let noise_idx = ((noise_uv.y * 4.0) as usize * 4 + (noise_uv.x * 4.0) as usize) % 16;
        let random_vec = self.noise[noise_idx];
        
        // Create TBN matrix for oriented hemisphere
        let tangent = random_vec.sub(&normal.scale(random_vec.dot(&normal))).normalize();
        let bitangent = normal.cross(&tangent);
        
        let mut occlusion = 0.0;
        
        for i in 0..self.samples as usize {
            // Transform sample to world space
            let sample = &self.kernel[i];
            let sample_pos = Vec3::new(
                tangent.x * sample.x + bitangent.x * sample.y + normal.x * sample.z,
                tangent.y * sample.x + bitangent.y * sample.y + normal.y * sample.z,
                tangent.z * sample.x + bitangent.z * sample.y + normal.z * sample.z,
            );
            
            let sample_world = position.add(&sample_pos.scale(self.radius));
            
            // Project to screen space
            let sample_screen = self.project_to_screen(&sample_world, ctx);
            
            // Sample depth buffer
            let sample_depth = self.linear_depth(
                depth_buffer.sample(sample_screen).r,
                ctx.near_plane,
                ctx.far_plane,
            );
            
            let sample_z = self.linear_depth(sample_screen.y, ctx.near_plane, ctx.far_plane);
            
            // Range check and accumulate
            let range_check = smoothstep(0.0, 1.0, self.radius / abs(position.z - sample_depth));
            
            if sample_depth >= sample_z + self.bias {
                occlusion += range_check;
            }
        }
        
        occlusion = 1.0 - (occlusion / self.samples as f32);
        pow(occlusion, self.intensity)
    }
    
    fn project_to_screen(&self, world_pos: &Vec3, ctx: &PostProcessContext) -> Vec2 {
        // Simplified projection
        Vec2::new(
            (world_pos.x / world_pos.z + 1.0) * 0.5,
            (world_pos.y / world_pos.z + 1.0) * 0.5,
        )
    }
    
    fn linear_depth(&self, depth: f32, near: f32, far: f32) -> f32 {
        near * far / (far + depth * (near - far))
    }
}

fn smoothstep(edge0: f32, edge1: f32, x: f32) -> f32 {
    let t = clamp((x - edge0) / (edge1 - edge0), 0.0, 1.0);
    t * t * (3.0 - 2.0 * t)
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCREEN SPACE GLOBAL ILLUMINATION (SSGI)
// ═══════════════════════════════════════════════════════════════════════════════

/// Quanta SSGI - Screen space global illumination
pub struct SSGI {
    pub enabled: bool,
    pub ray_steps: u32,
    pub ray_count: u32,
    pub max_distance: f32,
    pub thickness: f32,
    pub intensity: f32,
}

impl SSGI {
    pub fn new() -> Self {
        SSGI {
            enabled: true,
            ray_steps: 16,
            ray_count: 4,
            max_distance: 10.0,
            thickness: 0.5,
            intensity: 1.0,
        }
    }
    
    /// Compute indirect lighting for a pixel
    pub fn compute(
        &self,
        uv: Vec2,
        position: Vec3,
        normal: Vec3,
        color_buffer: &Texture2D,
        depth_buffer: &Texture2D,
        ctx: &PostProcessContext,
    ) -> RGB {
        if !self.enabled {
            return RGB::black();
        }
        
        let mut indirect = RGB::black();
        
        for ray in 0..self.ray_count {
            // Generate ray direction in hemisphere
            let phi = 2.0 * PI * (ray as f32 + 0.5) / self.ray_count as f32;
            let cos_theta = 0.5; // Simplified - would use importance sampling
            let sin_theta = sqrt(1.0 - cos_theta * cos_theta);
            
            let ray_dir = Vec3::new(
                sin_theta * cos(phi),
                sin_theta * sin(phi),
                cos_theta,
            );
            
            // Transform to world space aligned with normal
            let tangent = if abs(normal.y) < 0.99 {
                Vec3::new(0.0, 1.0, 0.0).cross(&normal).normalize()
            } else {
                Vec3::new(1.0, 0.0, 0.0).cross(&normal).normalize()
            };
            let bitangent = normal.cross(&tangent);
            
            let world_dir = Vec3::new(
                tangent.x * ray_dir.x + bitangent.x * ray_dir.y + normal.x * ray_dir.z,
                tangent.y * ray_dir.x + bitangent.y * ray_dir.y + normal.y * ray_dir.z,
                tangent.z * ray_dir.x + bitangent.z * ray_dir.y + normal.z * ray_dir.z,
            ).normalize();
            
            // Ray march
            let step_size = self.max_distance / self.ray_steps as f32;
            
            for step in 0..self.ray_steps {
                let t = (step as f32 + 0.5) * step_size;
                let sample_pos = position.add(&world_dir.scale(t));
                
                // Project to screen
                let sample_uv = self.project_to_screen(&sample_pos, ctx);
                
                if sample_uv.x < 0.0 || sample_uv.x > 1.0 || sample_uv.y < 0.0 || sample_uv.y > 1.0 {
                    continue;
                }
                
                // Check depth
                let scene_depth = depth_buffer.sample(sample_uv).r;
                let ray_depth = self.compute_depth(&sample_pos, ctx);
                
                if ray_depth > scene_depth && ray_depth < scene_depth + self.thickness {
                    // Hit! Sample color
                    let hit_color = color_buffer.sample(sample_uv);
                    let attenuation = 1.0 / (1.0 + t * t);
                    
                    indirect = RGB::new(
                        indirect.r + hit_color.r * attenuation,
                        indirect.g + hit_color.g * attenuation,
                        indirect.b + hit_color.b * attenuation,
                    );
                    break;
                }
            }
        }
        
        // Average and apply intensity
        RGB::new(
            indirect.r * self.intensity / self.ray_count as f32,
            indirect.g * self.intensity / self.ray_count as f32,
            indirect.b * self.intensity / self.ray_count as f32,
        )
    }
    
    fn project_to_screen(&self, world_pos: &Vec3, ctx: &PostProcessContext) -> Vec2 {
        Vec2::new(
            (world_pos.x / world_pos.z + 1.0) * 0.5,
            (world_pos.y / world_pos.z + 1.0) * 0.5,
        )
    }
    
    fn compute_depth(&self, world_pos: &Vec3, ctx: &PostProcessContext) -> f32 {
        -world_pos.z // Simplified
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BLOOM
// ═══════════════════════════════════════════════════════════════════════════════

/// Physically-based bloom effect
pub struct Bloom {
    pub enabled: bool,
    pub threshold: f32,
    pub soft_threshold: f32,
    pub intensity: f32,
    pub radius: f32,
    pub mip_levels: u32,
}

impl Bloom {
    pub fn new() -> Self {
        Bloom {
            enabled: true,
            threshold: 1.0,
            soft_threshold: 0.5,
            intensity: 1.0,
            radius: 1.0,
            mip_levels: 5,
        }
    }
    
    /// Extract bright pixels
    pub fn extract_bright(&self, color: RGB) -> RGB {
        if !self.enabled {
            return RGB::black();
        }
        
        let brightness = 0.2126 * color.r + 0.7152 * color.g + 0.0722 * color.b;
        
        // Soft knee threshold
        let knee = self.threshold * self.soft_threshold;
        let soft = brightness - self.threshold + knee;
        let soft = clamp(soft, 0.0, 2.0 * knee);
        let soft = soft * soft / (4.0 * knee + 0.00001);
        
        let contribution = max(soft, brightness - self.threshold) / max(brightness, 0.00001);
        
        RGB::new(
            color.r * contribution,
            color.g * contribution,
            color.b * contribution,
        )
    }
    
    /// Blur pass (separable Gaussian)
    pub fn blur_horizontal(&self, uv: Vec2, source: &Texture2D, texel_size: f32) -> RGB {
        let weights = [0.227027, 0.1945946, 0.1216216, 0.054054, 0.016216];
        let offsets = [0.0, 1.0, 2.0, 3.0, 4.0];
        
        let mut result = source.sample(uv).scale(weights[0]);
        
        for i in 1..5 {
            let offset = offsets[i] * texel_size * self.radius;
            let sample_left = source.sample(Vec2::new(uv.x - offset, uv.y));
            let sample_right = source.sample(Vec2::new(uv.x + offset, uv.y));
            
            result = RGB::new(
                result.r + (sample_left.r + sample_right.r) * weights[i],
                result.g + (sample_left.g + sample_right.g) * weights[i],
                result.b + (sample_left.b + sample_right.b) * weights[i],
            );
        }
        
        result
    }
    
    pub fn blur_vertical(&self, uv: Vec2, source: &Texture2D, texel_size: f32) -> RGB {
        let weights = [0.227027, 0.1945946, 0.1216216, 0.054054, 0.016216];
        let offsets = [0.0, 1.0, 2.0, 3.0, 4.0];
        
        let mut result = source.sample(uv).scale(weights[0]);
        
        for i in 1..5 {
            let offset = offsets[i] * texel_size * self.radius;
            let sample_up = source.sample(Vec2::new(uv.x, uv.y - offset));
            let sample_down = source.sample(Vec2::new(uv.x, uv.y + offset));
            
            result = RGB::new(
                result.r + (sample_up.r + sample_down.r) * weights[i],
                result.g + (sample_up.g + sample_down.g) * weights[i],
                result.b + (sample_up.b + sample_down.b) * weights[i],
            );
        }
        
        result
    }
    
    /// Combine bloom with original
    pub fn composite(&self, original: RGB, bloom: RGB) -> RGB {
        RGB::new(
            original.r + bloom.r * self.intensity,
            original.g + bloom.g * self.intensity,
            original.b + bloom.b * self.intensity,
        )
    }
}

impl RGB {
    fn scale(&self, s: f32) -> RGB {
        RGB::new(self.r * s, self.g * s, self.b * s)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPTH OF FIELD
// ═══════════════════════════════════════════════════════════════════════════════

/// Cinematic depth of field with bokeh
pub struct DepthOfField {
    pub enabled: bool,
    pub focus_distance: f32,
    pub aperture: f32,          // f-stop
    pub focal_length: f32,      // mm
    pub sensor_height: f32,     // mm
    pub max_blur: f32,
    pub bokeh_shape: BokehShape,
    pub samples: u32,
}

#[derive(Debug, Clone, Copy)]
pub enum BokehShape {
    Circle,
    Hexagon,
    Octagon,
}

impl DepthOfField {
    pub fn new() -> Self {
        DepthOfField {
            enabled: true,
            focus_distance: 5.0,
            aperture: 2.8,
            focal_length: 50.0,
            sensor_height: 24.0,
            max_blur: 10.0,
            bokeh_shape: BokehShape::Circle,
            samples: 32,
        }
    }
    
    /// Calculate circle of confusion radius
    pub fn coc(&self, depth: f32) -> f32 {
        let f = self.focal_length;
        let n = self.aperture;
        let s = self.focus_distance * 1000.0; // Convert to mm
        let d = depth * 1000.0;
        
        // CoC formula
        let coc = abs(f * f * (s - d)) / (n * d * (s - f));
        
        // Convert to pixels (assuming some sensor/resolution)
        let coc_pixels = coc / self.sensor_height * 1080.0;
        
        clamp(coc_pixels, 0.0, self.max_blur)
    }
    
    /// Apply DoF blur
    pub fn apply(
        &self,
        uv: Vec2,
        color_buffer: &Texture2D,
        depth_buffer: &Texture2D,
        ctx: &PostProcessContext,
    ) -> RGB {
        if !self.enabled {
            return color_buffer.sample(uv);
        }
        
        let depth = self.linear_depth(
            depth_buffer.sample(uv).r,
            ctx.near_plane,
            ctx.far_plane,
        );
        
        let blur_radius = self.coc(depth);
        
        if blur_radius < 0.5 {
            return color_buffer.sample(uv);
        }
        
        // Bokeh sampling
        let mut result = RGB::black();
        let mut weight_sum = 0.0;
        
        let texel_size = Vec2::new(
            1.0 / ctx.screen_width as f32,
            1.0 / ctx.screen_height as f32,
        );
        
        for i in 0..self.samples {
            let angle = 2.0 * PI * i as f32 / self.samples as f32;
            let radius_scale = (i as f32 + 1.0) / self.samples as f32;
            
            let offset = match self.bokeh_shape {
                BokehShape::Circle => {
                    Vec2::new(cos(angle), sin(angle)).scale(radius_scale * blur_radius)
                }
                BokehShape::Hexagon => {
                    // Map to hexagonal shape
                    let hex_angle = (angle * 3.0 / PI).floor() * PI / 3.0;
                    let hex_factor = cos(PI / 6.0) / cos(angle - hex_angle - PI / 6.0);
                    Vec2::new(cos(angle), sin(angle)).scale(radius_scale * blur_radius * hex_factor)
                }
                BokehShape::Octagon => {
                    let oct_angle = (angle * 4.0 / PI).floor() * PI / 4.0;
                    let oct_factor = cos(PI / 8.0) / cos(angle - oct_angle - PI / 8.0);
                    Vec2::new(cos(angle), sin(angle)).scale(radius_scale * blur_radius * oct_factor)
                }
            };
            
            let sample_uv = Vec2::new(
                uv.x + offset.x * texel_size.x,
                uv.y + offset.y * texel_size.y,
            );
            
            let sample_color = color_buffer.sample(sample_uv);
            let sample_depth = self.linear_depth(
                depth_buffer.sample(sample_uv).r,
                ctx.near_plane,
                ctx.far_plane,
            );
            
            let sample_coc = self.coc(sample_depth);
            let weight = if sample_coc >= blur_radius || sample_depth > depth { 1.0 } else { 0.1 };
            
            result = RGB::new(
                result.r + sample_color.r * weight,
                result.g + sample_color.g * weight,
                result.b + sample_color.b * weight,
            );
            weight_sum += weight;
        }
        
        RGB::new(
            result.r / weight_sum,
            result.g / weight_sum,
            result.b / weight_sum,
        )
    }
    
    fn linear_depth(&self, depth: f32, near: f32, far: f32) -> f32 {
        near * far / (far + depth * (near - far))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOTION BLUR
// ═══════════════════════════════════════════════════════════════════════════════

/// Per-object and camera motion blur
pub struct MotionBlur {
    pub enabled: bool,
    pub intensity: f32,
    pub samples: u32,
    pub max_blur: f32,
}

impl MotionBlur {
    pub fn new() -> Self {
        MotionBlur {
            enabled: true,
            intensity: 1.0,
            samples: 16,
            max_blur: 20.0,
        }
    }
    
    /// Apply motion blur using velocity buffer
    pub fn apply(
        &self,
        uv: Vec2,
        color_buffer: &Texture2D,
        velocity_buffer: &Texture2D,
        ctx: &PostProcessContext,
    ) -> RGB {
        if !self.enabled {
            return color_buffer.sample(uv);
        }
        
        // Sample velocity
        let velocity_sample = velocity_buffer.sample(uv);
        let velocity = Vec2::new(
            (velocity_sample.r * 2.0 - 1.0) * self.intensity,
            (velocity_sample.g * 2.0 - 1.0) * self.intensity,
        );
        
        let blur_length = velocity.length().min(self.max_blur / ctx.screen_width as f32);
        
        if blur_length < 0.001 {
            return color_buffer.sample(uv);
        }
        
        let blur_dir = velocity.normalize();
        let step = blur_dir.scale(blur_length / self.samples as f32);
        
        let mut result = RGB::black();
        
        for i in 0..self.samples {
            let t = (i as f32 / (self.samples - 1) as f32) - 0.5;
            let sample_uv = uv.add(&step.scale(t * self.samples as f32));
            
            let sample = color_buffer.sample(sample_uv);
            result = RGB::new(
                result.r + sample.r,
                result.g + sample.g,
                result.b + sample.b,
            );
        }
        
        result.scale(1.0 / self.samples as f32)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CHROMATIC ABERRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ChromaticAberration {
    pub enabled: bool,
    pub intensity: f32,
}

impl ChromaticAberration {
    pub fn new() -> Self {
        ChromaticAberration {
            enabled: true,
            intensity: 0.005,
        }
    }
    
    pub fn apply(&self, uv: Vec2, color_buffer: &Texture2D) -> RGB {
        if !self.enabled {
            return color_buffer.sample(uv);
        }
        
        let center = Vec2::new(0.5, 0.5);
        let dir = uv.sub(&center);
        let dist = dir.length();
        
        let offset = dir.scale(self.intensity * dist);
        
        let r = color_buffer.sample(uv.add(&offset)).r;
        let g = color_buffer.sample(uv).g;
        let b = color_buffer.sample(uv.sub(&offset)).b;
        
        RGB::new(r, g, b)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILM GRAIN
// ═══════════════════════════════════════════════════════════════════════════════

pub struct FilmGrain {
    pub enabled: bool,
    pub intensity: f32,
    pub response: f32,
}

impl FilmGrain {
    pub fn new() -> Self {
        FilmGrain {
            enabled: true,
            intensity: 0.05,
            response: 0.8,
        }
    }
    
    pub fn apply(&self, uv: Vec2, color: RGB, time: f32) -> RGB {
        if !self.enabled {
            return color;
        }
        
        // Generate noise
        let noise = self.hash(Vec3::new(uv.x * 1000.0, uv.y * 1000.0, time * 100.0));
        let noise = (noise - 0.5) * self.intensity;
        
        // Luminance-based response (more grain in midtones)
        let luma = 0.2126 * color.r + 0.7152 * color.g + 0.0722 * color.b;
        let response = 1.0 - abs(luma - 0.5) * 2.0 * self.response;
        
        RGB::new(
            color.r + noise * response,
            color.g + noise * response,
            color.b + noise * response,
        )
    }
    
    fn hash(&self, p: Vec3) -> f32 {
        let p = Vec3::new(
            p.x.fract() * 443.8975,
            p.y.fract() * 397.2973,
            p.z.fract() * 491.1871,
        );
        let dot = p.x + p.y + p.z + p.x * p.y;
        ((dot + dot * p.z) * 1000.0).fract()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIGNETTE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct Vignette {
    pub enabled: bool,
    pub intensity: f32,
    pub smoothness: f32,
    pub roundness: f32,
}

impl Vignette {
    pub fn new() -> Self {
        Vignette {
            enabled: true,
            intensity: 0.4,
            smoothness: 0.5,
            roundness: 1.0,
        }
    }
    
    pub fn apply(&self, uv: Vec2, color: RGB) -> RGB {
        if !self.enabled {
            return color;
        }
        
        let coord = (uv.sub(&Vec2::new(0.5, 0.5))).scale(2.0);
        let dist = pow(
            pow(abs(coord.x), 2.0 / self.roundness) + 
            pow(abs(coord.y), 2.0 / self.roundness),
            self.roundness / 2.0
        );
        
        let vignette = smoothstep(1.0, 1.0 - self.smoothness, dist);
        let factor = 1.0 - (1.0 - vignette) * self.intensity;
        
        color.scale(factor)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SHARPENING
// ═══════════════════════════════════════════════════════════════════════════════

/// Contrast Adaptive Sharpening
pub struct CAS {
    pub enabled: bool,
    pub sharpness: f32,
}

impl CAS {
    pub fn new() -> Self {
        CAS {
            enabled: true,
            sharpness: 0.5,
        }
    }
    
    pub fn apply(&self, uv: Vec2, color_buffer: &Texture2D, texel_size: Vec2) -> RGB {
        if !self.enabled {
            return color_buffer.sample(uv);
        }
        
        // Sample neighborhood
        let c = color_buffer.sample(uv);
        let n = color_buffer.sample(Vec2::new(uv.x, uv.y - texel_size.y));
        let s = color_buffer.sample(Vec2::new(uv.x, uv.y + texel_size.y));
        let e = color_buffer.sample(Vec2::new(uv.x + texel_size.x, uv.y));
        let w = color_buffer.sample(Vec2::new(uv.x - texel_size.x, uv.y));
        
        // Compute min/max
        let min_rgb = RGB::new(
            c.r.min(n.r).min(s.r).min(e.r).min(w.r),
            c.g.min(n.g).min(s.g).min(e.g).min(w.g),
            c.b.min(n.b).min(s.b).min(e.b).min(w.b),
        );
        
        let max_rgb = RGB::new(
            c.r.max(n.r).max(s.r).max(e.r).max(w.r),
            c.g.max(n.g).max(s.g).max(e.g).max(w.g),
            c.b.max(n.b).max(s.b).max(e.b).max(w.b),
        );
        
        // Compute sharpening weight
        let d = max_rgb.r - min_rgb.r;
        let d = d.max(max_rgb.g - min_rgb.g).max(max_rgb.b - min_rgb.b);
        
        let w = self.sharpness / d.max(0.001);
        let w = w.min(0.0).max(-0.125);
        
        // Apply sharpening
        let sum = RGB::new(
            n.r + s.r + e.r + w.r,
            n.g + s.g + e.g + w.g,
            n.b + s.b + e.b + w.b,
        );
        
        RGB::new(
            (c.r + sum.r * w) / (1.0 + 4.0 * w),
            (c.g + sum.g * w) / (1.0 + 4.0 * w),
            (c.b + sum.b * w) / (1.0 + 4.0 * w),
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// POST-PROCESSING PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Complete post-processing pipeline
pub struct PostProcessPipeline {
    pub ssao: SSAO,
    pub ssgi: SSGI,
    pub bloom: Bloom,
    pub dof: DepthOfField,
    pub motion_blur: MotionBlur,
    pub chromatic_aberration: ChromaticAberration,
    pub film_grain: FilmGrain,
    pub vignette: Vignette,
    pub sharpening: CAS,
}

impl PostProcessPipeline {
    pub fn new() -> Self {
        PostProcessPipeline {
            ssao: SSAO::new(),
            ssgi: SSGI::new(),
            bloom: Bloom::new(),
            dof: DepthOfField::new(),
            motion_blur: MotionBlur::new(),
            chromatic_aberration: ChromaticAberration::new(),
            film_grain: FilmGrain::new(),
            vignette: Vignette::new(),
            sharpening: CAS::new(),
        }
    }
    
    /// Process a single pixel through the entire pipeline
    pub fn process(
        &self,
        uv: Vec2,
        color_buffer: &Texture2D,
        depth_buffer: &Texture2D,
        normal_buffer: &Texture2D,
        velocity_buffer: &Texture2D,
        bloom_buffer: &Texture2D,
        ctx: &PostProcessContext,
    ) -> RGB {
        let texel_size = Vec2::new(
            1.0 / ctx.screen_width as f32,
            1.0 / ctx.screen_height as f32,
        );
        
        // Start with original color
        let mut color = color_buffer.sample(uv);
        
        // 1. Motion blur
        color = self.motion_blur.apply(uv, color_buffer, velocity_buffer, ctx);
        
        // 2. Depth of field
        color = self.dof.apply(uv, color_buffer, depth_buffer, ctx);
        
        // 3. Add bloom
        let bloom_color = bloom_buffer.sample(uv);
        color = self.bloom.composite(color, bloom_color);
        
        // 4. Chromatic aberration
        color = self.chromatic_aberration.apply(uv, color_buffer);
        
        // 5. Sharpening
        color = self.sharpening.apply(uv, color_buffer, texel_size);
        
        // 6. Film grain
        color = self.film_grain.apply(uv, color, ctx.time);
        
        // 7. Vignette
        color = self.vignette.apply(uv, color);
        
        color
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_ssao() {
        let ssao = SSAO::new();
        assert_eq!(ssao.kernel.len(), 64);
        assert_eq!(ssao.noise.len(), 16);
    }
    
    #[test]
    fn test_bloom() {
        let bloom = Bloom::new();
        
        let bright = RGB::new(2.0, 2.0, 2.0);
        let extracted = bloom.extract_bright(bright);
        assert!(extracted.r > 0.0);
        
        let dark = RGB::new(0.1, 0.1, 0.1);
        let extracted = bloom.extract_bright(dark);
        assert!(extracted.r < 0.01);
    }
    
    #[test]
    fn test_dof_coc() {
        let dof = DepthOfField::new();
        
        let coc_focus = dof.coc(dof.focus_distance);
        let coc_far = dof.coc(dof.focus_distance * 2.0);
        
        assert!(coc_focus < coc_far);
    }
    
    #[test]
    fn test_pipeline() {
        let pipeline = PostProcessPipeline::new();
        assert!(pipeline.ssao.enabled);
        assert!(pipeline.bloom.enabled);
    }
}
