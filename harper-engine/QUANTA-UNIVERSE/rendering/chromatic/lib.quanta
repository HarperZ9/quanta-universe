// GPU-OPTIMIZED FAST PATH
// ═══════════════════════════════════════════════════════════════════════════════

/// Fast approximation of Genesis Symmetric (for real-time use)
pub mod fast {
    use super::*;
    
    /// Fast sRGB to Genesis Symmetric (polynomial approximation)
    pub fn srgb_to_genesis_fast(r: f32, g: f32, b: f32) -> (f32, f32, f32) {
        // Approximate linear conversion
        let r_lin = srgb_to_linear_fast(r);
        let g_lin = srgb_to_linear_fast(g);
        let b_lin = srgb_to_linear_fast(b);
        
        // Simplified XYZ
        let y = 0.2126 * r_lin + 0.7152 * g_lin + 0.0722 * b_lin;
        
        // Fast lightness
        let L = if y <= 0.008856 {
            903.3 * y
        } else {
            116.0 * fast_cbrt(y) - 16.0
        } as f32;
        
        // Simplified opponent channels
        let a = ((r_lin - g_lin) * 100.0) as f32;
        let b_ch = ((0.5 * (r_lin + g_lin) - b_lin) * 100.0) as f32;
        
        (L, a, b_ch)
    }
    
    /// Fast Genesis Symmetric to sRGB
    pub fn genesis_to_srgb_fast(L: f32, a: f32, b: f32) -> (f32, f32, f32) {
        // Inverse lightness
        let y = if L <= 8.0 {
            L as f64 / 903.3
        } else {
            pow((L as f64 + 16.0) / 116.0, 3.0)
        };
        
        // Inverse opponent (approximate)
        let r_lin = (y + a as f64 / 100.0).max(0.0).min(1.0);
        let g_lin = (y - a as f64 / 100.0).max(0.0).min(1.0);
        let b_lin = (y - b as f64 / 100.0).max(0.0).min(1.0);
        
        (
            linear_to_srgb_fast(r_lin as f32),
            linear_to_srgb_fast(g_lin as f32),
            linear_to_srgb_fast(b_lin as f32),
        )
    }
    
    fn srgb_to_linear_fast(x: f32) -> f64 {
        if x <= 0.04045 {
            x as f64 / 12.92
        } else {
            pow((x as f64 + 0.055) / 1.055, 2.4)
        }
    }
    
    fn linear_to_srgb_fast(x: f32) -> f32 {
        if x <= 0.0031308 {
            (x * 12.92) as f32
        } else {
            (1.055 * pow(x as f64, 1.0 / 2.4) - 0.055) as f32
        }
    }
    
    fn fast_cbrt(x: f64) -> f64 {
        // Fast cube root using Newton-Raphson
        if x == 0.0 { return 0.0; }
        let mut y = x;
        for _ in 0..4 {
            y = (2.0 * y + x / (y * y)) / 3.0;
        }
        y
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR PALETTE GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Generate perceptually uniform color palette
pub fn generate_palette(base: GenesisSymmetric, count: usize) -> Vec<GenesisSymmetric> {
    let lch = base.to_lch();
    let mut palette = Vec::with_capacity(count);
    
    for i in 0..count {
        let h = (lch.h + (360.0 * i as f64 / count as f64)) % 360.0;
        let color = GenesisSymmetric::from_lch(GenesisLCH {
            L: lch.L,
            C: lch.C,
            h,
        });
        palette.push(color.gamut_map_srgb());
    }
    
    palette
}

/// Generate lightness ramp (grayscale gradient)
pub fn generate_lightness_ramp(steps: usize) -> Vec<GenesisSymmetric> {
    (0..steps)
        .map(|i| GenesisSymmetric::new(100.0 * i as f64 / (steps - 1) as f64, 0.0, 0.0))
        .collect()
}

// ═══════════════════════════════════════════════════════════════════════════════
// ACCESSIBILITY FEATURES
// ═══════════════════════════════════════════════════════════════════════════════

/// Color vision deficiency simulation types
#[derive(Debug, Clone, Copy)]
pub enum ColorBlindnessType {
    Protanopia,    // Red-blind
    Deuteranopia,  // Green-blind
    Tritanopia,    // Blue-blind
    Achromatopsia, // Complete color blindness
}

/// Simulate how a color appears to someone with color blindness
pub fn simulate_color_blindness(color: GenesisSymmetric, cvd_type: ColorBlindnessType) -> GenesisSymmetric {
    let rgb = color.to_linear_rgb();
    
    let simulated = match cvd_type {
        ColorBlindnessType::Protanopia => {
            LinearRGB {
                r: 0.567 * rgb.r + 0.433 * rgb.g + 0.000 * rgb.b,
                g: 0.558 * rgb.r + 0.442 * rgb.g + 0.000 * rgb.b,
                b: 0.000 * rgb.r + 0.242 * rgb.g + 0.758 * rgb.b,
            }
        }
        ColorBlindnessType::Deuteranopia => {
            LinearRGB {
                r: 0.625 * rgb.r + 0.375 * rgb.g + 0.000 * rgb.b,
                g: 0.700 * rgb.r + 0.300 * rgb.g + 0.000 * rgb.b,
                b: 0.000 * rgb.r + 0.300 * rgb.g + 0.700 * rgb.b,
            }
        }
        ColorBlindnessType::Tritanopia => {
            LinearRGB {
                r: 0.950 * rgb.r + 0.050 * rgb.g + 0.000 * rgb.b,
                g: 0.000 * rgb.r + 0.433 * rgb.g + 0.567 * rgb.b,
                b: 0.000 * rgb.r + 0.475 * rgb.g + 0.525 * rgb.b,
            }
        }
        ColorBlindnessType::Achromatopsia => {
            let gray = 0.299 * rgb.r + 0.587 * rgb.g + 0.114 * rgb.b;
            LinearRGB { r: gray, g: gray, b: gray }
        }
    };
    
    GenesisSymmetric::from_linear_rgb(simulated)
}

/// Check if two colors have sufficient contrast for accessibility (WCAG)
pub fn contrast_ratio(color1: GenesisSymmetric, color2: GenesisSymmetric) -> f64 {
    let l1 = inverse_genesis_lightness(color1.L);
    let l2 = inverse_genesis_lightness(color2.L);
    
    let lighter = l1.max(l2);
    let darker = l1.min(l2);
    
    (lighter + 0.05) / (darker + 0.05)
}

/// WCAG conformance levels
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum WCAGLevel {
    Fail,
    AA_Large,      // 3:1 for large text
    AA,            // 4.5:1 for normal text
    AAA_Large,     // 4.5:1 for large text (AAA)
    AAA,           // 7:1 for normal text (AAA)
}

pub fn wcag_conformance(color1: GenesisSymmetric, color2: GenesisSymmetric) -> WCAGLevel {
    let ratio = contrast_ratio(color1, color2);
    
    if ratio >= 7.0 {
        WCAGLevel::AAA
    } else if ratio >= 4.5 {
        WCAGLevel::AA
    } else if ratio >= 3.0 {
        WCAGLevel::AA_Large
    } else {
        WCAGLevel::Fail
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_roundtrip() {
        let original = LinearRGB { r: 0.5, g: 0.3, b: 0.8 };
        let genesis = GenesisSymmetric::from_linear_rgb(original);
        let recovered = genesis.to_linear_rgb();
        
        assert!((original.r - recovered.r).abs() < 0.01);
        assert!((original.g - recovered.g).abs() < 0.01);
        assert!((original.b - recovered.b).abs() < 0.01);
    }
    
    #[test]
    fn test_lightness_symmetry() {
        // Mid-gray should be at L=50
        let mid_gray = LinearRGB { r: 0.18, g: 0.18, b: 0.18 };
        let genesis = GenesisSymmetric::from_linear_rgb(mid_gray);
        assert!((genesis.L - 50.0).abs() < 5.0);
    }
    
    #[test]
    fn test_delta_e() {
        let white = GenesisSymmetric::white();
        let black = GenesisSymmetric::black();
        let delta = white.delta_e(&black);
        assert!(delta > 95.0 && delta < 105.0);
    }
    
    #[test]
    fn test_gamut_mapping() {
        // Out of gamut color
        let out_of_gamut = GenesisSymmetric::new(50.0, 200.0, 0.0);
        let mapped = out_of_gamut.gamut_map_srgb();
        assert!(mapped.in_srgb_gamut());
    }
    
    #[test]
    fn test_contrast_ratio() {
        let white = GenesisSymmetric::white();
        let black = GenesisSymmetric::black();
        let ratio = contrast_ratio(white, black);
        assert!(ratio > 20.0);
    }
}
