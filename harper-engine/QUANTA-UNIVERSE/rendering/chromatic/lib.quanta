// CORE COLOR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Linear RGB color (scene-referred)
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct LinearRGB {
    pub r: f64,
    pub g: f64,
    pub b: f64,
}

/// CIE XYZ tristimulus values
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct XYZ {
    pub x: f64,
    pub y: f64,
    pub z: f64,
}

/// CIE xyY chromaticity + luminance
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct xyY {
    pub x: f64,
    pub y: f64,
    pub Y: f64,
}

/// CIE L*a*b* (reference, not perceptually uniform)
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct Lab {
    pub L: f64,
    pub a: f64,
    pub b: f64,
}

/// Genesis Symmetric Color Space - Our proprietary perceptually uniform space
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct GenesisSymmetric {
    /// Lightness (0-100, perceptually linear)
    pub L: f64,
    /// Red-Green opponent channel
    pub a: f64,
    /// Yellow-Blue opponent channel  
    pub b: f64,
}

/// Genesis Symmetric Cylindrical (LCH-like)
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct GenesisLCH {
    /// Lightness (0-100)
    pub L: f64,
    /// Chroma (saturation, unbounded positive)
    pub C: f64,
    /// Hue angle (0-360 degrees)
    pub h: f64,
}

