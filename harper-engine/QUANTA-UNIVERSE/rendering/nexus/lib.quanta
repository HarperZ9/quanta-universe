// GAME DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Known game engine signatures
#[derive(Debug, Clone)]
pub struct GameSignature {
    pub id: String,
    pub name: String,
    pub engine: GameEngine,
    pub executable_patterns: Vec<String>,
    pub file_signatures: Vec<(String, Vec<u8>)>,
    pub registry_keys: Vec<String>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum GameEngine {
    Unity,
    UnrealEngine4,
    UnrealEngine5,
    CryEngine,
    IdTech,
    Source,
    Source2,
    Frostbite,
    REDEngine,
    CreationEngine,
    Proprietary,
    Unknown,
}

/// Game detector
pub struct GameDetector {
    signatures: Vec<GameSignature>,
}

impl GameDetector {
    pub fn new() -> Self {
        let mut detector = GameDetector {
            signatures: Vec::new(),
        };
        detector.load_default_signatures();
        detector
    }
    
    fn load_default_signatures(&mut self) {
        // Unity games
        self.signatures.push(GameSignature {
            id: "unity_generic".to_string(),
            name: "Unity Game".to_string(),
            engine: GameEngine::Unity,
            executable_patterns: vec!["*.exe".to_string()],
            file_signatures: vec![
                ("UnityPlayer.dll".to_string(), vec![]),
                ("*_Data/Managed/Assembly-CSharp.dll".to_string(), vec![]),
            ],
            registry_keys: vec![],
        });
        
        // Unreal Engine 4
        self.signatures.push(GameSignature {
            id: "ue4_generic".to_string(),
            name: "Unreal Engine 4 Game".to_string(),
            engine: GameEngine::UnrealEngine4,
            executable_patterns: vec!["*-Win64-Shipping.exe".to_string()],
            file_signatures: vec![
                ("Engine/Binaries/ThirdParty/Steamworks/".to_string(), vec![]),
            ],
            registry_keys: vec![],
        });
        
        // Add more signatures...
    }
    
    /// Detect game from executable path
    pub fn detect(&self, exe_path: &str) -> Option<GameSignature> {
        for sig in &self.signatures {
            if self.matches_signature(exe_path, sig) {
                return Some(sig.clone());
            }
        }
        None
    }
    
    fn matches_signature(&self, exe_path: &str, sig: &GameSignature) -> bool {
        // Check executable patterns
        for pattern in &sig.executable_patterns {
            if self.glob_match(exe_path, pattern) {
                return true;
            }
        }
        false
    }
    
    fn glob_match(&self, path: &str, pattern: &str) -> bool {
        // Simple glob matching
        if pattern == "*" { return true; }
        if pattern.starts_with("*.") {
            let ext = &pattern[2..];
            return path.ends_with(ext);
        }
        path.contains(&pattern.replace("*", ""))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD LOADER
// ═══════════════════════════════════════════════════════════════════════════════

/// Mod loader state
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum LoaderState {
    Uninitialized,
    Initializing,
    Ready,
    Loading,
    Active,
    Unloading,
    Error,
}

/// Events from the mod loader
#[derive(Debug, Clone)]
pub enum ModLoaderEvent {
    ModLoaded(String),
    ModUnloaded(String),
    ModError(String, String),
    ProfileActivated(String),
    ConflictDetected(ModConflict),
    HotReloadTriggered(String),
}

/// Main mod loader
pub struct ModLoader {
    state: LoaderState,
    game_info: Option<GameInfo>,
    hook: UniversalHook,
    resolver: DependencyResolver,
    conflict_detector: ConflictDetector,
    profile_manager: ProfileManager,
    loaded_mods: Vec<String>,
    event_queue: Vec<ModLoaderEvent>,
    hot_reload_enabled: bool,
}

impl ModLoader {
    pub fn new() -> Self {
        ModLoader {
            state: LoaderState::Uninitialized,
            game_info: None,
            hook: UniversalHook::new(),
            resolver: DependencyResolver::new(),
            conflict_detector: ConflictDetector::new(),
            profile_manager: ProfileManager::new(),
            loaded_mods: Vec::new(),
            event_queue: Vec::new(),
            hot_reload_enabled: true,
        }
    }
    
    /// Initialize the mod loader
    pub fn initialize(&mut self) -> Result<(), ModLoaderError> {
        self.state = LoaderState::Initializing;
        
        // Detect graphics API
        self.hook.detect_api()
            .ok_or(ModLoaderError::NoGraphicsAPI)?;
        
        // Install hooks
        self.hook.install_hooks()
            .map_err(|_| ModLoaderError::HookInstallFailed)?;
        
        self.state = LoaderState::Ready;
        Ok(())
    }
    
    /// Register a mod package
    pub fn register_mod(&mut self, pkg: ModPackage) {
        let id = pkg.metadata.id.clone();
        self.resolver.add_mod(pkg.clone());
        self.conflict_detector.add_mod(pkg);
    }
    
    /// Load mods from active profile
    pub fn load_profile_mods(&mut self) -> Result<(), ModLoaderError> {
        let profile = self.profile_manager.get_active()
            .ok_or(ModLoaderError::NoActiveProfile)?;
        
        let enabled_mods = profile.enabled_mods.clone();
        
        // Check for conflicts
        let conflicts = self.conflict_detector.detect_conflicts(&enabled_mods);
        let critical = conflicts.iter()
            .any(|c| c.severity == ConflictSeverity::Critical);
        
        if critical {
            for conflict in conflicts {
                self.event_queue.push(ModLoaderEvent::ConflictDetected(conflict));
            }
            return Err(ModLoaderError::CriticalConflict);
        }
        
        // Resolve dependencies
        match self.resolver.resolve(&enabled_mods) {
            DependencyResult::Resolved(order) => {
                self.state = LoaderState::Loading;
                
                for mod_id in order {
                    self.load_mod(&mod_id)?;
                }
                
                self.state = LoaderState::Active;
                Ok(())
            }
            DependencyResult::MissingDependencies(missing) => {
                Err(ModLoaderError::MissingDependencies(missing))
            }
            DependencyResult::CyclicDependency(cycle) => {
                Err(ModLoaderError::CyclicDependency(cycle))
            }
            DependencyResult::VersionConflict { mod_id, required, available } => {
                Err(ModLoaderError::VersionMismatch { mod_id, required, available })
            }
        }
    }
    
    fn load_mod(&mut self, mod_id: &str) -> Result<(), ModLoaderError> {
        // Would actually load the mod here
        self.loaded_mods.push(mod_id.to_string());
        self.event_queue.push(ModLoaderEvent::ModLoaded(mod_id.to_string()));
        Ok(())
    }
    
    /// Unload all mods
    pub fn unload_all(&mut self) {
        self.state = LoaderState::Unloading;
        
        for mod_id in self.loaded_mods.drain(..).rev() {
            self.event_queue.push(ModLoaderEvent::ModUnloaded(mod_id));
        }
        
        self.state = LoaderState::Ready;
    }
    
    /// Hot reload a specific mod
    pub fn hot_reload(&mut self, mod_id: &str) -> Result<(), ModLoaderError> {
        if !self.hot_reload_enabled {
            return Err(ModLoaderError::HotReloadDisabled);
        }
        
        if !self.loaded_mods.contains(&mod_id.to_string()) {
            return Err(ModLoaderError::ModNotLoaded(mod_id.to_string()));
        }
        
        self.event_queue.push(ModLoaderEvent::HotReloadTriggered(mod_id.to_string()));
        
        // Would actually reload the mod here
        
        Ok(())
    }
    
    /// Get pending events
    pub fn poll_events(&mut self) -> Vec<ModLoaderEvent> {
        std::mem::take(&mut self.event_queue)
    }
    
    pub fn state(&self) -> LoaderState {
        self.state
    }
    
    pub fn loaded_mods(&self) -> &[String] {
        &self.loaded_mods
    }
}

#[derive(Debug)]
pub enum ModLoaderError {
    NoGraphicsAPI,
    HookInstallFailed,
    NoActiveProfile,
    CriticalConflict,
    MissingDependencies(Vec<String>),
    CyclicDependency(Vec<String>),
    VersionMismatch { mod_id: String, required: Version, available: Version },
    HotReloadDisabled,
    ModNotLoaded(String),
    FileNotFound(String),
    InvalidModPackage(String),
}

