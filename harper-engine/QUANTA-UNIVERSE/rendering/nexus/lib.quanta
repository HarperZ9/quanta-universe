/// Mod category
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum ModCategory {
    Graphics,       // Visual enhancements
    Gameplay,       // Game mechanics changes
    UI,             // User interface modifications
    Audio,          // Sound and music
    Content,        // New content (maps, items, etc.)
    Fix,            // Bug fixes and patches
    Cheat,          // Cheats and trainers
    Utility,        // Tools and utilities
    Framework,      // Modding frameworks (required by other mods)
}

/// Mod compatibility status
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum CompatibilityStatus {
    Compatible,
    PartiallyCompatible(f32),  // Percentage of features working
    Incompatible,
    Unknown,
    RequiresTesting,
}

/// Mod load order priority
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum LoadPriority {
    Framework = 0,    // Load first (other mods depend on these)
    Early = 1,        // Load early
    Normal = 2,       // Default priority
    Late = 3,         // Load late
    Override = 4,     // Load last (overrides everything)
}

/// Semantic version
#[derive(Debug, Clone, PartialEq, Eq, PartialOrd, Ord)]
pub struct Version {
    pub major: u32,
    pub minor: u32,
    pub patch: u32,
}

impl Version {
    pub fn new(major: u32, minor: u32, patch: u32) -> Self {
        Version { major, minor, patch }
    }
    
    pub fn parse(s: &str) -> Option<Self> {
        let parts: Vec<&str> = s.split('.').collect();
        if parts.len() >= 3 {
            Some(Version {
                major: parts[0].parse().ok()?,
                minor: parts[1].parse().ok()?,
                patch: parts[2].parse().ok()?,
            })
        } else {
            None
        }
    }
    
    pub fn to_string(&self) -> String {
        format!("{}.{}.{}", self.major, self.minor, self.patch)
    }
    
    pub fn is_compatible(&self, other: &Version) -> bool {
        self.major == other.major
    }
}

/// Mod metadata
#[derive(Debug, Clone)]
pub struct ModMetadata {
    pub id: String,
    pub name: String,
    pub description: String,
    pub version: Version,
    pub author: String,
    pub website: Option<String>,
    pub category: ModCategory,
    pub priority: LoadPriority,
    pub dependencies: Vec<ModDependency>,
    pub conflicts: Vec<String>,
    pub supported_games: Vec<String>,  // Empty = all games
    pub tags: Vec<String>,
    pub screenshots: Vec<String>,
    pub changelog: Vec<ChangelogEntry>,
}

#[derive(Debug, Clone)]
pub struct ModDependency {
    pub mod_id: String,
    pub min_version: Option<Version>,
    pub max_version: Option<Version>,
    pub optional: bool,
}

#[derive(Debug, Clone)]
pub struct ChangelogEntry {
    pub version: Version,
    pub date: String,
    pub changes: Vec<String>,
}

impl ModMetadata {
    pub fn new(id: &str, name: &str, version: Version) -> Self {
        ModMetadata {
            id: id.to_string(),
            name: name.to_string(),
            description: String::new(),
            version,
            author: String::new(),
            website: None,
            category: ModCategory::Gameplay,
            priority: LoadPriority::Normal,
            dependencies: Vec::new(),
            conflicts: Vec::new(),
            supported_games: Vec::new(),
            tags: Vec::new(),
            screenshots: Vec::new(),
            changelog: Vec::new(),
        }
    }
}

