// MOD REPOSITORY
// ═══════════════════════════════════════════════════════════════════════════════

/// Remote mod repository
pub struct ModRepository {
    pub name: String,
    pub url: String,
    pub api_version: u32,
    cached_index: Option<Vec<ModMetadata>>,
}

impl ModRepository {
    pub fn new(name: &str, url: &str) -> Self {
        ModRepository {
            name: name.to_string(),
            url: url.to_string(),
            api_version: 1,
            cached_index: None,
        }
    }
    
    /// Search for mods
    pub fn search(&self, query: &str, category: Option<ModCategory>) -> Vec<ModMetadata> {
        // Would actually query the remote repository
        Vec::new()
    }
    
    /// Download a mod
    pub fn download(&self, mod_id: &str, version: Option<Version>) -> Result<ModPackage, RepositoryError> {
        // Would actually download from repository
        Err(RepositoryError::NotFound(mod_id.to_string()))
    }
}

#[derive(Debug)]
pub enum RepositoryError {
    NetworkError(String),
    NotFound(String),
    VersionNotFound(String, Version),
    Unauthorized,
    RateLimited,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_version_comparison() {
        let v1 = Version::new(1, 0, 0);
        let v2 = Version::new(1, 1, 0);
        let v3 = Version::new(2, 0, 0);
        
        assert!(v1 < v2);
        assert!(v2 < v3);
        assert!(v1.is_compatible(&v2));
        assert!(!v1.is_compatible(&v3));
    }
    
    #[test]
    fn test_dependency_resolution() {
        let mut resolver = DependencyResolver::new();
        
        let mut mod_a = ModPackage::new(ModMetadata::new("mod_a", "Mod A", Version::new(1, 0, 0)));
        mod_a.metadata.dependencies.push(ModDependency {
            mod_id: "mod_b".to_string(),
            min_version: None,
            max_version: None,
            optional: false,
        });
        
        let mod_b = ModPackage::new(ModMetadata::new("mod_b", "Mod B", Version::new(1, 0, 0)));
        
        resolver.add_mod(mod_a);
        resolver.add_mod(mod_b);
        
        match resolver.resolve(&["mod_a".to_string()]) {
            DependencyResult::Resolved(order) => {
                assert!(order.iter().position(|m| m == "mod_b") < order.iter().position(|m| m == "mod_a"));
            }
            _ => panic!("Should resolve successfully"),
        }
    }
    
    #[test]
    fn test_profile_management() {
        let mut manager = ProfileManager::new();
        
        let profile_id = manager.create_profile("Test Profile", "game_1");
        assert!(manager.activate_profile(&profile_id));
        
        if let Some(profile) = manager.get_active_mut() {
            profile.enable_mod("mod_1");
            profile.enable_mod("mod_2");
            assert_eq!(profile.enabled_mods.len(), 2);
        }
    }
}
