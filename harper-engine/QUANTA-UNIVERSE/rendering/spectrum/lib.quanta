// COLOR SPACE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// 5-Tier Precision System
/// Each tier provides increasing color accuracy at computational cost
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum PrecisionTier {
    /// Compatible: 45.8% sRGB coverage, fast, mobile-friendly
    Compatible,
    /// Standard: 63.2% DCI-P3 coverage, balanced
    Standard,
    /// Professional: 75.2% Adobe RGB coverage, high quality
    Professional,
    /// Maximum: 87.5% Rec.2020 coverage, broadcast quality
    Maximum,
    /// Absolute: 100% spectral accuracy, reference grade
    Absolute,
}

impl PrecisionTier {
    pub fn gamut_coverage(&self) -> f32 {
        match self {
            PrecisionTier::Compatible => 0.458,
            PrecisionTier::Standard => 0.632,
            PrecisionTier::Professional => 0.752,
            PrecisionTier::Maximum => 0.875,
            PrecisionTier::Absolute => 1.0,
        }
    }
    
    pub fn working_space(&self) -> ColorSpace {
        match self {
            PrecisionTier::Compatible => ColorSpace::SRGB,
            PrecisionTier::Standard => ColorSpace::DCI_P3,
            PrecisionTier::Professional => ColorSpace::AdobeRGB,
            PrecisionTier::Maximum => ColorSpace::Rec2020,
            PrecisionTier::Absolute => ColorSpace::ACES_AP0,
        }
    }
}

/// Supported color spaces
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ColorSpace {
    // Standard spaces
    SRGB,
    LinearSRGB,
    DCI_P3,
    DCI_P3_D65,
    AdobeRGB,
    Rec709,
    Rec2020,
    
    // ACES workflow
    ACES_AP0,      // ACES 2065-1
    ACES_AP1,      // ACEScg
    ACEScc,
    ACEScct,
    
    // Display spaces
    DisplayP3,
    ProPhotoRGB,
    
    // Perceptual spaces
    CIE_XYZ,
    CIE_xyY,
    CIE_Lab,
    CIE_LCH,
    OKLab,
    OKLCH,
    JzAzBz,
    ICtCp,
    
    // Quanta proprietary
    GenesisSymmetric,  // Perceptually uniform
    QuantaLog,         // HDR logarithmic
    BioLuminance,      // Biological vision model
}

