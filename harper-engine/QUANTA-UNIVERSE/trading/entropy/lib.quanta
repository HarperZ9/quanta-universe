// TRANSFORMER FOR MARKET ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Multi-head self-attention mechanism
pub struct MultiHeadAttention {
    num_heads: usize,
    d_model: usize,
    d_k: usize,
    w_q: Vec<Vec<f64>>,
    w_k: Vec<Vec<f64>>,
    w_v: Vec<Vec<f64>>,
    w_o: Vec<Vec<f64>>,
}

impl MultiHeadAttention {
    pub fn new(d_model: usize, num_heads: usize) -> Self {
        let d_k = d_model / num_heads;
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / d_model as f64);
        
        let init_weight = || -> Vec<Vec<f64>> {
            (0..d_model).map(|_| {
                (0..d_model).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect()
        };
        
        MultiHeadAttention {
            num_heads,
            d_model,
            d_k,
            w_q: init_weight(),
            w_k: init_weight(),
            w_v: init_weight(),
            w_o: init_weight(),
        }
    }
    
    /// Compute attention output
    pub fn forward(&self, query: &[Vec<f64>], key: &[Vec<f64>], value: &[Vec<f64>]) -> Vec<Vec<f64>> {
        let seq_len = query.len();
        
        // Project to Q, K, V
        let q = self.project(&self.w_q, query);
        let k = self.project(&self.w_k, key);
        let v = self.project(&self.w_v, value);
        
        // Scaled dot-product attention
        let scale = 1.0 / sqrt(self.d_k as f64);
        let mut attention_output = vec![vec![0.0; self.d_model]; seq_len];
        
        for i in 0..seq_len {
            // Compute attention weights
            let mut weights = vec![0.0; seq_len];
            for j in 0..seq_len {
                let dot: f64 = q[i].iter().zip(k[j].iter())
                    .map(|(qi, kj)| qi * kj)
                    .sum();
                weights[j] = dot * scale;
            }
            
            // Softmax
            let max_w = weights.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let exp_sum: f64 = weights.iter().map(|w| exp(w - max_w)).sum();
            let weights: Vec<f64> = weights.iter().map(|w| exp(w - max_w) / exp_sum).collect();
            
            // Weighted sum of values
            for j in 0..seq_len {
                for d in 0..self.d_model {
                    attention_output[i][d] += weights[j] * v[j][d];
                }
            }
        }
        
        // Output projection
        self.project(&self.w_o, &attention_output)
    }
    
    fn project(&self, weight: &[Vec<f64>], input: &[Vec<f64>]) -> Vec<Vec<f64>> {
        input.iter().map(|x| {
            (0..self.d_model).map(|i| {
                x.iter().zip(weight[i].iter())
                    .map(|(xi, wi)| xi * wi)
                    .sum()
            }).collect()
        }).collect()
    }
}

/// Transformer encoder layer
pub struct TransformerEncoder {
    attention: MultiHeadAttention,
    ff_hidden: usize,
    w1: Vec<Vec<f64>>,
    w2: Vec<Vec<f64>>,
    b1: Vec<f64>,
    b2: Vec<f64>,
}

impl TransformerEncoder {
    pub fn new(d_model: usize, num_heads: usize, ff_hidden: usize) -> Self {
        let mut rng = std::random::Random::new();
        let scale1 = sqrt(2.0 / d_model as f64);
        let scale2 = sqrt(2.0 / ff_hidden as f64);
        
        TransformerEncoder {
            attention: MultiHeadAttention::new(d_model, num_heads),
            ff_hidden,
            w1: (0..ff_hidden).map(|_| (0..d_model).map(|_| rng.gaussian(0.0, scale1)).collect()).collect(),
            w2: (0..d_model).map(|_| (0..ff_hidden).map(|_| rng.gaussian(0.0, scale2)).collect()).collect(),
            b1: vec![0.0; ff_hidden],
            b2: vec![0.0; d_model],
        }
    }
    
    pub fn forward(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
        // Self-attention + residual
        let attended = self.attention.forward(x, x, x);
        let x: Vec<Vec<f64>> = x.iter().zip(attended.iter())
            .map(|(a, b)| a.iter().zip(b.iter()).map(|(ai, bi)| ai + bi).collect())
            .collect();
        
        // Feed-forward + residual
        let ff_output: Vec<Vec<f64>> = x.iter().map(|xi| {
            // First layer with ReLU
            let hidden: Vec<f64> = (0..self.ff_hidden).map(|i| {
                let sum: f64 = xi.iter().zip(self.w1[i].iter())
                    .map(|(x, w)| x * w)
                    .sum::<f64>() + self.b1[i];
                sum.max(0.0) // ReLU
            }).collect();
            
            // Second layer
            (0..xi.len()).map(|i| {
                hidden.iter().zip(self.w2[i].iter())
                    .map(|(h, w)| h * w)
                    .sum::<f64>() + self.b2[i]
            }).collect()
        }).collect();
        
        // Residual connection
        x.iter().zip(ff_output.iter())
            .map(|(a, b)| a.iter().zip(b.iter()).map(|(ai, bi)| ai + bi).collect())
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REINFORCEMENT LEARNING AGENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Trading action space
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TradingAction {
    Hold,
    Buy(f64),   // Fraction of capital to invest
    Sell(f64),  // Fraction of position to sell
}

/// Trading environment state
#[derive(Debug, Clone)]
pub struct TradingState {
    pub features: Vec<f64>,
    pub position: f64,      // Current position size
    pub cash: f64,          // Available cash
    pub portfolio_value: f64,
    pub timestamp: u64,
}

/// PPO (Proximal Policy Optimization) agent
pub struct PPOAgent {
    policy_net: Vec<Vec<f64>>,
    value_net: Vec<Vec<f64>>,
    state_size: usize,
    action_size: usize,
    gamma: f64,          // Discount factor
    epsilon: f64,        // Clipping parameter
    learning_rate: f64,
}

impl PPOAgent {
    pub fn new(state_size: usize, action_size: usize) -> Self {
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / state_size as f64);
        
        let hidden_size = 64;
        
        PPOAgent {
            policy_net: (0..hidden_size).map(|_| {
                (0..state_size).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect(),
            value_net: (0..hidden_size).map(|_| {
                (0..state_size).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect(),
            state_size,
            action_size,
            gamma: 0.99,
            epsilon: 0.2,
            learning_rate: 0.0003,
        }
    }
    
    /// Select action using policy
    pub fn select_action(&self, state: &TradingState) -> TradingAction {
        let probs = self.policy(&state.features);
        
        // Sample from categorical distribution
        let mut rng = std::random::Random::new();
        let r = rng.uniform(0.0, 1.0);
        
        let mut cumsum = 0.0;
        for (i, &p) in probs.iter().enumerate() {
            cumsum += p;
            if r < cumsum {
                return match i {
                    0 => TradingAction::Hold,
                    1 => TradingAction::Buy(0.5),
                    2 => TradingAction::Sell(0.5),
                    _ => TradingAction::Hold,
                };
            }
        }
        
        TradingAction::Hold
    }
    
    /// Compute policy probabilities
    fn policy(&self, state: &[f64]) -> Vec<f64> {
        // Simple MLP policy
        let hidden: Vec<f64> = self.policy_net.iter().map(|weights| {
            let sum: f64 = state.iter().zip(weights.iter())
                .map(|(s, w)| s * w)
                .sum();
            tanh(sum)
        }).collect();
        
        // Softmax output
        let logits: Vec<f64> = (0..self.action_size).map(|i| {
            hidden.iter().enumerate()
                .map(|(j, &h)| h * (if i == j % self.action_size { 1.0 } else { 0.0 }))
                .sum()
        }).collect();
        
        let max_logit = logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let exp_sum: f64 = logits.iter().map(|&l| exp(l - max_logit)).sum();
        
        logits.iter().map(|&l| exp(l - max_logit) / exp_sum).collect()
    }
    
    /// Estimate state value
    pub fn value(&self, state: &[f64]) -> f64 {
        let hidden: Vec<f64> = self.value_net.iter().map(|weights| {
            let sum: f64 = state.iter().zip(weights.iter())
                .map(|(s, w)| s * w)
                .sum();
            tanh(sum)
        }).collect();
        
        hidden.iter().sum()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENSEMBLE MODELS
// ═══════════════════════════════════════════════════════════════════════════════

/// Ensemble model with dynamic weighting
pub struct EnsembleModel {
    models: Vec<Box<dyn Predictor>>,
    weights: Vec<f64>,
    performance_history: VecDeque<Vec<f64>>,
}

pub trait Predictor: Send + Sync {
    fn predict(&self, features: &[f64]) -> f64;
    fn name(&self) -> &str;
}

impl EnsembleModel {
    pub fn new() -> Self {
        EnsembleModel {
            models: Vec::new(),
            weights: Vec::new(),
            performance_history: VecDeque::with_capacity(100),
        }
    }
    
    pub fn add_model(&mut self, model: Box<dyn Predictor>, initial_weight: f64) {
        self.models.push(model);
        self.weights.push(initial_weight);
        self.normalize_weights();
    }
    
    fn normalize_weights(&mut self) {
        let sum: f64 = self.weights.iter().sum();
        if sum > 0.0 {
            for w in &mut self.weights {
                *w /= sum;
            }
        }
    }
    
    /// Make weighted prediction
    pub fn predict(&self, features: &[f64]) -> f64 {
        self.models.iter()
            .zip(self.weights.iter())
            .map(|(m, w)| m.predict(features) * w)
            .sum()
    }
    
    /// Update weights based on recent performance
    pub fn update_weights(&mut self, actual: f64, features: &[f64]) {
        let predictions: Vec<f64> = self.models.iter()
            .map(|m| m.predict(features))
            .collect();
        
        let errors: Vec<f64> = predictions.iter()
            .map(|p| (p - actual).abs())
            .collect();
        
        self.performance_history.push_back(errors.clone());
        if self.performance_history.len() > 100 {
            self.performance_history.pop_front();
        }
        
        // Update weights inversely proportional to average error
        let mut avg_errors = vec![0.0; self.models.len()];
        for history in &self.performance_history {
            for (i, &error) in history.iter().enumerate() {
                avg_errors[i] += error;
            }
        }
        
        let n = self.performance_history.len() as f64;
        for (i, w) in self.weights.iter_mut().enumerate() {
            let avg_error = avg_errors[i] / n;
            *w = 1.0 / (avg_error + 0.001);
        }
        
        self.normalize_weights();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WALK-FORWARD VALIDATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Walk-forward validation framework
pub struct WalkForwardValidator {
    train_size: usize,
    test_size: usize,
    step_size: usize,
}

#[derive(Debug, Clone)]
pub struct ValidationResult {
    pub fold: usize,
    pub train_start: usize,
    pub train_end: usize,
    pub test_start: usize,
    pub test_end: usize,
    pub train_score: f64,
    pub test_score: f64,
}

impl WalkForwardValidator {
    pub fn new(train_size: usize, test_size: usize, step_size: usize) -> Self {
        WalkForwardValidator { train_size, test_size, step_size }
    }
    
    /// Generate train/test splits
    pub fn splits(&self, data_size: usize) -> Vec<(std::ops::Range<usize>, std::ops::Range<usize>)> {
        let mut splits = Vec::new();
        let mut start = 0;
        
        while start + self.train_size + self.test_size <= data_size {
            let train_range = start..(start + self.train_size);
            let test_range = (start + self.train_size)..(start + self.train_size + self.test_size);
            
            splits.push((train_range, test_range));
            start += self.step_size;
        }
        
        splits
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_feature_engineering() {
        let prices: Vec<f64> = (0..100).map(|i| 100.0 + (i as f64 * 0.1).sin() * 10.0).collect();
        let volumes: Vec<f64> = vec![1000.0; 100];
        
        let fe = FeatureEngineering::new(20);
        let features = fe.generate(&prices, &volumes);
        
        assert!(!features.is_empty());
    }
    
    #[test]
    fn test_lstm() {
        let lstm = LSTMPredictor::new(5, &[32, 16], 1, 10);
        let sequence: Vec<Vec<f64>> = (0..10).map(|_| vec![0.1; 5]).collect();
        
        let output = lstm.predict(&sequence);
        assert_eq!(output.len(), 1);
    }
    
    #[test]
    fn test_ppo_agent() {
        let agent = PPOAgent::new(10, 3);
        let state = TradingState {
            features: vec![0.1; 10],
            position: 0.0,
            cash: 10000.0,
            portfolio_value: 10000.0,
            timestamp: 0,
        };
        
        let action = agent.select_action(&state);
        assert!(matches!(action, TradingAction::Hold | TradingAction::Buy(_) | TradingAction::Sell(_)));
    }
    
    #[test]
    fn test_walk_forward() {
        let validator = WalkForwardValidator::new(100, 20, 20);
        let splits = validator.splits(200);
        
        assert!(!splits.is_empty());
        assert_eq!(splits[0].0, 0..100);
        assert_eq!(splits[0].1, 100..120);
    }
}
