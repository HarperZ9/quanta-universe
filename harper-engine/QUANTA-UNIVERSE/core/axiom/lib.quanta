// ABSTRACT SYNTAX TREE (Differentiable)
// ═══════════════════════════════════════════════════════════════════════════════

/// AST node types for program representation
#[derive(Debug, Clone)]
pub enum ASTNode {
    // Literals
    Literal(f64),
    Variable(String),
    
    // Arithmetic
    Add(Box<ASTNode>, Box<ASTNode>),
    Sub(Box<ASTNode>, Box<ASTNode>),
    Mul(Box<ASTNode>, Box<ASTNode>),
    Div(Box<ASTNode>, Box<ASTNode>),
    Pow(Box<ASTNode>, Box<ASTNode>),
    Neg(Box<ASTNode>),
    
    // Functions
    Sin(Box<ASTNode>),
    Cos(Box<ASTNode>),
    Exp(Box<ASTNode>),
    Log(Box<ASTNode>),
    Sqrt(Box<ASTNode>),
    Abs(Box<ASTNode>),
    Tanh(Box<ASTNode>),
    
    // Control flow (differentiable via soft operations)
    If(Box<ASTNode>, Box<ASTNode>, Box<ASTNode>),  // condition, then, else
    
    // Higher-order
    Lambda(Vec<String>, Box<ASTNode>),
    Apply(Box<ASTNode>, Vec<ASTNode>),
    Let(String, Box<ASTNode>, Box<ASTNode>),
    
    // Recursion (via fixed-point combinator)
    Fix(String, Box<ASTNode>),
    
    // Lists
    Cons(Box<ASTNode>, Box<ASTNode>),
    Car(Box<ASTNode>),
    Cdr(Box<ASTNode>),
    Nil,
    
    // Neural network primitives
    Linear(usize, usize),  // input_dim, output_dim
    Activation(ActivationType),
    Attention(usize),      // num_heads
}

#[derive(Debug, Clone, Copy)]
pub enum ActivationType {
    ReLU,
    Sigmoid,
    Tanh,
    GELU,
    Swish,
    Softmax,
}

impl ASTNode {
    /// Count nodes in tree (complexity measure)
    pub fn size(&self) -> usize {
        match self {
            ASTNode::Literal(_) | ASTNode::Variable(_) | ASTNode::Nil => 1,
            ASTNode::Linear(_, _) | ASTNode::Activation(_) | ASTNode::Attention(_) => 1,
            
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) |
            ASTNode::Car(a) | ASTNode::Cdr(a) => 1 + a.size(),
            
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) | ASTNode::Cons(a, b) => {
                1 + a.size() + b.size()
            }
            
            ASTNode::If(c, t, e) => 1 + c.size() + t.size() + e.size(),
            
            ASTNode::Lambda(params, body) => 1 + params.len() + body.size(),
            ASTNode::Apply(func, args) => {
                1 + func.size() + args.iter().map(|a| a.size()).sum::<usize>()
            }
            ASTNode::Let(_, val, body) => 1 + val.size() + body.size(),
            ASTNode::Fix(_, body) => 1 + body.size(),
        }
    }
    
    /// Depth of tree
    pub fn depth(&self) -> usize {
        match self {
            ASTNode::Literal(_) | ASTNode::Variable(_) | ASTNode::Nil |
            ASTNode::Linear(_, _) | ASTNode::Activation(_) | ASTNode::Attention(_) => 1,
            
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) |
            ASTNode::Car(a) | ASTNode::Cdr(a) => 1 + a.depth(),
            
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) | ASTNode::Cons(a, b) => {
                1 + max(a.depth(), b.depth())
            }
            
            ASTNode::If(c, t, e) => 1 + max(c.depth(), max(t.depth(), e.depth())),
            
            ASTNode::Lambda(_, body) => 1 + body.depth(),
            ASTNode::Apply(func, args) => {
                let arg_depth = args.iter().map(|a| a.depth()).max().unwrap_or(0);
                1 + max(func.depth(), arg_depth)
            }
            ASTNode::Let(_, val, body) => 1 + max(val.depth(), body.depth()),
            ASTNode::Fix(_, body) => 1 + body.depth(),
        }
    }
    
    /// Get all variables used
    pub fn free_variables(&self) -> HashSet<String> {
        let mut vars = HashSet::new();
        self.collect_free_vars(&mut vars, &HashSet::new());
        vars
    }
    
    fn collect_free_vars(&self, free: &mut HashSet<String>, bound: &HashSet<String>) {
        match self {
            ASTNode::Variable(name) => {
                if !bound.contains(name) {
                    free.insert(name.clone());
                }
            }
            ASTNode::Lambda(params, body) => {
                let mut new_bound = bound.clone();
                for p in params {
                    new_bound.insert(p.clone());
                }
                body.collect_free_vars(free, &new_bound);
            }
            ASTNode::Let(name, val, body) => {
                val.collect_free_vars(free, bound);
                let mut new_bound = bound.clone();
                new_bound.insert(name.clone());
                body.collect_free_vars(free, &new_bound);
            }
            ASTNode::Fix(name, body) => {
                let mut new_bound = bound.clone();
                new_bound.insert(name.clone());
                body.collect_free_vars(free, &new_bound);
            }
            // Recursively handle other cases...
            ASTNode::Add(a, b) | ASTNode::Sub(a, b) | ASTNode::Mul(a, b) |
            ASTNode::Div(a, b) | ASTNode::Pow(a, b) => {
                a.collect_free_vars(free, bound);
                b.collect_free_vars(free, bound);
            }
            ASTNode::Neg(a) | ASTNode::Sin(a) | ASTNode::Cos(a) | ASTNode::Exp(a) |
            ASTNode::Log(a) | ASTNode::Sqrt(a) | ASTNode::Abs(a) | ASTNode::Tanh(a) => {
                a.collect_free_vars(free, bound);
            }
            ASTNode::If(c, t, e) => {
                c.collect_free_vars(free, bound);
                t.collect_free_vars(free, bound);
                e.collect_free_vars(free, bound);
            }
            ASTNode::Apply(func, args) => {
                func.collect_free_vars(free, bound);
                for arg in args {
                    arg.collect_free_vars(free, bound);
                }
            }
            _ => {}
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DUAL NUMBERS FOR AUTOMATIC DIFFERENTIATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Dual number for forward-mode automatic differentiation
#[derive(Debug, Clone, Copy)]
pub struct Dual {
    pub value: f64,
    pub derivative: f64,
}

impl Dual {
    pub fn new(value: f64, derivative: f64) -> Self {
        Dual { value, derivative }
    }
    
    pub fn constant(value: f64) -> Self {
        Dual { value, derivative: 0.0 }
    }
    
    pub fn variable(value: f64) -> Self {
        Dual { value, derivative: 1.0 }
    }
    
    pub fn add(&self, other: &Dual) -> Dual {
        Dual::new(
            self.value + other.value,
            self.derivative + other.derivative,
        )
    }
    
    pub fn sub(&self, other: &Dual) -> Dual {
        Dual::new(
            self.value - other.value,
            self.derivative - other.derivative,
        )
    }
    
    pub fn mul(&self, other: &Dual) -> Dual {
        Dual::new(
            self.value * other.value,
            self.value * other.derivative + self.derivative * other.value,
        )
    }
    
    pub fn div(&self, other: &Dual) -> Dual {
        let denom = other.value * other.value;
        Dual::new(
            self.value / other.value,
            (self.derivative * other.value - self.value * other.derivative) / denom,
        )
    }
    
    pub fn pow(&self, n: f64) -> Dual {
        Dual::new(
            pow(self.value, n),
            n * pow(self.value, n - 1.0) * self.derivative,
        )
    }
    
    pub fn sin(&self) -> Dual {
        Dual::new(
            sin(self.value),
            cos(self.value) * self.derivative,
        )
    }
    
    pub fn cos(&self) -> Dual {
        Dual::new(
            cos(self.value),
            -sin(self.value) * self.derivative,
        )
    }
    
    pub fn exp(&self) -> Dual {
        let e = exp(self.value);
        Dual::new(e, e * self.derivative)
    }
    
    pub fn log(&self) -> Dual {
        Dual::new(
            log(self.value),
            self.derivative / self.value,
        )
    }
    
    pub fn sqrt(&self) -> Dual {
        let s = sqrt(self.value);
        Dual::new(s, self.derivative / (2.0 * s))
    }
    
    pub fn tanh(&self) -> Dual {
        let t = tanh(self.value);
        Dual::new(t, (1.0 - t * t) * self.derivative)
    }
    
    pub fn abs(&self) -> Dual {
        if self.value >= 0.0 {
            *self
        } else {
            Dual::new(-self.value, -self.derivative)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOFT/DIFFERENTIABLE CONTROL FLOW
// ═══════════════════════════════════════════════════════════════════════════════

/// Soft if-then-else using sigmoid interpolation
pub fn soft_if(condition: f64, then_val: f64, else_val: f64, temperature: f64) -> f64 {
    let sigmoid = 1.0 / (1.0 + exp(-condition / temperature));
    sigmoid * then_val + (1.0 - sigmoid) * else_val
}

/// Soft if for dual numbers
pub fn soft_if_dual(condition: Dual, then_val: Dual, else_val: Dual, temperature: f64) -> Dual {
    let sigmoid = Dual::constant(1.0).div(&Dual::constant(1.0).add(
        &Dual::constant(-1.0).mul(&condition).div(&Dual::constant(temperature)).exp()
    ));
    sigmoid.mul(&then_val).add(&Dual::constant(1.0).sub(&sigmoid).mul(&else_val))
}

/// Gumbel-Softmax for differentiable discrete sampling
pub struct GumbelSoftmax {
    temperature: f64,
}

impl GumbelSoftmax {
    pub fn new(temperature: f64) -> Self {
        GumbelSoftmax { temperature }
    }
    
    /// Sample from categorical distribution (differentiable)
    pub fn sample(&self, logits: &[f64], rng: &mut Random) -> Vec<f64> {
        let gumbels: Vec<f64> = logits.iter()
            .map(|_| -log(-log(rng.next_f64())))
            .collect();
        
        let perturbed: Vec<f64> = logits.iter()
            .zip(gumbels.iter())
            .map(|(l, g)| (l + g) / self.temperature)
            .collect();
        
        // Softmax
        let max_val = perturbed.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let exps: Vec<f64> = perturbed.iter().map(|x| exp(x - max_val)).collect();
        let sum: f64 = exps.iter().sum();
        
        exps.iter().map(|e| e / sum).collect()
    }
    
    /// Anneal temperature
    pub fn anneal(&mut self, factor: f64) {
        self.temperature *= factor;
        self.temperature = self.temperature.max(0.01);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUANTA EVOLUTION EQUATION™
// ═══════════════════════════════════════════════════════════════════════════════

/// The Quanta Evolution Equation™:
/// ∂P/∂t = -∇L + η·Mutation + λ·Simplicity
/// 
/// Where:
/// - P: Program population in parameter space
/// - L: Loss function on training data
/// - η: Mutation rate (exploration)
/// - λ: Simplicity pressure (Occam's razor)
/// 
/// This equation governs the evolution of programs in a differentiable manner,
/// combining gradient descent with evolutionary operators.

pub struct QuantaEvolution {
    /// Learning rate for gradient updates
    pub learning_rate: f64,
    /// Mutation rate (η)
    pub mutation_rate: f64,
    /// Simplicity pressure (λ)
    pub simplicity_weight: f64,
    /// Population size
    pub population_size: usize,
    /// Temperature for selection
    pub temperature: f64,
    /// Random number generator
    rng: Random,
}

impl QuantaEvolution {
    pub fn new(seed: u64) -> Self {
        QuantaEvolution {
            learning_rate: 0.01,
            mutation_rate: 0.1,
            simplicity_weight: 0.001,
            population_size: 100,
            temperature: 1.0,
            rng: Random::new(seed),
        }
    }
    
    /// Compute the Quanta Evolution update
    /// Returns: ∂P/∂t = -∇L + η·Mutation + λ·Simplicity
    pub fn compute_update(
        &self,
        program: &Program,
        loss_gradient: f64,
    ) -> f64 {
        // Gradient term: -∇L
        let gradient_term = -loss_gradient * self.learning_rate;
        
        // Mutation term: η·Mutation (random perturbation)
        let mutation_term = self.mutation_rate * self.rng.next_gaussian();
        
        // Simplicity term: λ·Simplicity (penalize complexity)
        let complexity = program.ast.size() as f64;
        let simplicity_term = -self.simplicity_weight * complexity;
        
        gradient_term + mutation_term + simplicity_term
    }
    
    /// Evolve population for one generation
    pub fn evolve_generation(&mut self, population: &mut Vec<Program>, fitness_fn: &dyn Fn(&Program) -> f64) {
        // Evaluate fitness
        let mut fitness: Vec<(usize, f64)> = population.iter()
            .enumerate()
            .map(|(i, p)| (i, fitness_fn(p)))
            .collect();
        
        // Sort by fitness (descending)
        fitness.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
        
        // Selection (tournament)
        let mut new_population = Vec::with_capacity(self.population_size);
        
        // Elitism: keep top 10%
        let elite_count = self.population_size / 10;
        for i in 0..elite_count {
            new_population.push(population[fitness[i].0].clone());
        }
        
        // Fill rest with crossover and mutation
        while new_population.len() < self.population_size {
            let parent1 = self.tournament_select(&fitness, population);
            let parent2 = self.tournament_select(&fitness, population);
            
            let child = self.geodesic_crossover(&parent1, &parent2);
            let mutated = self.mutate(child);
            
            new_population.push(mutated);
        }
        
        *population = new_population;
    }
    
    fn tournament_select(&mut self, fitness: &[(usize, f64)], population: &[Program]) -> Program {
        let tournament_size = 5;
        let mut best_idx = self.rng.next_usize() % fitness.len();
        let mut best_fitness = fitness[best_idx].1;
        
        for _ in 1..tournament_size {
            let idx = self.rng.next_usize() % fitness.len();
            if fitness[idx].1 > best_fitness {
                best_idx = idx;
                best_fitness = fitness[idx].1;
            }
        }
        
        population[fitness[best_idx].0].clone()
    }
    
    /// Geodesic Crossover™: Interpolate programs along manifold
    fn geodesic_crossover(&mut self, parent1: &Program, parent2: &Program) -> Program {
        // Compute geodesic parameter t ∈ [0, 1]
        let t = self.rng.next_f64();
        
        // Interpolate program trees
        let new_ast = self.interpolate_ast(&parent1.ast, &parent2.ast, t);
        
        // Interpolate parameters
        let new_params: Vec<f64> = parent1.parameters.iter()
            .zip(parent2.parameters.iter())
            .map(|(&p1, &p2)| (1.0 - t) * p1 + t * p2)
            .collect();
        
        Program {
            ast: new_ast,
            parameters: new_params,
            fitness: 0.0,
        }
    }
    
    fn interpolate_ast(&mut self, ast1: &ASTNode, ast2: &ASTNode, t: f64) -> ASTNode {
        // With probability t, take from ast2, else ast1
        // For matching structure, interpolate recursively
        if self.rng.next_f64() < t {
            ast2.clone()
        } else {
            ast1.clone()
        }
    }
    
    /// Mutate program with various operators
    fn mutate(&mut self, mut program: Program) -> Program {
        if self.rng.next_f64() < self.mutation_rate {
            // Choose mutation type
            match self.rng.next_usize() % 5 {
                0 => self.point_mutation(&mut program),
                1 => self.subtree_mutation(&mut program),
                2 => self.constant_mutation(&mut program),
                3 => self.simplification(&mut program),
                4 => self.expansion(&mut program),
                _ => {}
            }
        }
        program
    }
    
    fn point_mutation(&mut self, program: &mut Program) {
        // Change a single operator
        // Implementation depends on AST traversal
    }
    
    fn subtree_mutation(&mut self, program: &mut Program) {
        // Replace a random subtree
    }
    
    fn constant_mutation(&mut self, program: &mut Program) {
        // Perturb numeric constants
        for param in &mut program.parameters {
            *param += self.rng.next_gaussian() * 0.1;
        }
    }
    
    fn simplification(&mut self, program: &mut Program) {
        // Apply algebraic simplifications
        program.ast = simplify(&program.ast);
    }
    
    fn expansion(&mut self, program: &mut Program) {
        // Add complexity (new operations)
    }
}

/// Algebraic simplification of AST
fn simplify(ast: &ASTNode) -> ASTNode {
    match ast {
        // x + 0 = x
        ASTNode::Add(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            match (&a_simp, &b_simp) {
                (_, ASTNode::Literal(0.0)) => a_simp,
                (ASTNode::Literal(0.0), _) => b_simp,
                (ASTNode::Literal(x), ASTNode::Literal(y)) => ASTNode::Literal(x + y),
                _ => ASTNode::Add(Box::new(a_simp), Box::new(b_simp)),
            }
        }
        // x * 0 = 0, x * 1 = x
        ASTNode::Mul(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            match (&a_simp, &b_simp) {
                (_, ASTNode::Literal(0.0)) | (ASTNode::Literal(0.0), _) => ASTNode::Literal(0.0),
                (_, ASTNode::Literal(1.0)) => a_simp,
                (ASTNode::Literal(1.0), _) => b_simp,
                (ASTNode::Literal(x), ASTNode::Literal(y)) => ASTNode::Literal(x * y),
                _ => ASTNode::Mul(Box::new(a_simp), Box::new(b_simp)),
            }
        }
        // x - x = 0
        ASTNode::Sub(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            if nodes_equal(&a_simp, &b_simp) {
                ASTNode::Literal(0.0)
            } else {
                match (&a_simp, &b_simp) {
                    (_, ASTNode::Literal(0.0)) => a_simp,
                    (ASTNode::Literal(x), ASTNode::Literal(y)) => ASTNode::Literal(x - y),
                    _ => ASTNode::Sub(Box::new(a_simp), Box::new(b_simp)),
                }
            }
        }
        // x / x = 1
        ASTNode::Div(a, b) => {
            let a_simp = simplify(a);
            let b_simp = simplify(b);
            if nodes_equal(&a_simp, &b_simp) {
                ASTNode::Literal(1.0)
            } else {
                match (&a_simp, &b_simp) {
                    (_, ASTNode::Literal(1.0)) => a_simp,
                    (ASTNode::Literal(x), ASTNode::Literal(y)) if *y != 0.0 => ASTNode::Literal(x / y),
                    _ => ASTNode::Div(Box::new(a_simp), Box::new(b_simp)),
                }
            }
        }
        // Double negation: --x = x
        ASTNode::Neg(inner) => {
            match &**inner {
                ASTNode::Neg(x) => simplify(x),
                ASTNode::Literal(x) => ASTNode::Literal(-x),
                _ => ASTNode::Neg(Box::new(simplify(inner))),
            }
        }
        // Pass through others
        _ => ast.clone(),
    }
}

fn nodes_equal(a: &ASTNode, b: &ASTNode) -> bool {
    match (a, b) {
        (ASTNode::Literal(x), ASTNode::Literal(y)) => (x - y).abs() < 1e-10,
        (ASTNode::Variable(x), ASTNode::Variable(y)) => x == y,
        _ => false, // Simplified comparison
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROGRAM REPRESENTATION
// ═══════════════════════════════════════════════════════════════════════════════

/// A program with its AST and learnable parameters
#[derive(Debug, Clone)]
pub struct Program {
    pub ast: ASTNode,
    pub parameters: Vec<f64>,
    pub fitness: f64,
}

impl Program {
    pub fn new(ast: ASTNode) -> Self {
        Program {
            ast,
            parameters: Vec::new(),
            fitness: 0.0,
        }
    }
    
    /// Evaluate program with given environment
    pub fn evaluate(&self, env: &HashMap<String, f64>) -> Result<f64, EvalError> {
        evaluate_ast(&self.ast, env)
    }
    
    /// Evaluate with automatic differentiation
    pub fn evaluate_dual(&self, env: &HashMap<String, Dual>) -> Result<Dual, EvalError> {
        evaluate_ast_dual(&self.ast, env)
    }
    
    /// Convert to Quanta source code
    pub fn to_quanta(&self) -> String {
        ast_to_quanta(&self.ast)
    }
}

fn evaluate_ast(ast: &ASTNode, env: &HashMap<String, f64>) -> Result<f64, EvalError> {
    match ast {
        ASTNode::Literal(v) => Ok(*v),
        ASTNode::Variable(name) => {
            env.get(name).copied().ok_or(EvalError::UndefinedVariable(name.clone()))
        }
        ASTNode::Add(a, b) => Ok(evaluate_ast(a, env)? + evaluate_ast(b, env)?),
        ASTNode::Sub(a, b) => Ok(evaluate_ast(a, env)? - evaluate_ast(b, env)?),
        ASTNode::Mul(a, b) => Ok(evaluate_ast(a, env)? * evaluate_ast(b, env)?),
        ASTNode::Div(a, b) => {
            let divisor = evaluate_ast(b, env)?;
            if divisor == 0.0 {
                Err(EvalError::DivisionByZero)
            } else {
                Ok(evaluate_ast(a, env)? / divisor)
            }
        }
        ASTNode::Pow(a, b) => Ok(pow(evaluate_ast(a, env)?, evaluate_ast(b, env)?)),
        ASTNode::Neg(a) => Ok(-evaluate_ast(a, env)?),
        ASTNode::Sin(a) => Ok(sin(evaluate_ast(a, env)?)),
        ASTNode::Cos(a) => Ok(cos(evaluate_ast(a, env)?)),
        ASTNode::Exp(a) => Ok(exp(evaluate_ast(a, env)?)),
        ASTNode::Log(a) => {
            let v = evaluate_ast(a, env)?;
            if v <= 0.0 {
                Err(EvalError::InvalidDomain)
            } else {
                Ok(log(v))
            }
        }
        ASTNode::Sqrt(a) => {
            let v = evaluate_ast(a, env)?;
            if v < 0.0 {
                Err(EvalError::InvalidDomain)
            } else {
                Ok(sqrt(v))
            }
        }
        ASTNode::Abs(a) => Ok(abs(evaluate_ast(a, env)?)),
        ASTNode::Tanh(a) => Ok(tanh(evaluate_ast(a, env)?)),
        ASTNode::If(cond, then_branch, else_branch) => {
            let c = evaluate_ast(cond, env)?;
            if c > 0.0 {
                evaluate_ast(then_branch, env)
            } else {
                evaluate_ast(else_branch, env)
            }
        }
        _ => Err(EvalError::UnsupportedOperation),
    }
}

fn evaluate_ast_dual(ast: &ASTNode, env: &HashMap<String, Dual>) -> Result<Dual, EvalError> {
    match ast {
        ASTNode::Literal(v) => Ok(Dual::constant(*v)),
        ASTNode::Variable(name) => {
            env.get(name).copied().ok_or(EvalError::UndefinedVariable(name.clone()))
        }
        ASTNode::Add(a, b) => Ok(evaluate_ast_dual(a, env)?.add(&evaluate_ast_dual(b, env)?)),
        ASTNode::Sub(a, b) => Ok(evaluate_ast_dual(a, env)?.sub(&evaluate_ast_dual(b, env)?)),
        ASTNode::Mul(a, b) => Ok(evaluate_ast_dual(a, env)?.mul(&evaluate_ast_dual(b, env)?)),
        ASTNode::Div(a, b) => Ok(evaluate_ast_dual(a, env)?.div(&evaluate_ast_dual(b, env)?)),
        ASTNode::Neg(a) => {
            let v = evaluate_ast_dual(a, env)?;
            Ok(Dual::new(-v.value, -v.derivative))
        }
        ASTNode::Sin(a) => Ok(evaluate_ast_dual(a, env)?.sin()),
        ASTNode::Cos(a) => Ok(evaluate_ast_dual(a, env)?.cos()),
        ASTNode::Exp(a) => Ok(evaluate_ast_dual(a, env)?.exp()),
        ASTNode::Log(a) => Ok(evaluate_ast_dual(a, env)?.log()),
        ASTNode::Sqrt(a) => Ok(evaluate_ast_dual(a, env)?.sqrt()),
        ASTNode::Tanh(a) => Ok(evaluate_ast_dual(a, env)?.tanh()),
        ASTNode::Abs(a) => Ok(evaluate_ast_dual(a, env)?.abs()),
        ASTNode::If(cond, then_branch, else_branch) => {
            let c = evaluate_ast_dual(cond, env)?;
            let t = evaluate_ast_dual(then_branch, env)?;
            let e = evaluate_ast_dual(else_branch, env)?;
            Ok(soft_if_dual(c, t, e, 1.0))
        }
        _ => Err(EvalError::UnsupportedOperation),
    }
}

fn ast_to_quanta(ast: &ASTNode) -> String {
    match ast {
        ASTNode::Literal(v) => format!("{}", v),
        ASTNode::Variable(name) => name.clone(),
        ASTNode::Add(a, b) => format!("({} + {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Sub(a, b) => format!("({} - {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Mul(a, b) => format!("({} * {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Div(a, b) => format!("({} / {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Pow(a, b) => format!("pow({}, {})", ast_to_quanta(a), ast_to_quanta(b)),
        ASTNode::Neg(a) => format!("(-{})", ast_to_quanta(a)),
        ASTNode::Sin(a) => format!("sin({})", ast_to_quanta(a)),
        ASTNode::Cos(a) => format!("cos({})", ast_to_quanta(a)),
        ASTNode::Exp(a) => format!("exp({})", ast_to_quanta(a)),
        ASTNode::Log(a) => format!("log({})", ast_to_quanta(a)),
        ASTNode::Sqrt(a) => format!("sqrt({})", ast_to_quanta(a)),
        ASTNode::Abs(a) => format!("abs({})", ast_to_quanta(a)),
        ASTNode::Tanh(a) => format!("tanh({})", ast_to_quanta(a)),
        ASTNode::If(c, t, e) => format!("if {} {{ {} }} else {{ {} }}", 
            ast_to_quanta(c), ast_to_quanta(t), ast_to_quanta(e)),
        ASTNode::Lambda(params, body) => {
            format!("|{}| {{ {} }}", params.join(", "), ast_to_quanta(body))
        }
        ASTNode::Let(name, val, body) => {
            format!("let {} = {}; {}", name, ast_to_quanta(val), ast_to_quanta(body))
        }
        _ => "/* unsupported */".to_string(),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL ARCHITECTURE SEARCH
// ═══════════════════════════════════════════════════════════════════════════════

/// Neural architecture representation
#[derive(Debug, Clone)]
pub struct NeuralArchitecture {
    pub layers: Vec<LayerSpec>,
    pub connections: Vec<(usize, usize)>,  // Skip connections
}

#[derive(Debug, Clone)]
pub enum LayerSpec {
    Dense { in_features: usize, out_features: usize },
    Conv2D { in_channels: usize, out_channels: usize, kernel: usize },
    Attention { heads: usize, dim: usize },
    LayerNorm { dim: usize },
    Dropout { rate: f64 },
    Activation(ActivationType),
    Residual(Box<NeuralArchitecture>),
}

/// Neural Architecture Search using Axiom evolution
pub struct NeuralArchitectureSearch {
    evolution: QuantaEvolution,
    max_layers: usize,
    max_params: usize,
}

impl NeuralArchitectureSearch {
    pub fn new(seed: u64) -> Self {
        NeuralArchitectureSearch {
            evolution: QuantaEvolution::new(seed),
            max_layers: 50,
            max_params: 100_000_000,
        }
    }
    
    /// Generate random architecture
    pub fn random_architecture(&mut self, input_dim: usize, output_dim: usize) -> NeuralArchitecture {
        let mut layers = Vec::new();
        let mut current_dim = input_dim;
        
        let num_layers = 3 + (self.evolution.rng.next_usize() % 10);
        
        for i in 0..num_layers {
            let out_dim = if i == num_layers - 1 {
                output_dim
            } else {
                32 * (1 << (self.evolution.rng.next_usize() % 4))
            };
            
            layers.push(LayerSpec::Dense { 
                in_features: current_dim, 
                out_features: out_dim 
            });
            
            if i < num_layers - 1 {
                layers.push(LayerSpec::Activation(ActivationType::GELU));
                
                if self.evolution.rng.next_f64() < 0.3 {
                    layers.push(LayerSpec::Dropout { rate: 0.1 });
                }
            }
            
            current_dim = out_dim;
        }
        
        NeuralArchitecture {
            layers,
            connections: Vec::new(),
        }
    }
    
    /// Mutate architecture
    pub fn mutate_architecture(&mut self, arch: &NeuralArchitecture) -> NeuralArchitecture {
        let mut new_arch = arch.clone();
        
        match self.evolution.rng.next_usize() % 4 {
            0 => self.add_layer(&mut new_arch),
            1 => self.remove_layer(&mut new_arch),
            2 => self.modify_layer(&mut new_arch),
            3 => self.add_skip_connection(&mut new_arch),
            _ => {}
        }
        
        new_arch
    }
    
    fn add_layer(&mut self, arch: &mut NeuralArchitecture) {
        if arch.layers.len() < self.max_layers {
            let pos = self.evolution.rng.next_usize() % (arch.layers.len() + 1);
            arch.layers.insert(pos, LayerSpec::Activation(ActivationType::ReLU));
        }
    }
    
    fn remove_layer(&mut self, arch: &mut NeuralArchitecture) {
        if arch.layers.len() > 2 {
            let pos = self.evolution.rng.next_usize() % arch.layers.len();
            arch.layers.remove(pos);
        }
    }
    
    fn modify_layer(&mut self, arch: &mut NeuralArchitecture) {
        if !arch.layers.is_empty() {
            let pos = self.evolution.rng.next_usize() % arch.layers.len();
            if let LayerSpec::Dense { in_features, .. } = arch.layers[pos] {
                let new_out = 32 * (1 << (self.evolution.rng.next_usize() % 5));
                arch.layers[pos] = LayerSpec::Dense { 
                    in_features, 
                    out_features: new_out 
                };
            }
        }
    }
    
    fn add_skip_connection(&mut self, arch: &mut NeuralArchitecture) {
        let n = arch.layers.len();
        if n > 2 {
            let from = self.evolution.rng.next_usize() % (n - 2);
            let to = from + 2 + (self.evolution.rng.next_usize() % (n - from - 2).max(1));
            if to < n {
                arch.connections.push((from, to));
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYMBOLIC REGRESSION
// ═══════════════════════════════════════════════════════════════════════════════

/// Symbolic regression: find formula from data
pub struct SymbolicRegression {
    evolution: QuantaEvolution,
    population: Vec<Program>,
    variables: Vec<String>,
}

impl SymbolicRegression {
    pub fn new(variables: Vec<String>, population_size: usize, seed: u64) -> Self {
        let mut sr = SymbolicRegression {
            evolution: QuantaEvolution::new(seed),
            population: Vec::new(),
            variables,
        };
        sr.evolution.population_size = population_size;
        sr.initialize_population();
        sr
    }
    
    fn initialize_population(&mut self) {
        for _ in 0..self.evolution.population_size {
            let ast = self.random_ast(3);
            self.population.push(Program::new(ast));
        }
    }
    
    fn random_ast(&mut self, max_depth: usize) -> ASTNode {
        if max_depth == 0 || self.evolution.rng.next_f64() < 0.3 {
            // Terminal
            if self.evolution.rng.next_f64() < 0.5 {
                ASTNode::Literal(self.evolution.rng.next_gaussian())
            } else {
                let var = &self.variables[self.evolution.rng.next_usize() % self.variables.len()];
                ASTNode::Variable(var.clone())
            }
        } else {
            // Function
            match self.evolution.rng.next_usize() % 10 {
                0 => ASTNode::Add(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                1 => ASTNode::Sub(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                2 => ASTNode::Mul(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                3 => ASTNode::Div(
                    Box::new(self.random_ast(max_depth - 1)),
                    Box::new(self.random_ast(max_depth - 1)),
                ),
                4 => ASTNode::Sin(Box::new(self.random_ast(max_depth - 1))),
                5 => ASTNode::Cos(Box::new(self.random_ast(max_depth - 1))),
                6 => ASTNode::Exp(Box::new(self.random_ast(max_depth - 1))),
                7 => ASTNode::Log(Box::new(self.random_ast(max_depth - 1))),
                8 => ASTNode::Sqrt(Box::new(self.random_ast(max_depth - 1))),
                _ => ASTNode::Neg(Box::new(self.random_ast(max_depth - 1))),
            }
        }
    }
    
    /// Fit to data
    pub fn fit(&mut self, x: &[HashMap<String, f64>], y: &[f64], generations: usize) -> Program {
        for gen in 0..generations {
            // Evaluate fitness (negative MSE)
            let fitness_fn = |p: &Program| {
                let mse: f64 = x.iter().zip(y.iter())
                    .map(|(xi, &yi)| {
                        match p.evaluate(xi) {
                            Ok(pred) => (pred - yi).powi(2),
                            Err(_) => 1e10,
                        }
                    })
                    .sum::<f64>() / x.len() as f64;
                
                let complexity_penalty = p.ast.size() as f64 * self.evolution.simplicity_weight;
                -mse - complexity_penalty
            };
            
            self.evolution.evolve_generation(&mut self.population, &fitness_fn);
            
            // Report best
            if gen % 10 == 0 {
                let best = self.population.iter()
                    .max_by(|a, b| a.fitness.partial_cmp(&b.fitness).unwrap())
                    .unwrap();
                println!("Generation {}: fitness={:.6}, formula={}", 
                    gen, best.fitness, best.to_quanta());
            }
        }
        
        self.population.iter()
            .max_by(|a, b| a.fitness.partial_cmp(&b.fitness).unwrap())
            .unwrap()
            .clone()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERROR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub enum EvalError {
    UndefinedVariable(String),
    DivisionByZero,
    InvalidDomain,
    UnsupportedOperation,
    StackOverflow,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_dual_arithmetic() {
        let x = Dual::variable(2.0);
        let y = Dual::constant(3.0);
        
        let sum = x.add(&y);
        assert!((sum.value - 5.0).abs() < 1e-10);
        assert!((sum.derivative - 1.0).abs() < 1e-10);
        
        let prod = x.mul(&y);
        assert!((prod.value - 6.0).abs() < 1e-10);
        assert!((prod.derivative - 3.0).abs() < 1e-10);
    }
    
    #[test]
    fn test_dual_chain_rule() {
        // d/dx sin(x^2) at x=1 should be 2*cos(1)
        let x = Dual::variable(1.0);
        let x_sq = x.mul(&x);
        let result = x_sq.sin();
        
        let expected_deriv = 2.0 * cos(1.0);
        assert!((result.derivative - expected_deriv).abs() < 1e-10);
    }
    
    #[test]
    fn test_simplification() {
        // x + 0 = x
        let ast = ASTNode::Add(
            Box::new(ASTNode::Variable("x".to_string())),
            Box::new(ASTNode::Literal(0.0)),
        );
        let simplified = simplify(&ast);
        assert!(matches!(simplified, ASTNode::Variable(ref s) if s == "x"));
        
        // x * 1 = x
        let ast2 = ASTNode::Mul(
            Box::new(ASTNode::Variable("y".to_string())),
            Box::new(ASTNode::Literal(1.0)),
        );
        let simplified2 = simplify(&ast2);
        assert!(matches!(simplified2, ASTNode::Variable(ref s) if s == "y"));
    }
    
    #[test]
    fn test_program_evaluation() {
        // f(x) = x^2 + 2*x + 1
        let ast = ASTNode::Add(
            Box::new(ASTNode::Add(
                Box::new(ASTNode::Mul(
                    Box::new(ASTNode::Variable("x".to_string())),
                    Box::new(ASTNode::Variable("x".to_string())),
                )),
                Box::new(ASTNode::Mul(
                    Box::new(ASTNode::Literal(2.0)),
                    Box::new(ASTNode::Variable("x".to_string())),
                )),
            )),
            Box::new(ASTNode::Literal(1.0)),
        );
        
        let program = Program::new(ast);
        
        let mut env = HashMap::new();
        env.insert("x".to_string(), 3.0);
        
        let result = program.evaluate(&env).unwrap();
        assert!((result - 16.0).abs() < 1e-10); // 9 + 6 + 1 = 16
    }
    
    #[test]
    fn test_ast_size() {
        let ast = ASTNode::Add(
            Box::new(ASTNode::Literal(1.0)),
            Box::new(ASTNode::Mul(
                Box::new(ASTNode::Variable("x".to_string())),
                Box::new(ASTNode::Literal(2.0)),
            )),
        );
        
        assert_eq!(ast.size(), 5); // Add, Lit, Mul, Var, Lit
    }
}
