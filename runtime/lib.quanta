/// Type descriptor for RTTI
#[derive(Clone)]
pub struct TypeDescriptor {
    pub id: TypeId,
    pub name: String,
    pub kind: TypeKind,
    pub size: usize,
    pub alignment: usize,
    pub fields: Vec<FieldDescriptor>,
    pub methods: Vec<MethodDescriptor>,
    pub traits: Vec<TypeId>,
    pub parent: Option<TypeId>,
    /// Generic parameters
    pub generics: Vec<TypeId>,
    /// Annotations
    pub annotations: Vec<Annotation>,
}

#[derive(Clone, Copy, Debug)]
pub enum TypeKind {
    Primitive,
    Struct,
    Enum,
    Class,
    Interface,
    Array,
    Tuple,
    Function,
    Pointer,
    Reference,
    Optional,
    Result,
    Generic,
}

#[derive(Clone)]
pub struct FieldDescriptor {
    pub name: String,
    pub type_id: TypeId,
    pub offset: usize,
    pub visibility: Visibility,
    pub is_final: bool,
    pub is_volatile: bool,
}

#[derive(Clone)]
pub struct MethodDescriptor {
    pub name: String,
    pub function_ref: FunctionRef,
    pub visibility: Visibility,
    pub is_static: bool,
    pub is_virtual: bool,
    pub is_abstract: bool,
    pub is_final: bool,
}

#[derive(Clone)]
pub struct Annotation {
    pub name: String,
    pub values: HashMap<String, Value>,
}

#[derive(Clone, Copy, Debug)]
pub enum Visibility {
    Public,
    Private,
    Protected,
    Internal,
}

/// Type registry for runtime type lookup
pub struct TypeRegistry {
    types: RwLock<HashMap<TypeId, TypeDescriptor>>,
    by_name: RwLock<HashMap<String, TypeId>>,
    next_id: AtomicU64,
    /// Generic type instantiations
    instantiations: RwLock<HashMap<(TypeId, Vec<TypeId>), TypeId>>,
}

impl TypeRegistry {
    pub fn new() -> Self {
        let registry = TypeRegistry {
            types: RwLock::new(HashMap::new()),
            by_name: RwLock::new(HashMap::new()),
            next_id: AtomicU64::new(TypeId::FIRST_USER_TYPE),
            instantiations: RwLock::new(HashMap::new()),
        };

        // Register built-in types
        registry.register_builtin_types();

        registry
    }

    fn register_builtin_types(&self) {
        let builtins = vec![
            (TypeId::NULL, "null", TypeKind::Primitive, 0),
            (TypeId::BOOL, "bool", TypeKind::Primitive, 1),
            (TypeId::INT8, "i8", TypeKind::Primitive, 1),
            (TypeId::INT16, "i16", TypeKind::Primitive, 2),
            (TypeId::INT32, "i32", TypeKind::Primitive, 4),
            (TypeId::INT64, "i64", TypeKind::Primitive, 8),
            (TypeId::UINT8, "u8", TypeKind::Primitive, 1),
            (TypeId::UINT16, "u16", TypeKind::Primitive, 2),
            (TypeId::UINT32, "u32", TypeKind::Primitive, 4),
            (TypeId::UINT64, "u64", TypeKind::Primitive, 8),
            (TypeId::FLOAT32, "f32", TypeKind::Primitive, 4),
            (TypeId::FLOAT64, "f64", TypeKind::Primitive, 8),
            (TypeId::CHAR, "char", TypeKind::Primitive, 4),
            (TypeId::STRING, "string", TypeKind::Class, 24),
            (TypeId::INT128, "i128", TypeKind::Primitive, 16),
            (TypeId::UINT128, "u128", TypeKind::Primitive, 16),
        ];

        let mut types = self.types.write().unwrap();
        let mut by_name = self.by_name.write().unwrap();

        for (id, name, kind, size) in builtins {
            let desc = TypeDescriptor {
                id,
                name: name.to_string(),
                kind,
                size,
                alignment: size.max(1),
                fields: Vec::new(),
                methods: Vec::new(),
                traits: Vec::new(),
                parent: None,
                generics: Vec::new(),
                annotations: Vec::new(),
            };
            types.insert(id, desc);
            by_name.insert(name.to_string(), id);
        }
    }

    /// Register a new type
    pub fn register(&self, desc: TypeDescriptor) -> TypeId {
        let id = desc.id;
        let name = desc.name.clone();

        let mut types = self.types.write().unwrap();
        let mut by_name = self.by_name.write().unwrap();

        types.insert(id, desc);
        by_name.insert(name, id);

        id
    }

    /// Allocate a new type ID
    pub fn allocate_id(&self) -> TypeId {
        TypeId(self.next_id.fetch_add(1, Ordering::SeqCst))
    }

    /// Lookup type by ID
    pub fn get(&self, id: TypeId) -> Option<TypeDescriptor> {
        let types = self.types.read().unwrap();
        types.get(&id).cloned()
    }

    /// Lookup type by name
    pub fn get_by_name(&self, name: &str) -> Option<TypeId> {
        let by_name = self.by_name.read().unwrap();
        by_name.get(name).copied()
    }

    /// Check if type A is subtype of type B
    pub fn is_subtype(&self, a: TypeId, b: TypeId) -> bool {
        if a == b {
            return true;
        }

        let types = self.types.read().unwrap();
        if let Some(desc) = types.get(&a) {
            if let Some(parent) = desc.parent {
                return self.is_subtype(parent, b);
            }

            // Check interfaces
            if desc.traits.contains(&b) {
                return true;
            }
        }

        false
    }

    /// Instantiate a generic type
    pub fn instantiate(&self, generic: TypeId, params: Vec<TypeId>) -> TypeId {
        let key = (generic, params.clone());

        // Check cache
        {
            let cache = self.instantiations.read().unwrap();
            if let Some(&id) = cache.get(&key) {
                return id;
            }
        }

        // Create new instantiation
        let base = self.get(generic).unwrap();
        let new_id = self.allocate_id();

        let instantiated = TypeDescriptor {
            id: new_id,
            name: format!("{}<{}>", base.name, params.iter().map(|p| format!("{}", p.0)).collect::<Vec<_>>().join(", ")),
            kind: base.kind,
            size: base.size,
            alignment: base.alignment,
            fields: base.fields.clone(),
            methods: base.methods.clone(),
            traits: base.traits.clone(),
            parent: base.parent,
            generics: params.clone(),
            annotations: base.annotations.clone(),
        };

        self.register(instantiated);

        // Cache
        let mut cache = self.instantiations.write().unwrap();
        cache.insert(key, new_id);

        new_id
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED MEMORY MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Memory pool (slab allocator) for fixed-size objects
pub struct MemoryPool {
    slab_size: usize,
    object_size: usize,
    slabs: RwLock<Vec<Slab>>,
    free_list: Mutex<Vec<*mut u8>>,
}

struct Slab {
    memory: Vec<u8>,
    used: usize,
    capacity: usize,
}

impl MemoryPool {
    pub fn new(object_size: usize, initial_capacity: usize) -> Self {
        let slab_size = 64 * 1024; // 64KB slabs
        let objects_per_slab = slab_size / object_size;

        let mut pool = MemoryPool {
            slab_size,
            object_size,
            slabs: RwLock::new(Vec::new()),
            free_list: Mutex::new(Vec::new()),
        };

        // Pre-allocate initial slabs
        let initial_slabs = (initial_capacity + objects_per_slab - 1) / objects_per_slab;
        for _ in 0..initial_slabs {
            pool.allocate_slab();
        }

        pool
    }

    fn allocate_slab(&self) {
        let slab = Slab {
            memory: vec![0u8; self.slab_size],
            used: 0,
            capacity: self.slab_size / self.object_size,
        };

        let mut slabs = self.slabs.write().unwrap();
        slabs.push(slab);
    }

    /// Allocate an object from the pool
    pub fn allocate(&self) -> Option<*mut u8> {
        // Try free list first
        {
            let mut free_list = self.free_list.lock().unwrap();
            if let Some(ptr) = free_list.pop() {
                return Some(ptr);
            }
        }

        // Allocate from current slab
        let mut slabs = self.slabs.write().unwrap();
        for slab in slabs.iter_mut() {
            if slab.used < slab.capacity {
                let offset = slab.used * self.object_size;
                slab.used += 1;
                return Some(slab.memory.as_mut_ptr().wrapping_add(offset));
            }
        }

        // Need new slab
        drop(slabs);
        self.allocate_slab();
        self.allocate()
    }

    /// Return an object to the pool
    pub fn deallocate(&self, ptr: *mut u8) {
        let mut free_list = self.free_list.lock().unwrap();
        free_list.push(ptr);
    }
}

/// Memory arena for bump allocation
pub struct Arena {
    chunks: RwLock<Vec<ArenaChunk>>,
    current: Mutex<ArenaChunk>,
    chunk_size: usize,
}

struct ArenaChunk {
    memory: Vec<u8>,
    offset: usize,
}

impl Arena {
    pub fn new(chunk_size: usize) -> Self {
        Arena {
            chunks: RwLock::new(Vec::new()),
            current: Mutex::new(ArenaChunk {
                memory: vec![0u8; chunk_size],
                offset: 0,
            }),
            chunk_size,
        }
    }

    /// Allocate memory from the arena (bump allocation)
    pub fn allocate(&self, size: usize, align: usize) -> *mut u8 {
        let mut current = self.current.lock().unwrap();

        // Align the offset
        let aligned_offset = (current.offset + align - 1) & !(align - 1);

        if aligned_offset + size <= current.memory.len() {
            let ptr = current.memory.as_mut_ptr().wrapping_add(aligned_offset);
            current.offset = aligned_offset + size;
            return ptr;
        }

        // Need new chunk
        let old_chunk = std::mem::replace(&mut *current, ArenaChunk {
            memory: vec![0u8; self.chunk_size.max(size + align)],
            offset: 0,
        });

        let mut chunks = self.chunks.write().unwrap();
        chunks.push(old_chunk);

        // Allocate from new chunk
        let aligned_offset = (current.offset + align - 1) & !(align - 1);
        let ptr = current.memory.as_mut_ptr().wrapping_add(aligned_offset);
        current.offset = aligned_offset + size;
        ptr
    }

    /// Reset the arena, reusing memory
    pub fn reset(&self) {
        let mut current = self.current.lock().unwrap();
        current.offset = 0;

        let mut chunks = self.chunks.write().unwrap();
        for chunk in chunks.iter_mut() {
            chunk.offset = 0;
        }
    }

    /// Total memory used
    pub fn used(&self) -> usize {
        let current = self.current.lock().unwrap();
        let chunks = self.chunks.read().unwrap();

        current.offset + chunks.iter().map(|c| c.offset).sum::<usize>()
    }
}

/// Stack frame for function execution
pub struct StackFrame {
    pub function: FunctionRef,
    pub locals: Vec<Value>,
    pub operand_stack: Vec<Value>,
    pub pc: usize,
    pub return_address: usize,
    pub exception_handlers: Vec<ExceptionHandler>,
    /// Monitor locks held
    pub monitors: Vec<usize>,
}

impl StackFrame {
    pub fn new(function: FunctionRef, num_locals: usize) -> Self {
        StackFrame {
            function,
            locals: vec![Value::Null; num_locals],
            operand_stack: Vec::with_capacity(32),
            pc: 0,
            return_address: 0,
            exception_handlers: Vec::new(),
            monitors: Vec::new(),
        }
    }

    pub fn push(&mut self, value: Value) {
        self.operand_stack.push(value);
    }

    pub fn pop(&mut self) -> Option<Value> {
        self.operand_stack.pop()
    }

    pub fn peek(&self) -> Option<&Value> {
        self.operand_stack.last()
    }

    pub fn stack_height(&self) -> usize {
        self.operand_stack.len()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOCK ELISION AND BIASED LOCKING
// ═══════════════════════════════════════════════════════════════════════════════

/// Lock manager with biased locking support
pub struct LockManager {
    locks: RwLock<HashMap<u64, LockInfo>>,
    next_id: AtomicU64,
    /// Bias revocation queue
    revocation_queue: Mutex<VecDeque<u64>>,
}

struct LockInfo {
    id: u64,
    state: LockState,
    owner: Option<ThreadId>,
    wait_queue: VecDeque<ThreadId>,
    recursion_count: u32,
}

impl LockManager {
    pub fn new() -> Self {
        LockManager {
            locks: RwLock::new(HashMap::new()),
            next_id: AtomicU64::new(0),
            revocation_queue: Mutex::new(VecDeque::new()),
        }
    }

    /// Create a new lock
    pub fn create_lock(&self) -> u64 {
        let id = self.next_id.fetch_add(1, Ordering::SeqCst);

        let mut locks = self.locks.write().unwrap();
        locks.insert(id, LockInfo {
            id,
            state: LockState::Unlocked,
            owner: None,
            wait_queue: VecDeque::new(),
            recursion_count: 0,
        });

        id
    }

    /// Acquire lock with biased locking
    pub fn lock(&self, lock_id: u64) -> Result<(), RuntimeError> {
        let thread_id = std::thread::current().id();

        let mut locks = self.locks.write().unwrap();
        let lock = locks.get_mut(&lock_id)
            .ok_or(RuntimeError::Other("Lock not found".to_string()))?;

        match lock.state {
            LockState::Unlocked => {
                // Fast path: bias to current thread
                lock.state = LockState::Biased(0); // Would use actual thread ID
                lock.owner = Some(thread_id);
                lock.recursion_count = 1;
                Ok(())
            }
            LockState::Biased(_) if lock.owner == Some(thread_id) => {
                // Recursive lock
                lock.recursion_count += 1;
                Ok(())
            }
            LockState::Biased(_) => {
                // Need to revoke bias
                self.revoke_bias(lock_id);
                lock.state = LockState::ThinLock(0);
                lock.owner = Some(thread_id);
                lock.recursion_count = 1;
                Ok(())
            }
            LockState::ThinLock(_) | LockState::FatLock(_) if lock.owner == Some(thread_id) => {
                // Recursive lock
                lock.recursion_count += 1;
                Ok(())
            }
            _ => {
                // Contention - inflate to fat lock and wait
                lock.state = LockState::FatLock(lock_id);
                lock.wait_queue.push_back(thread_id);
                // Would block here
                Ok(())
            }
        }
    }

    /// Release lock
    pub fn unlock(&self, lock_id: u64) -> Result<(), RuntimeError> {
        let thread_id = std::thread::current().id();

        let mut locks = self.locks.write().unwrap();
        let lock = locks.get_mut(&lock_id)
            .ok_or(RuntimeError::Other("Lock not found".to_string()))?;

        if lock.owner != Some(thread_id) {
            return Err(RuntimeError::Other("Not lock owner".to_string()));
        }

        lock.recursion_count -= 1;

        if lock.recursion_count == 0 {
            lock.owner = None;

            // Wake up next waiter
            if let Some(waiter) = lock.wait_queue.pop_front() {
                lock.owner = Some(waiter);
                lock.recursion_count = 1;
                // Would wake thread here
            } else {
                lock.state = LockState::Unlocked;
            }
        }

        Ok(())
    }

    fn revoke_bias(&self, lock_id: u64) {
        let mut queue = self.revocation_queue.lock().unwrap();
        queue.push_back(lock_id);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXCEPTION HANDLING
// ═══════════════════════════════════════════════════════════════════════════════

/// Runtime exception
#[derive(Debug, Clone)]
pub struct Exception {
    pub type_id: TypeId,
    pub message: String,
    pub cause: Option<Box<Exception>>,
    pub stack_trace: Vec<StackTraceElement>,
}

impl Exception {
    pub fn new(type_id: TypeId, message: String) -> Self {
        Exception {
            type_id,
            message,
            cause: None,
            stack_trace: Vec::new(),
        }
    }

    pub fn with_cause(mut self, cause: Exception) -> Self {
        self.cause = Some(Box::new(cause));
        self
    }

    pub fn capture_stack_trace(&mut self, frames: &[StackFrame]) {
        self.stack_trace = frames.iter().map(|f| StackTraceElement {
            function: f.function.clone(),
            pc: f.pc,
            line_number: None,
            source_file: None,
        }).collect();
    }
}

/// Stack trace element
#[derive(Debug, Clone)]
pub struct StackTraceElement {
    pub function: FunctionRef,
    pub pc: usize,
    pub line_number: Option<u32>,
    pub source_file: Option<String>,
}

/// Exception dispatcher
pub struct ExceptionDispatcher {
    handlers: RwLock<HashMap<TypeId, ExceptionHandlerCallback>>,
}

type ExceptionHandlerCallback = Arc<dyn Fn(&Exception) + Send + Sync>;

impl ExceptionDispatcher {
    pub fn new() -> Self {
        ExceptionDispatcher {
            handlers: RwLock::new(HashMap::new()),
        }
    }

    /// Register a global exception handler
    pub fn register_handler<F>(&self, type_id: TypeId, handler: F)
    where
        F: Fn(&Exception) + Send + Sync + 'static,
    {
        let mut handlers = self.handlers.write().unwrap();
        handlers.insert(type_id, Arc::new(handler));
    }

    /// Find a handler for an exception
    pub fn find_handler(&self, exception: &Exception) -> Option<ExceptionHandlerCallback> {
        let handlers = self.handlers.read().unwrap();
        handlers.get(&exception.type_id).cloned()
    }

    /// Dispatch an exception
    pub fn dispatch(&self, exception: &Exception) {
        if let Some(handler) = self.find_handler(exception) {
            handler(exception);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTERPRETER
// ═══════════════════════════════════════════════════════════════════════════════

/// Bytecode interpreter
pub struct Interpreter {
    frames: Vec<StackFrame>,
    globals: HashMap<u32, Value>,
    type_registry: Arc<TypeRegistry>,
    debugger: Option<Arc<Debugger>>,
    jit: Option<Arc<JITCompiler>>,
}

impl Interpreter {
    pub fn new(type_registry: Arc<TypeRegistry>) -> Self {
        Interpreter {
            frames: Vec::new(),
            globals: HashMap::new(),
            type_registry,
            debugger: None,
            jit: None,
        }
    }

    pub fn attach_debugger(&mut self, debugger: Arc<Debugger>) {
        self.debugger = Some(debugger);
    }

    pub fn attach_jit(&mut self, jit: Arc<JITCompiler>) {
        self.jit = Some(jit);
    }

    /// Execute bytecode
    pub fn execute(&mut self, function: &Function, args: Vec<Value>) -> Result<Value, RuntimeError> {
        // Check if we should JIT compile
        if let Some(ref jit) = self.jit {
            if let Some(tier) = jit.record_execution(&function.reference) {
                // Compile and execute native code
                match jit.compile(function, tier) {
                    Ok(compiled) => {
                        // Would execute native code here
                    }
                    Err(_) => {
                        // Fall back to interpretation
                    }
                }
            }
        }

        // Create stack frame
        let mut frame = StackFrame::new(function.reference.clone(), function.locals.len());

        // Initialize arguments
        for (i, arg) in args.into_iter().enumerate() {
            if i < frame.locals.len() {
                frame.locals[i] = arg;
            }
        }

        self.frames.push(frame);

        // Execute loop
        loop {
            let frame = self.frames.last_mut().ok_or(RuntimeError::Other("No stack frame".to_string()))?;

            if frame.pc >= function.bytecode.len() {
                break;
            }

            let opcode = &function.bytecode[frame.pc];
            frame.pc += 1;

            // Check debugger
            if let Some(ref debugger) = self.debugger {
                let location = BreakpointLocation {
                    module_id: frame.function.module_id,
                    function_id: frame.function.function_id,
                    pc: frame.pc - 1,
                };

                if debugger.should_break(&location) {
                    debugger.emit(DebugEvent::BreakpointHit {
                        id: 0,
                        location
                    });
                }
            }

            match opcode {
                Opcode::Nop => {}

                Opcode::Push(v) => {
                    frame.push(v.clone());
                }

                Opcode::Pop => {
                    frame.pop();
                }

                Opcode::Dup => {
                    if let Some(v) = frame.peek() {
                        let v = v.clone();
                        frame.push(v);
                    }
                }

                Opcode::Add => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.binary_op(&a, &b, |x, y| x + y, |x, y| x + y)?;
                    frame.push(result);
                }

                Opcode::Sub => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.binary_op(&a, &b, |x, y| x - y, |x, y| x - y)?;
                    frame.push(result);
                }

                Opcode::Mul => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.binary_op(&a, &b, |x, y| x * y, |x, y| x * y)?;
                    frame.push(result);
                }

                Opcode::Div => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.binary_op(&a, &b, |x, y| x / y, |x, y| x / y)?;
                    frame.push(result);
                }

                Opcode::LoadLocal(idx) => {
                    let value = frame.locals.get(*idx as usize).cloned().unwrap_or(Value::Null);
                    frame.push(value);
                }

                Opcode::StoreLocal(idx) => {
                    let value = frame.pop().unwrap_or(Value::Null);
                    if (*idx as usize) < frame.locals.len() {
                        frame.locals[*idx as usize] = value;
                    }
                }

                Opcode::LoadGlobal(idx) => {
                    let value = self.globals.get(idx).cloned().unwrap_or(Value::Null);
                    frame.push(value);
                }

                Opcode::StoreGlobal(idx) => {
                    let value = frame.pop().unwrap_or(Value::Null);
                    self.globals.insert(*idx, value);
                }

                Opcode::Jump(target) => {
                    frame.pc = *target;
                }

                Opcode::JumpIf(target) => {
                    let cond = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    if cond.is_truthy() {
                        frame.pc = *target;
                    }
                }

                Opcode::JumpIfNot(target) => {
                    let cond = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    if !cond.is_truthy() {
                        frame.pc = *target;
                    }
                }

                Opcode::Return | Opcode::ReturnVoid => {
                    let result = frame.pop().unwrap_or(Value::Null);
                    self.frames.pop();

                    if self.frames.is_empty() {
                        return Ok(result);
                    } else {
                        self.frames.last_mut().unwrap().push(result);
                    }
                }

                Opcode::Eq => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    frame.push(Value::Bool(self.equals(&a, &b)));
                }

                Opcode::Lt => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.compare(&a, &b)?;
                    frame.push(Value::Bool(result < 0));
                }

                Opcode::Le => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.compare(&a, &b)?;
                    frame.push(Value::Bool(result <= 0));
                }

                Opcode::Gt => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.compare(&a, &b)?;
                    frame.push(Value::Bool(result > 0));
                }

                Opcode::Ge => {
                    let b = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let a = frame.pop().ok_or(RuntimeError::Other("Stack underflow".to_string()))?;
                    let result = self.compare(&a, &b)?;
                    frame.push(Value::Bool(result >= 0));
                }

                _ => {
                    // Handle other opcodes
                }
            }
        }

        // Implicit return
        let frame = self.frames.pop();
        Ok(frame.and_then(|f| f.operand_stack.last().cloned()).unwrap_or(Value::Null))
    }

    fn binary_op<I, F>(&self, a: &Value, b: &Value, int_op: I, float_op: F) -> Result<Value, RuntimeError>
    where
        I: Fn(i64, i64) -> i64,
        F: Fn(f64, f64) -> f64,
    {
        match (a, b) {
            (Value::Int64(x), Value::Int64(y)) => Ok(Value::Int64(int_op(*x, *y))),
            (Value::Int32(x), Value::Int32(y)) => Ok(Value::Int32(int_op(*x as i64, *y as i64) as i32)),
            (Value::Float64(x), Value::Float64(y)) => Ok(Value::Float64(float_op(*x, *y))),
            (Value::Float32(x), Value::Float32(y)) => Ok(Value::Float32(float_op(*x as f64, *y as f64) as f32)),
            _ => Err(RuntimeError::Other("Type mismatch in binary operation".to_string())),
        }
    }

    fn equals(&self, a: &Value, b: &Value) -> bool {
        match (a, b) {
            (Value::Null, Value::Null) => true,
            (Value::Bool(x), Value::Bool(y)) => x == y,
            (Value::Int64(x), Value::Int64(y)) => x == y,
            (Value::Float64(x), Value::Float64(y)) => x == y,
            (Value::String(x), Value::String(y)) => x == y,
            _ => false,
        }
    }

    fn compare(&self, a: &Value, b: &Value) -> Result<i32, RuntimeError> {
        match (a, b) {
            (Value::Int64(x), Value::Int64(y)) => Ok(x.cmp(y) as i32),
            (Value::Float64(x), Value::Float64(y)) => {
                if x < y { Ok(-1) }
                else if x > y { Ok(1) }
                else { Ok(0) }
            }
            (Value::String(x), Value::String(y)) => Ok(x.cmp(y) as i32),
            _ => Err(RuntimeError::Other("Cannot compare values".to_string())),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEBUGGING SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Debugger interface
pub struct Debugger {
    breakpoints: RwLock<HashMap<BreakpointLocation, Breakpoint>>,
    watches: RwLock<Vec<Watch>>,
    stepping: AtomicBool,
    step_mode: Mutex<StepMode>,
    event_handlers: RwLock<Vec<DebugEventHandler>>,
}

type DebugEventHandler = Arc<dyn Fn(&DebugEvent) + Send + Sync>;

impl Debugger {
    pub fn new() -> Self {
        Debugger {
            breakpoints: RwLock::new(HashMap::new()),
            watches: RwLock::new(Vec::new()),
            stepping: AtomicBool::new(false),
            step_mode: Mutex::new(StepMode::None),
            event_handlers: RwLock::new(Vec::new()),
        }
    }

    /// Set a breakpoint
    pub fn set_breakpoint(&self, location: BreakpointLocation, condition: Option<String>) -> u64 {
        let mut breakpoints = self.breakpoints.write().unwrap();
        let id = breakpoints.len() as u64;
        breakpoints.insert(location.clone(), Breakpoint {
            id,
            location,
            condition,
            enabled: true,
            hit_count: AtomicU64::new(0),
        });
        id
    }

    /// Remove a breakpoint
    pub fn remove_breakpoint(&self, location: &BreakpointLocation) {
        let mut breakpoints = self.breakpoints.write().unwrap();
        breakpoints.remove(location);
    }

    /// Check if we should break at a location
    pub fn should_break(&self, location: &BreakpointLocation) -> bool {
        let breakpoints = self.breakpoints.read().unwrap();
        if let Some(bp) = breakpoints.get(location) {
            if bp.enabled {
                bp.hit_count.fetch_add(1, Ordering::SeqCst);
                return true;
            }
        }
        false
    }

    /// Emit a debug event
    pub fn emit(&self, event: DebugEvent) {
        let handlers = self.event_handlers.read().unwrap();
        for handler in handlers.iter() {
            handler(&event);
        }
    }
}

#[derive(Clone, Hash, PartialEq, Eq)]
pub struct BreakpointLocation {
    pub module_id: u32,
    pub function_id: u32,
    pub pc: usize,
}

pub struct Breakpoint {
    pub id: u64,
    pub location: BreakpointLocation,
    pub condition: Option<String>,
    pub enabled: bool,
    pub hit_count: AtomicU64,
}

pub struct Watch {
    pub id: u64,
    pub expression: String,
    pub last_value: Option<Value>,
}

#[derive(Clone, Copy, Debug)]
pub enum StepMode {
    None,
    StepInto,
    StepOver,
    StepOut,
}

#[derive(Debug)]
pub enum DebugEvent {
    BreakpointHit { id: u64, location: BreakpointLocation },
    StepComplete { location: BreakpointLocation },
    ExceptionThrown { exception: Exception },
    ModuleLoaded { module_id: u32, name: String },
    ThreadCreated { thread_id: u64 },
    ThreadExited { thread_id: u64 },
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_runtime_config_default() {
        let config = RuntimeConfig::default();
        assert_eq!(config.thread_pool_size, 8);
        assert!(config.gc_config.enabled);
        assert!(config.scheduler_config.work_stealing);
    }

    #[test]
    fn test_type_id_properties() {
        assert!(TypeId::INT32.is_primitive());
        assert!(TypeId::INT64.is_numeric());
        assert!(TypeId::INT32.is_integer());
        assert!(TypeId::FLOAT64.is_floating_point());
        assert!(!TypeId::STRING.is_primitive());
    }

    #[test]
    fn test_value_is_truthy() {
        assert!(!Value::Null.is_truthy());
        assert!(Value::Bool(true).is_truthy());
        assert!(!Value::Bool(false).is_truthy());
        assert!(Value::Int64(1).is_truthy());
        assert!(!Value::Int64(0).is_truthy());
    }

    #[test]
    fn test_work_stealing_queue() {
        let queue: WorkStealingQueue<i32> = WorkStealingQueue::new();

        queue.push(1);
        queue.push(2);
        queue.push(3);

        assert_eq!(queue.len(), 3);
        assert_eq!(queue.pop(), Some(3)); // LIFO for owner
        assert_eq!(queue.steal(), Some(1)); // FIFO for thieves
        assert_eq!(queue.len(), 1);
    }

    #[test]
    fn test_task_priority_weight() {
        assert!(TaskPriority::Critical.weight() > TaskPriority::Normal.weight());
        assert!(TaskPriority::Normal.weight() > TaskPriority::Low.weight());
    }

    #[test]
    fn test_memory_pool() {
        let pool = MemoryPool::new(64, 100);

        let ptr1 = pool.allocate();
        assert!(ptr1.is_some());

        let ptr2 = pool.allocate();
        assert!(ptr2.is_some());
        assert_ne!(ptr1, ptr2);
    }

    #[test]
    fn test_arena_allocation() {
        let arena = Arena::new(4096);

        let ptr1 = arena.allocate(64, 8);
        let ptr2 = arena.allocate(128, 8);

        assert!(!ptr1.is_null());
        assert!(!ptr2.is_null());
        assert_ne!(ptr1, ptr2);
    }

    #[test]
    fn test_type_registry() {
        let registry = TypeRegistry::new();

        assert!(registry.get(TypeId::INT32).is_some());
        assert!(registry.get_by_name("i32").is_some());
        assert!(registry.is_subtype(TypeId::INT32, TypeId::INT32));
    }

    #[test]
    fn test_gc_config_default() {
        let config = GCConfig::default();
        assert!(config.enabled);
        assert!(config.escape_analysis);
        assert!(matches!(config.gc_type, GCType::Generational));
    }

    #[test]
    fn test_jit_tier_ordering() {
        assert!(JITTier::PGO as u8 > JITTier::Optimizing as u8);
        assert!(JITTier::Optimizing as u8 > JITTier::Baseline as u8);
        assert!(JITTier::Baseline as u8 > JITTier::Interpreter as u8);
    }

    #[test]
    fn test_fiber_state() {
        assert_eq!(FiberState::Ready, FiberState::Ready);
        assert_ne!(FiberState::Ready, FiberState::Running);
    }

    #[test]
    fn test_stack_frame() {
        let func_ref = FunctionRef {
            module_id: 0,
            function_id: 0,
            arity: 0,
        };

        let mut frame = StackFrame::new(func_ref, 4);
        assert_eq!(frame.locals.len(), 4);

        frame.push(Value::Int64(42));
        assert_eq!(frame.stack_height(), 1);

        let val = frame.pop();
        assert!(matches!(val, Some(Value::Int64(42))));
    }

    #[test]
    fn test_version_display() {
        let version = Version { major: 1, minor: 2, patch: 3 };
        assert_eq!(format!("{}", version), "1.2.3");
    }

    #[test]
    fn test_ir_basic_block() {
        let block = BasicBlock::new(0);
        assert_eq!(block.id, 0);
        assert!(block.instructions.is_empty());
        assert!(block.terminator.is_none());
    }

    #[test]
    fn test_exception_creation() {
        let mut exc = Exception::new(TypeId::OBJECT, "Test error".to_string());
        assert!(exc.cause.is_none());
        assert!(exc.stack_trace.is_empty());

        exc = exc.with_cause(Exception::new(TypeId::OBJECT, "Inner".to_string()));
        assert!(exc.cause.is_some());
    }

    #[test]
    fn test_value_conversion() {
        assert_eq!(Value::Int32(42).to_i64(), Some(42));
        assert_eq!(Value::Float64(3.14).to_f64(), Some(3.14));
        assert!(Value::String(Arc::new("hello".to_string())).to_i64().is_none());
    }

    #[test]
    fn test_allocation_flags() {
        let flags = AllocationFlags::default();
        assert!(!flags.pinned);
        assert!(!flags.executable);
        assert!(flags.zero_filled);
    }

    #[test]
    fn test_generation() {
        assert_ne!(Generation::Young, Generation::Old);
        assert_ne!(Generation::Survivor, Generation::Permanent);
    }

    #[test]
    fn test_deopt_reason() {
        let reason = DeoptReason::TypeMismatch;
        assert!(matches!(reason, DeoptReason::TypeMismatch));
    }
}
