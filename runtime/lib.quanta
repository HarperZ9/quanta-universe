    pub branch_frequencies: HashMap<usize, f64>,
    pub type_feedback: HashMap<usize, Vec<TypeId>>,
}

/// Compilation error
#[derive(Debug)]
pub enum CompileError {
    InvalidBytecode(String),
    UnsupportedFeature(String),
    InternalError(String),
    OutOfMemory,
    CodeCacheFull,
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTERMEDIATE REPRESENTATION
// ═══════════════════════════════════════════════════════════════════════════════

/// IR Builder - converts bytecode to SSA form IR
pub struct IRBuilder {
    next_reg: u32,
    blocks: Vec<BasicBlock>,
}

impl IRBuilder {
    pub fn new() -> Self {
        IRBuilder {
            next_reg: 0,
            blocks: Vec::new(),
        }
    }

    pub fn build(&self, bytecode: &[Opcode]) -> Result<IRFunction, CompileError> {
        let mut blocks = Vec::new();
        let mut current_block = BasicBlock::new(0);

        for (i, op) in bytecode.iter().enumerate() {
            match op {
                Opcode::Jump(target) => {
                    current_block.terminator = Some(IRTerminator::Jump(*target));
                    blocks.push(current_block);
                    current_block = BasicBlock::new(blocks.len());
                }
                Opcode::JumpIf(target) => {
                    current_block.terminator = Some(IRTerminator::Branch {
                        cond: IRValue::Reg(current_block.instructions.len() as u32),
                        then_block: *target,
                        else_block: i + 1,
                    });
                    blocks.push(current_block);
                    current_block = BasicBlock::new(blocks.len());
                }
                Opcode::Return | Opcode::ReturnVoid => {
                    current_block.terminator = Some(IRTerminator::Return(None));
                    blocks.push(current_block);
                    current_block = BasicBlock::new(blocks.len());
                }
                _ => {
                    let ir_instr = self.opcode_to_ir(op)?;
                    current_block.instructions.push(ir_instr);
                }
            }
        }

        if current_block.terminator.is_none() {
            current_block.terminator = Some(IRTerminator::Return(None));
        }
        blocks.push(current_block);

        Ok(IRFunction { blocks, locals: Vec::new() })
    }

    /// Build IR for on-stack replacement starting at entry_pc
    pub fn build_osr(&self, bytecode: &[Opcode], entry_pc: usize) -> Result<IRFunction, CompileError> {
        // Build full IR first
        let mut ir = self.build(bytecode)?;

        // Mark entry block
        // In practice, would need to insert OSR entry prologue

        Ok(ir)
    }

    fn opcode_to_ir(&self, op: &Opcode) -> Result<IRInstruction, CompileError> {
        match op {
            Opcode::Add => Ok(IRInstruction::BinOp(IRBinOp::Add, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Sub => Ok(IRInstruction::BinOp(IRBinOp::Sub, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Mul => Ok(IRInstruction::BinOp(IRBinOp::Mul, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Div => Ok(IRInstruction::BinOp(IRBinOp::Div, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Mod => Ok(IRInstruction::BinOp(IRBinOp::Mod, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::And => Ok(IRInstruction::BinOp(IRBinOp::And, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Or => Ok(IRInstruction::BinOp(IRBinOp::Or, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Xor => Ok(IRInstruction::BinOp(IRBinOp::Xor, IRValue::Stack(0), IRValue::Stack(1))),
            Opcode::Push(v) => Ok(IRInstruction::Const(v.clone())),
            Opcode::LoadLocal(idx) => Ok(IRInstruction::Load(IRValue::Local(*idx as u32))),
            Opcode::StoreLocal(idx) => Ok(IRInstruction::Store(IRValue::Local(*idx as u32), IRValue::Stack(0))),
            Opcode::Neg => Ok(IRInstruction::UnOp(IRUnOp::Neg, IRValue::Stack(0))),
            Opcode::Not => Ok(IRInstruction::UnOp(IRUnOp::Not, IRValue::Stack(0))),
            _ => Ok(IRInstruction::Nop),
        }
    }
}

/// IR Function in SSA form
pub struct IRFunction {
    pub blocks: Vec<BasicBlock>,
    pub locals: Vec<IRLocal>,
}

#[derive(Clone)]
pub struct IRLocal {
    pub name: String,
    pub type_id: TypeId,
    pub is_param: bool,
}

/// Basic block in the control flow graph
pub struct BasicBlock {
    pub id: usize,
    pub instructions: Vec<IRInstruction>,
    pub terminator: Option<IRTerminator>,
    pub predecessors: Vec<usize>,
    pub successors: Vec<usize>,
    /// Phi nodes at block entry
    pub phis: Vec<PhiNode>,
    /// Loop depth (for optimization prioritization)
    pub loop_depth: u32,
}

#[derive(Clone)]
pub struct PhiNode {
    pub dest: u32,
    pub operands: Vec<(usize, IRValue)>,
}

impl BasicBlock {
    pub fn new(id: usize) -> Self {
        BasicBlock {
            id,
            instructions: Vec::new(),
            terminator: None,
            predecessors: Vec::new(),
            successors: Vec::new(),
            phis: Vec::new(),
            loop_depth: 0,
        }
    }
}

/// IR Instructions
#[derive(Clone, Debug)]
pub enum IRInstruction {
    Nop,
    Const(Value),
    BinOp(IRBinOp, IRValue, IRValue),
    UnOp(IRUnOp, IRValue),
    Load(IRValue),
    Store(IRValue, IRValue),
    Call(FunctionRef, Vec<IRValue>),
    Phi(Vec<(usize, IRValue)>),
    Alloca(TypeId),
    GetElementPtr(IRValue, Vec<IRValue>),
    Cast(IRValue, TypeId),
    /// Memory barrier
    Fence(MemoryOrdering),
    /// Compare and swap
    CmpXchg(IRValue, IRValue, IRValue),
    /// Atomic load
    AtomicLoad(IRValue, MemoryOrdering),
    /// Atomic store
    AtomicStore(IRValue, IRValue, MemoryOrdering),
    /// Call with inline cache
    CallVirtualIC(u32, IRValue, Vec<IRValue>),
    /// Type guard for speculative optimization
    TypeGuard(IRValue, TypeId, usize),
    /// Bounds check
    BoundsCheck(IRValue, IRValue),
    /// Null check
    NullCheck(IRValue),
}

#[derive(Clone, Copy, Debug)]
pub enum MemoryOrdering {
    Relaxed,
    Acquire,
    Release,
    AcqRel,
    SeqCst,
}

/// IR Binary operations
#[derive(Clone, Copy, Debug)]
pub enum IRBinOp {
    Add,
    Sub,
    Mul,
    Div,
    Mod,
    And,
    Or,
    Xor,
    Shl,
    Shr,
    Ushr,
    Eq,
    Ne,
    Lt,
    Le,
    Gt,
    Ge,
    /// Fused multiply-add
    Fma,
}

/// IR Unary operations
#[derive(Clone, Copy, Debug)]
pub enum IRUnOp {
    Neg,
    Not,
    Deref,
    AddressOf,
    Sqrt,
    Abs,
    Floor,
    Ceil,
    Round,
}

/// IR Values
#[derive(Clone, Debug)]
pub enum IRValue {
    Reg(u32),
    Stack(u32),
    Local(u32),
    Global(u32),
    Const(i64),
    Float(f64),
    /// Immediate pointer
    ImmPtr(usize),
}

/// IR Block terminators
#[derive(Clone, Debug)]
pub enum IRTerminator {
    Jump(usize),
    Branch { cond: IRValue, then_block: usize, else_block: usize },
    Switch { value: IRValue, cases: Vec<(i64, usize)>, default: usize },
    Return(Option<IRValue>),
    Unreachable,
    /// Throw exception
    Throw(IRValue),
    /// Tail call
    TailCall(FunctionRef, Vec<IRValue>),
}

// ═══════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION PASSES
// ═══════════════════════════════════════════════════════════════════════════════

/// IR Optimizer with configurable passes
pub struct Optimizer {
    tier: JITTier,
    passes: Vec<Box<dyn OptimizationPass>>,
}

impl Optimizer {
    pub fn new(tier: JITTier) -> Self {
        let mut passes: Vec<Box<dyn OptimizationPass>> = Vec::new();

        // Add passes based on optimization tier
        match tier {
            JITTier::Interpreter => {}
            JITTier::Baseline => {
                passes.push(Box::new(ConstantFolding));
                passes.push(Box::new(DeadCodeElimination));
                passes.push(Box::new(SimplePeephole));
            }
            JITTier::Optimizing => {
                passes.push(Box::new(ConstantFolding));
                passes.push(Box::new(DeadCodeElimination));
                passes.push(Box::new(CommonSubexpressionElimination));
                passes.push(Box::new(LoopInvariantCodeMotion));
                passes.push(Box::new(InstructionCombining));
                passes.push(Box::new(Inlining));
                passes.push(Box::new(EscapeAnalysis));
                passes.push(Box::new(ScalarReplacement));
                passes.push(Box::new(StrengthReduction));
                passes.push(Box::new(TailCallOptimization));
            }
            JITTier::PGO => {
                passes.push(Box::new(ConstantFolding));
                passes.push(Box::new(DeadCodeElimination));
                passes.push(Box::new(CommonSubexpressionElimination));
                passes.push(Box::new(LoopInvariantCodeMotion));
                passes.push(Box::new(InstructionCombining));
                passes.push(Box::new(Inlining));
                passes.push(Box::new(EscapeAnalysis));
                passes.push(Box::new(ScalarReplacement));
                passes.push(Box::new(ProfileGuidedOptimization));
                passes.push(Box::new(LoopUnrolling));
                passes.push(Box::new(Vectorization));
                passes.push(Box::new(SpeculativeDevirtualization));
                passes.push(Box::new(BranchPredictionHints));
            }
        }

        Optimizer { tier, passes }
    }

    pub fn optimize(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        let mut current = ir;

        for pass in &self.passes {
            current = pass.run(current)?;
        }

        Ok(current)
    }
}

/// Optimization pass trait
pub trait OptimizationPass: Send + Sync {
    fn name(&self) -> &'static str;
    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError>;
}

/// Constant folding pass
pub struct ConstantFolding;

impl OptimizationPass for ConstantFolding {
    fn name(&self) -> &'static str { "constant-folding" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Fold constant expressions at compile time
        // e.g., 2 + 3 -> 5
        Ok(ir)
    }
}

/// Dead code elimination pass
pub struct DeadCodeElimination;

impl OptimizationPass for DeadCodeElimination {
    fn name(&self) -> &'static str { "dead-code-elimination" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Remove unreachable code and unused computations
        Ok(ir)
    }
}

/// Simple peephole optimizations
pub struct SimplePeephole;

impl OptimizationPass for SimplePeephole {
    fn name(&self) -> &'static str { "peephole" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Pattern matching for simple optimizations
        Ok(ir)
    }
}

/// Common subexpression elimination
pub struct CommonSubexpressionElimination;

impl OptimizationPass for CommonSubexpressionElimination {
    fn name(&self) -> &'static str { "cse" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Reuse results of identical computations
        Ok(ir)
    }
}

/// Loop invariant code motion
pub struct LoopInvariantCodeMotion;

impl OptimizationPass for LoopInvariantCodeMotion {
    fn name(&self) -> &'static str { "licm" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Move loop-invariant computations outside loops
        Ok(ir)
    }
}

/// Instruction combining
pub struct InstructionCombining;

impl OptimizationPass for InstructionCombining {
    fn name(&self) -> &'static str { "instcombine" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Combine instructions into more efficient forms
        // e.g., x * 2 -> x << 1
        Ok(ir)
    }
}

/// Function inlining
pub struct Inlining;

impl OptimizationPass for Inlining {
    fn name(&self) -> &'static str { "inline" }

    fn run(&self, ir: IRFunction) -> Result<IRFunction, CompileError> {
        // Inline small functions at call sites
        Ok(ir)
    }
}

/// Escape analysis
