}

/// GC safe point information
#[derive(Clone, Debug)]
pub struct SafePoint {
    pub offset: usize,
    pub stack_map: Vec<StackSlotInfo>,
}

/// Stack slot information for GC
#[derive(Clone, Debug)]
pub struct StackSlotInfo {
