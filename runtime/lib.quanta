/// Register allocator using graph coloring
pub struct RegisterAllocator {
    registers: Vec<Register>,
    interference_graph: HashMap<u32, Vec<u32>>,
}

impl RegisterAllocator {
    pub fn new() -> Self {
        RegisterAllocator {
            registers: Vec::new(),
            interference_graph: HashMap::new(),
        }
    }

    pub fn allocate(&mut self, ir: &IRFunction) -> Result<RegisterAssignment, CompileError> {
        // Build interference graph
        self.build_interference_graph(ir);

        // Coalesce registers (copy propagation)
        self.coalesce();

        // Simplify graph
        self.simplify();

        // Color the graph
        let coloring = self.color_graph()?;

        // Assign registers
        Ok(RegisterAssignment { mapping: coloring })
    }

