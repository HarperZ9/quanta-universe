// QUANTA Lumina - Depth of Field
// Physically-based bokeh and cinematic DoF effects
// Includes circular, hexagonal, and custom aperture shapes

module lumina::dof;

use core::simd::{Vec2, Vec3, Vec4, Mat4x4};
use core::math::{pow, sqrt, abs, sin, cos, exp, log, PI, clamp, lerp, smoothstep, floor, ceil};
use core::gpu::{Texture2D, TextureFormat, RenderTarget, ComputeShader};

// ============================================================================
// DOF CONFIGURATION
// ============================================================================

/// DoF quality presets
enum DofQuality {
    Low,        // Simple gaussian blur
    Medium,     // Separable bokeh
    High,       // Scatter-based bokeh
    Ultra,      // Sprite-based gather
    Cinematic,  // Full physically-based
}

/// Aperture blade shapes
enum ApertureShape {
    /// Circular aperture (ideal)
    Circle,

    /// Polygonal aperture (blade count determines shape)
    Polygon(u32),

    /// Anamorphic (oval) aperture
    Anamorphic { ratio: f32, rotation: f32 },

    /// Custom aperture from texture
    Custom,
}

impl ApertureShape {
    fn pentagon() -> Self { ApertureShape::Polygon(5) }
    fn hexagon() -> Self { ApertureShape::Polygon(6) }
    fn heptagon() -> Self { ApertureShape::Polygon(7) }
    fn octagon() -> Self { ApertureShape::Polygon(8) }
}

/// Depth of field configuration
struct DofConfig {
    /// Enable DoF
    enabled: bool,

    /// Quality preset
    quality: DofQuality,

    /// Focus distance (world units)
    focus_distance: f32,

    /// Aperture f-stop (lower = more blur)
    aperture: f32,

    /// Focal length in mm
    focal_length: f32,

    /// Sensor height in mm (determines FoV relationship)
    sensor_height: f32,

    /// Maximum blur radius in pixels
    max_blur_radius: f32,

    /// Minimum blur radius threshold
    min_blur_radius: f32,

    /// Aperture shape
    aperture_shape: ApertureShape,

    /// Aperture blade curvature (for polygons)
    blade_curvature: f32,

    /// Aperture rotation angle
    aperture_rotation: f32,

    /// Enable foreground blur
    foreground_blur: bool,

    /// Foreground blur boost (makes near blur more visible)
    foreground_boost: f32,

    /// Chromatic aberration in bokeh
    chromatic_aberration: f32,

    /// Spherical aberration (cats-eye effect)
    spherical_aberration: f32,

    /// Optical vignetting
    optical_vignetting: f32,

    /// Sample count
    sample_count: u32,
}

impl DofConfig {
    fn default() -> Self {
        Self {
            enabled: true,
            quality: DofQuality::High,
            focus_distance: 5.0,
            aperture: 2.8,
            focal_length: 50.0,
            sensor_height: 24.0,
            max_blur_radius: 40.0,
            min_blur_radius: 0.5,
            aperture_shape: ApertureShape::hexagon(),
            blade_curvature: 0.0,
            aperture_rotation: 0.0,
            foreground_blur: true,
            foreground_boost: 1.5,
            chromatic_aberration: 0.0,
            spherical_aberration: 0.0,
            optical_vignetting: 0.0,
            sample_count: 64,
        }
    }

    fn cinematic() -> Self {
        Self {
            enabled: true,
            quality: DofQuality::Cinematic,
            focus_distance: 3.0,
            aperture: 1.4,
            focal_length: 85.0,
            sensor_height: 24.0,
            max_blur_radius: 60.0,
            min_blur_radius: 0.5,
            aperture_shape: ApertureShape::Polygon(9),
            blade_curvature: 0.3,
            aperture_rotation: 0.0,
            foreground_blur: true,
            foreground_boost: 2.0,
            chromatic_aberration: 0.02,
            spherical_aberration: 0.3,
            optical_vignetting: 0.2,
            sample_count: 128,
        }
    }

    fn portrait() -> Self {
        Self {
            enabled: true,
            quality: DofQuality::High,
            focus_distance: 2.0,
            aperture: 1.8,
            focal_length: 85.0,
            sensor_height: 36.0,  // Full frame
            max_blur_radius: 80.0,
            min_blur_radius: 0.5,
            aperture_shape: ApertureShape::Circle,
            blade_curvature: 0.0,
            aperture_rotation: 0.0,
            foreground_blur: true,
            foreground_boost: 1.2,
            chromatic_aberration: 0.01,
            spherical_aberration: 0.1,
            optical_vignetting: 0.1,
            sample_count: 96,
        }
    }

    fn macro_photography() -> Self {
        Self {
            enabled: true,
            quality: DofQuality::Ultra,
            focus_distance: 0.3,
            aperture: 5.6,
            focal_length: 100.0,
            sensor_height: 24.0,
            max_blur_radius: 50.0,
            min_blur_radius: 0.5,
            aperture_shape: ApertureShape::hexagon(),
            blade_curvature: 0.5,
            aperture_rotation: PI / 12.0,
            foreground_blur: true,
            foreground_boost: 1.0,
            chromatic_aberration: 0.0,
            spherical_aberration: 0.0,
            optical_vignetting: 0.0,
            sample_count: 64,
        }
    }
}

// ============================================================================
// CIRCLE OF CONFUSION
// ============================================================================

/// Circle of Confusion calculator
struct CocCalculator {
    /// Focal length (mm)
    focal_length: f32,

    /// Aperture (f-number)
    aperture: f32,

    /// Focus distance (mm)
    focus_distance: f32,

    /// Sensor height (mm)
    sensor_height: f32,

    /// Screen height (pixels)
    screen_height: f32,
}

impl CocCalculator {
    fn new(config: &DofConfig, screen_height: f32) -> Self {
        Self {
            focal_length: config.focal_length,
            aperture: config.aperture,
            focus_distance: config.focus_distance * 1000.0,  // Convert to mm
            sensor_height: config.sensor_height,
            screen_height,
        }
    }

    /// Calculate CoC diameter for a given depth (in mm)
    fn calculate(&self, depth_mm: f32) -> f32 {
        if depth_mm <= 0.0 {
            return 0.0;
        }

        let f = self.focal_length;
        let N = self.aperture;
        let s = self.focus_distance;
        let d = depth_mm;

        // Thin lens CoC formula
        // CoC = |S * f² * (d - s)| / (N * d * (s - f))
        let numerator = abs(s * f * f * (d - s));
        let denominator = N * d * (s - f);

        if denominator.abs() < 0.001 {
            return 0.0;
        }

        let coc_mm = numerator / denominator;

        // Convert to pixels
        let coc_pixels = coc_mm / self.sensor_height * self.screen_height;

        coc_pixels
    }

    /// Calculate CoC from normalized depth (0-1)
    fn calculate_from_normalized(&self, depth: f32, near: f32, far: f32) -> f32 {
        let linear_depth = near * far / (far - depth * (far - near));
        self.calculate(linear_depth * 1000.0)
    }

    /// Calculate signed CoC (positive = background, negative = foreground)
    fn calculate_signed(&self, depth_mm: f32) -> f32 {
        let coc = self.calculate(depth_mm);
        if depth_mm < self.focus_distance {
            -coc  // Foreground
        } else {
            coc   // Background
        }
    }

    /// Hyperfocal distance
    fn hyperfocal_distance(&self) -> f32 {
        // H = f²/(N*c) + f
        // Where c is the acceptable CoC (typically 0.03mm for 35mm)
        let acceptable_coc = 0.03;  // mm
        let f = self.focal_length;
        let N = self.aperture;

        (f * f) / (N * acceptable_coc) + f
    }

    /// Near focus limit
    fn near_focus_limit(&self) -> f32 {
        let H = self.hyperfocal_distance();
        let s = self.focus_distance;

        (H * s) / (H + s - self.focal_length)
    }

    /// Far focus limit
    fn far_focus_limit(&self) -> f32 {
        let H = self.hyperfocal_distance();
        let s = self.focus_distance;

        if s >= H {
            f32::INFINITY
        } else {
            (H * s) / (H - s + self.focal_length)
        }
    }
}

// ============================================================================
// BOKEH SAMPLING
// ============================================================================

/// Bokeh sample pattern generator
struct BokehSampler {
    /// Sample positions (normalized to unit disk)
    samples: Vec<Vec2>,

    /// Sample weights
    weights: Vec<f32>,

    /// Aperture shape function
    shape: ApertureShape,
}

impl BokehSampler {
    fn new(sample_count: u32, shape: ApertureShape, blade_curvature: f32, rotation: f32) -> Self {
        let samples = Self::generate_samples(sample_count, &shape, blade_curvature, rotation);
        let weights = vec![1.0 / sample_count as f32; sample_count as usize];

        Self {
            samples,
            weights,
            shape,
        }
    }

    /// Generate sample positions for given aperture shape
    fn generate_samples(count: u32, shape: &ApertureShape, curvature: f32, rotation: f32) -> Vec<Vec2> {
        match shape {
            ApertureShape::Circle => {
                Self::generate_disk_samples(count)
            }
            ApertureShape::Polygon(blades) => {
                Self::generate_polygon_samples(count, *blades, curvature, rotation)
            }
            ApertureShape::Anamorphic { ratio, rotation: ana_rot } => {
                Self::generate_anamorphic_samples(count, *ratio, *ana_rot + rotation)
            }
            ApertureShape::Custom => {
                // Would sample from texture
                Self::generate_disk_samples(count)
            }
        }
    }

    /// Generate samples on unit disk (circular aperture)
    fn generate_disk_samples(count: u32) -> Vec<Vec2> {
        let mut samples = Vec::with_capacity(count as usize);

        // Fibonacci spiral for uniform distribution
        let golden_angle = PI * (3.0 - sqrt(5.0));

        for i in 0..count {
            let r = sqrt((i as f32 + 0.5) / count as f32);
            let theta = golden_angle * i as f32;

            samples.push(Vec2::new(r * cos(theta), r * sin(theta)));
        }

        samples
    }

    /// Generate samples for polygonal aperture
    fn generate_polygon_samples(count: u32, blades: u32, curvature: f32, rotation: f32) -> Vec<Vec2> {
        let mut samples = Vec::with_capacity(count as usize);
        let blade_angle = 2.0 * PI / blades as f32;

        for i in 0..count {
            // Start with disk sample
            let r = sqrt((i as f32 + 0.5) / count as f32);
            let theta = (PI * (3.0 - sqrt(5.0))) * i as f32 + rotation;

            // Map to polygon
            let sector = (theta / blade_angle).floor();
            let local_angle = theta - sector * blade_angle - blade_angle / 2.0;

            // Polygon edge distance
            let edge_dist = cos(blade_angle / 2.0) / cos(local_angle);

            // Apply curvature (makes edges rounder)
            let curved_dist = lerp(edge_dist, 1.0, curvature);

            // Scale radius
            let scaled_r = r * curved_dist.min(1.0);

            samples.push(Vec2::new(scaled_r * cos(theta), scaled_r * sin(theta)));
        }

        samples
    }

    /// Generate samples for anamorphic (oval) aperture
    fn generate_anamorphic_samples(count: u32, ratio: f32, rotation: f32) -> Vec<Vec2> {
        let mut samples = Vec::with_capacity(count as usize);

        for i in 0..count {
            let r = sqrt((i as f32 + 0.5) / count as f32);
            let theta = (PI * (3.0 - sqrt(5.0))) * i as f32 + rotation;

            // Stretch horizontally
            let x = r * cos(theta) * ratio;
            let y = r * sin(theta);

            samples.push(Vec2::new(x, y));
        }

        samples
    }

    /// Get sample offset for given pixel
    fn get_sample(&self, index: usize, blur_radius: f32) -> Vec2 {
        let sample = &self.samples[index % self.samples.len()];
        Vec2::new(sample.x * blur_radius, sample.y * blur_radius)
    }
}

// ============================================================================
// DOF RENDERING
// ============================================================================

/// Main DoF renderer
struct DofRenderer {
    config: DofConfig,
    coc_calculator: CocCalculator,
    bokeh_sampler: BokehSampler,

    // Work buffers
    coc_buffer: Texture2D,
    near_field: Texture2D,
    far_field: Texture2D,
    combined: Texture2D,
}

impl DofRenderer {
    fn new(config: DofConfig, width: u32, height: u32) -> Self {
        let coc_calculator = CocCalculator::new(&config, height as f32);
        let bokeh_sampler = BokehSampler::new(
            config.sample_count,
            config.aperture_shape.clone(),
            config.blade_curvature,
            config.aperture_rotation
        );

        Self {
            config: config.clone(),
            coc_calculator,
            bokeh_sampler,
            coc_buffer: Texture2D::new(width, height, TextureFormat::RG16F),  // CoC + signed
            near_field: Texture2D::new(width / 2, height / 2, TextureFormat::RGBA16F),
            far_field: Texture2D::new(width / 2, height / 2, TextureFormat::RGBA16F),
            combined: Texture2D::new(width, height, TextureFormat::RGBA16F),
        }
    }

    /// Execute DoF pipeline
    fn execute(&self, color: &Texture2D, depth: &Texture2D, output: &Texture2D, near: f32, far: f32) {
        if !self.config.enabled {
            // Just copy
            return;
        }

        // 1. Compute CoC for each pixel
        self.compute_coc(depth, near, far);

        // 2. Separate near and far fields
        self.separate_fields(color);

        // 3. Blur far field
        self.blur_far_field();

        // 4. Blur near field
        if self.config.foreground_blur {
            self.blur_near_field();
        }

        // 5. Composite
        self.composite(color, output);
    }

    /// Compute CoC buffer
    fn compute_coc(&self, depth: &Texture2D, near: f32, far: f32) {
        // For each pixel, compute CoC using thin lens formula
        // Store signed CoC (negative for foreground)
