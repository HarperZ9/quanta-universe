/// Scatter-based DoF (more accurate, slower)
struct ScatterDof {
    config: DofConfig,

    /// Tile size for scatter optimization
    tile_size: u32,

    /// Max scatter radius per tile
    tile_coc: Texture2D,
}

impl ScatterDof {
    fn new(config: DofConfig, width: u32, height: u32) -> Self {
        let tile_size = 8;
        let tile_w = (width + tile_size - 1) / tile_size;
        let tile_h = (height + tile_size - 1) / tile_size;

        Self {
            config,
            tile_size,
            tile_coc: Texture2D::new(tile_w, tile_h, TextureFormat::R16F),
        }
    }

    /// Execute scatter DoF
    fn execute(&self, color: &Texture2D, depth: &Texture2D, coc: &Texture2D, output: &Texture2D) {
        // 1. Compute per-tile max CoC
        self.compute_tile_coc(coc);

