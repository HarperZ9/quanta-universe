// ============================================================================
// WGSL SHADERS
// ============================================================================

const BLOOM_PREFILTER_SHADER: &str = r#"
// Bloom Prefilter - Extract bright pixels with soft threshold

struct BloomParams {
    threshold: f32,
    knee: f32,
    intensity: f32,
    padding: f32,
}

@group(0) @binding(0) var<uniform> params: BloomParams;
@group(0) @binding(1) var input_texture: texture_2d<f32>;
@group(0) @binding(2) var input_sampler: sampler;

fn luminance(color: vec3<f32>) -> f32 {
    return dot(color, vec3<f32>(0.2126, 0.7152, 0.0722));
}

fn soft_threshold(color: vec3<f32>, threshold: f32, knee: f32) -> vec3<f32> {
    let brightness = luminance(color);
    let soft = brightness - threshold + knee;
    let soft_clamped = clamp(soft, 0.0, 2.0 * knee);
    let contribution = soft_clamped * soft_clamped / (4.0 * knee + 0.0001);
    let result = max(contribution, brightness - threshold) / max(brightness, 0.0001);
    return color * result;
}

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) uv: vec2<f32>,
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    let color = textureSample(input_texture, input_sampler, input.uv).rgb;
    let filtered = soft_threshold(color, params.threshold, params.knee);
    return vec4<f32>(filtered * params.intensity, 1.0);
}
"#;

const BLOOM_DOWNSAMPLE_SHADER: &str = r#"
// Bloom Downsample - 13-tap filter for quality downscaling

@group(0) @binding(0) var input_texture: texture_2d<f32>;
@group(0) @binding(1) var input_sampler: sampler;

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) uv: vec2<f32>,
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    let dims = vec2<f32>(textureDimensions(input_texture));
    let texel = 1.0 / dims;

    // 13-tap filter (using bilinear samples for efficiency)
    var result = textureSample(input_texture, input_sampler, input.uv) * 0.125;

    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(-1.0, -1.0) * texel) * 0.03125;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(1.0, -1.0) * texel) * 0.03125;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(-1.0, 1.0) * texel) * 0.03125;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(1.0, 1.0) * texel) * 0.03125;

    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(-2.0, 0.0) * texel) * 0.0625;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(2.0, 0.0) * texel) * 0.0625;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(0.0, -2.0) * texel) * 0.0625;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(0.0, 2.0) * texel) * 0.0625;

    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(-2.0, -2.0) * texel) * 0.03125;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(2.0, -2.0) * texel) * 0.03125;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(-2.0, 2.0) * texel) * 0.03125;
    result += textureSample(input_texture, input_sampler, input.uv + vec2<f32>(2.0, 2.0) * texel) * 0.03125;

    return result;
}
"#;

const BLOOM_UPSAMPLE_SHADER: &str = r#"
// Bloom Upsample - Tent filter upscaling with additive blend

struct UpsampleParams {
    scatter: f32,
    mip_weight: f32,
    padding: vec2<f32>,
}

@group(0) @binding(0) var<uniform> params: UpsampleParams;
@group(0) @binding(1) var current_mip: texture_2d<f32>;
@group(0) @binding(2) var higher_mip: texture_2d<f32>;
@group(0) @binding(3) var input_sampler: sampler;

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) uv: vec2<f32>,
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    let dims = vec2<f32>(textureDimensions(current_mip));
    let texel = 1.0 / dims;

    // 9-tap tent filter
    var upsampled = textureSample(current_mip, input_sampler, input.uv + vec2<f32>(-1.0, -1.0) * texel) * 1.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(0.0, -1.0) * texel) * 2.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(1.0, -1.0) * texel) * 1.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(-1.0, 0.0) * texel) * 2.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv) * 4.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(1.0, 0.0) * texel) * 2.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(-1.0, 1.0) * texel) * 1.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(0.0, 1.0) * texel) * 2.0;
    upsampled += textureSample(current_mip, input_sampler, input.uv + vec2<f32>(1.0, 1.0) * texel) * 1.0;
    upsampled /= 16.0;

    // Sample higher resolution mip
    let higher = textureSample(higher_mip, input_sampler, input.uv);

    // Blend with scatter control
    let bloom = upsampled * params.scatter;
    let combined = higher + bloom * params.mip_weight;

    return combined;
}
"#;

const BLOOM_COMPOSITE_SHADER: &str = r#"
// Bloom Composite - Combine bloom with original image

struct CompositeParams {
    intensity: f32,
    tint: vec3<f32>,
    dirt_intensity: f32,
    padding: vec3<f32>,
}

@group(0) @binding(0) var<uniform> params: CompositeParams;
@group(0) @binding(1) var original_texture: texture_2d<f32>;
@group(0) @binding(2) var bloom_texture: texture_2d<f32>;
@group(0) @binding(3) var dirt_texture: texture_2d<f32>;
@group(0) @binding(4) var input_sampler: sampler;

struct VertexOutput {
    @builtin(position) position: vec4<f32>,
    @location(0) uv: vec2<f32>,
}

@fragment
fn fs_main(input: VertexOutput) -> @location(0) vec4<f32> {
    let original = textureSample(original_texture, input_sampler, input.uv);
    let bloom = textureSample(bloom_texture, input_sampler, input.uv).rgb;
    let dirt = textureSample(dirt_texture, input_sampler, input.uv).rgb;

    // Apply tint
    let tinted_bloom = bloom * params.tint;

    // Apply lens dirt
    let dirt_bloom = tinted_bloom * (1.0 + dirt * params.dirt_intensity);

    // Additive blend
    let result = original.rgb + dirt_bloom * params.intensity;

    return vec4<f32>(result, original.a);
}
"#;

const DIFFRACTION_SPIKES_SHADER: &str = r#"
// Diffraction Spikes (Star Bloom)

struct SpikeParams {
    spike_count: u32,
    rotation: f32,
    length: f32,
    intensity: f32,
    sharpness: f32,
    chromatic: f32,
    padding: vec2<f32>,
}

@group(0) @binding(0) var<uniform> params: SpikeParams;
@group(0) @binding(1) var input_texture: texture_2d<f32>;
@group(0) @binding(2) var input_sampler: sampler;
@group(0) @binding(3) var output_texture: texture_storage_2d<rgba16float, write>;

const PI: f32 = 3.14159265359;

@compute @workgroup_size(16, 16)
fn main(@builtin(global_invocation_id) global_id: vec3<u32>) {
    let dims = textureDimensions(input_texture);
    if (global_id.x >= dims.x || global_id.y >= dims.y) { return; }

    let uv = (vec2<f32>(global_id.xy) + 0.5) / vec2<f32>(dims);
    var result = textureSample(input_texture, input_sampler, uv);

    // Find bright pixels and generate spikes
    let brightness = dot(result.rgb, vec3<f32>(0.2126, 0.7152, 0.0722));

    if (brightness > 1.0) {
        // Generate spikes radiating from this pixel
        var spike_contribution = vec3<f32>(0.0);

        for (var i = 0u; i < params.spike_count; i++) {
            let spike_angle = params.rotation + PI * f32(i) / f32(params.spike_count);
            let dir = vec2<f32>(cos(spike_angle), sin(spike_angle));

            // Sample along spike direction
            for (var j = 1u; j < 32u; j++) {
                let offset = dir * f32(j) * params.length / 32.0;
                let sample_uv = uv + offset;

                if (sample_uv.x < 0.0 || sample_uv.x > 1.0 || sample_uv.y < 0.0 || sample_uv.y > 1.0) {
                    break;
                }

                let falloff = exp(-f32(j) * params.sharpness * 0.2);
                let sample = textureSample(input_texture, input_sampler, sample_uv).rgb;
                spike_contribution += sample * falloff * params.intensity;
            }
        }

        result = vec4<f32>(result.rgb + spike_contribution / f32(params.spike_count), result.a);
    }

    textureStore(output_texture, vec2<i32>(global_id.xy), result);
}
"#;

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

fn luminance(color: Vec3) -> f32 {
    color.x * 0.2126 + color.y * 0.7152 + color.z * 0.0722
}

fn atan2(y: f32, x: f32) -> f32 {
    // Platform atan2 implementation
    core::math::atan2(y, x)
}

// ============================================================================
// UNIT TESTS
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    const EPSILON: f32 = 0.001;

    fn approx_eq(a: f32, b: f32) -> bool {
        (a - b).abs() < EPSILON
    }

    #[test]
    fn test_bloom_config_default() {
        let config = BloomConfig::default();
        assert!(config.enabled);
        assert!(approx_eq(config.threshold, 0.9));
        assert!(approx_eq(config.intensity, 0.5));
    }

    #[test]
    fn test_bloom_config_presets() {
        let cinematic = BloomConfig::cinematic();
        assert!(cinematic.dirt_intensity > 0.0);

        let neon = BloomConfig::neon();
        assert!(approx_eq(neon.intensity, 1.0));

        let subtle = BloomConfig::subtle();
        assert!(subtle.intensity < 0.5);
    }

    #[test]
    fn test_mip_bloom_mip_count() {
        assert_eq!(MipBloom::calculate_mip_count(&BloomQuality::Low), 3);
        assert_eq!(MipBloom::calculate_mip_count(&BloomQuality::High), 7);
        assert_eq!(MipBloom::calculate_mip_count(&BloomQuality::Ultra), 9);
    }

    #[test]
    fn test_gaussian_kernel_normalized() {
        let kernel = MipBloom::generate_kernel(&BloomQuality::High);
        let sum: f32 = kernel.iter().sum();
        assert!(approx_eq(sum, 1.0));
    }

    #[test]
    fn test_diffraction_spikes_disabled() {
        let mut spikes = DiffractionSpikes::new();
        spikes.enabled = false;

        let result = spikes.generate(Vec2::new(0.5, 0.5), Vec2::new(0.3, 0.3), Vec3::one());
        assert!(approx_eq(result.x, 0.0));
        assert!(approx_eq(result.y, 0.0));
        assert!(approx_eq(result.z, 0.0));
    }

    #[test]
    fn test_lens_ghosts_below_threshold() {
        let ghosts = LensGhosts::new();

        let result = ghosts.generate(Vec2::new(0.5, 0.5), Vec2::new(0.3, 0.3), 0.5);  // Below threshold
        assert!(approx_eq(result.x, 0.0));
    }

    #[test]
    fn test_luminance() {
        // White should have luminance of 1
        assert!(approx_eq(luminance(Vec3::one()), 1.0));

        // Black should have luminance of 0
        assert!(approx_eq(luminance(Vec3::zero()), 0.0));

        // Pure red
        let red_lum = luminance(Vec3::new(1.0, 0.0, 0.0));
        assert!(approx_eq(red_lum, 0.2126));
    }
}
