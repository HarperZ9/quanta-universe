// =============================================================================
// Lumina Anti-Aliasing - Comprehensive AA Solutions
// =============================================================================
// Full suite of anti-aliasing techniques including TAA, SMAA, FXAA,
// MLAA, and specialized gaming AA solutions.
// Target: Real-time rendering, game engines, VR/AR applications
// =============================================================================

module lumina::anti_aliasing;

use core::math::{Vec2, Vec3, Vec4, Mat4, lerp, saturate, smoothstep};
use core::simd::{f32x4, f32x8};
use lumina::{RenderTarget, Texture2D, TextureFormat, SamplerState};

// =============================================================================
// Constants
// =============================================================================

/// Edge detection threshold for FXAA
const FXAA_EDGE_THRESHOLD: f32 = 0.0833;
const FXAA_EDGE_THRESHOLD_MIN: f32 = 0.0312;

/// SMAA search steps
const SMAA_MAX_SEARCH_STEPS: u32 = 16;
const SMAA_MAX_SEARCH_STEPS_DIAG: u32 = 8;

/// TAA history blend
const TAA_DEFAULT_BLEND: f32 = 0.1;

// =============================================================================
// Configuration
// =============================================================================

/// Anti-aliasing algorithm types
@[repr(u8)]
enum AaAlgorithm {
    // Fast post-process AA
    Fxaa,           // Fast Approximate Anti-Aliasing
    FxaaQuality,    // High-quality FXAA

    // Morphological AA
    Smaa,           // Subpixel Morphological AA
    SmaaT2x,        // SMAA with temporal supersampling
    Mlaa,           // Morphological Anti-Aliasing

    // Temporal AA
    Taa,            // Temporal Anti-Aliasing
    TaaSharp,       // TAA with sharpening

    // Specialized
    Cmaa2,          // Conservative Morphological AA 2.0
    Dlaa,           // Directional Localized Anti-Aliasing

    // None
    None,
}

/// AA quality presets
@[repr(u8)]
enum AaQuality {
    Low = 0,
    Medium = 1,
    High = 2,
    Ultra = 3,
}

/// Anti-aliasing configuration
struct AaConfig {
    enabled: bool,
    algorithm: AaAlgorithm,
    quality: AaQuality,

    // FXAA settings
    fxaa_subpixel: f32,         // Subpixel quality (0-1)
    fxaa_edge_threshold: f32,   // Edge detection threshold
    fxaa_edge_threshold_min: f32,

    // SMAA settings
    smaa_threshold: f32,        // Edge threshold
    smaa_max_search_steps: u32,
    smaa_corner_rounding: f32,
    smaa_local_contrast_adaptation: f32,

    // TAA settings
    taa_blend_factor: f32,      // History blend (0.05-0.2)
    taa_motion_scale: f32,      // Motion blur scale
    taa_jitter_scale: f32,      // Jitter magnitude
    taa_sharpen: f32,           // Sharpening amount
    taa_variance_clipping: bool,
    taa_depth_rejection: bool,
}

impl AaConfig {
    /// Default balanced configuration
    pub fn default() -> Self {
        Self {
            enabled: true,
            algorithm: AaAlgorithm::Taa,
            quality: AaQuality::High,
            fxaa_subpixel: 0.75,
            fxaa_edge_threshold: 0.166,
            fxaa_edge_threshold_min: 0.0833,
            smaa_threshold: 0.1,
            smaa_max_search_steps: 16,
            smaa_corner_rounding: 25.0,
            smaa_local_contrast_adaptation: 2.0,
            taa_blend_factor: 0.1,
            taa_motion_scale: 1.0,
            taa_jitter_scale: 1.0,
            taa_sharpen: 0.0,
            taa_variance_clipping: true,
            taa_depth_rejection: true,
        }
    }

    /// Fast performance preset
    pub fn performance() -> Self {
        Self {
            enabled: true,
            algorithm: AaAlgorithm::Fxaa,
            quality: AaQuality::Medium,
            fxaa_subpixel: 0.5,
            fxaa_edge_threshold: 0.25,
            fxaa_edge_threshold_min: 0.125,
            smaa_threshold: 0.15,
            smaa_max_search_steps: 8,
            smaa_corner_rounding: 25.0,
            smaa_local_contrast_adaptation: 2.0,
            taa_blend_factor: 0.15,
            taa_motion_scale: 1.0,
            taa_jitter_scale: 1.0,
            taa_sharpen: 0.0,
            taa_variance_clipping: false,
            taa_depth_rejection: false,
        }
    }

    /// Maximum quality preset
    pub fn ultra() -> Self {
        Self {
            enabled: true,
            algorithm: AaAlgorithm::SmaaT2x,
            quality: AaQuality::Ultra,
            fxaa_subpixel: 1.0,
            fxaa_edge_threshold: 0.125,
            fxaa_edge_threshold_min: 0.0625,
            smaa_threshold: 0.05,
            smaa_max_search_steps: 32,
            smaa_corner_rounding: 50.0,
            smaa_local_contrast_adaptation: 2.0,
            taa_blend_factor: 0.05,
            taa_motion_scale: 1.0,
            taa_jitter_scale: 1.0,
            taa_sharpen: 0.2,
            taa_variance_clipping: true,
            taa_depth_rejection: true,
        }
    }
}

// =============================================================================
// FXAA - Fast Approximate Anti-Aliasing
// =============================================================================

/// FXAA implementation (NVIDIA algorithm)
struct Fxaa {
    config: AaConfig,
}

impl Fxaa {
    pub fn new(config: AaConfig) -> Self {
        Self { config }
    }

    /// Calculate luminance from RGB
    fn luminance(color: Vec3) -> f32 {
        color.x * 0.299 + color.y * 0.587 + color.z * 0.114
    }

    /// Sample with offset
    fn sample_offset(&self, color: &[Vec4], x: i32, y: i32, width: u32, height: u32) -> Vec4 {
        let cx = x.max(0).min(width as i32 - 1) as u32;
        let cy = y.max(0).min(height as i32 - 1) as u32;
        color[(cy * width + cx) as usize]
    }

    /// Apply FXAA to a pixel
    pub fn apply_pixel(
        &self,
        color: &[Vec4],
        x: u32,
        y: u32,
        width: u32,
        height: u32
    ) -> Vec4 {
        let ix = x as i32;
        let iy = y as i32;

        // Sample center and neighbors
        let rgbM = self.sample_offset(color, ix, iy, width, height);
        let rgbN = self.sample_offset(color, ix, iy - 1, width, height);
        let rgbS = self.sample_offset(color, ix, iy + 1, width, height);
        let rgbE = self.sample_offset(color, ix + 1, iy, width, height);
        let rgbW = self.sample_offset(color, ix - 1, iy, width, height);

        // Calculate luminance
        let lumM = Self::luminance(rgbM.xyz());
        let lumN = Self::luminance(rgbN.xyz());
        let lumS = Self::luminance(rgbS.xyz());
        let lumE = Self::luminance(rgbE.xyz());
        let lumW = Self::luminance(rgbW.xyz());

        let lumMin = lumN.min(lumS).min(lumE).min(lumW).min(lumM);
        let lumMax = lumN.max(lumS).max(lumE).max(lumW).max(lumM);
        let lumRange = lumMax - lumMin;

        // Early exit for low contrast
        if lumRange < self.config.fxaa_edge_threshold.max(lumMax * self.config.fxaa_edge_threshold_min) {
            return rgbM;
        }

        // Sample corners
        let rgbNW = self.sample_offset(color, ix - 1, iy - 1, width, height);
        let rgbNE = self.sample_offset(color, ix + 1, iy - 1, width, height);
        let rgbSW = self.sample_offset(color, ix - 1, iy + 1, width, height);
        let rgbSE = self.sample_offset(color, ix + 1, iy + 1, width, height);

        let lumNW = Self::luminance(rgbNW.xyz());
        let lumNE = Self::luminance(rgbNE.xyz());
        let lumSW = Self::luminance(rgbSW.xyz());
        let lumSE = Self::luminance(rgbSE.xyz());

        // Calculate edge direction
        let lumNS = lumN + lumS;
        let lumEW = lumE + lumW;

        let lumNWSW = lumNW + lumSW;
        let lumNENW = lumNE + lumNW;
        let lumNESE = lumNE + lumSE;
        let lumSESW = lumSE + lumSW;

        let edge_horz = (lumNWSW - 2.0 * lumW).abs()
            + (lumNS - 2.0 * lumM).abs() * 2.0
            + (lumNESE - 2.0 * lumE).abs();
        let edge_vert = (lumNENW - 2.0 * lumN).abs()
            + (lumEW - 2.0 * lumM).abs() * 2.0
            + (lumSESW - 2.0 * lumS).abs();

        let is_horizontal = edge_horz >= edge_vert;

        // Select edge endpoints
        let (lum1, lum2) = if is_horizontal {
            (lumN, lumS)
        } else {
            (lumW, lumE)
        };

        let gradient1 = lum1 - lumM;
        let gradient2 = lum2 - lumM;

        let is_1_steepest = gradient1.abs() >= gradient2.abs();
        let gradient_scaled = 0.25 * gradient1.abs().max(gradient2.abs());

        // Calculate step length
        let step_length = if is_horizontal {
            1.0 / height as f32
        } else {
            1.0 / width as f32
        };

        let lum_local_average = 0.0;
        let pixel_step = if is_1_steepest {
            -step_length
        } else {
            step_length
        };

        // Calculate subpixel offset
        let lum_average = (lumN + lumS + lumE + lumW) * 0.25;
        let sub_pixel_offset1 = saturate((lum_average - lumM).abs() / lumRange);
        let sub_pixel_offset2 = (-2.0 * sub_pixel_offset1 + 3.0) * sub_pixel_offset1 * sub_pixel_offset1;
        let sub_pixel_offset = sub_pixel_offset2 * sub_pixel_offset2 * self.config.fxaa_subpixel;

        // Search along edge
        let mut uv = Vec2::new(
            x as f32 / width as f32,
            y as f32 / height as f32
        );

        if is_horizontal {
            uv.y += pixel_step * 0.5;
        } else {
            uv.x += pixel_step * 0.5;
        }

        let uv_step = if is_horizontal {
            Vec2::new(1.0 / width as f32, 0.0)
        } else {
            Vec2::new(0.0, 1.0 / height as f32)
        };

        // Search in both directions
        let mut uv_neg = uv - uv_step;
        let mut uv_pos = uv + uv_step;

        let mut done_neg = false;
        let mut done_pos = false;
        let mut lum_end_neg = 0.0;
        let mut lum_end_pos = 0.0;

        let search_limit = match self.config.quality {
            AaQuality::Low => 4,
            AaQuality::Medium => 8,
            AaQuality::High => 16,
            AaQuality::Ultra => 32,
        };

        for _ in 0..search_limit {
            if !done_neg {
                let sx = (uv_neg.x * width as f32) as i32;
                let sy = (uv_neg.y * height as f32) as i32;
                let sample = self.sample_offset(color, sx, sy, width, height);
                lum_end_neg = Self::luminance(sample.xyz()) - lum_local_average;
                done_neg = (lum_end_neg - gradient_scaled).abs() >= gradient_scaled;
            }
            if !done_pos {
                let sx = (uv_pos.x * width as f32) as i32;
                let sy = (uv_pos.y * height as f32) as i32;
                let sample = self.sample_offset(color, sx, sy, width, height);
                lum_end_pos = Self::luminance(sample.xyz()) - lum_local_average;
                done_pos = (lum_end_pos - gradient_scaled).abs() >= gradient_scaled;
            }

            if done_neg && done_pos {
                break;
            }

            if !done_neg {
                uv_neg = uv_neg - uv_step;
            }
            if !done_pos {
                uv_pos = uv_pos + uv_step;
            }
        }

        // Calculate final offset
        let dist_neg = if is_horizontal {
            (x as f32 / width as f32) - uv_neg.x
        } else {
            (y as f32 / height as f32) - uv_neg.y
        };
        let dist_pos = if is_horizontal {
            uv_pos.x - (x as f32 / width as f32)
        } else {
            uv_pos.y - (y as f32 / height as f32)
        };

        let is_dir_neg = dist_neg < dist_pos;
        let dist_final = dist_neg.min(dist_pos);

        let edge_length = dist_neg + dist_pos;
        let pixel_offset = -dist_final / edge_length + 0.5;

        let is_lum_at_end_neg = if is_dir_neg { lum_end_neg } else { lum_end_pos } < 0.0;

        let final_offset = if is_lum_at_end_neg != (lumM < lum_local_average) {
            0.0
        } else {
            pixel_offset.max(sub_pixel_offset)
        };

        // Sample with offset
        let mut final_uv = Vec2::new(
            x as f32 / width as f32,
            y as f32 / height as f32
        );

        if is_horizontal {
            final_uv.y += final_offset * pixel_step;
        } else {
            final_uv.x += final_offset * pixel_step;
        }

        let fx = (final_uv.x * width as f32) as i32;
        let fy = (final_uv.y * height as f32) as i32;

        self.sample_offset(color, fx, fy, width, height)
    }

    /// Apply FXAA to entire image
    pub fn apply(&self, color: &[Vec4], width: u32, height: u32) -> Vec<Vec4> {
        let mut result = vec![Vec4::ZERO; color.len()];

        for y in 0..height {
            for x in 0..width {
                result[(y * width + x) as usize] = self.apply_pixel(color, x, y, width, height);
            }
        }

        result
    }
}

// =============================================================================
// SMAA - Subpixel Morphological Anti-Aliasing
// =============================================================================

/// SMAA edge types
@[repr(u8)]
enum SmaaEdgeType {
    None = 0,
    Horizontal = 1,
    Vertical = 2,
    Both = 3,
}

/// SMAA implementation
struct Smaa {
    config: AaConfig,
    search_tex: Vec<f32>,      // Pre-computed search texture
    area_tex: Vec<Vec2>,       // Pre-computed area texture
}

impl Smaa {
    pub fn new(config: AaConfig) -> Self {
        let mut smaa = Self {
            config,
            search_tex: Vec::new(),
            area_tex: Vec::new(),
        };
        smaa.generate_lookup_textures();
        smaa
    }

    /// Generate lookup textures for SMAA
    fn generate_lookup_textures(&mut self) {
        // Simplified search texture generation
        self.search_tex = vec![0.0f32; 64 * 16];

        // Generate search offsets
        for y in 0..16 {
            for x in 0..64 {
                let pattern = x as f32 / 63.0;
                self.search_tex[y * 64 + x] = pattern;
            }
        }

        // Simplified area texture
        self.area_tex = vec![Vec2::ZERO; 160 * 160];

        for y in 0..160 {
            for x in 0..160 {
                let u = x as f32 / 159.0;
                let v = y as f32 / 159.0;
                self.area_tex[y * 160 + x] = Vec2::new(u * 0.5, v * 0.5);
            }
        }
    }

    /// Edge detection pass
    pub fn detect_edges(&self, color: &[Vec4], width: u32, height: u32) -> Vec<Vec2> {
        let mut edges = vec![Vec2::ZERO; color.len()];

        for y in 0..height {
            for x in 0..width {
                let idx = (y * width + x) as usize;
                let lum = Self::luminance(color[idx].xyz());

                // Horizontal edge
                let left_idx = if x > 0 {
                    (y * width + x - 1) as usize
                } else {
                    idx
                };
                let left_lum = Self::luminance(color[left_idx].xyz());

                let edge_h = if (lum - left_lum).abs() > self.config.smaa_threshold {
                    1.0
                } else {
                    0.0
                };

                // Vertical edge
                let top_idx = if y > 0 {
                    ((y - 1) * width + x) as usize
                } else {
                    idx
                };
                let top_lum = Self::luminance(color[top_idx].xyz());

                let edge_v = if (lum - top_lum).abs() > self.config.smaa_threshold {
                    1.0
                } else {
                    0.0
                };

                edges[idx] = Vec2::new(edge_h, edge_v);
            }
        }

        edges
    }

    /// Calculate blend weights
    pub fn calculate_blend_weights(
        &self,
        edges: &[Vec2],
        width: u32,
        height: u32
    ) -> Vec<Vec4> {
        let mut weights = vec![Vec4::ZERO; edges.len()];
        let max_steps = self.config.smaa_max_search_steps;

        for y in 0..height {
            for x in 0..width {
                let idx = (y * width + x) as usize;
                let edge = edges[idx];

                if edge.x == 0.0 && edge.y == 0.0 {
                    continue;
                }

                // Search for edge ends (horizontal)
                if edge.x > 0.0 {
                    let mut left_dist = 0u32;
                    let mut right_dist = 0u32;

                    // Search left
                    for i in 1..=max_steps {
                        if x < i {
                            break;
                        }
                        let search_idx = (y * width + x - i) as usize;
                        if edges[search_idx].x == 0.0 {
                            break;
                        }
                        left_dist = i;
                    }

                    // Search right
                    for i in 1..=max_steps {
                        if x + i >= width {
                            break;
                        }
                        let search_idx = (y * width + x + i) as usize;
                        if edges[search_idx].x == 0.0 {
                            break;
                        }
                        right_dist = i;
                    }

                    let total_dist = left_dist + right_dist + 1;
                    let area = self.calculate_area(left_dist, right_dist, total_dist);

                    weights[idx].x = area.x;  // Top weight
                    weights[idx].y = area.y;  // Bottom weight
                }

                // Search for edge ends (vertical)
                if edge.y > 0.0 {
                    let mut top_dist = 0u32;
                    let mut bottom_dist = 0u32;

                    // Search up
                    for i in 1..=max_steps {
                        if y < i {
                            break;
                        }
                        let search_idx = ((y - i) * width + x) as usize;
                        if edges[search_idx].y == 0.0 {
                            break;
                        }
                        top_dist = i;
                    }

                    // Search down
                    for i in 1..=max_steps {
                        if y + i >= height {
                            break;
                        }
                        let search_idx = ((y + i) * width + x) as usize;
                        if edges[search_idx].y == 0.0 {
                            break;
                        }
                        bottom_dist = i;
                    }

                    let total_dist = top_dist + bottom_dist + 1;
                    let area = self.calculate_area(top_dist, bottom_dist, total_dist);

                    weights[idx].z = area.x;  // Left weight
                    weights[idx].w = area.y;  // Right weight
                }
            }
        }

        weights
    }

    /// Calculate area from distances
    fn calculate_area(&self, dist1: u32, dist2: u32, total: u32) -> Vec2 {
        if total <= 1 {
            return Vec2::ZERO;
        }

        let d1 = dist1 as f32 / (total - 1) as f32;
        let d2 = dist2 as f32 / (total - 1) as f32;

        // Ramp based on distance
        Vec2::new(
            smoothstep(0.0, 1.0, 0.5 - d1 * 0.5),
            smoothstep(0.0, 1.0, 0.5 - d2 * 0.5)
        )
    }

    /// Final neighborhood blending
    pub fn blend_neighbors(
        &self,
        color: &[Vec4],
        weights: &[Vec4],
        width: u32,
        height: u32
    ) -> Vec<Vec4> {
        let mut result = vec![Vec4::ZERO; color.len()];

        for y in 0..height {
            for x in 0..width {
                let idx = (y * width + x) as usize;
                let w = weights[idx];

                // Skip pixels without blending
                if w.x + w.y + w.z + w.w < 0.001 {
                    result[idx] = color[idx];
                    continue;
                }

                let mut blended = Vec4::ZERO;
                let mut total_weight = 0.0;

                // Blend with neighbors based on weights
                // Top
                if y > 0 && w.x > 0.0 {
                    let top_idx = ((y - 1) * width + x) as usize;
                    blended = blended + color[top_idx] * w.x;
                    total_weight += w.x;
                }

                // Bottom
                if y < height - 1 && w.y > 0.0 {
                    let bottom_idx = ((y + 1) * width + x) as usize;
                    blended = blended + color[bottom_idx] * w.y;
                    total_weight += w.y;
                }

                // Left
                if x > 0 && w.z > 0.0 {
                    let left_idx = (y * width + x - 1) as usize;
                    blended = blended + color[left_idx] * w.z;
                    total_weight += w.z;
                }

                // Right
                if x < width - 1 && w.w > 0.0 {
                    let right_idx = (y * width + x + 1) as usize;
                    blended = blended + color[right_idx] * w.w;
                    total_weight += w.w;
                }

                // Blend with center
                let center_weight = 1.0 - total_weight.min(1.0);
                result[idx] = color[idx] * center_weight + blended;
            }
        }

        result
    }

    /// Calculate luminance
    fn luminance(color: Vec3) -> f32 {
        color.x * 0.299 + color.y * 0.587 + color.z * 0.114
    }

    /// Apply full SMAA pipeline
    pub fn apply(&self, color: &[Vec4], width: u32, height: u32) -> Vec<Vec4> {
        // Pass 1: Edge detection
        let edges = self.detect_edges(color, width, height);

        // Pass 2: Blend weight calculation
        let weights = self.calculate_blend_weights(&edges, width, height);

        // Pass 3: Neighborhood blending
        self.blend_neighbors(color, &weights, width, height)
    }
}

// =============================================================================
// TAA - Temporal Anti-Aliasing
// =============================================================================

/// Jitter sequence type
@[repr(u8)]
enum JitterSequence {
    Halton23,       // Halton(2,3) sequence
    Halton35,       // Halton(3,5) sequence
    BlueNoise,      // Blue noise
    R2,             // R2 sequence (Martin Roberts)
    InterleavedGradient, // Interleaved gradient
}

/// Temporal Anti-Aliasing implementation
struct Taa {
    config: AaConfig,
    history: Vec<Vec4>,
    jitter_sequence: JitterSequence,
    frame_index: u32,
    jitter_samples: Vec<Vec2>,
}

impl Taa {
    pub fn new(width: u32, height: u32, config: AaConfig) -> Self {
        let mut taa = Self {
            history: vec![Vec4::ZERO; (width * height) as usize],
            jitter_sequence: JitterSequence::Halton23,
            frame_index: 0,
            jitter_samples: Vec::new(),
            config,
        };
        taa.generate_jitter_samples(16);
        taa
    }

    /// Generate jitter samples
    fn generate_jitter_samples(&mut self, count: u32) {
        self.jitter_samples.clear();

        for i in 0..count {
            let sample = match self.jitter_sequence {
                JitterSequence::Halton23 => {
                    Vec2::new(
                        Self::halton(i + 1, 2) - 0.5,
                        Self::halton(i + 1, 3) - 0.5
                    )
                },
                JitterSequence::Halton35 => {
                    Vec2::new(
                        Self::halton(i + 1, 3) - 0.5,
                        Self::halton(i + 1, 5) - 0.5
                    )
                },
                JitterSequence::R2 => {
                    let g = 1.32471795724; // Plastic constant
                    let a1 = 1.0 / g;
                    let a2 = 1.0 / (g * g);
                    Vec2::new(
                        (0.5 + a1 * i as f32).fract() - 0.5,
                        (0.5 + a2 * i as f32).fract() - 0.5
                    )
                },
                JitterSequence::InterleavedGradient => {
                    let x = i % 4;
                    let y = i / 4;
                    Vec2::new(
                        (x as f32 * 0.0671875 + y as f32 * 0.00583715).fract() - 0.5,
                        (x as f32 * 0.00583715 + y as f32 * 0.0671875).fract() - 0.5
                    )
                },
                _ => Vec2::new(
                    Self::halton(i + 1, 2) - 0.5,
                    Self::halton(i + 1, 3) - 0.5
                ),
            };

            self.jitter_samples.push(sample * self.config.taa_jitter_scale);
        }
    }

    /// Halton sequence
    fn halton(index: u32, base: u32) -> f32 {
        let mut f = 1.0f32;
        let mut r = 0.0f32;
        let mut i = index;

        while i > 0 {
            f = f / base as f32;
            r = r + f * (i % base) as f32;
            i = i / base;
        }

        r
    }

    /// Get current frame jitter
    pub fn get_jitter(&self) -> Vec2 {
        let idx = (self.frame_index as usize) % self.jitter_samples.len();
        self.jitter_samples[idx]
    }

    /// RGB to YCoCg color space (for variance clipping)
    fn rgb_to_ycocg(rgb: Vec3) -> Vec3 {
        Vec3::new(
            rgb.x * 0.25 + rgb.y * 0.5 + rgb.z * 0.25,
            rgb.x * 0.5 - rgb.z * 0.5,
            -rgb.x * 0.25 + rgb.y * 0.5 - rgb.z * 0.25
        )
    }

    /// YCoCg to RGB
    fn ycocg_to_rgb(ycocg: Vec3) -> Vec3 {
        Vec3::new(
            ycocg.x + ycocg.y - ycocg.z,
            ycocg.x + ycocg.z,
            ycocg.x - ycocg.y - ycocg.z
        )
    }

    /// Variance clipping to reduce ghosting
    fn variance_clip(
        &self,
        history_color: Vec3,
        current_color: Vec3,
        neighbors: &[Vec3; 9]
    ) -> Vec3 {
        // Calculate mean and variance of neighborhood
        let mut mean = Vec3::ZERO;
        let mut m2 = Vec3::ZERO;

        for neighbor in neighbors {
            let ycocg = Self::rgb_to_ycocg(*neighbor);
            mean = mean + ycocg;
            m2 = m2 + Vec3::new(ycocg.x * ycocg.x, ycocg.y * ycocg.y, ycocg.z * ycocg.z);
        }

        mean = mean / 9.0;
        let variance = m2 / 9.0 - Vec3::new(mean.x * mean.x, mean.y * mean.y, mean.z * mean.z);
        let stddev = Vec3::new(variance.x.sqrt(), variance.y.sqrt(), variance.z.sqrt());

        // Clip history to AABB
        let history_ycocg = Self::rgb_to_ycocg(history_color);
        let gamma = 1.0; // Clipping tightness

        let aabb_min = mean - stddev * gamma;
        let aabb_max = mean + stddev * gamma;

        let clipped = Vec3::new(
            history_ycocg.x.max(aabb_min.x).min(aabb_max.x),
            history_ycocg.y.max(aabb_min.y).min(aabb_max.y),
            history_ycocg.z.max(aabb_min.z).min(aabb_max.z)
        );

        Self::ycocg_to_rgb(clipped)
    }

    /// Sample history with reprojection
    fn sample_history(
        &self,
        history: &[Vec4],
        velocity: Vec2,
        x: u32,
        y: u32,
        width: u32,
        height: u32
    ) -> Option<Vec4> {
        let prev_x = x as f32 - velocity.x * width as f32;
        let prev_y = y as f32 - velocity.y * height as f32;

        // Bounds check
        if prev_x < 0.0 || prev_x >= width as f32 - 1.0 ||
           prev_y < 0.0 || prev_y >= height as f32 - 1.0 {
            return None;
        }

        // Bilinear interpolation
        let x0 = prev_x as u32;
        let y0 = prev_y as u32;
        let x1 = x0 + 1;
        let y1 = y0 + 1;

        let fx = prev_x.fract();
        let fy = prev_y.fract();

        let s00 = history[(y0 * width + x0) as usize];
        let s10 = history[(y0 * width + x1) as usize];
        let s01 = history[(y1 * width + x0) as usize];
        let s11 = history[(y1 * width + x1) as usize];

        let top = s00 * (1.0 - fx) + s10 * fx;
        let bottom = s01 * (1.0 - fx) + s11 * fx;

        Some(top * (1.0 - fy) + bottom * fy)
    }

    /// Apply TAA
    pub fn apply(
        &mut self,
        current: &[Vec4],
        velocity: Option<&[Vec2]>,
        depth: Option<&[f32]>,
        width: u32,
        height: u32
    ) -> Vec<Vec4> {
        let mut result = vec![Vec4::ZERO; current.len()];

        for y in 0..height {
            for x in 0..width {
                let idx = (y * width + x) as usize;
                let current_color = current[idx];

                // Get velocity for reprojection
                let vel = velocity.map(|v| v[idx]).unwrap_or(Vec2::ZERO);

                // Sample history
                let history_color = self.sample_history(
                    &self.history, vel, x, y, width, height
                );

                let blended = if let Some(history) = history_color {
                    // Apply variance clipping if enabled
                    let clipped_history = if self.config.taa_variance_clipping {
                        // Gather neighborhood
                        let mut neighbors = [Vec3::ZERO; 9];
                        let mut ni = 0;
                        for dy in -1i32..=1 {
                            for dx in -1i32..=1 {
                                let nx = (x as i32 + dx).max(0).min(width as i32 - 1) as u32;
                                let ny = (y as i32 + dy).max(0).min(height as i32 - 1) as u32;
                                neighbors[ni] = current[(ny * width + nx) as usize].xyz();
                                ni += 1;
                            }
                        }

                        Vec4::from_vec3(
                            self.variance_clip(history.xyz(), current_color.xyz(), &neighbors),
                            history.w
                        )
                    } else {
                        history
                    };

                    // Blend factor adjustment based on motion
                    let motion_weight = vel.length() * self.config.taa_motion_scale;
                    let blend_factor = lerp(
                        self.config.taa_blend_factor,
                        1.0,
                        saturate(motion_weight * 10.0)
                    );

                    // Depth rejection
                    let depth_blend = if self.config.taa_depth_rejection {
                        if let Some(d) = depth {
                            let current_depth = d[idx];
                            // Simple depth-based rejection (simplified)
                            if motion_weight > 0.01 {
                                blend_factor.max(0.5)
                            } else {
                                blend_factor
                            }
                        } else {
                            blend_factor
                        }
                    } else {
                        blend_factor
                    };

                    clipped_history * (1.0 - depth_blend) + current_color * depth_blend
                } else {
                    // No valid history, use current
                    current_color
                };

                result[idx] = blended;
            }
        }

        // Update history
        self.history = result.clone();
        self.frame_index += 1;

        // Apply sharpening if configured
        if self.config.taa_sharpen > 0.0 {
            self.sharpen(&mut result, width, height);
        }

        result
    }

    /// Apply contrast-adaptive sharpening
    fn sharpen(&self, image: &mut [Vec4], width: u32, height: u32) {
        let strength = self.config.taa_sharpen;
        let original = image.to_vec();

        for y in 1..height-1 {
            for x in 1..width-1 {
                let idx = (y * width + x) as usize;
                let center = original[idx];

                // 3x3 neighborhood
                let top = original[((y-1) * width + x) as usize];
                let bottom = original[((y+1) * width + x) as usize];
                let left = original[(y * width + x - 1) as usize];
                let right = original[(y * width + x + 1) as usize];

                // Laplacian-based sharpening
                let laplacian = center * 4.0 - top - bottom - left - right;
                image[idx] = center + laplacian * strength;

                // Clamp to valid range
                image[idx].x = image[idx].x.max(0.0);
                image[idx].y = image[idx].y.max(0.0);
                image[idx].z = image[idx].z.max(0.0);
            }
        }
    }

    /// Reset history
    pub fn reset(&mut self) {
        for h in &mut self.history {
            *h = Vec4::ZERO;
        }
        self.frame_index = 0;
    }
}

// =============================================================================
// AA Renderer
// =============================================================================

/// Main anti-aliasing renderer
struct AaRenderer {
    config: AaConfig,
    fxaa: Option<Fxaa>,
    smaa: Option<Smaa>,
    taa: Option<Taa>,
    width: u32,
    height: u32,
}

impl AaRenderer {
    /// Create new AA renderer
    pub fn new(width: u32, height: u32, config: AaConfig) -> Self {
        let mut renderer = Self {
            fxaa: None,
            smaa: None,
            taa: None,
            width,
            height,
            config,
        };

        renderer.initialize_algorithm();
        renderer
    }

    /// Initialize selected algorithm
    fn initialize_algorithm(&mut self) {
        match self.config.algorithm {
            AaAlgorithm::Fxaa | AaAlgorithm::FxaaQuality => {
                self.fxaa = Some(Fxaa::new(self.config.clone()));
            },
            AaAlgorithm::Smaa | AaAlgorithm::SmaaT2x => {
                self.smaa = Some(Smaa::new(self.config.clone()));
            },
            AaAlgorithm::Taa | AaAlgorithm::TaaSharp => {
                self.taa = Some(Taa::new(self.width, self.height, self.config.clone()));
            },
            AaAlgorithm::Mlaa | AaAlgorithm::Cmaa2 | AaAlgorithm::Dlaa => {
                // Use SMAA as fallback
                self.smaa = Some(Smaa::new(self.config.clone()));
            },
            AaAlgorithm::None => {},
        }
    }

    /// Get jitter offset for TAA
    pub fn get_jitter(&self) -> Vec2 {
        if let Some(ref taa) = self.taa {
            taa.get_jitter()
        } else {
            Vec2::ZERO
        }
    }

    /// Apply anti-aliasing
    pub fn apply(
        &mut self,
        color: &[Vec4],
        velocity: Option<&[Vec2]>,
        depth: Option<&[f32]>,
    ) -> Vec<Vec4> {
        if !self.config.enabled {
            return color.to_vec();
        }

        match self.config.algorithm {
            AaAlgorithm::Fxaa | AaAlgorithm::FxaaQuality => {
                if let Some(ref fxaa) = self.fxaa {
                    fxaa.apply(color, self.width, self.height)
                } else {
                    color.to_vec()
                }
            },
            AaAlgorithm::Smaa | AaAlgorithm::SmaaT2x |
            AaAlgorithm::Mlaa | AaAlgorithm::Cmaa2 | AaAlgorithm::Dlaa => {
                if let Some(ref smaa) = self.smaa {
                    smaa.apply(color, self.width, self.height)
                } else {
                    color.to_vec()
                }
            },
            AaAlgorithm::Taa | AaAlgorithm::TaaSharp => {
                if let Some(ref mut taa) = self.taa {
                    taa.apply(color, velocity, depth, self.width, self.height)
                } else {
                    color.to_vec()
                }
            },
            AaAlgorithm::None => color.to_vec(),
        }
    }

    /// Reset temporal data
    pub fn reset(&mut self) {
        if let Some(ref mut taa) = self.taa {
            taa.reset();
        }
    }
}

// =============================================================================
// WGSL Shaders
// =============================================================================

mod shaders {
    /// FXAA compute shader
    pub const FXAA_COMPUTE: &str = r#"
struct FxaaParams {
    resolution: vec2<f32>,
    subpixel_quality: f32,
    edge_threshold: f32,
    edge_threshold_min: f32,
    _pad: vec3<f32>,
}

@group(0) @binding(0) var<uniform> params: FxaaParams;
@group(0) @binding(1) var input_tex: texture_2d<f32>;
@group(0) @binding(2) var output_tex: texture_storage_2d<rgba16float, write>;
@group(0) @binding(3) var linear_sampler: sampler;

fn luminance(color: vec3<f32>) -> f32 {
    return dot(color, vec3<f32>(0.299, 0.587, 0.114));
}

@compute @workgroup_size(8, 8)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(input_tex);
    if (id.x >= dims.x || id.y >= dims.y) {
        return;
    }

    let uv = (vec2<f32>(id.xy) + 0.5) / params.resolution;
    let texel = 1.0 / params.resolution;

    // Sample center and neighbors
    let rgbM = textureSampleLevel(input_tex, linear_sampler, uv, 0.0);
    let rgbN = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(0.0, -texel.y), 0.0);
    let rgbS = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(0.0, texel.y), 0.0);
    let rgbE = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(texel.x, 0.0), 0.0);
    let rgbW = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(-texel.x, 0.0), 0.0);

    let lumM = luminance(rgbM.rgb);
    let lumN = luminance(rgbN.rgb);
    let lumS = luminance(rgbS.rgb);
    let lumE = luminance(rgbE.rgb);
    let lumW = luminance(rgbW.rgb);

    let lumMin = min(lumM, min(min(lumN, lumS), min(lumE, lumW)));
    let lumMax = max(lumM, max(max(lumN, lumS), max(lumE, lumW)));
    let lumRange = lumMax - lumMin;

    // Early exit
    if (lumRange < max(params.edge_threshold_min, lumMax * params.edge_threshold)) {
        textureStore(output_tex, id.xy, rgbM);
        return;
    }

    // Sample corners
    let rgbNW = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(-texel.x, -texel.y), 0.0);
    let rgbNE = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(texel.x, -texel.y), 0.0);
    let rgbSW = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(-texel.x, texel.y), 0.0);
    let rgbSE = textureSampleLevel(input_tex, linear_sampler, uv + vec2<f32>(texel.x, texel.y), 0.0);

    let lumNW = luminance(rgbNW.rgb);
    let lumNE = luminance(rgbNE.rgb);
    let lumSW = luminance(rgbSW.rgb);
    let lumSE = luminance(rgbSE.rgb);

    // Edge detection
    let edgeHorz = abs((lumNW + lumNE) - 2.0 * lumN) +
                   abs((lumW + lumE) - 2.0 * lumM) * 2.0 +
                   abs((lumSW + lumSE) - 2.0 * lumS);
    let edgeVert = abs((lumNW + lumSW) - 2.0 * lumW) +
                   abs((lumN + lumS) - 2.0 * lumM) * 2.0 +
                   abs((lumNE + lumSE) - 2.0 * lumE);

    let isHorizontal = edgeHorz >= edgeVert;

    // Calculate blend direction
    let lum1 = select(lumW, lumN, isHorizontal);
    let lum2 = select(lumE, lumS, isHorizontal);

    let gradient1 = lum1 - lumM;
    let gradient2 = lum2 - lumM;
    let gradient = max(abs(gradient1), abs(gradient2));

    let stepLength = select(texel.x, texel.y, isHorizontal);
    let pixelStep = select(
        select(-stepLength, stepLength, gradient2 > gradient1),
        select(-stepLength, stepLength, gradient2 > gradient1),
        isHorizontal
    );

    // Subpixel AA
    let lumAvg = (lumN + lumS + lumE + lumW) * 0.25;
    let subPixelOffset = saturate(abs(lumAvg - lumM) / lumRange);
    let subPixelOffsetFinal = pow(subPixelOffset, 2.0) * params.subpixel_quality;

    // Final sample
    var finalUv = uv;
    if (isHorizontal) {
        finalUv.y += pixelStep * subPixelOffsetFinal;
    } else {
        finalUv.x += pixelStep * subPixelOffsetFinal;
    }

    let result = textureSampleLevel(input_tex, linear_sampler, finalUv, 0.0);
    textureStore(output_tex, id.xy, result);
}
"#;

    /// TAA compute shader
    pub const TAA_COMPUTE: &str = r#"
struct TaaParams {
    resolution: vec2<f32>,
    blend_factor: f32,
    sharpen: f32,
    jitter: vec2<f32>,
    motion_scale: f32,
    use_variance_clipping: u32,
}

@group(0) @binding(0) var<uniform> params: TaaParams;
@group(0) @binding(1) var current_tex: texture_2d<f32>;
@group(0) @binding(2) var history_tex: texture_2d<f32>;
@group(0) @binding(3) var velocity_tex: texture_2d<f32>;
@group(0) @binding(4) var output_tex: texture_storage_2d<rgba16float, write>;
@group(0) @binding(5) var linear_sampler: sampler;

fn rgb_to_ycocg(rgb: vec3<f32>) -> vec3<f32> {
    return vec3<f32>(
        rgb.r * 0.25 + rgb.g * 0.5 + rgb.b * 0.25,
        rgb.r * 0.5 - rgb.b * 0.5,
        -rgb.r * 0.25 + rgb.g * 0.5 - rgb.b * 0.25
    );
}

fn ycocg_to_rgb(ycocg: vec3<f32>) -> vec3<f32> {
    return vec3<f32>(
        ycocg.x + ycocg.y - ycocg.z,
        ycocg.x + ycocg.z,
        ycocg.x - ycocg.y - ycocg.z
    );
}

fn variance_clip(history: vec3<f32>, current: vec3<f32>, m1: vec3<f32>, m2: vec3<f32>) -> vec3<f32> {
    let variance = m2 - m1 * m1;
    let stddev = sqrt(max(variance, vec3<f32>(0.0)));

    let history_ycocg = rgb_to_ycocg(history);
    let mean = rgb_to_ycocg(m1);

    let aabb_min = mean - stddev;
    let aabb_max = mean + stddev;

    let clipped = clamp(history_ycocg, aabb_min, aabb_max);
    return ycocg_to_rgb(clipped);
}

@compute @workgroup_size(8, 8)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(current_tex);
    if (id.x >= dims.x || id.y >= dims.y) {
        return;
    }

    let uv = (vec2<f32>(id.xy) + 0.5) / params.resolution;
    let current = textureSampleLevel(current_tex, linear_sampler, uv, 0.0);
    let velocity = textureSampleLevel(velocity_tex, linear_sampler, uv, 0.0).xy;

    // Reprojected UV
    let history_uv = uv - velocity;

    // Check bounds
    if (history_uv.x < 0.0 || history_uv.x > 1.0 || history_uv.y < 0.0 || history_uv.y > 1.0) {
        textureStore(output_tex, id.xy, current);
        return;
    }

    var history = textureSampleLevel(history_tex, linear_sampler, history_uv, 0.0);

    // Variance clipping
    if (params.use_variance_clipping == 1u) {
        var m1 = vec3<f32>(0.0);
        var m2 = vec3<f32>(0.0);

        let texel = 1.0 / params.resolution;
        for (var y = -1; y <= 1; y++) {
            for (var x = -1; x <= 1; x++) {
                let offset = vec2<f32>(f32(x), f32(y)) * texel;
                let sample = textureSampleLevel(current_tex, linear_sampler, uv + offset, 0.0).rgb;
                let ycocg = rgb_to_ycocg(sample);
                m1 += ycocg;
                m2 += ycocg * ycocg;
            }
        }

        m1 /= 9.0;
        m2 /= 9.0;

        history = vec4<f32>(variance_clip(history.rgb, current.rgb, ycocg_to_rgb(m1), ycocg_to_rgb(m2)), history.a);
    }

    // Adaptive blend based on motion
    let motion_weight = length(velocity) * params.motion_scale;
    let blend = mix(params.blend_factor, 1.0, saturate(motion_weight * 10.0));

    let result = mix(history, current, blend);
    textureStore(output_tex, id.xy, result);
}
"#;

    /// SMAA edge detection shader
    pub const SMAA_EDGE_DETECT: &str = r#"
struct SmaaParams {
    resolution: vec2<f32>,
    threshold: f32,
    _pad: f32,
}

@group(0) @binding(0) var<uniform> params: SmaaParams;
@group(0) @binding(1) var input_tex: texture_2d<f32>;
@group(0) @binding(2) var edges_tex: texture_storage_2d<rg8unorm, write>;
@group(0) @binding(3) var point_sampler: sampler;

fn luminance(color: vec3<f32>) -> f32 {
    return dot(color, vec3<f32>(0.299, 0.587, 0.114));
}

@compute @workgroup_size(8, 8)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(input_tex);
    if (id.x >= dims.x || id.y >= dims.y) {
        return;
    }

    let uv = (vec2<f32>(id.xy) + 0.5) / params.resolution;
    let texel = 1.0 / params.resolution;

    let center = textureSampleLevel(input_tex, point_sampler, uv, 0.0);
    let left = textureSampleLevel(input_tex, point_sampler, uv - vec2<f32>(texel.x, 0.0), 0.0);
    let top = textureSampleLevel(input_tex, point_sampler, uv - vec2<f32>(0.0, texel.y), 0.0);

    let lumCenter = luminance(center.rgb);
    let lumLeft = luminance(left.rgb);
    let lumTop = luminance(top.rgb);

    let edgeH = select(0.0, 1.0, abs(lumCenter - lumLeft) > params.threshold);
    let edgeV = select(0.0, 1.0, abs(lumCenter - lumTop) > params.threshold);

    textureStore(edges_tex, id.xy, vec4<f32>(edgeH, edgeV, 0.0, 1.0));
}
"#;

    /// Sharpening shader
    pub const SHARPEN: &str = r#"
struct SharpenParams {
    strength: f32,
    _pad: vec3<f32>,
}

@group(0) @binding(0) var<uniform> params: SharpenParams;
@group(0) @binding(1) var input_tex: texture_2d<f32>;
@group(0) @binding(2) var output_tex: texture_storage_2d<rgba16float, write>;

@compute @workgroup_size(8, 8)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let dims = textureDimensions(input_tex);
    if (id.x == 0u || id.y == 0u || id.x >= dims.x - 1u || id.y >= dims.y - 1u) {
        textureStore(output_tex, id.xy, textureLoad(input_tex, id.xy, 0));
        return;
    }

    let center = textureLoad(input_tex, id.xy, 0);
    let top = textureLoad(input_tex, vec2<u32>(id.x, id.y - 1u), 0);
    let bottom = textureLoad(input_tex, vec2<u32>(id.x, id.y + 1u), 0);
    let left = textureLoad(input_tex, vec2<u32>(id.x - 1u, id.y), 0);
    let right = textureLoad(input_tex, vec2<u32>(id.x + 1u, id.y), 0);

    let laplacian = center * 4.0 - top - bottom - left - right;
    let result = center + laplacian * params.strength;

    textureStore(output_tex, id.xy, max(result, vec4<f32>(0.0)));
}
"#;
}

// =============================================================================
// Unit Tests
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_config_presets() {
        let default = AaConfig::default();
        assert!(default.enabled);
        assert!(matches!(default.algorithm, AaAlgorithm::Taa));

        let perf = AaConfig::performance();
        assert!(matches!(perf.algorithm, AaAlgorithm::Fxaa));

        let ultra = AaConfig::ultra();
        assert!(matches!(ultra.algorithm, AaAlgorithm::SmaaT2x));
    }

    #[test]
    fn test_fxaa_luminance() {
        let white = Vec3::new(1.0, 1.0, 1.0);
        let lum = Fxaa::luminance(white);
        assert!((lum - 1.0).abs() < 0.01);

        let black = Vec3::ZERO;
        let lum = Fxaa::luminance(black);
        assert!(lum < 0.01);
    }

    #[test]
    fn test_taa_halton() {
        let h1 = Taa::halton(1, 2);
        let h2 = Taa::halton(2, 2);
        let h3 = Taa::halton(3, 2);

        assert!(h1 >= 0.0 && h1 < 1.0);
        assert!(h2 >= 0.0 && h2 < 1.0);
        assert!(h3 >= 0.0 && h3 < 1.0);

        // Should produce different values
        assert!(h1 != h2);
    }

    #[test]
    fn test_taa_jitter() {
        let config = AaConfig::default();
        let taa = Taa::new(256, 256, config);

        let jitter = taa.get_jitter();
        assert!(jitter.x.abs() <= 0.5);
        assert!(jitter.y.abs() <= 0.5);
    }

    #[test]
    fn test_taa_ycocg_roundtrip() {
        let rgb = Vec3::new(0.5, 0.3, 0.8);
        let ycocg = Taa::rgb_to_ycocg(rgb);
        let back = Taa::ycocg_to_rgb(ycocg);

        assert!((back.x - rgb.x).abs() < 0.001);
        assert!((back.y - rgb.y).abs() < 0.001);
        assert!((back.z - rgb.z).abs() < 0.001);
    }

    #[test]
    fn test_smaa_creation() {
        let config = AaConfig::default();
        let smaa = Smaa::new(config);

        assert!(!smaa.search_tex.is_empty());
        assert!(!smaa.area_tex.is_empty());
    }

    #[test]
    fn test_smaa_edge_detection() {
        let config = AaConfig::default();
        let smaa = Smaa::new(config);

        // Create test image with sharp edge
        let mut color = vec![Vec4::new(0.0, 0.0, 0.0, 1.0); 16 * 16];
        for y in 0..16 {
            for x in 8..16 {
                color[y * 16 + x] = Vec4::new(1.0, 1.0, 1.0, 1.0);
            }
        }

        let edges = smaa.detect_edges(&color, 16, 16);

        // Should detect vertical edge at x=8
        let edge_at_8 = edges[8 * 16 + 8];
        assert!(edge_at_8.x > 0.0 || edge_at_8.y > 0.0);
    }

    #[test]
    fn test_aa_renderer_creation() {
        let config = AaConfig::default();
        let renderer = AaRenderer::new(256, 256, config);

        assert!(renderer.taa.is_some()); // Default is TAA
    }

    #[test]
    fn test_aa_renderer_disabled() {
        let mut config = AaConfig::default();
        config.enabled = false;

        let mut renderer = AaRenderer::new(64, 64, config);
        let color = vec![Vec4::new(1.0, 0.0, 0.0, 1.0); 64 * 64];

        let result = renderer.apply(&color, None, None);

        // When disabled, should return input unchanged
        assert_eq!(result.len(), color.len());
        assert_eq!(result[0].x, color[0].x);
    }

    #[test]
    fn test_taa_reset() {
        let config = AaConfig::default();
        let mut taa = Taa::new(64, 64, config);

        // Apply once to accumulate history
        let color = vec![Vec4::new(1.0, 0.0, 0.0, 1.0); 64 * 64];
        taa.apply(&color, None, None, 64, 64);

        // Reset
        taa.reset();

        assert_eq!(taa.frame_index, 0);
        assert!(taa.history.iter().all(|c| c.x == 0.0));
    }
}
