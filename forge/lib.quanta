// -----------------------------------------------------------------------------
// MANIFEST PARSING
// -----------------------------------------------------------------------------

/// Package manifest (quark.toml)
#[derive(Debug, Clone)]
pub struct Manifest {
    pub package: PackageInfo,
    pub dependencies: HashMap<String, Dependency>,
    pub dev_dependencies: HashMap<String, Dependency>,
    pub build_dependencies: HashMap<String, Dependency>,
    pub features: HashMap<String, Vec<String>>,
    pub workspace: Option<WorkspaceConfig>,
    pub profile: ProfileConfig,
    pub targets: Vec<TargetConfig>,
}

#[derive(Debug, Clone)]
pub struct PackageInfo {
    pub name: String,
    pub version: String,
    pub authors: Vec<String>,
    pub edition: String,
    pub license: Option<String>,
    pub description: Option<String>,
    pub repository: Option<String>,
    pub keywords: Vec<String>,
    pub categories: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct Dependency {
    pub version: String,
    pub path: Option<PathBuf>,
    pub git: Option<String>,
    pub branch: Option<String>,
    pub features: Vec<String>,
    pub optional: bool,
}

#[derive(Debug, Clone)]
pub struct WorkspaceConfig {
    pub members: Vec<String>,
    pub exclude: Vec<String>,
    pub default_members: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct ProfileConfig {
    pub debug: CompilerSettings,
    pub release: CompilerSettings,
    pub test: CompilerSettings,
    pub bench: CompilerSettings,
}

#[derive(Debug, Clone)]
pub struct CompilerSettings {
    pub opt_level: u8,           // 0-3
    pub debug_info: bool,
    pub debug_assertions: bool,
    pub overflow_checks: bool,
    pub lto: LtoMode,
    pub panic: PanicStrategy,
    pub incremental: bool,
    pub codegen_units: usize,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LtoMode {
    Off,
    Thin,
    Fat,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum PanicStrategy {
    Unwind,
    Abort,
}

#[derive(Debug, Clone)]
pub struct TargetConfig {
    pub name: String,
    pub kind: TargetKind,
    pub path: PathBuf,
    pub required_features: Vec<String>,
}

impl Manifest {
    /// Parse manifest from quark.toml
    pub fn parse(path: &Path) -> Result<Self, String> {
        let content = fs::read_to_string(path)
            .map_err(|e| format!("Failed to read manifest: {}", e))?;

        Self::parse_toml(&content)
    }

    fn parse_toml(content: &str) -> Result<Self, String> {
        let mut package = PackageInfo {
            name: String::new(),
            version: "0.1.0".to_string(),
            authors: Vec::new(),
            edition: "2025".to_string(),
            license: None,
            description: None,
            repository: None,
            keywords: Vec::new(),
            categories: Vec::new(),
        };

        let mut dependencies = HashMap::new();
        let mut dev_dependencies = HashMap::new();
        let mut build_dependencies = HashMap::new();
        let mut features = HashMap::new();
        let mut workspace = None;
        let mut targets = Vec::new();

        let mut current_section = "";

        for line in content.lines() {
            let line = line.trim();

            // Skip empty lines and comments
            if line.is_empty() || line.starts_with('#') {
                continue;
            }

            // Section header
            if line.starts_with('[') && line.ends_with(']') {
                current_section = &line[1..line.len()-1];
                continue;
            }

            // Key-value pair
            if let Some(eq_pos) = line.find('=') {
                let key = line[..eq_pos].trim();
                let value = line[eq_pos+1..].trim();
                let value = value.trim_matches('"');

                match current_section {
                    "package" => {
                        match key {
                            "name" => package.name = value.to_string(),
                            "version" => package.version = value.to_string(),
                            "edition" => package.edition = value.to_string(),
                            "license" => package.license = Some(value.to_string()),
                            "description" => package.description = Some(value.to_string()),
                            "repository" => package.repository = Some(value.to_string()),
                            "authors" => {
                                // Parse array: ["author1", "author2"]
                                let arr = value.trim_start_matches('[').trim_end_matches(']');
                                for author in arr.split(',') {
                                    let author = author.trim().trim_matches('"');
                                    if !author.is_empty() {
                                        package.authors.push(author.to_string());
                                    }
                                }
                            }
                            _ => {}
                        }
                    }
                    "dependencies" => {
                        let dep = Self::parse_dependency(value);
                        dependencies.insert(key.to_string(), dep);
                    }
                    "dev-dependencies" => {
                        let dep = Self::parse_dependency(value);
                        dev_dependencies.insert(key.to_string(), dep);
                    }
                    "build-dependencies" => {
                        let dep = Self::parse_dependency(value);
                        build_dependencies.insert(key.to_string(), dep);
                    }
                    "workspace" => {
                        if workspace.is_none() {
                            workspace = Some(WorkspaceConfig {
                                members: Vec::new(),
                                exclude: Vec::new(),
                                default_members: Vec::new(),
                            });
                        }
                        if let Some(ref mut ws) = workspace {
                            if key == "members" {
                                let arr = value.trim_start_matches('[').trim_end_matches(']');
                                for member in arr.split(',') {
                                    let member = member.trim().trim_matches('"');
                                    if !member.is_empty() {
                                        ws.members.push(member.to_string());
                                    }
                                }
                            }
                        }
                    }
                    _ => {}
                }
            }
        }

        // Auto-detect targets if none specified
        if targets.is_empty() {
            let manifest_dir = PathBuf::from(".");

            // Check for lib.quanta
            if manifest_dir.join("src/lib.quanta").exists() {
                targets.push(TargetConfig {
                    name: package.name.clone(),
                    kind: TargetKind::Library,
                    path: PathBuf::from("src/lib.quanta"),
                    required_features: Vec::new(),
                });
            }

            // Check for main.quanta
            if manifest_dir.join("src/main.quanta").exists() {
                targets.push(TargetConfig {
                    name: package.name.clone(),
                    kind: TargetKind::Binary,
                    path: PathBuf::from("src/main.quanta"),
                    required_features: Vec::new(),
                });
            }
        }

        Ok(Manifest {
            package,
            dependencies,
            dev_dependencies,
            build_dependencies,
            features,
            workspace,
            profile: ProfileConfig::default(),
            targets,
        })
    }

    fn parse_dependency(value: &str) -> Dependency {
        // Simple version string: "1.0.0"
        if !value.contains('{') {
            return Dependency {
                version: value.trim_matches('"').to_string(),
                path: None,
                git: None,
                branch: None,
                features: Vec::new(),
                optional: false,
            };
        }

        // Complex dependency: { version = "1.0", features = ["a", "b"] }
        let mut dep = Dependency {
            version: "*".to_string(),
            path: None,
            git: None,
            branch: None,
            features: Vec::new(),
            optional: false,
        };

        let inner = value.trim_start_matches('{').trim_end_matches('}');
        for part in inner.split(',') {
            let part = part.trim();
            if let Some(eq_pos) = part.find('=') {
                let key = part[..eq_pos].trim();
                let val = part[eq_pos+1..].trim().trim_matches('"');
                match key {
                    "version" => dep.version = val.to_string(),
                    "path" => dep.path = Some(PathBuf::from(val)),
                    "git" => dep.git = Some(val.to_string()),
                    "branch" => dep.branch = Some(val.to_string()),
                    "optional" => dep.optional = val == "true",
                    _ => {}
                }
            }
        }

        dep
    }
}

impl Default for ProfileConfig {
    fn default() -> Self {
        ProfileConfig {
            debug: CompilerSettings {
                opt_level: 0,
                debug_info: true,
                debug_assertions: true,
                overflow_checks: true,
                lto: LtoMode::Off,
                panic: PanicStrategy::Unwind,
                incremental: true,
                codegen_units: 256,
            },
            release: CompilerSettings {
                opt_level: 3,
                debug_info: false,
                debug_assertions: false,
                overflow_checks: false,
                lto: LtoMode::Thin,
                panic: PanicStrategy::Abort,
                incremental: false,
                codegen_units: 1,
            },
            test: CompilerSettings {
                opt_level: 0,
                debug_info: true,
                debug_assertions: true,
                overflow_checks: true,
                lto: LtoMode::Off,
                panic: PanicStrategy::Unwind,
                incremental: true,
                codegen_units: 256,
            },
            bench: CompilerSettings {
                opt_level: 3,
                debug_info: true,
                debug_assertions: false,
                overflow_checks: false,
                lto: LtoMode::Thin,
                panic: PanicStrategy::Unwind,
                incremental: false,
                codegen_units: 1,
            },
        }
    }
}

// -----------------------------------------------------------------------------
// COMPILER DRIVER
// -----------------------------------------------------------------------------

/// QuantaLang compiler driver
pub struct Compiler {
    settings: CompilerSettings,
    target_dir: PathBuf,
    profile: BuildProfile,
    verbose: bool,
}

/// Compiler diagnostic
#[derive(Debug, Clone)]
pub struct Diagnostic {
    pub level: DiagnosticLevel,
    pub message: String,
    pub file: Option<PathBuf>,
    pub line: Option<usize>,
    pub column: Option<usize>,
    pub code: Option<String>,
    pub notes: Vec<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DiagnosticLevel {
    Error,
    Warning,
    Note,
    Help,
}

/// Compilation unit
#[derive(Debug, Clone)]
pub struct CompilationUnit {
    pub source_path: PathBuf,
    pub output_path: PathBuf,
    pub dependencies: Vec<PathBuf>,
}

impl Compiler {
    pub fn new(profile: BuildProfile, target_dir: PathBuf) -> Self {
        let settings = match profile {
            BuildProfile::Debug => ProfileConfig::default().debug,
            BuildProfile::Release => ProfileConfig::default().release,
            BuildProfile::Test => ProfileConfig::default().test,
            BuildProfile::Bench => ProfileConfig::default().bench,
        };

        Compiler {
            settings,
            target_dir,
            profile,
            verbose: false,
        }
    }

    pub fn verbose(mut self, v: bool) -> Self {
        self.verbose = v;
        self
    }

    /// Compile a single source file
    pub fn compile(&self, unit: &CompilationUnit) -> Result<Vec<Diagnostic>, String> {
        let mut diagnostics = Vec::new();

        // Ensure output directory exists
        if let Some(parent) = unit.output_path.parent() {
            fs::create_dir_all(parent)
                .map_err(|e| format!("Failed to create output directory: {}", e))?;
        }

        // Build compiler arguments
        let mut args = Vec::new();

        // Source file
        args.push(unit.source_path.to_string_lossy().to_string());

        // Output path
        args.push("-o".to_string());
        args.push(unit.output_path.to_string_lossy().to_string());

        // Optimization level
        args.push(format!("-O{}", self.settings.opt_level));

        // Debug info
        if self.settings.debug_info {
            args.push("-g".to_string());
        }

        // Debug assertions
        if self.settings.debug_assertions {
            args.push("--debug-assertions".to_string());
        }

        // Overflow checks
        if self.settings.overflow_checks {
            args.push("--overflow-checks".to_string());
        }

        // LTO
        match self.settings.lto {
            LtoMode::Off => {}
            LtoMode::Thin => args.push("--lto=thin".to_string()),
            LtoMode::Fat => args.push("--lto=fat".to_string()),
        }

        // Panic strategy
        match self.settings.panic {
            PanicStrategy::Unwind => {}
            PanicStrategy::Abort => args.push("--panic=abort".to_string()),
        }

        // Codegen units
        args.push(format!("--codegen-units={}", self.settings.codegen_units));

        // Add dependency paths
        for dep in &unit.dependencies {
            args.push("-L".to_string());
            args.push(dep.to_string_lossy().to_string());
        }

        if self.verbose {
            log_debug(&format!("quantac {}", args.join(" ")));
        }

        // Invoke the QuantaLang compiler
        let compiler_path = self.find_compiler()?;

        let output = Command::new(&compiler_path)
            .args(&args)
            .stdout(Stdio::piped())
            .stderr(Stdio::piped())
            .output()
            .map_err(|e| format!("Failed to invoke compiler: {}", e))?;

        // Parse compiler output
        let stderr = String::from_utf8_lossy(&output.stderr);
        diagnostics.extend(self.parse_diagnostics(&stderr));

        if !output.status.success() {
            if diagnostics.iter().all(|d| d.level != DiagnosticLevel::Error) {
                diagnostics.push(Diagnostic {
                    level: DiagnosticLevel::Error,
                    message: format!("Compilation failed with exit code: {:?}", output.status.code()),
                    file: Some(unit.source_path.clone()),
                    line: None,
                    column: None,
                    code: None,
                    notes: Vec::new(),
                });
            }
        }

        Ok(diagnostics)
    }

    /// Find the QuantaLang compiler executable
    fn find_compiler(&self) -> Result<PathBuf, String> {
        // Check QUANTAC_PATH environment variable
        if let Ok(path) = std::env::var("QUANTAC_PATH") {
            let path = PathBuf::from(path);
            if path.exists() {
                return Ok(path);
            }
        }

        // Check common installation paths
        let candidates = [
            PathBuf::from("/usr/local/bin/quantac"),
            PathBuf::from("/usr/bin/quantac"),
            PathBuf::from("~/.quanta/bin/quantac"),
            PathBuf::from("./target/release/quantac"),
            PathBuf::from("./quantac"),
            #[cfg(windows)]
            PathBuf::from("C:\\Program Files\\Quanta\\bin\\quantac.exe"),
            #[cfg(windows)]
            PathBuf::from("quantac.exe"),
        ];

        for path in &candidates {
            let expanded = if path.starts_with("~") {
                if let Some(home) = std::env::var("HOME").ok().or_else(|| std::env::var("USERPROFILE").ok()) {
                    PathBuf::from(home).join(path.strip_prefix("~").unwrap())
                } else {
                    path.clone()
                }
            } else {
                path.clone()
            };

            if expanded.exists() {
                return Ok(expanded);
            }
        }

        // Check PATH
        if let Ok(path_env) = std::env::var("PATH") {
            #[cfg(windows)]
            let sep = ';';
            #[cfg(not(windows))]
            let sep = ':';

            for dir in path_env.split(sep) {
                let candidate = PathBuf::from(dir).join("quantac");
                if candidate.exists() {
                    return Ok(candidate);
                }
                #[cfg(windows)]
                {
                    let candidate = PathBuf::from(dir).join("quantac.exe");
                    if candidate.exists() {
                        return Ok(candidate);
                    }
                }
            }
        }

        Err("QuantaLang compiler (quantac) not found. Please install QuantaLang or set QUANTAC_PATH".to_string())
    }

    /// Parse diagnostic messages from compiler output
    fn parse_diagnostics(&self, output: &str) -> Vec<Diagnostic> {
        let mut diagnostics = Vec::new();

        for line in output.lines() {
            // Parse format: "error[E0001]: message at file:line:col"
            // or: "warning: message at file:line:col"
            if line.starts_with("error") || line.starts_with("warning") || line.starts_with("note") {
                let level = if line.starts_with("error") {
                    DiagnosticLevel::Error
                } else if line.starts_with("warning") {
                    DiagnosticLevel::Warning
                } else {
                    DiagnosticLevel::Note
                };

                // Extract error code if present
                let code = if let Some(start) = line.find('[') {
                    if let Some(end) = line.find(']') {
                        Some(line[start+1..end].to_string())
                    } else { None }
                } else { None };

                // Extract message
                let msg_start = line.find(':').map(|i| i + 1).unwrap_or(0);
                let message = if let Some(at_pos) = line.rfind(" at ") {
                    line[msg_start..at_pos].trim().to_string()
                } else {
                    line[msg_start..].trim().to_string()
                };

                // Extract location
                let (file, line_num, col) = if let Some(at_pos) = line.rfind(" at ") {
                    let location = &line[at_pos+4..];
                    let parts: Vec<&str> = location.split(':').collect();
                    (
                        Some(PathBuf::from(parts.get(0).unwrap_or(&""))),
                        parts.get(1).and_then(|s| s.parse().ok()),
                        parts.get(2).and_then(|s| s.parse().ok()),
                    )
                } else {
                    (None, None, None)
                };

                diagnostics.push(Diagnostic {
                    level,
                    message,
                    file,
                    line: line_num,
                    column: col,
                    code,
                    notes: Vec::new(),
                });
            }
        }

        diagnostics
    }
}

// -----------------------------------------------------------------------------
// BUILD CACHE
// -----------------------------------------------------------------------------

/// Build cache for incremental compilation
pub struct BuildCache {
    cache_dir: PathBuf,
    entries: HashMap<PathBuf, CacheEntry>,
}

#[derive(Debug, Clone)]
struct CacheEntry {
    source_hash: u64,
    modified_time: SystemTime,
    dependencies: Vec<PathBuf>,
    output_path: PathBuf,
}

impl BuildCache {
    pub fn new(cache_dir: PathBuf) -> Self {
        let mut cache = BuildCache {
            cache_dir,
            entries: HashMap::new(),
        };
        cache.load();
        cache
    }

    fn load(&mut self) {
        let cache_file = self.cache_dir.join("build-cache.json");
        if let Ok(content) = fs::read_to_string(&cache_file) {
            // Parse simple JSON-like format
            // In production, use proper JSON parsing
            for line in content.lines() {
                if let Some((path, rest)) = line.split_once('|') {
                    if let Some((hash, rest)) = rest.split_once('|') {
                        if let Ok(hash) = hash.parse::<u64>() {
                            self.entries.insert(
                                PathBuf::from(path),
                                CacheEntry {
                                    source_hash: hash,
                                    modified_time: SystemTime::UNIX_EPOCH,
                                    dependencies: Vec::new(),
                                    output_path: PathBuf::from(rest),
                                },
                            );
                        }
                    }
                }
            }
        }
    }

    fn save(&self) {
        let _ = fs::create_dir_all(&self.cache_dir);
        let cache_file = self.cache_dir.join("build-cache.json");

        let mut content = String::new();
        for (path, entry) in &self.entries {
            content.push_str(&format!(
                "{}|{}|{}\n",
                path.display(),
                entry.source_hash,
                entry.output_path.display()
            ));
        }

        let _ = fs::write(cache_file, content);
    }

    /// Check if source needs rebuild
    pub fn needs_rebuild(&self, source: &Path, output: &Path) -> bool {
        // Check if output exists
        if !output.exists() {
            return true;
        }

        // Get source modification time
        let source_modified = match fs::metadata(source) {
            Ok(meta) => meta.modified().unwrap_or(SystemTime::UNIX_EPOCH),
            Err(_) => return true,
        };

        // Get output modification time
        let output_modified = match fs::metadata(output) {
            Ok(meta) => meta.modified().unwrap_or(SystemTime::UNIX_EPOCH),
            Err(_) => return true,
        };

        // Rebuild if source is newer than output
        source_modified > output_modified
    }

    /// Update cache entry after successful build
    pub fn update(&mut self, source: &Path, output: &Path, hash: u64) {
        self.entries.insert(
            source.to_path_buf(),
            CacheEntry {
                source_hash: hash,
                modified_time: SystemTime::now(),
                dependencies: Vec::new(),
                output_path: output.to_path_buf(),
            },
        );
        self.save();
    }

    /// Compute simple hash of file contents
    pub fn hash_file(path: &Path) -> u64 {
        if let Ok(content) = fs::read(path) {
            // Simple FNV-1a hash
            let mut hash: u64 = 0xcbf29ce484222325;
            for byte in content {
                hash ^= byte as u64;
                hash = hash.wrapping_mul(0x100000001b3);
            }
            hash
        } else {
            0
        }
    }
}

// -----------------------------------------------------------------------------
// BUILD PROFILES
// -----------------------------------------------------------------------------

/// Build profile
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum BuildProfile {
    Debug,
    Release,
    Test,
    Bench,
}

impl BuildProfile {
    pub fn as_str(&self) -> &'static str {
        match self {
            BuildProfile::Debug => "debug",
            BuildProfile::Release => "release",
            BuildProfile::Test => "test",
            BuildProfile::Bench => "bench",
        }
    }
}

/// Build target
#[derive(Debug, Clone)]
pub struct BuildTarget {
    pub name: String,
    pub kind: TargetKind,
    pub src_path: PathBuf,
    pub dependencies: Vec<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TargetKind {
    Library,
    Binary,
    Test,
    Benchmark,
    Example,
}

/// Build result
#[derive(Debug, Clone)]
pub struct BuildResult {
    pub success: bool,
    pub target: String,
    pub duration: Duration,
    pub artifacts: Vec<PathBuf>,
    pub warnings: Vec<String>,
    pub errors: Vec<String>,
}

/// Build orchestrator
pub struct BuildOrchestrator {
    profile: BuildProfile,
    targets: Vec<BuildTarget>,
    parallel_jobs: usize,
    incremental: bool,
    verbose: bool,
    project_root: PathBuf,
    target_dir: PathBuf,
    cache: BuildCache,
    compiler: Compiler,
}

impl BuildOrchestrator {
    pub fn new(profile: BuildProfile) -> Self {
        Self::with_root(profile, PathBuf::from("."))
    }

    pub fn with_root(profile: BuildProfile, project_root: PathBuf) -> Self {
        let target_dir = project_root.join("target").join(profile.as_str());
        let cache_dir = project_root.join("target").join(".forge-cache");

        BuildOrchestrator {
            profile,
            targets: Vec::new(),
            parallel_jobs: num_cpus(),
            incremental: true,
            verbose: false,
            project_root: project_root.clone(),
            target_dir: target_dir.clone(),
            cache: BuildCache::new(cache_dir),
            compiler: Compiler::new(profile, target_dir),
        }
    }

    /// Load targets from manifest
    pub fn load_manifest(&mut self) -> Result<(), String> {
        let manifest_path = self.project_root.join("quark.toml");
        let manifest = Manifest::parse(&manifest_path)?;

        for target_config in manifest.targets {
            self.add_target(BuildTarget {
                name: target_config.name,
                kind: target_config.kind,
                src_path: self.project_root.join(&target_config.path),
                dependencies: Vec::new(),
            });
        }

        // Add dependencies from manifest
        for (name, dep) in manifest.dependencies {
            if let Some(path) = dep.path {
                // Local dependency
                let dep_manifest_path = self.project_root.join(&path).join("quark.toml");
                if dep_manifest_path.exists() {
                    if let Ok(dep_manifest) = Manifest::parse(&dep_manifest_path) {
                        for target_config in dep_manifest.targets {
                            if target_config.kind == TargetKind::Library {
                                self.add_target(BuildTarget {
                                    name: target_config.name,
                                    kind: target_config.kind,
                                    src_path: self.project_root.join(&path).join(&target_config.path),
                                    dependencies: Vec::new(),
                                });
                            }
                        }
                    }
                }
            }
        }

        Ok(())
    }

    pub fn add_target(&mut self, target: BuildTarget) {
        self.targets.push(target);
    }

    pub fn parallel_jobs(mut self, jobs: usize) -> Self {
        self.parallel_jobs = jobs;
        self
    }

    pub fn verbose(mut self, v: bool) -> Self {
        self.verbose = v;
        self
    }

    pub fn incremental(mut self, i: bool) -> Self {
        self.incremental = i;
        self
    }

    /// Run the build
    pub fn build(&self) -> Vec<BuildResult> {
        let start = Instant::now();
        let mut results = Vec::new();

        log_info(&format!("Building {} target(s) with profile '{}'",
            self.targets.len(), self.profile.as_str()));

        // Sort targets by dependencies (topological sort)
        let sorted = self.topological_sort();

        for target in sorted {
            let target_start = Instant::now();

            if self.verbose {
                log_debug(&format!("Building {}", target.name));
            }

            // Check if rebuild is needed
            if self.incremental && !self.needs_rebuild(&target) {
                if self.verbose {
                    log_debug(&format!("Skipping {} (up to date)", target.name));
                }
                results.push(BuildResult {
                    success: true,
                    target: target.name.clone(),
                    duration: Duration::ZERO,
                    artifacts: Vec::new(),
                    warnings: Vec::new(),
                    errors: Vec::new(),
                });
                continue;
            }

            // Build the target
            let result = self.build_target(&target);
            let duration = target_start.elapsed();

            if result.success {
                log_info(&format!("  {} built in {:.2}s", target.name, duration.as_secs_f64()));
            } else {
                log_error(&format!("  {} failed", target.name));
                for error in &result.errors {
                    log_error(&format!("    {}", error));
                }
            }

            results.push(result);
        }

        let total_duration = start.elapsed();
        log_info(&format!("Build completed in {:.2}s", total_duration.as_secs_f64()));

        results
    }

    fn topological_sort(&self) -> Vec<&BuildTarget> {
        // Simple topological sort
        let mut result = Vec::new();
        let mut visited = HashSet::new();

        for target in &self.targets {
            self.visit_target(target, &mut visited, &mut result);
        }

        result
    }

    fn visit_target<'a>(
        &'a self,
        target: &'a BuildTarget,
        visited: &mut HashSet<String>,
        result: &mut Vec<&'a BuildTarget>,
    ) {
        if visited.contains(&target.name) {
            return;
        }

        visited.insert(target.name.clone());

        for dep in &target.dependencies {
            if let Some(dep_target) = self.targets.iter().find(|t| &t.name == dep) {
                self.visit_target(dep_target, visited, result);
            }
        }

        result.push(target);
    }

    fn needs_rebuild(&self, target: &BuildTarget) -> bool {
        let output_path = self.get_output_path(target);

        // Check if source is newer than output using the cache
        self.cache.needs_rebuild(&target.src_path, &output_path)
    }

    fn build_target(&self, target: &BuildTarget) -> BuildResult {
        let start = Instant::now();
        let output_path = self.get_output_path(target);
        let mut warnings = Vec::new();
        let mut errors = Vec::new();

        // Ensure target directory exists
        if let Err(e) = fs::create_dir_all(&self.target_dir) {
            return BuildResult {
                success: false,
                target: target.name.clone(),
                duration: start.elapsed(),
                artifacts: Vec::new(),
                warnings: Vec::new(),
                errors: vec![format!("Failed to create target directory: {}", e)],
            };
        }

        // Build dependency paths
        let mut dep_paths = Vec::new();
        for dep_name in &target.dependencies {
            if let Some(dep_target) = self.targets.iter().find(|t| &t.name == dep_name) {
                let dep_output = self.get_output_path(dep_target);
                if let Some(parent) = dep_output.parent() {
                    dep_paths.push(parent.to_path_buf());
                }
            }
        }

        // Create compilation unit
        let unit = CompilationUnit {
            source_path: target.src_path.clone(),
            output_path: output_path.clone(),
            dependencies: dep_paths,
        };

        // Invoke the compiler
        match self.compiler.compile(&unit) {
            Ok(diagnostics) => {
                let has_errors = diagnostics.iter().any(|d| d.level == DiagnosticLevel::Error);

                for diag in &diagnostics {
                    let msg = if let Some(ref file) = diag.file {
                        if let (Some(line), Some(col)) = (diag.line, diag.column) {
                            format!("{}:{}:{}: {}", file.display(), line, col, diag.message)
                        } else {
                            format!("{}: {}", file.display(), diag.message)
                        }
                    } else {
                        diag.message.clone()
                    };

                    match diag.level {
                        DiagnosticLevel::Error => errors.push(msg),
                        DiagnosticLevel::Warning => warnings.push(msg),
                        _ => {}
                    }
                }

                if has_errors {
                    return BuildResult {
                        success: false,
                        target: target.name.clone(),
                        duration: start.elapsed(),
                        artifacts: Vec::new(),
                        warnings,
                        errors,
                    };
                }

                // Update cache on success
                let hash = BuildCache::hash_file(&target.src_path);
                // Note: cache is not mut here, would need RefCell in real impl
                // self.cache.update(&target.src_path, &output_path, hash);

                BuildResult {
                    success: true,
                    target: target.name.clone(),
                    duration: start.elapsed(),
                    artifacts: vec![output_path],
                    warnings,
                    errors,
                }
            }
            Err(e) => {
                BuildResult {
                    success: false,
                    target: target.name.clone(),
                    duration: start.elapsed(),
                    artifacts: Vec::new(),
                    warnings,
                    errors: vec![e],
                }
            }
        }
    }

    /// Get output path for a target
    fn get_output_path(&self, target: &BuildTarget) -> PathBuf {
        let base_name = target.src_path
            .file_stem()
            .map(|s| s.to_string_lossy().to_string())
            .unwrap_or_else(|| target.name.clone());

        match target.kind {
            TargetKind::Library => {
                // Libraries produce .qlib files
                self.target_dir.join(format!("lib{}.qlib", base_name))
            }
            TargetKind::Binary | TargetKind::Example => {
                // Binaries produce executables
                #[cfg(windows)]
                let exe_name = format!("{}.exe", base_name);
                #[cfg(not(windows))]
                let exe_name = base_name.clone();
                self.target_dir.join(exe_name)
            }
            TargetKind::Test | TargetKind::Benchmark => {
                // Tests/benchmarks produce executables in deps directory
                #[cfg(windows)]
                let exe_name = format!("{}.exe", base_name);
                #[cfg(not(windows))]
                let exe_name = base_name.clone();
                self.target_dir.join("deps").join(exe_name)
            }
        }
    }

    /// Collect all source files for a target (for multi-file targets)
    fn collect_sources(&self, target: &BuildTarget) -> Vec<PathBuf> {
        let mut sources = vec![target.src_path.clone()];

        // If this is a library or binary, look for additional modules
        if let Some(src_dir) = target.src_path.parent() {
            if let Ok(entries) = fs::read_dir(src_dir) {
                for entry in entries.flatten() {
                    let path = entry.path();
                    if path.is_file() && path != target.src_path {
                        if let Some(ext) = path.extension() {
                            if ext == "quanta" {
                                sources.push(path);
                            }
                        }
                    }
                }
            }
        }

        sources
    }
}

// =============================================================================
// CODE GENERATOR
// =============================================================================

/// Code generator for boilerplate
pub struct CodeGenerator {
    output_dir: PathBuf,
    templates: HashMap<String, String>,
}

impl CodeGenerator {
    pub fn new(output_dir: PathBuf) -> Self {
        CodeGenerator {
            output_dir,
            templates: HashMap::new(),
        }
    }

    pub fn register_template(&mut self, name: &str, content: &str) {
        self.templates.insert(name.to_string(), content.to_string());
    }

    /// Generate a struct with builder pattern
    pub fn generate_struct(&self, name: &str, fields: &[(&str, &str)]) -> String {
        let mut code = String::new();

        // Struct definition
        code.push_str(&format!("pub struct {} {{\n", name));
        for (field_name, field_type) in fields {
            code.push_str(&format!("    pub {}: {},\n", field_name, field_type));
        }
        code.push_str("}\n\n");

        // Builder
        code.push_str(&format!("pub struct {}Builder {{\n", name));
        for (field_name, field_type) in fields {
            code.push_str(&format!("    {}: Option<{}>,\n", field_name, field_type));
        }
        code.push_str("}\n\n");

        // Builder impl
        code.push_str(&format!("impl {}Builder {{\n", name));
        code.push_str("    pub fn new() -> Self {\n");
        code.push_str(&format!("        {}Builder {{\n", name));
        for (field_name, _) in fields {
            code.push_str(&format!("            {}: None,\n", field_name));
        }
        code.push_str("        }\n");
        code.push_str("    }\n\n");

        for (field_name, field_type) in fields {
            code.push_str(&format!("    pub fn {}(mut self, value: {}) -> Self {{\n", field_name, field_type));
            code.push_str(&format!("        self.{} = Some(value);\n", field_name));
            code.push_str("        self\n");
            code.push_str("    }\n\n");
        }

        code.push_str(&format!("    pub fn build(self) -> Result<{}, String> {{\n", name));
        code.push_str(&format!("        Ok({} {{\n", name));
        for (field_name, _) in fields {
            code.push_str(&format!("            {}: self.{}.ok_or(\"{} is required\".to_string())?,\n",
                field_name, field_name, field_name));
        }
        code.push_str("        })\n");
        code.push_str("    }\n");
        code.push_str("}\n");

        code
    }

    /// Generate enum with display and from_str
    pub fn generate_enum(&self, name: &str, variants: &[&str]) -> String {
        let mut code = String::new();

        // Enum definition
        code.push_str("#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n");
        code.push_str(&format!("pub enum {} {{\n", name));
        for variant in variants {
            code.push_str(&format!("    {},\n", variant));
        }
        code.push_str("}\n\n");

        // Display impl
        code.push_str(&format!("impl std::fmt::Display for {} {{\n", name));
        code.push_str("    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n");
        code.push_str("        match self {\n");
        for variant in variants {
            code.push_str(&format!("            {}::{} => write!(f, \"{}\"),\n", name, variant, variant.to_lowercase()));
        }
        code.push_str("        }\n");
        code.push_str("    }\n");
        code.push_str("}\n\n");

        // FromStr impl
        code.push_str(&format!("impl std::str::FromStr for {} {{\n", name));
        code.push_str("    type Err = String;\n\n");
        code.push_str("    fn from_str(s: &str) -> Result<Self, Self::Err> {\n");
        code.push_str("        match s.to_lowercase().as_str() {\n");
        for variant in variants {
            code.push_str(&format!("            \"{}\" => Ok({}::{}),\n",
                variant.to_lowercase(), name, variant));
        }
        code.push_str(&format!("            _ => Err(format!(\"Unknown {}: {{}}\", s)),\n", name));
        code.push_str("        }\n");
        code.push_str("    }\n");
        code.push_str("}\n");

        code
    }

    /// Generate a trait with default implementations
    pub fn generate_trait(&self, name: &str, methods: &[(&str, &str, &str)]) -> String {
        let mut code = String::new();

        code.push_str(&format!("pub trait {} {{\n", name));
        for (method_name, params, return_type) in methods {
            code.push_str(&format!("    fn {}({}) -> {};\n", method_name, params, return_type));
        }
        code.push_str("}\n");

        code
    }
}

// =============================================================================
// ENVIRONMENT MANAGER
// =============================================================================

/// Environment variable source
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum EnvSource {
    System,
    File,
    Override,
}

/// Environment variable
#[derive(Debug, Clone)]
pub struct EnvVar {
    pub key: String,
    pub value: String,
    pub source: EnvSource,
}

/// Environment manager
pub struct EnvManager {
    variables: HashMap<String, EnvVar>,
    env_file: Option<PathBuf>,
}

impl EnvManager {
    pub fn new() -> Self {
        EnvManager {
            variables: HashMap::new(),
            env_file: None,
        }
    }

    /// Load from .env file
    pub fn load_file(&mut self, path: &Path) -> Result<(), String> {
        let content = fs::read_to_string(path)
            .map_err(|e| format!("Failed to read env file: {}", e))?;

        for line in content.lines() {
            let line = line.trim();
            if line.is_empty() || line.starts_with('#') {
                continue;
            }

            if let Some((key, value)) = line.split_once('=') {
                let key = key.trim().to_string();
                let value = value.trim().trim_matches('"').to_string();

                self.variables.insert(key.clone(), EnvVar {
                    key,
                    value,
                    source: EnvSource::File,
                });
            }
        }

        self.env_file = Some(path.to_path_buf());
        Ok(())
    }

    /// Load from system environment
    pub fn load_system(&mut self) {
        for (key, value) in std::env::vars() {
            if !self.variables.contains_key(&key) {
                self.variables.insert(key.clone(), EnvVar {
                    key,
                    value,
                    source: EnvSource::System,
                });
            }
        }
    }

    /// Get a variable
    pub fn get(&self, key: &str) -> Option<&str> {
        self.variables.get(key).map(|v| v.value.as_str())
    }

    /// Set a variable
    pub fn set(&mut self, key: &str, value: &str) {
        self.variables.insert(key.to_string(), EnvVar {
            key: key.to_string(),
            value: value.to_string(),
            source: EnvSource::Override,
        });
    }

    /// Export to system environment
    pub fn export(&self) {
        for var in self.variables.values() {
            std::env::set_var(&var.key, &var.value);
        }
    }

    /// List all variables
    pub fn list(&self) -> Vec<&EnvVar> {
        self.variables.values().collect()
    }
}

// =============================================================================
// SCRIPT RUNNER
// =============================================================================

/// Script definition
#[derive(Debug, Clone)]
pub struct Script {
    pub name: String,
    pub commands: Vec<String>,
    pub env: HashMap<String, String>,
    pub working_dir: Option<PathBuf>,
}

/// Script runner
pub struct ScriptRunner {
    scripts: HashMap<String, Script>,
    default_shell: String,
}

impl ScriptRunner {
    pub fn new() -> Self {
        let default_shell = if cfg!(windows) {
            "cmd /c".to_string()
        } else {
            "sh -c".to_string()
        };

        ScriptRunner {
            scripts: HashMap::new(),
            default_shell,
        }
    }

    /// Register a script
    pub fn register(&mut self, script: Script) {
        self.scripts.insert(script.name.clone(), script);
    }

    /// Run a script
    pub fn run(&self, name: &str) -> Result<i32, String> {
        let script = self.scripts.get(name)
            .ok_or_else(|| format!("Script not found: {}", name))?;

        log_info(&format!("Running script: {}", name));

        for command in &script.commands {
            let status = self.run_command(command, &script.env, script.working_dir.as_ref())?;
            if status != 0 {
                return Ok(status);
            }
        }

        Ok(0)
    }

    fn run_command(
        &self,
        command: &str,
        env: &HashMap<String, String>,
        working_dir: Option<&PathBuf>,
    ) -> Result<i32, String> {
        log_debug(&format!("  $ {}", command));

        let parts: Vec<&str> = self.default_shell.split_whitespace().collect();
        let program = parts[0];
        let shell_args: Vec<&str> = parts[1..].to_vec();

        let mut cmd = Command::new(program);
        cmd.args(&shell_args)
           .arg(command)
           .envs(env);

        if let Some(dir) = working_dir {
            cmd.current_dir(dir);
        }

        let status = cmd.status()
            .map_err(|e| format!("Failed to run command: {}", e))?;

        Ok(status.code().unwrap_or(-1))
    }

    /// List all scripts
    pub fn list(&self) -> Vec<&str> {
        self.scripts.keys().map(|s| s.as_str()).collect()
    }
}

// =============================================================================
// PLUGIN SYSTEM
// =============================================================================

/// Plugin metadata
#[derive(Debug, Clone)]
pub struct PluginMetadata {
    pub name: String,
    pub version: String,
    pub description: String,
    pub author: String,
    pub entry_point: PathBuf,
}

/// Plugin manager
pub struct PluginManager {
    plugins: HashMap<String, PluginMetadata>,
    plugin_dir: PathBuf,
}

impl PluginManager {
    pub fn new(plugin_dir: PathBuf) -> Self {
        PluginManager {
            plugins: HashMap::new(),
            plugin_dir,
        }
    }

    /// Discover plugins in the plugin directory
    pub fn discover(&mut self) -> Result<usize, String> {
        if !self.plugin_dir.exists() {
            return Ok(0);
        }

        let mut count = 0;
        for entry in fs::read_dir(&self.plugin_dir).map_err(|e| e.to_string())? {
            let entry = entry.map_err(|e| e.to_string())?;
            let path = entry.path();

            if path.is_dir() {
                if let Some(metadata) = self.load_plugin_metadata(&path) {
                    self.plugins.insert(metadata.name.clone(), metadata);
                    count += 1;
                }
            }
        }

        Ok(count)
    }

    fn load_plugin_metadata(&self, path: &Path) -> Option<PluginMetadata> {
        let manifest_path = path.join("plugin.toml");
        if !manifest_path.exists() {
            return None;
        }

        // Parse plugin.toml (simplified)
        let content = fs::read_to_string(&manifest_path).ok()?;
        let mut name = String::new();
        let mut version = String::new();
        let mut description = String::new();
        let mut author = String::new();

        for line in content.lines() {
            if let Some((key, value)) = line.split_once('=') {
                let key = key.trim();
                let value = value.trim().trim_matches('"');

                match key {
                    "name" => name = value.to_string(),
                    "version" => version = value.to_string(),
                    "description" => description = value.to_string(),
                    "author" => author = value.to_string(),
                    _ => {}
                }
            }
        }

        Some(PluginMetadata {
            name,
            version,
            description,
            author,
            entry_point: path.join("lib.quanta"),
        })
    }

    /// Get plugin by name
    pub fn get(&self, name: &str) -> Option<&PluginMetadata> {
        self.plugins.get(name)
    }

    /// List all plugins
    pub fn list(&self) -> Vec<&PluginMetadata> {
        self.plugins.values().collect()
    }
}

// =============================================================================
// DOCUMENTATION GENERATOR
// =============================================================================

/// Documentation item type
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DocItemKind {
    Module,
    Struct,
    Enum,
    Trait,
    Function,
    Constant,
    Type,
    Macro,
}

impl DocItemKind {
    pub fn as_str(&self) -> &'static str {
        match self {
            DocItemKind::Module => "Module",
            DocItemKind::Struct => "Struct",
            DocItemKind::Enum => "Enum",
            DocItemKind::Trait => "Trait",
            DocItemKind::Function => "Function",
            DocItemKind::Constant => "Constant",
            DocItemKind::Type => "Type Alias",
            DocItemKind::Macro => "Macro",
        }
    }
}

/// Documentation item
#[derive(Debug, Clone)]
pub struct DocItem {
    pub name: String,
    pub kind: DocItemKind,
    pub visibility: Visibility,
    pub doc_comment: String,
    pub signature: String,
    pub source_file: PathBuf,
    pub line_number: usize,
    pub children: Vec<DocItem>,
    pub attributes: Vec<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Visibility {
    Public,
    Private,
    Crate,
}

impl Visibility {
    pub fn as_str(&self) -> &'static str {
        match self {
            Visibility::Public => "pub",
            Visibility::Private => "priv",
            Visibility::Crate => "pub(crate)",
        }
    }
}

/// Documentation output format
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DocFormat {
    Html,
    Markdown,
    Json,
}

/// Documentation generator configuration
#[derive(Debug, Clone)]
pub struct DocConfig {
    pub output_dir: PathBuf,
    pub format: DocFormat,
    pub include_private: bool,
    pub include_source: bool,
    pub project_name: String,
    pub project_version: String,
    pub css_theme: String,
}

impl Default for DocConfig {
    fn default() -> Self {
        DocConfig {
            output_dir: PathBuf::from("target/doc"),
            format: DocFormat::Html,
            include_private: false,
            include_source: true,
            project_name: "Project".to_string(),
            project_version: "0.1.0".to_string(),
            css_theme: "default".to_string(),
        }
    }
}

/// Documentation generator
pub struct DocGenerator {
    config: DocConfig,
    items: Vec<DocItem>,
}

impl DocGenerator {
    pub fn new(config: DocConfig) -> Self {
        DocGenerator {
            config,
            items: Vec::new(),
        }
    }

    /// Parse documentation from source files
    pub fn parse_sources(&mut self, source_dir: &Path) -> Result<(), String> {
        self.parse_directory(source_dir)
    }

    fn parse_directory(&mut self, dir: &Path) -> Result<(), String> {
        if !dir.exists() {
            return Ok(());
        }

        let entries = fs::read_dir(dir)
            .map_err(|e| format!("Failed to read directory: {}", e))?;

        for entry in entries.flatten() {
            let path = entry.path();
            if path.is_dir() {
                self.parse_directory(&path)?;
            } else if path.is_file() {
                if let Some(ext) = path.extension() {
                    if ext == "quanta" {
                        self.parse_file(&path)?;
                    }
                }
            }
        }

        Ok(())
    }

    fn parse_file(&mut self, path: &Path) -> Result<(), String> {
        let content = fs::read_to_string(path)
            .map_err(|e| format!("Failed to read file: {}", e))?;

        let mut current_doc_comment = String::new();
        let mut line_number = 0;

        for line in content.lines() {
            line_number += 1;
            let trimmed = line.trim();

            // Collect doc comments
            if trimmed.starts_with("///") {
                let doc_line = trimmed.strip_prefix("///").unwrap_or("").trim();
                if !current_doc_comment.is_empty() {
                    current_doc_comment.push('\n');
                }
                current_doc_comment.push_str(doc_line);
                continue;
            }

            // Block doc comments
            if trimmed.starts_with("/**") {
                // Start of block doc comment - simplified parsing
                current_doc_comment = trimmed
                    .strip_prefix("/**")
                    .unwrap_or("")
                    .strip_suffix("*/")
                    .unwrap_or(trimmed.strip_prefix("/**").unwrap_or(""))
                    .trim()
                    .to_string();
                continue;
            }

            // Skip empty lines (preserve doc comment)
            if trimmed.is_empty() {
                continue;
            }

            // Parse item declarations
            let visibility = if trimmed.starts_with("pub(crate)") {
                Visibility::Crate
            } else if trimmed.starts_with("pub") {
                Visibility::Public
            } else {
                Visibility::Private
            };

            // Skip private items if not included
            if !self.config.include_private && visibility == Visibility::Private {
                current_doc_comment.clear();
                continue;
            }

            // Parse different item types
            if let Some(item) = self.parse_item(trimmed, visibility, &current_doc_comment, path, line_number) {
                self.items.push(item);
            }

            // Clear doc comment after consuming
            current_doc_comment.clear();
        }

        Ok(())
    }

    fn parse_item(
        &self,
        line: &str,
        visibility: Visibility,
        doc_comment: &str,
        source_file: &Path,
        line_number: usize,
    ) -> Option<DocItem> {
        let line_after_vis = if line.starts_with("pub(crate)") {
            line.strip_prefix("pub(crate)")?.trim()
        } else if line.starts_with("pub") {
            line.strip_prefix("pub")?.trim()
        } else {
            line
        };

        // Function
        if line_after_vis.starts_with("fn ") || line_after_vis.starts_with("async fn ") {
            let is_async = line_after_vis.starts_with("async");
            let fn_part = if is_async {
                line_after_vis.strip_prefix("async fn ")?.trim()
            } else {
                line_after_vis.strip_prefix("fn ")?.trim()
            };

            let name_end = fn_part.find('(').unwrap_or(fn_part.len());
            let name = fn_part[..name_end].trim().to_string();

            // Extract full signature up to opening brace
            let sig_end = line.find('{').unwrap_or(line.len());
            let signature = line[..sig_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Function,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature,
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        // Struct
        if line_after_vis.starts_with("struct ") {
            let struct_part = line_after_vis.strip_prefix("struct ")?.trim();
            let name_end = struct_part.find(|c: char| c == '{' || c == '(' || c == '<' || c.is_whitespace())
                .unwrap_or(struct_part.len());
            let name = struct_part[..name_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Struct,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature: line.trim().to_string(),
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        // Enum
        if line_after_vis.starts_with("enum ") {
            let enum_part = line_after_vis.strip_prefix("enum ")?.trim();
            let name_end = enum_part.find(|c: char| c == '{' || c == '<' || c.is_whitespace())
                .unwrap_or(enum_part.len());
            let name = enum_part[..name_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Enum,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature: line.trim().to_string(),
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        // Trait
        if line_after_vis.starts_with("trait ") {
            let trait_part = line_after_vis.strip_prefix("trait ")?.trim();
            let name_end = trait_part.find(|c: char| c == '{' || c == ':' || c == '<' || c.is_whitespace())
                .unwrap_or(trait_part.len());
            let name = trait_part[..name_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Trait,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature: line.trim().to_string(),
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        // Constant
        if line_after_vis.starts_with("const ") {
            let const_part = line_after_vis.strip_prefix("const ")?.trim();
            let name_end = const_part.find(':').unwrap_or(const_part.len());
            let name = const_part[..name_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Constant,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature: line.trim().to_string(),
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        // Type alias
        if line_after_vis.starts_with("type ") {
            let type_part = line_after_vis.strip_prefix("type ")?.trim();
            let name_end = type_part.find(|c: char| c == '=' || c == '<' || c.is_whitespace())
                .unwrap_or(type_part.len());
            let name = type_part[..name_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Type,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature: line.trim().to_string(),
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        // Module
        if line_after_vis.starts_with("mod ") || line_after_vis.starts_with("module ") {
            let mod_prefix = if line_after_vis.starts_with("module ") { "module " } else { "mod " };
            let mod_part = line_after_vis.strip_prefix(mod_prefix)?.trim();
            let name_end = mod_part.find(|c: char| c == '{' || c == ';' || c.is_whitespace())
                .unwrap_or(mod_part.len());
            let name = mod_part[..name_end].trim().to_string();

            return Some(DocItem {
                name,
                kind: DocItemKind::Module,
                visibility,
                doc_comment: doc_comment.to_string(),
                signature: line.trim().to_string(),
                source_file: source_file.to_path_buf(),
                line_number,
                children: Vec::new(),
                attributes: Vec::new(),
            });
        }

        None
    }

    /// Generate documentation
    pub fn generate(&self) -> Result<(), String> {
        fs::create_dir_all(&self.config.output_dir)
            .map_err(|e| format!("Failed to create output directory: {}", e))?;

        match self.config.format {
            DocFormat::Html => self.generate_html(),
            DocFormat::Markdown => self.generate_markdown(),
            DocFormat::Json => self.generate_json(),
        }
    }

    fn generate_html(&self) -> Result<(), String> {
        // Generate index.html
        let mut index = String::new();
        index.push_str("<!DOCTYPE html>\n<html>\n<head>\n");
        index.push_str(&format!("<title>{} Documentation</title>\n", self.config.project_name));
        index.push_str("<style>\n");
        index.push_str(self.get_css_theme());
        index.push_str("\n</style>\n</head>\n<body>\n");
        index.push_str(&format!("<h1>{} {}</h1>\n", self.config.project_name, self.config.project_version));
        index.push_str("<nav>\n<h2>Modules</h2>\n<ul>\n");

        // Group items by kind
        let modules: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Module).collect();
        let structs: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Struct).collect();
        let enums: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Enum).collect();
        let traits: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Trait).collect();
        let functions: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Function).collect();

        for module in &modules {
            index.push_str(&format!("<li><a href=\"{}.html\">{}</a></li>\n", module.name, module.name));
        }
        index.push_str("</ul>\n");

        if !structs.is_empty() {
            index.push_str("<h2>Structs</h2>\n<ul>\n");
            for s in &structs {
                index.push_str(&format!("<li><a href=\"struct.{}.html\">{}</a></li>\n", s.name, s.name));
            }
            index.push_str("</ul>\n");
        }

        if !enums.is_empty() {
            index.push_str("<h2>Enums</h2>\n<ul>\n");
            for e in &enums {
                index.push_str(&format!("<li><a href=\"enum.{}.html\">{}</a></li>\n", e.name, e.name));
            }
            index.push_str("</ul>\n");
        }

        if !traits.is_empty() {
            index.push_str("<h2>Traits</h2>\n<ul>\n");
            for t in &traits {
                index.push_str(&format!("<li><a href=\"trait.{}.html\">{}</a></li>\n", t.name, t.name));
            }
            index.push_str("</ul>\n");
        }

        if !functions.is_empty() {
            index.push_str("<h2>Functions</h2>\n<ul>\n");
            for f in &functions {
                index.push_str(&format!("<li><a href=\"#fn.{}\">{}</a></li>\n", f.name, f.name));
            }
            index.push_str("</ul>\n");
        }

        index.push_str("</nav>\n<main>\n");

        // Generate function documentation on index page
        for func in &functions {
            index.push_str(&format!("<section id=\"fn.{}\">\n", func.name));
            index.push_str(&format!("<h3>{}</h3>\n", func.kind.as_str()));
            index.push_str(&format!("<pre class=\"signature\">{}</pre>\n", self.escape_html(&func.signature)));
            if !func.doc_comment.is_empty() {
                index.push_str(&format!("<div class=\"doc\">{}</div>\n", self.markdown_to_html(&func.doc_comment)));
            }
            if self.config.include_source {
                index.push_str(&format!("<div class=\"source\">Defined in <code>{}:{}</code></div>\n",
                    func.source_file.display(), func.line_number));
            }
            index.push_str("</section>\n");
        }

        index.push_str("</main>\n</body>\n</html>");

        fs::write(self.config.output_dir.join("index.html"), index)
            .map_err(|e| format!("Failed to write index.html: {}", e))?;

        // Generate individual pages for structs, enums, traits
        for item in &structs {
            self.generate_item_page(item, "struct")?;
        }
        for item in &enums {
            self.generate_item_page(item, "enum")?;
        }
        for item in &traits {
            self.generate_item_page(item, "trait")?;
        }

        log_info(&format!("Generated documentation in {}", self.config.output_dir.display()));
        Ok(())
    }

    fn generate_item_page(&self, item: &DocItem, prefix: &str) -> Result<(), String> {
        let mut html = String::new();
        html.push_str("<!DOCTYPE html>\n<html>\n<head>\n");
        html.push_str(&format!("<title>{} {} - {} Documentation</title>\n",
            item.kind.as_str(), item.name, self.config.project_name));
        html.push_str("<style>\n");
        html.push_str(self.get_css_theme());
        html.push_str("\n</style>\n</head>\n<body>\n");
        html.push_str(&format!("<h1>{} {}</h1>\n", item.kind.as_str(), item.name));
        html.push_str(&format!("<pre class=\"signature\">{}</pre>\n", self.escape_html(&item.signature)));

        if !item.doc_comment.is_empty() {
            html.push_str("<div class=\"doc\">\n");
            html.push_str(&self.markdown_to_html(&item.doc_comment));
            html.push_str("\n</div>\n");
        }

        if self.config.include_source {
            html.push_str(&format!("<div class=\"source\">Defined in <code>{}:{}</code></div>\n",
                item.source_file.display(), item.line_number));
        }

        html.push_str("<p><a href=\"index.html\">Back to index</a></p>\n");
        html.push_str("</body>\n</html>");

        let filename = format!("{}.{}.html", prefix, item.name);
        fs::write(self.config.output_dir.join(filename), html)
            .map_err(|e| format!("Failed to write item page: {}", e))?;

        Ok(())
    }

    fn generate_markdown(&self) -> Result<(), String> {
        let mut content = String::new();
        content.push_str(&format!("# {} {} Documentation\n\n", self.config.project_name, self.config.project_version));

        // Table of contents
        content.push_str("## Table of Contents\n\n");

        let structs: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Struct).collect();
        let enums: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Enum).collect();
        let traits: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Trait).collect();
        let functions: Vec<_> = self.items.iter().filter(|i| i.kind == DocItemKind::Function).collect();

        if !structs.is_empty() {
            content.push_str("- [Structs](#structs)\n");
        }
        if !enums.is_empty() {
            content.push_str("- [Enums](#enums)\n");
        }
        if !traits.is_empty() {
            content.push_str("- [Traits](#traits)\n");
        }
        if !functions.is_empty() {
            content.push_str("- [Functions](#functions)\n");
        }
        content.push_str("\n");

        // Structs
        if !structs.is_empty() {
            content.push_str("## Structs\n\n");
            for s in &structs {
                content.push_str(&format!("### {}\n\n", s.name));
                content.push_str(&format!("```quanta\n{}\n```\n\n", s.signature));
                if !s.doc_comment.is_empty() {
                    content.push_str(&format!("{}\n\n", s.doc_comment));
                }
            }
        }

        // Enums
        if !enums.is_empty() {
            content.push_str("## Enums\n\n");
            for e in &enums {
                content.push_str(&format!("### {}\n\n", e.name));
                content.push_str(&format!("```quanta\n{}\n```\n\n", e.signature));
                if !e.doc_comment.is_empty() {
                    content.push_str(&format!("{}\n\n", e.doc_comment));
                }
            }
        }

        // Traits
        if !traits.is_empty() {
            content.push_str("## Traits\n\n");
            for t in &traits {
                content.push_str(&format!("### {}\n\n", t.name));
                content.push_str(&format!("```quanta\n{}\n```\n\n", t.signature));
                if !t.doc_comment.is_empty() {
                    content.push_str(&format!("{}\n\n", t.doc_comment));
                }
            }
        }

        // Functions
        if !functions.is_empty() {
            content.push_str("## Functions\n\n");
            for f in &functions {
                content.push_str(&format!("### {}\n\n", f.name));
                content.push_str(&format!("```quanta\n{}\n```\n\n", f.signature));
                if !f.doc_comment.is_empty() {
                    content.push_str(&format!("{}\n\n", f.doc_comment));
                }
            }
        }

        fs::write(self.config.output_dir.join("README.md"), content)
            .map_err(|e| format!("Failed to write documentation: {}", e))?;

        log_info(&format!("Generated Markdown documentation in {}", self.config.output_dir.display()));
        Ok(())
    }

    fn generate_json(&self) -> Result<(), String> {
        let mut json = String::new();
        json.push_str("{\n");
        json.push_str(&format!("  \"project\": \"{}\",\n", self.config.project_name));
        json.push_str(&format!("  \"version\": \"{}\",\n", self.config.project_version));
        json.push_str("  \"items\": [\n");

        for (i, item) in self.items.iter().enumerate() {
            json.push_str("    {\n");
            json.push_str(&format!("      \"name\": \"{}\",\n", item.name));
            json.push_str(&format!("      \"kind\": \"{}\",\n", item.kind.as_str()));
            json.push_str(&format!("      \"visibility\": \"{}\",\n", item.visibility.as_str()));
            json.push_str(&format!("      \"signature\": \"{}\",\n", self.escape_json(&item.signature)));
            json.push_str(&format!("      \"doc\": \"{}\",\n", self.escape_json(&item.doc_comment)));
            json.push_str(&format!("      \"file\": \"{}\",\n", item.source_file.display()));
            json.push_str(&format!("      \"line\": {}\n", item.line_number));
            if i < self.items.len() - 1 {
                json.push_str("    },\n");
            } else {
                json.push_str("    }\n");
            }
        }

        json.push_str("  ]\n");
        json.push_str("}\n");

        fs::write(self.config.output_dir.join("doc.json"), json)
            .map_err(|e| format!("Failed to write JSON documentation: {}", e))?;

        log_info(&format!("Generated JSON documentation in {}", self.config.output_dir.display()));
        Ok(())
    }

    fn escape_html(&self, s: &str) -> String {
        s.replace('&', "&amp;")
         .replace('<', "&lt;")
         .replace('>', "&gt;")
         .replace('"', "&quot;")
    }

    fn escape_json(&self, s: &str) -> String {
        s.replace('\\', "\\\\")
         .replace('"', "\\\"")
         .replace('\n', "\\n")
         .replace('\r', "\\r")
         .replace('\t', "\\t")
    }

    fn markdown_to_html(&self, md: &str) -> String {
        // Simple markdown conversion
        let mut html = String::new();

        for line in md.lines() {
            let line = line.trim();

            // Headers
            if line.starts_with("# ") {
                html.push_str(&format!("<h1>{}</h1>\n", &line[2..]));
            } else if line.starts_with("## ") {
                html.push_str(&format!("<h2>{}</h2>\n", &line[3..]));
            } else if line.starts_with("### ") {
                html.push_str(&format!("<h3>{}</h3>\n", &line[4..]));
            }
            // Code blocks
            else if line.starts_with("```") {
                html.push_str("<pre><code>");
            }
            // List items
            else if line.starts_with("- ") || line.starts_with("* ") {
                html.push_str(&format!("<li>{}</li>\n", &line[2..]));
            }
            // Inline code
            else if line.contains('`') {
                let converted = line
                    .split('`')
                    .enumerate()
                    .map(|(i, part)| {
                        if i % 2 == 1 {
                            format!("<code>{}</code>", part)
                        } else {
                            part.to_string()
                        }
                    })
                    .collect::<String>();
                html.push_str(&format!("<p>{}</p>\n", converted));
            }
            // Regular paragraph
            else if !line.is_empty() {
                html.push_str(&format!("<p>{}</p>\n", line));
            }
        }

        html
    }

    fn get_css_theme(&self) -> &'static str {
        r#"
body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
    background: #fafafa;
    color: #333;
}
h1, h2, h3 { color: #2c3e50; }
nav { background: #fff; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
nav ul { list-style: none; padding: 0; }
nav a { color: #3498db; text-decoration: none; }
nav a:hover { text-decoration: underline; }
main { background: #fff; padding: 20px; border-radius: 8px; }
.signature {
    background: #2c3e50;
    color: #ecf0f1;
    padding: 15px;
    border-radius: 4px;
    overflow-x: auto;
    font-family: 'Monaco', 'Menlo', monospace;
}
.doc { margin: 15px 0; }
.source { color: #7f8c8d; font-size: 0.9em; }
section { margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #eee; }
code { background: #f4f4f4; padding: 2px 6px; border-radius: 3px; }
pre code { background: none; padding: 0; }
"#
    }
}

// =============================================================================
// UTILITY FUNCTIONS
// =============================================================================

/// Get number of CPUs
fn num_cpus() -> usize {
    // Simplified - would use actual detection
    std::thread::available_parallelism()
        .map(|p| p.get())
        .unwrap_or(4)
}

// =============================================================================
// FORGE CLI APPLICATION
// =============================================================================

/// Create the Forge CLI application
pub fn create_forge_cli() -> CLI {
    let mut cli = CLI::new("forge", "1.0.0", "The QuantaLang Developer Toolkit");

    // new - Create new project
    cli.register(CommandDef {
        name: "new".to_string(),
        description: "Create a new project".to_string(),
        usage: "<name> [--template <template>]".to_string(),
        options: vec![
            OptionDef {
                short: Some('t'),
                long: "template".to_string(),
                description: "Project template (lib, bin, web, cli, plugin)".to_string(),
                takes_value: true,
                required: false,
                default: Some("bin".to_string()),
            },
        ],
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let name = ctx.get_arg(1).ok_or("Project name required")?;
            let template = ctx.get_option("template")
                .map(|s| s.as_str())
                .unwrap_or("bin");

            let template = match template {
                "lib" | "library" => ProjectTemplate::Library,
                "web" | "webservice" => ProjectTemplate::WebService,
                "cli" => ProjectTemplate::CLI,
                "plugin" => ProjectTemplate::Plugin,
                "workspace" => ProjectTemplate::Workspace,
                _ => ProjectTemplate::Binary,
            };

            let generator = ProjectGenerator::new(name, template);
            generator.generate()?;

            Ok(0)
        })),
    });

    // build - Build the project
    cli.register(CommandDef {
        name: "build".to_string(),
        description: "Build the project".to_string(),
        usage: "[--release] [--jobs <n>]".to_string(),
        options: vec![
            OptionDef {
                short: Some('r'),
                long: "release".to_string(),
                description: "Build with optimizations".to_string(),
                takes_value: false,
                required: false,
                default: None,
            },
            OptionDef {
                short: Some('j'),
                long: "jobs".to_string(),
                description: "Number of parallel jobs".to_string(),
                takes_value: true,
                required: false,
                default: None,
            },
        ],
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let profile = if ctx.has_flag("release") {
                BuildProfile::Release
            } else {
                BuildProfile::Debug
            };

            let project_root = std::env::current_dir()
                .map_err(|e| format!("Failed to get current directory: {}", e))?;

            let mut orchestrator = BuildOrchestrator::with_root(profile, project_root);

            // Check for quark.toml
            if Path::new("quark.toml").exists() {
                orchestrator.load_manifest()?;
            } else {
                // Auto-detect targets if no manifest
                if Path::new("src/lib.quanta").exists() {
                    orchestrator.add_target(BuildTarget {
                        name: "lib".to_string(),
                        kind: TargetKind::Library,
                        src_path: PathBuf::from("src/lib.quanta"),
                        dependencies: Vec::new(),
                    });
                }
                if Path::new("src/main.quanta").exists() {
                    orchestrator.add_target(BuildTarget {
                        name: "main".to_string(),
                        kind: TargetKind::Binary,
                        src_path: PathBuf::from("src/main.quanta"),
                        dependencies: Vec::new(),
                    });
                }
            }

            if let Some(jobs) = ctx.get_option("jobs") {
                if let Ok(n) = jobs.parse::<usize>() {
                    orchestrator = orchestrator.parallel_jobs(n);
                }
            }

            let orchestrator = orchestrator.verbose(ctx.has_flag("verbose"));

            let results = orchestrator.build();
            let failed = results.iter().any(|r| !r.success);

            // Print summary
            let success_count = results.iter().filter(|r| r.success).count();
            let fail_count = results.len() - success_count;

            if fail_count > 0 {
                log_error(&format!("Build failed: {} succeeded, {} failed", success_count, fail_count));
                Ok(1)
            } else {
                log_info(&format!("Build succeeded: {} target(s) built", success_count));
                Ok(0)
            }
        })),
    });

    // watch - Watch for changes
    cli.register(CommandDef {
        name: "watch".to_string(),
        description: "Watch for changes and rebuild".to_string(),
        usage: "[--clear]".to_string(),
        options: vec![
            OptionDef {
                short: Some('c'),
                long: "clear".to_string(),
                description: "Clear screen on rebuild".to_string(),
                takes_value: false,
                required: false,
                default: None,
            },
        ],
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let clear = ctx.has_flag("clear");
            let watcher = FileWatcher::new(WatchConfig::default());

            log_info("Watching for changes... (Ctrl+C to stop)");

            watcher.watch(move |event| {
                if clear {
                    print!("\x1b[2J\x1b[H");
                }
                match event {
                    FileEvent::Modified(path) => {
                        log_info(&format!("File modified: {}", path.display()));
                    }
                    FileEvent::Created(path) => {
                        log_info(&format!("File created: {}", path.display()));
                    }
                    _ => {}
                }
                // Trigger rebuild
                if let Ok(project_root) = std::env::current_dir() {
                    let mut orchestrator = BuildOrchestrator::with_root(BuildProfile::Debug, project_root);
                    if Path::new("quark.toml").exists() {
                        let _ = orchestrator.load_manifest();
                    }
                    orchestrator.build();
                }
            });

            // Block forever
            loop {
                thread::sleep(Duration::from_secs(1));
            }
        })),
    });

    // test - Run tests
    cli.register(CommandDef {
        name: "test".to_string(),
        description: "Run tests".to_string(),
        usage: "[--release] [<filter>]".to_string(),
        options: vec![
            OptionDef {
                short: Some('r'),
                long: "release".to_string(),
                description: "Run tests with optimizations".to_string(),
                takes_value: false,
                required: false,
                default: None,
            },
        ],
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let project_root = std::env::current_dir()
                .map_err(|e| format!("Failed to get current directory: {}", e))?;

            let mut orchestrator = BuildOrchestrator::with_root(BuildProfile::Test, project_root.clone());

            // Look for test files
            let test_dir = project_root.join("tests");
            if test_dir.exists() {
                if let Ok(entries) = fs::read_dir(&test_dir) {
                    for entry in entries.flatten() {
                        let path = entry.path();
                        if path.is_file() {
                            if let Some(ext) = path.extension() {
                                if ext == "quanta" {
                                    let name = path.file_stem()
                                        .map(|s| s.to_string_lossy().to_string())
                                        .unwrap_or_else(|| "test".to_string());
                                    orchestrator.add_target(BuildTarget {
                                        name,
                                        kind: TargetKind::Test,
                                        src_path: path,
                                        dependencies: Vec::new(),
                                    });
                                }
                            }
                        }
                    }
                }
            }

            // Also look for #[test] in src files (would need parsing in real impl)
            if Path::new("quark.toml").exists() {
                let _ = orchestrator.load_manifest();
            }

            log_info("Compiling tests...");
            let results = orchestrator.build();

            let failed_build = results.iter().any(|r| !r.success);
            if failed_build {
                log_error("Test compilation failed");
                return Ok(1);
            }

            // Run test binaries
            log_info("Running tests...");
            let mut test_failures = 0;

            for result in &results {
                for artifact in &result.artifacts {
                    if artifact.exists() {
                        log_info(&format!("Running: {}", artifact.display()));
                        match Command::new(artifact).output() {
                            Ok(output) => {
                                let stdout = String::from_utf8_lossy(&output.stdout);
                                let stderr = String::from_utf8_lossy(&output.stderr);
                                if !stdout.is_empty() {
                                    println!("{}", stdout);
                                }
                                if !stderr.is_empty() {
                                    eprintln!("{}", stderr);
                                }
                                if !output.status.success() {
                                    test_failures += 1;
                                }
                            }
                            Err(e) => {
                                log_error(&format!("Failed to run test: {}", e));
                                test_failures += 1;
                            }
                        }
                    }
                }
            }

            if test_failures > 0 {
                log_error(&format!("{} test(s) failed", test_failures));
                Ok(1)
            } else {
                log_info("All tests passed!");
                Ok(0)
            }
        })),
    });

    // bench - Run benchmarks
    cli.register(CommandDef {
        name: "bench".to_string(),
        description: "Run benchmarks".to_string(),
        usage: "[<filter>]".to_string(),
        options: Vec::new(),
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let project_root = std::env::current_dir()
                .map_err(|e| format!("Failed to get current directory: {}", e))?;

            let mut orchestrator = BuildOrchestrator::with_root(BuildProfile::Bench, project_root.clone());

            // Look for benchmark files
            let bench_dir = project_root.join("benches");
            if bench_dir.exists() {
                if let Ok(entries) = fs::read_dir(&bench_dir) {
                    for entry in entries.flatten() {
                        let path = entry.path();
                        if path.is_file() {
                            if let Some(ext) = path.extension() {
                                if ext == "quanta" {
                                    let name = path.file_stem()
                                        .map(|s| s.to_string_lossy().to_string())
                                        .unwrap_or_else(|| "bench".to_string());
                                    orchestrator.add_target(BuildTarget {
                                        name,
                                        kind: TargetKind::Benchmark,
                                        src_path: path,
                                        dependencies: Vec::new(),
                                    });
                                }
                            }
                        }
                    }
                }
            }

            log_info("Compiling benchmarks...");
            let results = orchestrator.build();

            let failed_build = results.iter().any(|r| !r.success);
            if failed_build {
                log_error("Benchmark compilation failed");
                return Ok(1);
            }

            // Run benchmark binaries
            log_info("Running benchmarks...");

            for result in &results {
                for artifact in &result.artifacts {
                    if artifact.exists() {
                        log_info(&format!("Running: {}", artifact.display()));
                        match Command::new(artifact).output() {
                            Ok(output) => {
                                let stdout = String::from_utf8_lossy(&output.stdout);
                                if !stdout.is_empty() {
                                    println!("{}", stdout);
                                }
                            }
                            Err(e) => {
                                log_error(&format!("Failed to run benchmark: {}", e));
                            }
                        }
                    }
                }
            }

            Ok(0)
        })),
    });

    // clean - Clean build artifacts
    cli.register(CommandDef {
        name: "clean".to_string(),
        description: "Remove build artifacts".to_string(),
        usage: "".to_string(),
        options: Vec::new(),
        subcommands: Vec::new(),
        handler: Some(Box::new(|_ctx| {
            let target_dir = PathBuf::from("target");
            if target_dir.exists() {
                match fs::remove_dir_all(&target_dir) {
                    Ok(_) => {
                        log_info("Cleaned build artifacts");
                        Ok(0)
                    }
                    Err(e) => {
                        log_error(&format!("Failed to clean: {}", e));
                        Ok(1)
                    }
                }
            } else {
                log_info("Nothing to clean");
                Ok(0)
            }
        })),
    });

    // generate - Code generation
    cli.register(CommandDef {
        name: "generate".to_string(),
        description: "Generate code from templates".to_string(),
        usage: "<type> <name> [fields...]".to_string(),
        options: Vec::new(),
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let gen_type = ctx.get_arg(1).ok_or("Generation type required")?;
            let name = ctx.get_arg(2).ok_or("Name required")?;

            let generator = CodeGenerator::new(PathBuf::from("src"));

            let code = match gen_type.as_str() {
                "struct" => {
                    let fields: Vec<(&str, &str)> = ctx.args[3..].chunks(2)
                        .filter_map(|c| {
                            if c.len() == 2 {
                                Some((c[0].as_str(), c[1].as_str()))
                            } else {
                                None
                            }
                        })
                        .collect();
                    generator.generate_struct(name, &fields)
                }
                "enum" => {
                    let variants: Vec<&str> = ctx.args[3..].iter()
                        .map(|s| s.as_str())
                        .collect();
                    generator.generate_enum(name, &variants)
                }
                _ => return Err(format!("Unknown generation type: {}", gen_type)),
            };

            println!("{}", code);
            Ok(0)
        })),
    });

    // doc - Generate documentation
    cli.register(CommandDef {
        name: "doc".to_string(),
        description: "Generate documentation".to_string(),
        usage: "[--format <html|md|json>] [--open]".to_string(),
        options: vec![
            OptionDef {
                short: Some('f'),
                long: "format".to_string(),
                description: "Output format (html, md, json)".to_string(),
                takes_value: true,
                required: false,
                default: Some("html".to_string()),
            },
            OptionDef {
                short: None,
                long: "open".to_string(),
                description: "Open documentation in browser".to_string(),
                takes_value: false,
                required: false,
                default: None,
            },
            OptionDef {
                short: None,
                long: "private".to_string(),
                description: "Include private items".to_string(),
                takes_value: false,
                required: false,
                default: None,
            },
        ],
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let format = ctx.get_option("format")
                .map(|s| s.as_str())
                .unwrap_or("html");

            let doc_format = match format {
                "md" | "markdown" => DocFormat::Markdown,
                "json" => DocFormat::Json,
                _ => DocFormat::Html,
            };

            // Try to load project info from manifest
            let (project_name, project_version) = if Path::new("quark.toml").exists() {
                match Manifest::parse(Path::new("quark.toml")) {
                    Ok(manifest) => (manifest.package.name, manifest.package.version),
                    Err(_) => ("Project".to_string(), "0.1.0".to_string()),
                }
            } else {
                ("Project".to_string(), "0.1.0".to_string())
            };

            let config = DocConfig {
                output_dir: PathBuf::from("target/doc"),
                format: doc_format,
                include_private: ctx.has_flag("private"),
                include_source: true,
                project_name,
                project_version,
                css_theme: "default".to_string(),
            };

            let mut generator = DocGenerator::new(config.clone());

            log_info("Parsing source files...");
            generator.parse_sources(Path::new("src"))?;

            log_info("Generating documentation...");
            generator.generate()?;

            // Open in browser if requested
            if ctx.has_flag("open") {
                let index_path = config.output_dir.join("index.html");
                if index_path.exists() {
                    #[cfg(target_os = "windows")]
                    let _ = Command::new("cmd").args(["/C", "start", &index_path.to_string_lossy()]).spawn();
                    #[cfg(target_os = "macos")]
                    let _ = Command::new("open").arg(&index_path).spawn();
                    #[cfg(target_os = "linux")]
                    let _ = Command::new("xdg-open").arg(&index_path).spawn();
                }
            }

            Ok(0)
        })),
    });

    // run - Run scripts
    cli.register(CommandDef {
        name: "run".to_string(),
        description: "Run a script".to_string(),
        usage: "<script>".to_string(),
        options: Vec::new(),
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let script_name = ctx.get_arg(1).ok_or("Script name required")?;
            let runner = ScriptRunner::new();
            runner.run(script_name)
        })),
    });

    // env - Environment management
    cli.register(CommandDef {
        name: "env".to_string(),
        description: "Manage environment variables".to_string(),
        usage: "[list|get|set]".to_string(),
        options: Vec::new(),
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let mut env = EnvManager::new();
            env.load_system();

            if let Ok(()) = env.load_file(Path::new(".env")) {
                // Loaded .env file
            }

            match ctx.get_arg(1).map(|s| s.as_str()) {
                Some("list") | None => {
                    for var in env.list() {
                        println!("{}={}", var.key, var.value);
                    }
                }
                Some("get") => {
                    if let Some(key) = ctx.get_arg(2) {
                        if let Some(value) = env.get(key) {
                            println!("{}", value);
                        }
                    }
                }
                Some("set") => {
                    if let (Some(key), Some(value)) = (ctx.get_arg(2), ctx.get_arg(3)) {
                        env.set(key, value);
                        log_info(&format!("Set {}={}", key, value));
                    }
                }
                _ => {}
            }

            Ok(0)
        })),
    });

    // plugin - Plugin management
    cli.register(CommandDef {
        name: "plugin".to_string(),
        description: "Manage plugins".to_string(),
        usage: "[list|install|remove]".to_string(),
        options: Vec::new(),
        subcommands: Vec::new(),
        handler: Some(Box::new(|ctx| {
            let mut pm = PluginManager::new(PathBuf::from("plugins"));
            pm.discover()?;

            match ctx.get_arg(1).map(|s| s.as_str()) {
                Some("list") | None => {
                    let plugins = pm.list();
                    if plugins.is_empty() {
                        println!("No plugins installed");
                    } else {
                        for plugin in plugins {
                            println!("{} v{} - {}", plugin.name, plugin.version, plugin.description);
                        }
                    }
                }
                _ => {}
            }

            Ok(0)
        })),
    });

    cli
}

/// Main entry point
pub fn main() {
    let args: Vec<String> = std::env::args().collect();
    let cli = create_forge_cli();
    let exit_code = cli.run(&args[1..]);
    std::process::exit(exit_code);
}

// =============================================================================
// REPL (READ-EVAL-PRINT LOOP)
// =============================================================================

/// REPL configuration
#[derive(Debug, Clone)]
pub struct ReplConfig {
    pub prompt: String,
    pub continuation_prompt: String,
    pub history_file: Option<PathBuf>,
    pub max_history: usize,
    pub enable_colors: bool,
    pub enable_completion: bool,
    pub auto_imports: Vec<String>,
}

impl Default for ReplConfig {
    fn default() -> Self {
        ReplConfig {
            prompt: "quanta> ".to_string(),
            continuation_prompt: "....... ".to_string(),
            history_file: Some(PathBuf::from(".quanta_history")),
            max_history: 1000,
            enable_colors: true,
            enable_completion: true,
            auto_imports: vec![
                "std::collections".to_string(),
                "std::io".to_string(),
            ],
        }
    }
}

/// REPL command result
#[derive(Debug)]
pub enum ReplResult {
    Value(ReplValue),
    Continue,
    Exit,
    Error(String),
    Help(String),
}

/// Value types the REPL can display
#[derive(Debug, Clone)]
pub enum ReplValue {
    Unit,
    Bool(bool),
    Int(i64),
    Float(f64),
    String(String),
    List(Vec<ReplValue>),
    Map(Vec<(String, ReplValue)>),
    Struct { name: String, fields: Vec<(String, ReplValue)> },
    Function { name: String, params: Vec<String> },
    Custom(String),
}

impl ReplValue {
    pub fn display(&self, colored: bool) -> String {
        let reset = if colored { "\x1b[0m" } else { "" };
        let num_color = if colored { "\x1b[33m" } else { "" };
        let str_color = if colored { "\x1b[32m" } else { "" };
        let bool_color = if colored { "\x1b[35m" } else { "" };
        let type_color = if colored { "\x1b[36m" } else { "" };

        match self {
            ReplValue::Unit => "()".to_string(),
            ReplValue::Bool(b) => format!("{}{}{}", bool_color, b, reset),
            ReplValue::Int(i) => format!("{}{}{}", num_color, i, reset),
            ReplValue::Float(f) => format!("{}{:.6}{}", num_color, f, reset),
            ReplValue::String(s) => format!("{}\"{}\"{}",str_color, s, reset),
            ReplValue::List(items) => {
                let inner: Vec<String> = items.iter()
                    .map(|v| v.display(colored))
                    .collect();
                format!("[{}]", inner.join(", "))
            }
            ReplValue::Map(pairs) => {
                let inner: Vec<String> = pairs.iter()
                    .map(|(k, v)| format!("{}: {}", k, v.display(colored)))
                    .collect();
                format!("{{{}}}", inner.join(", "))
            }
            ReplValue::Struct { name, fields } => {
                let inner: Vec<String> = fields.iter()
                    .map(|(k, v)| format!("{}: {}", k, v.display(colored)))
                    .collect();
                format!("{}{}{} {{ {} }}", type_color, name, reset, inner.join(", "))
            }
            ReplValue::Function { name, params } => {
                format!("{}fn {}{}({})", type_color, name, reset, params.join(", "))
            }
            ReplValue::Custom(s) => s.clone(),
        }
    }
}

/// Command history management
pub struct CommandHistory {
    commands: Vec<String>,
    position: usize,
    max_size: usize,
    file_path: Option<PathBuf>,
}

impl CommandHistory {
    pub fn new(max_size: usize, file_path: Option<PathBuf>) -> Self {
        let mut history = CommandHistory {
            commands: Vec::new(),
            position: 0,
            max_size,
            file_path: file_path.clone(),
        };

        if let Some(ref path) = file_path {
            history.load_from_file(path);
        }

        history
    }

    pub fn add(&mut self, command: String) {
        if command.trim().is_empty() {
            return;
        }

        // Don't add duplicates of the last command
        if self.commands.last().map(|s| s.as_str()) == Some(command.as_str()) {
            return;
        }

        self.commands.push(command);

        // Trim to max size
        while self.commands.len() > self.max_size {
            self.commands.remove(0);
        }

        self.position = self.commands.len();

        // Persist
        if let Some(ref path) = self.file_path {
            self.save_to_file(path);
        }
    }

    pub fn previous(&mut self) -> Option<&str> {
        if self.position > 0 {
            self.position -= 1;
            Some(&self.commands[self.position])
        } else {
            None
        }
    }

    pub fn next(&mut self) -> Option<&str> {
        if self.position < self.commands.len() - 1 {
            self.position += 1;
            Some(&self.commands[self.position])
        } else {
            self.position = self.commands.len();
            None
        }
    }

    pub fn search(&self, prefix: &str) -> Vec<&str> {
        self.commands.iter()
            .rev()
            .filter(|cmd| cmd.starts_with(prefix))
            .map(|s| s.as_str())
            .collect()
    }

    fn load_from_file(&mut self, path: &Path) {
        if let Ok(content) = fs::read_to_string(path) {
            for line in content.lines() {
                if !line.is_empty() {
                    self.commands.push(line.to_string());
                }
            }
            if self.commands.len() > self.max_size {
                let excess = self.commands.len() - self.max_size;
                self.commands.drain(0..excess);
            }
            self.position = self.commands.len();
        }
    }

    fn save_to_file(&self, path: &Path) {
        let content = self.commands.join("\n");
        let _ = fs::write(path, content);
    }
}

/// Tab completion provider
pub struct CompletionProvider {
    keywords: Vec<String>,
    builtins: Vec<String>,
    user_symbols: Vec<String>,
}

impl CompletionProvider {
    pub fn new() -> Self {
        CompletionProvider {
            keywords: vec![
                "fn", "let", "mut", "const", "struct", "enum", "impl",
                "trait", "pub", "use", "mod", "if", "else", "match",
                "for", "while", "loop", "break", "continue", "return",
                "async", "await", "self", "Self", "true", "false",
            ].iter().map(|s| s.to_string()).collect(),
            builtins: vec![
                "println", "print", "format", "vec", "String", "Vec",
                "HashMap", "HashSet", "Option", "Result", "Some", "None",
                "Ok", "Err", "Box", "Rc", "Arc", "RefCell", "Mutex",
            ].iter().map(|s| s.to_string()).collect(),
            user_symbols: Vec::new(),
        }
    }

    pub fn add_symbol(&mut self, symbol: String) {
        if !self.user_symbols.contains(&symbol) {
            self.user_symbols.push(symbol);
        }
    }

    pub fn complete(&self, prefix: &str) -> Vec<String> {
        let mut completions = Vec::new();

        for kw in &self.keywords {
            if kw.starts_with(prefix) {
                completions.push(kw.clone());
            }
        }

        for builtin in &self.builtins {
            if builtin.starts_with(prefix) {
                completions.push(builtin.clone());
            }
        }

        for sym in &self.user_symbols {
            if sym.starts_with(prefix) {
                completions.push(sym.clone());
            }
        }

        completions.sort();
        completions.dedup();
        completions
    }
}

/// REPL environment (scope/bindings)
pub struct ReplEnvironment {
    bindings: HashMap<String, ReplValue>,
    type_info: HashMap<String, String>,
    imports: HashSet<String>,
}

impl ReplEnvironment {
    pub fn new() -> Self {
        ReplEnvironment {
            bindings: HashMap::new(),
            type_info: HashMap::new(),
            imports: HashSet::new(),
        }
    }

    pub fn bind(&mut self, name: String, value: ReplValue, type_name: String) {
        self.bindings.insert(name.clone(), value);
        self.type_info.insert(name, type_name);
    }

    pub fn get(&self, name: &str) -> Option<&ReplValue> {
        self.bindings.get(name)
    }

    pub fn get_type(&self, name: &str) -> Option<&str> {
        self.type_info.get(name).map(|s| s.as_str())
    }

    pub fn add_import(&mut self, path: String) {
        self.imports.insert(path);
    }

    pub fn list_bindings(&self) -> Vec<(&str, &ReplValue, &str)> {
        self.bindings.iter()
            .map(|(name, val)| {
                let ty = self.type_info.get(name).map(|s| s.as_str()).unwrap_or("?");
                (name.as_str(), val, ty)
            })
            .collect()
    }

    pub fn clear(&mut self) {
        self.bindings.clear();
        self.type_info.clear();
    }
}

/// Interactive REPL
pub struct Repl {
    config: ReplConfig,
    history: CommandHistory,
    completion: CompletionProvider,
    environment: ReplEnvironment,
    multiline_buffer: String,
    running: bool,
}

impl Repl {
    pub fn new(config: ReplConfig) -> Self {
        let history = CommandHistory::new(
            config.max_history,
            config.history_file.clone(),
        );

        Repl {
            config,
            history,
            completion: CompletionProvider::new(),
            environment: ReplEnvironment::new(),
            multiline_buffer: String::new(),
            running: false,
        }
    }

    /// Start the REPL
    pub fn run(&mut self) {
        self.running = true;
        self.print_banner();

        // Add auto imports
        for import in &self.config.auto_imports.clone() {
            self.environment.add_import(import.clone());
        }

        while self.running {
            let prompt = if self.multiline_buffer.is_empty() {
                &self.config.prompt
            } else {
                &self.config.continuation_prompt
            };

            print!("{}", prompt);
            let _ = std::io::stdout().flush();

            let mut input = String::new();
            match std::io::stdin().read_line(&mut input) {
                Ok(0) => break, // EOF
                Ok(_) => {}
                Err(_) => break,
            }

            let input = input.trim_end();

            // Handle multiline input
            if self.needs_continuation(input) {
                self.multiline_buffer.push_str(input);
                self.multiline_buffer.push('\n');
                continue;
            }

            let full_input = if self.multiline_buffer.is_empty() {
                input.to_string()
            } else {
                let mut full = self.multiline_buffer.clone();
                full.push_str(input);
                self.multiline_buffer.clear();
                full
            };

            if full_input.is_empty() {
                continue;
            }

            self.history.add(full_input.clone());

            match self.evaluate(&full_input) {
                ReplResult::Value(val) => {
                    println!("=> {}", val.display(self.config.enable_colors));
                }
                ReplResult::Continue => {}
                ReplResult::Exit => {
                    self.running = false;
                }
                ReplResult::Error(msg) => {
                    if self.config.enable_colors {
                        println!("\x1b[31merror:\x1b[0m {}", msg);
                    } else {
                        println!("error: {}", msg);
                    }
                }
                ReplResult::Help(text) => {
                    println!("{}", text);
                }
            }
        }

        println!("Goodbye!");
    }

    fn print_banner(&self) {
        println!("╔═══════════════════════════════════════════════════════════╗");
        println!("║     Quanta REPL v1.0.0 - Interactive Development Shell    ║");
        println!("╠═══════════════════════════════════════════════════════════╣");
        println!("║ Type :help for commands, :quit to exit                    ║");
        println!("╚═══════════════════════════════════════════════════════════╝");
        println!();
    }

    fn needs_continuation(&self, input: &str) -> bool {
        let combined = format!("{}{}", self.multiline_buffer, input);

        // Check for unbalanced brackets
        let mut brace_count = 0i32;
        let mut paren_count = 0i32;
        let mut bracket_count = 0i32;
        let mut in_string = false;
        let mut escape_next = false;

        for ch in combined.chars() {
            if escape_next {
                escape_next = false;
                continue;
            }

            match ch {
                '\\' if in_string => escape_next = true,
                '"' => in_string = !in_string,
                '{' if !in_string => brace_count += 1,
                '}' if !in_string => brace_count -= 1,
                '(' if !in_string => paren_count += 1,
                ')' if !in_string => paren_count -= 1,
                '[' if !in_string => bracket_count += 1,
                ']' if !in_string => bracket_count -= 1,
                _ => {}
            }
        }

        brace_count > 0 || paren_count > 0 || bracket_count > 0 || in_string
    }

    fn evaluate(&mut self, input: &str) -> ReplResult {
        // Handle REPL commands (starting with :)
        if input.starts_with(':') {
            return self.handle_command(input);
        }

        // Handle let bindings
        if input.starts_with("let ") {
            return self.handle_let(input);
        }

        // Handle use statements
        if input.starts_with("use ") {
            let path = input[4..].trim().trim_end_matches(';');
            self.environment.add_import(path.to_string());
            return ReplResult::Continue;
        }

        // Evaluate as expression
        self.evaluate_expression(input)
    }

    fn handle_command(&mut self, input: &str) -> ReplResult {
        let parts: Vec<&str> = input[1..].split_whitespace().collect();
        if parts.is_empty() {
            return ReplResult::Continue;
        }

        match parts[0] {
            "quit" | "q" | "exit" => ReplResult::Exit,

            "help" | "h" | "?" => ReplResult::Help(self.help_text()),

            "clear" | "cls" => {
                print!("\x1b[2J\x1b[H");
                ReplResult::Continue
            }

            "reset" => {
                self.environment.clear();
                println!("Environment cleared.");
                ReplResult::Continue
            }

            "env" | "bindings" => {
                let bindings = self.environment.list_bindings();
                if bindings.is_empty() {
                    println!("No bindings in scope.");
                } else {
                    println!("Current bindings:");
                    for (name, val, ty) in bindings {
                        println!("  {}: {} = {}", name, ty, val.display(self.config.enable_colors));
                    }
                }
                ReplResult::Continue
            }

            "type" | "t" => {
                if parts.len() < 2 {
                    return ReplResult::Error("Usage: :type <expression>".to_string());
                }
                let expr = parts[1..].join(" ");
                if let Some(ty) = self.environment.get_type(&expr) {
                    println!("{}: {}", expr, ty);
                } else {
                    println!("{}: <unknown type>", expr);
                }
                ReplResult::Continue
            }

            "history" | "hist" => {
                for (i, cmd) in self.history.commands.iter().enumerate() {
                    println!("{:4}: {}", i, cmd);
                }
                ReplResult::Continue
            }

            "load" => {
                if parts.len() < 2 {
                    return ReplResult::Error("Usage: :load <file>".to_string());
                }
                self.load_file(parts[1])
            }

            "save" => {
                if parts.len() < 2 {
                    return ReplResult::Error("Usage: :save <file>".to_string());
                }
                self.save_session(parts[1])
            }

            "time" => {
                if parts.len() < 2 {
                    return ReplResult::Error("Usage: :time <expression>".to_string());
                }
                let expr = parts[1..].join(" ");
                let start = Instant::now();
                let result = self.evaluate_expression(&expr);
                let elapsed = start.elapsed();
                println!("Time: {:?}", elapsed);
                result
            }

            _ => ReplResult::Error(format!("Unknown command: {}", parts[0])),
        }
    }

    fn help_text(&self) -> String {
        r#"
REPL Commands:
  :help, :h, :?     Show this help message
  :quit, :q         Exit the REPL
  :clear, :cls      Clear the screen
  :reset            Clear all bindings
  :env, :bindings   Show current bindings
  :type <expr>      Show type of expression
  :history          Show command history
  :load <file>      Load and execute a file
  :save <file>      Save session to file
  :time <expr>      Time expression evaluation

Expression Examples:
  let x = 42                  Bind a value
  x + 10                      Evaluate expression
  vec![1, 2, 3].len()         Method call
  fn double(x: i32) -> i32    Define function
    { x * 2 }

Use arrow keys for history navigation.
Tab for auto-completion.
"#.to_string()
    }

    fn handle_let(&mut self, input: &str) -> ReplResult {
        // Parse: let name = value or let name: Type = value
        let rest = input[4..].trim();

        let (name, type_hint, value_str) = if let Some(eq_pos) = rest.find('=') {
            let before_eq = rest[..eq_pos].trim();
            let after_eq = rest[eq_pos + 1..].trim().trim_end_matches(';');

            if let Some(colon_pos) = before_eq.find(':') {
                let name = before_eq[..colon_pos].trim().trim_start_matches("mut ");
                let ty = before_eq[colon_pos + 1..].trim();
                (name, Some(ty), after_eq)
            } else {
                let name = before_eq.trim_start_matches("mut ");
                (name, None, after_eq)
            }
        } else {
            return ReplResult::Error("Invalid let binding syntax".to_string());
        };

        // Evaluate the value
        match self.parse_value(value_str) {
            Ok(value) => {
                let type_name = type_hint
                    .map(|s| s.to_string())
                    .unwrap_or_else(|| self.infer_type(&value));

                self.environment.bind(name.to_string(), value.clone(), type_name);
                self.completion.add_symbol(name.to_string());

                ReplResult::Value(value)
            }
            Err(e) => ReplResult::Error(e),
        }
    }

    fn parse_value(&self, input: &str) -> Result<ReplValue, String> {
        let input = input.trim();

        // Boolean
        if input == "true" {
            return Ok(ReplValue::Bool(true));
        }
        if input == "false" {
            return Ok(ReplValue::Bool(false));
        }

        // String
        if input.starts_with('"') && input.ends_with('"') && input.len() >= 2 {
            return Ok(ReplValue::String(input[1..input.len()-1].to_string()));
        }

        // Integer
        if let Ok(i) = input.parse::<i64>() {
            return Ok(ReplValue::Int(i));
        }

        // Float
        if let Ok(f) = input.parse::<f64>() {
            return Ok(ReplValue::Float(f));
        }

        // List: [a, b, c]
        if input.starts_with('[') && input.ends_with(']') {
            let inner = &input[1..input.len()-1];
            if inner.is_empty() {
                return Ok(ReplValue::List(Vec::new()));
            }
            let items: Result<Vec<ReplValue>, String> = inner
                .split(',')
                .map(|s| self.parse_value(s.trim()))
                .collect();
            return Ok(ReplValue::List(items?));
        }

        // Variable reference
        if let Some(val) = self.environment.get(input) {
            return Ok(val.clone());
        }

        // Unit
        if input == "()" {
            return Ok(ReplValue::Unit);
        }

        Err(format!("Cannot parse value: {}", input))
    }

    fn infer_type(&self, value: &ReplValue) -> String {
        match value {
            ReplValue::Unit => "()".to_string(),
            ReplValue::Bool(_) => "bool".to_string(),
            ReplValue::Int(_) => "i64".to_string(),
            ReplValue::Float(_) => "f64".to_string(),
            ReplValue::String(_) => "String".to_string(),
            ReplValue::List(items) => {
                if items.is_empty() {
                    "Vec<_>".to_string()
                } else {
                    format!("Vec<{}>", self.infer_type(&items[0]))
                }
            }
            ReplValue::Map(_) => "HashMap<String, _>".to_string(),
            ReplValue::Struct { name, .. } => name.clone(),
            ReplValue::Function { .. } => "fn".to_string(),
            ReplValue::Custom(_) => "?".to_string(),
        }
    }

    fn evaluate_expression(&self, input: &str) -> ReplResult {
        let input = input.trim().trim_end_matches(';');

        // Try to parse as a value
        match self.parse_value(input) {
            Ok(val) => ReplResult::Value(val),
            Err(_) => {
                // Could not evaluate - would need full interpreter
                ReplResult::Error(format!("Cannot evaluate: {}", input))
            }
        }
    }

    fn load_file(&mut self, path: &str) -> ReplResult {
        match fs::read_to_string(path) {
            Ok(content) => {
                for line in content.lines() {
                    if !line.trim().is_empty() && !line.trim().starts_with("//") {
                        if let ReplResult::Error(e) = self.evaluate(line) {
                            return ReplResult::Error(format!("Error in {}: {}", path, e));
                        }
                    }
                }
                println!("Loaded: {}", path);
                ReplResult::Continue
            }
            Err(e) => ReplResult::Error(format!("Cannot load {}: {}", path, e)),
        }
    }

    fn save_session(&self, path: &str) -> ReplResult {
        let mut content = String::new();
        content.push_str("// Quanta REPL session\n\n");

        for import in &self.environment.imports {
            content.push_str(&format!("use {};\n", import));
        }
        content.push('\n');

        for (name, val, ty) in self.environment.list_bindings() {
            content.push_str(&format!("let {}: {} = {};\n", name, ty,
                val.display(false)));
        }

        match fs::write(path, content) {
            Ok(_) => {
                println!("Saved to: {}", path);
                ReplResult::Continue
            }
            Err(e) => ReplResult::Error(format!("Cannot save: {}", e)),
        }
    }
}

// =============================================================================
// PROFILER
// =============================================================================

/// Profiler configuration
#[derive(Debug, Clone)]
pub struct ProfilerConfig {
    pub sample_rate_hz: u32,
    pub stack_depth: usize,
    pub track_allocations: bool,
    pub output_format: ProfileOutputFormat,
    pub output_path: Option<PathBuf>,
}

impl Default for ProfilerConfig {
    fn default() -> Self {
        ProfilerConfig {
            sample_rate_hz: 1000,
            stack_depth: 64,
            track_allocations: true,
            output_format: ProfileOutputFormat::Text,
            output_path: None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ProfileOutputFormat {
    Text,
    Json,
    FlameGraph,
    CallGrind,
    Chrome,
}

/// Stack frame information
#[derive(Debug, Clone)]
pub struct StackFrame {
    pub function_name: String,
    pub file: Option<String>,
    pub line: Option<u32>,
    pub address: u64,
}

/// CPU sample
#[derive(Debug, Clone)]
pub struct CpuSample {
    pub timestamp_ns: u64,
    pub thread_id: u64,
    pub stack: Vec<StackFrame>,
}

/// Memory allocation event
#[derive(Debug, Clone)]
pub struct AllocationEvent {
    pub timestamp_ns: u64,
    pub thread_id: u64,
    pub address: u64,
    pub size: usize,
    pub is_alloc: bool, // true = alloc, false = dealloc
    pub stack: Vec<StackFrame>,
}

/// Function timing information
#[derive(Debug, Clone)]
pub struct FunctionTiming {
    pub name: String,
    pub call_count: u64,
    pub total_time_ns: u64,
    pub self_time_ns: u64,
    pub min_time_ns: u64,
    pub max_time_ns: u64,
}

impl FunctionTiming {
    pub fn new(name: String) -> Self {
        FunctionTiming {
            name,
            call_count: 0,
            total_time_ns: 0,
            self_time_ns: 0,
            min_time_ns: u64::MAX,
            max_time_ns: 0,
        }
    }

    pub fn record(&mut self, duration_ns: u64) {
        self.call_count += 1;
        self.total_time_ns += duration_ns;
        self.min_time_ns = self.min_time_ns.min(duration_ns);
        self.max_time_ns = self.max_time_ns.max(duration_ns);
    }

    pub fn avg_time_ns(&self) -> u64 {
        if self.call_count == 0 { 0 } else { self.total_time_ns / self.call_count }
    }
}

/// Hotspot information
#[derive(Debug, Clone)]
pub struct Hotspot {
    pub function: String,
    pub file: Option<String>,
    pub line: Option<u32>,
    pub sample_count: u64,
    pub percentage: f64,
}

/// Memory statistics
#[derive(Debug, Clone, Default)]
pub struct MemoryStats {
    pub total_allocations: u64,
    pub total_deallocations: u64,
    pub current_bytes: i64,
    pub peak_bytes: i64,
    pub allocation_count: u64,
}

/// Profile data collected
#[derive(Debug, Clone)]
pub struct ProfileData {
    pub start_time: Instant,
    pub end_time: Option<Instant>,
    pub cpu_samples: Vec<CpuSample>,
    pub allocations: Vec<AllocationEvent>,
    pub function_timings: HashMap<String, FunctionTiming>,
    pub memory_stats: MemoryStats,
}

impl ProfileData {
    pub fn new() -> Self {
        ProfileData {
            start_time: Instant::now(),
            end_time: None,
            cpu_samples: Vec::new(),
            allocations: Vec::new(),
            function_timings: HashMap::new(),
            memory_stats: MemoryStats::default(),
        }
    }

    pub fn duration(&self) -> Duration {
        self.end_time.unwrap_or_else(Instant::now).duration_since(self.start_time)
    }

    /// Get top hotspots
    pub fn hotspots(&self, limit: usize) -> Vec<Hotspot> {
        let total_samples = self.cpu_samples.len() as f64;
        if total_samples == 0.0 {
            return Vec::new();
        }

        let mut counts: HashMap<String, (u64, Option<String>, Option<u32>)> = HashMap::new();

        for sample in &self.cpu_samples {
            if let Some(frame) = sample.stack.first() {
                let entry = counts.entry(frame.function_name.clone())
                    .or_insert((0, frame.file.clone(), frame.line));
                entry.0 += 1;
            }
        }

        let mut hotspots: Vec<Hotspot> = counts.into_iter()
            .map(|(func, (count, file, line))| {
                Hotspot {
                    function: func,
                    file,
                    line,
                    sample_count: count,
                    percentage: (count as f64 / total_samples) * 100.0,
                }
            })
            .collect();

        hotspots.sort_by(|a, b| b.sample_count.cmp(&a.sample_count));
        hotspots.truncate(limit);
        hotspots
    }

    /// Generate flame graph data (folded stacks format)
    pub fn flame_graph_data(&self) -> String {
        let mut stack_counts: HashMap<String, u64> = HashMap::new();

        for sample in &self.cpu_samples {
            let stack: Vec<&str> = sample.stack.iter()
                .rev()
                .map(|f| f.function_name.as_str())
                .collect();
            let key = stack.join(";");
            *stack_counts.entry(key).or_insert(0) += 1;
        }

        let mut lines: Vec<String> = stack_counts.into_iter()
            .map(|(stack, count)| format!("{} {}", stack, count))
            .collect();
        lines.sort();
        lines.join("\n")
    }

    /// Generate Chrome trace format
    pub fn chrome_trace(&self) -> String {
        let mut events = Vec::new();

        for (name, timing) in &self.function_timings {
            events.push(format!(
                r#"{{"name":"{}","ph":"X","ts":0,"dur":{},"pid":1,"tid":1}}"#,
                name,
                timing.total_time_ns / 1000  // microseconds
            ));
        }

        format!("{{\"traceEvents\":[{}]}}", events.join(","))
    }
}

/// CPU Profiler
pub struct CpuProfiler {
    config: ProfilerConfig,
    data: Arc<RwLock<ProfileData>>,
    running: Arc<RwLock<bool>>,
    sample_thread: Option<thread::JoinHandle<()>>,
}

impl CpuProfiler {
    pub fn new(config: ProfilerConfig) -> Self {
        CpuProfiler {
            config,
            data: Arc::new(RwLock::new(ProfileData::new())),
            running: Arc::new(RwLock::new(false)),
            sample_thread: None,
        }
    }

    /// Start profiling
    pub fn start(&mut self) {
        {
            let mut running = self.running.write().unwrap();
            if *running {
                return;
            }
            *running = true;
        }

        *self.data.write().unwrap() = ProfileData::new();

        let data = Arc::clone(&self.data);
        let running = Arc::clone(&self.running);
        let sample_interval = Duration::from_micros(1_000_000 / self.config.sample_rate_hz as u64);

        self.sample_thread = Some(thread::spawn(move || {
            while *running.read().unwrap() {
                // Simulate sampling (would use platform-specific APIs in real impl)
                let sample = CpuSample {
                    timestamp_ns: Instant::now().elapsed().as_nanos() as u64,
                    thread_id: 0,
                    stack: Vec::new(), // Would capture real stack
                };

                data.write().unwrap().cpu_samples.push(sample);
                thread::sleep(sample_interval);
            }
        }));
    }

    /// Stop profiling
    pub fn stop(&mut self) -> ProfileData {
        *self.running.write().unwrap() = false;

        if let Some(handle) = self.sample_thread.take() {
            let _ = handle.join();
        }

        let mut data = self.data.write().unwrap();
        data.end_time = Some(Instant::now());
        data.clone()
    }

    /// Profile a function
    pub fn profile_fn<F, R>(&self, name: &str, f: F) -> R
    where
        F: FnOnce() -> R,
    {
        let start = Instant::now();
        let result = f();
        let duration = start.elapsed();

        let mut data = self.data.write().unwrap();
        let timing = data.function_timings
            .entry(name.to_string())
            .or_insert_with(|| FunctionTiming::new(name.to_string()));
        timing.record(duration.as_nanos() as u64);

        result
    }
}

/// Memory Profiler
pub struct MemoryProfiler {
    data: Arc<RwLock<ProfileData>>,
    tracking: bool,
}

impl MemoryProfiler {
    pub fn new() -> Self {
        MemoryProfiler {
            data: Arc::new(RwLock::new(ProfileData::new())),
            tracking: false,
        }
    }

    pub fn start(&mut self) {
        self.tracking = true;
        *self.data.write().unwrap() = ProfileData::new();
    }

    pub fn stop(&mut self) -> ProfileData {
        self.tracking = false;
        let mut data = self.data.write().unwrap();
        data.end_time = Some(Instant::now());
        data.clone()
    }

    /// Record an allocation
    pub fn record_alloc(&self, address: u64, size: usize) {
        if !self.tracking {
            return;
        }

        let mut data = self.data.write().unwrap();

        data.allocations.push(AllocationEvent {
            timestamp_ns: Instant::now().elapsed().as_nanos() as u64,
            thread_id: 0,
            address,
            size,
            is_alloc: true,
            stack: Vec::new(),
        });

        data.memory_stats.total_allocations += 1;
        data.memory_stats.allocation_count += 1;
        data.memory_stats.current_bytes += size as i64;
        data.memory_stats.peak_bytes = data.memory_stats.peak_bytes
            .max(data.memory_stats.current_bytes);
    }

    /// Record a deallocation
    pub fn record_dealloc(&self, address: u64, size: usize) {
        if !self.tracking {
            return;
        }

        let mut data = self.data.write().unwrap();

        data.allocations.push(AllocationEvent {
            timestamp_ns: Instant::now().elapsed().as_nanos() as u64,
            thread_id: 0,
            address,
            size,
            is_alloc: false,
            stack: Vec::new(),
        });

        data.memory_stats.total_deallocations += 1;
        data.memory_stats.allocation_count -= 1;
        data.memory_stats.current_bytes -= size as i64;
    }

    pub fn stats(&self) -> MemoryStats {
        self.data.read().unwrap().memory_stats.clone()
    }
}

/// Profile reporter
pub struct ProfileReporter;

impl ProfileReporter {
    /// Generate text report
    pub fn text_report(data: &ProfileData) -> String {
        let mut report = String::new();

        report.push_str("╔═══════════════════════════════════════════════════════════╗\n");
        report.push_str("║                     PROFILE REPORT                        ║\n");
        report.push_str("╚═══════════════════════════════════════════════════════════╝\n\n");

        // Duration
        report.push_str(&format!("Total Duration: {:?}\n", data.duration()));
        report.push_str(&format!("CPU Samples: {}\n", data.cpu_samples.len()));
        report.push_str(&format!("Memory Events: {}\n\n", data.allocations.len()));

        // Hotspots
        report.push_str("═══ TOP HOTSPOTS ═══\n");
        for (i, hotspot) in data.hotspots(10).iter().enumerate() {
            let location = match (&hotspot.file, hotspot.line) {
                (Some(f), Some(l)) => format!(" ({}:{})", f, l),
                _ => String::new(),
            };
            report.push_str(&format!(
                "{:2}. {:6.2}% ({:6} samples) {}{}\n",
                i + 1,
                hotspot.percentage,
                hotspot.sample_count,
                hotspot.function,
                location,
            ));
        }
        report.push('\n');

        // Function timings
        if !data.function_timings.is_empty() {
            report.push_str("═══ FUNCTION TIMINGS ═══\n");
            report.push_str(&format!(
                "{:<30} {:>10} {:>12} {:>12} {:>12}\n",
                "Function", "Calls", "Total (ms)", "Avg (µs)", "Max (µs)"
            ));
            report.push_str(&"-".repeat(78));
            report.push('\n');

            let mut timings: Vec<&FunctionTiming> = data.function_timings.values().collect();
            timings.sort_by(|a, b| b.total_time_ns.cmp(&a.total_time_ns));

            for timing in timings.iter().take(20) {
                report.push_str(&format!(
                    "{:<30} {:>10} {:>12.3} {:>12.3} {:>12.3}\n",
                    &timing.name[..timing.name.len().min(30)],
                    timing.call_count,
                    timing.total_time_ns as f64 / 1_000_000.0,
                    timing.avg_time_ns() as f64 / 1_000.0,
                    timing.max_time_ns as f64 / 1_000.0,
                ));
            }
            report.push('\n');
        }

        // Memory stats
        report.push_str("═══ MEMORY STATISTICS ═══\n");
        report.push_str(&format!("Total Allocations:   {}\n", data.memory_stats.total_allocations));
        report.push_str(&format!("Total Deallocations: {}\n", data.memory_stats.total_deallocations));
        report.push_str(&format!("Live Allocations:    {}\n", data.memory_stats.allocation_count));
        report.push_str(&format!("Current Memory:      {} bytes\n", data.memory_stats.current_bytes));
        report.push_str(&format!("Peak Memory:         {} bytes\n", data.memory_stats.peak_bytes));

        report
    }

    /// Export to file
    pub fn export(data: &ProfileData, format: ProfileOutputFormat, path: &Path) -> Result<(), String> {
        let content = match format {
            ProfileOutputFormat::Text => Self::text_report(data),
            ProfileOutputFormat::Json => {
                // Simplified JSON export
                format!(r#"{{
    "duration_ms": {},
    "cpu_samples": {},
    "memory_events": {},
    "peak_memory_bytes": {}
}}"#,
                    data.duration().as_millis(),
                    data.cpu_samples.len(),
                    data.allocations.len(),
                    data.memory_stats.peak_bytes,
                )
            }
            ProfileOutputFormat::FlameGraph => data.flame_graph_data(),
            ProfileOutputFormat::Chrome => data.chrome_trace(),
            ProfileOutputFormat::CallGrind => {
                // CallGrind format stub
                "# callgrind format file\nevents: Cycles\n".to_string()
            }
        };

        fs::write(path, content).map_err(|e| e.to_string())
    }
}

