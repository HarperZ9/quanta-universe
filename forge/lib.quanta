#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_logger() {
        let logger = Logger::new(LogConfig::default());
        logger.info("Test message");
    }

    #[test]
    fn test_cli_parse() {
        let cli = CLI::new("test", "1.0.0", "Test CLI");
        // Would test argument parsing
    }

    #[test]
    fn test_code_generator_struct() {
        let gen = CodeGenerator::new(PathBuf::from("."));
        let code = gen.generate_struct("User", &[("name", "String"), ("age", "u32")]);
        assert!(code.contains("pub struct User"));
        assert!(code.contains("pub name: String"));
    }

    #[test]
    fn test_code_generator_enum() {
        let gen = CodeGenerator::new(PathBuf::from("."));
        let code = gen.generate_enum("Status", &["Active", "Inactive", "Pending"]);
        assert!(code.contains("pub enum Status"));
        assert!(code.contains("Active"));
    }

    #[test]
    fn test_env_manager() {
        let mut env = EnvManager::new();
        env.set("TEST_VAR", "test_value");
        assert_eq!(env.get("TEST_VAR"), Some("test_value"));
    }

    #[test]
    fn test_pascal_case() {
        assert_eq!(to_pascal_case("my_plugin"), "MyPlugin");
        assert_eq!(to_pascal_case("hello-world"), "HelloWorld");
    }
}
