// =============================================================================
// LOGGING SYSTEM
// =============================================================================

/// Log level
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum LogLevel {
    Trace,
    Debug,
    Info,
    Warn,
    Error,
    Fatal,
}

impl LogLevel {
    pub fn as_str(&self) -> &'static str {
        match self {
            LogLevel::Trace => "TRACE",
            LogLevel::Debug => "DEBUG",
            LogLevel::Info => "INFO",
            LogLevel::Warn => "WARN",
            LogLevel::Error => "ERROR",
            LogLevel::Fatal => "FATAL",
        }
    }

    pub fn color(&self) -> &'static str {
        match self {
            LogLevel::Trace => "\x1b[90m",
            LogLevel::Debug => "\x1b[36m",
            LogLevel::Info => "\x1b[32m",
            LogLevel::Warn => "\x1b[33m",
            LogLevel::Error => "\x1b[31m",
            LogLevel::Fatal => "\x1b[35m",
        }
    }
}

/// Logger configuration
#[derive(Debug, Clone)]
pub struct LogConfig {
    pub level: LogLevel,
    pub show_timestamp: bool,
    pub show_location: bool,
    pub colored: bool,
    pub output_file: Option<PathBuf>,
}

impl Default for LogConfig {
    fn default() -> Self {
        LogConfig {
            level: LogLevel::Info,
            show_timestamp: true,
            show_location: false,
            colored: true,
            output_file: None,
        }
    }
}

/// Logger instance
pub struct Logger {
    config: RwLock<LogConfig>,
    file_writer: Mutex<Option<BufWriter<fs::File>>>,
}

impl Logger {
    pub fn new(config: LogConfig) -> Self {
        let file_writer = if let Some(ref path) = config.output_file {
            fs::File::create(path).ok().map(|f| BufWriter::new(f))
        } else {
            None
        };

        Logger {
            config: RwLock::new(config),
            file_writer: Mutex::new(file_writer),
        }
    }

    pub fn global() -> &'static Logger {
        static LOGGER: std::sync::OnceLock<Logger> = std::sync::OnceLock::new();
        LOGGER.get_or_init(|| Logger::new(LogConfig::default()))
    }

    pub fn set_level(&self, level: LogLevel) {
        self.config.write().unwrap().level = level;
    }

    pub fn log(&self, level: LogLevel, message: &str, file: Option<&str>, line: Option<u32>) {
        let config = self.config.read().unwrap();

        if level < config.level {
            return;
        }

        let mut output = String::new();

        // Timestamp
        if config.show_timestamp {
            let now = SystemTime::now()
                .duration_since(SystemTime::UNIX_EPOCH)
                .unwrap_or_default();
            let secs = now.as_secs();
            let millis = now.subsec_millis();
            output.push_str(&format!("[{}.{:03}] ", secs, millis));
        }

        // Level with color
        if config.colored {
            output.push_str(&format!("{}[{}]\x1b[0m ", level.color(), level.as_str()));
        } else {
            output.push_str(&format!("[{}] ", level.as_str()));
        }

        // Location
        if config.show_location {
            if let (Some(f), Some(l)) = (file, line) {
                output.push_str(&format!("{}:{}: ", f, l));
            }
        }

        // Message
        output.push_str(message);

        // Output
        println!("{}", output);

        // File output
        if let Ok(mut writer) = self.file_writer.lock() {
            if let Some(ref mut w) = *writer {
                let _ = writeln!(w, "{}", output);
                let _ = w.flush();
            }
        }
    }

    pub fn trace(&self, msg: &str) { self.log(LogLevel::Trace, msg, None, None); }
    pub fn debug(&self, msg: &str) { self.log(LogLevel::Debug, msg, None, None); }
    pub fn info(&self, msg: &str) { self.log(LogLevel::Info, msg, None, None); }
    pub fn warn(&self, msg: &str) { self.log(LogLevel::Warn, msg, None, None); }
    pub fn error(&self, msg: &str) { self.log(LogLevel::Error, msg, None, None); }
    pub fn fatal(&self, msg: &str) { self.log(LogLevel::Fatal, msg, None, None); }
}

// Convenience macros would go here in real implementation
pub fn log_info(msg: &str) { Logger::global().info(msg); }
pub fn log_warn(msg: &str) { Logger::global().warn(msg); }
pub fn log_error(msg: &str) { Logger::global().error(msg); }
pub fn log_debug(msg: &str) { Logger::global().debug(msg); }

// =============================================================================
// CLI FRAMEWORK
// =============================================================================

/// Command handler type
pub type CommandHandler = Box<dyn Fn(&CommandContext) -> Result<i32, String> + Send + Sync>;

/// Command definition
pub struct CommandDef {
    pub name: String,
    pub description: String,
    pub usage: String,
    pub options: Vec<OptionDef>,
    pub subcommands: Vec<CommandDef>,
    pub handler: Option<CommandHandler>,
}

/// Option definition
#[derive(Clone)]
pub struct OptionDef {
    pub short: Option<char>,
    pub long: String,
    pub description: String,
    pub takes_value: bool,
    pub required: bool,
    pub default: Option<String>,
}

/// Command execution context
pub struct CommandContext {
    pub command: String,
    pub args: Vec<String>,
    pub options: HashMap<String, String>,
    pub flags: HashSet<String>,
    pub working_dir: PathBuf,
}

impl CommandContext {
    pub fn get_option(&self, name: &str) -> Option<&String> {
        self.options.get(name)
    }

    pub fn has_flag(&self, name: &str) -> bool {
        self.flags.contains(name)
    }

    pub fn get_arg(&self, index: usize) -> Option<&String> {
        self.args.get(index)
    }
}

/// CLI application
pub struct CLI {
    name: String,
    version: String,
    description: String,
    commands: HashMap<String, CommandDef>,
    global_options: Vec<OptionDef>,
}

impl CLI {
    pub fn new(name: &str, version: &str, description: &str) -> Self {
        CLI {
            name: name.to_string(),
            version: version.to_string(),
            description: description.to_string(),
            commands: HashMap::new(),
            global_options: vec![
                OptionDef {
                    short: Some('h'),
                    long: "help".to_string(),
                    description: "Show help message".to_string(),
                    takes_value: false,
                    required: false,
                    default: None,
                },
                OptionDef {
                    short: Some('V'),
                    long: "version".to_string(),
                    description: "Show version".to_string(),
                    takes_value: false,
                    required: false,
                    default: None,
                },
                OptionDef {
                    short: Some('v'),
                    long: "verbose".to_string(),
                    description: "Enable verbose output".to_string(),
                    takes_value: false,
                    required: false,
                    default: None,
                },
                OptionDef {
                    short: Some('q'),
                    long: "quiet".to_string(),
                    description: "Suppress output".to_string(),
                    takes_value: false,
                    required: false,
                    default: None,
                },
            ],
        }
    }

    pub fn register(&mut self, command: CommandDef) {
        self.commands.insert(command.name.clone(), command);
    }

    pub fn run(&self, args: &[String]) -> i32 {
        let ctx = self.parse_args(args);

        // Handle global flags
        if ctx.has_flag("help") {
            self.print_help(ctx.args.first().map(|s| s.as_str()));
            return 0;
        }

        if ctx.has_flag("version") {
            println!("{} v{}", self.name, self.version);
            return 0;
        }

        if ctx.has_flag("verbose") {
            Logger::global().set_level(LogLevel::Debug);
        }

        if ctx.has_flag("quiet") {
            Logger::global().set_level(LogLevel::Error);
        }

        // Find and run command
        if let Some(cmd_name) = ctx.args.first() {
            if let Some(cmd) = self.commands.get(cmd_name) {
                if let Some(ref handler) = cmd.handler {
                    match handler(&ctx) {
                        Ok(code) => return code,
                        Err(e) => {
                            log_error(&format!("Error: {}", e));
                            return 1;
                        }
                    }
                }
            } else {
                log_error(&format!("Unknown command: {}", cmd_name));
                return 1;
            }
        } else {
            self.print_help(None);
        }

        0
    }

    fn parse_args(&self, args: &[String]) -> CommandContext {
        let mut options = HashMap::new();
        let mut flags = HashSet::new();
        let mut positional = Vec::new();
        let mut i = 0;

        while i < args.len() {
            let arg = &args[i];

            if arg.starts_with("--") {
                let name = &arg[2..];
                if let Some((key, value)) = name.split_once('=') {
                    options.insert(key.to_string(), value.to_string());
                } else if i + 1 < args.len() && !args[i + 1].starts_with('-') {
                    options.insert(name.to_string(), args[i + 1].clone());
                    i += 1;
                } else {
                    flags.insert(name.to_string());
                }
            } else if arg.starts_with('-') && arg.len() > 1 {
                for c in arg[1..].chars() {
                    // Map short to long
                    let long = self.global_options.iter()
                        .find(|o| o.short == Some(c))
                        .map(|o| o.long.clone())
                        .unwrap_or_else(|| c.to_string());
                    flags.insert(long);
                }
            } else {
                positional.push(arg.clone());
            }

            i += 1;
        }

        CommandContext {
            command: positional.first().cloned().unwrap_or_default(),
            args: positional,
            options,
            flags,
            working_dir: std::env::current_dir().unwrap_or_default(),
        }
    }

    fn print_help(&self, command: Option<&str>) {
        if let Some(cmd_name) = command {
            if let Some(cmd) = self.commands.get(cmd_name) {
                println!("{}", cmd.description);
                println!("\nUSAGE:");
                println!("    {} {} {}", self.name, cmd_name, cmd.usage);
                if !cmd.options.is_empty() {
                    println!("\nOPTIONS:");
                    for opt in &cmd.options {
                        let short = opt.short.map(|c| format!("-{}, ", c)).unwrap_or_default();
                        println!("    {}--{:<20} {}", short, opt.long, opt.description);
                    }
                }
                return;
            }
        }

        println!("{} v{}", self.name, self.version);
        println!("{}\n", self.description);
        println!("USAGE:");
        println!("    {} [OPTIONS] <COMMAND> [ARGS...]\n", self.name);
        println!("COMMANDS:");
        for (name, cmd) in &self.commands {
            println!("    {:<20} {}", name, cmd.description);
        }
        println!("\nGLOBAL OPTIONS:");
        for opt in &self.global_options {
            let short = opt.short.map(|c| format!("-{}, ", c)).unwrap_or_default();
            println!("    {}--{:<20} {}", short, opt.long, opt.description);
        }
    }
}

// =============================================================================
// PROJECT SCAFFOLDING
// =============================================================================

/// Project template types
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ProjectTemplate {
    Library,
    Binary,
    Workspace,
    WebService,
    CLI,
    Plugin,
}

impl ProjectTemplate {
    pub fn as_str(&self) -> &'static str {
        match self {
            ProjectTemplate::Library => "lib",
            ProjectTemplate::Binary => "bin",
            ProjectTemplate::Workspace => "workspace",
            ProjectTemplate::WebService => "web",
            ProjectTemplate::CLI => "cli",
            ProjectTemplate::Plugin => "plugin",
        }
    }
}

/// Project generator
pub struct ProjectGenerator {
    template: ProjectTemplate,
    name: String,
    path: PathBuf,
    author: Option<String>,
    license: Option<String>,
}

impl ProjectGenerator {
    pub fn new(name: &str, template: ProjectTemplate) -> Self {
        ProjectGenerator {
            template,
            name: name.to_string(),
            path: PathBuf::from(name),
            author: None,
            license: None,
        }
    }

    pub fn path(mut self, path: PathBuf) -> Self {
        self.path = path;
        self
    }

    pub fn author(mut self, author: &str) -> Self {
        self.author = Some(author.to_string());
        self
    }

    pub fn license(mut self, license: &str) -> Self {
        self.license = Some(license.to_string());
        self
    }

    pub fn generate(&self) -> Result<(), String> {
        // Create project directory
        fs::create_dir_all(&self.path)
            .map_err(|e| format!("Failed to create directory: {}", e))?;

        // Generate quark.toml
        self.generate_manifest()?;

        // Generate source files based on template
        match self.template {
            ProjectTemplate::Library => self.generate_library()?,
            ProjectTemplate::Binary => self.generate_binary()?,
            ProjectTemplate::Workspace => self.generate_workspace()?,
            ProjectTemplate::WebService => self.generate_web_service()?,
            ProjectTemplate::CLI => self.generate_cli()?,
            ProjectTemplate::Plugin => self.generate_plugin()?,
        }

        // Generate common files
        self.generate_gitignore()?;
        self.generate_readme()?;

        log_info(&format!("Created {} project '{}'", self.template.as_str(), self.name));
        Ok(())
    }

    fn generate_manifest(&self) -> Result<(), String> {
        let content = format!(r#"[package]
name = "{}"
version = "0.1.0"
authors = ["{}"]
license = "{}"
edition = "2025"

[dependencies]

[dev-dependencies]
"#,
            self.name,
            self.author.as_deref().unwrap_or("Anonymous"),
            self.license.as_deref().unwrap_or("MIT"),
        );

        fs::write(self.path.join("quark.toml"), content)
            .map_err(|e| format!("Failed to write manifest: {}", e))
    }

    fn generate_library(&self) -> Result<(), String> {
        let src_dir = self.path.join("src");
        fs::create_dir_all(&src_dir)
            .map_err(|e| format!("Failed to create src directory: {}", e))?;

        let lib_content = format!(r#"// {} - A QuantaLang Library
//
// Add your library code here.

module {}

/// Example function
pub fn hello() -> String {{
    "Hello from {}!".to_string()
}}

#[cfg(test)]
mod tests {{
    use super::*;

    #[test]
    fn test_hello() {{
        assert_eq!(hello(), "Hello from {}!");
    }}
}}
"#, self.name, self.name, self.name, self.name);

        fs::write(src_dir.join("lib.quanta"), lib_content)
            .map_err(|e| format!("Failed to write lib.quanta: {}", e))
    }

    fn generate_binary(&self) -> Result<(), String> {
        let src_dir = self.path.join("src");
        fs::create_dir_all(&src_dir)
            .map_err(|e| format!("Failed to create src directory: {}", e))?;

        let main_content = format!(r#"// {} - A QuantaLang Application
//
// Entry point for the application.

use std::env

fn main() {{
    let args: Vec<String> = env::args().collect();

    println!("Hello from {}!");

    if args.len() > 1 {{
        println!("Arguments: {{:?}}", &args[1..]);
    }}
}}
"#, self.name, self.name);

        fs::write(src_dir.join("main.quanta"), main_content)
            .map_err(|e| format!("Failed to write main.quanta: {}", e))
    }

    fn generate_workspace(&self) -> Result<(), String> {
        let manifest = format!(r#"[workspace]
members = [
    "packages/*",
]

[workspace.package]
version = "0.1.0"
authors = ["{}"]
license = "{}"
edition = "2025"
"#,
            self.author.as_deref().unwrap_or("Anonymous"),
            self.license.as_deref().unwrap_or("MIT"),
        );

        fs::write(self.path.join("quark.toml"), manifest)
            .map_err(|e| format!("Failed to write manifest: {}", e))?;

        fs::create_dir_all(self.path.join("packages"))
            .map_err(|e| format!("Failed to create packages directory: {}", e))
    }

    fn generate_web_service(&self) -> Result<(), String> {
        let src_dir = self.path.join("src");
        fs::create_dir_all(&src_dir)
            .map_err(|e| format!("Failed to create src directory: {}", e))?;

        let main_content = format!(r#"// {} - Web Service
//
// A simple HTTP web service.

use std::net::{{TcpListener, TcpStream}}
use std::io::{{Read, Write}}

fn main() {{
    let listener = TcpListener::bind("127.0.0.1:8080").unwrap();
    println!("{} server running on http://127.0.0.1:8080");

    for stream in listener.incoming() {{
        if let Ok(stream) = stream {{
            handle_connection(stream);
        }}
    }}
}}

fn handle_connection(mut stream: TcpStream) {{
    let mut buffer = [0u8; 1024];
    stream.read(&mut buffer).unwrap();

    let response = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\n\r\n{{\"status\": \"ok\"}}";
    stream.write_all(response.as_bytes()).unwrap();
    stream.flush().unwrap();
}}
"#, self.name, self.name);

        fs::write(src_dir.join("main.quanta"), main_content)
            .map_err(|e| format!("Failed to write main.quanta: {}", e))
    }

    fn generate_cli(&self) -> Result<(), String> {
        let src_dir = self.path.join("src");
        fs::create_dir_all(&src_dir)
            .map_err(|e| format!("Failed to create src directory: {}", e))?;

        let main_content = format!(r#"// {} - Command Line Interface
//
// A CLI application with argument parsing.

use std::env
use std::collections::HashMap

fn main() {{
    let args: Vec<String> = env::args().collect();
    let (command, options) = parse_args(&args[1..]);

    match command.as_deref() {{
        Some("help") | None => print_help(),
        Some("version") => println!("{} v0.1.0"),
        Some(cmd) => {{
            println!("Unknown command: {{}}", cmd);
            print_help();
        }}
    }}
}}

fn parse_args(args: &[String]) -> (Option<String>, HashMap<String, String>) {{
    let mut command = None;
    let mut options = HashMap::new();

    for arg in args {{
        if arg.starts_with("--") {{
            if let Some((k, v)) = arg[2..].split_once('=') {{
                options.insert(k.to_string(), v.to_string());
            }}
        }} else if command.is_none() {{
            command = Some(arg.clone());
        }}
    }}

    (command, options)
}}

fn print_help() {{
    println!("{} v0.1.0");
    println!();
    println!("USAGE:");
    println!("    {} [OPTIONS] <COMMAND>");
    println!();
    println!("COMMANDS:");
    println!("    help      Show this help message");
    println!("    version   Show version");
}}
"#, self.name, self.name, self.name, self.name);

        fs::write(src_dir.join("main.quanta"), main_content)
            .map_err(|e| format!("Failed to write main.quanta: {}", e))
    }

    fn generate_plugin(&self) -> Result<(), String> {
        let src_dir = self.path.join("src");
        fs::create_dir_all(&src_dir)
            .map_err(|e| format!("Failed to create src directory: {}", e))?;

        let lib_content = format!(r#"// {} - Plugin
//
// A plugin that can be loaded dynamically.

module {}

use std::any::Any

/// Plugin metadata
pub const PLUGIN_NAME: &str = "{}";
pub const PLUGIN_VERSION: &str = "0.1.0";
pub const PLUGIN_API_VERSION: u32 = 1;

/// Plugin trait that all plugins must implement
pub trait Plugin: Send + Sync {{
    fn name(&self) -> &str;
    fn version(&self) -> &str;
    fn init(&mut self) -> Result<(), String>;
    fn shutdown(&mut self) -> Result<(), String>;
    fn execute(&self, command: &str, args: &[&str]) -> Result<Box<dyn Any>, String>;
}}

/// Main plugin implementation
pub struct {}Plugin {{
    initialized: bool,
}}

impl {}Plugin {{
    pub fn new() -> Self {{
        {}Plugin {{ initialized: false }}
    }}
}}

impl Plugin for {}Plugin {{
    fn name(&self) -> &str {{ PLUGIN_NAME }}
    fn version(&self) -> &str {{ PLUGIN_VERSION }}

    fn init(&mut self) -> Result<(), String> {{
        self.initialized = true;
        Ok(())
    }}

    fn shutdown(&mut self) -> Result<(), String> {{
        self.initialized = false;
        Ok(())
    }}

    fn execute(&self, command: &str, args: &[&str]) -> Result<Box<dyn Any>, String> {{
        if !self.initialized {{
            return Err("Plugin not initialized".to_string());
        }}

        match command {{
            "hello" => Ok(Box::new("Hello from plugin!".to_string())),
            _ => Err(format!("Unknown command: {{}}", command)),
        }}
    }}
}}

/// Plugin entry point (called by host application)
#[no_mangle]
pub extern "C" fn create_plugin() -> Box<dyn Plugin> {{
    Box::new({}Plugin::new())
}}
"#, self.name, self.name, self.name,
    to_pascal_case(&self.name), to_pascal_case(&self.name), to_pascal_case(&self.name),
    to_pascal_case(&self.name), to_pascal_case(&self.name));

        fs::write(src_dir.join("lib.quanta"), lib_content)
            .map_err(|e| format!("Failed to write lib.quanta: {}", e))
    }

    fn generate_gitignore(&self) -> Result<(), String> {
        let content = r#"# Build artifacts
/target/
/build/
*.o
*.a
*.so
*.dll

# IDE
.idea/
.vscode/
*.swp
*.swo

# Dependencies
/deps/
quark.lock

# Environment
.env
.env.local

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
"#;

        fs::write(self.path.join(".gitignore"), content)
            .map_err(|e| format!("Failed to write .gitignore: {}", e))
    }

    fn generate_readme(&self) -> Result<(), String> {
        let content = format!(r#"# {}

A QuantaLang project.

## Building

```bash
quark build
```

## Running

```bash
quark run
```

## Testing

```bash
quark test
```

## License

{}
"#, self.name, self.license.as_deref().unwrap_or("MIT"));

        fs::write(self.path.join("README.md"), content)
            .map_err(|e| format!("Failed to write README.md: {}", e))
    }
}

fn to_pascal_case(s: &str) -> String {
    s.split(|c: char| c == '_' || c == '-')
        .map(|word| {
            let mut chars = word.chars();
            match chars.next() {
                Some(first) => first.to_uppercase().chain(chars).collect(),
                None => String::new(),
            }
        })
        .collect()
}

// =============================================================================
// FILE WATCHER
// =============================================================================

/// File change event
#[derive(Debug, Clone)]
pub enum FileEvent {
    Created(PathBuf),
    Modified(PathBuf),
    Deleted(PathBuf),
    Renamed(PathBuf, PathBuf),
}

/// File watcher configuration
#[derive(Debug, Clone)]
pub struct WatchConfig {
    pub paths: Vec<PathBuf>,
    pub extensions: HashSet<String>,
    pub ignore_patterns: Vec<String>,
    pub debounce_ms: u64,
    pub recursive: bool,
}

impl Default for WatchConfig {
    fn default() -> Self {
        let mut extensions = HashSet::new();
        extensions.insert("quanta".to_string());
        extensions.insert("toml".to_string());

        WatchConfig {
            paths: vec![PathBuf::from("src")],
            extensions,
            ignore_patterns: vec![
                "target".to_string(),
                ".git".to_string(),
                "node_modules".to_string(),
            ],
            debounce_ms: 100,
            recursive: true,
        }
    }
}

/// File watcher for hot reload
pub struct FileWatcher {
    config: WatchConfig,
    running: Arc<std::sync::atomic::AtomicBool>,
    last_modified: Arc<RwLock<HashMap<PathBuf, SystemTime>>>,
}

impl FileWatcher {
    pub fn new(config: WatchConfig) -> Self {
        FileWatcher {
            config,
            running: Arc::new(std::sync::atomic::AtomicBool::new(false)),
            last_modified: Arc::new(RwLock::new(HashMap::new())),
        }
    }

    /// Start watching for changes
    pub fn watch<F>(&self, callback: F)
    where
        F: Fn(FileEvent) + Send + Sync + 'static
    {
        self.running.store(true, std::sync::atomic::Ordering::SeqCst);

        let config = self.config.clone();
        let running = Arc::clone(&self.running);
        let last_modified = Arc::clone(&self.last_modified);
        let callback = Arc::new(callback);

        thread::spawn(move || {
            let poll_interval = Duration::from_millis(config.debounce_ms.max(50));

            while running.load(std::sync::atomic::Ordering::SeqCst) {
                for path in &config.paths {
                    Self::scan_directory(
                        path,
                        &config,
                        &last_modified,
                        &callback,
                    );
                }
                thread::sleep(poll_interval);
            }
        });
    }

    fn scan_directory<F>(
        path: &Path,
        config: &WatchConfig,
        last_modified: &Arc<RwLock<HashMap<PathBuf, SystemTime>>>,
        callback: &Arc<F>,
    ) where F: Fn(FileEvent) + Send + Sync
    {
        if !path.exists() {
            return;
        }

        // Check ignore patterns
        let path_str = path.to_string_lossy();
        for pattern in &config.ignore_patterns {
            if path_str.contains(pattern) {
                return;
            }
        }

        if path.is_file() {
            // Check extension
            if let Some(ext) = path.extension() {
                if config.extensions.contains(ext.to_string_lossy().as_ref()) {
                    Self::check_file(path, last_modified, callback);
                }
            }
        } else if path.is_dir() && config.recursive {
            if let Ok(entries) = fs::read_dir(path) {
                for entry in entries.flatten() {
                    Self::scan_directory(&entry.path(), config, last_modified, callback);
                }
            }
        }
    }

    fn check_file<F>(
        path: &Path,
        last_modified: &Arc<RwLock<HashMap<PathBuf, SystemTime>>>,
        callback: &Arc<F>,
    ) where F: Fn(FileEvent) + Send + Sync
    {
        if let Ok(metadata) = fs::metadata(path) {
            if let Ok(modified) = metadata.modified() {
                let mut cache = last_modified.write().unwrap();
                let path_buf = path.to_path_buf();

                if let Some(last) = cache.get(&path_buf) {
                    if modified > *last {
                        cache.insert(path_buf.clone(), modified);
                        callback(FileEvent::Modified(path_buf));
                    }
                } else {
                    cache.insert(path_buf.clone(), modified);
                    callback(FileEvent::Created(path_buf));
                }
            }
        }
    }

    /// Stop watching
    pub fn stop(&self) {
        self.running.store(false, std::sync::atomic::Ordering::SeqCst);
    }
}

