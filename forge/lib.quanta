// REMOTE DEBUGGER
// =============================================================================

/// Debug breakpoint
#[derive(Debug, Clone)]
pub struct Breakpoint {
    pub id: u32,
    pub file: PathBuf,
    pub line: u32,
    pub condition: Option<String>,
    pub hit_count: u32,
    pub enabled: bool,
}

/// Debug variable
#[derive(Debug, Clone)]
pub struct DebugVariable {
    pub name: String,
    pub value: String,
    pub type_name: String,
    pub children: Vec<DebugVariable>,
}

/// Debug stack frame
#[derive(Debug, Clone)]
pub struct DebugStackFrame {
    pub id: u32,
    pub function: String,
    pub file: Option<PathBuf>,
    pub line: Option<u32>,
    pub locals: Vec<DebugVariable>,
}

/// Debug thread state
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ThreadState {
    Running,
    Stopped,
    Suspended,
    Terminated,
}

/// Debug thread info
#[derive(Debug, Clone)]
pub struct DebugThread {
    pub id: u64,
    pub name: String,
    pub state: ThreadState,
    pub stack_frames: Vec<DebugStackFrame>,
}

/// Debug event
#[derive(Debug, Clone)]
pub enum DebugEvent {
    Stopped { thread_id: u64, reason: StopReason },
    Continued { thread_id: u64 },
    Breakpoint { breakpoint_id: u32, thread_id: u64 },
    Exception { thread_id: u64, message: String },
    Output { category: String, output: String },
    Terminated,
}

/// Reason for stopping
#[derive(Debug, Clone)]
pub enum StopReason {
    Breakpoint(u32),
    Step,
    Exception(String),
    Pause,
    Entry,
}

/// Debug command from client
#[derive(Debug, Clone)]
pub enum DebugCommand {
    Continue { thread_id: Option<u64> },
    Pause { thread_id: Option<u64> },
    StepOver { thread_id: u64 },
    StepInto { thread_id: u64 },
    StepOut { thread_id: u64 },
    SetBreakpoint { file: PathBuf, line: u32, condition: Option<String> },
    RemoveBreakpoint { id: u32 },
    GetThreads,
    GetStackTrace { thread_id: u64 },
    GetScopes { frame_id: u32 },
    GetVariables { scope_id: u32 },
    Evaluate { expression: String, frame_id: Option<u32> },
    Disconnect,
}

/// Debug response to client
#[derive(Debug, Clone)]
pub enum DebugResponse {
    Success,
    Threads(Vec<DebugThread>),
    StackTrace(Vec<DebugStackFrame>),
    Variables(Vec<DebugVariable>),
    Evaluated { result: String, type_name: String },
    Error(String),
}

/// Debug adapter protocol message types
#[derive(Debug)]
pub struct DapMessage {
    pub seq: u32,
    pub msg_type: String,
    pub command: Option<String>,
    pub body: HashMap<String, String>,
}

/// Remote debug server
pub struct DebugServer {
    address: String,
    port: u16,
    breakpoints: Arc<RwLock<Vec<Breakpoint>>>,
    threads: Arc<RwLock<Vec<DebugThread>>>,
    next_breakpoint_id: Arc<RwLock<u32>>,
    event_handlers: Arc<RwLock<Vec<Box<dyn Fn(DebugEvent) + Send + Sync>>>>,
    running: Arc<RwLock<bool>>,
}

impl DebugServer {
    pub fn new(address: &str, port: u16) -> Self {
        DebugServer {
            address: address.to_string(),
            port,
            breakpoints: Arc::new(RwLock::new(Vec::new())),
            threads: Arc::new(RwLock::new(Vec::new())),
            next_breakpoint_id: Arc::new(RwLock::new(1)),
            event_handlers: Arc::new(RwLock::new(Vec::new())),
            running: Arc::new(RwLock::new(false)),
        }
    }

    /// Register event handler
    pub fn on_event<F>(&self, handler: F)
    where
        F: Fn(DebugEvent) + Send + Sync + 'static,
    {
        self.event_handlers.write().unwrap().push(Box::new(handler));
    }

    /// Start the debug server
    pub fn start(&self) -> Result<(), String> {
        *self.running.write().unwrap() = true;

        log_info(&format!("Debug server listening on {}:{}", self.address, self.port));

        // In real implementation, would start TCP server here
        // For now, just log

        Ok(())
    }

    /// Stop the debug server
    pub fn stop(&self) {
        *self.running.write().unwrap() = false;
        log_info("Debug server stopped");
    }

    /// Handle debug command
    pub fn handle_command(&self, command: DebugCommand) -> DebugResponse {
        match command {
            DebugCommand::SetBreakpoint { file, line, condition } => {
                let mut id = self.next_breakpoint_id.write().unwrap();
                let bp = Breakpoint {
                    id: *id,
                    file,
                    line,
                    condition,
                    hit_count: 0,
                    enabled: true,
                };
                *id += 1;
                self.breakpoints.write().unwrap().push(bp);
                DebugResponse::Success
            }

            DebugCommand::RemoveBreakpoint { id } => {
                self.breakpoints.write().unwrap().retain(|bp| bp.id != id);
                DebugResponse::Success
            }

            DebugCommand::GetThreads => {
                let threads = self.threads.read().unwrap().clone();
                DebugResponse::Threads(threads)
            }

            DebugCommand::GetStackTrace { thread_id } => {
                let threads = self.threads.read().unwrap();
                if let Some(thread) = threads.iter().find(|t| t.id == thread_id) {
                    DebugResponse::StackTrace(thread.stack_frames.clone())
                } else {
                    DebugResponse::Error("Thread not found".to_string())
                }
            }

            DebugCommand::Evaluate { expression, frame_id: _ } => {
                // Simplified evaluation
                DebugResponse::Evaluated {
                    result: format!("<evaluation of '{}'>", expression),
                    type_name: "?".to_string(),
                }
            }

            DebugCommand::Continue { .. } => {
                self.emit_event(DebugEvent::Continued { thread_id: 0 });
                DebugResponse::Success
            }

            DebugCommand::Pause { .. } => {
                self.emit_event(DebugEvent::Stopped {
                    thread_id: 0,
                    reason: StopReason::Pause,
                });
                DebugResponse::Success
            }

            DebugCommand::StepOver { thread_id } |
            DebugCommand::StepInto { thread_id } |
            DebugCommand::StepOut { thread_id } => {
                self.emit_event(DebugEvent::Stopped {
                    thread_id,
                    reason: StopReason::Step,
                });
                DebugResponse::Success
            }

            DebugCommand::GetScopes { .. } |
            DebugCommand::GetVariables { .. } => {
                DebugResponse::Variables(Vec::new())
            }

            DebugCommand::Disconnect => {
                self.stop();
                DebugResponse::Success
            }
        }
    }

    /// Emit debug event
    fn emit_event(&self, event: DebugEvent) {
        let handlers = self.event_handlers.read().unwrap();
        for handler in handlers.iter() {
            handler(event.clone());
        }
    }

    /// Check if we should break at location
    pub fn should_break(&self, file: &Path, line: u32) -> Option<u32> {
        let breakpoints = self.breakpoints.read().unwrap();
        for bp in breakpoints.iter() {
            if bp.enabled && bp.file == file && bp.line == line {
                // Would evaluate condition here
                return Some(bp.id);
            }
        }
        None
    }

    /// Register a thread
    pub fn register_thread(&self, id: u64, name: String) {
        self.threads.write().unwrap().push(DebugThread {
            id,
            name,
            state: ThreadState::Running,
            stack_frames: Vec::new(),
        });
    }

    /// Update thread state
    pub fn update_thread_state(&self, id: u64, state: ThreadState) {
        if let Some(thread) = self.threads.write().unwrap().iter_mut().find(|t| t.id == id) {
            thread.state = state;
        }
    }

    /// List all breakpoints
    pub fn list_breakpoints(&self) -> Vec<Breakpoint> {
        self.breakpoints.read().unwrap().clone()
    }
}

/// Debug client for connecting to remote debugger
pub struct DebugClient {
    address: String,
    port: u16,
    connected: bool,
    seq: u32,
}

impl DebugClient {
    pub fn new(address: &str, port: u16) -> Self {
        DebugClient {
            address: address.to_string(),
            port,
            connected: false,
            seq: 0,
        }
    }

    /// Connect to debug server
    pub fn connect(&mut self) -> Result<(), String> {
        log_info(&format!("Connecting to debug server at {}:{}", self.address, self.port));
        // Would establish TCP connection in real implementation
        self.connected = true;
        Ok(())
    }

    /// Disconnect from debug server
    pub fn disconnect(&mut self) {
        self.connected = false;
        log_info("Disconnected from debug server");
    }

    /// Send command
    pub fn send_command(&mut self, command: DebugCommand) -> Result<DebugResponse, String> {
        if !self.connected {
            return Err("Not connected".to_string());
        }

        self.seq += 1;

        // Would serialize and send over TCP in real implementation
        log_debug(&format!("Sending command: {:?}", command));

        Ok(DebugResponse::Success)
    }

    /// Set a breakpoint
    pub fn set_breakpoint(&mut self, file: &Path, line: u32) -> Result<u32, String> {
        match self.send_command(DebugCommand::SetBreakpoint {
            file: file.to_path_buf(),
            line,
            condition: None,
        })? {
            DebugResponse::Success => Ok(self.seq),
            DebugResponse::Error(e) => Err(e),
            _ => Err("Unexpected response".to_string()),
        }
    }

    /// Continue execution
    pub fn continue_execution(&mut self) -> Result<(), String> {
        self.send_command(DebugCommand::Continue { thread_id: None })?;
        Ok(())
    }

    /// Pause execution
    pub fn pause(&mut self) -> Result<(), String> {
        self.send_command(DebugCommand::Pause { thread_id: None })?;
        Ok(())
    }

    /// Step over
    pub fn step_over(&mut self, thread_id: u64) -> Result<(), String> {
        self.send_command(DebugCommand::StepOver { thread_id })?;
        Ok(())
    }

    /// Step into
    pub fn step_into(&mut self, thread_id: u64) -> Result<(), String> {
        self.send_command(DebugCommand::StepInto { thread_id })?;
        Ok(())
    }

    /// Step out
    pub fn step_out(&mut self, thread_id: u64) -> Result<(), String> {
        self.send_command(DebugCommand::StepOut { thread_id })?;
        Ok(())
    }

    /// Get threads
    pub fn get_threads(&mut self) -> Result<Vec<DebugThread>, String> {
        match self.send_command(DebugCommand::GetThreads)? {
            DebugResponse::Threads(threads) => Ok(threads),
            DebugResponse::Error(e) => Err(e),
            _ => Err("Unexpected response".to_string()),
        }
    }

    /// Get stack trace
    pub fn get_stack_trace(&mut self, thread_id: u64) -> Result<Vec<DebugStackFrame>, String> {
        match self.send_command(DebugCommand::GetStackTrace { thread_id })? {
            DebugResponse::StackTrace(frames) => Ok(frames),
            DebugResponse::Error(e) => Err(e),
            _ => Err("Unexpected response".to_string()),
        }
    }

    /// Evaluate expression
    pub fn evaluate(&mut self, expression: &str, frame_id: Option<u32>) -> Result<(String, String), String> {
        match self.send_command(DebugCommand::Evaluate {
            expression: expression.to_string(),
            frame_id,
        })? {
            DebugResponse::Evaluated { result, type_name } => Ok((result, type_name)),
            DebugResponse::Error(e) => Err(e),
            _ => Err("Unexpected response".to_string()),
        }
    }
}

// =============================================================================
// PROFILER SYSTEM
// =============================================================================

/// Profiler types
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ProfilerType {
    CPU,
    Memory,
    IO,
    Network,
    All,
}

/// Sample data for profiling
#[derive(Debug, Clone)]
pub struct ProfileSample {
    pub timestamp: u64,
    pub thread_id: u64,
    pub stack: Vec<StackEntry>,
    pub cpu_time_ns: u64,
    pub memory_bytes: u64,
}

#[derive(Debug, Clone)]
pub struct StackEntry {
    pub function: String,
    pub file: String,
    pub line: u32,
    pub self_time_ns: u64,
    pub total_time_ns: u64,
}

/// CPU profiler using sampling
pub struct CPUProfiler {
    samples: Vec<ProfileSample>,
    sample_rate_hz: u32,
    is_running: bool,
    start_time: u64,
    thread_filter: Option<Vec<u64>>,
}

impl CPUProfiler {
    pub fn new(sample_rate_hz: u32) -> Self {
        Self {
            samples: Vec::new(),
            sample_rate_hz,
            is_running: false,
            start_time: 0,
            thread_filter: None,
        }
    }

    pub fn start(&mut self) {
        self.samples.clear();
        self.start_time = Self::current_time_ns();
        self.is_running = true;
    }

    pub fn stop(&mut self) {
        self.is_running = false;
    }

    pub fn add_sample(&mut self, sample: ProfileSample) {
        if self.is_running {
            if let Some(ref filter) = self.thread_filter {
                if !filter.contains(&sample.thread_id) {
                    return;
                }
            }
            self.samples.push(sample);
        }
    }

    fn current_time_ns() -> u64 {
        std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap_or_default()
            .as_nanos() as u64
    }

    pub fn generate_report(&self) -> ProfileReport {
        let mut function_stats: HashMap<String, FunctionStats> = HashMap::new();
        let total_samples = self.samples.len();

        for sample in &self.samples {
            for (depth, entry) in sample.stack.iter().enumerate() {
                let stats = function_stats.entry(entry.function.clone()).or_insert(FunctionStats {
                    function_name: entry.function.clone(),
                    file: entry.file.clone(),
                    line: entry.line,
                    self_time_ns: 0,
                    total_time_ns: 0,
                    call_count: 0,
                    sample_count: 0,
                });
                stats.sample_count += 1;
                stats.self_time_ns += entry.self_time_ns;
                stats.total_time_ns += entry.total_time_ns;
                if depth == 0 {
                    stats.call_count += 1;
                }
            }
        }

        let total_time = self.samples.iter().map(|s| s.cpu_time_ns).sum();
        let mut functions: Vec<_> = function_stats.into_values().collect();
        functions.sort_by(|a, b| b.self_time_ns.cmp(&a.self_time_ns));

        ProfileReport {
            profiler_type: ProfilerType::CPU,
            total_samples,
            total_time_ns: total_time,
            start_time: self.start_time,
            end_time: Self::current_time_ns(),
            functions,
            hotspots: self.find_hotspots(),
        }
    }

    fn find_hotspots(&self) -> Vec<Hotspot> {
        let mut hotspots = Vec::new();
        let mut location_counts: HashMap<(String, u32), u64> = HashMap::new();

        for sample in &self.samples {
            for entry in &sample.stack {
                let key = (entry.file.clone(), entry.line);
                *location_counts.entry(key).or_insert(0) += entry.self_time_ns;
            }
        }

        let mut sorted: Vec<_> = location_counts.into_iter().collect();
        sorted.sort_by(|a, b| b.1.cmp(&a.1));

        for ((file, line), time) in sorted.into_iter().take(10) {
            hotspots.push(Hotspot {
                file,
                line,
                time_ns: time,
                percentage: 0.0,
            });
        }

        let total: u64 = hotspots.iter().map(|h| h.time_ns).sum();
        for h in &mut hotspots {
            h.percentage = if total > 0 { h.time_ns as f64 / total as f64 * 100.0 } else { 0.0 };
        }

        hotspots
    }
}

#[derive(Debug, Clone)]
pub struct FunctionStats {
    pub function_name: String,
    pub file: String,
    pub line: u32,
    pub self_time_ns: u64,
    pub total_time_ns: u64,
    pub call_count: u64,
    pub sample_count: u64,
}

#[derive(Debug, Clone)]
pub struct Hotspot {
    pub file: String,
    pub line: u32,
    pub time_ns: u64,
    pub percentage: f64,
}

#[derive(Debug)]
pub struct ProfileReport {
    pub profiler_type: ProfilerType,
    pub total_samples: usize,
    pub total_time_ns: u64,
    pub start_time: u64,
    pub end_time: u64,
    pub functions: Vec<FunctionStats>,
    pub hotspots: Vec<Hotspot>,
}

impl ProfileReport {
    pub fn to_text(&self) -> String {
        let mut output = String::new();
        output.push_str(&format!("Profile Report ({:?})\n", self.profiler_type));
        output.push_str(&format!("Total samples: {}\n", self.total_samples));
        output.push_str(&format!("Total time: {:.2}ms\n\n", self.total_time_ns as f64 / 1_000_000.0));

        output.push_str("Top Functions by Self Time:\n");
        output.push_str("-".repeat(80).as_str());
        output.push('\n');
        for func in self.functions.iter().take(20) {
            let pct = if self.total_time_ns > 0 {
                func.self_time_ns as f64 / self.total_time_ns as f64 * 100.0
            } else { 0.0 };
            output.push_str(&format!("{:40} {:>8.2}ms ({:>5.1}%)\n",
                &func.function_name[..func.function_name.len().min(40)],
                func.self_time_ns as f64 / 1_000_000.0,
                pct
            ));
        }

        output.push_str("\nHotspots:\n");
        for h in &self.hotspots {
            output.push_str(&format!("  {}:{} - {:.2}ms ({:.1}%)\n",
                h.file, h.line, h.time_ns as f64 / 1_000_000.0, h.percentage));
        }

        output
    }
}

/// Memory profiler for tracking allocations
pub struct MemoryProfiler {
    allocations: HashMap<usize, AllocationRecord>,
    allocation_history: Vec<AllocationEvent>,
    peak_memory: u64,
    current_memory: u64,
    is_running: bool,
}

#[derive(Debug, Clone)]
pub struct AllocationRecord {
    pub address: usize,
    pub size: u64,
    pub stack: Vec<String>,
    pub timestamp: u64,
    pub thread_id: u64,
}

#[derive(Debug, Clone)]
pub struct AllocationEvent {
    pub event_type: AllocationType,
    pub address: usize,
    pub size: u64,
    pub timestamp: u64,
}

#[derive(Debug, Clone, Copy)]
pub enum AllocationType {
    Alloc,
    Realloc,
    Free,
}

impl MemoryProfiler {
    pub fn new() -> Self {
        Self {
            allocations: HashMap::new(),
            allocation_history: Vec::new(),
            peak_memory: 0,
            current_memory: 0,
            is_running: false,
        }
    }

    pub fn start(&mut self) {
        self.allocations.clear();
        self.allocation_history.clear();
        self.peak_memory = 0;
        self.current_memory = 0;
        self.is_running = true;
    }

    pub fn stop(&mut self) {
        self.is_running = false;
    }

    pub fn record_alloc(&mut self, address: usize, size: u64, stack: Vec<String>, thread_id: u64) {
        if !self.is_running { return; }

        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap_or_default()
            .as_nanos() as u64;

        self.allocations.insert(address, AllocationRecord {
            address, size, stack, timestamp: now, thread_id,
        });

        self.allocation_history.push(AllocationEvent {
            event_type: AllocationType::Alloc,
            address, size, timestamp: now,
        });

        self.current_memory += size;
        self.peak_memory = self.peak_memory.max(self.current_memory);
    }

    pub fn record_free(&mut self, address: usize) {
        if !self.is_running { return; }

        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap_or_default()
            .as_nanos() as u64;

        if let Some(record) = self.allocations.remove(&address) {
            self.current_memory = self.current_memory.saturating_sub(record.size);
            self.allocation_history.push(AllocationEvent {
                event_type: AllocationType::Free,
                address,
                size: record.size,
                timestamp: now,
            });
        }
    }

    pub fn find_leaks(&self) -> Vec<&AllocationRecord> {
        self.allocations.values().collect()
    }

    pub fn generate_report(&self) -> MemoryReport {
        let mut allocations_by_stack: HashMap<String, (u64, u64)> = HashMap::new();

        for record in self.allocations.values() {
            let key = record.stack.join(" <- ");
            let entry = allocations_by_stack.entry(key).or_insert((0, 0));
            entry.0 += 1;
            entry.1 += record.size;
        }

        let mut top_allocators: Vec<_> = allocations_by_stack.into_iter()
            .map(|(stack, (count, size))| (stack, count, size))
            .collect();
        top_allocators.sort_by(|a, b| b.2.cmp(&a.2));

        MemoryReport {
            peak_memory: self.peak_memory,
            current_memory: self.current_memory,
            total_allocations: self.allocation_history.iter()
                .filter(|e| matches!(e.event_type, AllocationType::Alloc))
                .count() as u64,
            live_allocations: self.allocations.len() as u64,
            potential_leaks: self.allocations.len() as u64,
            top_allocators: top_allocators.into_iter().take(10).collect(),
        }
    }
}

#[derive(Debug)]
pub struct MemoryReport {
    pub peak_memory: u64,
    pub current_memory: u64,
    pub total_allocations: u64,
    pub live_allocations: u64,
    pub potential_leaks: u64,
    pub top_allocators: Vec<(String, u64, u64)>,
}

impl MemoryReport {
    pub fn to_text(&self) -> String {
        let mut output = String::new();
        output.push_str("Memory Profile Report\n");
        output.push_str("=".repeat(60).as_str());
        output.push('\n');
        output.push_str(&format!("Peak memory:        {} KB\n", self.peak_memory / 1024));
        output.push_str(&format!("Current memory:     {} KB\n", self.current_memory / 1024));
        output.push_str(&format!("Total allocations:  {}\n", self.total_allocations));
        output.push_str(&format!("Live allocations:   {}\n", self.live_allocations));
        output.push_str(&format!("Potential leaks:    {}\n\n", self.potential_leaks));

        output.push_str("Top Allocators:\n");
        for (stack, count, size) in &self.top_allocators {
            output.push_str(&format!("  {} allocs, {} KB\n", count, size / 1024));
            output.push_str(&format!("    {}\n", stack));
        }

        output
    }
}

/// Flame graph generator
pub struct FlameGraphGenerator {
    stacks: Vec<(Vec<String>, u64)>,
}

impl FlameGraphGenerator {
    pub fn new() -> Self {
        Self { stacks: Vec::new() }
    }

    pub fn add_stack(&mut self, stack: Vec<String>, count: u64) {
        self.stacks.push((stack, count));
    }

    pub fn from_profile(report: &ProfileReport) -> Self {
        let mut gen = Self::new();
        for func in &report.functions {
            gen.add_stack(vec![func.function_name.clone()], func.sample_count);
        }
        gen
    }

    pub fn generate_svg(&self, width: u32, height: u32) -> String {
        let mut svg = String::new();
        svg.push_str(&format!(r#"<svg xmlns="http://www.w3.org/2000/svg" width="{}" height="{}">"#, width, height));
        svg.push_str("\n<style>");
        svg.push_str("rect { stroke: #333; stroke-width: 0.5; }");
        svg.push_str("text { font-family: monospace; font-size: 10px; }");
        svg.push_str("</style>\n");

        let total_samples: u64 = self.stacks.iter().map(|(_, c)| c).sum();
        if total_samples == 0 {
            svg.push_str("</svg>");
            return svg;
        }

        let bar_height = 18;
        let mut y = height - bar_height;
        let mut x = 0;

        for (stack, count) in &self.stacks {
            let w = (*count as f64 / total_samples as f64 * width as f64) as u32;
            if w == 0 { continue; }

            let color = self.hash_color(&stack.join(";"));
            svg.push_str(&format!(
                r#"<rect x="{}" y="{}" width="{}" height="{}" fill="{}" />"#,
                x, y, w, bar_height, color
            ));

            if w > 30 {
                let label = if stack.is_empty() { "root" } else { &stack[stack.len() - 1] };
                let label_trunc = if label.len() > (w / 7) as usize {
                    &label[..((w / 7) as usize).saturating_sub(2)]
                } else {
                    label
                };
                svg.push_str(&format!(
                    r#"<text x="{}" y="{}" fill="#000">{}</text>"#,
                    x + 2, y + 13, label_trunc
                ));
            }

            x += w;
        }

        svg.push_str("\n</svg>");
        svg
    }

    fn hash_color(&self, s: &str) -> String {
        let mut h: u32 = 0;
        for b in s.bytes() {
            h = h.wrapping_mul(31).wrapping_add(b as u32);
        }
        let r = 200 + (h % 55);
        let g = 100 + ((h >> 8) % 100);
        let b = 50 + ((h >> 16) % 50);
        format!("rgb({},{},{})", r, g, b)
    }
}

// =============================================================================
// CODE COVERAGE
// =============================================================================

/// Coverage data for a file
#[derive(Debug, Clone)]
pub struct FileCoverage {
    pub file_path: PathBuf,
    pub total_lines: u32,
    pub covered_lines: u32,
    pub line_coverage: HashMap<u32, u32>,  // line -> hit count
    pub branch_coverage: HashMap<u32, (u32, u32)>,  // branch_id -> (taken, not_taken)
}

/// Coverage report for the project
#[derive(Debug)]
pub struct CoverageReport {
    pub files: Vec<FileCoverage>,
    pub total_lines: u32,
    pub covered_lines: u32,
    pub total_branches: u32,
    pub covered_branches: u32,
}

impl CoverageReport {
    pub fn line_percentage(&self) -> f64 {
        if self.total_lines == 0 { return 0.0; }
        self.covered_lines as f64 / self.total_lines as f64 * 100.0
    }

    pub fn branch_percentage(&self) -> f64 {
        if self.total_branches == 0 { return 0.0; }
        self.covered_branches as f64 / self.total_branches as f64 * 100.0
    }

    pub fn to_text(&self) -> String {
        let mut output = String::new();
        output.push_str("Coverage Report\n");
        output.push_str("=".repeat(70).as_str());
        output.push('\n');
        output.push_str(&format!("Line Coverage:   {:.1}% ({}/{})\n",
            self.line_percentage(), self.covered_lines, self.total_lines));
        output.push_str(&format!("Branch Coverage: {:.1}% ({}/{})\n\n",
            self.branch_percentage(), self.covered_branches, self.total_branches));

        output.push_str("File Coverage:\n");
        output.push_str("-".repeat(70).as_str());
        output.push('\n');

        for file in &self.files {
            let pct = if file.total_lines == 0 { 0.0 }
                else { file.covered_lines as f64 / file.total_lines as f64 * 100.0 };
            let bar_len = (pct / 5.0) as usize;
            let bar = "#".repeat(bar_len) + &" ".repeat(20 - bar_len);
            output.push_str(&format!("{:40} [{bar}] {:>5.1}%\n",
                file.file_path.file_name().unwrap_or_default().to_string_lossy(),
                pct));
        }

        output
    }

    pub fn to_lcov(&self) -> String {
        let mut output = String::new();
        for file in &self.files {
            output.push_str(&format!("SF:{}\n", file.file_path.display()));
            for (line, count) in &file.line_coverage {
                output.push_str(&format!("DA:{},{}\n", line, count));
            }
            output.push_str(&format!("LF:{}\n", file.total_lines));
            output.push_str(&format!("LH:{}\n", file.covered_lines));
            output.push_str("end_of_record\n");
        }
        output
    }

    pub fn to_html(&self) -> String {
        let mut html = String::new();
        html.push_str("<!DOCTYPE html><html><head><title>Coverage Report</title>");
        html.push_str("<style>");
        html.push_str("body { font-family: sans-serif; margin: 20px; }");
        html.push_str("table { border-collapse: collapse; width: 100%; }");
        html.push_str("th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }");
        html.push_str("th { background: #4CAF50; color: white; }");
        html.push_str(".low { background: #ffcccc; }");
        html.push_str(".medium { background: #ffffcc; }");
        html.push_str(".high { background: #ccffcc; }");
        html.push_str(".progress { background: #ddd; height: 20px; border-radius: 4px; }");
        html.push_str(".progress-bar { background: #4CAF50; height: 100%; border-radius: 4px; }");
        html.push_str("</style></head><body>");
        html.push_str("<h1>Coverage Report</h1>");

        html.push_str(&format!("<p>Line Coverage: <strong>{:.1}%</strong> ({}/{})</p>",
            self.line_percentage(), self.covered_lines, self.total_lines));
        html.push_str(&format!("<p>Branch Coverage: <strong>{:.1}%</strong> ({}/{})</p>",
            self.branch_percentage(), self.covered_branches, self.total_branches));

        html.push_str("<table><tr><th>File</th><th>Lines</th><th>Coverage</th><th>Visual</th></tr>");
        for file in &self.files {
            let pct = if file.total_lines == 0 { 0.0 }
                else { file.covered_lines as f64 / file.total_lines as f64 * 100.0 };
            let class = if pct < 50.0 { "low" } else if pct < 80.0 { "medium" } else { "high" };
            html.push_str(&format!("<tr class='{}'><td>{}</td><td>{}/{}</td><td>{:.1}%</td>",
                class,
                file.file_path.display(),
                file.covered_lines, file.total_lines,
                pct));
            html.push_str(&format!("<td><div class='progress'><div class='progress-bar' style='width: {}%'></div></div></td></tr>",
                pct as i32));
        }
        html.push_str("</table></body></html>");
        html
    }
}

/// Coverage collector
pub struct CoverageCollector {
    files: HashMap<PathBuf, FileCoverage>,
    is_running: bool,
}

impl CoverageCollector {
    pub fn new() -> Self {
        Self {
            files: HashMap::new(),
            is_running: false,
        }
    }

    pub fn start(&mut self) {
        self.files.clear();
        self.is_running = true;
    }

    pub fn stop(&mut self) {
        self.is_running = false;
    }

    pub fn register_file(&mut self, path: PathBuf, total_lines: u32) {
        self.files.insert(path.clone(), FileCoverage {
            file_path: path,
            total_lines,
            covered_lines: 0,
            line_coverage: HashMap::new(),
            branch_coverage: HashMap::new(),
        });
    }

    pub fn record_line(&mut self, file: &Path, line: u32) {
        if !self.is_running { return; }
        if let Some(fc) = self.files.get_mut(file) {
            let count = fc.line_coverage.entry(line).or_insert(0);
            if *count == 0 {
                fc.covered_lines += 1;
            }
            *count += 1;
        }
    }

    pub fn record_branch(&mut self, file: &Path, branch_id: u32, taken: bool) {
        if !self.is_running { return; }
        if let Some(fc) = self.files.get_mut(file) {
            let entry = fc.branch_coverage.entry(branch_id).or_insert((0, 0));
            if taken {
                entry.0 += 1;
            } else {
                entry.1 += 1;
            }
        }
    }

    pub fn generate_report(&self) -> CoverageReport {
        let files: Vec<_> = self.files.values().cloned().collect();
        let total_lines: u32 = files.iter().map(|f| f.total_lines).sum();
        let covered_lines: u32 = files.iter().map(|f| f.covered_lines).sum();
        let total_branches: u32 = files.iter().map(|f| f.branch_coverage.len() as u32).sum();
        let covered_branches: u32 = files.iter()
            .flat_map(|f| f.branch_coverage.values())
            .filter(|(t, n)| *t > 0 && *n > 0)
            .count() as u32;

        CoverageReport {
            files,
            total_lines,
            covered_lines,
            total_branches,
            covered_branches,
        }
    }
}

// =============================================================================
// DEPENDENCY ANALYZER
// =============================================================================

/// Dependency node
#[derive(Debug, Clone)]
pub struct DepNode {
    pub name: String,
    pub version: String,
    pub source: DepSource,
    pub dependencies: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum DepSource {
    Registry(String),
    Git { url: String, rev: Option<String> },
    Path(PathBuf),
}

/// Dependency analyzer
pub struct DependencyAnalyzer {
    nodes: HashMap<String, DepNode>,
    circular_deps: Vec<Vec<String>>,
}

impl DependencyAnalyzer {
    pub fn new() -> Self {
        Self {
            nodes: HashMap::new(),
            circular_deps: Vec::new(),
        }
    }

    pub fn add_dependency(&mut self, node: DepNode) {
        self.nodes.insert(node.name.clone(), node);
    }

    pub fn detect_cycles(&mut self) {
        self.circular_deps.clear();
        let mut visited = HashSet::new();
        let mut rec_stack = HashSet::new();
        let mut path = Vec::new();

        for name in self.nodes.keys().cloned().collect::<Vec<_>>() {
            if !visited.contains(&name) {
                self.dfs_cycle(&name, &mut visited, &mut rec_stack, &mut path);
            }
        }
    }

    fn dfs_cycle(&mut self, node: &str, visited: &mut HashSet<String>,
                 rec_stack: &mut HashSet<String>, path: &mut Vec<String>) {
        visited.insert(node.to_string());
        rec_stack.insert(node.to_string());
        path.push(node.to_string());

        if let Some(n) = self.nodes.get(node) {
            for dep in n.dependencies.clone() {
                if !visited.contains(&dep) {
                    self.dfs_cycle(&dep, visited, rec_stack, path);
                } else if rec_stack.contains(&dep) {
                    let start = path.iter().position(|x| x == &dep).unwrap_or(0);
                    let cycle: Vec<_> = path[start..].to_vec();
                    self.circular_deps.push(cycle);
                }
            }
        }

        path.pop();
        rec_stack.remove(node);
    }

    pub fn find_unused(&self, used: &HashSet<String>) -> Vec<&DepNode> {
        self.nodes.values()
            .filter(|n| !used.contains(&n.name))
            .collect()
    }

    pub fn find_duplicates(&self) -> HashMap<String, Vec<String>> {
        let mut name_versions: HashMap<String, Vec<String>> = HashMap::new();
        for node in self.nodes.values() {
            let base_name = node.name.split('@').next().unwrap_or(&node.name);
            name_versions.entry(base_name.to_string())
                .or_default()
                .push(node.version.clone());
        }
        name_versions.into_iter()
            .filter(|(_, versions)| versions.len() > 1)
            .collect()
    }

    pub fn generate_tree(&self, root: &str, depth: usize) -> String {
        let mut output = String::new();
        self.build_tree(&mut output, root, 0, depth, &mut HashSet::new());
        output
    }

    fn build_tree(&self, output: &mut String, name: &str, level: usize, max_depth: usize, seen: &mut HashSet<String>) {
        if level > max_depth || seen.contains(name) {
            return;
        }
        seen.insert(name.to_string());

        let indent = "  ".repeat(level);
        let prefix = if level == 0 { "" } else { "├─ " };

        if let Some(node) = self.nodes.get(name) {
            output.push_str(&format!("{}{}{} v{}\n", indent, prefix, node.name, node.version));
            for dep in &node.dependencies {
                self.build_tree(output, dep, level + 1, max_depth, seen);
            }
        }
    }

    pub fn to_graphviz(&self) -> String {
        let mut dot = String::from("digraph dependencies {\n");
        dot.push_str("  rankdir=LR;\n");
        dot.push_str("  node [shape=box];\n");

        for node in self.nodes.values() {
            dot.push_str(&format!("  \"{}\" [label=\"{}\\n{}\"];\n",
                node.name, node.name, node.version));
            for dep in &node.dependencies {
                dot.push_str(&format!("  \"{}\" -> \"{}\";\n", node.name, dep));
            }
        }

        dot.push_str("}\n");
        dot
    }
}

// =============================================================================
// AST VISUALIZATION
// =============================================================================

enum AstNodeKind { Module, Function, Struct, Enum, Trait, Impl, Statement, Expression, Type, Pattern }

struct AstNode {
    kind: AstNodeKind,
    name: Option<string>,
    span: Span,
    children: [AstNode],
    attributes: HashMap<string, string>
}

struct Span { start: usize, end: usize, line: usize, column: usize }

struct AstVisualizer {
    root: Option<AstNode>,
    theme: VisualizationTheme,
    max_depth: usize
}

struct VisualizationTheme {
    function_color: string,
    struct_color: string,
    expression_color: string,
    statement_color: string
}

impl AstVisualizer {
    fn new() -> AstVisualizer {
        AstVisualizer {
            root: None, max_depth: 10,
            theme: VisualizationTheme {
                function_color: "#4CAF50".into(), struct_color: "#2196F3".into(),
                expression_color: "#FF9800".into(), statement_color: "#9C27B0".into()
            }
        }
    }

    fn parse_and_visualize(mut self, source: string) -> string {
        self.root = Some(self.parse_to_ast(&source));
        self.to_html()
    }

    fn parse_to_ast(self, source: string) -> AstNode {
        AstNode { kind: AstNodeKind::Module, name: Some("root".into()), span: Span { start: 0, end: source.len(), line: 1, column: 1 }, children: vec![], attributes: HashMap::new() }
    }

    fn to_html(self) -> string {
        let mut html = String::from("<!DOCTYPE html><html><head><style>");
        html.push_str(".node { margin-left: 20px; border-left: 2px solid #ccc; padding-left: 10px; }");
        html.push_str(".function { color: "); html.push_str(&self.theme.function_color); html.push_str("; }");
        html.push_str("</style></head><body>");
        if let Some(ref root) = self.root {
            self.render_node(&mut html, root, 0);
        }
        html.push_str("</body></html>");
        html
    }

    fn render_node(self, html: mut string, node: AstNode, depth: usize) {
        if depth > self.max_depth { return; }
        let class = match node.kind {
            Function => "function", Struct => "struct", Expression => "expression", _ => "statement"
        };
        html.push_str(&format!("<div class='node {}'>{:?}", class, node.kind));
        if let Some(ref name) = node.name { html.push_str(&format!(" <b>{}</b>", name)); }
        html.push_str("</div>");
        for child in node.children.iter() { self.render_node(html, child.clone(), depth + 1); }
    }

    fn to_json(self) -> string {
        if let Some(ref root) = self.root { self.node_to_json(root) }
        else { "{}".into() }
    }

    fn node_to_json(self, node: AstNode) -> string {
        let children: Vec<_> = node.children.iter().map(|c| self.node_to_json(c)).collect();
        format!(r#"{{"kind":"{:?}","name":{:?},"span":{{"start":{},"end":{}}},"children":[{}]}}"#,
            node.kind, node.name, node.span.start, node.span.end, children.join(","))
    }
}

// =============================================================================
// REFACTORING TOOLS
// =============================================================================

enum RefactorKind { Rename, ExtractFunction, ExtractVariable, InlineVariable, InlineFunction, MoveToModule, ChangeSignature }

struct RefactorRequest {
    kind: RefactorKind,
    target_span: Span,
    new_name: Option<string>,
    parameters: HashMap<string, string>
}

struct RefactorResult { success: bool, edits: [TextEdit], diagnostics: [string] }
struct TextEdit { span: Span, new_text: string }

struct Refactorer {
    source: string,
    symbol_table: SymbolTable
}

struct SymbolTable {
    symbols: HashMap<string, SymbolInfo>,
    scopes: [Scope]
}

struct SymbolInfo { name: string, kind: SymbolKind, span: Span, references: [Span] }
enum SymbolKind { Variable, Function, Type, Module, Constant, Parameter }
struct Scope { parent: Option<usize>, symbols: [string], span: Span }

impl Refactorer {
    fn new(source: string) -> Refactorer {
        let mut r = Refactorer { source: source.clone(), symbol_table: SymbolTable { symbols: HashMap::new(), scopes: vec![] } };
        r.build_symbol_table();
        r
    }

    fn build_symbol_table(mut self) { /* Parse and build symbols */ }

    fn apply(self, request: RefactorRequest) -> RefactorResult {
        match request.kind {
            Rename => self.rename(request.target_span, request.new_name.unwrap_or_default()),
            ExtractFunction => self.extract_function(request.target_span, request.new_name.unwrap_or("extracted".into())),
            ExtractVariable => self.extract_variable(request.target_span, request.new_name.unwrap_or("extracted".into())),
            InlineVariable => self.inline_variable(request.target_span),
            InlineFunction => self.inline_function(request.target_span),
            MoveToModule => self.move_to_module(request.target_span, request.parameters.get("target").cloned().unwrap_or_default()),
            ChangeSignature => self.change_signature(request.target_span, request.parameters.clone())
        }
    }

    fn rename(self, span: Span, new_name: string) -> RefactorResult {
        let symbol_at = self.find_symbol_at(span);
        if symbol_at.is_none() { return RefactorResult { success: false, edits: vec![], diagnostics: vec!["No symbol at location".into()] }; }
        let symbol = symbol_at.unwrap();
        let mut edits = vec![TextEdit { span: symbol.span.clone(), new_text: new_name.clone() }];
        for ref_span in symbol.references.iter() {
            edits.push(TextEdit { span: ref_span.clone(), new_text: new_name.clone() });
        }
        RefactorResult { success: true, edits: edits, diagnostics: vec![] }
    }

    fn extract_function(self, span: Span, name: string) -> RefactorResult {
        let code = &self.source[span.start..span.end];
        let free_vars = self.find_free_variables(span.clone());
        let params: Vec<_> = free_vars.iter().map(|v| format!("{}: _", v)).collect();
        let call_args = free_vars.join(", ");
        let new_fn = format!("fn {}({}) {{\n    {}\n}}\n", name, params.join(", "), code);
        let call = format!("{}({})", name, call_args);
        RefactorResult {
            success: true,
            edits: vec![
                TextEdit { span: span.clone(), new_text: call },
                TextEdit { span: Span { start: 0, end: 0, line: 1, column: 1 }, new_text: new_fn }
            ],
            diagnostics: vec![]
        }
    }

    fn extract_variable(self, span: Span, name: string) -> RefactorResult {
        let expr = &self.source[span.start..span.end];
        let decl = format!("let {} = {};\n", name, expr);
        RefactorResult {
            success: true,
            edits: vec![
                TextEdit { span: Span { start: span.start, end: span.start, line: span.line, column: 1 }, new_text: decl },
                TextEdit { span: span, new_text: name }
            ],
            diagnostics: vec![]
        }
    }

    fn inline_variable(self, span: Span) -> RefactorResult {
        let symbol = self.find_symbol_at(span.clone());
        if symbol.is_none() { return RefactorResult { success: false, edits: vec![], diagnostics: vec!["Not a variable".into()] }; }
        let sym = symbol.unwrap();
        let value = self.find_initializer(sym.span.clone());
        let mut edits = vec![];
        for ref_span in sym.references.iter() {
            edits.push(TextEdit { span: ref_span.clone(), new_text: value.clone() });
        }
        RefactorResult { success: true, edits: edits, diagnostics: vec![] }
    }

    fn inline_function(self, span: Span) -> RefactorResult {
        RefactorResult { success: true, edits: vec![], diagnostics: vec!["Function inlining not yet implemented".into()] }
    }

    fn move_to_module(self, span: Span, target: string) -> RefactorResult {
        let code = &self.source[span.start..span.end];
        RefactorResult {
            success: true,
            edits: vec![TextEdit { span: span, new_text: format!("use {}::*;\n", target) }],
            diagnostics: vec![format!("Move code to {}.quanta", target)]
        }
    }

    fn change_signature(self, span: Span, params: HashMap<string, string>) -> RefactorResult {
        RefactorResult { success: true, edits: vec![], diagnostics: vec!["Signature change requires manual review".into()] }
    }

    fn find_symbol_at(self, span: Span) -> Option<SymbolInfo> { self.symbol_table.symbols.values().find(|s| s.span.start <= span.start && s.span.end >= span.end).cloned() }
    fn find_free_variables(self, span: Span) -> [string] { vec![] }
    fn find_initializer(self, span: Span) -> string { "/* value */".into() }
}

// =============================================================================
// SYMBOL INDEX
// =============================================================================

struct SymbolIndex {
    entries: HashMap<string, [IndexEntry]>,
    by_file: HashMap<string, [string]>,
    by_kind: HashMap<SymbolKind, [string]>
}

struct IndexEntry {
    name: string,
    qualified_name: string,
    kind: SymbolKind,
    file: string,
    span: Span,
    signature: Option<string>,
    doc_comment: Option<string>
}

impl SymbolIndex {
    fn new() -> SymbolIndex {
        SymbolIndex { entries: HashMap::new(), by_file: HashMap::new(), by_kind: HashMap::new() }
    }

    fn index_file(mut self, path: string, source: string) {
        let symbols = self.extract_symbols(&source);
        for sym in symbols {
            let name = sym.name.clone();
            self.entries.entry(name.clone()).or_default().push(sym.clone());
            self.by_file.entry(path.clone()).or_default().push(name.clone());
            self.by_kind.entry(sym.kind.clone()).or_default().push(name);
        }
    }

    fn extract_symbols(self, source: string) -> [IndexEntry] {
        let mut symbols = vec![];
        // Pattern-based extraction
        for (i, line) in source.lines().enumerate() {
            if line.starts_with("fn ") {
                let name = line[3..].split('(').next().unwrap_or("").trim().to_string();
                symbols.push(IndexEntry {
                    name: name.clone(), qualified_name: name.clone(), kind: SymbolKind::Function,
                    file: "".into(), span: Span { start: 0, end: line.len(), line: i + 1, column: 1 },
                    signature: Some(line.to_string()), doc_comment: None
                });
            } else if line.starts_with("struct ") {
                let name = line[7..].split('{').next().unwrap_or("").split('<').next().unwrap_or("").trim().to_string();
                symbols.push(IndexEntry {
                    name: name.clone(), qualified_name: name.clone(), kind: SymbolKind::Type,
                    file: "".into(), span: Span { start: 0, end: line.len(), line: i + 1, column: 1 },
                    signature: None, doc_comment: None
                });
            }
        }
        symbols
    }

    fn find(self, query: string) -> [IndexEntry] {
        let mut results = vec![];
        for (name, entries) in self.entries.iter() {
            if name.contains(&query) { results.extend(entries.clone()); }
        }
        results.sort_by(|a, b| a.name.cmp(&b.name));
        results
    }

    fn find_by_prefix(self, prefix: string) -> [IndexEntry] {
        self.entries.iter().filter(|(k, _)| k.starts_with(&prefix)).flat_map(|(_, v)| v.clone()).collect()
    }

    fn find_references(self, symbol: string) -> [Span] { vec![] }

    fn get_definition(self, symbol: string) -> Option<IndexEntry> {
        self.entries.get(&symbol).and_then(|e| e.first().cloned())
    }
}

// =============================================================================
// DIFF/PATCH TOOLS
// =============================================================================

enum DiffOp { Equal(string), Insert(string), Delete(string), Replace(string, string) }

struct DiffResult { ops: [DiffOp], stats: DiffStats }
struct DiffStats { additions: usize, deletions: usize, changes: usize }

struct Differ {
    context_lines: usize,
    ignore_whitespace: bool,
    algorithm: DiffAlgorithm
}

enum DiffAlgorithm { Myers, Patience, Histogram }

impl Differ {
    fn new() -> Differ { Differ { context_lines: 3, ignore_whitespace: false, algorithm: DiffAlgorithm::Myers } }

    fn diff(self, old: string, new: string) -> DiffResult {
        let old_lines: Vec<_> = old.lines().collect();
        let new_lines: Vec<_> = new.lines().collect();
        let lcs = self.longest_common_subsequence(&old_lines, &new_lines);
        let ops = self.build_ops(&old_lines, &new_lines, &lcs);
        let stats = DiffStats {
            additions: ops.iter().filter(|o| matches!(o, Insert(_))).count(),
            deletions: ops.iter().filter(|o| matches!(o, Delete(_))).count(),
            changes: ops.iter().filter(|o| matches!(o, Replace(_, _))).count()
        };
        DiffResult { ops: ops, stats: stats }
    }

    fn longest_common_subsequence(self, a: [string], b: [string]) -> [[usize]] {
        let m = a.len(); let n = b.len();
        let mut dp = vec![vec![0usize; n + 1]; m + 1];
        for i in 1..=m {
            for j in 1..=n {
                if a[i-1] == b[j-1] { dp[i][j] = dp[i-1][j-1] + 1; }
                else { dp[i][j] = dp[i-1][j].max(dp[i][j-1]); }
            }
        }
        dp
    }

    fn build_ops(self, old: [string], new: [string], lcs: [[usize]]) -> [DiffOp] {
        let mut ops = vec![];
        let (mut i, mut j) = (old.len(), new.len());
        while i > 0 || j > 0 {
            if i > 0 && j > 0 && old[i-1] == new[j-1] {
                ops.insert(0, DiffOp::Equal(old[i-1].to_string()));
                i -= 1; j -= 1;
            } else if j > 0 && (i == 0 || lcs[i][j-1] >= lcs[i-1][j]) {
                ops.insert(0, DiffOp::Insert(new[j-1].to_string()));
                j -= 1;
            } else if i > 0 {
                ops.insert(0, DiffOp::Delete(old[i-1].to_string()));
                i -= 1;
            }
        }
        ops
    }

    fn to_unified(self, diff: DiffResult, old_name: string, new_name: string) -> string {
        let mut output = format!("--- {}\n+++ {}\n", old_name, new_name);
        for op in diff.ops.iter() {
            match op {
                Equal(s) => output.push_str(&format!(" {}\n", s)),
                Insert(s) => output.push_str(&format!("+{}\n", s)),
                Delete(s) => output.push_str(&format!("-{}\n", s)),
                Replace(o, n) => { output.push_str(&format!("-{}\n+{}\n", o, n)); }
            }
        }
        output
    }
}

struct Patcher { strict_mode: bool }

impl Patcher {
    fn new() -> Patcher { Patcher { strict_mode: false } }

    fn apply(self, original: string, patch: string) -> Result<string, string> {
        let hunks = self.parse_patch(&patch);
        let mut lines: Vec<_> = original.lines().map(String::from).collect();
        for hunk in hunks.iter().rev() {
            self.apply_hunk(&mut lines, hunk)?;
        }
        Ok(lines.join("\n"))
    }

    fn parse_patch(self, patch: string) -> [PatchHunk] {
        let mut hunks = vec![];
        let mut current_hunk: Option<PatchHunk> = None;
        for line in patch.lines() {
            if line.starts_with("@@") {
                if let Some(h) = current_hunk.take() { hunks.push(h); }
                current_hunk = Some(PatchHunk { old_start: 0, old_count: 0, new_start: 0, new_count: 0, lines: vec![] });
            } else if let Some(ref mut hunk) = current_hunk {
                hunk.lines.push(line.to_string());
            }
        }
        if let Some(h) = current_hunk { hunks.push(h); }
        hunks
    }

    fn apply_hunk(self, lines: mut [string], hunk: PatchHunk) -> Result<(), string> {
        let start = hunk.old_start.saturating_sub(1);
        let mut new_lines = vec![];
        for line in hunk.lines.iter() {
            if line.starts_with('+') { new_lines.push(line[1..].to_string()); }
            else if !line.starts_with('-') { new_lines.push(line.get(1..).unwrap_or(line).to_string()); }
        }
        lines.splice(start..start + hunk.old_count, new_lines);
        Ok(())
    }
}

struct PatchHunk { old_start: usize, old_count: usize, new_start: usize, new_count: usize, lines: [string] }

// =============================================================================
// LINT ENGINE
// =============================================================================

enum Severity { Error, Warning, Info, Hint }

struct LintDiagnostic {
    rule: string,
    message: string,
    severity: Severity,
    span: Span,
    fix: Option<TextEdit>
}

trait LintRule { fn name(self) -> string; fn check(self, source: string) -> [LintDiagnostic]; }

struct LintEngine {
    rules: [Box<dyn LintRule>],
    config: LintConfig
}

struct LintConfig {
    enabled_rules: HashSet<string>,
    disabled_rules: HashSet<string>,
    severity_overrides: HashMap<string, Severity>
}

impl LintEngine {
    fn new() -> LintEngine {
        let mut engine = LintEngine { rules: vec![], config: LintConfig { enabled_rules: HashSet::new(), disabled_rules: HashSet::new(), severity_overrides: HashMap::new() } };
        engine.register_default_rules();
        engine
    }

    fn register_default_rules(mut self) {
        self.rules.push(Box::new(UnusedVariableRule {}));
        self.rules.push(Box::new(UnreachableCodeRule {}));
        self.rules.push(Box::new(NamingConventionRule {}));
        self.rules.push(Box::new(ComplexityRule { max_complexity: 10 }));
        self.rules.push(Box::new(LineLengthRule { max_length: 120 }));
    }

    fn lint(self, source: string) -> [LintDiagnostic] {
        let mut diagnostics = vec![];
        for rule in self.rules.iter() {
            if self.config.disabled_rules.contains(&rule.name()) { continue; }
            let mut rule_diags = rule.check(source.clone());
            for diag in rule_diags.iter_mut() {
                if let Some(sev) = self.config.severity_overrides.get(&diag.rule) {
                    diag.severity = sev.clone();
                }
            }
            diagnostics.extend(rule_diags);
        }
        diagnostics.sort_by_key(|d| d.span.start);
        diagnostics
    }

    fn fix_all(self, source: string) -> string {
        let diagnostics = self.lint(source.clone());
        let mut result = source;
        for diag in diagnostics.iter().rev() {
            if let Some(ref fix) = diag.fix {
                result = format!("{}{}{}", &result[..fix.span.start], fix.new_text, &result[fix.span.end..]);
            }
        }
        result
    }
}

struct UnusedVariableRule {}
impl LintRule for UnusedVariableRule {
    fn name(self) -> string { "unused-variable".into() }
    fn check(self, source: string) -> [LintDiagnostic] { vec![] }
}

struct UnreachableCodeRule {}
impl LintRule for UnreachableCodeRule {
    fn name(self) -> string { "unreachable-code".into() }
    fn check(self, source: string) -> [LintDiagnostic] { vec![] }
}

struct NamingConventionRule {}
impl LintRule for NamingConventionRule {
    fn name(self) -> string { "naming-convention".into() }
    fn check(self, source: string) -> [LintDiagnostic] {
        let mut diagnostics = vec![];
        for (i, line) in source.lines().enumerate() {
            if line.contains("fn ") {
                let name = line.split("fn ").nth(1).and_then(|s| s.split('(').next());
                if let Some(n) = name {
                    if n.chars().next().map(|c| c.is_uppercase()).unwrap_or(false) {
                        diagnostics.push(LintDiagnostic {
                            rule: "naming-convention".into(),
                            message: "Function names should be snake_case".into(),
                            severity: Severity::Warning,
                            span: Span { start: 0, end: line.len(), line: i + 1, column: 1 },
                            fix: None
                        });
                    }
                }
            }
        }
        diagnostics
    }
}

struct ComplexityRule { max_complexity: usize }
impl LintRule for ComplexityRule {
    fn name(self) -> string { "complexity".into() }
    fn check(self, source: string) -> [LintDiagnostic] { vec![] }
}

struct LineLengthRule { max_length: usize }
impl LintRule for LineLengthRule {
    fn name(self) -> string { "line-length".into() }
    fn check(self, source: string) -> [LintDiagnostic] {
        source.lines().enumerate()
            .filter(|(_, l)| l.len() > self.max_length)
            .map(|(i, l)| LintDiagnostic {
                rule: "line-length".into(),
                message: format!("Line exceeds {} characters", self.max_length),
                severity: Severity::Warning,
                span: Span { start: 0, end: l.len(), line: i + 1, column: 1 },
                fix: None
            }).collect()
    }
}

// =============================================================================
// PACKAGE PUBLISHING
// =============================================================================

struct PackageMetadata {
    name: string,
    version: string,
    description: string,
    authors: [string],
    license: string,
    repository: Option<string>,
    keywords: [string],
    dependencies: HashMap<string, string>
}

struct Publisher {
    registry_url: string,
    auth_token: Option<string>,
    dry_run: bool
}

struct PublishResult { success: bool, package_url: Option<string>, errors: [string] }

impl Publisher {
    fn new(registry_url: string) -> Publisher {
        Publisher { registry_url: registry_url, auth_token: None, dry_run: false }
    }

    fn with_auth(mut self, token: string) -> Publisher { self.auth_token = Some(token); self }
    fn dry_run(mut self) -> Publisher { self.dry_run = true; self }

    fn publish(self, path: string) -> PublishResult {
        // 1. Read and validate manifest
        let manifest = self.read_manifest(&path);
        if manifest.is_none() {
            return PublishResult { success: false, package_url: None, errors: vec!["Could not read quark.toml".into()] };
        }
        let meta = manifest.unwrap();

        // 2. Validate package
        let validation_errors = self.validate(&meta, &path);
        if !validation_errors.is_empty() {
            return PublishResult { success: false, package_url: None, errors: validation_errors };
        }

        // 3. Build tarball
        let tarball = self.create_tarball(&path, &meta);
        if tarball.is_none() {
            return PublishResult { success: false, package_url: None, errors: vec!["Failed to create package".into()] };
        }

        // 4. Upload
        if self.dry_run {
            return PublishResult { success: true, package_url: None, errors: vec!["Dry run - not uploaded".into()] };
        }

        let upload_result = self.upload(&tarball.unwrap(), &meta);
        upload_result
    }

    fn read_manifest(self, path: string) -> Option<PackageMetadata> {
        let manifest_path = format!("{}/quark.toml", path);
        // Parse TOML
        Some(PackageMetadata {
            name: "package".into(), version: "0.1.0".into(), description: "".into(),
            authors: vec![], license: "MIT".into(), repository: None, keywords: vec![],
            dependencies: HashMap::new()
        })
    }

    fn validate(self, meta: PackageMetadata, path: string) -> [string] {
        let mut errors = vec![];
        if meta.name.is_empty() { errors.push("Package name is required".into()); }
        if meta.version.is_empty() { errors.push("Package version is required".into()); }
        if !self.is_valid_semver(&meta.version) { errors.push("Invalid semantic version".into()); }
        if meta.license.is_empty() { errors.push("License is required".into()); }
        errors
    }

    fn is_valid_semver(self, version: string) -> bool {
        let parts: Vec<_> = version.split('.').collect();
        parts.len() == 3 && parts.iter().all(|p| p.parse::<u32>().is_ok())
    }

    fn create_tarball(self, path: string, meta: PackageMetadata) -> Option<[u8]> {
        let mut tarball = vec![];
        // Create tar.gz archive
        Some(tarball)
    }

    fn upload(self, tarball: [u8], meta: PackageMetadata) -> PublishResult {
        let url = format!("{}/api/v1/crates/new", self.registry_url);
        // HTTP PUT with auth
        PublishResult {
            success: true,
            package_url: Some(format!("{}/crates/{}/{}", self.registry_url, meta.name, meta.version)),
            errors: vec![]
        }
    }

    fn yank(self, name: string, version: string) -> bool {
        // Mark version as yanked
        true
    }

    fn unyank(self, name: string, version: string) -> bool {
        // Unmark version as yanked
        true
    }
}

// =============================================================================
// LANGUAGE SERVER PROTOCOL (LSP) IMPLEMENTATION
// =============================================================================

pub mod lsp {
    use std::collections::HashMap;
    use std::sync::{Arc, RwLock, Mutex};

    #[derive(Debug, Clone)]
    pub struct Position { pub line: u32, pub character: u32 }

    #[derive(Debug, Clone)]
    pub struct Range { pub start: Position, pub end: Position }

    #[derive(Debug, Clone)]
    pub struct Location { pub uri: String, pub range: Range }

    #[derive(Debug, Clone, PartialEq)]
    pub enum DiagnosticSeverity { Error = 1, Warning = 2, Information = 3, Hint = 4 }

    #[derive(Debug, Clone)]
    pub struct Diagnostic {
        pub range: Range,
        pub severity: DiagnosticSeverity,
        pub code: Option<String>,
        pub source: String,
        pub message: String,
        pub related_information: Vec<DiagnosticRelatedInfo>,
        pub tags: Vec<DiagnosticTag>,
    }

    #[derive(Debug, Clone)]
    pub struct DiagnosticRelatedInfo { pub location: Location, pub message: String }

    #[derive(Debug, Clone, PartialEq)]
    pub enum DiagnosticTag { Unnecessary = 1, Deprecated = 2 }

    #[derive(Debug, Clone, PartialEq)]
    pub enum CompletionItemKind {
        Text = 1, Method = 2, Function = 3, Constructor = 4, Field = 5,
        Variable = 6, Class = 7, Interface = 8, Module = 9, Property = 10,
        Unit = 11, Value = 12, Enum = 13, Keyword = 14, Snippet = 15,
        Color = 16, File = 17, Reference = 18, Folder = 19, EnumMember = 20,
        Constant = 21, Struct = 22, Event = 23, Operator = 24, TypeParameter = 25,
    }

    #[derive(Debug, Clone)]
    pub struct CompletionItem {
        pub label: String,
        pub kind: CompletionItemKind,
        pub detail: Option<String>,
        pub documentation: Option<MarkupContent>,
        pub deprecated: bool,
        pub preselect: bool,
        pub sort_text: Option<String>,
        pub filter_text: Option<String>,
        pub insert_text: Option<String>,
        pub insert_text_format: InsertTextFormat,
        pub text_edit: Option<TextEdit>,
        pub additional_text_edits: Vec<TextEdit>,
        pub commit_characters: Vec<char>,
        pub command: Option<Command>,
        pub data: Option<String>,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum InsertTextFormat { PlainText = 1, Snippet = 2 }

    #[derive(Debug, Clone)]
    pub struct TextEdit { pub range: Range, pub new_text: String }

    #[derive(Debug, Clone)]
    pub struct Command { pub title: String, pub command: String, pub arguments: Vec<String> }

    #[derive(Debug, Clone)]
    pub struct MarkupContent { pub kind: MarkupKind, pub value: String }

    #[derive(Debug, Clone, PartialEq)]
    pub enum MarkupKind { PlainText, Markdown }

    #[derive(Debug, Clone)]
    pub struct Hover { pub contents: MarkupContent, pub range: Option<Range> }

    #[derive(Debug, Clone, PartialEq)]
    pub enum SymbolKind {
        File = 1, Module = 2, Namespace = 3, Package = 4, Class = 5,
        Method = 6, Property = 7, Field = 8, Constructor = 9, Enum = 10,
        Interface = 11, Function = 12, Variable = 13, Constant = 14,
        String = 15, Number = 16, Boolean = 17, Array = 18, Object = 19,
        Key = 20, Null = 21, EnumMember = 22, Struct = 23, Event = 24,
        Operator = 25, TypeParameter = 26,
    }

    #[derive(Debug, Clone)]
    pub struct DocumentSymbol {
        pub name: String,
        pub detail: Option<String>,
        pub kind: SymbolKind,
        pub deprecated: bool,
        pub range: Range,
        pub selection_range: Range,
        pub children: Vec<DocumentSymbol>,
    }

    #[derive(Debug, Clone)]
    pub struct WorkspaceSymbol {
        pub name: String,
        pub kind: SymbolKind,
        pub location: Location,
        pub container_name: Option<String>,
    }

    #[derive(Debug, Clone)]
    pub struct SignatureHelp {
        pub signatures: Vec<SignatureInformation>,
        pub active_signature: usize,
        pub active_parameter: usize,
    }

    #[derive(Debug, Clone)]
    pub struct SignatureInformation {
        pub label: String,
        pub documentation: Option<MarkupContent>,
        pub parameters: Vec<ParameterInformation>,
    }

    #[derive(Debug, Clone)]
    pub struct ParameterInformation {
        pub label: String,
        pub documentation: Option<MarkupContent>,
    }

    #[derive(Debug, Clone)]
    pub struct CodeAction {
        pub title: String,
        pub kind: CodeActionKind,
        pub diagnostics: Vec<Diagnostic>,
        pub is_preferred: bool,
        pub disabled_reason: Option<String>,
        pub edit: Option<WorkspaceEdit>,
        pub command: Option<Command>,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum CodeActionKind {
        Empty, QuickFix, Refactor, RefactorExtract, RefactorInline,
        RefactorRewrite, Source, SourceOrganizeImports, SourceFixAll,
    }

    #[derive(Debug, Clone)]
    pub struct WorkspaceEdit {
        pub changes: HashMap<String, Vec<TextEdit>>,
        pub document_changes: Vec<TextDocumentEdit>,
    }

    #[derive(Debug, Clone)]
    pub struct TextDocumentEdit {
        pub text_document: VersionedTextDocumentIdentifier,
        pub edits: Vec<TextEdit>,
    }

    #[derive(Debug, Clone)]
    pub struct VersionedTextDocumentIdentifier { pub uri: String, pub version: i64 }

    #[derive(Debug, Clone)]
    pub struct CodeLens { pub range: Range, pub command: Option<Command>, pub data: Option<String> }

    #[derive(Debug, Clone)]
    pub struct DocumentLink { pub range: Range, pub target: Option<String>, pub tooltip: Option<String> }

    #[derive(Debug, Clone)]
    pub struct FoldingRange {
        pub start_line: u32,
        pub start_character: Option<u32>,
        pub end_line: u32,
        pub end_character: Option<u32>,
        pub kind: FoldingRangeKind,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum FoldingRangeKind { Comment, Imports, Region }

    #[derive(Debug, Clone)]
    pub struct SelectionRange { pub range: Range, pub parent: Option<Box<SelectionRange>> }

    #[derive(Debug, Clone)]
    pub struct SemanticTokens { pub result_id: Option<String>, pub data: Vec<u32> }

    #[derive(Debug, Clone)]
    pub struct SemanticTokensLegend {
        pub token_types: Vec<String>,
        pub token_modifiers: Vec<String>,
    }

    pub struct LanguageServer {
        documents: RwLock<HashMap<String, TextDocument>>,
        diagnostics: RwLock<HashMap<String, Vec<Diagnostic>>>,
        symbol_index: RwLock<HashMap<String, Vec<WorkspaceSymbol>>>,
        capabilities: ServerCapabilities,
        root_uri: Mutex<Option<String>>,
    }

    #[derive(Debug, Clone)]
    pub struct TextDocument {
        pub uri: String,
        pub language_id: String,
        pub version: i64,
        pub content: String,
        lines: Vec<usize>,
    }

    impl TextDocument {
        pub fn new(uri: String, language_id: String, version: i64, content: String) -> Self {
            let lines = Self::compute_line_offsets(&content);
            Self { uri, language_id, version, content, lines }
        }

        fn compute_line_offsets(text: &str) -> Vec<usize> {
            let mut offsets = vec![0];
            for (i, c) in text.char_indices() {
                if c == '\n' { offsets.push(i + 1); }
            }
            offsets
        }

        pub fn position_to_offset(&self, pos: &Position) -> usize {
            if pos.line as usize >= self.lines.len() { return self.content.len(); }
            let line_start = self.lines[pos.line as usize];
            line_start + pos.character as usize
        }

        pub fn offset_to_position(&self, offset: usize) -> Position {
            let line = self.lines.iter().rposition(|&o| o <= offset).unwrap_or(0);
            let character = offset - self.lines[line];
            Position { line: line as u32, character: character as u32 }
        }

        pub fn get_line(&self, line: u32) -> Option<&str> {
            let line = line as usize;
            if line >= self.lines.len() { return None; }
            let start = self.lines[line];
            let end = self.lines.get(line + 1).copied().unwrap_or(self.content.len());
            Some(&self.content[start..end].trim_end_matches('\n'))
        }

        pub fn get_range(&self, range: &Range) -> &str {
            let start = self.position_to_offset(&range.start);
            let end = self.position_to_offset(&range.end);
            &self.content[start..end]
        }

        pub fn apply_edit(&mut self, edit: &TextEdit) {
            let start = self.position_to_offset(&edit.range.start);
            let end = self.position_to_offset(&edit.range.end);
            self.content = format!("{}{}{}", &self.content[..start], &edit.new_text, &self.content[end..]);
            self.lines = Self::compute_line_offsets(&self.content);
            self.version += 1;
        }
    }

    #[derive(Debug, Clone)]
    pub struct ServerCapabilities {
        pub hover_provider: bool,
        pub completion_provider: Option<CompletionOptions>,
        pub signature_help_provider: Option<SignatureHelpOptions>,
        pub definition_provider: bool,
        pub type_definition_provider: bool,
        pub implementation_provider: bool,
        pub references_provider: bool,
        pub document_highlight_provider: bool,
        pub document_symbol_provider: bool,
        pub workspace_symbol_provider: bool,
        pub code_action_provider: bool,
        pub code_lens_provider: bool,
        pub document_formatting_provider: bool,
        pub document_range_formatting_provider: bool,
        pub rename_provider: bool,
        pub folding_range_provider: bool,
        pub selection_range_provider: bool,
        pub semantic_tokens_provider: Option<SemanticTokensOptions>,
    }

    #[derive(Debug, Clone)]
    pub struct CompletionOptions {
        pub trigger_characters: Vec<char>,
        pub resolve_provider: bool,
    }

    #[derive(Debug, Clone)]
    pub struct SignatureHelpOptions { pub trigger_characters: Vec<char>, pub retrigger_characters: Vec<char> }

    #[derive(Debug, Clone)]
    pub struct SemanticTokensOptions { pub full: bool, pub range: bool, pub legend: SemanticTokensLegend }

    impl LanguageServer {
        pub fn new() -> Self {
            Self {
                documents: RwLock::new(HashMap::new()),
                diagnostics: RwLock::new(HashMap::new()),
                symbol_index: RwLock::new(HashMap::new()),
                capabilities: ServerCapabilities {
                    hover_provider: true,
                    completion_provider: Some(CompletionOptions {
                        trigger_characters: vec!['.', ':', '<', '(', ','],
                        resolve_provider: true,
                    }),
                    signature_help_provider: Some(SignatureHelpOptions {
                        trigger_characters: vec!['(', ','],
                        retrigger_characters: vec![','],
                    }),
                    definition_provider: true,
                    type_definition_provider: true,
                    implementation_provider: true,
                    references_provider: true,
                    document_highlight_provider: true,
                    document_symbol_provider: true,
                    workspace_symbol_provider: true,
                    code_action_provider: true,
                    code_lens_provider: true,
                    document_formatting_provider: true,
                    document_range_formatting_provider: true,
                    rename_provider: true,
                    folding_range_provider: true,
                    selection_range_provider: true,
                    semantic_tokens_provider: Some(SemanticTokensOptions {
                        full: true,
                        range: true,
                        legend: SemanticTokensLegend {
                            token_types: vec![
                                "namespace".into(), "type".into(), "class".into(), "enum".into(),
                                "interface".into(), "struct".into(), "typeParameter".into(),
                                "parameter".into(), "variable".into(), "property".into(),
                                "enumMember".into(), "function".into(), "method".into(),
                                "macro".into(), "keyword".into(), "comment".into(), "string".into(),
                                "number".into(), "operator".into(),
                            ],
                            token_modifiers: vec![
                                "declaration".into(), "definition".into(), "readonly".into(),
                                "static".into(), "deprecated".into(), "async".into(),
                            ],
                        },
                    }),
                },
                root_uri: Mutex::new(None),
            }
        }

        pub fn initialize(&self, root_uri: Option<String>) -> &ServerCapabilities {
            *self.root_uri.lock().unwrap() = root_uri;
            &self.capabilities
        }

        pub fn open_document(&self, uri: String, language_id: String, version: i64, content: String) {
            let doc = TextDocument::new(uri.clone(), language_id, version, content);
            self.documents.write().unwrap().insert(uri.clone(), doc);
            self.analyze_document(&uri);
        }

        pub fn update_document(&self, uri: &str, version: i64, changes: Vec<TextEdit>) {
            let mut docs = self.documents.write().unwrap();
            if let Some(doc) = docs.get_mut(uri) {
                doc.version = version;
                for edit in changes { doc.apply_edit(&edit); }
                drop(docs);
                self.analyze_document(uri);
            }
        }

        pub fn close_document(&self, uri: &str) {
            self.documents.write().unwrap().remove(uri);
            self.diagnostics.write().unwrap().remove(uri);
        }

        fn analyze_document(&self, uri: &str) {
            let docs = self.documents.read().unwrap();
            if let Some(doc) = docs.get(uri) {
                let diags = self.run_diagnostics(doc);
                drop(docs);
                self.diagnostics.write().unwrap().insert(uri.to_string(), diags);
                self.update_symbol_index(uri);
            }
        }

        fn run_diagnostics(&self, doc: &TextDocument) -> Vec<Diagnostic> {
            let mut diagnostics = Vec::new();
            for (line_num, line_start) in doc.lines.iter().enumerate() {
                let line_end = doc.lines.get(line_num + 1).copied().unwrap_or(doc.content.len());
                let line = &doc.content[*line_start..line_end];
                if line.contains("TODO") {
                    if let Some(col) = line.find("TODO") {
                        diagnostics.push(Diagnostic {
                            range: Range {
                                start: Position { line: line_num as u32, character: col as u32 },
                                end: Position { line: line_num as u32, character: (col + 4) as u32 },
                            },
                            severity: DiagnosticSeverity::Information,
                            code: Some("todo-comment".into()),
                            source: "quanta-lsp".into(),
                            message: "TODO comment found".into(),
                            related_information: vec![],
                            tags: vec![],
                        });
                    }
                }
                if line.len() > 120 {
                    diagnostics.push(Diagnostic {
                        range: Range {
                            start: Position { line: line_num as u32, character: 120 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        severity: DiagnosticSeverity::Warning,
                        code: Some("line-length".into()),
                        source: "quanta-lsp".into(),
                        message: format!("Line exceeds 120 characters ({} chars)", line.len()),
                        related_information: vec![],
                        tags: vec![],
                    });
                }
            }
            diagnostics
        }

        fn update_symbol_index(&self, uri: &str) {
            let docs = self.documents.read().unwrap();
            if let Some(doc) = docs.get(uri) {
                let symbols = self.extract_symbols(doc);
                drop(docs);
                self.symbol_index.write().unwrap().insert(uri.to_string(), symbols);
            }
        }

        fn extract_symbols(&self, doc: &TextDocument) -> Vec<WorkspaceSymbol> {
            let mut symbols = Vec::new();
            let fn_pattern = "fn ";
            let struct_pattern = "struct ";
            let enum_pattern = "enum ";
            let trait_pattern = "trait ";
            for (line_num, line_start) in doc.lines.iter().enumerate() {
                let line_end = doc.lines.get(line_num + 1).copied().unwrap_or(doc.content.len());
                let line = &doc.content[*line_start..line_end];
                let trimmed = line.trim();
                if let Some(pos) = trimmed.find(fn_pattern) {
                    if pos < 10 {
                        if let Some(name) = Self::extract_identifier(&trimmed[pos + fn_pattern.len()..]) {
                            symbols.push(WorkspaceSymbol {
                                name: name.to_string(),
                                kind: SymbolKind::Function,
                                location: Location {
                                    uri: doc.uri.clone(),
                                    range: Range {
                                        start: Position { line: line_num as u32, character: 0 },
                                        end: Position { line: line_num as u32, character: line.len() as u32 },
                                    },
                                },
                                container_name: None,
                            });
                        }
                    }
                }
                if let Some(pos) = trimmed.find(struct_pattern) {
                    if pos < 10 {
                        if let Some(name) = Self::extract_identifier(&trimmed[pos + struct_pattern.len()..]) {
                            symbols.push(WorkspaceSymbol {
                                name: name.to_string(),
                                kind: SymbolKind::Struct,
                                location: Location {
                                    uri: doc.uri.clone(),
                                    range: Range {
                                        start: Position { line: line_num as u32, character: 0 },
                                        end: Position { line: line_num as u32, character: line.len() as u32 },
                                    },
                                },
                                container_name: None,
                            });
                        }
                    }
                }
            }
            symbols
        }

        fn extract_identifier(text: &str) -> Option<&str> {
            let trimmed = text.trim();
            let end = trimmed.find(|c: char| !c.is_alphanumeric() && c != '_').unwrap_or(trimmed.len());
            if end > 0 { Some(&trimmed[..end]) } else { None }
        }

        pub fn get_diagnostics(&self, uri: &str) -> Vec<Diagnostic> {
            self.diagnostics.read().unwrap().get(uri).cloned().unwrap_or_default()
        }

        pub fn completion(&self, uri: &str, position: &Position) -> Vec<CompletionItem> {
            let docs = self.documents.read().unwrap();
            let doc = match docs.get(uri) { Some(d) => d, None => return vec![] };
            let line = match doc.get_line(position.line) { Some(l) => l, None => return vec![] };
            let prefix: String = line.chars().take(position.character as usize).collect();
            let mut items = Vec::new();
            if prefix.ends_with('.') {
                items.push(CompletionItem {
                    label: "len".into(),
                    kind: CompletionItemKind::Method,
                    detail: Some("fn len(&self) -> usize".into()),
                    documentation: Some(MarkupContent { kind: MarkupKind::Markdown, value: "Returns the length.".into() }),
                    deprecated: false, preselect: false, sort_text: None, filter_text: None,
                    insert_text: Some("len()".into()), insert_text_format: InsertTextFormat::PlainText,
                    text_edit: None, additional_text_edits: vec![], commit_characters: vec!['('],
                    command: None, data: None,
                });
            }
            let keywords = ["fn", "let", "mut", "const", "struct", "enum", "trait", "impl", "pub", "mod", "use", "if", "else", "match", "for", "while", "loop", "return", "break", "continue", "async", "await"];
            for kw in &keywords {
                items.push(CompletionItem {
                    label: (*kw).to_string(),
                    kind: CompletionItemKind::Keyword,
                    detail: Some(format!("{} keyword", kw)),
                    documentation: None, deprecated: false, preselect: false, sort_text: None,
                    filter_text: None, insert_text: None, insert_text_format: InsertTextFormat::PlainText,
                    text_edit: None, additional_text_edits: vec![], commit_characters: vec![],
                    command: None, data: None,
                });
            }
            items
        }

        pub fn hover(&self, uri: &str, position: &Position) -> Option<Hover> {
            let docs = self.documents.read().unwrap();
            let doc = docs.get(uri)?;
            let line = doc.get_line(position.line)?;
            let word_start = line[..position.character as usize].rfind(|c: char| !c.is_alphanumeric() && c != '_').map(|i| i + 1).unwrap_or(0);
            let word_end = line[position.character as usize..].find(|c: char| !c.is_alphanumeric() && c != '_').map(|i| i + position.character as usize).unwrap_or(line.len());
            let word = &line[word_start..word_end];
            if word.is_empty() { return None; }
            let symbols = self.symbol_index.read().unwrap();
            for syms in symbols.values() {
                for sym in syms {
                    if sym.name == word {
                        return Some(Hover {
                            contents: MarkupContent {
                                kind: MarkupKind::Markdown,
                                value: format!("```quanta\n{:?} {}\n```", sym.kind, sym.name),
                            },
                            range: Some(Range {
                                start: Position { line: position.line, character: word_start as u32 },
                                end: Position { line: position.line, character: word_end as u32 },
                            }),
                        });
                    }
                }
            }
            None
        }

        pub fn goto_definition(&self, uri: &str, position: &Position) -> Vec<Location> {
            let docs = self.documents.read().unwrap();
            let doc = match docs.get(uri) { Some(d) => d, None => return vec![] };
            let line = match doc.get_line(position.line) { Some(l) => l, None => return vec![] };
            let word_start = line[..position.character as usize].rfind(|c: char| !c.is_alphanumeric() && c != '_').map(|i| i + 1).unwrap_or(0);
            let word_end = line[position.character as usize..].find(|c: char| !c.is_alphanumeric() && c != '_').map(|i| i + position.character as usize).unwrap_or(line.len());
            let word = &line[word_start..word_end];
            if word.is_empty() { return vec![]; }
            drop(docs);
            let mut locations = Vec::new();
            let symbols = self.symbol_index.read().unwrap();
            for syms in symbols.values() {
                for sym in syms {
                    if sym.name == word {
                        locations.push(sym.location.clone());
                    }
                }
            }
            locations
        }

        pub fn find_references(&self, uri: &str, position: &Position, include_declaration: bool) -> Vec<Location> {
            let docs = self.documents.read().unwrap();
            let doc = match docs.get(uri) { Some(d) => d, None => return vec![] };
            let line = match doc.get_line(position.line) { Some(l) => l, None => return vec![] };
            let word_start = line[..position.character as usize].rfind(|c: char| !c.is_alphanumeric() && c != '_').map(|i| i + 1).unwrap_or(0);
            let word_end = line[position.character as usize..].find(|c: char| !c.is_alphanumeric() && c != '_').map(|i| i + position.character as usize).unwrap_or(line.len());
            let word = &line[word_start..word_end];
            if word.is_empty() { return vec![]; }
            let mut references = Vec::new();
            for (doc_uri, doc) in docs.iter() {
                for (line_num, line_start) in doc.lines.iter().enumerate() {
                    let line_end = doc.lines.get(line_num + 1).copied().unwrap_or(doc.content.len());
                    let text = &doc.content[*line_start..line_end];
                    let mut search_start = 0;
                    while let Some(pos) = text[search_start..].find(word) {
                        let abs_pos = search_start + pos;
                        let before = if abs_pos > 0 { text.chars().nth(abs_pos - 1) } else { None };
                        let after = text.chars().nth(abs_pos + word.len());
                        let is_word_boundary = |c: Option<char>| c.map(|c| !c.is_alphanumeric() && c != '_').unwrap_or(true);
                        if is_word_boundary(before) && is_word_boundary(after) {
                            references.push(Location {
                                uri: doc_uri.clone(),
                                range: Range {
                                    start: Position { line: line_num as u32, character: abs_pos as u32 },
                                    end: Position { line: line_num as u32, character: (abs_pos + word.len()) as u32 },
                                },
                            });
                        }
                        search_start = abs_pos + word.len();
                    }
                }
            }
            references
        }

        pub fn document_symbols(&self, uri: &str) -> Vec<DocumentSymbol> {
            let symbols = self.symbol_index.read().unwrap();
            let workspace_symbols = match symbols.get(uri) { Some(s) => s, None => return vec![] };
            workspace_symbols.iter().map(|ws| DocumentSymbol {
                name: ws.name.clone(),
                detail: ws.container_name.clone(),
                kind: ws.kind.clone(),
                deprecated: false,
                range: ws.location.range.clone(),
                selection_range: ws.location.range.clone(),
                children: vec![],
            }).collect()
        }

        pub fn workspace_symbols(&self, query: &str) -> Vec<WorkspaceSymbol> {
            let symbols = self.symbol_index.read().unwrap();
            let query_lower = query.to_lowercase();
            symbols.values()
                .flat_map(|syms| syms.iter())
                .filter(|s| s.name.to_lowercase().contains(&query_lower))
                .cloned()
                .collect()
        }

        pub fn formatting(&self, uri: &str) -> Vec<TextEdit> {
            let docs = self.documents.read().unwrap();
            let doc = match docs.get(uri) { Some(d) => d, None => return vec![] };
            let mut edits = Vec::new();
            for (line_num, line_start) in doc.lines.iter().enumerate() {
                let line_end = doc.lines.get(line_num + 1).copied().unwrap_or(doc.content.len());
                let line = &doc.content[*line_start..line_end];
                let trimmed_end = line.trim_end();
                if trimmed_end.len() < line.len() {
                    edits.push(TextEdit {
                        range: Range {
                            start: Position { line: line_num as u32, character: trimmed_end.len() as u32 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        new_text: String::new(),
                    });
                }
            }
            edits
        }

        pub fn folding_ranges(&self, uri: &str) -> Vec<FoldingRange> {
            let docs = self.documents.read().unwrap();
            let doc = match docs.get(uri) { Some(d) => d, None => return vec![] };
            let mut ranges = Vec::new();
            let mut brace_stack: Vec<u32> = Vec::new();
            for (line_num, line_start) in doc.lines.iter().enumerate() {
                let line_end = doc.lines.get(line_num + 1).copied().unwrap_or(doc.content.len());
                let line = &doc.content[*line_start..line_end];
                for c in line.chars() {
                    if c == '{' {
                        brace_stack.push(line_num as u32);
                    } else if c == '}' && !brace_stack.is_empty() {
                        let start = brace_stack.pop().unwrap();
                        if (line_num as u32) > start {
                            ranges.push(FoldingRange {
                                start_line: start,
                                start_character: None,
                                end_line: line_num as u32,
                                end_character: None,
                                kind: FoldingRangeKind::Region,
                            });
                        }
                    }
                }
            }
            ranges
        }
    }
}

// =============================================================================
// DEBUG ADAPTER PROTOCOL (DAP) IMPLEMENTATION
// =============================================================================

pub mod dap {
    use std::collections::HashMap;
    use std::sync::{Arc, Mutex, RwLock, atomic::{AtomicBool, AtomicU64, Ordering}};

    #[derive(Debug, Clone, PartialEq)]
    pub enum BreakpointType { Line, Conditional, Function, Exception, Data, Logpoint }

    #[derive(Debug, Clone)]
    pub struct Breakpoint {
        pub id: u64,
        pub verified: bool,
        pub source: Source,
        pub line: u32,
        pub column: Option<u32>,
        pub end_line: Option<u32>,
        pub end_column: Option<u32>,
        pub condition: Option<String>,
        pub hit_condition: Option<String>,
        pub log_message: Option<String>,
        pub breakpoint_type: BreakpointType,
        hit_count: AtomicU64,
    }

    impl Breakpoint {
        pub fn hit_count(&self) -> u64 { self.hit_count.load(Ordering::Relaxed) }
        pub fn increment_hit(&self) { self.hit_count.fetch_add(1, Ordering::Relaxed); }
    }

    #[derive(Debug, Clone)]
    pub struct Source { pub name: Option<String>, pub path: Option<String>, pub source_reference: u64 }

    #[derive(Debug, Clone)]
    pub struct StackFrame {
        pub id: u64,
        pub name: String,
        pub source: Option<Source>,
        pub line: u32,
        pub column: u32,
        pub end_line: Option<u32>,
        pub end_column: Option<u32>,
        pub can_restart: bool,
        pub instruction_pointer: Option<String>,
        pub module_id: Option<u64>,
    }

    #[derive(Debug, Clone)]
    pub struct Scope {
        pub name: String,
        pub presentation_hint: ScopePresentationHint,
        pub variables_reference: u64,
        pub named_variables: Option<u32>,
        pub indexed_variables: Option<u32>,
        pub expensive: bool,
        pub source: Option<Source>,
        pub line: Option<u32>,
        pub column: Option<u32>,
        pub end_line: Option<u32>,
        pub end_column: Option<u32>,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum ScopePresentationHint { Arguments, Locals, Registers, ReturnValue }

    #[derive(Debug, Clone)]
    pub struct Variable {
        pub name: String,
        pub value: String,
        pub var_type: Option<String>,
        pub presentation_hint: Option<VariablePresentationHint>,
        pub evaluate_name: Option<String>,
        pub variables_reference: u64,
        pub named_variables: Option<u32>,
        pub indexed_variables: Option<u32>,
        pub memory_reference: Option<String>,
    }

    #[derive(Debug, Clone)]
    pub struct VariablePresentationHint {
        pub kind: String,
        pub attributes: Vec<String>,
        pub visibility: String,
    }

    #[derive(Debug, Clone)]
    pub struct Thread { pub id: u64, pub name: String }

    #[derive(Debug, Clone, PartialEq)]
    pub enum StopReason { Step, Breakpoint, Exception, Pause, Entry, Goto, FunctionBreakpoint, DataBreakpoint }

    #[derive(Debug, Clone)]
    pub struct StoppedEvent {
        pub reason: StopReason,
        pub description: Option<String>,
        pub thread_id: Option<u64>,
        pub preserve_focus_hint: bool,
        pub text: Option<String>,
        pub all_threads_stopped: bool,
        pub hit_breakpoint_ids: Vec<u64>,
    }

    #[derive(Debug, Clone)]
    pub struct Capabilities {
        pub supports_configuration_done: bool,
        pub supports_function_breakpoints: bool,
        pub supports_conditional_breakpoints: bool,
        pub supports_hit_conditional_breakpoints: bool,
        pub supports_evaluate_for_hovers: bool,
        pub supports_step_back: bool,
        pub supports_set_variable: bool,
        pub supports_restart_frame: bool,
        pub supports_goto_targets: bool,
        pub supports_step_in_targets: bool,
        pub supports_completions: bool,
        pub supports_modules: bool,
        pub supports_restart: bool,
        pub supports_exception_options: bool,
        pub supports_value_formatting_options: bool,
        pub supports_exception_info: bool,
        pub supports_terminate: bool,
        pub supports_suspend: bool,
        pub supports_loaded_sources: bool,
        pub supports_logpoints: bool,
        pub supports_terminate_threads: bool,
        pub supports_data_breakpoints: bool,
        pub supports_read_memory: bool,
        pub supports_write_memory: bool,
        pub supports_disassemble: bool,
        pub supports_cancel: bool,
        pub supports_clipboard_context: bool,
        pub supports_stepping_granularity: bool,
        pub supports_instruction_breakpoints: bool,
        pub supports_exception_filter_options: bool,
    }

    impl Default for Capabilities {
        fn default() -> Self {
            Self {
                supports_configuration_done: true,
                supports_function_breakpoints: true,
                supports_conditional_breakpoints: true,
                supports_hit_conditional_breakpoints: true,
                supports_evaluate_for_hovers: true,
                supports_step_back: false,
                supports_set_variable: true,
                supports_restart_frame: true,
                supports_goto_targets: true,
                supports_step_in_targets: true,
                supports_completions: true,
                supports_modules: true,
                supports_restart: true,
                supports_exception_options: true,
                supports_value_formatting_options: true,
                supports_exception_info: true,
                supports_terminate: true,
                supports_suspend: true,
                supports_loaded_sources: true,
                supports_logpoints: true,
                supports_terminate_threads: true,
                supports_data_breakpoints: true,
                supports_read_memory: true,
                supports_write_memory: true,
                supports_disassemble: true,
                supports_cancel: true,
                supports_clipboard_context: true,
                supports_stepping_granularity: true,
                supports_instruction_breakpoints: true,
                supports_exception_filter_options: true,
            }
        }
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum ExceptionBreakMode { Never, Always, Unhandled, UserUnhandled }

    #[derive(Debug, Clone)]
    pub struct ExceptionFilterOptions {
        pub filter_id: String,
        pub condition: Option<String>,
    }

    #[derive(Debug, Clone)]
    pub struct Module {
        pub id: u64,
        pub name: String,
        pub path: Option<String>,
        pub is_optimized: bool,
        pub is_user_code: bool,
        pub version: Option<String>,
        pub symbol_status: String,
        pub symbol_file_path: Option<String>,
        pub date_time_stamp: Option<String>,
        pub address_range: Option<String>,
    }

    #[derive(Debug, Clone)]
    pub struct DisassembledInstruction {
        pub address: String,
        pub instruction_bytes: Option<String>,
        pub instruction: String,
        pub symbol: Option<String>,
        pub location: Option<Source>,
        pub line: Option<u32>,
        pub column: Option<u32>,
        pub end_line: Option<u32>,
        pub end_column: Option<u32>,
    }

    pub struct DebugAdapter {
        breakpoints: RwLock<HashMap<String, Vec<Breakpoint>>>,
        function_breakpoints: RwLock<Vec<Breakpoint>>,
        exception_breakpoints: RwLock<Vec<ExceptionFilterOptions>>,
        threads: RwLock<HashMap<u64, Thread>>,
        stack_frames: RwLock<HashMap<u64, Vec<StackFrame>>>,
        variables: RwLock<HashMap<u64, Vec<Variable>>>,
        modules: RwLock<Vec<Module>>,
        next_breakpoint_id: AtomicU64,
        next_var_reference: AtomicU64,
        is_running: AtomicBool,
        current_thread: AtomicU64,
        capabilities: Capabilities,
    }

    impl DebugAdapter {
        pub fn new() -> Self {
            Self {
                breakpoints: RwLock::new(HashMap::new()),
                function_breakpoints: RwLock::new(Vec::new()),
                exception_breakpoints: RwLock::new(Vec::new()),
                threads: RwLock::new(HashMap::new()),
                stack_frames: RwLock::new(HashMap::new()),
                variables: RwLock::new(HashMap::new()),
                modules: RwLock::new(Vec::new()),
                next_breakpoint_id: AtomicU64::new(1),
                next_var_reference: AtomicU64::new(1),
                is_running: AtomicBool::new(false),
                current_thread: AtomicU64::new(0),
                capabilities: Capabilities::default(),
            }
        }

        pub fn capabilities(&self) -> &Capabilities { &self.capabilities }

        pub fn set_breakpoints(&self, source: Source, breakpoints: Vec<(u32, Option<String>, Option<String>)>) -> Vec<Breakpoint> {
            let path = source.path.clone().unwrap_or_default();
            let verified_breakpoints: Vec<Breakpoint> = breakpoints.iter().map(|(line, condition, log_msg)| {
                Breakpoint {
                    id: self.next_breakpoint_id.fetch_add(1, Ordering::Relaxed),
                    verified: true,
                    source: source.clone(),
                    line: *line,
                    column: None,
                    end_line: None,
                    end_column: None,
                    condition: condition.clone(),
                    hit_condition: None,
                    log_message: log_msg.clone(),
                    breakpoint_type: if log_msg.is_some() { BreakpointType::Logpoint } else if condition.is_some() { BreakpointType::Conditional } else { BreakpointType::Line },
                    hit_count: AtomicU64::new(0),
                }
            }).collect();
            self.breakpoints.write().unwrap().insert(path, verified_breakpoints.clone());
            verified_breakpoints
        }

        pub fn set_function_breakpoints(&self, names: Vec<(String, Option<String>)>) -> Vec<Breakpoint> {
            let breakpoints: Vec<Breakpoint> = names.iter().map(|(name, condition)| {
                Breakpoint {
                    id: self.next_breakpoint_id.fetch_add(1, Ordering::Relaxed),
                    verified: true,
                    source: Source { name: Some(name.clone()), path: None, source_reference: 0 },
                    line: 0,
                    column: None,
                    end_line: None,
                    end_column: None,
                    condition: condition.clone(),
                    hit_condition: None,
                    log_message: None,
                    breakpoint_type: BreakpointType::Function,
                    hit_count: AtomicU64::new(0),
                }
            }).collect();
            *self.function_breakpoints.write().unwrap() = breakpoints.clone();
            breakpoints
        }

        pub fn set_exception_breakpoints(&self, filters: Vec<ExceptionFilterOptions>) {
            *self.exception_breakpoints.write().unwrap() = filters;
        }

        pub fn get_breakpoints(&self, path: &str) -> Vec<Breakpoint> {
            self.breakpoints.read().unwrap().get(path).cloned().unwrap_or_default()
        }

        pub fn check_breakpoint(&self, path: &str, line: u32) -> Option<Breakpoint> {
            self.breakpoints.read().unwrap()
                .get(path)?
                .iter()
                .find(|bp| bp.line == line)
                .cloned()
        }

        pub fn launch(&self, program: &str, args: Vec<String>, cwd: Option<String>, env: HashMap<String, String>) -> bool {
            let main_thread = Thread { id: 1, name: "main".into() };
            self.threads.write().unwrap().insert(1, main_thread);
            self.current_thread.store(1, Ordering::Relaxed);
            self.is_running.store(true, Ordering::Relaxed);
            true
        }

        pub fn attach(&self, pid: u64) -> bool {
            let main_thread = Thread { id: 1, name: format!("Thread {}", pid) };
            self.threads.write().unwrap().insert(1, main_thread);
            self.current_thread.store(1, Ordering::Relaxed);
            self.is_running.store(true, Ordering::Relaxed);
            true
        }

        pub fn continue_execution(&self, thread_id: Option<u64>) -> bool {
            self.is_running.store(true, Ordering::Relaxed);
            true
        }

        pub fn pause(&self, thread_id: Option<u64>) -> bool {
            self.is_running.store(false, Ordering::Relaxed);
            true
        }

        pub fn step_over(&self, thread_id: u64) -> bool {
            self.is_running.store(false, Ordering::Relaxed);
            true
        }

        pub fn step_into(&self, thread_id: u64) -> bool {
            self.is_running.store(false, Ordering::Relaxed);
            true
        }

        pub fn step_out(&self, thread_id: u64) -> bool {
            self.is_running.store(false, Ordering::Relaxed);
            true
        }

        pub fn terminate(&self) -> bool {
            self.is_running.store(false, Ordering::Relaxed);
            self.threads.write().unwrap().clear();
            self.stack_frames.write().unwrap().clear();
            self.variables.write().unwrap().clear();
            true
        }

        pub fn threads(&self) -> Vec<Thread> {
            self.threads.read().unwrap().values().cloned().collect()
        }

        pub fn stack_trace(&self, thread_id: u64, start_frame: Option<u32>, levels: Option<u32>) -> Vec<StackFrame> {
            self.stack_frames.read().unwrap().get(&thread_id).cloned().unwrap_or_default()
        }

        pub fn scopes(&self, frame_id: u64) -> Vec<Scope> {
            vec![
                Scope {
                    name: "Locals".into(),
                    presentation_hint: ScopePresentationHint::Locals,
                    variables_reference: self.next_var_reference.fetch_add(1, Ordering::Relaxed),
                    named_variables: None,
                    indexed_variables: None,
                    expensive: false,
                    source: None, line: None, column: None, end_line: None, end_column: None,
                },
                Scope {
                    name: "Arguments".into(),
                    presentation_hint: ScopePresentationHint::Arguments,
                    variables_reference: self.next_var_reference.fetch_add(1, Ordering::Relaxed),
                    named_variables: None,
                    indexed_variables: None,
                    expensive: false,
                    source: None, line: None, column: None, end_line: None, end_column: None,
                },
            ]
        }

        pub fn variables(&self, variables_reference: u64) -> Vec<Variable> {
            self.variables.read().unwrap().get(&variables_reference).cloned().unwrap_or_default()
        }

        pub fn set_variable(&self, variables_reference: u64, name: &str, value: &str) -> Option<Variable> {
            let mut vars = self.variables.write().unwrap();
            if let Some(ref_vars) = vars.get_mut(&variables_reference) {
                if let Some(var) = ref_vars.iter_mut().find(|v| v.name == name) {
                    var.value = value.to_string();
                    return Some(var.clone());
                }
            }
            None
        }

        pub fn evaluate(&self, expression: &str, frame_id: Option<u64>, context: &str) -> Option<(String, String, u64)> {
            Some((expression.to_string(), "evaluated".into(), 0))
        }

        pub fn loaded_sources(&self) -> Vec<Source> {
            self.breakpoints.read().unwrap().keys().map(|path| {
                Source { name: Some(path.split('/').last().unwrap_or(path).to_string()), path: Some(path.clone()), source_reference: 0 }
            }).collect()
        }

        pub fn modules(&self) -> Vec<Module> {
            self.modules.read().unwrap().clone()
        }

        pub fn read_memory(&self, address: &str, offset: i64, count: u64) -> Option<(String, Vec<u8>)> {
            Some((address.to_string(), vec![0; count as usize]))
        }

        pub fn disassemble(&self, address: &str, offset: i64, count: u64) -> Vec<DisassembledInstruction> {
            Vec::new()
        }
    }
}

// =============================================================================
// STATIC ANALYSIS ENGINE
// =============================================================================

pub mod static_analysis {
    use std::collections::{HashMap, HashSet};

    #[derive(Debug, Clone, PartialEq)]
    pub enum Severity { Error, Warning, Info, Hint }

    #[derive(Debug, Clone)]
    pub struct AnalysisIssue {
        pub severity: Severity,
        pub code: String,
        pub message: String,
        pub file: String,
        pub line: u32,
        pub column: u32,
        pub end_line: Option<u32>,
        pub end_column: Option<u32>,
        pub suggestion: Option<String>,
        pub category: IssueCategory,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum IssueCategory {
        Correctness, Performance, Security, Style, Complexity, Maintainability, Deprecated,
    }

    #[derive(Debug, Clone)]
    pub struct AnalysisConfig {
        pub enabled_rules: HashSet<String>,
        pub disabled_rules: HashSet<String>,
        pub severity_overrides: HashMap<String, Severity>,
        pub max_line_length: usize,
        pub max_function_length: usize,
        pub max_complexity: usize,
        pub max_nesting_depth: usize,
        pub check_unused: bool,
        pub check_dead_code: bool,
        pub check_security: bool,
    }

    impl Default for AnalysisConfig {
        fn default() -> Self {
            Self {
                enabled_rules: HashSet::new(),
                disabled_rules: HashSet::new(),
                severity_overrides: HashMap::new(),
                max_line_length: 120,
                max_function_length: 50,
                max_complexity: 10,
                max_nesting_depth: 4,
                check_unused: true,
                check_dead_code: true,
                check_security: true,
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct FunctionMetrics {
        pub name: String,
        pub lines: usize,
        pub cyclomatic_complexity: usize,
        pub cognitive_complexity: usize,
        pub nesting_depth: usize,
        pub parameter_count: usize,
        pub return_count: usize,
        pub halstead_volume: f64,
        pub maintainability_index: f64,
    }

    #[derive(Debug, Clone)]
    pub struct FileMetrics {
        pub path: String,
        pub lines_of_code: usize,
        pub blank_lines: usize,
        pub comment_lines: usize,
        pub functions: Vec<FunctionMetrics>,
        pub classes: usize,
        pub imports: usize,
        pub avg_complexity: f64,
    }

    pub struct StaticAnalyzer {
        config: AnalysisConfig,
        rules: Vec<Box<dyn AnalysisRule>>,
    }

    pub trait AnalysisRule: Send + Sync {
        fn name(&self) -> &str;
        fn code(&self) -> &str;
        fn category(&self) -> IssueCategory;
        fn analyze(&self, source: &str, file: &str) -> Vec<AnalysisIssue>;
    }

    struct UnusedVariableRule;
    impl AnalysisRule for UnusedVariableRule {
        fn name(&self) -> &str { "Unused Variable" }
        fn code(&self) -> &str { "unused-variable" }
        fn category(&self) -> IssueCategory { IssueCategory::Maintainability }
        fn analyze(&self, source: &str, file: &str) -> Vec<AnalysisIssue> {
            let mut issues = Vec::new();
            let mut declared: HashMap<String, (u32, u32)> = HashMap::new();
            let mut used: HashSet<String> = HashSet::new();
            for (line_num, line) in source.lines().enumerate() {
                if let Some(cap) = line.find("let ") {
                    let rest = &line[cap + 4..];
                    if let Some(name) = rest.split(|c: char| !c.is_alphanumeric() && c != '_').next() {
                        if !name.is_empty() && !name.starts_with('_') {
                            declared.insert(name.to_string(), (line_num as u32 + 1, cap as u32));
                        }
                    }
                }
                for word in line.split(|c: char| !c.is_alphanumeric() && c != '_').filter(|w| !w.is_empty()) {
                    used.insert(word.to_string());
                }
            }
            for (name, (line, col)) in declared {
                if !used.contains(&name) || used.iter().filter(|w| *w == &name).count() <= 1 {
                    issues.push(AnalysisIssue {
                        severity: Severity::Warning,
                        code: self.code().into(),
                        message: format!("Variable '{}' is declared but never used", name),
                        file: file.into(),
                        line, column: col,
                        end_line: None, end_column: None,
                        suggestion: Some(format!("Remove unused variable or prefix with '_': _{}", name)),
                        category: self.category(),
                    });
                }
            }
            issues
        }
    }

    struct LineLengthRule { max_length: usize }
    impl AnalysisRule for LineLengthRule {
        fn name(&self) -> &str { "Line Length" }
        fn code(&self) -> &str { "line-length" }
        fn category(&self) -> IssueCategory { IssueCategory::Style }
        fn analyze(&self, source: &str, file: &str) -> Vec<AnalysisIssue> {
            source.lines().enumerate()
                .filter(|(_, line)| line.len() > self.max_length)
                .map(|(num, line)| AnalysisIssue {
                    severity: Severity::Warning,
                    code: self.code().into(),
                    message: format!("Line exceeds {} characters ({} chars)", self.max_length, line.len()),
                    file: file.into(),
                    line: num as u32 + 1,
                    column: self.max_length as u32,
                    end_line: None,
                    end_column: Some(line.len() as u32),
                    suggestion: Some("Consider breaking this line into multiple lines".into()),
                    category: self.category(),
                }).collect()
        }
    }

    struct SecurityRule;
    impl AnalysisRule for SecurityRule {
        fn name(&self) -> &str { "Security Check" }
        fn code(&self) -> &str { "security" }
        fn category(&self) -> IssueCategory { IssueCategory::Security }
        fn analyze(&self, source: &str, file: &str) -> Vec<AnalysisIssue> {
            let mut issues = Vec::new();
            let patterns = [
                ("eval(", "eval-usage", "Avoid using eval() as it can execute arbitrary code"),
                ("innerHTML", "inner-html", "innerHTML can lead to XSS vulnerabilities"),
                ("dangerouslySetInnerHTML", "dangerous-html", "dangerouslySetInnerHTML can lead to XSS"),
                ("password", "hardcoded-secret", "Possible hardcoded password detected"),
                ("api_key", "hardcoded-secret", "Possible hardcoded API key detected"),
                ("exec(", "command-injection", "Command execution can lead to injection attacks"),
                ("shell(", "command-injection", "Shell execution can lead to injection attacks"),
            ];
            for (line_num, line) in source.lines().enumerate() {
                let lower = line.to_lowercase();
                for (pattern, code, message) in &patterns {
                    if lower.contains(*pattern) {
                        if let Some(col) = lower.find(*pattern) {
                            issues.push(AnalysisIssue {
                                severity: Severity::Warning,
                                code: format!("{}-{}", self.code(), code),
                                message: (*message).to_string(),
                                file: file.into(),
                                line: line_num as u32 + 1,
                                column: col as u32,
                                end_line: None, end_column: None,
                                suggestion: None,
                                category: self.category(),
                            });
                        }
                    }
                }
            }
            issues
        }
    }

    struct ComplexityRule { max_complexity: usize }
    impl ComplexityRule {
        fn calculate_cyclomatic(&self, function_body: &str) -> usize {
            let mut complexity = 1;
            let keywords = ["if", "else if", "elif", "for", "while", "case", "catch", "&&", "||", "?"];
            for keyword in &keywords {
                complexity += function_body.matches(keyword).count();
            }
            complexity
        }
    }
    impl AnalysisRule for ComplexityRule {
        fn name(&self) -> &str { "Complexity" }
        fn code(&self) -> &str { "complexity" }
        fn category(&self) -> IssueCategory { IssueCategory::Complexity }
        fn analyze(&self, source: &str, file: &str) -> Vec<AnalysisIssue> {
            let mut issues = Vec::new();
            let mut in_function = false;
            let mut function_name = String::new();
            let mut function_start = 0;
            let mut function_body = String::new();
            let mut brace_count = 0;
            for (line_num, line) in source.lines().enumerate() {
                if !in_function {
                    if let Some(fn_pos) = line.find("fn ") {
                        let rest = &line[fn_pos + 3..];
                        if let Some(name) = rest.split('(').next() {
                            function_name = name.trim().to_string();
                            function_start = line_num as u32 + 1;
                            in_function = true;
                            brace_count = 0;
                        }
                    }
                }
                if in_function {
                    function_body.push_str(line);
                    function_body.push('\n');
                    brace_count += line.matches('{').count();
                    brace_count -= line.matches('}').count();
                    if brace_count == 0 && function_body.contains('{') {
                        let complexity = self.calculate_cyclomatic(&function_body);
                        if complexity > self.max_complexity {
                            issues.push(AnalysisIssue {
                                severity: Severity::Warning,
                                code: self.code().into(),
                                message: format!("Function '{}' has cyclomatic complexity of {} (max: {})", function_name, complexity, self.max_complexity),
                                file: file.into(),
                                line: function_start,
                                column: 0,
                                end_line: Some(line_num as u32 + 1),
                                end_column: None,
                                suggestion: Some("Consider refactoring to reduce complexity".into()),
                                category: self.category(),
                            });
                        }
                        in_function = false;
                        function_body.clear();
                    }
                }
            }
            issues
        }
    }

    impl StaticAnalyzer {
        pub fn new(config: AnalysisConfig) -> Self {
            let mut rules: Vec<Box<dyn AnalysisRule>> = Vec::new();
            if config.check_unused {
                rules.push(Box::new(UnusedVariableRule));
            }
            rules.push(Box::new(LineLengthRule { max_length: config.max_line_length }));
            if config.check_security {
                rules.push(Box::new(SecurityRule));
            }
            rules.push(Box::new(ComplexityRule { max_complexity: config.max_complexity }));
            Self { config, rules }
        }

        pub fn analyze(&self, source: &str, file: &str) -> Vec<AnalysisIssue> {
            self.rules.iter()
                .filter(|r| !self.config.disabled_rules.contains(r.code()))
                .flat_map(|r| r.analyze(source, file))
                .map(|mut issue| {
                    if let Some(severity) = self.config.severity_overrides.get(&issue.code) {
                        issue.severity = severity.clone();
                    }
                    issue
                }).collect()
        }

        pub fn compute_metrics(&self, source: &str, file: &str) -> FileMetrics {
            let lines: Vec<&str> = source.lines().collect();
            let lines_of_code = lines.iter().filter(|l| !l.trim().is_empty() && !l.trim().starts_with("//")).count();
            let blank_lines = lines.iter().filter(|l| l.trim().is_empty()).count();
            let comment_lines = lines.iter().filter(|l| l.trim().starts_with("//")).count();
            FileMetrics {
                path: file.into(),
                lines_of_code,
                blank_lines,
                comment_lines,
                functions: Vec::new(),
                classes: 0,
                imports: lines.iter().filter(|l| l.trim().starts_with("use ") || l.trim().starts_with("import ")).count(),
                avg_complexity: 0.0,
            }
        }

        pub fn add_rule(&mut self, rule: Box<dyn AnalysisRule>) {
            self.rules.push(rule);
        }
    }
}

// =============================================================================
// REFACTORING ENGINE
// =============================================================================

pub mod refactoring {
    use std::collections::HashMap;

    #[derive(Debug, Clone)]
    pub struct TextEdit { pub start: usize, pub end: usize, pub new_text: String }

    #[derive(Debug, Clone)]
    pub struct RefactoringResult {
        pub edits: HashMap<String, Vec<TextEdit>>,
        pub files_created: Vec<(String, String)>,
        pub files_deleted: Vec<String>,
        pub files_renamed: Vec<(String, String)>,
    }

    impl RefactoringResult {
        pub fn new() -> Self {
            Self { edits: HashMap::new(), files_created: vec![], files_deleted: vec![], files_renamed: vec![] }
        }
        pub fn add_edit(&mut self, file: &str, edit: TextEdit) {
            self.edits.entry(file.to_string()).or_insert_with(Vec::new).push(edit);
        }
    }

    pub struct RefactoringEngine {
        sources: HashMap<String, String>,
    }

    impl RefactoringEngine {
        pub fn new() -> Self { Self { sources: HashMap::new() } }

        pub fn load_source(&mut self, path: &str, content: String) {
            self.sources.insert(path.to_string(), content);
        }

        pub fn rename_symbol(&self, file: &str, position: usize, new_name: &str) -> RefactoringResult {
            let mut result = RefactoringResult::new();
            let source = match self.sources.get(file) { Some(s) => s, None => return result };
            let old_name = Self::extract_word_at(source, position);
            if old_name.is_empty() { return result; }
            for (path, content) in &self.sources {
                let mut search_start = 0;
                while let Some(pos) = content[search_start..].find(&old_name) {
                    let abs_pos = search_start + pos;
                    let before = if abs_pos > 0 { content.chars().nth(abs_pos - 1) } else { None };
                    let after = content.chars().nth(abs_pos + old_name.len());
                    let is_boundary = |c: Option<char>| c.map(|c| !c.is_alphanumeric() && c != '_').unwrap_or(true);
                    if is_boundary(before) && is_boundary(after) {
                        result.add_edit(path, TextEdit {
                            start: abs_pos,
                            end: abs_pos + old_name.len(),
                            new_text: new_name.to_string(),
                        });
                    }
                    search_start = abs_pos + old_name.len();
                }
            }
            result
        }

        fn extract_word_at(source: &str, position: usize) -> String {
            let chars: Vec<char> = source.chars().collect();
            if position >= chars.len() { return String::new(); }
            let mut start = position;
            while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') { start -= 1; }
            let mut end = position;
            while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') { end += 1; }
            chars[start..end].iter().collect()
        }

        pub fn extract_function(&self, file: &str, start: usize, end: usize, fn_name: &str) -> RefactoringResult {
            let mut result = RefactoringResult::new();
            let source = match self.sources.get(file) { Some(s) => s, None => return result };
            if end > source.len() || start >= end { return result; }
            let extracted = &source[start..end];
            let indent = Self::detect_indent(source, start);
            let new_function = format!("\n{}fn {}() {{\n{}    {}\n{}}}\n", indent, fn_name, indent, extracted.trim(), indent);
            let line_end = source[end..].find('\n').map(|p| end + p + 1).unwrap_or(source.len());
            result.add_edit(file, TextEdit { start: line_end, end: line_end, new_text: new_function });
            result.add_edit(file, TextEdit { start, end, new_text: format!("{}()", fn_name) });
            result
        }

        fn detect_indent(source: &str, position: usize) -> String {
            let line_start = source[..position].rfind('\n').map(|p| p + 1).unwrap_or(0);
            let line = &source[line_start..];
            line.chars().take_while(|c| c.is_whitespace()).collect()
        }

        pub fn extract_variable(&self, file: &str, start: usize, end: usize, var_name: &str) -> RefactoringResult {
            let mut result = RefactoringResult::new();
            let source = match self.sources.get(file) { Some(s) => s, None => return result };
            if end > source.len() || start >= end { return result; }
            let extracted = &source[start..end];
            let indent = Self::detect_indent(source, start);
            let line_start = source[..start].rfind('\n').map(|p| p + 1).unwrap_or(0);
            let declaration = format!("{}let {} = {};\n", indent, var_name, extracted.trim());
            result.add_edit(file, TextEdit { start, end, new_text: var_name.to_string() });
            result.add_edit(file, TextEdit { start: line_start, end: line_start, new_text: declaration });
            result
        }

        pub fn inline_variable(&self, file: &str, position: usize) -> RefactoringResult {
            let mut result = RefactoringResult::new();
            let source = match self.sources.get(file) { Some(s) => s, None => return result };
            let var_name = Self::extract_word_at(source, position);
            if var_name.is_empty() { return result; }
            let pattern = format!("let {} = ", var_name);
            if let Some(decl_pos) = source.find(&pattern) {
                let value_start = decl_pos + pattern.len();
                let value_end = source[value_start..].find(';').map(|p| value_start + p).unwrap_or(source.len());
                let value = source[value_start..value_end].trim().to_string();
                let line_end = source[value_end..].find('\n').map(|p| value_end + p + 1).unwrap_or(source.len());
                result.add_edit(file, TextEdit { start: source[..decl_pos].rfind('\n').map(|p| p + 1).unwrap_or(0), end: line_end, new_text: String::new() });
                let mut search_start = line_end;
                while let Some(pos) = source[search_start..].find(&var_name) {
                    let abs_pos = search_start + pos;
                    let before = if abs_pos > 0 { source.chars().nth(abs_pos - 1) } else { None };
                    let after = source.chars().nth(abs_pos + var_name.len());
                    let is_boundary = |c: Option<char>| c.map(|c| !c.is_alphanumeric() && c != '_').unwrap_or(true);
                    if is_boundary(before) && is_boundary(after) {
                        result.add_edit(file, TextEdit { start: abs_pos, end: abs_pos + var_name.len(), new_text: value.clone() });
                    }
                    search_start = abs_pos + var_name.len();
                }
            }
            result
        }

        pub fn move_to_file(&self, file: &str, start: usize, end: usize, new_file: &str) -> RefactoringResult {
            let mut result = RefactoringResult::new();
            let source = match self.sources.get(file) { Some(s) => s, None => return result };
            if end > source.len() || start >= end { return result; }
            let extracted = source[start..end].to_string();
            result.add_edit(file, TextEdit { start, end, new_text: String::new() });
            result.files_created.push((new_file.to_string(), extracted));
            result
        }

        pub fn organize_imports(&self, file: &str) -> RefactoringResult {
            let mut result = RefactoringResult::new();
            let source = match self.sources.get(file) { Some(s) => s, None => return result };
            let mut imports: Vec<(usize, usize, &str)> = Vec::new();
            let mut current_pos = 0;
            for line in source.lines() {
                let trimmed = line.trim();
                if trimmed.starts_with("use ") || trimmed.starts_with("import ") {
                    imports.push((current_pos, current_pos + line.len() + 1, trimmed));
                }
                current_pos += line.len() + 1;
            }
            if imports.len() <= 1 { return result; }
            let mut sorted: Vec<&str> = imports.iter().map(|(_, _, s)| *s).collect();
            sorted.sort();
            if sorted == imports.iter().map(|(_, _, s)| *s).collect::<Vec<_>>() { return result; }
            let first_start = imports[0].0;
            let last_end = imports.last().unwrap().1;
            let new_imports = sorted.join("\n") + "\n";
            result.add_edit(file, TextEdit { start: first_start, end: last_end, new_text: new_imports });
            result
        }
    }
}

// =============================================================================
// BUILD CACHE SYSTEM
// =============================================================================

pub mod build_cache {
    use std::collections::HashMap;
    use std::sync::{Arc, RwLock};
    use std::time::{Duration, SystemTime};

    #[derive(Debug, Clone, Hash, PartialEq, Eq)]
    pub struct CacheKey { pub source_hash: String, pub target: String, pub compiler_version: String, pub flags: Vec<String> }

    #[derive(Debug, Clone)]
    pub struct CacheEntry {
        pub key: CacheKey,
        pub artifact_path: String,
        pub created_at: SystemTime,
        pub last_accessed: SystemTime,
        pub size_bytes: u64,
        pub dependencies: Vec<String>,
        pub metadata: HashMap<String, String>,
    }

    #[derive(Debug, Clone)]
    pub struct CacheConfig {
        pub max_size_bytes: u64,
        pub max_entries: usize,
        pub ttl: Duration,
        pub cache_dir: String,
        pub compression: bool,
        pub shared: bool,
    }

    impl Default for CacheConfig {
        fn default() -> Self {
            Self {
                max_size_bytes: 10 * 1024 * 1024 * 1024,
                max_entries: 10000,
                ttl: Duration::from_secs(7 * 24 * 60 * 60),
                cache_dir: ".build-cache".into(),
                compression: true,
                shared: false,
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct CacheStats {
        pub hits: u64,
        pub misses: u64,
        pub entries: usize,
        pub size_bytes: u64,
        pub evictions: u64,
        pub hit_rate: f64,
    }

    pub struct BuildCache {
        config: CacheConfig,
        entries: RwLock<HashMap<CacheKey, CacheEntry>>,
        stats: RwLock<CacheStats>,
    }

    impl BuildCache {
        pub fn new(config: CacheConfig) -> Self {
            Self {
                config,
                entries: RwLock::new(HashMap::new()),
                stats: RwLock::new(CacheStats { hits: 0, misses: 0, entries: 0, size_bytes: 0, evictions: 0, hit_rate: 0.0 }),
            }
        }

        pub fn get(&self, key: &CacheKey) -> Option<CacheEntry> {
            let entries = self.entries.read().unwrap();
            if let Some(entry) = entries.get(key) {
                if entry.created_at.elapsed().ok()? < self.config.ttl {
                    let mut stats = self.stats.write().unwrap();
                    stats.hits += 1;
                    stats.hit_rate = stats.hits as f64 / (stats.hits + stats.misses) as f64;
                    return Some(entry.clone());
                }
            }
            let mut stats = self.stats.write().unwrap();
            stats.misses += 1;
            stats.hit_rate = stats.hits as f64 / (stats.hits + stats.misses) as f64;
            None
        }

        pub fn put(&self, key: CacheKey, artifact_path: String, size_bytes: u64, dependencies: Vec<String>) -> bool {
            let mut entries = self.entries.write().unwrap();
            let mut stats = self.stats.write().unwrap();
            while stats.size_bytes + size_bytes > self.config.max_size_bytes || entries.len() >= self.config.max_entries {
                if let Some(oldest_key) = Self::find_lru(&entries) {
                    if let Some(removed) = entries.remove(&oldest_key) {
                        stats.size_bytes -= removed.size_bytes;
                        stats.evictions += 1;
                    }
                } else {
                    break;
                }
            }
            let now = SystemTime::now();
            let entry = CacheEntry { key: key.clone(), artifact_path, created_at: now, last_accessed: now, size_bytes, dependencies, metadata: HashMap::new() };
            entries.insert(key, entry);
            stats.entries = entries.len();
            stats.size_bytes += size_bytes;
            true
        }

        fn find_lru(entries: &HashMap<CacheKey, CacheEntry>) -> Option<CacheKey> {
            entries.iter().min_by_key(|(_, e)| e.last_accessed).map(|(k, _)| k.clone())
        }

        pub fn invalidate(&self, key: &CacheKey) -> bool {
            let mut entries = self.entries.write().unwrap();
            if let Some(removed) = entries.remove(key) {
                let mut stats = self.stats.write().unwrap();
                stats.size_bytes -= removed.size_bytes;
                stats.entries = entries.len();
                return true;
            }
            false
        }

        pub fn invalidate_by_dependency(&self, dependency: &str) -> usize {
            let mut entries = self.entries.write().unwrap();
            let mut stats = self.stats.write().unwrap();
            let to_remove: Vec<CacheKey> = entries.iter()
                .filter(|(_, e)| e.dependencies.iter().any(|d| d == dependency))
                .map(|(k, _)| k.clone()).collect();
            let count = to_remove.len();
            for key in to_remove {
                if let Some(removed) = entries.remove(&key) {
                    stats.size_bytes -= removed.size_bytes;
                }
            }
            stats.entries = entries.len();
            count
        }

        pub fn clear(&self) {
            let mut entries = self.entries.write().unwrap();
            let mut stats = self.stats.write().unwrap();
            entries.clear();
            stats.entries = 0;
            stats.size_bytes = 0;
        }

        pub fn prune_expired(&self) -> usize {
            let mut entries = self.entries.write().unwrap();
            let mut stats = self.stats.write().unwrap();
            let now = SystemTime::now();
            let to_remove: Vec<CacheKey> = entries.iter()
                .filter(|(_, e)| e.created_at.elapsed().map(|d| d > self.config.ttl).unwrap_or(true))
                .map(|(k, _)| k.clone()).collect();
            let count = to_remove.len();
            for key in to_remove {
                if let Some(removed) = entries.remove(&key) {
                    stats.size_bytes -= removed.size_bytes;
                }
            }
            stats.entries = entries.len();
            count
        }

        pub fn stats(&self) -> CacheStats { self.stats.read().unwrap().clone() }

        pub fn hash_content(content: &[u8]) -> String {
            let mut hash: u64 = 0xcbf29ce484222325;
            for byte in content {
                hash ^= *byte as u64;
                hash = hash.wrapping_mul(0x100000001b3);
            }
            format!("{:016x}", hash)
        }
    }
}

// =============================================================================
// SOURCE MAP GENERATOR
// =============================================================================

pub mod source_maps {
    use std::collections::HashMap;

    #[derive(Debug, Clone)]
    pub struct Position { pub line: u32, pub column: u32 }

    #[derive(Debug, Clone)]
    pub struct Mapping {
        pub generated: Position,
        pub original: Option<Position>,
        pub source_index: Option<usize>,
        pub name_index: Option<usize>,
    }

    #[derive(Debug, Clone)]
    pub struct SourceMap {
        pub version: u32,
        pub file: Option<String>,
        pub source_root: Option<String>,
        pub sources: Vec<String>,
        pub sources_content: Vec<Option<String>>,
        pub names: Vec<String>,
        pub mappings: String,
        decoded_mappings: Vec<Mapping>,
    }

    impl SourceMap {
        pub fn new() -> Self {
            Self {
                version: 3,
                file: None,
                source_root: None,
                sources: Vec::new(),
                sources_content: Vec::new(),
                names: Vec::new(),
                mappings: String::new(),
                decoded_mappings: Vec::new(),
            }
        }

        pub fn add_source(&mut self, source: String, content: Option<String>) -> usize {
            let index = self.sources.len();
            self.sources.push(source);
            self.sources_content.push(content);
            index
        }

        pub fn add_name(&mut self, name: String) -> usize {
            if let Some(index) = self.names.iter().position(|n| n == &name) { return index; }
            let index = self.names.len();
            self.names.push(name);
            index
        }

        pub fn add_mapping(&mut self, mapping: Mapping) {
            self.decoded_mappings.push(mapping);
        }

        pub fn encode(&mut self) {
            self.decoded_mappings.sort_by(|a, b| {
                a.generated.line.cmp(&b.generated.line)
                    .then(a.generated.column.cmp(&b.generated.column))
            });
            let mut result = String::new();
            let mut prev_gen_line = 0u32;
            let mut prev_gen_col = 0u32;
            let mut prev_source = 0i64;
            let mut prev_orig_line = 0i64;
            let mut prev_orig_col = 0i64;
            let mut prev_name = 0i64;
            for mapping in &self.decoded_mappings {
                while prev_gen_line < mapping.generated.line {
                    result.push(';');
                    prev_gen_line += 1;
                    prev_gen_col = 0;
                }
                if !result.is_empty() && !result.ends_with(';') { result.push(','); }
                result.push_str(&Self::vlq_encode(mapping.generated.column as i64 - prev_gen_col as i64));
                prev_gen_col = mapping.generated.column;
                if let (Some(orig), Some(source_idx)) = (&mapping.original, mapping.source_index) {
                    result.push_str(&Self::vlq_encode(source_idx as i64 - prev_source));
                    prev_source = source_idx as i64;
                    result.push_str(&Self::vlq_encode(orig.line as i64 - prev_orig_line));
                    prev_orig_line = orig.line as i64;
                    result.push_str(&Self::vlq_encode(orig.column as i64 - prev_orig_col));
                    prev_orig_col = orig.column as i64;
                    if let Some(name_idx) = mapping.name_index {
                        result.push_str(&Self::vlq_encode(name_idx as i64 - prev_name));
                        prev_name = name_idx as i64;
                    }
                }
            }
            self.mappings = result;
        }

        fn vlq_encode(value: i64) -> String {
            const BASE64: &[u8] = b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
            let mut result = String::new();
            let mut v = if value < 0 { ((-value) << 1) | 1 } else { value << 1 };
            loop {
                let mut digit = (v & 0x1f) as usize;
                v >>= 5;
                if v > 0 { digit |= 0x20; }
                result.push(BASE64[digit] as char);
                if v == 0 { break; }
            }
            result
        }

        pub fn decode(&mut self) {
            self.decoded_mappings.clear();
            let mut gen_line = 0u32;
            let mut gen_col = 0i64;
            let mut source_idx = 0i64;
            let mut orig_line = 0i64;
            let mut orig_col = 0i64;
            let mut name_idx = 0i64;
            for segment in self.mappings.split(';') {
                gen_col = 0;
                for mapping_str in segment.split(',') {
                    if mapping_str.is_empty() { continue; }
                    let values = Self::vlq_decode_all(mapping_str);
                    if values.is_empty() { continue; }
                    gen_col += values[0];
                    let mut mapping = Mapping {
                        generated: Position { line: gen_line, column: gen_col as u32 },
                        original: None,
                        source_index: None,
                        name_index: None,
                    };
                    if values.len() >= 4 {
                        source_idx += values[1];
                        orig_line += values[2];
                        orig_col += values[3];
                        mapping.source_index = Some(source_idx as usize);
                        mapping.original = Some(Position { line: orig_line as u32, column: orig_col as u32 });
                        if values.len() >= 5 {
                            name_idx += values[4];
                            mapping.name_index = Some(name_idx as usize);
                        }
                    }
                    self.decoded_mappings.push(mapping);
                }
                gen_line += 1;
            }
        }

        fn vlq_decode_all(input: &str) -> Vec<i64> {
            const BASE64: &str = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
            let mut result = Vec::new();
            let mut value = 0i64;
            let mut shift = 0;
            for c in input.chars() {
                let digit = match BASE64.find(c) { Some(d) => d as i64, None => continue };
                value += (digit & 0x1f) << shift;
                shift += 5;
                if (digit & 0x20) == 0 {
                    let neg = (value & 1) == 1;
                    value >>= 1;
                    result.push(if neg { -value } else { value });
                    value = 0;
                    shift = 0;
                }
            }
            result
        }

        pub fn lookup(&self, generated: &Position) -> Option<(&str, Position, Option<&str>)> {
            let mapping = self.decoded_mappings.iter()
                .filter(|m| m.generated.line == generated.line && m.generated.column <= generated.column)
                .max_by_key(|m| m.generated.column)?;
            let source = mapping.source_index.and_then(|i| self.sources.get(i))?;
            let original = mapping.original.as_ref()?;
            let name = mapping.name_index.and_then(|i| self.names.get(i)).map(|s| s.as_str());
            Some((source, original.clone(), name))
        }

        pub fn to_json(&self) -> String {
            let sources_json: Vec<String> = self.sources.iter().map(|s| format!("\"{}\"", s)).collect();
            let names_json: Vec<String> = self.names.iter().map(|s| format!("\"{}\"", s)).collect();
            let sources_content_json: Vec<String> = self.sources_content.iter()
                .map(|s| s.as_ref().map(|c| format!("\"{}\"", c.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n"))).unwrap_or("null".into())).collect();
            format!(r#"{{"version":{},"file":{},"sourceRoot":{},"sources":[{}],"sourcesContent":[{}],"names":[{}],"mappings":"{}"}}"#,
                self.version,
                self.file.as_ref().map(|f| format!("\"{}\"", f)).unwrap_or("null".into()),
                self.source_root.as_ref().map(|r| format!("\"{}\"", r)).unwrap_or("null".into()),
                sources_json.join(","),
                sources_content_json.join(","),
                names_json.join(","),
                self.mappings)
        }
    }

    pub struct SourceMapGenerator {
        source_maps: HashMap<String, SourceMap>,
    }

    impl SourceMapGenerator {
        pub fn new() -> Self { Self { source_maps: HashMap::new() } }

        pub fn create(&mut self, output_file: &str) -> &mut SourceMap {
            let mut map = SourceMap::new();
            map.file = Some(output_file.to_string());
            self.source_maps.insert(output_file.to_string(), map);
            self.source_maps.get_mut(output_file).unwrap()
        }

        pub fn get(&self, output_file: &str) -> Option<&SourceMap> { self.source_maps.get(output_file) }
        pub fn get_mut(&mut self, output_file: &str) -> Option<&mut SourceMap> { self.source_maps.get_mut(output_file) }
    }
}

// =============================================================================
// DOCUMENTATION GENERATOR
// =============================================================================

pub mod documentation {
    use std::collections::HashMap;

    #[derive(Debug, Clone)]
    pub struct DocComment {
        pub summary: String,
        pub description: String,
        pub params: Vec<ParamDoc>,
        pub returns: Option<String>,
        pub throws: Vec<String>,
        pub examples: Vec<String>,
        pub see_also: Vec<String>,
        pub since: Option<String>,
        pub deprecated: Option<String>,
        pub tags: HashMap<String, String>,
    }

    #[derive(Debug, Clone)]
    pub struct ParamDoc { pub name: String, pub param_type: Option<String>, pub description: String, pub optional: bool, pub default: Option<String> }

    #[derive(Debug, Clone, PartialEq)]
    pub enum ItemKind { Module, Struct, Enum, Trait, Function, Method, Constant, Type, Field, Variant }

    #[derive(Debug, Clone)]
    pub struct DocumentedItem {
        pub name: String,
        pub kind: ItemKind,
        pub signature: String,
        pub doc: Option<DocComment>,
        pub visibility: Visibility,
        pub source_file: String,
        pub line: u32,
        pub children: Vec<DocumentedItem>,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum Visibility { Public, Private, Protected, Internal }

    #[derive(Debug, Clone)]
    pub struct DocumentationConfig {
        pub include_private: bool,
        pub include_source: bool,
        pub include_examples: bool,
        pub output_format: OutputFormat,
        pub theme: String,
    }

    #[derive(Debug, Clone, PartialEq)]
    pub enum OutputFormat { Html, Markdown, Json }

    impl Default for DocumentationConfig {
        fn default() -> Self {
            Self { include_private: false, include_source: true, include_examples: true, output_format: OutputFormat::Html, theme: "default".into() }
        }
    }

    pub struct DocGenerator {
        config: DocumentationConfig,
        items: Vec<DocumentedItem>,
    }

    impl DocGenerator {
        pub fn new(config: DocumentationConfig) -> Self { Self { config, items: Vec::new() } }

        pub fn parse_source(&mut self, source: &str, file: &str) {
            let lines: Vec<&str> = source.lines().collect();
            let mut i = 0;
            while i < lines.len() {
                if let Some(doc) = self.try_parse_doc_comment(&lines, &mut i) {
                    if i < lines.len() {
                        if let Some(item) = self.try_parse_item(&lines, i, doc, file) {
                            if item.visibility == Visibility::Public || self.config.include_private {
                                self.items.push(item);
                            }
                        }
                    }
                }
                i += 1;
            }
        }

        fn try_parse_doc_comment(&self, lines: &[&str], index: &mut usize) -> Option<DocComment> {
            let mut doc_lines = Vec::new();
            while *index < lines.len() {
                let line = lines[*index].trim();
                if line.starts_with("///") {
                    doc_lines.push(line[3..].trim());
                    *index += 1;
                } else if line.starts_with("//!") {
                    doc_lines.push(line[3..].trim());
                    *index += 1;
                } else {
                    break;
                }
            }
            if doc_lines.is_empty() { return None; }
            Some(self.parse_doc_content(&doc_lines))
        }

        fn parse_doc_content(&self, lines: &[&str]) -> DocComment {
            let mut doc = DocComment {
                summary: String::new(),
                description: String::new(),
                params: Vec::new(),
                returns: None,
                throws: Vec::new(),
                examples: Vec::new(),
                see_also: Vec::new(),
                since: None,
                deprecated: None,
                tags: HashMap::new(),
            };
            let mut in_example = false;
            let mut example_buf = String::new();
            for line in lines {
                if line.starts_with("@param") || line.starts_with("# Arguments") {
                    let rest = line.strip_prefix("@param").unwrap_or(line).trim();
                    let parts: Vec<&str> = rest.splitn(2, ' ').collect();
                    if !parts.is_empty() {
                        doc.params.push(ParamDoc {
                            name: parts[0].to_string(),
                            param_type: None,
                            description: parts.get(1).unwrap_or(&"").to_string(),
                            optional: false,
                            default: None,
                        });
                    }
                } else if line.starts_with("@returns") || line.starts_with("# Returns") {
                    doc.returns = Some(line.strip_prefix("@returns").or_else(|| line.strip_prefix("# Returns")).unwrap_or(line).trim().to_string());
                } else if line.starts_with("@throws") || line.starts_with("# Errors") {
                    doc.throws.push(line.strip_prefix("@throws").or_else(|| line.strip_prefix("# Errors")).unwrap_or(line).trim().to_string());
                } else if line.starts_with("@since") {
                    doc.since = Some(line.strip_prefix("@since").unwrap_or(line).trim().to_string());
                } else if line.starts_with("@deprecated") {
                    doc.deprecated = Some(line.strip_prefix("@deprecated").unwrap_or(line).trim().to_string());
                } else if line.starts_with("@see") {
                    doc.see_also.push(line.strip_prefix("@see").unwrap_or(line).trim().to_string());
                } else if line.starts_with("```") || line.starts_with("# Example") {
                    if in_example {
                        doc.examples.push(example_buf.clone());
                        example_buf.clear();
                        in_example = false;
                    } else {
                        in_example = true;
                    }
                } else if in_example {
                    example_buf.push_str(line);
                    example_buf.push('\n');
                } else if doc.summary.is_empty() {
                    doc.summary = line.to_string();
                } else {
                    doc.description.push_str(line);
                    doc.description.push('\n');
                }
            }
            doc
        }

        fn try_parse_item(&self, lines: &[&str], index: usize, doc: DocComment, file: &str) -> Option<DocumentedItem> {
            let line = lines[index].trim();
            let visibility = if line.starts_with("pub ") { Visibility::Public } else { Visibility::Private };
            let cleaned = line.strip_prefix("pub ").unwrap_or(line);
            let (kind, name, signature) = if cleaned.starts_with("fn ") {
                let sig = cleaned.to_string();
                let name = cleaned[3..].split('(').next()?.trim().to_string();
                (ItemKind::Function, name, sig)
            } else if cleaned.starts_with("struct ") {
                let name = cleaned[7..].split(|c: char| !c.is_alphanumeric() && c != '_').next()?.to_string();
                (ItemKind::Struct, name, cleaned.to_string())
            } else if cleaned.starts_with("enum ") {
                let name = cleaned[5..].split(|c: char| !c.is_alphanumeric() && c != '_').next()?.to_string();
                (ItemKind::Enum, name, cleaned.to_string())
            } else if cleaned.starts_with("trait ") {
                let name = cleaned[6..].split(|c: char| !c.is_alphanumeric() && c != '_').next()?.to_string();
                (ItemKind::Trait, name, cleaned.to_string())
            } else if cleaned.starts_with("mod ") {
                let name = cleaned[4..].split(|c: char| !c.is_alphanumeric() && c != '_').next()?.to_string();
                (ItemKind::Module, name, cleaned.to_string())
            } else if cleaned.starts_with("const ") {
                let name = cleaned[6..].split(':').next()?.trim().to_string();
                (ItemKind::Constant, name, cleaned.to_string())
            } else if cleaned.starts_with("type ") {
                let name = cleaned[5..].split('=').next()?.trim().to_string();
                (ItemKind::Type, name, cleaned.to_string())
            } else {
                return None;
            };
            Some(DocumentedItem {
                name, kind, signature,
                doc: Some(doc),
                visibility,
                source_file: file.to_string(),
                line: index as u32 + 1,
                children: Vec::new(),
            })
        }

        pub fn generate(&self) -> String {
            match self.config.output_format {
                OutputFormat::Html => self.generate_html(),
                OutputFormat::Markdown => self.generate_markdown(),
                OutputFormat::Json => self.generate_json(),
            }
        }

        fn generate_html(&self) -> String {
            let mut html = String::from("<!DOCTYPE html><html><head><title>API Documentation</title><style>");
            html.push_str("body{font-family:sans-serif;margin:40px;} .item{margin:20px 0;padding:20px;border:1px solid #ddd;} ");
            html.push_str(".signature{font-family:monospace;background:#f5f5f5;padding:10px;} .params{margin-left:20px;}");
            html.push_str("</style></head><body><h1>API Documentation</h1>");
            for item in &self.items {
                html.push_str(&self.item_to_html(item));
            }
            html.push_str("</body></html>");
            html
        }

        fn item_to_html(&self, item: &DocumentedItem) -> String {
            let mut html = format!("<div class=\"item\"><h2>{:?}: {}</h2>", item.kind, item.name);
            html.push_str(&format!("<pre class=\"signature\">{}</pre>", item.signature));
            if let Some(doc) = &item.doc {
                if !doc.summary.is_empty() { html.push_str(&format!("<p><strong>{}</strong></p>", doc.summary)); }
                if !doc.description.is_empty() { html.push_str(&format!("<p>{}</p>", doc.description)); }
                if !doc.params.is_empty() {
                    html.push_str("<h4>Parameters</h4><ul class=\"params\">");
                    for param in &doc.params {
                        html.push_str(&format!("<li><code>{}</code>: {}</li>", param.name, param.description));
                    }
                    html.push_str("</ul>");
                }
                if let Some(returns) = &doc.returns { html.push_str(&format!("<h4>Returns</h4><p>{}</p>", returns)); }
            }
            html.push_str("</div>");
            html
        }

        fn generate_markdown(&self) -> String {
            let mut md = String::from("# API Documentation\n\n");
            for item in &self.items {
                md.push_str(&format!("## {:?}: {}\n\n", item.kind, item.name));
                md.push_str(&format!("```\n{}\n```\n\n", item.signature));
                if let Some(doc) = &item.doc {
                    if !doc.summary.is_empty() { md.push_str(&format!("**{}**\n\n", doc.summary)); }
                    if !doc.description.is_empty() { md.push_str(&format!("{}\n\n", doc.description)); }
                    if !doc.params.is_empty() {
                        md.push_str("### Parameters\n\n");
                        for param in &doc.params {
                            md.push_str(&format!("- `{}`: {}\n", param.name, param.description));
                        }
                        md.push('\n');
                    }
                    if let Some(returns) = &doc.returns { md.push_str(&format!("### Returns\n\n{}\n\n", returns)); }
                }
            }
            md
        }

        fn generate_json(&self) -> String {
            let mut json = String::from("{\"items\":[");
            for (i, item) in self.items.iter().enumerate() {
                if i > 0 { json.push(','); }
                json.push_str(&format!(r#"{{"name":"{}","kind":"{:?}","signature":"{}""#, item.name, item.kind, item.signature.replace("\"", "\\\"")));
                if let Some(doc) = &item.doc {
                    json.push_str(&format!(r#","summary":"{}""#, doc.summary.replace("\"", "\\\"")));
                }
                json.push('}');
            }
            json.push_str("]}");
            json
        }
    }
}

// =============================================================================
// CODE COVERAGE ANALYZER
// =============================================================================

pub mod coverage {
    use std::collections::HashMap;
    use std::sync::{Arc, RwLock, atomic::{AtomicU64, Ordering}};

    #[derive(Debug, Clone)]
    pub struct LineCoverage { pub line: u32, pub hits: u64, pub branch_taken: Option<bool>, pub branch_missed: Option<bool> }

    #[derive(Debug, Clone)]
    pub struct FunctionCoverage { pub name: String, pub start_line: u32, pub end_line: u32, pub hits: u64, pub branches_covered: u32, pub branches_total: u32 }

    #[derive(Debug, Clone)]
    pub struct FileCoverage {
        pub path: String,
        pub lines: Vec<LineCoverage>,
        pub functions: Vec<FunctionCoverage>,
        pub lines_covered: u32,
        pub lines_total: u32,
        pub branches_covered: u32,
        pub branches_total: u32,
    }

    impl FileCoverage {
        pub fn line_coverage_pct(&self) -> f64 {
            if self.lines_total == 0 { return 100.0; }
            (self.lines_covered as f64 / self.lines_total as f64) * 100.0
        }
        pub fn branch_coverage_pct(&self) -> f64 {
            if self.branches_total == 0 { return 100.0; }
            (self.branches_covered as f64 / self.branches_total as f64) * 100.0
        }
    }

    #[derive(Debug, Clone)]
    pub struct CoverageReport {
        pub files: Vec<FileCoverage>,
        pub total_lines_covered: u32,
        pub total_lines: u32,
        pub total_branches_covered: u32,
        pub total_branches: u32,
        pub total_functions_covered: u32,
        pub total_functions: u32,
    }

    impl CoverageReport {
        pub fn line_coverage_pct(&self) -> f64 {
            if self.total_lines == 0 { return 100.0; }
            (self.total_lines_covered as f64 / self.total_lines as f64) * 100.0
        }
        pub fn branch_coverage_pct(&self) -> f64 {
            if self.total_branches == 0 { return 100.0; }
            (self.total_branches_covered as f64 / self.total_branches as f64) * 100.0
        }
        pub fn function_coverage_pct(&self) -> f64 {
            if self.total_functions == 0 { return 100.0; }
            (self.total_functions_covered as f64 / self.total_functions as f64) * 100.0
        }
    }

    pub struct CoverageCollector {
        files: RwLock<HashMap<String, FileCollector>>,
    }

    struct FileCollector {
        line_hits: HashMap<u32, AtomicU64>,
        function_hits: HashMap<String, AtomicU64>,
        branches: HashMap<u32, (AtomicU64, AtomicU64)>,
    }

    impl CoverageCollector {
        pub fn new() -> Self { Self { files: RwLock::new(HashMap::new()) } }

        pub fn register_file(&self, path: &str, lines: Vec<u32>, functions: Vec<(String, u32, u32)>, branches: Vec<u32>) {
            let mut files = self.files.write().unwrap();
            let mut line_hits = HashMap::new();
            for line in lines { line_hits.insert(line, AtomicU64::new(0)); }
            let mut function_hits = HashMap::new();
            for (name, _, _) in functions { function_hits.insert(name, AtomicU64::new(0)); }
            let mut branch_map = HashMap::new();
            for line in branches { branch_map.insert(line, (AtomicU64::new(0), AtomicU64::new(0))); }
            files.insert(path.to_string(), FileCollector { line_hits, function_hits, branches: branch_map });
        }

        pub fn record_line(&self, path: &str, line: u32) {
            let files = self.files.read().unwrap();
            if let Some(fc) = files.get(path) {
                if let Some(hits) = fc.line_hits.get(&line) { hits.fetch_add(1, Ordering::Relaxed); }
            }
        }

        pub fn record_function(&self, path: &str, name: &str) {
            let files = self.files.read().unwrap();
            if let Some(fc) = files.get(path) {
                if let Some(hits) = fc.function_hits.get(name) { hits.fetch_add(1, Ordering::Relaxed); }
            }
        }

        pub fn record_branch(&self, path: &str, line: u32, taken: bool) {
            let files = self.files.read().unwrap();
            if let Some(fc) = files.get(path) {
                if let Some((taken_count, missed_count)) = fc.branches.get(&line) {
                    if taken { taken_count.fetch_add(1, Ordering::Relaxed); }
                    else { missed_count.fetch_add(1, Ordering::Relaxed); }
                }
            }
        }

        pub fn generate_report(&self) -> CoverageReport {
            let files = self.files.read().unwrap();
            let mut report_files = Vec::new();
            let mut total_lines_covered = 0u32;
            let mut total_lines = 0u32;
            let mut total_branches_covered = 0u32;
            let mut total_branches = 0u32;
            let mut total_functions_covered = 0u32;
            let mut total_functions = 0u32;
            for (path, fc) in files.iter() {
                let mut lines = Vec::new();
                let mut lines_covered = 0u32;
                for (line, hits) in &fc.line_hits {
                    let hit_count = hits.load(Ordering::Relaxed);
                    lines.push(LineCoverage { line: *line, hits: hit_count, branch_taken: None, branch_missed: None });
                    if hit_count > 0 { lines_covered += 1; }
                }
                let mut functions = Vec::new();
                for (name, hits) in &fc.function_hits {
                    let hit_count = hits.load(Ordering::Relaxed);
                    functions.push(FunctionCoverage { name: name.clone(), start_line: 0, end_line: 0, hits: hit_count, branches_covered: 0, branches_total: 0 });
                    if hit_count > 0 { total_functions_covered += 1; }
                    total_functions += 1;
                }
                let mut branches_covered = 0u32;
                for (line, (taken, missed)) in &fc.branches {
                    let taken_count = taken.load(Ordering::Relaxed);
                    let missed_count = missed.load(Ordering::Relaxed);
                    if taken_count > 0 { branches_covered += 1; }
                    if missed_count > 0 { branches_covered += 1; }
                }
                let file_cov = FileCoverage {
                    path: path.clone(),
                    lines,
                    functions,
                    lines_covered,
                    lines_total: fc.line_hits.len() as u32,
                    branches_covered,
                    branches_total: (fc.branches.len() * 2) as u32,
                };
                total_lines_covered += lines_covered;
                total_lines += fc.line_hits.len() as u32;
                total_branches_covered += branches_covered;
                total_branches += (fc.branches.len() * 2) as u32;
                report_files.push(file_cov);
            }
            CoverageReport {
                files: report_files,
                total_lines_covered,
                total_lines,
                total_branches_covered,
                total_branches,
                total_functions_covered,
                total_functions,
            }
        }

        pub fn to_lcov(&self) -> String {
            let report = self.generate_report();
            let mut lcov = String::new();
            for file in &report.files {
                lcov.push_str(&format!("SF:{}\n", file.path));
                for func in &file.functions {
                    lcov.push_str(&format!("FN:{},{}\n", func.start_line, func.name));
                    lcov.push_str(&format!("FNDA:{},{}\n", func.hits, func.name));
                }
                lcov.push_str(&format!("FNF:{}\n", file.functions.len()));
                lcov.push_str(&format!("FNH:{}\n", file.functions.iter().filter(|f| f.hits > 0).count()));
                for line in &file.lines {
                    lcov.push_str(&format!("DA:{},{}\n", line.line, line.hits));
                }
                lcov.push_str(&format!("LF:{}\n", file.lines_total));
                lcov.push_str(&format!("LH:{}\n", file.lines_covered));
                lcov.push_str("end_of_record\n");
            }
            lcov
        }

        pub fn to_cobertura(&self) -> String {
            let report = self.generate_report();
            let mut xml = String::from(r#"<?xml version="1.0"?><coverage version="1.0">"#);
            xml.push_str(&format!(r#"<packages><package name="all" line-rate="{:.4}" branch-rate="{:.4}">"#, report.line_coverage_pct() / 100.0, report.branch_coverage_pct() / 100.0));
            xml.push_str("<classes>");
            for file in &report.files {
                xml.push_str(&format!(r#"<class name="{}" filename="{}" line-rate="{:.4}">"#, file.path.replace("/", "."), file.path, file.line_coverage_pct() / 100.0));
                xml.push_str("<lines>");
                for line in &file.lines {
                    xml.push_str(&format!(r#"<line number="{}" hits="{}"/>"#, line.line, line.hits));
                }
                xml.push_str("</lines></class>");
            }
            xml.push_str("</classes></package></packages></coverage>");
            xml
        }
    }
}

