// ============================================================================
// REGION: Unit Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_storage_value_types() {
        let null = StorageValue::Null;
        assert_eq!(null.type_name(), "null");

        let boolean = StorageValue::Bool(true);
        assert_eq!(boolean.as_bool(), Some(true));

        let integer = StorageValue::Int(42);
        assert_eq!(integer.as_int(), Some(42));

        let float = StorageValue::Float(3.14);
        assert!((float.as_float().unwrap() - 3.14).abs() < 0.001);

        let string = StorageValue::String("hello".to_string());
        assert_eq!(string.as_string(), Some("hello"));
    }

    #[test]
    fn test_storage_value_path_access() {
        let mut inner = HashMap::new();
        inner.insert("name".to_string(), StorageValue::String("test".to_string()));
        inner.insert("value".to_string(), StorageValue::Int(100));

        let mut outer = HashMap::new();
        outer.insert("player".to_string(), StorageValue::Map(inner));

        let value = StorageValue::Map(outer);

        assert_eq!(
            value.get_path("player.name").and_then(|v| v.as_string()),
            Some("test")
        );
        assert_eq!(
            value.get_path("player.value").and_then(|v| v.as_int()),
            Some(100)
        );
    }

    #[test]
    fn test_save_header() {
        let header = SaveHeader::new("test_mod", Version::new(1, 0, 0));

        assert_eq!(header.magic, SAVE_MAGIC);
        assert_eq!(header.version, 1);
        assert!(header.validate().is_ok());
    }

    #[test]
    fn test_save_slot() {
        let slot = SaveSlot::new(0, "/saves");

        assert_eq!(slot.slot_id, 0);
        assert!(slot.is_empty());
        assert_eq!(slot.path, "/saves/save_0.sav");
    }

    #[test]
    fn test_serialization_format() {
        assert_eq!(SerializationFormat::Json.extension(), ".json");
        assert_eq!(SerializationFormat::Binary.extension(), ".bin");

        assert_eq!(
            SerializationFormat::from_extension(".json"),
            Some(SerializationFormat::Json)
        );
    }

    #[test]
    fn test_key_value_store() {
        let mut store = KeyValueStore {
            path: "/test/store.json".to_string(),
            data: HashMap::new(),
            dirty: false,
            auto_save: false,
        };

        store.set_string("name", "test");
        store.set_int("count", 42);
        store.set_bool("enabled", true);

        assert_eq!(store.get_string("name"), Some("test"));
        assert_eq!(store.get_int("count"), Some(42));
        assert_eq!(store.get_bool("enabled"), Some(true));
        assert!(store.dirty);
    }

    #[test]
    fn test_migration_manager() {
        let mut manager = MigrationManager::new(3);

        manager.register(1, 2, |data| {
            // Migration logic
            Ok(data)
        });

        manager.register(2, 3, |data| {
            // Migration logic
            Ok(data)
        });

        assert!(manager.needs_migration(1));
        assert!(manager.needs_migration(2));
        assert!(!manager.needs_migration(3));
    }

    #[test]
    fn test_checksum() {
        let data1 = vec![1, 2, 3, 4, 5];
        let data2 = vec![1, 2, 3, 4, 5];
        let data3 = vec![1, 2, 3, 4, 6];

        assert_eq!(compute_checksum(&data1), compute_checksum(&data2));
        assert_ne!(compute_checksum(&data1), compute_checksum(&data3));
    }
}
