// ============================================================================
// REGION: Unit Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_load_state_transitions() {
        assert!(LoadState::Unknown.can_transition_to(LoadState::Discovered));
        assert!(LoadState::Discovered.can_transition_to(LoadState::Validated));
        assert!(LoadState::Active.can_transition_to(LoadState::Suspended));
        assert!(!LoadState::Unknown.can_transition_to(LoadState::Active));
        assert!(!LoadState::Failed.can_transition_to(LoadState::Active));
    }

    #[test]
    fn test_load_options_presets() {
        let default_opts = LoadOptions::default();
        assert_eq!(default_opts.max_concurrent, 4);
        assert!(default_opts.verify_checksums);

        let fast_opts = LoadOptions::fast();
        assert_eq!(fast_opts.max_concurrent, 8);
        assert!(!fast_opts.verify_checksums);

        let dev_opts = LoadOptions::development();
        assert!(dev_opts.hot_reload);
        assert!(dev_opts.debug_logging);
    }

    #[test]
    fn test_load_queue() {
        let mut queue = LoadQueue::new(2);

        queue.enqueue("mod_a".to_string(), "/path/a".to_string(), 10);
        queue.enqueue("mod_b".to_string(), "/path/b".to_string(), 20);
        queue.enqueue("mod_c".to_string(), "/path/c".to_string(), 5);

        // Higher priority should come first
        assert_eq!(queue.pending[0].mod_id, "mod_b");
        assert_eq!(queue.pending[1].mod_id, "mod_a");
        assert_eq!(queue.pending[2].mod_id, "mod_c");
    }

    #[test]
    fn test_load_progress() {
        let mut progress = LoadProgress::new();
        progress.step = 5;
        progress.total_steps = 10;

        assert!((progress.phase_progress() - 0.5).abs() < 0.001);

        progress.bytes_loaded = 1000;
        progress.bytes_total = 2000;
        assert!((progress.bytes_progress() - 0.5).abs() < 0.001);
    }

    #[test]
    fn test_load_task_phases() {
        let mut task = LoadTask::new(1, "test_mod".to_string(), 30000);

        assert_eq!(task.phase, LoadPhase::Discovery);
        assert!(task.progress() < 0.1);

        task.advance_phase();
        assert_eq!(task.phase, LoadPhase::Validation);

        task.advance_phase();
        task.advance_phase();
        task.advance_phase();
        assert_eq!(task.phase, LoadPhase::Compilation);
    }

    #[test]
    fn test_mod_instance() {
        let metadata = ModMetadata {
            id: "test_mod".to_string(),
            name: "Test Mod".to_string(),
            version: Version::new(1, 0, 0),
            dependencies: Vec::new(),
            ..Default::default()
        };

        let mut instance = ModInstance::new(1, metadata);

        assert_eq!(instance.mod_id(), "test_mod");
        assert_eq!(instance.state, LoadState::Unknown);

        instance.transition_to(LoadState::Discovered).ok();
        assert_eq!(instance.state, LoadState::Discovered);
    }

    #[test]
    fn test_load_result() {
        let mut result = LoadResult::new();

        result.add_success("mod_a".to_string());
        result.add_success("mod_b".to_string());
        result.add_failure("mod_c".to_string(), LoadError::NotFound {
            path: "/bad/path".to_string()
        });

        assert!(!result.is_success());
        assert_eq!(result.success_count(), 2);
        assert_eq!(result.failure_count(), 1);
    }

    #[test]
    fn test_file_watcher() {
        let mut watcher = FileWatcher::new(100);

        watcher.watch("test_mod", "/mods/test/mod.toml");
        assert!(watcher.watched_paths.contains_key("/mods/test/mod.toml"));

        watcher.unwatch("/mods/test/mod.toml");
        assert!(!watcher.watched_paths.contains_key("/mods/test/mod.toml"));
    }

    #[test]
    fn test_load_error_messages() {
        let error = LoadError::MissingDependency {
            mod_id: "mod_a".to_string(),
            dependency: "mod_b".to_string(),
        };

        assert!(error.to_string().contains("mod_a"));
        assert!(error.to_string().contains("mod_b"));
    }
}
