// ============================================================================
// NEXUS - Event System
// ============================================================================
// Comprehensive event bus for mod communication and game event interception
// Supports typed events, filtering, priority dispatch, and async handlers
// ============================================================================

module nexus::events;

use core::sync::{Mutex, RwLock, Arc, mpsc};
use core::collections::{HashMap, Vec, BTreeMap, VecDeque};
use core::any::Any;

// ============================================================================
// Event Types
// ============================================================================

/// Event priority for handler ordering
@derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum EventPriority {
    Highest = 0,
    High = 1,
    Normal = 2,
    Low = 3,
    Lowest = 4,
    Monitor = 5
}

impl EventPriority {
    pub fn value(&self) -> i32 {
        *self as i32
    }
}

/// Event propagation control
@derive(Clone, Copy, PartialEq, Eq)]
pub enum EventPropagation {
    Continue,      // Continue to next handler
    Stop,          // Stop propagation
    Consume        // Consume event (stop + mark handled)
}

/// Event phase in the lifecycle
@derive(Clone, Copy, PartialEq, Eq)]
pub enum EventPhase {
    Capture,       // Propagating down
    Target,        // At target
    Bubble         // Propagating up
}

/// Base event trait
pub trait EventTrait: Any + Send + Sync {
    fn event_type(&self) -> &str;
    fn is_cancellable(&self) -> bool { true }
    fn timestamp(&self) -> u64;
    fn source(&self) -> Option<&str> { None }
}

/// Generic event wrapper
pub struct Event {
    event_type: String,
    data: Box<dyn Any + Send + Sync>,
    timestamp: u64,
    source: Option<String>,
    cancelled: bool,
    consumed: bool,
    propagation: EventPropagation,
    phase: EventPhase,
    metadata: HashMap<String, String>
}

impl Event {
    pub fn new(event_type: &str) -> Self {
        Self {
            event_type: event_type.to_string(),
            data: Box::new(()),
            timestamp: 0,
            source: None,
            cancelled: false,
            consumed: false,
            propagation: EventPropagation::Continue,
            phase: EventPhase::Target,
            metadata: HashMap::new()
        }
    }

    pub fn with_data<T: Any + Send + Sync + 'static>(mut self, data: T) -> Self {
        self.data = Box::new(data);
        self
    }

    pub fn with_source(mut self, source: &str) -> Self {
        self.source = Some(source.to_string());
        self
    }

    pub fn with_timestamp(mut self, ts: u64) -> Self {
        self.timestamp = ts;
        self
    }

    pub fn with_metadata(mut self, key: &str, value: &str) -> Self {
        self.metadata.insert(key.to_string(), value.to_string());
        self
    }

    pub fn event_type(&self) -> &str { &self.event_type }
    pub fn timestamp(&self) -> u64 { self.timestamp }
    pub fn source(&self) -> Option<&str> { self.source.as_deref() }
    pub fn phase(&self) -> EventPhase { self.phase }

    pub fn data<T: 'static>(&self) -> Option<&T> {
        self.data.downcast_ref()
    }

    pub fn data_mut<T: 'static>(&mut self) -> Option<&mut T> {
        self.data.downcast_mut()
    }

    pub fn metadata(&self, key: &str) -> Option<&str> {
        self.metadata.get(key).map(|s| s.as_str())
    }

    pub fn cancel(&mut self) {
        self.cancelled = true;
    }

    pub fn is_cancelled(&self) -> bool { self.cancelled }

    pub fn consume(&mut self) {
        self.consumed = true;
        self.propagation = EventPropagation::Consume;
    }

    pub fn is_consumed(&self) -> bool { self.consumed }

    pub fn stop_propagation(&mut self) {
        self.propagation = EventPropagation::Stop;
    }

    pub fn should_propagate(&self) -> bool {
        self.propagation == EventPropagation::Continue
    }

    pub fn set_phase(&mut self, phase: EventPhase) {
        self.phase = phase;
    }
}

