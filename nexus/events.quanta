        pub horizontal: bool,
        pub timestamp: u64
    }

    pub struct GamepadButtonEvent {
        pub gamepad_id: u32,
        pub button: u32,
        pub pressed: bool,
        pub timestamp: u64
    }

    pub struct GamepadAxisEvent {
        pub gamepad_id: u32,
        pub axis: u32,
        pub value: f32,
        pub timestamp: u64
    }
}

