    /// Get current frame number
    fn frame_count(&self) -> u64 { 0 }

    /// Get player position
    fn player_position(&self) -> (f32, f32, f32) { (0.0, 0.0, 0.0) }

    /// Get camera position
    fn camera_position(&self) -> (f32, f32, f32) { (0.0, 0.0, 0.0) }

    /// Get camera rotation
    fn camera_rotation(&self) -> (f32, f32, f32) { (0.0, 0.0, 0.0) }

    /// Get current level/map name
    fn current_level(&self) -> Option<String> { None }

    /// Get current game state
    fn game_state(&self) -> GameState { GameState::MainMenu }

    /// Get game version
