// ============================================================================
// REGION: Mod Trait
// ============================================================================

/// Main trait that all mods must implement
trait Mod {
    /// Called when the mod is first loaded
    fn on_load(&mut self, ctx: &mut ModContext) -> Result<(), ModError>;

    /// Called when the mod is being unloaded
    fn on_unload(&mut self, ctx: &mut ModContext);

    /// Called once per frame (if registered)
    fn on_update(&mut self, ctx: &mut ModContext, delta_time: f32) {}

    /// Called when mod configuration changes
    fn on_config_changed(&mut self, ctx: &mut ModContext) {}

    /// Called when another mod sends a message
    fn on_message(&mut self, ctx: &mut ModContext, from: &str, message: &Message) {}

    /// Get mod metadata
    fn metadata(&self) -> &ModMetadata;

    /// Get mod configuration schema
    fn config_schema(&self) -> Option<ConfigSchema> { None }

    /// Get mod commands (for console)
    fn commands(&self) -> Vec<ModCommand> { Vec::new() }
}

// ============================================================================
// REGION: Mod Context
// ============================================================================

/// Context provided to mods during callbacks
@derive(Debug)]
struct ModContext {
    /// Mod's own ID
    mod_id: String,
    /// Mod logger
    logger: ModLogger,
    /// Event bus for sending events
    events: Arc<EventBus>,
    /// Asset manager
    assets: Arc<ModAssetManager>,
    /// Configuration access
    config: ModConfig,
    /// Key-value storage
    storage: KeyValueStore,
    /// Inter-mod messaging
    messenger: ModMessenger,
    /// API access
    api: ModAPI,
}

impl ModContext {
    fn new(
        mod_id: &str,
        logger: ModLogger,
        events: Arc<EventBus>,
        assets: Arc<ModAssetManager>,
        config: ModConfig,
        storage_path: &str,
    ) -> Self {
        ModContext {
            mod_id: mod_id.to_string(),
            logger,
            events,
            assets,
            config,
            storage: KeyValueStore::new(&format!("{}/{}.json", storage_path, mod_id)),
            messenger: ModMessenger::new(mod_id),
            api: ModAPI::new(),
        }
    }

    /// Get mod ID
    fn mod_id(&self) -> &str {
        &self.mod_id
    }

    /// Log a message
    fn log(&self, level: LogLevel, message: &str) {
        self.logger.log(level, "mod", message);
    }

    /// Log debug message
    fn debug(&self, message: &str) {
        self.logger.debug(message);
    }

    /// Log info message
    fn info(&self, message: &str) {
        self.logger.info(message);
    }

    /// Log warning message
    fn warn(&self, message: &str) {
        self.logger.warn(message);
    }

    /// Log error message
    fn error(&self, message: &str) {
        self.logger.error(message);
    }

    /// Emit an event
    fn emit<E: Event>(&self, event: E) {
        self.events.emit(event);
    }

    /// Subscribe to an event
    fn subscribe<E: Event, F: Fn(&E) + 'static>(&mut self, handler: F) {
        self.events.subscribe(handler);
    }

    /// Get a config value
    fn get_config<T: FromConfigValue>(&self, key: &str) -> Option<T> {
        self.config.get(key).and_then(|v| T::from_config_value(v))
    }

    /// Set a config value
    fn set_config<T: ToConfigValue>(&mut self, key: &str, value: T) {
        self.config.set(key, value.to_config_value());
    }

    /// Save persistent data
    fn save<T: ToStorageValue>(&mut self, key: &str, value: T) {
        self.storage.set(key, value.to_storage_value());
    }

    /// Load persistent data
    fn load<T: FromStorageValue>(&self, key: &str) -> Option<T> {
        self.storage.get(key).and_then(|v| T::from_storage_value(v))
    }

    /// Send message to another mod
    fn send_message(&self, to: &str, message: Message) {
        self.messenger.send(to, message);
    }

    /// Get game API
    fn game(&self) -> &GameAPI {
        self.api.game()
    }

    /// Get graphics API
    fn graphics(&self) -> &GraphicsAPI {
        self.api.graphics()
    }

    /// Get input API
    fn input(&self) -> &InputAPI {
        self.api.input()
    }

    /// Get audio API
    fn audio(&self) -> &AudioAPI {
        self.api.audio()
    }
}

// ============================================================================
// REGION: Mod Error
// ============================================================================

/// Errors that can occur in mod operations
@derive(Debug, Clone)]
enum ModError {
    /// Initialization failed
    InitFailed { reason: String },
    /// Resource not found
    ResourceNotFound { resource: String },
    /// Permission denied
    PermissionDenied { operation: String },
    /// Invalid operation
    InvalidOperation { reason: String },
    /// Dependency error
    DependencyError { dependency: String, reason: String },
    /// Configuration error
    ConfigError { key: String, reason: String },
    /// Runtime error
    RuntimeError { reason: String },
    /// API error
    APIError { api: String, reason: String },
    /// Generic error
    Other { message: String },
}

impl ModError {
    fn to_string(&self) -> String {
        match self {
            ModError::InitFailed { reason } =>
                format!("Initialization failed: {}", reason),
            ModError::ResourceNotFound { resource } =>
                format!("Resource not found: {}", resource),
            ModError::PermissionDenied { operation } =>
                format!("Permission denied: {}", operation),
            ModError::InvalidOperation { reason } =>
                format!("Invalid operation: {}", reason),
            ModError::DependencyError { dependency, reason } =>
                format!("Dependency '{}' error: {}", dependency, reason),
            ModError::ConfigError { key, reason } =>
                format!("Config '{}' error: {}", key, reason),
            ModError::RuntimeError { reason } =>
                format!("Runtime error: {}", reason),
            ModError::APIError { api, reason } =>
                format!("API '{}' error: {}", api, reason),
            ModError::Other { message } =>
                message.clone(),
        }
    }
}

// ============================================================================
// REGION: Mod Message
// ============================================================================

/// Inter-mod message
@derive(Debug, Clone)]
struct Message {
    /// Message type/name
    msg_type: String,
    /// Message payload
    payload: MessagePayload,
    /// Reply expected
    expects_reply: bool,
}

@derive(Debug, Clone)]
enum MessagePayload {
    None,
    Bool(bool),
    Int(i64),
    Float(f64),
    String(String),
    Bytes(Vec<u8>),
    Json(String),
    Custom(Box<dyn Any>),
}

impl Message {
    fn new(msg_type: &str) -> Self {
        Message {
            msg_type: msg_type.to_string(),
            payload: MessagePayload::None,
            expects_reply: false,
        }
    }

    fn with_payload(mut self, payload: MessagePayload) -> Self {
        self.payload = payload;
        self
    }

    fn with_string(mut self, value: &str) -> Self {
        self.payload = MessagePayload::String(value.to_string());
        self
    }

    fn with_json<T: Serialize>(mut self, value: &T) -> Self {
        self.payload = MessagePayload::Json(serialize_json(value));
        self
    }

    fn expecting_reply(mut self) -> Self {
        self.expects_reply = true;
        self
    }

    fn get_string(&self) -> Option<&str> {
        match &self.payload {
            MessagePayload::String(s) => Some(s),
            _ => None,
        }
    }

    fn get_json<T: Deserialize>(&self) -> Option<T> {
        match &self.payload {
            MessagePayload::Json(s) => deserialize_json(s).ok(),
            _ => None,
        }
    }
}

/// Messenger for inter-mod communication
@derive(Debug)]
struct ModMessenger {
    mod_id: String,
    outbox: Vec<(String, Message)>,
    inbox: Vec<(String, Message)>,
}

impl ModMessenger {
    fn new(mod_id: &str) -> Self {
        ModMessenger {
            mod_id: mod_id.to_string(),
            outbox: Vec::new(),
            inbox: Vec::new(),
        }
    }

    fn send(&mut self, to: &str, message: Message) {
        self.outbox.push((to.to_string(), message));
    }

    fn broadcast(&mut self, message: Message) {
        self.outbox.push(("*".to_string(), message));
    }

    fn receive(&mut self) -> Option<(String, Message)> {
        self.inbox.pop()
    }

    fn has_messages(&self) -> bool {
        !self.inbox.is_empty()
    }
}

// ============================================================================
// REGION: Mod Command
// ============================================================================

/// Console command provided by a mod
@derive(Debug)]
struct ModCommand {
    /// Command name
    name: String,
    /// Description
    description: String,
    /// Usage string
    usage: String,
    /// Required arguments
    required_args: u32,
    /// Optional arguments
    optional_args: u32,
    /// Handler function
    handler: Box<dyn Fn(&ModContext, &[&str]) -> CommandResult>,
}

@derive(Debug)]
enum CommandResult {
    Success(String),
    Error(String),
    None,
}

impl ModCommand {
    fn new(name: &str, handler: impl Fn(&ModContext, &[&str]) -> CommandResult + 'static) -> Self {
        ModCommand {
            name: name.to_string(),
            description: String::new(),
            usage: name.to_string(),
            required_args: 0,
            optional_args: 0,
            handler: Box::new(handler),
        }
    }

    fn with_description(mut self, description: &str) -> Self {
        self.description = description.to_string();
        self
    }

    fn with_usage(mut self, usage: &str) -> Self {
        self.usage = usage.to_string();
        self
    }

    fn with_args(mut self, required: u32, optional: u32) -> Self {
        self.required_args = required;
        self.optional_args = optional;
        self
    }

    fn execute(&self, ctx: &ModContext, args: &[&str]) -> CommandResult {
        if args.len() < self.required_args as usize {
            return CommandResult::Error(format!(
                "Usage: {}",
                self.usage
            ));
        }
        (self.handler)(ctx, args)
    }
}

