// ============================================================================
// REGION: Conversion Traits
// ============================================================================

/// Convert from ConfigValue
trait FromConfigValue: Sized {
    fn from_config_value(value: &ConfigValue) -> Option<Self>;
}

/// Convert to ConfigValue
trait ToConfigValue {
    fn to_config_value(&self) -> ConfigValue;
}

/// Convert from StorageValue
trait FromStorageValue: Sized {
    fn from_storage_value(value: &StorageValue) -> Option<Self>;
}

/// Convert to StorageValue
trait ToStorageValue {
    fn to_storage_value(&self) -> StorageValue;
}

// Implement for basic types
impl FromConfigValue for bool {
    fn from_config_value(value: &ConfigValue) -> Option<Self> {
        match value {
            ConfigValue::Bool(v) => Some(*v),
            _ => None,
        }
    }
}

impl ToConfigValue for bool {
    fn to_config_value(&self) -> ConfigValue {
        ConfigValue::Bool(*self)
    }
}

impl FromConfigValue for i64 {
    fn from_config_value(value: &ConfigValue) -> Option<Self> {
        match value {
            ConfigValue::Int(v) => Some(*v),
            _ => None,
        }
    }
}

impl ToConfigValue for i64 {
    fn to_config_value(&self) -> ConfigValue {
        ConfigValue::Int(*self)
    }
}

impl FromConfigValue for f64 {
    fn from_config_value(value: &ConfigValue) -> Option<Self> {
        match value {
            ConfigValue::Float(v) => Some(*v),
            _ => None,
        }
    }
}

impl ToConfigValue for f64 {
    fn to_config_value(&self) -> ConfigValue {
        ConfigValue::Float(*self)
    }
}

impl FromConfigValue for String {
    fn from_config_value(value: &ConfigValue) -> Option<Self> {
        match value {
            ConfigValue::String(v) => Some(v.clone()),
            _ => None,
        }
    }
}

impl ToConfigValue for String {
    fn to_config_value(&self) -> ConfigValue {
        ConfigValue::String(self.clone())
    }
}

// ============================================================================
// REGION: Macros for Mod Development
// ============================================================================

/// Macro for declaring a mod
macro_rules! declare_mod {
    ($name:ident, $metadata:expr) => {
        #[no_mangle]
        pub fn create_mod() -> Box<dyn Mod> {
            Box::new($name::new())
        }

        #[no_mangle]
        pub fn get_metadata() -> ModMetadata {
            $metadata
        }
    };
}

/// Macro for logging
macro_rules! log {
    ($ctx:expr, $level:ident, $($arg:tt)*) => {
        $ctx.log(LogLevel::$level, &format!($($arg)*))
    };
}

/// Macro for debug logging
macro_rules! debug {
    ($ctx:expr, $($arg:tt)*) => {
        $ctx.debug(&format!($($arg)*))
    };
}

/// Macro for info logging
macro_rules! info {
    ($ctx:expr, $($arg:tt)*) => {
        $ctx.info(&format!($($arg)*))
    };
}

/// Macro for warning logging
macro_rules! warn {
    ($ctx:expr, $($arg:tt)*) => {
        $ctx.warn(&format!($($arg)*))
    };
}

/// Macro for error logging
macro_rules! error {
    ($ctx:expr, $($arg:tt)*) => {
        $ctx.error(&format!($($arg)*))
    };
}

// ============================================================================
// REGION: Example Mod Implementation
// ============================================================================

/// Example mod demonstrating the API
mod example {
    use super::*;

    struct ExampleMod {
        metadata: ModMetadata,
        counter: u32,
    }

    impl ExampleMod {
        fn new() -> Self {
            ExampleMod {
                metadata: ModMetadata {
                    id: "example_mod".to_string(),
                    name: "Example Mod".to_string(),
                    version: Version::new(1, 0, 0),
                    author: "Nexus".to_string(),
                    description: "An example mod".to_string(),
                    ..Default::default()
                },
                counter: 0,
            }
        }
    }

    impl Mod for ExampleMod {
        fn on_load(&mut self, ctx: &mut ModContext) -> Result<(), ModError> {
            ctx.info("Example mod loaded!");

            // Subscribe to events
            ctx.subscribe(|event: &GameStartEvent| {
                // Handle game start
            });

            // Load saved state
            if let Some(count) = ctx.load::<u32>("counter") {
                self.counter = count;
            }

            Ok(())
        }

        fn on_unload(&mut self, ctx: &mut ModContext) {
            ctx.info("Example mod unloading...");
            ctx.save("counter", self.counter);
        }

        fn on_update(&mut self, ctx: &mut ModContext, delta_time: f32) {
            self.counter += 1;

            if self.counter % 1000 == 0 {
                ctx.debug(&format!("Frame {}", self.counter));
            }
        }

        fn metadata(&self) -> &ModMetadata {
            &self.metadata
        }

        fn commands(&self) -> Vec<ModCommand> {
            vec![
                ModCommand::new("example_hello", |ctx, args| {
                    let name = args.get(0).unwrap_or(&"World");
                    CommandResult::Success(format!("Hello, {}!", name))
                })
                .with_description("Say hello")
                .with_usage("example_hello [name]")
                .with_args(0, 1),
            ]
        }
    }

    // Placeholder event type
    struct GameStartEvent;
    impl Event for GameStartEvent {}
}

