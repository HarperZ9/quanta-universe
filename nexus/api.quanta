/// Central API access point
@derive(Debug)]
struct ModAPI {
    game: GameAPI,
    graphics: GraphicsAPI,
    input: InputAPI,
    audio: AudioAPI,
    ui: UIAPI,
    network: NetworkAPI,
}

impl ModAPI {
    fn new() -> Self {
        ModAPI {
            game: GameAPI::new(),
            graphics: GraphicsAPI::new(),
            input: InputAPI::new(),
            audio: AudioAPI::new(),
            ui: UIAPI::new(),
            network: NetworkAPI::new(),
        }
    }

    fn game(&self) -> &GameAPI { &self.game }
    fn graphics(&self) -> &GraphicsAPI { &self.graphics }
    fn input(&self) -> &InputAPI { &self.input }
    fn audio(&self) -> &AudioAPI { &self.audio }
    fn ui(&self) -> &UIAPI { &self.ui }
    fn network(&self) -> &NetworkAPI { &self.network }
}

/// Game API for accessing game state
@derive(Debug)]
struct GameAPI {
    // Internal state
}

impl GameAPI {
    fn new() -> Self { GameAPI {} }

    /// Check if game is running
