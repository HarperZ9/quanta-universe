}

// ============================================================================
// REGION: Unit Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_message() {
        let msg = Message::new("test")
            .with_string("Hello");

        assert_eq!(msg.msg_type, "test");
        assert_eq!(msg.get_string(), Some("Hello"));
    }

    #[test]
    fn test_mod_command() {
        let cmd = ModCommand::new("test", |_, _| CommandResult::Success("OK".to_string()))
            .with_description("Test command")
            .with_args(1, 2);

        assert_eq!(cmd.name, "test");
        assert_eq!(cmd.required_args, 1);
        assert_eq!(cmd.optional_args, 2);
    }

    #[test]
    fn test_mod_error() {
        let error = ModError::InitFailed { reason: "test".to_string() };
        assert!(error.to_string().contains("Initialization failed"));

        let error = ModError::ResourceNotFound { resource: "texture.png".to_string() };
        assert!(error.to_string().contains("texture.png"));
    }

    #[test]
    fn test_shader_value() {
        let _float = ShaderValue::Float(1.0);
        let _vec3 = ShaderValue::Vec3(1.0, 2.0, 3.0);
        let _bool = ShaderValue::Bool(true);
    }

    #[test]
    fn test_config_value_conversion() {
        let value = true.to_config_value();
        assert_eq!(bool::from_config_value(&value), Some(true));

        let value = 42i64.to_config_value();
        assert_eq!(i64::from_config_value(&value), Some(42));

        let value = "hello".to_string().to_config_value();
        assert_eq!(String::from_config_value(&value), Some("hello".to_string()));
    }

    #[test]
    fn test_game_state() {
        assert_ne!(GameState::MainMenu, GameState::Playing);
        assert_eq!(GameState::Paused, GameState::Paused);
    }

    #[test]
    fn test_messenger() {
        let mut messenger = ModMessenger::new("test_mod");

        messenger.send("other_mod", Message::new("ping"));
        assert_eq!(messenger.outbox.len(), 1);

        messenger.broadcast(Message::new("announcement"));
        assert_eq!(messenger.outbox.len(), 2);
    }
}
