// ============================================================================
// REGION: Unit Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_network_error_retryable() {
        assert!(NetworkError::Timeout { operation: "test".to_string(), timeout_ms: 1000 }.is_retryable());
        assert!(NetworkError::ServerError { status: 503, message: "Unavailable".to_string() }.is_retryable());
        assert!(!NetworkError::NotFound { resource: "test".to_string() }.is_retryable());
        assert!(!NetworkError::AuthFailed { reason: "test".to_string() }.is_retryable());
    }

    #[test]
    fn test_http_request_builder() {
        let request = HttpRequest::get("https://example.com/api")
            .with_header("Accept", "application/json")
            .with_timeout(5000);

        assert_eq!(request.method, HttpMethod::GET);
        assert!(request.headers.contains_key("Accept"));
        assert_eq!(request.timeout_ms, 5000);
    }

    #[test]
    fn test_retry_config() {
        let config = RetryConfig::default();

        assert_eq!(config.delay_for_attempt(0), 1000);
        assert_eq!(config.delay_for_attempt(1), 2000);
        assert_eq!(config.delay_for_attempt(2), 4000);

        // Should cap at max delay
        assert!(config.delay_for_attempt(10) <= config.max_delay_ms);
    }

    #[test]
    fn test_search_params() {
        let params = SearchParams::new()
            .with_query("shader")
            .with_tag("graphics")
            .with_sort(SortField::Downloads, SortOrder::Descending);

        let query = params.to_query_string();
        assert!(query.contains("q=shader"));
        assert!(query.contains("tag=graphics"));
        assert!(query.contains("sort=downloads"));
    }

    #[test]
    fn test_repository_cache() {
        let mut cache = RepositoryCache::new(60000, 10);

        cache.set("key1".to_string(), vec![1, 2, 3], Some("etag1".to_string()));

        let entry = cache.get("key1");
        assert!(entry.is_some());
        assert_eq!(entry.unwrap().data, vec![1, 2, 3]);

        cache.invalidate("key1");
        assert!(cache.get("key1").is_none());
    }

    #[test]
    fn test_download_handle_progress() {
        let handle = DownloadHandle {
            url: "https://example.com/mod.zip".to_string(),
            checksum: "abc123".to_string(),
            size_bytes: 1000,
            downloaded_bytes: 500,
            state: DownloadState::Downloading,
            data: Vec::new(),
        };

        assert!((handle.progress() - 0.5).abs() < 0.001);
    }

    #[test]
    fn test_websocket_state() {
        let ws = WebSocketClient::new("wss://example.com/sync");
        assert_eq!(ws.state, WebSocketState::Closed);
        assert!(!ws.is_connected());
    }

    #[test]
    fn test_sync_mod_info() {
        let info = SyncModInfo {
            mod_id: "test_mod".to_string(),
            version: Version::new(1, 0, 0),
            checksum: "abc123".to_string(),
            required: true,
        };

        assert!(info.required);
        assert_eq!(info.mod_id, "test_mod");
    }
}
