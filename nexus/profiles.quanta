// ============================================================================
// REGION: Unit Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_profile_creation() {
        let profile = Profile::new("test", "Test Profile");

        assert_eq!(profile.id, "test");
        assert_eq!(profile.name, "Test Profile");
        assert!(profile.mods.is_empty());
        assert!(profile.is_editable());
    }

    #[test]
    fn test_profile_mod_management() {
        let mut profile = Profile::new("test", "Test");

        let entry = ProfileModEntry::new("mod_a")
            .with_priority(10);
        profile.add_mod(entry);

        assert_eq!(profile.mod_count(), 1);
        assert!(profile.is_mod_enabled("mod_a"));

        profile.disable_mod("mod_a");
        assert!(!profile.is_mod_enabled("mod_a"));

        profile.toggle_mod("mod_a");
        assert!(profile.is_mod_enabled("mod_a"));
    }

    #[test]
    fn test_profile_validation() {
        let mut profile = Profile::new("", "");
        assert!(profile.validate().is_err());

        profile.name = "Valid Name".to_string();
        assert!(profile.validate().is_ok());

        profile.name = "Invalid/Name".to_string();
        assert!(profile.validate().is_err());
    }

    #[test]
    fn test_profile_diff() {
        let mut profile_a = Profile::new("a", "Profile A");
        profile_a.add_mod(ProfileModEntry::new("mod1"));
        profile_a.add_mod(ProfileModEntry::new("mod2"));

        let mut profile_b = Profile::new("b", "Profile B");
        profile_b.add_mod(ProfileModEntry::new("mod2"));
        profile_b.add_mod(ProfileModEntry::new("mod3"));

        let diff = profile_a.diff(&profile_b);

        assert!(diff.added_mods.contains(&"mod1".to_string()));
        assert!(diff.removed_mods.contains(&"mod3".to_string()));
    }

    #[test]
    fn test_profile_clone() {
        let mut original = Profile::new("original", "Original");
        original.add_mod(ProfileModEntry::new("mod1"));
        original.description = "Original description".to_string();

        let cloned = original.clone_as("clone", "Cloned");

        assert_eq!(cloned.id, "clone");
        assert_eq!(cloned.name, "Cloned");
        assert_eq!(cloned.parent, Some("original".to_string()));
        assert_eq!(cloned.mod_count(), 1);
    }

    #[test]
    fn test_profile_manager() {
        let mut manager = ProfileManager::new("/profiles");

        // Default profile exists
        assert!(manager.get("default").is_some());

        // Create new profile
        manager.create("test", "Test").ok();
        assert!(manager.get("test").is_some());

        // Activate
        manager.activate("test").ok();
        assert_eq!(manager.active_id(), Some("test"));

        // Delete
        manager.delete("test").ok();
        assert!(manager.get("test").is_none());
    }

    #[test]
    fn test_profile_template() {
        let template = ProfileTemplate::new()
            .enable_category("graphics")
            .disable_category("audio")
            .include_mod("essential_mod")
            .with_setting("quality", ConfigValue::String("high".to_string()));

        assert!(template.enabled_categories.contains(&"graphics".to_string()));
        assert!(template.disabled_categories.contains(&"audio".to_string()));
        assert!(template.included_mods.contains(&"essential_mod".to_string()));
    }

    #[test]
    fn test_profile_history() {
        let mut history = ProfileHistory::new(100);

        history.record(ProfileHistoryEntry {
            timestamp: 1000,
            profile_id: "test".to_string(),
            change_type: ProfileChangeType::ModAdded,
            description: "Added mod_a".to_string(),
            undo_data: Some("{}".to_string()),
        });

        assert_eq!(history.entries.len(), 1);
        assert!(history.can_undo());
        assert!(!history.can_redo());

        history.undo();
        assert!(history.can_redo());
    }
}
