// SCRIPTING BRIDGE
// ═══════════════════════════════════════════════════════════════════════════════

/// Script execution context
pub struct ScriptContext {
    pub mod_id: String,
    pub game_info: GameInfo,
    variables: HashMap<String, ScriptValue>,
    functions: HashMap<String, Box<dyn Fn(&[ScriptValue]) -> ScriptValue + Send + Sync>>,
}

/// Script value types
#[derive(Debug, Clone)]
pub enum ScriptValue {
    Null,
    Bool(bool),
    Int(i64),
    Float(f64),
    String(String),
    Array(Vec<ScriptValue>),
    Object(HashMap<String, ScriptValue>),
    Pointer(usize),
}

impl ScriptContext {
    pub fn new(mod_id: &str, game_info: GameInfo) -> Self {
        let mut ctx = ScriptContext {
            mod_id: mod_id.to_string(),
            game_info,
            variables: HashMap::new(),
            functions: HashMap::new(),
        };
        ctx.register_builtins();
        ctx
    }

    fn register_builtins(&mut self) {
        // Register built-in functions
        self.functions.insert("print".to_string(), Box::new(|args| {
            for arg in args {
                // Would actually log to console
            }
            ScriptValue::Null
        }));

        self.functions.insert("read_memory".to_string(), Box::new(|args| {
            if let Some(ScriptValue::Pointer(addr)) = args.get(0) {
                // Would read memory at address
                ScriptValue::Int(0)
            } else {
                ScriptValue::Null
            }
        }));

        self.functions.insert("write_memory".to_string(), Box::new(|args| {
            // Would write to memory
            ScriptValue::Bool(true)
        }));
    }

    /// Set a variable
    pub fn set_var(&mut self, name: &str, value: ScriptValue) {
        self.variables.insert(name.to_string(), value);
    }

    /// Get a variable
    pub fn get_var(&self, name: &str) -> Option<&ScriptValue> {
        self.variables.get(name)
    }

    /// Call a function
    pub fn call(&self, name: &str, args: &[ScriptValue]) -> Option<ScriptValue> {
        self.functions.get(name).map(|f| f(args))
    }

    /// Register a custom function
    pub fn register_function<F>(&mut self, name: &str, func: F)
    where
        F: Fn(&[ScriptValue]) -> ScriptValue + Send + Sync + 'static,
    {
        self.functions.insert(name.to_string(), Box::new(func));
    }
}

/// Scripting bridge for mods
pub struct ScriptBridge {
    contexts: HashMap<String, ScriptContext>,
}

impl ScriptBridge {
    pub fn new() -> Self {
        ScriptBridge {
            contexts: HashMap::new(),
        }
    }

    /// Create context for a mod
    pub fn create_context(&mut self, mod_id: &str, game_info: GameInfo) -> &mut ScriptContext {
        self.contexts.entry(mod_id.to_string())
            .or_insert_with(|| ScriptContext::new(mod_id, game_info))
    }

    /// Get context for a mod
    pub fn get_context(&self, mod_id: &str) -> Option<&ScriptContext> {
        self.contexts.get(mod_id)
    }

    /// Remove context for a mod
    pub fn remove_context(&mut self, mod_id: &str) {
        self.contexts.remove(mod_id);
    }
}

