pub struct PluginManager {
    plugins: HashMap<GameEngine, Box<dyn EnginePlugin>>,
    active_plugin: Option<GameEngine>,
}

impl PluginManager {
    pub fn new() -> Self {
        let mut manager = PluginManager { plugins: HashMap::new(), active_plugin: None };
        manager.register_default_plugins();
        manager
    }

    fn register_default_plugins(&mut self) {
        self.plugins.insert(GameEngine::Unity, Box::new(UnityPlugin::new()));
        self.plugins.insert(GameEngine::UnrealEngine4, Box::new(UnrealPlugin::new()));
    }

    pub fn initialize_for_game(&mut self, game_info: &GameInfo, engine: GameEngine) -> Result<(), PluginError> {
        if let Some(plugin) = self.plugins.get_mut(&engine) {
            plugin.initialize(game_info)?;
            self.active_plugin = Some(engine);
            Ok(())
        } else {
            Err(PluginError::NotSupported)
        }
    }

    pub fn get_active(&mut self) -> Option<&mut Box<dyn EnginePlugin>> {
        let engine = self.active_plugin?;
        self.plugins.get_mut(&engine)
    }

    pub fn shutdown(&mut self) {
        if let Some(engine) = self.active_plugin {
            if let Some(plugin) = self.plugins.get_mut(&engine) {
                plugin.shutdown();
            }
        }
        self.active_plugin = None;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ANALYTICS & TELEMETRY
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct AnalyticsEvent {
    pub event_type: EventType,
    pub mod_id: Option<String>,
    pub game_id: Option<String>,
    pub timestamp: u64,
    pub properties: HashMap<String, String>,
}

#[derive(Debug, Clone, Copy)]
pub enum EventType {
    ModInstalled,
    ModUninstalled,
    ModEnabled,
    ModDisabled,
    ModCrash,
    GameLaunched,
    GameClosed,
    ProfileActivated,
    UpdateApplied,
    ErrorOccurred,
}

pub struct Analytics {
    enabled: bool,
    events: Vec<AnalyticsEvent>,
    session_id: String,
    endpoint: Option<String>,
    batch_size: usize,
}

impl Analytics {
    pub fn new(enabled: bool) -> Self {
        Analytics {
            enabled,
            events: Vec::new(),
            session_id: format!("session_{}", 0),
            endpoint: None,
            batch_size: 50,
        }
    }

    pub fn track(&mut self, event_type: EventType, mod_id: Option<&str>, properties: HashMap<String, String>) {
        if !self.enabled { return; }

        self.events.push(AnalyticsEvent {
            event_type,
            mod_id: mod_id.map(|s| s.to_string()),
            game_id: None,
            timestamp: 0,
            properties,
        });

        if self.events.len() >= self.batch_size {
            self.flush();
        }
    }

    pub fn flush(&mut self) {
        if self.events.is_empty() || self.endpoint.is_none() { return; }
        // Would send to analytics endpoint
        self.events.clear();
    }

    pub fn get_mod_stats(&self, mod_id: &str) -> ModAnalytics {
        let mut stats = ModAnalytics::default();

        for event in &self.events {
            if event.mod_id.as_deref() != Some(mod_id) { continue; }
            match event.event_type {
                EventType::ModEnabled => stats.enable_count += 1,
                EventType::ModDisabled => stats.disable_count += 1,
                EventType::ModCrash => stats.crash_count += 1,
                _ => {}
            }
        }

        stats
    }

    pub fn set_enabled(&mut self, enabled: bool) {
        self.enabled = enabled;
        if !enabled { self.events.clear(); }
    }
}

#[derive(Debug, Default)]
pub struct ModAnalytics {
    pub enable_count: u64,
    pub disable_count: u64,
    pub crash_count: u64,
    pub avg_session_minutes: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPATIBILITY LAYER
// ═══════════════════════════════════════════════════════════════════════════════

pub struct CompatibilityLayer {
    mappings: HashMap<String, CompatibilityMapping>,
    shims: Vec<CompatibilityShim>,
}

#[derive(Debug, Clone)]
pub struct CompatibilityMapping {
    pub source_game: String,
    pub target_game: String,
    pub asset_mappings: HashMap<String, String>,
    pub function_mappings: HashMap<String, String>,
    pub version_range: (Version, Version),
}

#[derive(Debug, Clone)]
pub struct CompatibilityShim {
    pub name: String,
    pub description: String,
    pub applies_to: Vec<String>,
    pub transforms: Vec<ShimTransform>,
}

#[derive(Debug, Clone)]
pub enum ShimTransform {
    RenameFile { from: String, to: String },
    RemapAsset { from: String, to: String },
    PatchFunction { original: String, replacement: String },
    InjectCode { location: String, code: Vec<u8> },
}

impl CompatibilityLayer {
    pub fn new() -> Self {
        CompatibilityLayer { mappings: HashMap::new(), shims: Vec::new() }
    }

    pub fn add_mapping(&mut self, mapping: CompatibilityMapping) {
        let key = format!("{}:{}", mapping.source_game, mapping.target_game);
        self.mappings.insert(key, mapping);
    }

    pub fn can_translate(&self, source: &str, target: &str) -> bool {
        self.mappings.contains_key(&format!("{}:{}", source, target))
    }

    pub fn translate_asset(&self, source_game: &str, target_game: &str, asset_id: &str) -> Option<String> {
        let key = format!("{}:{}", source_game, target_game);
        self.mappings.get(&key)?.asset_mappings.get(asset_id).cloned()
    }

    pub fn apply_shims(&self, mod_id: &str, pkg: &mut ModPackage) {
        for shim in &self.shims {
            if !shim.applies_to.contains(&mod_id.to_string()) { continue; }

            for transform in &shim.transforms {
                match transform {
                    ShimTransform::RenameFile { from, to } => {
                        for file in &mut pkg.files {
                            if file.path == *from {
                                file.path = to.clone();
                            }
                        }
                    }
                    _ => {}
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD DEBUGGING TOOLS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ModDebugger {
    breakpoints: Vec<Breakpoint>,
    watches: Vec<WatchExpression>,
    call_stack: Vec<StackFrame>,
    variables: HashMap<String, DebugValue>,
    state: DebugState,
    log_buffer: Vec<DebugLog>,
}

#[derive(Debug, Clone)]
pub struct Breakpoint {
    pub id: u64,
    pub mod_id: String,
    pub location: BreakpointLocation,
    pub condition: Option<String>,
    pub hit_count: u32,
    pub enabled: bool,
}

#[derive(Debug, Clone)]
pub enum BreakpointLocation {
    Address(u64),
    Function(String),
    SourceLine { file: String, line: u32 },
}

#[derive(Debug, Clone)]
pub struct WatchExpression {
    pub id: u64,
    pub expression: String,
    pub current_value: Option<DebugValue>,
    pub break_on_change: bool,
}

#[derive(Debug, Clone)]
pub struct StackFrame {
    pub function_name: String,
    pub address: u64,
    pub source_file: Option<String>,
    pub line: Option<u32>,
    pub locals: HashMap<String, DebugValue>,
}

#[derive(Debug, Clone)]
pub enum DebugValue {
    Int(i64),
    Float(f64),
    String(String),
    Bool(bool),
    Pointer(u64),
    Array(Vec<DebugValue>),
    Struct { name: String, fields: HashMap<String, DebugValue> },
    Unknown,
}

#[derive(Debug, Clone, PartialEq)]
pub enum DebugState {
    Running,
    Paused,
    Stepping,
    Stopped,
}

#[derive(Debug, Clone)]
pub struct DebugLog {
    pub timestamp: u64,
    pub level: LogLevel,
    pub mod_id: String,
    pub message: String,
}

#[derive(Debug, Clone)]
pub enum LogLevel { Trace, Debug, Info, Warn, Error }

impl ModDebugger {
    pub fn new() -> Self {
        ModDebugger {
            breakpoints: Vec::new(), watches: Vec::new(), call_stack: Vec::new(),
            variables: HashMap::new(), state: DebugState::Stopped, log_buffer: Vec::new(),
        }
    }

    pub fn add_breakpoint(&mut self, mod_id: &str, location: BreakpointLocation) -> u64 {
        let id = self.breakpoints.len() as u64;
        self.breakpoints.push(Breakpoint {
            id, mod_id: mod_id.to_string(), location, condition: None, hit_count: 0, enabled: true,
        });
        id
    }

    pub fn remove_breakpoint(&mut self, id: u64) { self.breakpoints.retain(|bp| bp.id != id); }
    pub fn toggle_breakpoint(&mut self, id: u64) {
        if let Some(bp) = self.breakpoints.iter_mut().find(|bp| bp.id == id) { bp.enabled = !bp.enabled; }
    }

    pub fn add_watch(&mut self, expression: &str) -> u64 {
        let id = self.watches.len() as u64;
        self.watches.push(WatchExpression { id, expression: expression.to_string(), current_value: None, break_on_change: false });
        id
    }

    pub fn step_over(&mut self) { self.state = DebugState::Stepping; }
    pub fn step_into(&mut self) { self.state = DebugState::Stepping; }
    pub fn step_out(&mut self) { self.state = DebugState::Stepping; }
    pub fn continue_execution(&mut self) { self.state = DebugState::Running; }
    pub fn pause(&mut self) { self.state = DebugState::Paused; }

    pub fn read_memory(&self, address: u64, size: usize) -> Vec<u8> { vec![0u8; size] }
    pub fn write_memory(&mut self, _address: u64, _data: &[u8]) {}
    pub fn get_call_stack(&self) -> &[StackFrame] { &self.call_stack }
    pub fn get_variables(&self) -> &HashMap<String, DebugValue> { &self.variables }
    pub fn log(&mut self, level: LogLevel, mod_id: &str, message: &str) {
        self.log_buffer.push(DebugLog { timestamp: 0, level, mod_id: mod_id.to_string(), message: message.to_string() });
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NETWORK SYNC FOR MULTIPLAYER MODS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ModNetworkSync {
    peers: HashMap<u64, Peer>,
    sync_objects: HashMap<u64, SyncObject>,
    pending_updates: Vec<SyncUpdate>,
    local_peer_id: u64,
    authority_mode: AuthorityMode,
}

#[derive(Debug, Clone)]
pub struct Peer {
    pub id: u64,
    pub name: String,
    pub address: String,
    pub latency_ms: u32,
    pub connected: bool,
    pub mod_versions: HashMap<String, Version>,
}

#[derive(Debug, Clone)]
pub struct SyncObject {
    pub id: u64,
    pub mod_id: String,
    pub owner_peer: u64,
    pub state: Vec<u8>,
    pub last_update: u64,
    pub sync_rate: SyncRate,
}

#[derive(Debug, Clone, Copy)]
pub enum SyncRate { Immediate, HighFrequency, LowFrequency, OnChange }

#[derive(Debug, Clone)]
pub struct SyncUpdate {
    pub object_id: u64,
    pub from_peer: u64,
    pub timestamp: u64,
    pub delta: Vec<u8>,
    pub reliable: bool,
}

#[derive(Debug, Clone, Copy)]
pub enum AuthorityMode { ServerAuthoritative, PeerToPeer, OwnerAuthoritative }

impl ModNetworkSync {
    pub fn new(local_id: u64) -> Self {
        ModNetworkSync {
            peers: HashMap::new(), sync_objects: HashMap::new(), pending_updates: Vec::new(),
            local_peer_id: local_id, authority_mode: AuthorityMode::ServerAuthoritative,
        }
    }

    pub fn connect_peer(&mut self, peer: Peer) { self.peers.insert(peer.id, peer); }
    pub fn disconnect_peer(&mut self, peer_id: u64) { self.peers.remove(&peer_id); }

    pub fn register_sync_object(&mut self, mod_id: &str, rate: SyncRate) -> u64 {
        let id = self.sync_objects.len() as u64;
        self.sync_objects.insert(id, SyncObject {
            id, mod_id: mod_id.to_string(), owner_peer: self.local_peer_id,
            state: Vec::new(), last_update: 0, sync_rate: rate,
        });
        id
    }

    pub fn update_object(&mut self, object_id: u64, state: Vec<u8>) {
        if let Some(obj) = self.sync_objects.get_mut(&object_id) {
            let delta = self.compute_delta(&obj.state, &state);
            obj.state = state;
            obj.last_update += 1;
            self.pending_updates.push(SyncUpdate {
                object_id, from_peer: self.local_peer_id, timestamp: obj.last_update,
                delta, reliable: matches!(obj.sync_rate, SyncRate::OnChange),
            });
        }
    }

    fn compute_delta(&self, _old: &[u8], new: &[u8]) -> Vec<u8> { new.to_vec() }

    pub fn apply_remote_update(&mut self, update: SyncUpdate) {
        if let Some(obj) = self.sync_objects.get_mut(&update.object_id) {
            if update.timestamp > obj.last_update {
                obj.state = update.delta.clone();
                obj.last_update = update.timestamp;
            }
        }
    }

    pub fn check_mod_compatibility(&self, peer_id: u64, mod_id: &str, version: &Version) -> bool {
        self.peers.get(&peer_id).map_or(false, |p| p.mod_versions.get(mod_id).map_or(false, |v| v.is_compatible(version)))
    }

    pub fn flush_updates(&mut self) -> Vec<SyncUpdate> { std::mem::take(&mut self.pending_updates) }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD PACKAGING & DEPLOYMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ModPackager {
    compression: CompressionType,
    include_debug: bool,
    signing_key: Option<Vec<u8>>,
}

#[derive(Debug, Clone, Copy)]
pub enum CompressionType { None, Zstd, Lz4, Deflate }

#[derive(Debug, Clone)]
pub struct PackagedMod {
    pub header: PackageHeader,
    pub manifest: Vec<u8>,
    pub files: Vec<PackagedFile>,
    pub signature: Option<Vec<u8>>,
}

#[derive(Debug, Clone)]
pub struct PackageHeader {
    pub magic: [u8; 4],
    pub version: u32,
    pub compression: CompressionType,
    pub manifest_offset: u64,
    pub manifest_size: u64,
    pub files_offset: u64,
    pub total_size: u64,
    pub checksum: u32,
}

#[derive(Debug, Clone)]
pub struct PackagedFile {
    pub path: String,
    pub offset: u64,
    pub compressed_size: u64,
    pub uncompressed_size: u64,
    pub checksum: u32,
}

impl ModPackager {
    pub fn new() -> Self { ModPackager { compression: CompressionType::Zstd, include_debug: false, signing_key: None } }
    pub fn with_compression(mut self, c: CompressionType) -> Self { self.compression = c; self }
    pub fn with_debug(mut self, d: bool) -> Self { self.include_debug = d; self }
    pub fn with_signing_key(mut self, k: Vec<u8>) -> Self { self.signing_key = Some(k); self }

    pub fn package(&self, pkg: &ModPackage) -> Result<PackagedMod, PackageError> {
        let manifest = self.serialize_manifest(&pkg.metadata)?;
        let mut files = Vec::new();
        let mut offset = 0u64;

        for file in &pkg.files {
            let compressed = self.compress(&file.data)?;
            files.push(PackagedFile {
                path: file.path.clone(), offset, compressed_size: compressed.len() as u64,
                uncompressed_size: file.data.len() as u64, checksum: self.crc32(&file.data),
            });
            offset += compressed.len() as u64;
        }

        let header = PackageHeader {
            magic: *b"NXPK", version: 1, compression: self.compression,
            manifest_offset: 0, manifest_size: manifest.len() as u64,
            files_offset: manifest.len() as u64, total_size: offset, checksum: 0,
        };

        let signature = self.signing_key.as_ref().map(|_| vec![0u8; 64]);
        Ok(PackagedMod { header, manifest, files, signature })
    }

    pub fn unpackage(&self, data: &[u8]) -> Result<ModPackage, PackageError> {
        if data.len() < 32 { return Err(PackageError::InvalidFormat); }
        if &data[0..4] != b"NXPK" { return Err(PackageError::InvalidMagic); }
        Ok(ModPackage::new(ModMetadata::new("unpacked", "Unpacked", Version::new(1, 0, 0))))
    }

    fn serialize_manifest(&self, _m: &ModMetadata) -> Result<Vec<u8>, PackageError> { Ok(Vec::new()) }
    fn compress(&self, data: &[u8]) -> Result<Vec<u8>, PackageError> { Ok(data.to_vec()) }
    fn crc32(&self, data: &[u8]) -> u32 { data.iter().fold(0u32, |acc, b| acc.wrapping_add(*b as u32)) }
}

#[derive(Debug)]
pub enum PackageError { InvalidFormat, InvalidMagic, CompressionError, SignatureError, IoError(String) }

pub struct ModDeployer {
    install_path: String,
    backup_path: String,
    verify_signatures: bool,
}

impl ModDeployer {
    pub fn new(install: &str, backup: &str) -> Self {
        ModDeployer { install_path: install.to_string(), backup_path: backup.to_string(), verify_signatures: true }
    }

    pub fn deploy(&self, pkg: &PackagedMod) -> Result<DeployResult, DeployError> {
        if self.verify_signatures { if let Some(_sig) = &pkg.signature { /* verify */ } }
        Ok(DeployResult { files_installed: pkg.files.len(), backup_created: true })
    }

    pub fn undeploy(&self, mod_id: &str) -> Result<(), DeployError> {
        let _ = mod_id;
        Ok(())
    }
}

#[derive(Debug)]
pub struct DeployResult { pub files_installed: usize, pub backup_created: bool }

#[derive(Debug)]
pub enum DeployError { PermissionDenied, DiskFull, SignatureInvalid, BackupFailed }

