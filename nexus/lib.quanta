// GAME DETECTION & CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct GameConfig { pub game_id: String, pub name: String, pub executable: String, pub data_folder: String, pub plugin_extension: String, pub max_plugins: u32, pub supports_light_plugins: bool, pub supports_medium_plugins: bool, pub registry_key: Option<String>, pub steam_app_id: Option<u32>, pub gog_id: Option<String> }

pub struct GameDetector { pub known_games: Vec<GameConfig>, pub search_paths: Vec<String>, pub detected: HashMap<String, DetectedGame> }
pub struct DetectedGame { pub config: GameConfig, pub install_path: String, pub data_path: String, pub version: String, pub store: GameStore }
pub enum GameStore { Steam, GOG, Epic, Bethesda, Manual }

impl GameDetector {
    pub fn new() -> Self {
        let games = vec![
            GameConfig { game_id: "skyrimse".to_string(), name: "Skyrim Special Edition".to_string(), executable: "SkyrimSE.exe".to_string(), data_folder: "Data".to_string(), plugin_extension: "esp".to_string(), max_plugins: 254, supports_light_plugins: true, supports_medium_plugins: false, registry_key: Some(r"HKLM\SOFTWARE\WOW6432Node\Bethesda Softworks\Skyrim Special Edition".to_string()), steam_app_id: Some(489830), gog_id: None },
            GameConfig { game_id: "skyrimvr".to_string(), name: "Skyrim VR".to_string(), executable: "SkyrimVR.exe".to_string(), data_folder: "Data".to_string(), plugin_extension: "esp".to_string(), max_plugins: 254, supports_light_plugins: true, supports_medium_plugins: false, registry_key: None, steam_app_id: Some(611670), gog_id: None },
            GameConfig { game_id: "fallout4".to_string(), name: "Fallout 4".to_string(), executable: "Fallout4.exe".to_string(), data_folder: "Data".to_string(), plugin_extension: "esp".to_string(), max_plugins: 254, supports_light_plugins: true, supports_medium_plugins: false, registry_key: Some(r"HKLM\SOFTWARE\WOW6432Node\Bethesda Softworks\Fallout4".to_string()), steam_app_id: Some(377160), gog_id: None },
            GameConfig { game_id: "starfield".to_string(), name: "Starfield".to_string(), executable: "Starfield.exe".to_string(), data_folder: "Data".to_string(), plugin_extension: "esm".to_string(), max_plugins: 254, supports_light_plugins: true, supports_medium_plugins: true, registry_key: None, steam_app_id: Some(1716740), gog_id: None },
        ];
        Self { known_games: games, search_paths: Vec::new(), detected: HashMap::new() }
    }

    pub fn add_search_path(&mut self, path: &str) { self.search_paths.push(path.to_string()); }

    pub fn detect(&mut self, game_id: &str, path: &str, store: GameStore) -> bool {
        if let Some(config) = self.known_games.iter().find(|g| g.game_id == game_id).cloned() {
            let data_path = format!("{}/{}", path, config.data_folder);
            self.detected.insert(game_id.to_string(), DetectedGame { config, install_path: path.to_string(), data_path, version: "1.0.0".to_string(), store });
            true
        } else { false }
    }

    pub fn get_game(&self, game_id: &str) -> Option<&DetectedGame> { self.detected.get(game_id) }

    pub fn list_detected(&self) -> Vec<&DetectedGame> { self.detected.values().collect() }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED CONFLICT DETECTION - FILE & RECORD-LEVEL ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod conflict_detection {
    use super::*;
    use std::collections::{HashMap, HashSet, BTreeMap};

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum ConflictSeverity { Info, Warning, Error, Critical }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum ConflictType { FileOverwrite, RecordOverride, AssetDuplicate, PluginOrder, MasterMissing, VersionMismatch, FormIdCollision, ScriptConflict, INIOverride, ResourcePackConflict }

    #[derive(Debug, Clone)]
    pub struct ConflictRecord {
        pub conflict_type: ConflictType,
        pub severity: ConflictSeverity,
        pub source_mod: String,
        pub target_mod: String,
        pub file_path: String,
        pub details: String,
        pub suggested_resolution: Option<String>,
        pub auto_resolvable: bool,
    }

    #[derive(Debug, Clone)]
    pub struct FileSignature {
        pub path: String,
        pub hash: u64,
        pub size: u64,
        pub mod_id: String,
        pub record_ids: Vec<String>,
    }

    pub struct ConflictDetector {
        file_registry: HashMap<String, Vec<FileSignature>>,
        record_registry: HashMap<String, Vec<(String, String)>>,
        conflicts: Vec<ConflictRecord>,
        ignored_paths: HashSet<String>,
        priority_overrides: HashMap<(String, String), String>,
    }

    impl ConflictDetector {
        pub fn new() -> Self { Self { file_registry: HashMap::new(), record_registry: HashMap::new(), conflicts: Vec::new(), ignored_paths: HashSet::new(), priority_overrides: HashMap::new() } }

        pub fn register_file(&mut self, sig: FileSignature) { self.file_registry.entry(sig.path.clone()).or_default().push(sig); }

        pub fn register_record(&mut self, record_id: &str, mod_id: &str, file_path: &str) { self.record_registry.entry(record_id.to_string()).or_default().push((mod_id.to_string(), file_path.to_string())); }

        pub fn ignore_path(&mut self, path: &str) { self.ignored_paths.insert(path.to_lowercase()); }

        pub fn set_priority(&mut self, path: &str, winner: &str) { self.priority_overrides.insert((path.to_string(), String::new()), winner.to_string()); }

        pub fn detect_all(&mut self) {
            self.conflicts.clear();
            for (path, files) in &self.file_registry {
                if self.ignored_paths.contains(&path.to_lowercase()) { continue; }
                if files.len() > 1 {
                    for i in 0..files.len() {
                        for j in (i+1)..files.len() {
                            let severity = if files[i].hash == files[j].hash { ConflictSeverity::Info } else { ConflictSeverity::Warning };
                            self.conflicts.push(ConflictRecord {
                                conflict_type: ConflictType::FileOverwrite,
                                severity,
                                source_mod: files[i].mod_id.clone(),
                                target_mod: files[j].mod_id.clone(),
                                file_path: path.clone(),
                                details: format!("Both mods provide {}", path),
                                suggested_resolution: Some("Check load order or create a patch".to_string()),
                                auto_resolvable: files[i].hash == files[j].hash,
                            });
                        }
                    }
                }
            }
            for (record_id, sources) in &self.record_registry {
                if sources.len() > 1 {
                    for i in 0..sources.len() {
                        for j in (i+1)..sources.len() {
                            self.conflicts.push(ConflictRecord {
                                conflict_type: ConflictType::RecordOverride,
                                severity: ConflictSeverity::Warning,
                                source_mod: sources[i].0.clone(),
                                target_mod: sources[j].0.clone(),
                                file_path: sources[i].1.clone(),
                                details: format!("Record {} is modified by multiple mods", record_id),
                                suggested_resolution: Some("Create a merged patch".to_string()),
                                auto_resolvable: false,
                            });
                        }
                    }
                }
            }
        }

        pub fn get_conflicts(&self) -> &[ConflictRecord] { &self.conflicts }
        pub fn get_conflicts_for_mod(&self, mod_id: &str) -> Vec<&ConflictRecord> { self.conflicts.iter().filter(|c| c.source_mod == mod_id || c.target_mod == mod_id).collect() }
        pub fn get_critical_conflicts(&self) -> Vec<&ConflictRecord> { self.conflicts.iter().filter(|c| c.severity == ConflictSeverity::Critical || c.severity == ConflictSeverity::Error).collect() }
        pub fn has_blocking_conflicts(&self) -> bool { self.conflicts.iter().any(|c| c.severity == ConflictSeverity::Critical) }
    }

    #[derive(Debug, Clone)]
    pub struct FormIdRange {
        pub mod_id: String,
        pub start: u32,
        pub end: u32,
        pub light_master: bool,
    }

    pub struct FormIdAllocator {
        ranges: BTreeMap<u32, FormIdRange>,
        light_master_ranges: BTreeMap<u16, String>,
        next_regular: u8,
        next_light: u16,
    }

    impl FormIdAllocator {
        pub fn new() -> Self { Self { ranges: BTreeMap::new(), light_master_ranges: BTreeMap::new(), next_regular: 0, next_light: 0 } }

        pub fn allocate_regular(&mut self, mod_id: &str) -> Option<FormIdRange> {
            if self.next_regular >= 254 { return None; }
            let idx = self.next_regular;
            self.next_regular += 1;
            let start = (idx as u32) << 24;
            let end = start | 0x00FFFFFF;
            let range = FormIdRange { mod_id: mod_id.to_string(), start, end, light_master: false };
            self.ranges.insert(start, range.clone());
            Some(range)
        }

        pub fn allocate_light(&mut self, mod_id: &str) -> Option<FormIdRange> {
            if self.next_light >= 4096 { return None; }
            let idx = self.next_light;
            self.next_light += 1;
            let start = 0xFE000000 | ((idx as u32) << 12);
            let end = start | 0x00000FFF;
            let range = FormIdRange { mod_id: mod_id.to_string(), start, end, light_master: true };
            self.ranges.insert(start, range.clone());
            self.light_master_ranges.insert(idx, mod_id.to_string());
            Some(range)
        }

        pub fn find_owner(&self, form_id: u32) -> Option<&str> {
            if (form_id >> 24) == 0xFE {
                let light_idx = ((form_id >> 12) & 0xFFF) as u16;
                self.light_master_ranges.get(&light_idx).map(|s| s.as_str())
            } else {
                for (start, range) in self.ranges.range(..=form_id).rev() {
                    if form_id >= *start && form_id <= range.end { return Some(&range.mod_id); }
                }
                None
            }
        }

        pub fn check_collision(&self, form_id: u32) -> Option<Vec<&str>> {
            let owners: Vec<_> = self.ranges.values().filter(|r| form_id >= r.start && form_id <= r.end).map(|r| r.mod_id.as_str()).collect();
            if owners.len() > 1 { Some(owners) } else { None }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD VIRTUALIZATION - VIRTUAL FILE SYSTEM FOR MODS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod virtualization {
    use super::*;
    use std::collections::{HashMap, BTreeMap};

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum VFSNodeType { File, Directory, Link, Overlay }

    #[derive(Debug, Clone)]
    pub struct VFSNode {
        pub name: String,
        pub node_type: VFSNodeType,
        pub real_path: Option<String>,
        pub mod_id: Option<String>,
        pub priority: i32,
        pub children: HashMap<String, VFSNode>,
        pub metadata: VFSMetadata,
    }

    #[derive(Debug, Clone, Default)]
    pub struct VFSMetadata {
        pub size: u64,
        pub created: u64,
        pub modified: u64,
        pub readonly: bool,
        pub hidden: bool,
    }

    impl VFSNode {
        pub fn directory(name: &str) -> Self { Self { name: name.to_string(), node_type: VFSNodeType::Directory, real_path: None, mod_id: None, priority: 0, children: HashMap::new(), metadata: VFSMetadata::default() } }

        pub fn file(name: &str, real_path: &str, mod_id: &str, priority: i32) -> Self {
            Self { name: name.to_string(), node_type: VFSNodeType::File, real_path: Some(real_path.to_string()), mod_id: Some(mod_id.to_string()), priority, children: HashMap::new(), metadata: VFSMetadata::default() }
        }

        pub fn add_child(&mut self, node: VFSNode) { self.children.insert(node.name.clone(), node); }

        pub fn get_child(&self, name: &str) -> Option<&VFSNode> { self.children.get(name) }

        pub fn get_child_mut(&mut self, name: &str) -> Option<&mut VFSNode> { self.children.get_mut(name) }
    }

    pub struct VirtualFileSystem {
        root: VFSNode,
        mod_paths: HashMap<String, String>,
        overlays: Vec<(String, i32)>,
        redirects: HashMap<String, String>,
        mount_points: HashMap<String, String>,
    }

    impl VirtualFileSystem {
        pub fn new() -> Self { Self { root: VFSNode::directory(""), mod_paths: HashMap::new(), overlays: Vec::new(), redirects: HashMap::new(), mount_points: HashMap::new() } }

        pub fn register_mod(&mut self, mod_id: &str, path: &str, priority: i32) {
            self.mod_paths.insert(mod_id.to_string(), path.to_string());
            self.overlays.push((mod_id.to_string(), priority));
            self.overlays.sort_by(|a, b| a.1.cmp(&b.1));
        }

        pub fn mount(&mut self, virtual_path: &str, real_path: &str) { self.mount_points.insert(virtual_path.to_string(), real_path.to_string()); }

        pub fn add_redirect(&mut self, from: &str, to: &str) { self.redirects.insert(from.to_lowercase(), to.to_string()); }

        pub fn add_file(&mut self, virtual_path: &str, real_path: &str, mod_id: &str, priority: i32) {
            let parts: Vec<_> = virtual_path.split('/').filter(|s| !s.is_empty()).collect();
            if parts.is_empty() { return; }
            let mut current = &mut self.root;
            for (i, part) in parts.iter().enumerate() {
                if i == parts.len() - 1 {
                    let existing = current.children.get(*part);
                    if existing.is_none() || existing.map(|n| n.priority).unwrap_or(-1) < priority {
                        current.add_child(VFSNode::file(part, real_path, mod_id, priority));
                    }
                } else {
                    if !current.children.contains_key(*part) { current.add_child(VFSNode::directory(part)); }
                    current = current.children.get_mut(*part).unwrap();
                }
            }
        }

        pub fn resolve(&self, virtual_path: &str) -> Option<String> {
            let path = virtual_path.to_lowercase();
            if let Some(redirect) = self.redirects.get(&path) { return Some(redirect.clone()); }
            for (mount, real) in &self.mount_points { if path.starts_with(&mount.to_lowercase()) { return Some(path.replacen(mount, real, 1)); } }
            let parts: Vec<_> = path.split('/').filter(|s| !s.is_empty()).collect();
            let mut current = &self.root;
            for part in &parts {
                match current.get_child(part) {
                    Some(node) => current = node,
                    None => return None,
                }
            }
            current.real_path.clone()
        }

        pub fn list_directory(&self, virtual_path: &str) -> Vec<String> {
            let parts: Vec<_> = virtual_path.split('/').filter(|s| !s.is_empty()).collect();
            let mut current = &self.root;
            for part in &parts { match current.get_child(part) { Some(node) => current = node, None => return Vec::new() } }
            current.children.keys().cloned().collect()
        }

        pub fn get_providing_mod(&self, virtual_path: &str) -> Option<String> {
            let parts: Vec<_> = virtual_path.to_lowercase().split('/').filter(|s| !s.is_empty()).collect();
            let mut current = &self.root;
            for part in &parts { match current.get_child(part) { Some(node) => current = node, None => return None } }
            current.mod_id.clone()
        }

        pub fn rebuild(&mut self) {
            self.root = VFSNode::directory("");
            let overlays = self.overlays.clone();
            for (mod_id, priority) in overlays {
                if let Some(path) = self.mod_paths.get(&mod_id).cloned() {
                    self.scan_mod_directory(&mod_id, &path, priority);
                }
            }
        }

        fn scan_mod_directory(&mut self, mod_id: &str, base_path: &str, priority: i32) {
            fn scan_recursive(vfs: &mut VirtualFileSystem, mod_id: &str, current_path: &str, virtual_prefix: &str, priority: i32) {
                let entries = ["meshes", "textures", "sound", "scripts", "interface"];
                for entry in entries { vfs.add_file(&format!("{}/{}/placeholder.txt", virtual_prefix, entry), &format!("{}/{}/placeholder.txt", current_path, entry), mod_id, priority); }
            }
            scan_recursive(self, mod_id, base_path, "", priority);
        }
    }

    pub struct OverwriteManager {
        overwrites: HashMap<String, String>,
        original_locations: HashMap<String, String>,
        staged_files: HashMap<String, (String, String)>,
    }

    impl OverwriteManager {
        pub fn new() -> Self { Self { overwrites: HashMap::new(), original_locations: HashMap::new(), staged_files: HashMap::new() } }

        pub fn track_overwrite(&mut self, path: &str, winning_mod: &str) { self.overwrites.insert(path.to_string(), winning_mod.to_string()); }

        pub fn record_original(&mut self, path: &str, original_path: &str) { self.original_locations.insert(path.to_string(), original_path.to_string()); }

        pub fn stage_file(&mut self, virtual_path: &str, real_path: &str, mod_id: &str) { self.staged_files.insert(virtual_path.to_string(), (real_path.to_string(), mod_id.to_string())); }

        pub fn get_winner(&self, path: &str) -> Option<&str> { self.overwrites.get(path).map(|s| s.as_str()) }

        pub fn get_original(&self, path: &str) -> Option<&str> { self.original_locations.get(path).map(|s| s.as_str()) }

        pub fn apply_staged(&mut self) -> Vec<(String, String)> { self.staged_files.drain().map(|(v, (r, _))| (v, r)).collect() }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOAD ORDER MANAGEMENT - AUTOMATIC SORTING & OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod load_order {
    use super::*;
    use std::collections::{HashMap, HashSet, VecDeque};

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum PluginFlag { Master, Light, Medium, Regular, Overlay }

    #[derive(Debug, Clone)]
    pub struct PluginEntry {
        pub filename: String,
        pub mod_id: String,
        pub flag: PluginFlag,
        pub masters: Vec<String>,
        pub is_active: bool,
        pub load_index: Option<u8>,
        pub light_index: Option<u16>,
        pub description: String,
        pub author: String,
        pub form_count: u32,
    }

    #[derive(Debug, Clone)]
    pub struct SortingRule {
        pub plugin: String,
        pub load_after: Vec<String>,
        pub load_before: Vec<String>,
        pub group: Option<String>,
        pub note: String,
    }

    pub struct LoadOrderManager {
        plugins: HashMap<String, PluginEntry>,
        order: Vec<String>,
        rules: Vec<SortingRule>,
        groups: HashMap<String, Vec<String>>,
        master_list: Vec<SortingRule>,
        user_rules: Vec<SortingRule>,
    }

    impl LoadOrderManager {
        pub fn new() -> Self { Self { plugins: HashMap::new(), order: Vec::new(), rules: Vec::new(), groups: HashMap::new(), master_list: Vec::new(), user_rules: Vec::new() } }

        pub fn add_plugin(&mut self, plugin: PluginEntry) {
            let name = plugin.filename.clone();
            self.plugins.insert(name.clone(), plugin);
            if !self.order.contains(&name) { self.order.push(name); }
        }

        pub fn add_rule(&mut self, rule: SortingRule) { self.rules.push(rule); }

        pub fn add_user_rule(&mut self, rule: SortingRule) { self.user_rules.push(rule); }

        pub fn load_master_list(&mut self, rules: Vec<SortingRule>) { self.master_list = rules; }

        pub fn sort(&mut self) -> Result<(), String> {
            let mut graph: HashMap<String, HashSet<String>> = HashMap::new();
            let mut in_degree: HashMap<String, usize> = HashMap::new();
            for name in &self.order {
                graph.entry(name.clone()).or_default();
                in_degree.entry(name.clone()).or_insert(0);
            }
            for (name, plugin) in &self.plugins {
                for master in &plugin.masters {
                    if self.order.contains(master) {
                        graph.entry(master.clone()).or_default().insert(name.clone());
                        *in_degree.entry(name.clone()).or_insert(0) += 1;
                    }
                }
            }
            for rule in self.master_list.iter().chain(self.rules.iter()).chain(self.user_rules.iter()) {
                if !self.order.contains(&rule.plugin) { continue; }
                for after in &rule.load_after {
                    if self.order.contains(after) {
                        graph.entry(after.clone()).or_default().insert(rule.plugin.clone());
                        *in_degree.entry(rule.plugin.clone()).or_insert(0) += 1;
                    }
                }
                for before in &rule.load_before {
                    if self.order.contains(before) {
                        graph.entry(rule.plugin.clone()).or_default().insert(before.clone());
                        *in_degree.entry(before.clone()).or_insert(0) += 1;
                    }
                }
            }
            let mut queue: VecDeque<String> = in_degree.iter().filter(|(_, &d)| d == 0).map(|(n, _)| n.clone()).collect();
            let mut sorted = Vec::new();
            while let Some(node) = queue.pop_front() {
                sorted.push(node.clone());
                if let Some(neighbors) = graph.get(&node) {
                    for neighbor in neighbors {
                        let degree = in_degree.get_mut(neighbor).unwrap();
                        *degree -= 1;
                        if *degree == 0 { queue.push_back(neighbor.clone()); }
                    }
                }
            }
            if sorted.len() != self.order.len() { return Err("Circular dependency detected".to_string()); }
            let mut masters: Vec<_> = sorted.iter().filter(|n| self.plugins.get(*n).map(|p| p.flag == PluginFlag::Master).unwrap_or(false)).cloned().collect();
            let non_masters: Vec<_> = sorted.into_iter().filter(|n| self.plugins.get(n).map(|p| p.flag != PluginFlag::Master).unwrap_or(true)).collect();
            masters.extend(non_masters);
            self.order = masters;
            self.assign_indices();
            Ok(())
        }

        fn assign_indices(&mut self) {
            let mut regular_idx: u8 = 0;
            let mut light_idx: u16 = 0;
            for name in &self.order {
                if let Some(plugin) = self.plugins.get_mut(name) {
                    if !plugin.is_active { continue; }
                    match plugin.flag {
                        PluginFlag::Light | PluginFlag::Overlay => {
                            plugin.light_index = Some(light_idx);
                            plugin.load_index = Some(0xFE);
                            light_idx += 1;
                        }
                        _ => {
                            plugin.load_index = Some(regular_idx);
                            if regular_idx < 254 { regular_idx += 1; }
                        }
                    }
                }
            }
        }

        pub fn get_order(&self) -> &[String] { &self.order }

        pub fn move_plugin(&mut self, plugin: &str, new_position: usize) {
            if let Some(pos) = self.order.iter().position(|p| p == plugin) {
                let p = self.order.remove(pos);
                let insert_pos = new_position.min(self.order.len());
                self.order.insert(insert_pos, p);
            }
        }

        pub fn get_active_count(&self) -> (usize, usize) {
            let regular = self.plugins.values().filter(|p| p.is_active && p.flag != PluginFlag::Light && p.flag != PluginFlag::Overlay).count();
            let light = self.plugins.values().filter(|p| p.is_active && (p.flag == PluginFlag::Light || p.flag == PluginFlag::Overlay)).count();
            (regular, light)
        }

        pub fn validate(&self) -> Vec<String> {
            let mut issues = Vec::new();
            let (regular, light) = self.get_active_count();
            if regular > 254 { issues.push(format!("Too many regular plugins: {} (max 254)", regular)); }
            if light > 4096 { issues.push(format!("Too many light plugins: {} (max 4096)", light)); }
            for (name, plugin) in &self.plugins {
                for master in &plugin.masters {
                    if !self.plugins.contains_key(master) || !self.plugins.get(master).map(|p| p.is_active).unwrap_or(false) {
                        issues.push(format!("{} requires missing/inactive master: {}", name, master));
                    }
                }
            }
            issues
        }

        pub fn export_loadorder_txt(&self) -> String { self.order.iter().filter(|n| self.plugins.get(*n).map(|p| p.is_active).unwrap_or(false)).map(|n| format!("*{}\n", n)).collect() }

        pub fn export_plugins_txt(&self) -> String { self.order.iter().map(|n| { let active = self.plugins.get(n).map(|p| p.is_active).unwrap_or(false); if active { format!("*{}\n", n) } else { format!("{}\n", n) } }).collect() }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOWNLOAD MANAGEMENT - NEXUS API & CDN INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod downloads {
    use super::*;
    use std::collections::HashMap;

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum DownloadState { Queued, Downloading, Paused, Completed, Failed, Verifying, Extracting }

    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum DownloadPriority { Low, Normal, High, Urgent }

    #[derive(Debug, Clone)]
    pub struct DownloadTask {
        pub id: String,
        pub url: String,
        pub filename: String,
        pub mod_id: String,
        pub file_id: String,
        pub game_id: String,
        pub state: DownloadState,
        pub priority: DownloadPriority,
        pub total_bytes: u64,
        pub downloaded_bytes: u64,
        pub speed_bps: u64,
        pub eta_seconds: u64,
        pub checksum: Option<String>,
        pub chunks: Vec<DownloadChunk>,
        pub retries: u32,
        pub max_retries: u32,
        pub error: Option<String>,
    }

    #[derive(Debug, Clone)]
    pub struct DownloadChunk {
        pub start: u64,
        pub end: u64,
        pub downloaded: u64,
        pub state: DownloadState,
    }

    impl DownloadTask {
        pub fn new(url: &str, filename: &str, mod_id: &str, file_id: &str, game_id: &str) -> Self {
            Self { id: format!("{}-{}", mod_id, file_id), url: url.to_string(), filename: filename.to_string(), mod_id: mod_id.to_string(), file_id: file_id.to_string(), game_id: game_id.to_string(),
                state: DownloadState::Queued, priority: DownloadPriority::Normal, total_bytes: 0, downloaded_bytes: 0, speed_bps: 0, eta_seconds: 0, checksum: None, chunks: Vec::new(), retries: 0, max_retries: 3, error: None }
        }

        pub fn progress(&self) -> f32 { if self.total_bytes == 0 { 0.0 } else { self.downloaded_bytes as f32 / self.total_bytes as f32 } }

        pub fn split_chunks(&mut self, count: usize) {
            if self.total_bytes == 0 || count == 0 { return; }
            let chunk_size = self.total_bytes / count as u64;
            self.chunks.clear();
            for i in 0..count {
                let start = i as u64 * chunk_size;
                let end = if i == count - 1 { self.total_bytes - 1 } else { start + chunk_size - 1 };
                self.chunks.push(DownloadChunk { start, end, downloaded: 0, state: DownloadState::Queued });
            }
        }

        pub fn update_chunk(&mut self, chunk_idx: usize, downloaded: u64) {
            if let Some(chunk) = self.chunks.get_mut(chunk_idx) { chunk.downloaded = downloaded; }
            self.downloaded_bytes = self.chunks.iter().map(|c| c.downloaded).sum();
        }
    }

    pub struct DownloadManager {
        tasks: HashMap<String, DownloadTask>,
        queue: Vec<String>,
        active_downloads: usize,
        max_concurrent: usize,
        bandwidth_limit: Option<u64>,
        download_path: String,
        temp_path: String,
        api_key: Option<String>,
        premium: bool,
    }

    impl DownloadManager {
        pub fn new(download_path: &str, temp_path: &str) -> Self {
            Self { tasks: HashMap::new(), queue: Vec::new(), active_downloads: 0, max_concurrent: 3, bandwidth_limit: None, download_path: download_path.to_string(), temp_path: temp_path.to_string(), api_key: None, premium: false }
        }

        pub fn set_api_key(&mut self, key: &str, premium: bool) { self.api_key = Some(key.to_string()); self.premium = premium; }

        pub fn set_concurrent(&mut self, max: usize) { self.max_concurrent = max; }

        pub fn set_bandwidth_limit(&mut self, bytes_per_sec: Option<u64>) { self.bandwidth_limit = bytes_per_sec; }

        pub fn add_download(&mut self, task: DownloadTask) {
            let id = task.id.clone();
            self.tasks.insert(id.clone(), task);
            self.queue.push(id);
            self.queue.sort_by(|a, b| {
                let pa = self.tasks.get(a).map(|t| t.priority).unwrap_or(DownloadPriority::Normal);
                let pb = self.tasks.get(b).map(|t| t.priority).unwrap_or(DownloadPriority::Normal);
                pb.cmp(&pa)
            });
        }

        pub fn start_next(&mut self) -> Option<String> {
            if self.active_downloads >= self.max_concurrent { return None; }
            let next = self.queue.iter().find(|id| self.tasks.get(*id).map(|t| t.state == DownloadState::Queued).unwrap_or(false)).cloned();
            if let Some(ref id) = next { if let Some(task) = self.tasks.get_mut(id) { task.state = DownloadState::Downloading; self.active_downloads += 1; } }
            next
        }

        pub fn pause(&mut self, id: &str) -> bool { if let Some(task) = self.tasks.get_mut(id) { if task.state == DownloadState::Downloading { task.state = DownloadState::Paused; self.active_downloads = self.active_downloads.saturating_sub(1); return true; } } return false; }

        pub fn resume(&mut self, id: &str) -> bool { if let Some(task) = self.tasks.get_mut(id) { if task.state == DownloadState::Paused { task.state = DownloadState::Queued; return true; } } return false; }

        pub fn cancel(&mut self, id: &str) -> bool { if let Some(task) = self.tasks.get_mut(id) { if task.state == DownloadState::Downloading { self.active_downloads = self.active_downloads.saturating_sub(1); } task.state = DownloadState::Failed; self.queue.retain(|q| q != id); return true; } return false; }

        pub fn complete(&mut self, id: &str) { if let Some(task) = self.tasks.get_mut(id) { task.state = DownloadState::Completed; self.active_downloads = self.active_downloads.saturating_sub(1); } }

        pub fn get_task(&self, id: &str) -> Option<&DownloadTask> { self.tasks.get(id) }

        pub fn get_active(&self) -> Vec<&DownloadTask> { self.tasks.values().filter(|t| t.state == DownloadState::Downloading).collect() }

        pub fn get_queued(&self) -> Vec<&DownloadTask> { self.tasks.values().filter(|t| t.state == DownloadState::Queued).collect() }

        pub fn total_speed(&self) -> u64 { self.tasks.values().filter(|t| t.state == DownloadState::Downloading).map(|t| t.speed_bps).sum() }
    }

    #[derive(Debug, Clone)]
    pub struct NexusFile {
        pub file_id: u64,
        pub name: String,
        pub filename: String,
        pub version: String,
        pub category: String,
        pub is_primary: bool,
        pub size_bytes: u64,
        pub uploaded_timestamp: u64,
        pub mod_version: String,
        pub changelog: String,
        pub content_preview_link: Option<String>,
    }

    pub struct NexusApiClient {
        api_key: String,
        base_url: String,
        rate_limit_remaining: u32,
        rate_limit_reset: u64,
        premium: bool,
    }

    impl NexusApiClient {
        pub fn new(api_key: &str) -> Self { Self { api_key: api_key.to_string(), base_url: "https://api.nexusmods.com/v1".to_string(), rate_limit_remaining: 100, rate_limit_reset: 0, premium: false } }

        pub fn is_premium(&self) -> bool { self.premium }

        pub fn get_mod_files(&self, game_id: &str, mod_id: u64) -> Vec<NexusFile> { Vec::new() }

        pub fn get_download_link(&self, game_id: &str, mod_id: u64, file_id: u64, key: Option<&str>, expires: Option<u64>) -> Option<String> { Some(format!("{}/games/{}/mods/{}/files/{}/download_link.json", self.base_url, game_id, mod_id, file_id)) }

        pub fn check_for_updates(&self, game_id: &str, mod_id: u64, current_version: &str) -> Option<NexusFile> { None }

        pub fn get_endorsement_status(&self, game_id: &str, mod_id: u64) -> bool { false }

        pub fn endorse_mod(&self, game_id: &str, mod_id: u64, endorse: bool) -> bool { true }

        pub fn track_mod(&self, game_id: &str, mod_id: u64, track: bool) -> bool { true }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BACKUP & RESTORE - COMPREHENSIVE DATA PROTECTION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod backup {
    use super::*;
    use std::collections::HashMap;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum BackupType { Full, Incremental, Differential, Snapshot }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum BackupScope { Profile, LoadOrder, Settings, Mods, SaveGames, Everything }

    #[derive(Debug, Clone)]
    pub struct BackupManifest {
        pub id: String,
        pub name: String,
        pub backup_type: BackupType,
        pub scope: BackupScope,
        pub created: u64,
        pub size_bytes: u64,
        pub game_id: String,
        pub profile_id: Option<String>,
        pub parent_backup: Option<String>,
        pub file_count: u32,
        pub checksum: String,
        pub compressed: bool,
        pub encrypted: bool,
    }

    #[derive(Debug, Clone)]
    pub struct BackupFile {
        pub relative_path: String,
        pub size: u64,
        pub checksum: String,
        pub modified: u64,
        pub compressed_size: Option<u64>,
    }

    pub struct BackupManager {
        backups: HashMap<String, BackupManifest>,
        backup_path: String,
        max_backups: usize,
        auto_backup_enabled: bool,
        auto_backup_interval: u64,
        last_auto_backup: u64,
        compression_level: u32,
        encryption_key: Option<String>,
    }

    impl BackupManager {
        pub fn new(backup_path: &str) -> Self {
            Self { backups: HashMap::new(), backup_path: backup_path.to_string(), max_backups: 10, auto_backup_enabled: false, auto_backup_interval: 86400, last_auto_backup: 0, compression_level: 6, encryption_key: None }
        }

        pub fn set_encryption(&mut self, key: Option<&str>) { self.encryption_key = key.map(|s| s.to_string()); }

        pub fn create_backup(&mut self, name: &str, backup_type: BackupType, scope: BackupScope, game_id: &str, profile_id: Option<&str>) -> Result<String, String> {
            let id = format!("backup_{}", std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).map(|d| d.as_secs()).unwrap_or(0));
            let manifest = BackupManifest {
                id: id.clone(), name: name.to_string(), backup_type, scope, created: 0, size_bytes: 0, game_id: game_id.to_string(),
                profile_id: profile_id.map(|s| s.to_string()), parent_backup: None, file_count: 0, checksum: String::new(), compressed: true, encrypted: self.encryption_key.is_some(),
            };
            self.backups.insert(id.clone(), manifest);
            self.cleanup_old_backups();
            Ok(id)
        }

        pub fn restore_backup(&self, backup_id: &str) -> Result<(), String> {
            if !self.backups.contains_key(backup_id) { return Err("Backup not found".to_string()); }
            Ok(())
        }

        pub fn delete_backup(&mut self, backup_id: &str) -> bool { self.backups.remove(backup_id).is_some() }

        pub fn list_backups(&self) -> Vec<&BackupManifest> { self.backups.values().collect() }

        pub fn get_backup(&self, backup_id: &str) -> Option<&BackupManifest> { self.backups.get(backup_id) }

        fn cleanup_old_backups(&mut self) {
            if self.backups.len() <= self.max_backups { return; }
            let mut by_date: Vec<_> = self.backups.iter().map(|(id, m)| (id.clone(), m.created)).collect();
            by_date.sort_by(|a, b| a.1.cmp(&b.1));
            while self.backups.len() > self.max_backups { if let Some((id, _)) = by_date.first() { self.backups.remove(id); by_date.remove(0); } else { break; } }
        }

        pub fn enable_auto_backup(&mut self, enabled: bool, interval_secs: u64) { self.auto_backup_enabled = enabled; self.auto_backup_interval = interval_secs; }

        pub fn check_auto_backup(&mut self, current_time: u64, game_id: &str) -> Option<String> {
            if !self.auto_backup_enabled { return None; }
            if current_time - self.last_auto_backup >= self.auto_backup_interval {
                self.last_auto_backup = current_time;
                self.create_backup("Auto Backup", BackupType::Incremental, BackupScope::Profile, game_id, None).ok()
            } else { None }
        }

        pub fn compare_backups(&self, backup_a: &str, backup_b: &str) -> Vec<String> { Vec::new() }

        pub fn verify_backup(&self, backup_id: &str) -> Result<bool, String> {
            if !self.backups.contains_key(backup_id) { return Err("Backup not found".to_string()); }
            Ok(true)
        }
    }

    pub struct SaveGameManager {
        saves_path: String,
        backups: HashMap<String, Vec<String>>,
        max_saves_per_character: usize,
    }

    impl SaveGameManager {
        pub fn new(saves_path: &str) -> Self { Self { saves_path: saves_path.to_string(), backups: HashMap::new(), max_saves_per_character: 5 } }

        pub fn backup_save(&mut self, save_file: &str, character_id: &str) -> Result<String, String> {
            let backup_id = format!("save_{}_{}", character_id, std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).map(|d| d.as_secs()).unwrap_or(0));
            self.backups.entry(character_id.to_string()).or_default().push(backup_id.clone());
            self.cleanup_character_saves(character_id);
            Ok(backup_id)
        }

        fn cleanup_character_saves(&mut self, character_id: &str) {
            if let Some(saves) = self.backups.get_mut(character_id) { while saves.len() > self.max_saves_per_character { saves.remove(0); } }
        }

        pub fn restore_save(&self, backup_id: &str) -> Result<(), String> { Ok(()) }

        pub fn list_character_saves(&self, character_id: &str) -> Vec<&String> { self.backups.get(character_id).map(|v| v.iter().collect()).unwrap_or_default() }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_version_comparison() {
        let v1 = Version::new(1, 0, 0);
        let v2 = Version::new(1, 1, 0);
        let v3 = Version::new(2, 0, 0);
        
        assert!(v1 < v2);
        assert!(v2 < v3);
        assert!(v1.is_compatible(&v2));
        assert!(!v1.is_compatible(&v3));
    }
    
    #[test]
    fn test_dependency_resolution() {
        let mut resolver = DependencyResolver::new();
        
        let mut mod_a = ModPackage::new(ModMetadata::new("mod_a", "Mod A", Version::new(1, 0, 0)));
        mod_a.metadata.dependencies.push(ModDependency {
            mod_id: "mod_b".to_string(),
            min_version: None,
            max_version: None,
            optional: false,
        });
        
        let mod_b = ModPackage::new(ModMetadata::new("mod_b", "Mod B", Version::new(1, 0, 0)));
        
        resolver.add_mod(mod_a);
        resolver.add_mod(mod_b);
        
        match resolver.resolve(&["mod_a".to_string()]) {
            DependencyResult::Resolved(order) => {
                assert!(order.iter().position(|m| m == "mod_b") < order.iter().position(|m| m == "mod_a"));
            }
            _ => panic!("Should resolve successfully"),
        }
    }
    
    #[test]
    fn test_profile_management() {
        let mut manager = ProfileManager::new();
        
        let profile_id = manager.create_profile("Test Profile", "game_1");
        assert!(manager.activate_profile(&profile_id));
        
        if let Some(profile) = manager.get_active_mut() {
            profile.enable_mod("mod_1");
            profile.enable_mod("mod_2");
            assert_eq!(profile.enabled_mods.len(), 2);
        }
    }
}
