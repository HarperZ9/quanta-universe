impl EnginePlugin for UnrealPlugin {
    fn engine(&self) -> GameEngine { GameEngine::UnrealEngine4 }

    fn initialize(&mut self, game_info: &GameInfo) -> Result<(), PluginError> {
        // Find GObjects, GNames, etc.
        Ok(())
    }

    fn on_frame(&mut self) {}

    fn on_load_asset(&mut self, _asset_type: AssetType, _asset_id: &str) -> Option<Vec<u8>> { None }

    fn on_script_call(&mut self, _function: &str, _args: &[ScriptValue]) -> Option<ScriptValue> { None }

    fn shutdown(&mut self) {
