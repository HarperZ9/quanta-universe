// ROLLBACK SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Snapshot of game state before mod changes
#[derive(Debug, Clone)]
pub struct StateSnapshot {
    pub id: String,
    pub timestamp: u64,
    pub description: String,
    pub file_backups: HashMap<String, Vec<u8>>,
    pub memory_patches: Vec<MemoryPatch>,
    pub registry_backups: HashMap<String, Vec<u8>>,
}

/// Rollback manager for undoing mod changes
pub struct RollbackManager {
    snapshots: Vec<StateSnapshot>,
    max_snapshots: usize,
    backup_dir: String,
}

impl RollbackManager {
    pub fn new(backup_dir: &str, max_snapshots: usize) -> Self {
        RollbackManager {
            snapshots: Vec::new(),
            max_snapshots,
            backup_dir: backup_dir.to_string(),
        }
    }

    /// Create a snapshot before making changes
    pub fn create_snapshot(&mut self, description: &str) -> String {
        let id = format!("snapshot_{}", self.snapshots.len());

        let snapshot = StateSnapshot {
            id: id.clone(),
            timestamp: 0, // Would use real timestamp
            description: description.to_string(),
            file_backups: HashMap::new(),
            memory_patches: Vec::new(),
            registry_backups: HashMap::new(),
        };

        // Remove oldest if at limit
        if self.snapshots.len() >= self.max_snapshots {
            self.snapshots.remove(0);
        }

        self.snapshots.push(snapshot);
        id
    }

    /// Backup a file before modifying
    pub fn backup_file(&mut self, snapshot_id: &str, path: &str, contents: Vec<u8>) {
        if let Some(snapshot) = self.snapshots.iter_mut().find(|s| s.id == snapshot_id) {
            snapshot.file_backups.insert(path.to_string(), contents);
        }
    }

    /// Rollback to a snapshot
    pub fn rollback(&mut self, snapshot_id: &str) -> Result<(), RollbackError> {
        let snapshot = self.snapshots.iter()
            .find(|s| s.id == snapshot_id)
            .ok_or(RollbackError::SnapshotNotFound(snapshot_id.to_string()))?
            .clone();

        // Restore files
        for (path, contents) in &snapshot.file_backups {
            // Would write file
        }

        // Revert memory patches
        for patch in &snapshot.memory_patches {
            // Would revert patch
        }

        // Remove snapshots after this one
        let idx = self.snapshots.iter().position(|s| s.id == snapshot_id).unwrap();
        self.snapshots.truncate(idx + 1);

        Ok(())
    }

    /// Get all snapshots
    pub fn list_snapshots(&self) -> &[StateSnapshot] {
        &self.snapshots
    }

    /// Delete a snapshot
    pub fn delete_snapshot(&mut self, snapshot_id: &str) {
        self.snapshots.retain(|s| s.id != snapshot_id);
    }
}

#[derive(Debug)]
pub enum RollbackError {
    SnapshotNotFound(String),
    RestoreFailed(String),
    IoError(String),
}

