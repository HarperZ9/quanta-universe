pub trait EnginePlugin: Send + Sync {
    fn engine(&self) -> GameEngine;
    fn initialize(&mut self, game_info: &GameInfo) -> Result<(), PluginError>;
    fn on_frame(&mut self);
    fn on_load_asset(&mut self, asset_type: AssetType, asset_id: &str) -> Option<Vec<u8>>;
    fn on_script_call(&mut self, function: &str, args: &[ScriptValue]) -> Option<ScriptValue>;
    fn shutdown(&mut self);
}

#[derive(Debug)]
pub enum PluginError {
    InitFailed(String),
    NotSupported,
    GameMismatch,
}

pub struct UnityPlugin {
    mono_domain: Option<usize>,
    assemblies: HashMap<String, usize>,
}

impl UnityPlugin {
    pub fn new() -> Self {
        UnityPlugin { mono_domain: None, assemblies: HashMap::new() }
    }

    fn inject_assembly(&mut self, name: &str, data: &[u8]) -> Result<usize, PluginError> {
        // Would use Mono API to inject assembly
        Ok(0)
    }

    fn call_method(&self, class: &str, method: &str, args: &[ScriptValue]) -> Option<ScriptValue> {
        // Would invoke Mono method
        None
    }
}

impl EnginePlugin for UnityPlugin {
    fn engine(&self) -> GameEngine { GameEngine::Unity }

    fn initialize(&mut self, game_info: &GameInfo) -> Result<(), PluginError> {
        // Find mono_domain_get, mono_assembly_load, etc.
        Ok(())
    }

    fn on_frame(&mut self) {}

    fn on_load_asset(&mut self, _asset_type: AssetType, _asset_id: &str) -> Option<Vec<u8>> { None }

    fn on_script_call(&mut self, function: &str, args: &[ScriptValue]) -> Option<ScriptValue> {
        self.call_method("ModBridge", function, args)
    }

    fn shutdown(&mut self) {
        self.assemblies.clear();
        self.mono_domain = None;
    }
}

