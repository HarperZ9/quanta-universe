pub struct CrashReporter {
    reports: Vec<CrashReport>,
    upload_endpoint: Option<String>,
    include_system_info: bool,
    max_reports: usize,
}

#[derive(Debug, Clone)]
pub struct CrashReport {
    pub id: String,
    pub timestamp: u64,
    pub mod_id: Option<String>,
    pub exception_type: String,
    pub message: String,
    pub stack_trace: Vec<StackTraceFrame>,
    pub system_info: Option<SystemInfo>,
    pub mod_list: Vec<ModInfo>,
    pub memory_dump: Option<Vec<u8>>,
    pub user_notes: Option<String>,
}

#[derive(Debug, Clone)]
pub struct StackTraceFrame {
    pub address: u64,
    pub module: String,
    pub function: Option<String>,
    pub file: Option<String>,
    pub line: Option<u32>,
}

#[derive(Debug, Clone)]
pub struct SystemInfo {
    pub os_name: String,
    pub os_version: String,
    pub cpu: String,
    pub ram_mb: u64,
    pub gpu: String,
    pub game_name: String,
    pub game_version: String,
}

#[derive(Debug, Clone)]
pub struct ModInfo {
    pub id: String,
    pub name: String,
    pub version: Version,
    pub enabled: bool,
}

impl CrashReporter {
    pub fn new() -> Self {
        CrashReporter { reports: Vec::new(), upload_endpoint: None, include_system_info: true, max_reports: 100 }
    }

    pub fn set_endpoint(&mut self, url: &str) { self.upload_endpoint = Some(url.to_string()); }

    pub fn capture_crash(&mut self, exception: &str, message: &str, stack: Vec<StackTraceFrame>) -> String {
        let id = format!("crash_{}", self.reports.len());
        let report = CrashReport {
            id: id.clone(), timestamp: 0, mod_id: None, exception_type: exception.to_string(),
            message: message.to_string(), stack_trace: stack, system_info: self.gather_system_info(),
            mod_list: Vec::new(), memory_dump: None, user_notes: None,
        };
        self.reports.push(report);
        if self.reports.len() > self.max_reports { self.reports.remove(0); }
        id
    }

    pub fn attribute_to_mod(&mut self, report_id: &str, mod_id: &str) {
        if let Some(r) = self.reports.iter_mut().find(|r| r.id == report_id) { r.mod_id = Some(mod_id.to_string()); }
    }

    pub fn add_user_notes(&mut self, report_id: &str, notes: &str) {
        if let Some(r) = self.reports.iter_mut().find(|r| r.id == report_id) { r.user_notes = Some(notes.to_string()); }
    }

    pub fn upload_report(&self, report_id: &str) -> Result<(), String> {
        if self.upload_endpoint.is_none() { return Err("No endpoint".to_string()); }
        let _report = self.reports.iter().find(|r| r.id == report_id).ok_or("Not found")?;
        Ok(())
    }

    fn gather_system_info(&self) -> Option<SystemInfo> {
        if !self.include_system_info { return None; }
        Some(SystemInfo {
            os_name: "Windows".to_string(), os_version: "10".to_string(), cpu: "Unknown".to_string(),
            ram_mb: 16384, gpu: "Unknown".to_string(), game_name: "Unknown".to_string(), game_version: "1.0".to_string(),
        })
    }

    pub fn get_mod_crash_frequency(&self, mod_id: &str) -> usize {
        self.reports.iter().filter(|r| r.mod_id.as_deref() == Some(mod_id)).count()
    }

    pub fn export_reports(&self) -> Vec<u8> { Vec::new() }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECURITY SANDBOX
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ModSandbox {
    policies: HashMap<String, SandboxPolicy>,
    violations: Vec<SecurityViolation>,
    enabled: bool,
}

#[derive(Debug, Clone)]
pub struct SandboxPolicy {
    pub mod_id: String,
    pub file_access: FileAccessPolicy,
    pub network_access: NetworkPolicy,
    pub memory_limits: MemoryLimits,
    pub api_whitelist: Vec<String>,
    pub api_blacklist: Vec<String>,
    pub trust_level: TrustLevel,
}

#[derive(Debug, Clone)]
pub struct FileAccessPolicy {
    pub allowed_paths: Vec<PathPattern>,
    pub denied_paths: Vec<PathPattern>,
    pub allow_write: bool,
    pub allow_execute: bool,
}

#[derive(Debug, Clone)]
pub struct PathPattern { pub pattern: String, pub recursive: bool }

#[derive(Debug, Clone)]
pub struct NetworkPolicy {
    pub allow_outbound: bool,
    pub allow_inbound: bool,
    pub allowed_hosts: Vec<String>,
    pub blocked_hosts: Vec<String>,
    pub allowed_ports: Vec<u16>,
}

#[derive(Debug, Clone)]
pub struct MemoryLimits {
    pub max_heap_mb: u64,
    pub max_stack_mb: u64,
    pub max_allocations: u64,
}

#[derive(Debug, Clone, Copy, PartialEq, Ord, PartialOrd, Eq)]
pub enum TrustLevel { Untrusted, Limited, Standard, Elevated, Full }

#[derive(Debug, Clone)]
pub struct SecurityViolation {
    pub timestamp: u64,
    pub mod_id: String,
    pub violation_type: ViolationType,
    pub details: String,
    pub action_taken: ViolationAction,
}

#[derive(Debug, Clone)]
pub enum ViolationType {
    FileAccessDenied, NetworkAccessDenied, MemoryLimitExceeded,
    ApiCallBlocked, SuspiciousBehavior, IntegrityViolation,
}

#[derive(Debug, Clone, Copy)]
pub enum ViolationAction { Logged, Warned, Blocked, ModDisabled, SessionTerminated }

impl ModSandbox {
    pub fn new() -> Self { ModSandbox { policies: HashMap::new(), violations: Vec::new(), enabled: true } }

    pub fn set_policy(&mut self, policy: SandboxPolicy) { self.policies.insert(policy.mod_id.clone(), policy); }

    pub fn check_file_access(&mut self, mod_id: &str, path: &str, write: bool) -> bool {
        let policy = match self.policies.get(mod_id) { Some(p) => p, None => return false };
        if policy.trust_level == TrustLevel::Full { return true; }

        let fp = &policy.file_access;
        if write && !fp.allow_write { self.log_violation(mod_id, ViolationType::FileAccessDenied, path); return false; }

        for denied in &fp.denied_paths {
            if self.path_matches(path, &denied.pattern, denied.recursive) {
                self.log_violation(mod_id, ViolationType::FileAccessDenied, path); return false;
            }
        }

        for allowed in &fp.allowed_paths {
            if self.path_matches(path, &allowed.pattern, allowed.recursive) { return true; }
        }

        self.log_violation(mod_id, ViolationType::FileAccessDenied, path);
        false
    }

    pub fn check_network_access(&mut self, mod_id: &str, host: &str, port: u16, outbound: bool) -> bool {
        let policy = match self.policies.get(mod_id) { Some(p) => p, None => return false };
        if policy.trust_level == TrustLevel::Full { return true; }

        let np = &policy.network_access;
        if outbound && !np.allow_outbound { self.log_violation(mod_id, ViolationType::NetworkAccessDenied, host); return false; }
        if !outbound && !np.allow_inbound { self.log_violation(mod_id, ViolationType::NetworkAccessDenied, host); return false; }

        if np.blocked_hosts.iter().any(|h| host.contains(h)) {
            self.log_violation(mod_id, ViolationType::NetworkAccessDenied, host); return false;
        }

        if !np.allowed_hosts.is_empty() && !np.allowed_hosts.iter().any(|h| host.contains(h)) {
            self.log_violation(mod_id, ViolationType::NetworkAccessDenied, host); return false;
        }

        if !np.allowed_ports.is_empty() && !np.allowed_ports.contains(&port) {
            self.log_violation(mod_id, ViolationType::NetworkAccessDenied, &format!("{}:{}", host, port)); return false;
        }

        true
    }

    pub fn check_api_call(&mut self, mod_id: &str, api: &str) -> bool {
        let policy = match self.policies.get(mod_id) { Some(p) => p, None => return false };
        if policy.trust_level == TrustLevel::Full { return true; }

        if policy.api_blacklist.iter().any(|a| api.starts_with(a)) {
            self.log_violation(mod_id, ViolationType::ApiCallBlocked, api); return false;
        }

        if !policy.api_whitelist.is_empty() && !policy.api_whitelist.iter().any(|a| api.starts_with(a)) {
            self.log_violation(mod_id, ViolationType::ApiCallBlocked, api); return false;
        }

        true
    }

    pub fn check_memory(&mut self, mod_id: &str, heap_mb: u64, allocations: u64) -> bool {
        let policy = match self.policies.get(mod_id) { Some(p) => p, None => return false };
        let ml = &policy.memory_limits;

        if heap_mb > ml.max_heap_mb || allocations > ml.max_allocations {
            self.log_violation(mod_id, ViolationType::MemoryLimitExceeded, &format!("{}MB/{} allocs", heap_mb, allocations));
            return false;
        }
        true
    }

    fn log_violation(&mut self, mod_id: &str, vtype: ViolationType, details: &str) {
        self.violations.push(SecurityViolation {
            timestamp: 0, mod_id: mod_id.to_string(), violation_type: vtype,
            details: details.to_string(), action_taken: ViolationAction::Blocked,
        });
    }

    fn path_matches(&self, path: &str, pattern: &str, recursive: bool) -> bool {
        if recursive { path.starts_with(pattern) } else { path == pattern }
    }

    pub fn get_violations(&self, mod_id: &str) -> Vec<&SecurityViolation> {
        self.violations.iter().filter(|v| v.mod_id == mod_id).collect()
    }
}

