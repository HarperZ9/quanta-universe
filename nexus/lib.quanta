// MOD MARKETPLACE
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct MarketplaceListing {
    pub mod_id: String,
    pub metadata: ModMetadata,
    pub download_count: u64,
    pub rating: Rating,
    pub reviews: Vec<Review>,
    pub price: Option<Price>,
    pub featured: bool,
    pub verified: bool,
    pub upload_date: u64,
    pub last_update: u64,
}

#[derive(Debug, Clone)]
pub struct Rating {
    pub average: f32,
    pub count: u64,
    pub distribution: [u64; 5], // 1-5 stars
}

impl Rating {
    pub fn new() -> Self {
        Rating { average: 0.0, count: 0, distribution: [0; 5] }
    }

    pub fn add_rating(&mut self, stars: u8) {
        if stars >= 1 && stars <= 5 {
            self.distribution[(stars - 1) as usize] += 1;
            self.count += 1;
            self.recalculate();
        }
    }

    fn recalculate(&mut self) {
        if self.count == 0 { return; }
        let sum: u64 = self.distribution.iter().enumerate()
            .map(|(i, &c)| (i as u64 + 1) * c)
            .sum();
        self.average = sum as f32 / self.count as f32;
    }
}

#[derive(Debug, Clone)]
pub struct Review {
    pub id: String,
    pub author: String,
    pub rating: u8,
    pub title: String,
    pub content: String,
    pub helpful_count: u64,
    pub timestamp: u64,
    pub verified_purchase: bool,
    pub response: Option<AuthorResponse>,
}

#[derive(Debug, Clone)]
pub struct AuthorResponse {
    pub content: String,
    pub timestamp: u64,
}

#[derive(Debug, Clone)]
pub struct Price {
    pub amount_cents: u32,
    pub currency: String,
    pub discount_percent: Option<u8>,
    pub original_cents: Option<u32>,
}

pub struct Marketplace {
    pub endpoint: String,
    listings: HashMap<String, MarketplaceListing>,
    user_purchases: HashSet<String>,
    favorites: Vec<String>,
}

impl Marketplace {
    pub fn new(endpoint: &str) -> Self {
        Marketplace {
            endpoint: endpoint.to_string(),
            listings: HashMap::new(),
            user_purchases: HashSet::new(),
            favorites: Vec::new(),
        }
    }

    pub fn search(&self, query: &MarketplaceQuery) -> Vec<&MarketplaceListing> {
        let mut results: Vec<_> = self.listings.values()
            .filter(|l| self.matches_query(l, query))
            .collect();

        match query.sort_by {
            SortBy::Downloads => results.sort_by(|a, b| b.download_count.cmp(&a.download_count)),
            SortBy::Rating => results.sort_by(|a, b| b.rating.average.partial_cmp(&a.rating.average).unwrap_or(std::cmp::Ordering::Equal)),
            SortBy::Recent => results.sort_by(|a, b| b.last_update.cmp(&a.last_update)),
            SortBy::Name => results.sort_by(|a, b| a.metadata.name.cmp(&b.metadata.name)),
        }

        results
    }

    fn matches_query(&self, listing: &MarketplaceListing, query: &MarketplaceQuery) -> bool {
        if !query.text.is_empty() {
            let text_lower = query.text.to_lowercase();
            if !listing.metadata.name.to_lowercase().contains(&text_lower) &&
               !listing.metadata.description.to_lowercase().contains(&text_lower) {
                return false;
            }
        }
        if let Some(cat) = query.category {
            if listing.metadata.category != cat { return false; }
        }
        if query.free_only && listing.price.is_some() { return false; }
        if query.verified_only && !listing.verified { return false; }
        true
    }

    pub fn purchase(&mut self, mod_id: &str) -> Result<(), MarketplaceError> {
        if self.user_purchases.contains(mod_id) {
            return Err(MarketplaceError::AlreadyOwned);
        }
        // Would process payment
        self.user_purchases.insert(mod_id.to_string());
        Ok(())
    }

    pub fn submit_review(&mut self, mod_id: &str, review: Review) -> Result<(), MarketplaceError> {
        let listing = self.listings.get_mut(mod_id)
            .ok_or(MarketplaceError::NotFound)?;
        listing.reviews.push(review.clone());
        listing.rating.add_rating(review.rating);
        Ok(())
    }

    pub fn add_favorite(&mut self, mod_id: &str) {
        if !self.favorites.contains(&mod_id.to_string()) {
            self.favorites.push(mod_id.to_string());
        }
    }
}

#[derive(Debug, Clone)]
pub struct MarketplaceQuery {
    pub text: String,
    pub category: Option<ModCategory>,
    pub game_id: Option<String>,
    pub sort_by: SortBy,
    pub free_only: bool,
    pub verified_only: bool,
    pub min_rating: f32,
    pub page: u32,
    pub per_page: u32,
}

#[derive(Debug, Clone, Copy)]
pub enum SortBy {
    Downloads,
    Rating,
    Recent,
    Name,
}

#[derive(Debug)]
pub enum MarketplaceError {
    NotFound,
    AlreadyOwned,
    PaymentFailed,
    NetworkError,
    Unauthorized,
}

