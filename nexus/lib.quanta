// MOD REPOSITORY INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod repository {
    use super::*;

    pub struct ModRepository {
        pub name: String,
        pub base_url: String,
        pub api_key: Option<String>,
        pub cache_dir: String,
        pub enabled: bool,
    }

    pub struct RemoteMod {
        pub id: String,
        pub name: String,
        pub version: Version,
        pub author: String,
        pub description: String,
        pub download_url: String,
        pub file_size: u64,
        pub checksum: String,
        pub downloads: u64,
        pub rating: f32,
        pub tags: Vec<String>,
        pub dependencies: Vec<(String, String)>,
        pub screenshots: Vec<String>,
    }

    pub struct SearchQuery {
        pub query: String,
        pub category: Option<ModCategory>,
        pub tags: Vec<String>,
        pub sort_by: SortBy,
        pub page: u32,
        pub per_page: u32,
    }

    pub enum SortBy { Downloads, Rating, Recent, Updated, Name }

    impl ModRepository {
        pub fn new(name: &str, base_url: &str) -> Self {
            Self {
                name: name.to_string(), base_url: base_url.to_string(),
                api_key: None, cache_dir: "./cache".to_string(), enabled: true,
            }
        }

        pub fn search(&self, query: &SearchQuery) -> Result<Vec<RemoteMod>, String> {
            let url = format!("{}/api/v1/mods/search?q={}&page={}&per_page={}",
                self.base_url, query.query, query.page, query.per_page);
            // HTTP request simulation
            Ok(Vec::new())
        }

        pub fn get_mod_info(&self, mod_id: &str) -> Result<RemoteMod, String> {
            let url = format!("{}/api/v1/mods/{}", self.base_url, mod_id);
            Err("Not implemented".to_string())
        }

        pub fn download_mod(&self, remote_mod: &RemoteMod, dest: &str) -> Result<String, String> {
            let file_path = format!("{}/{}-{}.zip", dest, remote_mod.id, remote_mod.version);
            // Download simulation
            Ok(file_path)
        }

        pub fn verify_checksum(&self, file_path: &str, expected: &str) -> bool {
            // SHA256 verification
            true
        }
    }

    pub struct RepositoryManager {
        repositories: Vec<ModRepository>,
        installed_mods: HashMap<String, Version>,
    }

    impl RepositoryManager {
        pub fn new() -> Self {
            Self { repositories: Vec::new(), installed_mods: HashMap::new() }
        }

        pub fn add_repository(&mut self, repo: ModRepository) {
            self.repositories.push(repo);
        }

        pub fn search_all(&self, query: &SearchQuery) -> Vec<RemoteMod> {
            let mut results = Vec::new();
            for repo in &self.repositories {
                if repo.enabled {
                    if let Ok(mods) = repo.search(query) {
                        results.extend(mods);
                    }
                }
            }
            results
        }

        pub fn install_mod(&mut self, mod_id: &str, version: &Version) -> Result<(), String> {
            for repo in &self.repositories {
                if let Ok(remote) = repo.get_mod_info(mod_id) {
                    let path = repo.download_mod(&remote, &repo.cache_dir)?;
                    if repo.verify_checksum(&path, &remote.checksum) {
                        self.installed_mods.insert(mod_id.to_string(), version.clone());
                        return Ok(());
                    }
                }
            }
            Err("Mod not found".to_string())
        }

        pub fn check_updates(&self) -> Vec<(String, Version, Version)> {
            let mut updates = Vec::new();
            for (mod_id, installed_ver) in &self.installed_mods {
                for repo in &self.repositories {
                    if let Ok(remote) = repo.get_mod_info(mod_id) {
                        if remote.version > *installed_ver {
                            updates.push((mod_id.clone(), installed_ver.clone(), remote.version));
                            break;
                        }
                    }
                }
            }
            updates
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTO-UPDATER
// ═══════════════════════════════════════════════════════════════════════════════

pub mod auto_update {
    use super::*;

    pub struct UpdateConfig {
        pub check_on_startup: bool,
        pub auto_download: bool,
        pub auto_install: bool,
        pub backup_before_update: bool,
        pub update_channel: UpdateChannel,
    }

    pub enum UpdateChannel { Stable, Beta, Alpha, Nightly }

    pub struct UpdateInfo {
        pub mod_id: String,
        pub current_version: Version,
        pub new_version: Version,
        pub changelog: String,
        pub breaking_changes: bool,
        pub file_size: u64,
        pub download_url: String,
    }

    pub struct AutoUpdater {
        config: UpdateConfig,
        pending_updates: Vec<UpdateInfo>,
        update_history: Vec<UpdateRecord>,
    }

    pub struct UpdateRecord {
        pub mod_id: String,
        pub from_version: Version,
        pub to_version: Version,
        pub timestamp: u64,
        pub success: bool,
        pub backup_path: Option<String>,
    }

    impl AutoUpdater {
        pub fn new(config: UpdateConfig) -> Self {
            Self { config, pending_updates: Vec::new(), update_history: Vec::new() }
        }

        pub fn check_for_updates(&mut self, installed: &HashMap<String, Version>) -> Vec<&UpdateInfo> {
            self.pending_updates.clear();
            // Check repositories for updates
            self.pending_updates.iter().collect()
        }

        pub fn download_update(&self, update: &UpdateInfo, dest: &str) -> Result<String, String> {
            let path = format!("{}/{}-{}.zip", dest, update.mod_id, update.new_version);
            // Download logic
            Ok(path)
        }

        pub fn create_backup(&self, mod_path: &str) -> Result<String, String> {
            if !self.config.backup_before_update { return Ok(String::new()); }
            let backup_path = format!("{}.backup", mod_path);
            // Backup logic
            Ok(backup_path)
        }

        pub fn apply_update(&mut self, update: &UpdateInfo, downloaded_path: &str) -> Result<(), String> {
            let backup = self.create_backup(&update.mod_id)?;
            // Extract and install
            self.update_history.push(UpdateRecord {
                mod_id: update.mod_id.clone(),
                from_version: update.current_version.clone(),
                to_version: update.new_version.clone(),
                timestamp: 0, success: true,
                backup_path: if backup.is_empty() { None } else { Some(backup) },
            });
            Ok(())
        }

        pub fn rollback(&self, mod_id: &str) -> Result<(), String> {
            if let Some(record) = self.update_history.iter().rev().find(|r| r.mod_id == mod_id && r.backup_path.is_some()) {
                // Restore from backup
                Ok(())
            } else {
                Err("No backup available".to_string())
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD SCRIPTING ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod scripting {
    use super::*;

    pub enum ScriptLanguage { Lua, JavaScript, Python, QuantaScript }

    pub struct ScriptEngine {
        language: ScriptLanguage,
        globals: HashMap<String, ScriptValue>,
        functions: HashMap<String, Box<dyn Fn(Vec<ScriptValue>) -> ScriptValue>>,
        scripts: HashMap<String, String>,
    }

    pub enum ScriptValue {
        Nil, Bool(bool), Int(i64), Float(f64), String(String),
        Array(Vec<ScriptValue>), Object(HashMap<String, ScriptValue>),
        Function(String),
    }

    pub struct ScriptContext {
        pub mod_id: String,
        pub game_state: HashMap<String, ScriptValue>,
        pub callbacks: Vec<ScriptCallback>,
    }

    pub struct ScriptCallback {
        pub event: String,
        pub function_name: String,
        pub priority: i32,
    }

    impl ScriptEngine {
        pub fn new(language: ScriptLanguage) -> Self {
            Self {
                language, globals: HashMap::new(),
                functions: HashMap::new(), scripts: HashMap::new(),
            }
        }

        pub fn register_global(&mut self, name: &str, value: ScriptValue) {
            self.globals.insert(name.to_string(), value);
        }

        pub fn load_script(&mut self, name: &str, source: &str) -> Result<(), String> {
            // Parse and validate script
            self.scripts.insert(name.to_string(), source.to_string());
            Ok(())
        }

        pub fn execute(&self, script_name: &str, context: &mut ScriptContext) -> Result<ScriptValue, String> {
            let source = self.scripts.get(script_name).ok_or("Script not found")?;
            // Execute script with context
            Ok(ScriptValue::Nil)
        }

        pub fn call_function(&self, name: &str, args: Vec<ScriptValue>) -> Result<ScriptValue, String> {
            // Call registered function
            Ok(ScriptValue::Nil)
        }
    }

    pub struct ScriptHooks {
        hooks: HashMap<String, Vec<(String, i32)>>,  // event -> [(function, priority)]
    }

    impl ScriptHooks {
        pub fn new() -> Self { Self { hooks: HashMap::new() } }

        pub fn register(&mut self, event: &str, function: &str, priority: i32) {
            self.hooks.entry(event.to_string())
                .or_insert_with(Vec::new)
                .push((function.to_string(), priority));
            if let Some(hooks) = self.hooks.get_mut(event) {
                hooks.sort_by(|a, b| b.1.cmp(&a.1));
            }
        }

        pub fn unregister(&mut self, event: &str, function: &str) {
            if let Some(hooks) = self.hooks.get_mut(event) {
                hooks.retain(|(f, _)| f != function);
            }
        }

        pub fn get_hooks(&self, event: &str) -> Vec<&str> {
            self.hooks.get(event)
                .map(|h| h.iter().map(|(f, _)| f.as_str()).collect())
                .unwrap_or_default()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEMORY PATCHING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod memory {
    use super::*;

    pub struct RawMemoryPatch {
        pub name: String,
        pub address: usize,
        pub original_bytes: Vec<u8>,
        pub patch_bytes: Vec<u8>,
        pub is_applied: bool,
    }

    pub struct PatternScanner {
        pub patterns: HashMap<String, Vec<PatternByte>>,
    }

    pub enum PatternByte { Exact(u8), Wildcard }

    impl PatternScanner {
        pub fn new() -> Self { Self { patterns: HashMap::new() } }

        pub fn add_pattern(&mut self, name: &str, pattern: &str) {
            let bytes: Vec<PatternByte> = pattern.split_whitespace()
                .map(|b| {
                    if b == "??" || b == "?" { PatternByte::Wildcard }
                    else { PatternByte::Exact(u8::from_str_radix(b, 16).unwrap_or(0)) }
                })
                .collect();
            self.patterns.insert(name.to_string(), bytes);
        }

        pub fn scan(&self, name: &str, memory: &[u8], start: usize) -> Option<usize> {
            let pattern = self.patterns.get(name)?;
            for i in 0..memory.len().saturating_sub(pattern.len()) {
                let mut found = true;
                for (j, pb) in pattern.iter().enumerate() {
                    match pb {
                        PatternByte::Exact(b) if memory[i + j] != *b => { found = false; break; },
                        _ => {},
                    }
                }
                if found { return Some(start + i); }
            }
            None
        }

        pub fn scan_all(&self, name: &str, memory: &[u8], start: usize) -> Vec<usize> {
            let mut results = Vec::new();
            let pattern = match self.patterns.get(name) { Some(p) => p, None => return results };
            for i in 0..memory.len().saturating_sub(pattern.len()) {
                let mut found = true;
                for (j, pb) in pattern.iter().enumerate() {
                    match pb {
                        PatternByte::Exact(b) if memory[i + j] != *b => { found = false; break; },
                        _ => {},
                    }
                }
                if found { results.push(start + i); }
            }
            results
        }
    }

    pub struct PatchManager {
        patches: Vec<RawMemoryPatch>,
        scanner: PatternScanner,
    }

    impl PatchManager {
        pub fn new() -> Self {
            Self { patches: Vec::new(), scanner: PatternScanner::new() }
        }

        pub fn create_patch(&mut self, name: &str, address: usize, patch_bytes: Vec<u8>) -> &RawMemoryPatch {
            let original = vec![0u8; patch_bytes.len()];  // Would read actual memory
            self.patches.push(RawMemoryPatch {
                name: name.to_string(), address, original_bytes: original,
                patch_bytes, is_applied: false,
            });
            self.patches.last().unwrap()
        }

        pub fn apply_patch(&mut self, name: &str) -> Result<(), String> {
            let patch = self.patches.iter_mut().find(|p| p.name == name).ok_or("Patch not found")?;
            if patch.is_applied { return Err("Already applied".to_string()); }
            // Write patch bytes to memory
            patch.is_applied = true;
            Ok(())
        }

        pub fn revert_patch(&mut self, name: &str) -> Result<(), String> {
            let patch = self.patches.iter_mut().find(|p| p.name == name).ok_or("Patch not found")?;
            if !patch.is_applied { return Err("Not applied".to_string()); }
            // Write original bytes to memory
            patch.is_applied = false;
            Ok(())
        }

        pub fn apply_all(&mut self) {
            for patch in &mut self.patches {
                if !patch.is_applied { patch.is_applied = true; }
            }
        }

        pub fn revert_all(&mut self) {
            for patch in &mut self.patches {
                if patch.is_applied { patch.is_applied = false; }
            }
        }
    }

    /// Hook manager for function detouring
    pub struct HookManager {
        hooks: HashMap<String, FunctionHook>,
    }

    pub struct FunctionHook {
        pub name: String,
        pub original_address: usize,
        pub hook_address: usize,
        pub trampoline: Vec<u8>,
        pub active: bool,
    }

    impl HookManager {
        pub fn new() -> Self { Self { hooks: HashMap::new() } }

        pub fn create_hook(&mut self, name: &str, target: usize, detour: usize) -> Result<(), String> {
            let trampoline = vec![0u8; 16];  // Allocate trampoline
            self.hooks.insert(name.to_string(), FunctionHook {
                name: name.to_string(),
                original_address: target,
                hook_address: detour,
                trampoline,
                active: false,
            });
            Ok(())
        }

        pub fn enable_hook(&mut self, name: &str) -> Result<(), String> {
            let hook = self.hooks.get_mut(name).ok_or("Hook not found")?;
            if hook.active { return Err("Already active".to_string()); }
            // Install jump to detour
            hook.active = true;
            Ok(())
        }

        pub fn disable_hook(&mut self, name: &str) -> Result<(), String> {
            let hook = self.hooks.get_mut(name).ok_or("Hook not found")?;
            if !hook.active { return Err("Not active".to_string()); }
            // Restore original bytes
            hook.active = false;
            Ok(())
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIRTUAL FILE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub mod vfs {
    use super::*;

    pub enum VFSEntry {
        File { content: Vec<u8>, mod_source: String },
        Directory { children: HashMap<String, VFSEntry> },
        Redirect { target: String },
    }

    pub struct VirtualFileSystem {
        root: VFSEntry,
        mount_points: Vec<MountPoint>,
        redirects: HashMap<String, String>,
    }

    pub struct MountPoint {
        pub virtual_path: String,
        pub real_path: String,
        pub mod_id: String,
        pub priority: i32,
        pub read_only: bool,
    }

    impl VirtualFileSystem {
        pub fn new() -> Self {
            Self {
                root: VFSEntry::Directory { children: HashMap::new() },
                mount_points: Vec::new(),
                redirects: HashMap::new(),
            }
        }

        pub fn mount(&mut self, mount_point: MountPoint) {
            let priority = mount_point.priority;
            self.mount_points.push(mount_point);
            self.mount_points.sort_by(|a, b| b.priority.cmp(&a.priority));
        }

        pub fn unmount(&mut self, virtual_path: &str) {
            self.mount_points.retain(|m| m.virtual_path != virtual_path);
        }

        pub fn add_redirect(&mut self, from: &str, to: &str) {
            self.redirects.insert(from.to_string(), to.to_string());
        }

        pub fn resolve_path(&self, path: &str) -> String {
            // Check redirects first
            if let Some(redirect) = self.redirects.get(path) {
                return redirect.clone();
            }

            // Check mount points by priority
            for mount in &self.mount_points {
                if path.starts_with(&mount.virtual_path) {
                    let vp_len = mount.virtual_path.len();
                    let relative = if path.len() > vp_len { &path[vp_len..] } else { "" };
                    let resolved = format!("{}{}", mount.real_path, relative);
                    // Check if file exists at resolved path
                    return resolved;
                }
            }

            path.to_string()
        }

        pub fn read_file(&self, path: &str) -> Result<Vec<u8>, String> {
            let resolved = self.resolve_path(path);
            // Read from resolved path
            Err("File not found".to_string())
        }

        pub fn write_file(&mut self, path: &str, content: Vec<u8>) -> Result<(), String> {
            let resolved = self.resolve_path(path);
            // Check if path is in a read-only mount
            for mount in &self.mount_points {
                if resolved.starts_with(&mount.real_path) && mount.read_only {
                    return Err("Mount is read-only".to_string());
                }
            }
            // Write to resolved path
            Ok(())
        }

        pub fn list_directory(&self, path: &str) -> Vec<String> {
            let mut entries = Vec::new();
            // Merge entries from all applicable mounts
            for mount in &self.mount_points {
                if path.starts_with(&mount.virtual_path) || mount.virtual_path.starts_with(path) {
                    // Add entries from this mount
                }
            }
            entries.sort();
            entries.dedup();
            entries
        }

        pub fn file_exists(&self, path: &str) -> bool {
            let resolved = self.resolve_path(path);
            // Check existence
            false
        }

        pub fn get_file_info(&self, path: &str) -> Option<FileInfo> {
            let resolved = self.resolve_path(path);
            None
        }
    }

    pub struct FileInfo {
        pub path: String,
        pub size: u64,
        pub is_directory: bool,
        pub mod_source: Option<String>,
        pub is_overridden: bool,
    }

    /// Archive handler for common mod formats
    pub struct ArchiveHandler {
        supported_formats: Vec<ArchiveFormat>,
    }

    pub enum ArchiveFormat { Zip, SevenZip, Rar, Tar, TarGz, Bsa, Ba2, Pak }

    impl ArchiveHandler {
        pub fn new() -> Self {
            Self {
                supported_formats: vec![
                    ArchiveFormat::Zip, ArchiveFormat::SevenZip, ArchiveFormat::Rar,
                    ArchiveFormat::Bsa, ArchiveFormat::Ba2, ArchiveFormat::Pak,
                ],
            }
        }

        pub fn detect_format(&self, path: &str) -> Option<ArchiveFormat> {
            let ext = path.rsplit('.').next()?;
            match ext.to_lowercase().as_str() {
                "zip" => Some(ArchiveFormat::Zip),
                "7z" => Some(ArchiveFormat::SevenZip),
                "rar" => Some(ArchiveFormat::Rar),
                "tar" => Some(ArchiveFormat::Tar),
                "gz" | "tgz" => Some(ArchiveFormat::TarGz),
                "bsa" => Some(ArchiveFormat::Bsa),
                "ba2" => Some(ArchiveFormat::Ba2),
                "pak" => Some(ArchiveFormat::Pak),
                _ => None,
            }
        }

        pub fn list_contents(&self, archive_path: &str) -> Result<Vec<String>, String> {
            let format = self.detect_format(archive_path).ok_or("Unknown format")?;
            // List archive contents
            Ok(Vec::new())
        }

        pub fn extract(&self, archive_path: &str, dest: &str) -> Result<(), String> {
            let format = self.detect_format(archive_path).ok_or("Unknown format")?;
            // Extract based on format
            Ok(())
        }

        pub fn extract_file(&self, archive_path: &str, file_path: &str) -> Result<Vec<u8>, String> {
            let format = self.detect_format(archive_path).ok_or("Unknown format")?;
            // Extract single file
            Err("Not found".to_string())
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// UI MOD FRAMEWORK
// ═══════════════════════════════════════════════════════════════════════════════

pub mod ui_mods {
    use super::*;

    pub struct UIElement {
        pub id: String,
        pub element_type: UIElementType,
        pub position: (f32, f32),
        pub size: (f32, f32),
        pub visible: bool,
        pub enabled: bool,
        pub style: UIStyle,
        pub children: Vec<UIElement>,
    }

    pub enum UIElementType {
        Panel, Button, Label, TextInput, Checkbox, Slider, Dropdown,
        Image, ProgressBar, ListView, TreeView, TabControl,
    }

    pub struct UIStyle {
        pub background_color: (u8, u8, u8, u8),
        pub text_color: (u8, u8, u8, u8),
        pub border_color: (u8, u8, u8, u8),
        pub border_width: f32,
        pub corner_radius: f32,
        pub font_size: f32,
        pub padding: (f32, f32, f32, f32),
    }

    pub struct ModUI {
        pub mod_id: String,
        pub root: UIElement,
        pub visible: bool,
        pub hotkey: Option<u32>,
    }

    pub struct UIManager {
        mod_uis: HashMap<String, ModUI>,
        overlay_active: bool,
        focus_mod: Option<String>,
    }

    impl UIManager {
        pub fn new() -> Self {
            Self { mod_uis: HashMap::new(), overlay_active: false, focus_mod: None }
        }

        pub fn register_ui(&mut self, mod_id: &str, ui: ModUI) {
            self.mod_uis.insert(mod_id.to_string(), ui);
        }

        pub fn unregister_ui(&mut self, mod_id: &str) {
            self.mod_uis.remove(mod_id);
        }

        pub fn toggle_mod_ui(&mut self, mod_id: &str) {
            if let Some(ui) = self.mod_uis.get_mut(mod_id) {
                ui.visible = !ui.visible;
            }
        }

        pub fn toggle_overlay(&mut self) {
            self.overlay_active = !self.overlay_active;
        }

        pub fn handle_input(&mut self, key: u32, pressed: bool) -> bool {
            // Check for mod hotkeys
            for (mod_id, ui) in &mut self.mod_uis {
                if ui.hotkey == Some(key) && pressed {
                    ui.visible = !ui.visible;
                    return true;
                }
            }
            false
        }

        pub fn render(&self) {
            if !self.overlay_active { return; }
            for ui in self.mod_uis.values() {
                if ui.visible {
                    self.render_element(&ui.root);
                }
            }
        }

        fn render_element(&self, element: &UIElement) {
            if !element.visible { return; }
            // Render element based on type
            for child in &element.children {
                self.render_element(child);
            }
        }
    }

    impl Default for UIStyle {
        fn default() -> Self {
            Self {
                background_color: (40, 40, 40, 220),
                text_color: (255, 255, 255, 255),
                border_color: (80, 80, 80, 255),
                border_width: 1.0,
                corner_radius: 4.0,
                font_size: 14.0,
                padding: (8.0, 8.0, 8.0, 8.0),
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOAD ORDER MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub struct LoadOrderEntry { pub mod_id: String, pub priority: i32, pub enabled: bool, pub group: String }

pub struct LoadOrderManager {
    pub entries: Vec<LoadOrderEntry>,
    pub groups: HashMap<String, i32>,
    pub rules: Vec<LoadOrderRule>,
    pub locked_entries: HashSet<String>,
}

pub enum LoadOrderRule {
    Before { mod_id: String, before: String },
    After { mod_id: String, after: String },
    Conflict { mod_a: String, mod_b: String },
    Require { mod_id: String, requires: String },
    Group { mod_id: String, group: String },
}

impl LoadOrderManager {
    pub fn new() -> Self { Self { entries: Vec::new(), groups: HashMap::new(), rules: Vec::new(), locked_entries: HashSet::new() } }

    pub fn add(&mut self, entry: LoadOrderEntry) { self.entries.push(entry); }
    pub fn add_rule(&mut self, rule: LoadOrderRule) { self.rules.push(rule); }
    pub fn set_group_priority(&mut self, group: &str, priority: i32) { self.groups.insert(group.to_string(), priority); }
    pub fn lock(&mut self, mod_id: &str) { self.locked_entries.insert(mod_id.to_string()); }

    pub fn sort(&mut self) -> Result<(), Vec<String>> {
        let mut errors = Vec::new();
        self.entries.sort_by(|a, b| {
            let ga = self.groups.get(&a.group).copied().unwrap_or(0);
            let gb = self.groups.get(&b.group).copied().unwrap_or(0);
            ga.cmp(&gb).then(a.priority.cmp(&b.priority))
        });
        let idx_map: HashMap<String, usize> = self.entries.iter().enumerate().map(|(i, e)| (e.mod_id.clone(), i)).collect();
        for rule in &self.rules {
            match rule {
                LoadOrderRule::Before { mod_id, before } => {
                    if let (Some(&i), Some(&j)) = (idx_map.get(mod_id), idx_map.get(before)) {
                        if i >= j { errors.push(format!("{} must load before {}", mod_id, before)); }
                    }
                },
                LoadOrderRule::Conflict { mod_a, mod_b } => {
                    let a_enabled = self.entries.iter().find(|e| &e.mod_id == mod_a).map(|e| e.enabled).unwrap_or(false);
                    let b_enabled = self.entries.iter().find(|e| &e.mod_id == mod_b).map(|e| e.enabled).unwrap_or(false);
                    if a_enabled && b_enabled { errors.push(format!("{} conflicts with {}", mod_a, mod_b)); }
                },
                LoadOrderRule::Require { mod_id, requires } => {
                    let mod_enabled = self.entries.iter().find(|e| &e.mod_id == mod_id).map(|e| e.enabled).unwrap_or(false);
                    let req_enabled = self.entries.iter().find(|e| &e.mod_id == requires).map(|e| e.enabled).unwrap_or(false);
                    if mod_enabled && !req_enabled { errors.push(format!("{} requires {}", mod_id, requires)); }
                },
                _ => {}
            }
        }
        if errors.is_empty() { Ok(()) } else { Err(errors) }
    }

    pub fn move_up(&mut self, mod_id: &str) -> bool {
        if self.locked_entries.contains(mod_id) { return false; }
        if let Some(i) = self.entries.iter().position(|e| e.mod_id == mod_id) {
            if i > 0 { self.entries.swap(i, i - 1); return true; }
        }
        false
    }

    pub fn move_down(&mut self, mod_id: &str) -> bool {
        if self.locked_entries.contains(mod_id) { return false; }
        if let Some(i) = self.entries.iter().position(|e| e.mod_id == mod_id) {
            if i < self.entries.len() - 1 { self.entries.swap(i, i + 1); return true; }
        }
        false
    }

    pub fn export(&self) -> String {
        let mut s = String::new();
        for (i, e) in self.entries.iter().enumerate() {
            s.push_str(&format!("{}: {} [{}] {}\n", i, e.mod_id, e.group, if e.enabled { "ON" } else { "OFF" }));
        }
        s
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD BACKUP & RESTORE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct BackupEntry { pub path: String, pub hash: String, pub size: u64, pub timestamp: u64 }

pub struct ModBackup {
    pub name: String,
    pub created: u64,
    pub mod_id: String,
    pub version: String,
    pub files: Vec<BackupEntry>,
    pub metadata: HashMap<String, String>,
}

pub struct BackupManager {
    pub backups: HashMap<String, Vec<ModBackup>>,
    pub backup_dir: String,
    pub max_backups_per_mod: usize,
    pub auto_backup: bool,
}

impl BackupManager {
    pub fn new(backup_dir: &str) -> Self {
        Self { backups: HashMap::new(), backup_dir: backup_dir.to_string(), max_backups_per_mod: 5, auto_backup: true }
    }

    pub fn create_backup(&mut self, mod_id: &str, version: &str, files: Vec<BackupEntry>) -> String {
        let timestamp = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
        let backup_name = format!("{}_{}_{}",mod_id, version, timestamp);
        let backup = ModBackup { name: backup_name.clone(), created: timestamp, mod_id: mod_id.to_string(), version: version.to_string(), files, metadata: HashMap::new() };
        let list = self.backups.entry(mod_id.to_string()).or_insert_with(Vec::new);
        list.push(backup);
        while list.len() > self.max_backups_per_mod { list.remove(0); }
        backup_name
    }

    pub fn restore(&self, backup_name: &str) -> Option<&ModBackup> {
        for list in self.backups.values() { if let Some(b) = list.iter().find(|b| b.name == backup_name) { return Some(b); } }
        None
    }

    pub fn list_backups(&self, mod_id: &str) -> Vec<&ModBackup> {
        self.backups.get(mod_id).map(|l| l.iter().collect()).unwrap_or_default()
    }

    pub fn delete_backup(&mut self, backup_name: &str) -> bool {
        for list in self.backups.values_mut() {
            if let Some(i) = list.iter().position(|b| b.name == backup_name) { list.remove(i); return true; }
        }
        false
    }

    pub fn prune_old(&mut self, max_age_secs: u64) {
        let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
        for list in self.backups.values_mut() { list.retain(|b| now - b.created < max_age_secs); }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLICT DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

pub enum ConflictType { FileOverwrite, AssetConflict, PluginConflict, RecordConflict, ResourceConflict }
pub enum ConflictSeverity { Low, Medium, High, Critical }

pub struct ModConflict {
    pub conflict_type: ModConflictType,
    pub severity: ModConflictSeverity,
    pub mod_a: String,
    pub mod_b: String,
    pub resource: String,
    pub description: String,
    pub auto_resolvable: bool,
}

pub struct ModConflictDetector {
    pub conflicts: Vec<ModConflict>,
    pub file_owners: HashMap<String, Vec<String>>,
    pub record_owners: HashMap<String, Vec<String>>,
    pub ignore_patterns: Vec<String>,
}

impl ModConflictDetector {
    pub fn new() -> Self { Self { conflicts: Vec::new(), file_owners: HashMap::new(), record_owners: HashMap::new(), ignore_patterns: Vec::new() } }

    pub fn register_file(&mut self, path: &str, mod_id: &str) {
        self.file_owners.entry(path.to_string()).or_insert_with(Vec::new).push(mod_id.to_string());
    }

    pub fn register_record(&mut self, record_id: &str, mod_id: &str) {
        self.record_owners.entry(record_id.to_string()).or_insert_with(Vec::new).push(mod_id.to_string());
    }

    pub fn detect(&mut self) {
        self.conflicts.clear();
        for (path, owners) in &self.file_owners {
            if owners.len() > 1 && !self.is_ignored(path) {
                for i in 0..owners.len() - 1 {
                    self.conflicts.push(Conflict {
                        conflict_type: ConflictType::FileOverwrite, severity: ConflictSeverity::Medium,
                        mod_a: owners[i].clone(), mod_b: owners[i + 1].clone(), resource: path.clone(),
                        description: format!("Both mods modify {}", path), auto_resolvable: true,
                    });
                }
            }
        }
        for (rec, owners) in &self.record_owners {
            if owners.len() > 1 {
                for i in 0..owners.len() - 1 {
                    self.conflicts.push(Conflict {
                        conflict_type: ConflictType::RecordConflict, severity: ConflictSeverity::High,
                        mod_a: owners[i].clone(), mod_b: owners[i + 1].clone(), resource: rec.clone(),
                        description: format!("Record {} modified by multiple mods", rec), auto_resolvable: false,
                    });
                }
            }
        }
    }

    fn is_ignored(&self, path: &str) -> bool {
        self.ignore_patterns.iter().any(|p| path.contains(p))
    }

    pub fn by_severity(&self, sev: ConflictSeverity) -> Vec<&Conflict> {
        self.conflicts.iter().filter(|c| matches!((&c.severity, &sev), (ConflictSeverity::Low, ConflictSeverity::Low) | (ConflictSeverity::Medium, ConflictSeverity::Medium) | (ConflictSeverity::High, ConflictSeverity::High) | (ConflictSeverity::Critical, ConflictSeverity::Critical))).collect()
    }

    pub fn auto_resolve(&mut self) -> usize {
        let resolvable: Vec<usize> = self.conflicts.iter().enumerate().filter(|(_, c)| c.auto_resolvable).map(|(i, _)| i).collect();
        let count = resolvable.len();
        for i in resolvable.into_iter().rev() { self.conflicts.remove(i); }
        count
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROFILE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SimpleProfile {
    pub name: String,
    pub description: String,
    pub enabled_mods: Vec<String>,
    pub load_order: Vec<String>,
    pub settings: HashMap<String, String>,
    pub created: u64,
    pub last_used: u64,
}

pub struct ProfileManager {
    pub profiles: HashMap<String, SimpleProfile>,
    pub active_profile: Option<String>,
    pub default_profile: String,
}

impl ProfileManager {
    pub fn new() -> Self { Self { profiles: HashMap::new(), active_profile: None, default_profile: "Default".to_string() } }

    pub fn create(&mut self, name: &str, description: &str) -> bool {
        if self.profiles.contains_key(name) { return false; }
        let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
        self.profiles.insert(name.to_string(), SimpleProfile {
            name: name.to_string(), description: description.to_string(), enabled_mods: Vec::new(),
            load_order: Vec::new(), settings: HashMap::new(), created: now, last_used: now,
        });
        true
    }

    pub fn activate(&mut self, name: &str) -> bool {
        if self.profiles.contains_key(name) {
            self.active_profile = Some(name.to_string());
            if let Some(p) = self.profiles.get_mut(name) {
                p.last_used = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
            }
            return true;
        }
        return false;
    }

    pub fn delete(&mut self, name: &str) -> bool {
        if name == self.default_profile { return false; }
        if self.active_profile.as_ref() == Some(&name.to_string()) { self.active_profile = None; }
        self.profiles.remove(name).is_some()
    }

    pub fn duplicate(&mut self, source: &str, new_name: &str) -> bool {
        if let Some(src) = self.profiles.get(source).cloned() {
            if self.profiles.contains_key(new_name) { return false; }
            let now = std::time::SystemTime::now().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs();
            let mut new_profile = src;
            new_profile.name = new_name.to_string();
            new_profile.created = now;
            new_profile.last_used = now;
            self.profiles.insert(new_name.to_string(), new_profile);
            true
        } else { false }
    }

    pub fn active(&self) -> Option<&SimpleProfile> {
        self.active_profile.as_ref().and_then(|n| self.profiles.get(n))
    }

    pub fn active_mut(&mut self) -> Option<&mut SimpleProfile> {
        let name = self.active_profile.clone()?;
        self.profiles.get_mut(&name)
    }

    pub fn export_profile(&self, name: &str) -> Option<String> {
        let p = self.profiles.get(name)?;
        let mut s = format!("[Profile:{}]\n", p.name);
        s.push_str(&format!("description={}\n", p.description));
        s.push_str(&format!("mods={}\n", p.enabled_mods.join(",")));
        s.push_str(&format!("order={}\n", p.load_order.join(",")));
        Some(s)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASSET REDIRECTION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SimpleRedirect { pub original: String, pub replacement: String, pub mod_id: String, pub priority: i32 }

pub struct AssetRedirector {
    pub redirects: HashMap<String, Vec<SimpleRedirect>>,
    pub cache: HashMap<String, String>,
    pub enabled: bool,
}

impl AssetRedirector {
    pub fn new() -> Self { Self { redirects: HashMap::new(), cache: HashMap::new(), enabled: true } }

    pub fn add_redirect(&mut self, original: &str, replacement: &str, mod_id: &str, priority: i32) {
        let redirect = SimpleRedirect { original: original.to_string(), replacement: replacement.to_string(), mod_id: mod_id.to_string(), priority };
        self.redirects.entry(original.to_string()).or_insert_with(Vec::new).push(redirect);
        self.redirects.get_mut(original).unwrap().sort_by(|a, b| b.priority.cmp(&a.priority));
        self.cache.remove(original);
    }

    pub fn resolve(&mut self, path: &str) -> &str {
        if !self.enabled { return path; }
        if let Some(cached) = self.cache.get(path) { return cached; }
        if let Some(redirects) = self.redirects.get(path) {
            if let Some(r) = redirects.first() {
                self.cache.insert(path.to_string(), r.replacement.clone());
                return self.cache.get(path).unwrap();
            }
        }
        path
    }

    pub fn remove_mod(&mut self, mod_id: &str) {
        for list in self.redirects.values_mut() { list.retain(|r| r.mod_id != mod_id); }
        self.cache.clear();
    }

    pub fn stats(&self) -> (usize, usize) {
        let total: usize = self.redirects.values().map(|v| v.len()).sum();
        (self.redirects.len(), total)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIRTUAL FILE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub enum VfsNodeType { File, Directory, Symlink(String), Archive }
pub struct VfsNode { pub name: String, pub node_type: VfsNodeType, pub size: u64, pub modified: u64, pub source_mod: Option<String>, pub priority: i32, pub children: HashMap<String, VfsNode> }

impl VfsNode {
    pub fn new_file(name: &str, size: u64, modified: u64) -> Self { Self { name: name.to_string(), node_type: VfsNodeType::File, size, modified, source_mod: None, priority: 0, children: HashMap::new() } }
    pub fn new_dir(name: &str) -> Self { Self { name: name.to_string(), node_type: VfsNodeType::Directory, size: 0, modified: 0, source_mod: None, priority: 0, children: HashMap::new() } }
    pub fn with_mod(mut self, mod_id: &str, priority: i32) -> Self { self.source_mod = Some(mod_id.to_string()); self.priority = priority; self }
}

pub struct VirtualFileSystem {
    pub root: VfsNode,
    pub mount_points: HashMap<String, String>,
    pub overlays: Vec<VfsOverlay>,
    pub case_sensitive: bool,
    pub read_only: bool,
}

pub struct VfsOverlay { pub mod_id: String, pub base_path: String, pub priority: i32, pub enabled: bool }

impl VirtualFileSystem {
    pub fn new() -> Self { Self { root: VfsNode::new_dir("/"), mount_points: HashMap::new(), overlays: Vec::new(), case_sensitive: false, read_only: false } }

    pub fn normalize_path(&self, path: &str) -> String {
        let normalized = path.replace('\\', "/").trim_matches('/').to_string();
        if self.case_sensitive { normalized } else { normalized.to_lowercase() }
    }

    pub fn add_overlay(&mut self, mod_id: &str, base_path: &str, priority: i32) {
        self.overlays.push(VfsOverlay { mod_id: mod_id.to_string(), base_path: base_path.to_string(), priority, enabled: true });
        self.overlays.sort_by(|a, b| b.priority.cmp(&a.priority));
    }

    pub fn remove_overlay(&mut self, mod_id: &str) { self.overlays.retain(|o| o.mod_id != mod_id); }

    pub fn mount(&mut self, virtual_path: &str, physical_path: &str) { self.mount_points.insert(self.normalize_path(virtual_path), physical_path.to_string()); }

    pub fn resolve(&self, virtual_path: &str) -> Option<String> {
        let normalized = self.normalize_path(virtual_path);
        for overlay in &self.overlays {
            if !overlay.enabled { continue; }
            let candidate = format!("{}/{}", overlay.base_path, normalized);
            return Some(candidate);
        }
        self.mount_points.get(&normalized).cloned()
    }

    pub fn add_node(&mut self, path: &str, node: VfsNode) -> bool {
        let normalized = self.normalize_path(path);
        let parts: Vec<&str> = normalized.split('/').filter(|s| !s.is_empty()).collect();
        let mut current = &mut self.root;
        for (i, part) in parts.iter().enumerate() {
            if i == parts.len() - 1 { current.children.insert(part.to_string(), node); return true; }
            if !current.children.contains_key(*part) { current.children.insert(part.to_string(), VfsNode::new_dir(part)); }
            current = current.children.get_mut(*part).unwrap();
        }
        false
    }

    pub fn get_node(&self, path: &str) -> Option<&VfsNode> {
        let normalized = self.normalize_path(path);
        let parts: Vec<&str> = normalized.split('/').filter(|s| !s.is_empty()).collect();
        let mut current = &self.root;
        for part in parts { current = current.children.get(part)?; }
        Some(current)
    }

    pub fn list_dir(&self, path: &str) -> Vec<&VfsNode> {
        match self.get_node(path) {
            Some(node) => node.children.values().collect(),
            None => Vec::new()
        }
    }

    pub fn walk<F: FnMut(&str, &VfsNode)>(&self, path: &str, f: &mut F) {
        fn walk_impl<F: FnMut(&str, &VfsNode)>(node: &VfsNode, current_path: &str, f: &mut F) {
            let full_path = if current_path.is_empty() { node.name.clone() } else { format!("{}/{}", current_path, node.name) };
            f(&full_path, node);
            for child in node.children.values() { walk_impl(child, &full_path, f); }
        }
        if let Some(node) = self.get_node(path) { walk_impl(node, "", f); }
    }

    pub fn total_size(&self) -> u64 {
        let mut size = 0u64;
        self.walk("/", &mut |_, node| { size += node.size; });
        size
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD PACKAGE FORMAT
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ModPackage {
    pub id: String,
    pub name: String,
    pub version: SemanticVersion,
    pub author: String,
    pub description: String,
    pub website: Option<String>,
    pub license: String,
    pub dependencies: Vec<ModDependency>,
    pub conflicts: Vec<String>,
    pub provides: Vec<String>,
    pub files: Vec<ModFile>,
    pub install_scripts: Vec<InstallScript>,
    pub fomod_config: Option<FomodConfig>,
    pub checksum: String,
    pub size_bytes: u64,
    pub created: u64,
    pub updated: u64,
}

pub struct SemanticVersion { pub major: u32, pub minor: u32, pub patch: u32, pub prerelease: Option<String>, pub build: Option<String> }
impl SemanticVersion {
    pub fn parse(s: &str) -> Option<Self> {
        let s = s.trim_start_matches('v');
        let (main, pre_build) = s.split_once('-').map(|(m, p)| (m, Some(p))).unwrap_or((s, None));
        let parts: Vec<&str> = main.split('.').collect();
        if parts.len() < 2 { return None; }
        let major = parts[0].parse().ok()?;
        let minor = parts[1].parse().ok()?;
        let patch = parts.get(2).and_then(|p| p.parse().ok()).unwrap_or(0);
        let (prerelease, build) = match pre_build {
            Some(pb) => pb.split_once('+').map(|(p, b)| (Some(p.to_string()), Some(b.to_string()))).unwrap_or((Some(pb.to_string()), None)),
            None => (None, None)
        };
        Some(Self { major, minor, patch, prerelease, build })
    }
    pub fn to_string(&self) -> String {
        let mut s = format!("{}.{}.{}", self.major, self.minor, self.patch);
        if let Some(ref pre) = self.prerelease { s.push('-'); s.push_str(pre); }
        if let Some(ref build) = self.build { s.push('+'); s.push_str(build); }
        s
    }
    pub fn compare(&self, other: &Self) -> i32 {
        if self.major != other.major { return (self.major as i32) - (other.major as i32); }
        if self.minor != other.minor { return (self.minor as i32) - (other.minor as i32); }
        if self.patch != other.patch { return (self.patch as i32) - (other.patch as i32); }
        match (&self.prerelease, &other.prerelease) {
            (None, Some(_)) => 1, (Some(_), None) => -1,
            (Some(a), Some(b)) => a.cmp(b) as i32,
            (None, None) => 0
        }
    }
    pub fn satisfies(&self, constraint: &VersionConstraint) -> bool {
        match constraint {
            VersionConstraint::Exact(v) => self.compare(v) == 0,
            VersionConstraint::GreaterThan(v) => self.compare(v) > 0,
            VersionConstraint::GreaterOrEqual(v) => self.compare(v) >= 0,
            VersionConstraint::LessThan(v) => self.compare(v) < 0,
            VersionConstraint::LessOrEqual(v) => self.compare(v) <= 0,
            VersionConstraint::Range(min, max) => self.compare(min) >= 0 && self.compare(max) <= 0,
            VersionConstraint::Caret(v) => self.major == v.major && self.compare(v) >= 0,
            VersionConstraint::Tilde(v) => self.major == v.major && self.minor == v.minor && self.compare(v) >= 0,
            VersionConstraint::Any => true,
        }
    }
}

pub enum VersionConstraint { Exact(SemanticVersion), GreaterThan(SemanticVersion), GreaterOrEqual(SemanticVersion), LessThan(SemanticVersion), LessOrEqual(SemanticVersion), Range(SemanticVersion, SemanticVersion), Caret(SemanticVersion), Tilde(SemanticVersion), Any }

pub struct ModDependency { pub mod_id: String, pub version: VersionConstraint, pub optional: bool, pub condition: Option<String> }

pub struct ModFile { pub path: String, pub source: String, pub size: u64, pub checksum: String, pub install_type: InstallType, pub condition: Option<String> }
pub enum InstallType { Copy, Symlink, Patch, Merge }

pub struct InstallScript { pub phase: InstallPhase, pub interpreter: String, pub content: String, pub timeout_ms: u64 }
pub enum InstallPhase { PreInstall, PostInstall, PreUninstall, PostUninstall, PreEnable, PostEnable, PreDisable, PostDisable }

impl ModPackage {
    pub fn validate(&self) -> Vec<ValidationError> {
        let mut errors = Vec::new();
        if self.id.is_empty() { errors.push(ValidationError::new("id", "Mod ID cannot be empty")); }
        if !self.id.chars().all(|c| c.is_ascii_alphanumeric() || c == '-' || c == '_') { errors.push(ValidationError::new("id", "Mod ID contains invalid characters")); }
        if self.name.is_empty() { errors.push(ValidationError::new("name", "Mod name cannot be empty")); }
        if self.author.is_empty() { errors.push(ValidationError::new("author", "Author cannot be empty")); }
        if self.files.is_empty() { errors.push(ValidationError::new("files", "Mod must contain at least one file")); }
        for (i, file) in self.files.iter().enumerate() {
            if file.path.is_empty() { errors.push(ValidationError::new(&format!("files[{}].path", i), "File path cannot be empty")); }
            if file.path.contains("..") { errors.push(ValidationError::new(&format!("files[{}].path", i), "File path cannot contain '..'")); }
        }
        for (i, dep) in self.dependencies.iter().enumerate() {
            if dep.mod_id.is_empty() { errors.push(ValidationError::new(&format!("dependencies[{}].mod_id", i), "Dependency mod ID cannot be empty")); }
            if dep.mod_id == self.id { errors.push(ValidationError::new(&format!("dependencies[{}].mod_id", i), "Mod cannot depend on itself")); }
        }
        errors
    }

    pub fn compute_checksum(&mut self) {
        let mut hasher = Sha256::new();
        hasher.update(self.id.as_bytes());
        hasher.update(self.version.to_string().as_bytes());
        for file in &self.files { hasher.update(file.path.as_bytes()); hasher.update(file.checksum.as_bytes()); }
        self.checksum = hasher.finalize_hex();
    }
}

pub struct ValidationError { pub field: String, pub message: String }
impl ValidationError { pub fn new(field: &str, message: &str) -> Self { Self { field: field.to_string(), message: message.to_string() } } }

// ═══════════════════════════════════════════════════════════════════════════════
// FOMOD INSTALLER
// ═══════════════════════════════════════════════════════════════════════════════

pub struct FomodConfig { pub module_name: String, pub install_steps: Vec<FomodStep>, pub required_files: Vec<FomodFileList>, pub conditional_installs: Vec<FomodConditional> }
pub struct FomodStep { pub name: String, pub groups: Vec<FomodGroup>, pub visible: Option<FomodCondition> }
pub struct FomodGroup { pub name: String, pub group_type: FomodGroupType, pub plugins: Vec<FomodPlugin> }
pub enum FomodGroupType { SelectExactlyOne, SelectAtMostOne, SelectAtLeastOne, SelectAny, SelectAll }
pub struct FomodPlugin { pub name: String, pub description: String, pub image: Option<String>, pub files: FomodFileList, pub flags: Vec<FomodFlag>, pub type_descriptor: FomodTypeDescriptor, pub condition: Option<FomodCondition> }
pub struct FomodFileList { pub files: Vec<FomodFile>, pub folders: Vec<FomodFolder> }
pub struct FomodFile { pub source: String, pub destination: String, pub priority: i32, pub always_install: bool, pub install_if_usable: bool }
pub struct FomodFolder { pub source: String, pub destination: String, pub priority: i32, pub always_install: bool }
pub struct FomodFlag { pub name: String, pub value: String }
pub struct FomodTypeDescriptor { pub default_type: FomodPluginType, pub dependency_type: Option<FomodPluginType> }
pub enum FomodPluginType { Required, Optional, Recommended, NotUsable, CouldBeUsable }
pub struct FomodCondition { pub operator: FomodConditionOp, pub conditions: Vec<FomodConditionItem> }
pub enum FomodConditionOp { And, Or }
pub enum FomodConditionItem { Flag { name: String, value: String }, File { path: String, state: FomodFileState }, Version { version: String, comparator: String } }
pub enum FomodFileState { Active, Inactive, Missing }
pub struct FomodConditional { pub condition: FomodCondition, pub files: FomodFileList }

pub struct FomodInstaller { pub config: FomodConfig, pub flags: HashMap<String, String>, pub selected_plugins: HashSet<String>, pub files_to_install: Vec<FomodFile> }

impl FomodInstaller {
    pub fn new(config: FomodConfig) -> Self { Self { config, flags: HashMap::new(), selected_plugins: HashSet::new(), files_to_install: Vec::new() } }

    pub fn set_flag(&mut self, name: &str, value: &str) { self.flags.insert(name.to_string(), value.to_string()); }

    pub fn evaluate_condition(&self, condition: &FomodCondition) -> bool {
        let results: Vec<bool> = condition.conditions.iter().map(|item| {
            match item {
                FomodConditionItem::Flag { name, value } => self.flags.get(name).map(|v| v == value).unwrap_or(false),
                FomodConditionItem::File { path, state } => match state { FomodFileState::Active => true, FomodFileState::Inactive => false, FomodFileState::Missing => false },
                FomodConditionItem::Version { .. } => true,
            }
        }).collect();
        return match condition.operator { FomodConditionOp::And => results.iter().all(|&b| b), FomodConditionOp::Or => results.iter().any(|&b| b) };
    }

    pub fn select_plugin(&mut self, step_idx: usize, group_idx: usize, plugin_idx: usize) -> Result<(), String> {
        let step = self.config.install_steps.get(step_idx).ok_or("Invalid step")?;
        let group = step.groups.get(group_idx).ok_or("Invalid group")?;
        let plugin = group.plugins.get(plugin_idx).ok_or("Invalid plugin")?;
        let key = format!("{}_{}_{}", step_idx, group_idx, plugin_idx);
        match group.group_type {
            FomodGroupType::SelectExactlyOne | FomodGroupType::SelectAtMostOne => {
                for i in 0..group.plugins.len() { self.selected_plugins.remove(&format!("{}_{}_{}", step_idx, group_idx, i)); }
            }
            _ => {}
        }
        self.selected_plugins.insert(key);
        for flag in &plugin.flags { self.set_flag(&flag.name, &flag.value); }
        Ok(())
    }

    pub fn validate_selections(&self) -> Vec<String> {
        let mut errors = Vec::new();
        for (step_idx, step) in self.config.install_steps.iter().enumerate() {
            if let Some(ref cond) = step.visible { if !self.evaluate_condition(cond) { continue; } }
            for (group_idx, group) in step.groups.iter().enumerate() {
                let mut count: i64 = 0;
                for i in 0..group.plugins.len() {
                    let key = format!("{}_{}_{}", step_idx, group_idx, i);
                    if self.selected_plugins.contains(&key) { count = count + 1; }
                }
                match group.group_type {
                    FomodGroupType::SelectExactlyOne => if count != 1 { errors.push(format!("Group '{}' requires exactly one selection", group.name)); },
                    FomodGroupType::SelectAtLeastOne => if count < 1 { errors.push(format!("Group '{}' requires at least one selection", group.name)); },
                    FomodGroupType::SelectAll => if count != group.plugins.len() { errors.push(format!("Group '{}' requires all options selected", group.name)); },
                    _ => {}
                }
            }
        }
        errors
    }

    pub fn compute_files(&mut self) {
        self.files_to_install.clear();
        for filelist in &self.config.required_files { for file in &filelist.files { self.files_to_install.push(file.clone()); } }
        for (step_idx, step) in self.config.install_steps.iter().enumerate() {
            for (group_idx, group) in step.groups.iter().enumerate() {
                for (plugin_idx, plugin) in group.plugins.iter().enumerate() {
                    let key = format!("{}_{}_{}", step_idx, group_idx, plugin_idx);
                    if self.selected_plugins.contains(&key) { for file in &plugin.files.files { self.files_to_install.push(file.clone()); } }
                }
            }
        }
        for cond in &self.config.conditional_installs { if self.evaluate_condition(&cond.condition) { for file in &cond.files.files { self.files_to_install.push(file.clone()); } } }
        self.files_to_install.sort_by(|a, b| a.priority.cmp(&b.priority));
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD REPOSITORY & DOWNLOAD MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SimpleModRepo { pub name: String, pub base_url: String, pub api_key: Option<String>, pub enabled: bool, pub priority: i32, pub cache: HashMap<String, CachedModInfo>, pub last_sync: u64 }
pub struct CachedModInfo { pub mod_id: String, pub name: String, pub version: String, pub author: String, pub description: String, pub downloads: u64, pub endorsements: u64, pub updated: u64, pub files: Vec<RemoteFile> }
pub struct RemoteFile { pub file_id: String, pub name: String, pub version: String, pub size: u64, pub primary: bool, pub download_url: Option<String> }

impl SimpleModRepo {
    pub fn new(name: &str, base_url: &str) -> Self { Self { name: name.to_string(), base_url: base_url.to_string(), api_key: None, enabled: true, priority: 0, cache: HashMap::new(), last_sync: 0 } }
    pub fn with_api_key(mut self, key: &str) -> Self { self.api_key = Some(key.to_string()); self }
    pub fn search(&self, query: &str) -> Vec<&CachedModInfo> { self.cache.values().filter(|m| m.name.to_lowercase().contains(&query.to_lowercase()) || m.description.to_lowercase().contains(&query.to_lowercase())).collect() }
    pub fn get_mod(&self, mod_id: &str) -> Option<&CachedModInfo> { self.cache.get(mod_id) }
}

pub struct DownloadManager {
    pub downloads: HashMap<String, Download>,
    pub queue: VecDeque<String>,
    pub active_limit: usize,
    pub download_path: String,
    pub bandwidth_limit: Option<u64>,
    pub retry_count: u32,
    pub retry_delay_ms: u64,
}

pub struct Download {
    pub id: String,
    pub url: String,
    pub destination: String,
    pub size: u64,
    pub downloaded: u64,
    pub status: DownloadStatus,
    pub speed_bps: u64,
    pub eta_seconds: u64,
    pub retries: u32,
    pub checksum: Option<String>,
    pub started: u64,
    pub completed: Option<u64>,
    pub error: Option<String>,
}

pub enum DownloadStatus { Queued, Downloading, Paused, Completed, Failed, Verifying, Extracting }

impl DownloadManager {
    pub fn new(download_path: &str) -> Self { Self { downloads: HashMap::new(), queue: VecDeque::new(), active_limit: 3, download_path: download_path.to_string(), bandwidth_limit: None, retry_count: 3, retry_delay_ms: 5000 } }

    pub fn add(&mut self, url: &str, filename: &str, size: u64, checksum: Option<&str>) -> String {
        let id = format!("dl_{}", self.downloads.len());
        let destination = format!("{}/{}", self.download_path, filename);
        let download = Download { id: id.clone(), url: url.to_string(), destination, size, downloaded: 0, status: DownloadStatus::Queued, speed_bps: 0, eta_seconds: 0, retries: 0, checksum: checksum.map(|s| s.to_string()), started: 0, completed: None, error: None };
        self.downloads.insert(id.clone(), download);
        self.queue.push_back(id.clone());
        id
    }

    pub fn pause(&mut self, id: &str) -> bool { if let Some(dl) = self.downloads.get_mut(id) { if matches!(dl.status, DownloadStatus::Downloading) { dl.status = DownloadStatus::Paused; return true; } } return false; }
    pub fn resume(&mut self, id: &str) -> bool { if let Some(dl) = self.downloads.get_mut(id) { if matches!(dl.status, DownloadStatus::Paused) { dl.status = DownloadStatus::Queued; self.queue.push_back(id.to_string()); return true; } } return false; }
    pub fn cancel(&mut self, id: &str) -> bool { let removed = self.downloads.remove(id); return removed.is_some(); }
    pub fn retry(&mut self, id: &str) -> bool { if let Some(dl) = self.downloads.get_mut(id) { if matches!(dl.status, DownloadStatus::Failed) { dl.status = DownloadStatus::Queued; dl.retries += 1; dl.error = None; self.queue.push_back(id.to_string()); return true; } } return false; }

    pub fn active_count(&self) -> usize { self.downloads.values().filter(|d| matches!(d.status, DownloadStatus::Downloading)).count() }
    pub fn total_progress(&self) -> (u64, u64) { self.downloads.values().fold((0, 0), |(d, t), dl| (d + dl.downloaded, t + dl.size)) }
    pub fn overall_speed(&self) -> u64 { self.downloads.values().filter(|d| matches!(d.status, DownloadStatus::Downloading)).map(|d| d.speed_bps).sum() }

    pub fn update_progress(&mut self, id: &str, downloaded: u64, speed: u64) {
        if let Some(dl) = self.downloads.get_mut(id) {
            dl.downloaded = downloaded;
            dl.speed_bps = speed;
            dl.eta_seconds = if speed > 0 { (dl.size - downloaded) / speed } else { 0 };
            if downloaded >= dl.size { dl.status = DownloadStatus::Verifying; }
        }
    }

    pub fn complete(&mut self, id: &str, success: bool, error: Option<&str>) {
        if let Some(dl) = self.downloads.get_mut(id) {
            if success { dl.status = DownloadStatus::Completed; dl.completed = Some(0); }
            else { dl.status = DownloadStatus::Failed; dl.error = error.map(|s| s.to_string()); }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLUGIN RECORDS & DATA PATCHING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct PluginFile { pub filename: String, pub master_flag: bool, pub light_flag: bool, pub author: String, pub description: String, pub masters: Vec<String>, pub groups: Vec<RecordGroup>, pub header: PluginHeader }
pub struct PluginHeader { pub version: f32, pub num_records: u32, pub next_object_id: u32, pub flags: u32 }
pub struct RecordGroup { pub group_type: GroupType, pub label: [u8; 4], pub timestamp: u16, pub version: u16, pub records: Vec<Record> }
pub enum GroupType { Top, WorldChildren, InteriorCell, InteriorSubCell, ExteriorCell, ExteriorSubCell, CellChildren, TopicChildren, CellPersistent, CellTemporary }
pub struct Record { pub record_type: [u8; 4], pub size: u32, pub flags: u32, pub form_id: u32, pub timestamp: u16, pub version: u16, pub subrecords: Vec<Subrecord> }
pub struct Subrecord { pub subrecord_type: [u8; 4], pub size: u16, pub data: Vec<u8> }

impl Record {
    pub fn is_deleted(&self) -> bool { self.flags & 0x20 != 0 }
    pub fn is_ignored(&self) -> bool { self.flags & 0x1000 != 0 }
    pub fn is_compressed(&self) -> bool { self.flags & 0x40000 != 0 }
    pub fn type_string(&self) -> String { String::from_utf8_lossy(&self.record_type).to_string() }
    pub fn get_subrecord(&self, subtype: &[u8; 4]) -> Option<&Subrecord> { self.subrecords.iter().find(|s| &s.subrecord_type == subtype) }
    pub fn get_all_subrecords(&self, subtype: &[u8; 4]) -> Vec<&Subrecord> { self.subrecords.iter().filter(|s| &s.subrecord_type == subtype).collect() }
}

pub struct RecordPatch { pub plugin: String, pub form_id: u32, pub operations: Vec<PatchOperation> }
pub enum PatchOperation { SetSubrecord { subtype: [u8; 4], data: Vec<u8> }, DeleteSubrecord { subtype: [u8; 4], index: Option<u32> }, AppendSubrecord { subtype: [u8; 4], data: Vec<u8> }, ModifyFlags { set: u32, clear: u32 }, DeleteRecord, ForwardRecord { from_plugin: String } }

pub struct PatchEngine { pub patches: Vec<RecordPatch>, pub forward_map: HashMap<u32, String> }

impl PatchEngine {
    pub fn new() -> Self { Self { patches: Vec::new(), forward_map: HashMap::new() } }
    pub fn add_patch(&mut self, patch: RecordPatch) { self.patches.push(patch); }

    pub fn apply(&self, record: &mut Record, plugin: &str) -> bool {
        let mut modified = false;
        for patch in self.patches.iter().filter(|p| p.plugin == plugin && p.form_id == record.form_id) {
            for op in &patch.operations {
                match op {
                    PatchOperation::SetSubrecord { subtype, data } => {
                        if let Some(sub) = record.subrecords.iter_mut().find(|s| &s.subrecord_type == subtype) { sub.data = data.clone(); sub.size = data.len() as u16; }
                        else { record.subrecords.push(Subrecord { subrecord_type: *subtype, size: data.len() as u16, data: data.clone() }); }
                        modified = true;
                    }
                    PatchOperation::DeleteSubrecord { subtype, index } => {
                        match index {
                            Some(i) => { let matching: Vec<usize> = record.subrecords.iter().enumerate().filter(|(_, s)| &s.subrecord_type == subtype).map(|(i, _)| i).collect(); if let Some(&idx) = matching.get(*i as usize) { record.subrecords.remove(idx); modified = true; } }
                            None => { record.subrecords.retain(|s| &s.subrecord_type != subtype); modified = true; }
                        }
                    }
                    PatchOperation::AppendSubrecord { subtype, data } => { record.subrecords.push(Subrecord { subrecord_type: *subtype, size: data.len() as u16, data: data.clone() }); modified = true; }
                    PatchOperation::ModifyFlags { set, clear } => { record.flags = (record.flags | set) & !clear; modified = true; }
                    PatchOperation::DeleteRecord => { record.flags |= 0x20; modified = true; }
                    PatchOperation::ForwardRecord { .. } => {}
                }
            }
        }
        modified
    }

    pub fn generate_patch_plugin(&self, name: &str, masters: &[&str]) -> PluginFile {
        PluginFile {
            filename: format!("{}.esp", name),
            master_flag: false,
            light_flag: true,
            author: "Generated".to_string(),
            description: format!("Auto-generated patch: {}", name),
            masters: masters.iter().map(|s| s.to_string()).collect(),
            groups: Vec::new(),
            header: PluginHeader { version: 1.0, num_records: 0, next_object_id: 0x800, flags: 0 }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BASHED PATCH GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct BashPatchBuilder { pub name: String, pub masters: Vec<String>, pub merged_lists: HashMap<u32, MergedList>, pub merged_records: HashMap<u32, MergedRecord>, pub tags: HashMap<String, Vec<BashTag>> }
pub struct MergedList { pub form_id: u32, pub list_type: [u8; 4], pub entries: Vec<ListEntry>, pub sources: Vec<String> }
pub struct ListEntry { pub form_id: u32, pub level: Option<u16>, pub count: Option<u16>, pub source: String }
pub struct MergedRecord { pub form_id: u32, pub record_type: [u8; 4], pub subrecords: HashMap<[u8; 4], MergedSubrecord> }
pub struct MergedSubrecord { pub data: Vec<u8>, pub sources: Vec<String>, pub priority: i32 }
pub enum BashTag { Delev, Relev, Names, Stats, Graphics, Sound, Actors, Factions, Relations, Invent, Scripts, Enchant, SpellStats }

impl BashPatchBuilder {
    pub fn new(name: &str) -> Self { Self { name: name.to_string(), masters: Vec::new(), merged_lists: HashMap::new(), merged_records: HashMap::new(), tags: HashMap::new() } }

    pub fn add_master(&mut self, master: &str) { if !self.masters.contains(&master.to_string()) { self.masters.push(master.to_string()); } }

    pub fn add_list_entry(&mut self, form_id: u32, list_type: [u8; 4], entry_form_id: u32, level: Option<u16>, count: Option<u16>, source: &str) {
        let list = self.merged_lists.entry(form_id).or_insert_with(|| MergedList { form_id, list_type, entries: Vec::new(), sources: Vec::new() });
        if !list.entries.iter().any(|e| e.form_id == entry_form_id) { list.entries.push(ListEntry { form_id: entry_form_id, level, count, source: source.to_string() }); }
        if !list.sources.contains(&source.to_string()) { list.sources.push(source.to_string()); }
    }

    pub fn remove_list_entry(&mut self, form_id: u32, entry_form_id: u32) {
        if let Some(list) = self.merged_lists.get_mut(&form_id) { list.entries.retain(|e| e.form_id != entry_form_id); }
    }

    pub fn merge_subrecord(&mut self, form_id: u32, record_type: [u8; 4], subtype: [u8; 4], data: Vec<u8>, source: &str, priority: i32) {
        let record = self.merged_records.entry(form_id).or_insert_with(|| MergedRecord { form_id, record_type, subrecords: HashMap::new() });
        let sub = record.subrecords.entry(subtype).or_insert_with(|| MergedSubrecord { data: Vec::new(), sources: Vec::new(), priority: 0 });
        if priority >= sub.priority { sub.data = data; sub.priority = priority; }
        if !sub.sources.contains(&source.to_string()) { sub.sources.push(source.to_string()); }
    }

    pub fn set_tags(&mut self, plugin: &str, tags: Vec<BashTag>) { self.tags.insert(plugin.to_string(), tags); }

    pub fn has_tag(&self, plugin: &str, tag: &BashTag) -> bool {
        self.tags.get(plugin).map(|tags| tags.iter().any(|t| std::mem::discriminant(t) == std::mem::discriminant(tag))).unwrap_or(false)
    }

    pub fn build(&self) -> PluginFile {
        PluginFile {
            filename: format!("{}.esp", self.name),
            master_flag: false,
            light_flag: false,
            author: "Bashed Patch".to_string(),
            description: format!("Merged patch from {} masters", self.masters.len()),
            masters: self.masters.clone(),
            groups: Vec::new(),
            header: PluginHeader { version: 1.0, num_records: (self.merged_lists.len() + self.merged_records.len()) as u32, next_object_id: 0x800, flags: 0 }
        }
    }

    pub fn stats(&self) -> (usize, usize, usize) { (self.masters.len(), self.merged_lists.len(), self.merged_records.len()) }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD ORGANIZER INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ModOrganizerProfile { pub name: String, pub game_name: String, pub base_directory: String, pub mods_directory: String, pub overwrite_directory: String, pub profiles_directory: String, pub ini_files: Vec<IniOverride>, pub mod_list: Vec<ModListEntry>, pub plugin_list: Vec<PluginListEntry>, pub local_saves: bool, pub local_settings: bool }
pub struct IniOverride { pub filename: String, pub section: String, pub key: String, pub value: String }
pub struct ModListEntry { pub name: String, pub enabled: bool, pub priority: i32, pub notes: Option<String>, pub nexus_id: Option<u32>, pub version: Option<String> }
pub struct PluginListEntry { pub filename: String, pub enabled: bool, pub priority: i32 }

impl ModOrganizerProfile {
    pub fn new(name: &str, game: &str, base_dir: &str) -> Self {
        Self {
            name: name.to_string(), game_name: game.to_string(), base_directory: base_dir.to_string(),
            mods_directory: format!("{}/mods", base_dir), overwrite_directory: format!("{}/overwrite", base_dir),
            profiles_directory: format!("{}/profiles", base_dir), ini_files: Vec::new(),
            mod_list: Vec::new(), plugin_list: Vec::new(), local_saves: true, local_settings: true
        }
    }

    pub fn add_mod(&mut self, name: &str, enabled: bool) -> usize {
        let priority = self.mod_list.len() as i32;
        self.mod_list.push(ModListEntry { name: name.to_string(), enabled, priority, notes: None, nexus_id: None, version: None });
        priority as usize
    }

    pub fn set_mod_priority(&mut self, name: &str, new_priority: i32) {
        if let Some(entry) = self.mod_list.iter_mut().find(|e| e.name == name) {
            let old = entry.priority;
            for e in &mut self.mod_list {
                if e.priority > old && e.priority <= new_priority { e.priority -= 1; }
                else if e.priority < old && e.priority >= new_priority { e.priority += 1; }
            }
            entry.priority = new_priority;
        }
        self.mod_list.sort_by_key(|e| e.priority);
    }

    pub fn export_modlist(&self) -> String {
        let mut s = String::from("# Mod Organizer Modlist\n");
        let mut sorted = self.mod_list.clone();
        sorted.sort_by_key(|e| e.priority);
        for entry in sorted { s.push_str(&format!("{}{}\n", if entry.enabled { "+" } else { "-" }, entry.name)); }
        s
    }

    pub fn export_plugins(&self) -> String {
        let mut s = String::from("# Plugin List\n");
        let mut sorted = self.plugin_list.clone();
        sorted.sort_by_key(|e| e.priority);
        for entry in sorted { s.push_str(&format!("{}{}\n", if entry.enabled { "*" } else { "" }, entry.filename)); }
        s
    }

    pub fn parse_modlist(content: &str) -> Vec<ModListEntry> {
        content.lines().filter(|l| !l.starts_with('#') && !l.trim().is_empty()).enumerate().map(|(i, line)| {
            let enabled = line.starts_with('+');
            let name = line.trim_start_matches(|c| c == '+' || c == '-').trim().to_string();
            ModListEntry { name, enabled, priority: i as i32, notes: None, nexus_id: None, version: None }
        }).collect()
    }
}

