// MOD REPOSITORY
// ═══════════════════════════════════════════════════════════════════════════════

/// Remote mod repository
pub struct ModRepository {
    pub name: String,
    pub url: String,
    pub api_version: u32,
    cached_index: Option<Vec<ModMetadata>>,
}

impl ModRepository {
    pub fn new(name: &str, url: &str) -> Self {
        ModRepository {
            name: name.to_string(),
            url: url.to_string(),
            api_version: 1,
            cached_index: None,
        }
    }
    
    /// Search for mods
    pub fn search(&self, query: &str, category: Option<ModCategory>) -> Vec<ModMetadata> {
        // Would actually query the remote repository
        Vec::new()
    }
    
    /// Download a mod
    pub fn download(&self, mod_id: &str, version: Option<Version>) -> Result<ModPackage, RepositoryError> {
        // Would actually download from repository
        Err(RepositoryError::NotFound(mod_id.to_string()))
    }
}

#[derive(Debug)]
pub enum RepositoryError {
    NetworkError(String),
    NotFound(String),
    VersionNotFound(String, Version),
    Unauthorized,
    RateLimited,
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIRTUAL FILE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Virtual file entry - represents a file overlay
#[derive(Debug, Clone)]
pub struct VirtualFile {
    pub original_path: String,
    pub mod_path: String,
    pub mod_id: String,
    pub priority: i32,
    pub file_size: u64,
    pub hash: String,
}

/// Virtual File System - non-destructive file replacement
pub struct VirtualFileSystem {
    overlays: HashMap<String, Vec<VirtualFile>>,
    backup_dir: String,
    hooks_installed: bool,
}

impl VirtualFileSystem {
    pub fn new(backup_dir: &str) -> Self {
        VirtualFileSystem {
            overlays: HashMap::new(),
            backup_dir: backup_dir.to_string(),
            hooks_installed: false,
        }
    }

    /// Add a file overlay
    pub fn add_overlay(&mut self, original: &str, vfile: VirtualFile) {
        let normalized = self.normalize_path(original);
        self.overlays.entry(normalized)
            .or_insert_with(Vec::new)
            .push(vfile);

        // Sort by priority (higher first)
        if let Some(overlays) = self.overlays.get_mut(&self.normalize_path(original)) {
            overlays.sort_by(|a, b| b.priority.cmp(&a.priority));
        }
    }

    /// Remove all overlays for a mod
    pub fn remove_mod_overlays(&mut self, mod_id: &str) {
        for overlays in self.overlays.values_mut() {
            overlays.retain(|o| o.mod_id != mod_id);
        }
        self.overlays.retain(|_, v| !v.is_empty());
    }

    /// Resolve a file path to its virtual replacement
    pub fn resolve(&self, path: &str) -> Option<&str> {
        let normalized = self.normalize_path(path);
        self.overlays.get(&normalized)
            .and_then(|o| o.first())
            .map(|o| o.mod_path.as_str())
    }

    /// Get all overlays for a path
    pub fn get_overlays(&self, path: &str) -> &[VirtualFile] {
        let normalized = self.normalize_path(path);
        self.overlays.get(&normalized)
            .map(|v| v.as_slice())
            .unwrap_or(&[])
    }

    /// Install file system hooks
    pub fn install_hooks(&mut self) -> Result<(), VFSError> {
        if self.hooks_installed {
            return Ok(());
        }

        // Hook CreateFileW, ReadFile, etc.
        // In practice, would use detours or inline hooks
        self.hooks_installed = true;
        Ok(())
    }

    fn normalize_path(&self, path: &str) -> String {
        path.to_lowercase().replace('/', "\\")
    }

    /// Get statistics
    pub fn stats(&self) -> VFSStats {
        let total_files = self.overlays.len();
        let total_overlays: usize = self.overlays.values().map(|v| v.len()).sum();

        VFSStats {
            total_files,
            total_overlays,
            hooks_installed: self.hooks_installed,
        }
    }
}

#[derive(Debug, Clone)]
pub struct VFSStats {
    pub total_files: usize,
    pub total_overlays: usize,
    pub hooks_installed: bool,
}

#[derive(Debug)]
pub enum VFSError {
    HookFailed(String),
    PathNotFound(String),
    PermissionDenied,
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEMORY PATCH SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Memory patch types
#[derive(Debug, Clone)]
pub enum PatchType {
    /// Replace bytes at address
    BytePatch { address: usize, original: Vec<u8>, patched: Vec<u8> },
    /// JMP hook - redirect execution
    JmpHook { address: usize, target: usize, original: Vec<u8> },
    /// CALL hook - intercept function calls
    CallHook { address: usize, target: usize, original: Vec<u8> },
    /// VTable hook - replace virtual function
    VTableHook { vtable: usize, index: usize, target: usize, original: usize },
    /// IAT hook - import address table
    IATHook { module: String, function: String, target: usize, original: usize },
    /// NOP slide - replace with NOPs
    NopSlide { address: usize, length: usize, original: Vec<u8> },
}

/// A memory patch with metadata
#[derive(Debug, Clone)]
pub struct MemoryPatch {
    pub id: String,
    pub mod_id: String,
    pub description: String,
    pub patch_type: PatchType,
    pub applied: bool,
    pub conditional: Option<String>,  // Only apply if condition matches
}

impl MemoryPatch {
    pub fn new(id: &str, mod_id: &str, patch_type: PatchType) -> Self {
        MemoryPatch {
            id: id.to_string(),
            mod_id: mod_id.to_string(),
            description: String::new(),
            patch_type,
            applied: false,
            conditional: None,
        }
    }
}

/// Memory Patch Manager
pub struct PatchManager {
    patches: HashMap<String, MemoryPatch>,
    applied_order: Vec<String>,
}

impl PatchManager {
    pub fn new() -> Self {
        PatchManager {
            patches: HashMap::new(),
            applied_order: Vec::new(),
        }
    }

    /// Register a patch
    pub fn register(&mut self, patch: MemoryPatch) {
        self.patches.insert(patch.id.clone(), patch);
    }

    /// Apply a patch
    pub fn apply(&mut self, patch_id: &str) -> Result<(), PatchError> {
        let patch = self.patches.get_mut(patch_id)
            .ok_or(PatchError::NotFound(patch_id.to_string()))?;

        if patch.applied {
            return Ok(());
        }

        // Apply based on type
        match &patch.patch_type {
            PatchType::BytePatch { address, patched, .. } => {
                unsafe {
                    self.write_memory(*address, patched)?;
                }
            }
            PatchType::JmpHook { address, target, .. } => {
                self.install_jmp_hook(*address, *target)?;
            }
            PatchType::CallHook { address, target, .. } => {
                self.install_call_hook(*address, *target)?;
            }
            PatchType::VTableHook { vtable, index, target, .. } => {
                self.install_vtable_hook(*vtable, *index, *target)?;
            }
            PatchType::IATHook { module, function, target, .. } => {
                self.install_iat_hook(module, function, *target)?;
            }
            PatchType::NopSlide { address, length, .. } => {
                let nops = vec![0x90u8; *length];
                unsafe {
                    self.write_memory(*address, &nops)?;
                }
            }
        }

        patch.applied = true;
        self.applied_order.push(patch_id.to_string());
        Ok(())
    }

    /// Revert a patch
    pub fn revert(&mut self, patch_id: &str) -> Result<(), PatchError> {
        let patch = self.patches.get_mut(patch_id)
            .ok_or(PatchError::NotFound(patch_id.to_string()))?;

        if !patch.applied {
            return Ok(());
        }

        // Revert based on type
        match &patch.patch_type {
            PatchType::BytePatch { address, original, .. } => {
                unsafe {
                    self.write_memory(*address, original)?;
                }
            }
            PatchType::JmpHook { address, original, .. } => {
                unsafe {
                    self.write_memory(*address, original)?;
                }
            }
            PatchType::CallHook { address, original, .. } => {
                unsafe {
                    self.write_memory(*address, original)?;
                }
            }
            PatchType::VTableHook { vtable, index, original, .. } => {
                self.install_vtable_hook(*vtable, *index, *original)?;
            }
            PatchType::IATHook { module, function, original, .. } => {
                self.install_iat_hook(module, function, *original)?;
            }
            PatchType::NopSlide { address, original, .. } => {
                unsafe {
                    self.write_memory(*address, original)?;
                }
            }
            _ => {}
        }

        patch.applied = false;
        self.applied_order.retain(|id| id != patch_id);
        Ok(())
    }

    /// Revert all patches in reverse order
    pub fn revert_all(&mut self) -> Vec<PatchError> {
        let mut errors = Vec::new();

        let order: Vec<String> = self.applied_order.iter().rev().cloned().collect();
        for patch_id in order {
            if let Err(e) = self.revert(&patch_id) {
                errors.push(e);
            }
        }

        errors
    }

    /// Remove all patches for a mod
    pub fn remove_mod_patches(&mut self, mod_id: &str) -> Vec<PatchError> {
        let mut errors = Vec::new();

        let mod_patches: Vec<String> = self.patches.iter()
            .filter(|(_, p)| p.mod_id == mod_id && p.applied)
            .map(|(id, _)| id.clone())
            .collect();

        for patch_id in mod_patches {
            if let Err(e) = self.revert(&patch_id) {
                errors.push(e);
            }
        }

        self.patches.retain(|_, p| p.mod_id != mod_id);
        errors
    }

    unsafe fn write_memory(&self, address: usize, data: &[u8]) -> Result<(), PatchError> {
        // Would use VirtualProtect + memcpy on Windows
        // This is a placeholder
        Ok(())
    }

    fn install_jmp_hook(&self, address: usize, target: usize) -> Result<(), PatchError> {
        // E9 xx xx xx xx - relative JMP
        let offset = (target as isize - address as isize - 5) as i32;
        let mut bytes = vec![0xE9u8];
        bytes.extend_from_slice(&offset.to_le_bytes());
        unsafe { self.write_memory(address, &bytes) }
    }

    fn install_call_hook(&self, address: usize, target: usize) -> Result<(), PatchError> {
        // E8 xx xx xx xx - relative CALL
        let offset = (target as isize - address as isize - 5) as i32;
        let mut bytes = vec![0xE8u8];
        bytes.extend_from_slice(&offset.to_le_bytes());
        unsafe { self.write_memory(address, &bytes) }
    }

    fn install_vtable_hook(&self, vtable: usize, index: usize, target: usize) -> Result<(), PatchError> {
        let ptr_size: usize = 8; // size_of::<usize>() on 64-bit
        let address = vtable + index * ptr_size;
        unsafe { self.write_memory(address, &target.to_le_bytes()) }
    }

    fn install_iat_hook(&self, _module: &str, _function: &str, _target: usize) -> Result<(), PatchError> {
        // Would walk PE import table
        Ok(())
    }
}

#[derive(Debug)]
pub enum PatchError {
    NotFound(String),
    MemoryProtection(usize),
    InvalidAddress(usize),
    AlreadyApplied(String),
    HookTooSmall(usize),
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE WATCHER (Hot Reload Support)
// ═══════════════════════════════════════════════════════════════════════════════

/// File change event
#[derive(Debug, Clone)]
pub struct FileChangeEvent {
    pub path: String,
    pub event_type: FileEventType,
    pub timestamp: u64,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum FileEventType {
    Created,
    Modified,
    Deleted,
    Renamed,
}

/// File watcher for hot reload
pub struct FileWatcher {
    watched_dirs: HashMap<String, WatchedDirectory>,
    debounce_ms: u64,
    pending_events: Vec<FileChangeEvent>,
    callback: Option<Box<dyn Fn(&FileChangeEvent) + Send + Sync>>,
}

struct WatchedDirectory {
    path: String,
    recursive: bool,
    filter: Vec<String>,  // File extensions to watch
    last_scan: HashMap<String, u64>,  // path -> mtime
}

impl FileWatcher {
    pub fn new(debounce_ms: u64) -> Self {
        FileWatcher {
            watched_dirs: HashMap::new(),
            debounce_ms,
            pending_events: Vec::new(),
            callback: None,
        }
    }

    /// Watch a directory for changes
    pub fn watch(&mut self, path: &str, recursive: bool, extensions: &[&str]) {
        self.watched_dirs.insert(path.to_string(), WatchedDirectory {
            path: path.to_string(),
            recursive,
            filter: extensions.iter().map(|s| s.to_string()).collect(),
            last_scan: HashMap::new(),
        });
    }

    /// Stop watching a directory
    pub fn unwatch(&mut self, path: &str) {
        self.watched_dirs.remove(path);
    }

    /// Set callback for file changes
    pub fn on_change<F>(&mut self, callback: F)
    where
        F: Fn(&FileChangeEvent) + Send + Sync + 'static,
    {
        self.callback = Some(Box::new(callback));
    }

    /// Poll for changes (would be called periodically)
    pub fn poll(&mut self) -> Vec<FileChangeEvent> {
        // Would scan directories and compare mtimes
        std::mem::take(&mut self.pending_events)
    }

    /// Process a detected change
    fn process_change(&mut self, event: FileChangeEvent) {
        self.pending_events.push(event.clone());

        if let Some(ref callback) = self.callback {
            callback(&event);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD MERGER
// ═══════════════════════════════════════════════════════════════════════════════

/// Merge strategy for conflicting changes
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum MergeStrategy {
    /// Use the higher priority mod's version
    Priority,
    /// Attempt to merge changes
    AutoMerge,
    /// Keep both (for additive content)
    Additive,
    /// Ask user
    Interactive,
}

/// Result of a merge operation
#[derive(Debug)]
pub enum FileMergeResult {
    Success(Vec<u8>),
    Conflict(MergeConflict),
    Failed(String),
}

#[derive(Debug)]
pub struct MergeConflict {
    pub file_path: String,
    pub mod_a: String,
    pub mod_b: String,
    pub diff_a: Vec<u8>,
    pub diff_b: Vec<u8>,
}

/// Mod file merger for compatible changes
pub struct ModMerger {
    strategy: MergeStrategy,
}

impl ModMerger {
    pub fn new(strategy: MergeStrategy) -> Self {
        ModMerger { strategy }
    }

    /// Merge two versions of a file
    pub fn merge(&self, original: &[u8], version_a: &[u8], version_b: &[u8]) -> FileMergeResult {
        match self.strategy {
            MergeStrategy::Priority => {
                // Just use version_a (higher priority)
                FileMergeResult::Success(version_a.to_vec())
            }
            MergeStrategy::AutoMerge => {
                self.three_way_merge(original, version_a, version_b)
            }
            MergeStrategy::Additive => {
                // Concatenate changes
                let mut result = version_a.to_vec();
                result.extend_from_slice(version_b);
                FileMergeResult::Success(result)
            }
            MergeStrategy::Interactive => {
                let conflict = MergeConflict {
                    file_path: String::new(),
                    mod_a: String::new(),
                    mod_b: String::new(),
                    diff_a: version_a.to_vec(),
                    diff_b: version_b.to_vec(),
                };
                FileMergeResult::Conflict(conflict)
            }
        }
    }

    /// Three-way merge algorithm
    fn three_way_merge(&self, original: &[u8], version_a: &[u8], version_b: &[u8]) -> FileMergeResult {
        // Compute diffs
        let diff_a = self.compute_diff(original, version_a);
        let diff_b = self.compute_diff(original, version_b);

        // Check for overlapping changes
        if self.diffs_overlap(&diff_a, &diff_b) {
            let conflict = MergeConflict {
                file_path: String::new(),
                mod_a: String::new(),
                mod_b: String::new(),
                diff_a: version_a.to_vec(),
                diff_b: version_b.to_vec(),
            };
            return FileMergeResult::Conflict(conflict);
        }

        // Apply both diffs
        let mut result = original.to_vec();
        self.apply_diff(&mut result, &diff_a);
        self.apply_diff(&mut result, &diff_b);

        FileMergeResult::Success(result)
    }

    fn compute_diff(&self, original: &[u8], modified: &[u8]) -> Vec<DiffHunk> {
        // Simple LCS-based diff
        let mut hunks = Vec::new();

        let mut i = 0;
        let mut j = 0;

        while i < original.len() && j < modified.len() {
            if original[i] == modified[j] {
                i += 1;
                j += 1;
            } else {
                // Found a difference
                let start = i;
                while i < original.len() && j < modified.len() && original[i] != modified[j] {
                    i += 1;
                    j += 1;
                }
                hunks.push(DiffHunk {
                    original_start: start,
                    original_len: i - start,
                    modified_data: modified[start..j].to_vec(),
                });
            }
        }

        // Handle remaining bytes
        if j < modified.len() {
            hunks.push(DiffHunk {
                original_start: i,
                original_len: 0,
                modified_data: modified[j..].to_vec(),
            });
        }

        hunks
    }

    fn diffs_overlap(&self, diff_a: &[DiffHunk], diff_b: &[DiffHunk]) -> bool {
        for hunk_a in diff_a {
            let a_end = hunk_a.original_start + hunk_a.original_len;
            for hunk_b in diff_b {
                let b_end = hunk_b.original_start + hunk_b.original_len;
                // Check for overlap
                if !(a_end <= hunk_b.original_start || b_end <= hunk_a.original_start) {
                    return true;
                }
            }
        }
        false
    }

    fn apply_diff(&self, data: &mut Vec<u8>, hunks: &[DiffHunk]) {
        // Apply in reverse order to preserve offsets
        let mut sorted_hunks: Vec<_> = hunks.iter().collect();
        sorted_hunks.sort_by(|a, b| b.original_start.cmp(&a.original_start));

        for hunk in sorted_hunks {
            let end = hunk.original_start + hunk.original_len;
            data.splice(hunk.original_start..end, hunk.modified_data.iter().cloned());
        }
    }
}

#[derive(Debug, Clone)]
struct DiffHunk {
    original_start: usize,
    original_len: usize,
    modified_data: Vec<u8>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASSET REDIRECTOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Asset type for redirection
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum AssetType {
    Texture,
    Model,
    Sound,
    Animation,
    Shader,
    Material,
    Localization,
    Script,
    Config,
    Level,
    Other,
}

/// Asset redirect entry
#[derive(Debug, Clone)]
pub struct AssetRedirect {
    pub asset_type: AssetType,
    pub original_id: String,
    pub redirect_path: String,
    pub mod_id: String,
    pub priority: i32,
    pub conditional: Option<AssetCondition>,
}

/// Condition for asset redirection
#[derive(Debug, Clone)]
pub struct AssetCondition {
    pub variable: String,
    pub operator: ConditionOp,
    pub value: String,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ConditionOp {
    Equals,
    NotEquals,
    GreaterThan,
    LessThan,
    Contains,
    Matches,  // Regex
}

/// Asset Redirector - intercepts asset loads
pub struct AssetRedirector {
    redirects: HashMap<(AssetType, String), Vec<AssetRedirect>>,
    variables: HashMap<String, String>,
    stats: AssetRedirectStats,
}

#[derive(Debug, Default, Clone)]
pub struct AssetRedirectStats {
    pub total_redirects: u64,
    pub cache_hits: u64,
    pub cache_misses: u64,
    pub failed_loads: u64,
}

impl AssetRedirector {
    pub fn new() -> Self {
        AssetRedirector {
            redirects: HashMap::new(),
            variables: HashMap::new(),
            stats: AssetRedirectStats::default(),
        }
    }

    /// Add an asset redirect
    pub fn add_redirect(&mut self, redirect: AssetRedirect) {
        let key = (redirect.asset_type, redirect.original_id.clone());
        self.redirects.entry(key)
            .or_insert_with(Vec::new)
            .push(redirect);

        // Sort by priority
        for redirects in self.redirects.values_mut() {
            redirects.sort_by(|a, b| b.priority.cmp(&a.priority));
        }
    }

    /// Remove all redirects for a mod
    pub fn remove_mod_redirects(&mut self, mod_id: &str) {
        for redirects in self.redirects.values_mut() {
            redirects.retain(|r| r.mod_id != mod_id);
        }
        self.redirects.retain(|_, v| !v.is_empty());
    }

    /// Resolve an asset to its redirect
    pub fn resolve(&mut self, asset_type: AssetType, asset_id: &str) -> Option<&str> {
        let key = (asset_type, asset_id.to_string());

        if let Some(redirects) = self.redirects.get(&key) {
            for redirect in redirects {
                if self.check_condition(&redirect.conditional) {
                    self.stats.total_redirects += 1;
                    return Some(&redirect.redirect_path);
                }
            }
        }

        None
    }

    /// Set a variable for conditional redirects
    pub fn set_variable(&mut self, name: &str, value: &str) {
        self.variables.insert(name.to_string(), value.to_string());
    }

    fn check_condition(&self, condition: &Option<AssetCondition>) -> bool {
        match condition {
            None => true,
            Some(cond) => {
                let var_value = self.variables.get(&cond.variable)
                    .map(|s| s.as_str())
                    .unwrap_or("");

                match cond.operator {
                    ConditionOp::Equals => var_value == cond.value,
                    ConditionOp::NotEquals => var_value != cond.value,
                    ConditionOp::GreaterThan => {
                        var_value.parse::<f64>().unwrap_or(0.0) > cond.value.parse::<f64>().unwrap_or(0.0)
                    }
                    ConditionOp::LessThan => {
                        var_value.parse::<f64>().unwrap_or(0.0) < cond.value.parse::<f64>().unwrap_or(0.0)
                    }
                    ConditionOp::Contains => var_value.contains(&cond.value),
                    ConditionOp::Matches => {
                        // Would use regex here
                        var_value.contains(&cond.value)
                    }
                }
            }
        }
    }

    pub fn stats(&self) -> &AssetRedirectStats {
        &self.stats
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE TRACKER
// ═══════════════════════════════════════════════════════════════════════════════

/// Performance metrics for a mod
#[derive(Debug, Clone, Default)]
pub struct ModPerformanceMetrics {
    pub load_time_ms: f64,
    pub memory_usage_bytes: u64,
    pub frame_time_impact_us: f64,
    pub hook_overhead_us: f64,
    pub asset_load_count: u64,
    pub asset_load_time_ms: f64,
    pub error_count: u64,
    pub last_error: Option<String>,
}

/// Performance tracker for all mods
pub struct PerformanceTracker {
    metrics: HashMap<String, ModPerformanceMetrics>,
    baseline_frame_time: f64,
    frame_samples: Vec<f64>,
    sample_limit: usize,
}

impl PerformanceTracker {
    pub fn new(sample_limit: usize) -> Self {
        PerformanceTracker {
            metrics: HashMap::new(),
            baseline_frame_time: 0.0,
            frame_samples: Vec::with_capacity(sample_limit),
            sample_limit,
        }
    }

    /// Record mod load time
    pub fn record_load(&mut self, mod_id: &str, load_time_ms: f64) {
        self.metrics.entry(mod_id.to_string())
            .or_default()
            .load_time_ms = load_time_ms;
    }

    /// Record memory usage
    pub fn record_memory(&mut self, mod_id: &str, bytes: u64) {
        self.metrics.entry(mod_id.to_string())
            .or_default()
            .memory_usage_bytes = bytes;
    }

    /// Record a frame sample
    pub fn record_frame(&mut self, frame_time_us: f64) {
        if self.frame_samples.len() >= self.sample_limit {
            self.frame_samples.remove(0);
        }
        self.frame_samples.push(frame_time_us);
    }

    /// Set baseline (no mods) frame time
    pub fn set_baseline(&mut self, frame_time_us: f64) {
        self.baseline_frame_time = frame_time_us;
    }

    /// Calculate total mod overhead
    pub fn total_overhead(&self) -> f64 {
        if self.frame_samples.is_empty() {
            return 0.0;
        }

        let avg: f64 = self.frame_samples.iter().sum::<f64>() / self.frame_samples.len() as f64;
        (avg - self.baseline_frame_time).max(0.0)
    }

    /// Get metrics for a mod
    pub fn get_metrics(&self, mod_id: &str) -> Option<&ModPerformanceMetrics> {
        self.metrics.get(mod_id)
    }

    /// Get all metrics sorted by impact
    pub fn get_all_sorted(&self) -> Vec<(&String, &ModPerformanceMetrics)> {
        let mut sorted: Vec<_> = self.metrics.iter().collect();
        sorted.sort_by(|a, b| {
            b.1.frame_time_impact_us.partial_cmp(&a.1.frame_time_impact_us)
                .unwrap_or(std::cmp::Ordering::Equal)
        });
        sorted
    }

    /// Generate performance report
    pub fn generate_report(&self) -> PerformanceReport {
        let total_memory: u64 = self.metrics.values().map(|m| m.memory_usage_bytes).sum();
        let total_load_time: f64 = self.metrics.values().map(|m| m.load_time_ms).sum();
        let avg_frame = if self.frame_samples.is_empty() {
            0.0
        } else {
            self.frame_samples.iter().sum::<f64>() / self.frame_samples.len() as f64
        };

        PerformanceReport {
            total_mods: self.metrics.len(),
            total_memory_mb: total_memory as f64 / (1024.0 * 1024.0),
            total_load_time_ms: total_load_time,
            baseline_frame_time_us: self.baseline_frame_time,
            current_frame_time_us: avg_frame,
            overhead_us: self.total_overhead(),
            overhead_percent: if self.baseline_frame_time > 0.0 {
                self.total_overhead() / self.baseline_frame_time * 100.0
            } else {
                0.0
            },
        }
    }
}

#[derive(Debug, Clone)]
pub struct PerformanceReport {
    pub total_mods: usize,
    pub total_memory_mb: f64,
    pub total_load_time_ms: f64,
    pub baseline_frame_time_us: f64,
    pub current_frame_time_us: f64,
    pub overhead_us: f64,
    pub overhead_percent: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARCHIVE HANDLER
// ═══════════════════════════════════════════════════════════════════════════════

/// Supported archive formats
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ArchiveFormat {
    Zip,
    SevenZip,
    Rar,
    TarGz,
    TarXz,
}

impl ArchiveFormat {
    pub fn from_extension(path: &str) -> Option<Self> {
        let lower = path.to_lowercase();
        if lower.ends_with(".zip") { Some(ArchiveFormat::Zip) }
        else if lower.ends_with(".7z") { Some(ArchiveFormat::SevenZip) }
        else if lower.ends_with(".rar") { Some(ArchiveFormat::Rar) }
        else if lower.ends_with(".tar.gz") || lower.ends_with(".tgz") { Some(ArchiveFormat::TarGz) }
        else if lower.ends_with(".tar.xz") { Some(ArchiveFormat::TarXz) }
        else { None }
    }
}

/// Archive entry
#[derive(Debug, Clone)]
pub struct ArchiveEntry {
    pub path: String,
    pub size: u64,
    pub compressed_size: u64,
    pub is_directory: bool,
}

/// Archive handler for mod packages
pub struct ArchiveHandler;

impl ArchiveHandler {
    /// List contents of an archive
    pub fn list_contents(path: &str) -> Result<Vec<ArchiveEntry>, ArchiveError> {
        let format = ArchiveFormat::from_extension(path)
            .ok_or(ArchiveError::UnsupportedFormat)?;

        // Would use appropriate library based on format
        Ok(Vec::new())
    }

    /// Extract archive to directory
    pub fn extract(archive_path: &str, dest_dir: &str) -> Result<usize, ArchiveError> {
        let format = ArchiveFormat::from_extension(archive_path)
            .ok_or(ArchiveError::UnsupportedFormat)?;

        // Would extract using appropriate library
        Ok(0)
    }

    /// Extract single file from archive
    pub fn extract_file(archive_path: &str, file_path: &str) -> Result<Vec<u8>, ArchiveError> {
        let format = ArchiveFormat::from_extension(archive_path)
            .ok_or(ArchiveError::UnsupportedFormat)?;

        // Would extract specific file
        Err(ArchiveError::FileNotFound(file_path.to_string()))
    }

    /// Create archive from mod files
    pub fn create(dest_path: &str, files: &[(String, Vec<u8>)]) -> Result<(), ArchiveError> {
        let format = ArchiveFormat::from_extension(dest_path)
            .ok_or(ArchiveError::UnsupportedFormat)?;

        // Would create archive
        Ok(())
    }
}

#[derive(Debug)]
pub enum ArchiveError {
    UnsupportedFormat,
    IoError(String),
    FileNotFound(String),
    CorruptArchive,
    PasswordRequired,
}

