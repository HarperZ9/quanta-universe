/// Types of mod files
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ModFileType {
    Script,         // Quanta scripts (.quanta)
    Shader,         // Shader files (.hlsl, .glsl, .fx)
    Texture,        // Image files
    Model,          // 3D models
    Audio,          // Sound files
    Config,         // Configuration files
    Data,           // Generic data files
    Binary,         // Compiled binaries
    Documentation,  // README, etc.
}

/// A file within a mod
#[derive(Debug, Clone)]
pub struct ModFile {
    pub path: String,
    pub file_type: ModFileType,
    pub size: u64,
    pub hash: String,
    pub target_path: Option<String>,  // Where to install (for replacements)
}

/// Complete mod package
#[derive(Debug, Clone)]
pub struct ModPackage {
    pub metadata: ModMetadata,
    pub files: Vec<ModFile>,
    pub install_path: String,
    pub enabled: bool,
    pub installed: bool,
}

impl ModPackage {
    pub fn new(metadata: ModMetadata) -> Self {
        ModPackage {
            metadata,
            files: Vec::new(),
            install_path: String::new(),
            enabled: false,
            installed: false,
        }
    }
    
    pub fn total_size(&self) -> u64 {
        self.files.iter().map(|f| f.size).sum()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPENDENCY RESOLVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Dependency resolution result
#[derive(Debug)]
pub enum DependencyResult {
    Resolved(Vec<String>),  // Ordered list of mod IDs to load
    MissingDependencies(Vec<String>),
    CyclicDependency(Vec<String>),
    VersionConflict { mod_id: String, required: Version, available: Version },
}

/// Dependency resolver using topological sort
pub struct DependencyResolver {
    mods: HashMap<String, ModPackage>,
}

impl DependencyResolver {
    pub fn new() -> Self {
        DependencyResolver {
            mods: HashMap::new(),
        }
    }
    
    pub fn add_mod(&mut self, pkg: ModPackage) {
        self.mods.insert(pkg.metadata.id.clone(), pkg);
    }
    
    /// Resolve dependencies and return load order
    pub fn resolve(&self, enabled_mods: &[String]) -> DependencyResult {
        let mut visited = HashSet::new();
        let mut in_progress = HashSet::new();
        let mut order = Vec::new();
        
        // Check for missing dependencies first
        let mut missing = Vec::new();
        for mod_id in enabled_mods {
            if let Some(pkg) = self.mods.get(mod_id) {
                for dep in &pkg.metadata.dependencies {
                    if !dep.optional && !self.mods.contains_key(&dep.mod_id) {
                        missing.push(dep.mod_id.clone());
                    }
                }
            }
        }
        
        if !missing.is_empty() {
            return DependencyResult::MissingDependencies(missing);
        }
        
        // Topological sort
        for mod_id in enabled_mods {
            if let Err(cycle) = self.visit(mod_id, &mut visited, &mut in_progress, &mut order) {
                return DependencyResult::CyclicDependency(cycle);
            }
        }
        
        // Sort by priority within the topological order
        order.sort_by(|a, b| {
            let pa = self.mods.get(a).map(|m| m.metadata.priority).unwrap_or(LoadPriority::Normal);
            let pb = self.mods.get(b).map(|m| m.metadata.priority).unwrap_or(LoadPriority::Normal);
            pa.cmp(&pb)
        });
        
        DependencyResult::Resolved(order)
    }
    
    fn visit(
        &self,
        mod_id: &str,
        visited: &mut HashSet<String>,
        in_progress: &mut HashSet<String>,
        order: &mut Vec<String>,
    ) -> Result<(), Vec<String>> {
        if visited.contains(mod_id) {
            return Ok(());
        }
        
        if in_progress.contains(mod_id) {
            return Err(vec![mod_id.to_string()]);
        }
        
        in_progress.insert(mod_id.to_string());
        
        if let Some(pkg) = self.mods.get(mod_id) {
            for dep in &pkg.metadata.dependencies {
                if !dep.optional {
                    if let Err(mut cycle) = self.visit(&dep.mod_id, visited, in_progress, order) {
                        cycle.push(mod_id.to_string());
                        return Err(cycle);
                    }
                }
            }
        }
        
        in_progress.remove(mod_id);
        visited.insert(mod_id.to_string());
        order.push(mod_id.to_string());
        
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLICT DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Conflict between mods
#[derive(Debug, Clone)]
pub struct ModConflict {
    pub mod_a: String,
    pub mod_b: String,
    pub conflict_type: ConflictType,
    pub severity: ConflictSeverity,
    pub description: String,
    pub resolution: Option<ConflictResolution>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ConflictType {
    ExplicitIncompatibility,  // Mods declare each other as conflicts
    FileOverwrite,            // Both mods modify same file
    MemoryConflict,          // Both mods hook same memory address
    ResourceConflict,        // Both mods use same resource ID
    FeatureConflict,         // Both mods implement same feature differently
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum ConflictSeverity {
    Info,       // User might want to know
    Warning,    // Could cause issues
    Error,      // Will definitely cause issues
    Critical,   // Will crash the game
}

#[derive(Debug, Clone)]
pub enum ConflictResolution {
    DisableOne(String),       // Disable one of the mods
    LoadOrder(String, String), // Load first mod before second
    UsePatch(String),         // Use a compatibility patch
    ManualMerge,             // User must manually resolve
}

/// Conflict detector
pub struct ConflictDetector {
    mods: HashMap<String, ModPackage>,
}

impl ConflictDetector {
    pub fn new() -> Self {
        ConflictDetector {
            mods: HashMap::new(),
        }
    }
    
    pub fn add_mod(&mut self, pkg: ModPackage) {
        self.mods.insert(pkg.metadata.id.clone(), pkg);
    }
    
    /// Detect all conflicts between enabled mods
    pub fn detect_conflicts(&self, enabled_mods: &[String]) -> Vec<ModConflict> {
        let mut conflicts = Vec::new();
        
        for i in 0..enabled_mods.len() {
            for j in (i + 1)..enabled_mods.len() {
                let mod_a = &enabled_mods[i];
                let mod_b = &enabled_mods[j];
                
                conflicts.extend(self.check_pair(mod_a, mod_b));
            }
        }
        
        conflicts.sort_by(|a, b| b.severity.cmp(&a.severity));
        conflicts
    }
    
    fn check_pair(&self, mod_a: &str, mod_b: &str) -> Vec<ModConflict> {
        let mut conflicts = Vec::new();
        
        let pkg_a = match self.mods.get(mod_a) { Some(p) => p, None => return conflicts };
        let pkg_b = match self.mods.get(mod_b) { Some(p) => p, None => return conflicts };
        
        // Check explicit conflicts
        if pkg_a.metadata.conflicts.contains(&mod_b.to_string()) ||
           pkg_b.metadata.conflicts.contains(&mod_a.to_string()) {
            conflicts.push(ModConflict {
                mod_a: mod_a.to_string(),
                mod_b: mod_b.to_string(),
                conflict_type: ConflictType::ExplicitIncompatibility,
                severity: ConflictSeverity::Error,
                description: format!("'{}' and '{}' are explicitly incompatible", 
                                   pkg_a.metadata.name, pkg_b.metadata.name),
                resolution: Some(ConflictResolution::DisableOne(mod_b.to_string())),
            });
        }
        
        // Check file conflicts
        let files_a: HashSet<&String> = pkg_a.files.iter()
            .filter_map(|f| f.target_path.as_ref())
            .collect();
        
        for file in &pkg_b.files {
            if let Some(target) = &file.target_path {
                if files_a.contains(target) {
                    conflicts.push(ModConflict {
                        mod_a: mod_a.to_string(),
                        mod_b: mod_b.to_string(),
                        conflict_type: ConflictType::FileOverwrite,
                        severity: ConflictSeverity::Warning,
                        description: format!("Both mods modify '{}'", target),
                        resolution: Some(ConflictResolution::LoadOrder(mod_a.to_string(), mod_b.to_string())),
                    });
                }
            }
        }
        
        conflicts
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD PROFILES
// ═══════════════════════════════════════════════════════════════════════════════

/// A saved configuration of enabled mods
#[derive(Debug, Clone)]
pub struct ModProfile {
    pub id: String,
    pub name: String,
    pub description: String,
    pub game_id: String,
    pub enabled_mods: Vec<String>,
    pub mod_configs: HashMap<String, HashMap<String, String>>,  // mod_id -> config
    pub created: u64,
    pub modified: u64,
}

impl ModProfile {
    pub fn new(id: &str, name: &str, game_id: &str) -> Self {
        ModProfile {
            id: id.to_string(),
            name: name.to_string(),
            description: String::new(),
            game_id: game_id.to_string(),
            enabled_mods: Vec::new(),
            mod_configs: HashMap::new(),
            created: 0,
            modified: 0,
        }
    }
    
    pub fn enable_mod(&mut self, mod_id: &str) {
        if !self.enabled_mods.contains(&mod_id.to_string()) {
            self.enabled_mods.push(mod_id.to_string());
        }
    }
    
    pub fn disable_mod(&mut self, mod_id: &str) {
        self.enabled_mods.retain(|m| m != mod_id);
    }
    
    pub fn set_config(&mut self, mod_id: &str, key: &str, value: &str) {
        self.mod_configs
            .entry(mod_id.to_string())
            .or_insert_with(HashMap::new)
            .insert(key.to_string(), value.to_string());
    }
}

/// Profile manager
pub struct ProfileManager {
    profiles: HashMap<String, ModProfile>,
    active_profile: Option<String>,
}

impl ProfileManager {
    pub fn new() -> Self {
        ProfileManager {
            profiles: HashMap::new(),
            active_profile: None,
        }
    }
    
    pub fn create_profile(&mut self, name: &str, game_id: &str) -> String {
        let id = format!("profile_{}", self.profiles.len());
        let profile = ModProfile::new(&id, name, game_id);
        self.profiles.insert(id.clone(), profile);
        id
    }
    
    pub fn activate_profile(&mut self, profile_id: &str) -> bool {
        if self.profiles.contains_key(profile_id) {
            self.active_profile = Some(profile_id.to_string());
            true
        } else {
            false
        }
    }
    
    pub fn get_active(&self) -> Option<&ModProfile> {
        self.active_profile.as_ref().and_then(|id| self.profiles.get(id))
    }
    
    pub fn get_active_mut(&mut self) -> Option<&mut ModProfile> {
        let id = self.active_profile.clone()?;
        self.profiles.get_mut(&id)
    }
    
    pub fn duplicate_profile(&mut self, profile_id: &str, new_name: &str) -> Option<String> {
        let source = self.profiles.get(profile_id)?.clone();
        let new_id = format!("profile_{}", self.profiles.len());
        
        let mut new_profile = source;
        new_profile.id = new_id.clone();
        new_profile.name = new_name.to_string();
        
        self.profiles.insert(new_id.clone(), new_profile);
        Some(new_id)
    }
}

