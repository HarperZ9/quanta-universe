// MOD COLLECTIONS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct ModCollection {
    pub id: String,
    pub name: String,
    pub description: String,
    pub author: String,
    pub mods: Vec<CollectionMod>,
    pub subscribers: u64,
    pub rating: Rating,
    pub game_id: String,
    pub tags: Vec<String>,
    pub created: u64,
    pub updated: u64,
}

#[derive(Debug, Clone)]
pub struct CollectionMod {
    pub mod_id: String,
    pub version: Option<Version>,
    pub required: bool,
    pub notes: String,
    pub load_order: i32,
}

pub struct CollectionManager {
    collections: HashMap<String, ModCollection>,
    subscribed: Vec<String>,
}

impl CollectionManager {
    pub fn new() -> Self {
        CollectionManager { collections: HashMap::new(), subscribed: Vec::new() }
    }

    pub fn create(&mut self, name: &str, game_id: &str) -> String {
        let id = format!("collection_{}", self.collections.len());
        let collection = ModCollection {
            id: id.clone(),
            name: name.to_string(),
            description: String::new(),
            author: String::new(),
            mods: Vec::new(),
            subscribers: 0,
            rating: Rating::new(),
            game_id: game_id.to_string(),
            tags: Vec::new(),
            created: 0,
            updated: 0,
        };
        self.collections.insert(id.clone(), collection);
        id
    }

    pub fn add_mod(&mut self, collection_id: &str, mod_entry: CollectionMod) -> bool {
        if let Some(collection) = self.collections.get_mut(collection_id) {
            collection.mods.push(mod_entry);
            collection.mods.sort_by(|a, b| a.load_order.cmp(&b.load_order));
            true
        } else { false }
    }

    pub fn subscribe(&mut self, collection_id: &str) {
        if !self.subscribed.contains(&collection_id.to_string()) {
            self.subscribed.push(collection_id.to_string());
            if let Some(c) = self.collections.get_mut(collection_id) {
                c.subscribers += 1;
            }
        }
    }

    pub fn get_collection_mods(&self, collection_id: &str) -> Option<&[CollectionMod]> {
        self.collections.get(collection_id).map(|c| c.mods.as_slice())
    }

    pub fn validate_collection(&self, collection_id: &str, installed: &HashSet<String>) -> CollectionValidation {
        let collection = match self.collections.get(collection_id) {
            Some(c) => c,
            None => return CollectionValidation { valid: false, missing: vec![], outdated: vec![] },
        };

        let mut missing = Vec::new();
        let outdated = Vec::new();

        for mod_entry in &collection.mods {
            if mod_entry.required && !installed.contains(&mod_entry.mod_id) {
                missing.push(mod_entry.mod_id.clone());
            }
        }

        CollectionValidation { valid: missing.is_empty(), missing, outdated }
    }
}

#[derive(Debug)]
pub struct CollectionValidation {
    pub valid: bool,
    pub missing: Vec<String>,
    pub outdated: Vec<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOD SIGNING & VERIFICATION
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct ModSignature {
    pub mod_id: String,
    pub version: Version,
    pub signature: Vec<u8>,
    pub public_key: Vec<u8>,
    pub timestamp: u64,
    pub signed_by: String,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum VerificationResult {
    Valid,
    InvalidSignature,
    ExpiredSignature,
    UnknownSigner,
    TamperedContent,
    NotSigned,
}

pub struct ModVerifier {
    trusted_keys: HashMap<String, Vec<u8>>,
    verified_cache: HashMap<String, VerificationResult>,
}

impl ModVerifier {
    pub fn new() -> Self {
        ModVerifier { trusted_keys: HashMap::new(), verified_cache: HashMap::new() }
    }

    pub fn add_trusted_key(&mut self, signer_id: &str, public_key: Vec<u8>) {
        self.trusted_keys.insert(signer_id.to_string(), public_key);
    }

    pub fn verify(&mut self, pkg: &ModPackage, signature: &ModSignature) -> VerificationResult {
        if let Some(cached) = self.verified_cache.get(&pkg.metadata.id) {
            return *cached;
        }

        // Check if signer is trusted
        if !self.trusted_keys.contains_key(&signature.signed_by) {
            return VerificationResult::UnknownSigner;
        }

        let public_key = &self.trusted_keys[&signature.signed_by];

        // Compute content hash
        let content_hash = self.compute_hash(pkg);

        // Verify signature (simplified - would use actual crypto)
        let result = if self.verify_signature(&content_hash, &signature.signature, public_key) {
            VerificationResult::Valid
        } else {
            VerificationResult::InvalidSignature
        };

        self.verified_cache.insert(pkg.metadata.id.clone(), result);
        result
    }

    fn compute_hash(&self, pkg: &ModPackage) -> Vec<u8> {
        // Would compute SHA-256 of mod contents
        vec![0u8; 32]
    }

    fn verify_signature(&self, hash: &[u8], signature: &[u8], public_key: &[u8]) -> bool {
        // Would use Ed25519 or RSA verification
        !signature.is_empty() && !public_key.is_empty()
    }

    pub fn sign(&self, pkg: &ModPackage, private_key: &[u8]) -> ModSignature {
        let hash = self.compute_hash(pkg);
        // Would sign with private key
        ModSignature {
            mod_id: pkg.metadata.id.clone(),
            version: pkg.metadata.version.clone(),
            signature: vec![0u8; 64],
            public_key: vec![],
            timestamp: 0,
            signed_by: String::new(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOCALIZATION SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct LocalizationEntry {
    pub key: String,
    pub translations: HashMap<String, String>, // locale -> text
    pub context: Option<String>,
    pub max_length: Option<usize>,
}

pub struct LocalizationManager {
    entries: HashMap<String, LocalizationEntry>,
    current_locale: String,
    fallback_locale: String,
    mod_strings: HashMap<String, HashMap<String, String>>, // mod_id -> key -> value
}

impl LocalizationManager {
    pub fn new(default_locale: &str) -> Self {
        LocalizationManager {
            entries: HashMap::new(),
            current_locale: default_locale.to_string(),
            fallback_locale: "en".to_string(),
            mod_strings: HashMap::new(),
        }
    }

    pub fn set_locale(&mut self, locale: &str) {
        self.current_locale = locale.to_string();
    }

    pub fn add_entry(&mut self, key: &str, translations: HashMap<String, String>) {
        self.entries.insert(key.to_string(), LocalizationEntry {
            key: key.to_string(),
            translations,
            context: None,
            max_length: None,
        });
    }

    pub fn get(&self, key: &str) -> &str {
        if let Some(entry) = self.entries.get(key) {
            if let Some(text) = entry.translations.get(&self.current_locale) {
                return text;
            }
            if let Some(text) = entry.translations.get(&self.fallback_locale) {
                return text;
            }
        }
        return key;
    }

    pub fn get_formatted(&self, key: &str, args: &HashMap<String, String>) -> String {
        let mut text = self.get(key).to_string();
        for (arg_key, arg_val) in args {
            text = text.replace(&format!("{{{}}}", arg_key), arg_val);
        }
        text
    }

    pub fn load_mod_strings(&mut self, mod_id: &str, locale: &str, strings: HashMap<String, String>) {
        let full_strings: HashMap<String, String> = strings.into_iter()
            .map(|(k, v)| (format!("{}:{}", mod_id, k), v))
            .collect();

        self.mod_strings.entry(mod_id.to_string())
            .or_insert_with(HashMap::new)
            .extend(full_strings);
    }

    pub fn get_mod_string(&self, mod_id: &str, key: &str) -> Option<&String> {
        self.mod_strings.get(mod_id)?.get(key)
    }

    pub fn available_locales(&self) -> HashSet<String> {
        let mut locales = HashSet::new();
        for entry in self.entries.values() {
            for locale in entry.translations.keys() {
                locales.insert(locale.clone());
            }
        }
        locales
    }
}

