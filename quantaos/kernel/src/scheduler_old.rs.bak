// =============================================================================
// PUBLIC INTERFACE
// =============================================================================

/// Initialize the scheduler
pub fn init() {
    let _sched = SCHEDULER.lock();

    // Create idle thread
    // sched.idle_thread = Some(create_idle_thread());
}

/// Enter the scheduler main loop (never returns)
pub fn run() -> ! {
    loop {
        // Poll network stack for I/O
        crate::net::poll();

        // Run scheduler
        {
            let mut sched = SCHEDULER.lock();
            sched.schedule();
        }

        // Wait for next interrupt
        crate::cpu::halt();
    }
}

/// Yield the current thread
pub fn yield_now() {
    let mut sched = SCHEDULER.lock();
    sched.yield_current();
    sched.schedule();
}

/// Yield CPU (alias for yield_now)
pub fn yield_cpu() {
    yield_now();
}

/// Add a thread to the scheduler
pub fn add_thread(tid: Tid, priority: i32) {
    let mut sched = SCHEDULER.lock();
    sched.enqueue(tid, priority);
}

/// Remove a thread from the scheduler
pub fn remove_thread(tid: Tid) {
    let mut sched = SCHEDULER.lock();
    // Remove from all queues
    for queue in &mut sched.run_queues {
        queue.threads.retain(|&t| t != tid);
    }
}

/// Apply AI priority boost
pub fn ai_priority_boost(tid: Tid, boost: f32) {
    let mut sched = SCHEDULER.lock();
    sched.ai_boost(tid, boost);
}

/// Timer tick handler
pub fn timer_tick() {
    let mut sched = SCHEDULER.lock();
    sched.tick();
}

/// Timer tick handler with interrupt frame (for preemption)
pub fn timer_tick_with_frame(frame: &crate::interrupts::InterruptFrame) {
    // Update current thread's context from interrupt frame
    if let Some(tid) = crate::process::current_thread() {
        let ctx = crate::context::context_from_interrupt_frame(frame);
        crate::process::set_thread_context(tid, ctx);
    }

    // Process timer tick
    {
        let mut sched = SCHEDULER.lock();
        sched.stats.timeslices_expired += 1;

        // Re-enqueue current thread if it was running
        if let Some(tid) = sched.current {
            sched.enqueue(tid, DEFAULT_PRIORITY);
        }
    }

    // Note: actual context switch happens when interrupt returns
    // because we've updated the thread's saved context
}

/// Get scheduler statistics
pub fn get_stats() -> SchedulerStats {
    let sched = SCHEDULER.lock();
    SchedulerStats {
        context_switches: sched.stats.context_switches,
        timeslices_expired: sched.stats.timeslices_expired,
        voluntary_yields: sched.stats.voluntary_yields,
        ai_adjustments: sched.stats.ai_adjustments,
    }
}
