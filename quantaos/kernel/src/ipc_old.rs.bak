/// Initialize IPC subsystem
pub fn init() {
    crate::kprintln!("[IPC] Initializing inter-process communication...");
    crate::kprintln!("[IPC] IPC subsystem ready");
}

// =============================================================================
// STATISTICS
// =============================================================================

/// Get number of active pipes
pub fn pipe_count() -> usize {
    PIPES.read().len()
}

/// Get number of message queues
pub fn mq_count() -> usize {
    MSG_QUEUES.read().len()
}

/// Get number of shared memory segments
pub fn shm_count() -> usize {
    SHM_SEGMENTS.read().len()
}

/// Get number of semaphores
pub fn sem_count() -> usize {
    SEMAPHORES.read().len()
}
