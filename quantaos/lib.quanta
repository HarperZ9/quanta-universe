#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum KernelError {
    OutOfMemory,
    InvalidAddress,
    InvalidPid,
    InvalidTid,
    InvalidFd,
    ProcessNotFound,
    ThreadNotFound,
    PermissionDenied,
    ResourceBusy,
    Deadlock,
    InvalidSyscall,
    AIModelNotLoaded,
    AIInferenceFailed,
    CheckpointFailed,
    RestoreFailed,
    IoError,
    NotImplemented,
}

pub type KernelResult<T> = Result<T, KernelError>;

