/// Supported architectures
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Architecture {
    X86_64,
    ARM64,
    RISCV64,
}

impl Architecture {
    pub fn page_levels(&self) -> usize {
        match self {
            Architecture::X86_64 => 4,  // PML4 -> PDPT -> PD -> PT
            Architecture::ARM64 => 4,   // L0 -> L1 -> L2 -> L3
            Architecture::RISCV64 => 4, // Sv48
        }
    }

    pub fn phys_addr_width(&self) -> usize {
        match self {
            Architecture::X86_64 => 52,
            Architecture::ARM64 => 48,
            Architecture::RISCV64 => 56,
        }
    }
}

