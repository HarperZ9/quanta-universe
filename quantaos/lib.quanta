// PHYSICAL MEMORY MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Physical address wrapper
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub struct PhysAddr(pub u64);

impl PhysAddr {
    pub fn new(addr: u64) -> Self {
        PhysAddr(addr & 0x000F_FFFF_FFFF_F000) // Mask to valid physical address
    }

    pub fn as_u64(&self) -> u64 {
        self.0
    }

    pub fn offset(&self, offset: u64) -> Self {
        PhysAddr(self.0 + offset)
    }

    pub fn page_index(&self) -> usize {
        (self.0 >> PAGE_SHIFT) as usize
    }
}

/// Virtual address wrapper
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub struct VirtAddr(pub u64);

impl VirtAddr {
    pub fn new(addr: u64) -> Self {
        // Sign extend for canonical addresses
        let sign_extended = if addr & (1 << 47) != 0 {
            addr | 0xFFFF_0000_0000_0000
        } else {
            addr & 0x0000_FFFF_FFFF_FFFF
        };
        VirtAddr(sign_extended)
    }

    pub fn as_u64(&self) -> u64 {
        self.0
    }

    pub fn page_offset(&self) -> usize {
        (self.0 & 0xFFF) as usize
    }

    pub fn pml4_index(&self) -> usize {
        ((self.0 >> 39) & 0x1FF) as usize
    }

    pub fn pdpt_index(&self) -> usize {
        ((self.0 >> 30) & 0x1FF) as usize
    }

    pub fn pd_index(&self) -> usize {
        ((self.0 >> 21) & 0x1FF) as usize
    }

    pub fn pt_index(&self) -> usize {
        ((self.0 >> 12) & 0x1FF) as usize
    }
}

/// Physical memory region type
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum MemoryRegionType {
    Available,
    Reserved,
    AcpiReclaimable,
    AcpiNvs,
    BadMemory,
    KernelCode,
    KernelData,
    KernelStack,
    FrameBuffer,
    AITensorPool,
}

/// Memory region descriptor
#[derive(Debug, Clone)]
pub struct MemoryRegion {
    pub start: PhysAddr,
    pub size: usize,
    pub region_type: MemoryRegionType,
}

/// Buddy allocator for physical pages
pub struct BuddyAllocator {
    /// Free lists for each order (0 = 4KB, 1 = 8KB, ..., 10 = 4MB)
    free_lists: [Vec<PhysAddr>; 11],
    /// Total available memory
    total_memory: usize,
    /// Currently free memory
    free_memory: usize,
    /// Bitmap of allocated pages
    bitmap: Vec<u64>,
}

impl BuddyAllocator {
    pub fn new(total_pages: usize) -> Self {
        let bitmap_size = (total_pages + 63) / 64;
        BuddyAllocator {
            free_lists: Default::default(),
            total_memory: total_pages * PAGE_SIZE,
            free_memory: 0,
            bitmap: vec![0; bitmap_size],
        }
    }

    /// Initialize with memory map
    pub fn init(&mut self, regions: &[MemoryRegion]) {
        for region in regions {
            if region.region_type == MemoryRegionType::Available {
                let start_page = region.start.page_index();
                let num_pages = region.size / PAGE_SIZE;

                // Add to highest possible order
                let mut remaining = num_pages;
                let mut current_page = start_page;

                while remaining > 0 {
                    let order = self.find_order(remaining, current_page);
                    let pages_in_block = 1 << order;

                    self.free_lists[order].push(PhysAddr::new((current_page as u64) << PAGE_SHIFT));
                    self.free_memory += pages_in_block * PAGE_SIZE;

                    current_page += pages_in_block;
                    remaining -= pages_in_block;
                }
            }
        }
    }

    fn find_order(&self, remaining: usize, page: usize) -> usize {
        for order in (0..=10).rev() {
            let block_size = 1 << order;
            if remaining >= block_size && (page % block_size) == 0 {
                return order;
            }
        }
        0
    }

    /// Allocate contiguous pages
    pub fn allocate(&mut self, order: usize) -> KernelResult<PhysAddr> {
        if order > 10 {
            return Err(KernelError::InvalidAddress);
        }

        // Find smallest available block
        for o in order..=10 {
            if let Some(addr) = self.free_lists[o].pop() {
                // Split larger blocks if necessary
                let mut current_order = o;
                let mut current_addr = addr;

                while current_order > order {
                    current_order -= 1;
                    let buddy_addr = PhysAddr::new(
                        current_addr.as_u64() + ((1 << current_order) * PAGE_SIZE) as u64
                    );
                    self.free_lists[current_order].push(buddy_addr);
                }

                let pages = 1 << order;
                self.free_memory -= pages * PAGE_SIZE;

                // Mark as allocated in bitmap
                let start_page = current_addr.page_index();
                for i in 0..pages {
                    self.mark_allocated(start_page + i);
                }

                return Ok(current_addr);
            }
        }

        Err(KernelError::OutOfMemory)
    }

    /// Free contiguous pages
    pub fn free(&mut self, addr: PhysAddr, order: usize) {
        if order > 10 {
            return;
        }

        let pages = 1 << order;
        let start_page = addr.page_index();

        // Mark as free in bitmap
        for i in 0..pages {
            self.mark_free(start_page + i);
        }

        // Try to coalesce with buddy
        let mut current_addr = addr;
        let mut current_order = order;

        while current_order < 10 {
            let buddy_addr = self.get_buddy(current_addr, current_order);

            // Check if buddy is free
            if let Some(idx) = self.free_lists[current_order].iter().position(|&a| a == buddy_addr) {
                self.free_lists[current_order].remove(idx);
                current_addr = PhysAddr::new(current_addr.as_u64().min(buddy_addr.as_u64()));
                current_order += 1;
            } else {
                break;
            }
        }

        self.free_lists[current_order].push(current_addr);
        self.free_memory += pages * PAGE_SIZE;
    }

    fn get_buddy(&self, addr: PhysAddr, order: usize) -> PhysAddr {
        let buddy_offset = (1 << order) * PAGE_SIZE;
        PhysAddr::new(addr.as_u64() ^ buddy_offset as u64)
    }

    fn mark_allocated(&mut self, page: usize) {
        let word = page / 64;
        let bit = page % 64;
        if word < self.bitmap.len() {
            self.bitmap[word] |= 1 << bit;
        }
    }

    fn mark_free(&mut self, page: usize) {
        let word = page / 64;
        let bit = page % 64;
        if word < self.bitmap.len() {
            self.bitmap[word] &= !(1 << bit);
        }
    }

    pub fn available_memory(&self) -> usize {
        self.free_memory
    }

    pub fn total_memory(&self) -> usize {
        self.total_memory
    }
}

