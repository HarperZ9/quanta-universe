// ═══════════════════════════════════════════════════════════════════════════════
// POWER MANAGEMENT - CPU and Device Power States
// ═══════════════════════════════════════════════════════════════════════════════

/// Power management subsystem
pub struct PowerManager {
    /// CPU power states
    cpu_states: Vec<CpuPowerState>,
    /// Device power states
    device_states: HashMap<DeviceId, DevicePowerState>,
    /// Power policies
    policies: HashMap<String, PowerPolicy>,
    /// Active policy
    active_policy: String,
    /// Suspend/resume handlers
    suspend_handlers: Vec<Box<dyn SuspendHandler>>,
    /// Power event log
    events: VecDeque<PowerEvent>,
    /// Statistics
    stats: PowerStats,
}

pub type DeviceId = u64;

/// CPU power state
pub struct CpuPowerState {
    pub cpu_id: u32,
    pub state: CpuState,
    pub frequency: u64,
    pub voltage: u32,
    pub temperature: i32,
    pub idle_time: Duration,
    pub active_time: Duration,
}

#[derive(Debug, Clone, PartialEq)]
pub enum CpuState {
    Active,
    Idle(u8),       // C-state level
    Offline,
}

/// Device power state
pub struct DevicePowerState {
    pub device_id: DeviceId,
    pub device_name: String,
    pub state: DeviceState,
    pub runtime_suspended: bool,
    pub wakeup_enabled: bool,
    pub last_activity: Instant,
    pub auto_suspend_delay: Duration,
}

#[derive(Debug, Clone, PartialEq)]
pub enum DeviceState {
    D0,     // Fully on
    D1,     // Intermediate
    D2,     // Intermediate
    D3Hot,  // Software off
    D3Cold, // Hardware off
}

/// Power policy
pub struct PowerPolicy {
    pub name: String,
    pub governor: CpuGovernor,
    pub min_frequency: u64,
    pub max_frequency: u64,
    pub energy_preference: EnergyPreference,
    pub turbo_enabled: bool,
    pub suspend_timeout: Duration,
    pub hibernate_timeout: Duration,
}

#[derive(Debug, Clone)]
pub enum CpuGovernor {
    Performance,
    Powersave,
    Ondemand,
    Conservative,
    Schedutil,
    Userspace,
}

#[derive(Debug, Clone)]
pub enum EnergyPreference {
    Performance,
    BalancePerformance,
    Balance,
    BalancePower,
    Power,
}

/// Suspend handler trait
pub trait SuspendHandler: Send + Sync {
    fn name(&self) -> &str;
    fn suspend(&mut self) -> Result<(), OsError>;
    fn resume(&mut self) -> Result<(), OsError>;
    fn priority(&self) -> i32;
}

/// Power event
pub struct PowerEvent {
    pub timestamp: Instant,
    pub event_type: PowerEventType,
    pub device_id: Option<DeviceId>,
    pub details: String,
}

#[derive(Debug, Clone)]
pub enum PowerEventType {
    CpuFrequencyChange,
    CpuStateChange,
    DeviceStateChange,
    SystemSuspend,
    SystemResume,
    PolicyChange,
    ThermalThrottle,
}

/// Power statistics
pub struct PowerStats {
    pub total_energy: f64,
    pub cpu_energy: f64,
    pub device_energy: f64,
    pub suspend_count: u64,
    pub resume_count: u64,
    pub time_in_suspend: Duration,
    pub time_active: Duration,
}

impl PowerManager {
    pub fn new(cpu_count: u32) -> Self {
        let mut cpu_states = Vec::with_capacity(cpu_count as usize);
        for i in 0..cpu_count {
            cpu_states.push(CpuPowerState {
                cpu_id: i,
                state: CpuState::Active,
                frequency: 2400_000_000, // 2.4 GHz
                voltage: 1000,           // 1.0V
                temperature: 50,
                idle_time: Duration::ZERO,
                active_time: Duration::ZERO,
            });
        }

        let mut policies = HashMap::new();
        policies.insert("balanced".to_string(), PowerPolicy::balanced());
        policies.insert("performance".to_string(), PowerPolicy::performance());
        policies.insert("powersave".to_string(), PowerPolicy::powersave());

        Self {
            cpu_states,
            device_states: HashMap::new(),
            policies,
            active_policy: "balanced".to_string(),
            suspend_handlers: Vec::new(),
            events: VecDeque::with_capacity(1000),
            stats: PowerStats::new(),
        }
    }

    /// Set CPU frequency
    pub fn set_cpu_frequency(&mut self, cpu_id: u32, frequency: u64) -> Result<(), OsError> {
        let state = self.cpu_states.get_mut(cpu_id as usize)
            .ok_or(OsError::NotFound)?;

        let policy = self.policies.get(&self.active_policy).unwrap();

        if frequency < policy.min_frequency || frequency > policy.max_frequency {
            return Err(OsError::InvalidArgument);
        }

        state.frequency = frequency;
        self.log_event(PowerEventType::CpuFrequencyChange, None,
            format!("CPU {} frequency set to {} Hz", cpu_id, frequency));

        Ok(())
    }

    /// Set CPU state
    pub fn set_cpu_state(&mut self, cpu_id: u32, state: CpuState) -> Result<(), OsError> {
        let cpu_state = self.cpu_states.get_mut(cpu_id as usize)
            .ok_or(OsError::NotFound)?;

        cpu_state.state = state.clone();
        self.log_event(PowerEventType::CpuStateChange, None,
            format!("CPU {} state changed to {:?}", cpu_id, state));

        Ok(())
    }

    /// Set device power state
    pub fn set_device_state(&mut self, device_id: DeviceId, state: DeviceState) -> Result<(), OsError> {
        let device = self.device_states.get_mut(&device_id)
            .ok_or(OsError::NotFound)?;

        device.state = state.clone();
        self.log_event(PowerEventType::DeviceStateChange, Some(device_id),
            format!("Device {} state changed to {:?}", device.device_name, state));

        Ok(())
    }

    /// Register a device for power management
    pub fn register_device(&mut self, device_id: DeviceId, name: &str) {
        self.device_states.insert(device_id, DevicePowerState {
            device_id,
            device_name: name.to_string(),
            state: DeviceState::D0,
            runtime_suspended: false,
            wakeup_enabled: true,
            last_activity: Instant::now(),
            auto_suspend_delay: Duration::from_secs(5),
        });
    }

    /// Set active power policy
    pub fn set_policy(&mut self, policy_name: &str) -> Result<(), OsError> {
        if !self.policies.contains_key(policy_name) {
            return Err(OsError::NotFound);
        }

        self.active_policy = policy_name.to_string();
        self.apply_policy()?;

        self.log_event(PowerEventType::PolicyChange, None,
            format!("Policy changed to {}", policy_name));

        Ok(())
    }

    /// System suspend
    pub fn suspend(&mut self) -> Result<(), OsError> {
        self.log_event(PowerEventType::SystemSuspend, None, "System suspending".to_string());

        // Sort handlers by priority
        self.suspend_handlers.sort_by_key(|h| -h.priority());

        // Call suspend handlers
        for handler in &mut self.suspend_handlers {
            handler.suspend()?;
        }

        self.stats.suspend_count += 1;
        Ok(())
    }

    /// System resume
    pub fn resume(&mut self) -> Result<(), OsError> {
        // Call resume handlers in reverse order
        for handler in self.suspend_handlers.iter_mut().rev() {
            handler.resume()?;
        }

        self.stats.resume_count += 1;
        self.log_event(PowerEventType::SystemResume, None, "System resumed".to_string());

        Ok(())
    }

    /// Register suspend handler
    pub fn register_suspend_handler(&mut self, handler: Box<dyn SuspendHandler>) {
        self.suspend_handlers.push(handler);
    }

    /// Get power statistics
    pub fn get_stats(&self) -> &PowerStats {
        &self.stats
    }

    /// Get CPU power states
    pub fn get_cpu_states(&self) -> &[CpuPowerState] {
        &self.cpu_states
    }

    fn apply_policy(&mut self) -> Result<(), OsError> {
        let policy = self.policies.get(&self.active_policy).unwrap().clone();

        for cpu_state in &mut self.cpu_states {
            if cpu_state.frequency < policy.min_frequency {
                cpu_state.frequency = policy.min_frequency;
            } else if cpu_state.frequency > policy.max_frequency {
                cpu_state.frequency = policy.max_frequency;
            }
        }

        Ok(())
    }

    fn log_event(&mut self, event_type: PowerEventType, device_id: Option<DeviceId>, details: String) {
        self.events.push_back(PowerEvent {
            timestamp: Instant::now(),
            event_type,
            device_id,
            details,
        });

        if self.events.len() > 1000 {
            self.events.pop_front();
        }
    }
}

impl PowerPolicy {
    pub fn balanced() -> Self {
        Self {
            name: "balanced".to_string(),
            governor: CpuGovernor::Schedutil,
            min_frequency: 800_000_000,
            max_frequency: 3_600_000_000,
            energy_preference: EnergyPreference::Balance,
            turbo_enabled: true,
            suspend_timeout: Duration::from_secs(1800),
            hibernate_timeout: Duration::from_secs(7200),
        }
    }

    pub fn performance() -> Self {
        Self {
            name: "performance".to_string(),
            governor: CpuGovernor::Performance,
            min_frequency: 2_000_000_000,
            max_frequency: 5_000_000_000,
            energy_preference: EnergyPreference::Performance,
            turbo_enabled: true,
            suspend_timeout: Duration::from_secs(0),
            hibernate_timeout: Duration::from_secs(0),
        }
    }

    pub fn powersave() -> Self {
        Self {
            name: "powersave".to_string(),
            governor: CpuGovernor::Powersave,
            min_frequency: 400_000_000,
            max_frequency: 2_000_000_000,
            energy_preference: EnergyPreference::Power,
            turbo_enabled: false,
            suspend_timeout: Duration::from_secs(300),
            hibernate_timeout: Duration::from_secs(1800),
        }
    }
}

impl PowerStats {
    pub fn new() -> Self {
        Self {
            total_energy: 0.0,
            cpu_energy: 0.0,
            device_energy: 0.0,
            suspend_count: 0,
            resume_count: 0,
            time_in_suspend: Duration::ZERO,
            time_active: Duration::ZERO,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECURITY MODULE - Mandatory Access Control
// ═══════════════════════════════════════════════════════════════════════════════

/// Mandatory access control module
pub struct SecurityModule {
    /// Security policies
    policies: HashMap<String, SecurityPolicy>,
    /// Subject labels (processes)
    subject_labels: HashMap<Pid, SecurityLabel>,
    /// Object labels (files, sockets, etc.)
    object_labels: HashMap<u64, SecurityLabel>,
    /// Type enforcement rules
    type_rules: Vec<TypeEnforcementRule>,
    /// Role-based access control
    rbac: RbacManager,
    /// Audit log
    audit_log: VecDeque<SecurityAuditEvent>,
    /// Module configuration
    config: SecurityModuleConfig,
    /// Enforcing mode
    enforcing: AtomicBool,
}

/// Security label
#[derive(Clone, Debug)]
pub struct SecurityLabel {
    pub user: String,
    pub role: String,
    pub label_type: String,
    pub level: SecurityLevel,
    pub categories: HashSet<String>,
}

/// Security level (MLS)
#[derive(Clone, Debug, PartialEq, Eq, PartialOrd, Ord)]
pub struct SecurityLevel {
    pub sensitivity: u8,
    pub categories: Vec<u16>,
}

/// Security policy
pub struct SecurityPolicy {
    pub name: String,
    pub version: u32,
    pub types: Vec<TypeDefinition>,
    pub roles: Vec<RoleDefinition>,
    pub users: Vec<UserDefinition>,
    pub rules: Vec<PolicyRule>,
}

/// Type definition
pub struct TypeDefinition {
    pub name: String,
    pub attributes: Vec<String>,
    pub aliases: Vec<String>,
}

/// Role definition
pub struct RoleDefinition {
    pub name: String,
    pub types: Vec<String>,
    pub dominates: Vec<String>,
}

/// User definition
pub struct UserDefinition {
    pub name: String,
    pub roles: Vec<String>,
    pub default_level: SecurityLevel,
    pub range: (SecurityLevel, SecurityLevel),
}

/// Policy rule
pub struct PolicyRule {
    pub rule_type: PolicyRuleType,
    pub source: String,
    pub target: String,
    pub class: String,
    pub permissions: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum PolicyRuleType {
    Allow,
    Deny,
    Audit,
    DontAudit,
    TypeTransition,
    TypeMember,
    TypeChange,
}

/// Type enforcement rule
pub struct TypeEnforcementRule {
    pub source_type: String,
    pub target_type: String,
    pub object_class: String,
    pub permissions: HashSet<String>,
    pub audit: bool,
}

/// Role-based access control manager
pub struct RbacManager {
    /// User to role mappings
    user_roles: HashMap<String, Vec<String>>,
    /// Role to permission mappings
    role_permissions: HashMap<String, HashSet<String>>,
    /// Role hierarchy
    role_hierarchy: HashMap<String, Vec<String>>,
}

/// Security audit event
pub struct SecurityAuditEvent {
    pub timestamp: Instant,
    pub event_type: AuditEventType,
    pub subject: Option<SecurityLabel>,
    pub object: Option<SecurityLabel>,
    pub action: String,
    pub result: AuditResult,
    pub details: String,
}

#[derive(Debug, Clone)]
pub enum AuditEventType {
    AccessCheck,
    PolicyLoad,
    PolicyChange,
    LabelChange,
    EnforcementChange,
    SecurityViolation,
}

#[derive(Debug, Clone)]
pub enum AuditResult {
    Granted,
    Denied,
    Error(String),
}

/// Security module configuration
pub struct SecurityModuleConfig {
    pub enforce_by_default: bool,
    pub audit_denied: bool,
    pub audit_granted: bool,
    pub max_audit_events: usize,
    pub default_user: String,
    pub default_role: String,
    pub default_type: String,
}

impl SecurityModule {
    pub fn new(config: SecurityModuleConfig) -> Self {
        Self {
            policies: HashMap::new(),
            subject_labels: HashMap::new(),
            object_labels: HashMap::new(),
            type_rules: Vec::new(),
            rbac: RbacManager::new(),
            audit_log: VecDeque::with_capacity(config.max_audit_events),
            enforcing: AtomicBool::new(config.enforce_by_default),
            config,
        }
    }

    /// Load a security policy
    pub fn load_policy(&mut self, policy: SecurityPolicy) -> Result<(), OsError> {
        self.audit_event(AuditEventType::PolicyLoad, None, None,
            "policy_load", AuditResult::Granted,
            format!("Loading policy: {}", policy.name));

        // Build type enforcement rules from policy
        for rule in &policy.rules {
            if matches!(rule.rule_type, PolicyRuleType::Allow) {
                self.type_rules.push(TypeEnforcementRule {
                    source_type: rule.source.clone(),
                    target_type: rule.target.clone(),
                    object_class: rule.class.clone(),
                    permissions: rule.permissions.iter().cloned().collect(),
                    audit: false,
                });
            }
        }

        self.policies.insert(policy.name.clone(), policy);
        Ok(())
    }

    /// Check access permission
    pub fn check_access(
        &self,
        subject_pid: Pid,
        object_id: u64,
        object_class: &str,
        permission: &str,
    ) -> Result<bool, OsError> {
        let subject_label = self.subject_labels.get(&subject_pid)
            .ok_or(OsError::NotFound)?;

        let object_label = self.object_labels.get(&object_id)
            .ok_or(OsError::NotFound)?;

        // Check type enforcement
        let allowed = self.check_type_enforcement(
            &subject_label.label_type,
            &object_label.label_type,
            object_class,
            permission,
        );

        // Check MLS constraints
        let mls_allowed = self.check_mls(subject_label, object_label, permission);

        let result = allowed && mls_allowed;

        if self.config.audit_denied && !result {
            self.audit_access(subject_label, object_label, object_class, permission, AuditResult::Denied);
        } else if self.config.audit_granted && result {
            self.audit_access(subject_label, object_label, object_class, permission, AuditResult::Granted);
        }

        if !result && self.enforcing.load(Ordering::SeqCst) {
            return Ok(false);
        }

        Ok(result || !self.enforcing.load(Ordering::SeqCst))
    }

    /// Set subject label
    pub fn set_subject_label(&mut self, pid: Pid, label: SecurityLabel) {
        self.subject_labels.insert(pid, label);
    }

    /// Set object label
    pub fn set_object_label(&mut self, object_id: u64, label: SecurityLabel) {
        self.object_labels.insert(object_id, label);
    }

    /// Set enforcing mode
    pub fn set_enforcing(&self, enforcing: bool) {
        self.enforcing.store(enforcing, Ordering::SeqCst);
        // Audit this change
    }

    /// Check if enforcing
    pub fn is_enforcing(&self) -> bool {
        self.enforcing.load(Ordering::SeqCst)
    }

    /// Get audit log
    pub fn get_audit_log(&self) -> &VecDeque<SecurityAuditEvent> {
        &self.audit_log
    }

    fn check_type_enforcement(
        &self,
        source_type: &str,
        target_type: &str,
        object_class: &str,
        permission: &str,
    ) -> bool {
        for rule in &self.type_rules {
            if rule.source_type == source_type
                && rule.target_type == target_type
                && rule.object_class == object_class
                && rule.permissions.contains(permission)
            {
                return true;
            }
        }
        false
    }

    fn check_mls(&self, subject: &SecurityLabel, object: &SecurityLabel, permission: &str) -> bool {
        // Bell-LaPadula model:
        // - No read up (subject level >= object level for read)
        // - No write down (subject level <= object level for write)

        match permission {
            "read" | "getattr" | "search" => {
                subject.level >= object.level
            }
            "write" | "append" | "create" | "unlink" => {
                subject.level <= object.level
            }
            _ => {
                // Default: require equal levels
                subject.level == object.level
            }
        }
    }

    fn audit_access(
        &self,
        subject: &SecurityLabel,
        object: &SecurityLabel,
        object_class: &str,
        permission: &str,
        result: AuditResult,
    ) {
        // In a real implementation, this would add to audit log
        let _ = (subject, object, object_class, permission, result);
    }

    fn audit_event(
        &mut self,
        event_type: AuditEventType,
        subject: Option<SecurityLabel>,
        object: Option<SecurityLabel>,
        action: &str,
        result: AuditResult,
        details: String,
    ) {
        self.audit_log.push_back(SecurityAuditEvent {
            timestamp: Instant::now(),
            event_type,
            subject,
            object,
            action: action.to_string(),
            result,
            details,
        });

        if self.audit_log.len() > self.config.max_audit_events {
            self.audit_log.pop_front();
        }
    }
}

impl RbacManager {
    pub fn new() -> Self {
        Self {
            user_roles: HashMap::new(),
            role_permissions: HashMap::new(),
            role_hierarchy: HashMap::new(),
        }
    }

    pub fn assign_role(&mut self, user: &str, role: &str) {
        self.user_roles.entry(user.to_string())
            .or_insert_with(Vec::new)
            .push(role.to_string());
    }

    pub fn add_permission(&mut self, role: &str, permission: &str) {
        self.role_permissions.entry(role.to_string())
            .or_insert_with(HashSet::new)
            .insert(permission.to_string());
    }

    pub fn has_permission(&self, user: &str, permission: &str) -> bool {
        if let Some(roles) = self.user_roles.get(user) {
            for role in roles {
                if self.role_has_permission(role, permission) {
                    return true;
                }
            }
        }
        false
    }

    fn role_has_permission(&self, role: &str, permission: &str) -> bool {
        if let Some(perms) = self.role_permissions.get(role) {
            if perms.contains(permission) {
                return true;
            }
        }

        // Check role hierarchy
        if let Some(parent_roles) = self.role_hierarchy.get(role) {
            for parent in parent_roles {
                if self.role_has_permission(parent, permission) {
                    return true;
                }
            }
        }

        false
    }
}

impl Default for SecurityModuleConfig {
    fn default() -> Self {
        Self {
            enforce_by_default: true,
            audit_denied: true,
            audit_granted: false,
            max_audit_events: 10000,
            default_user: "system_u".to_string(),
            default_role: "system_r".to_string(),
            default_type: "unconfined_t".to_string(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OS ERROR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub enum OsError {
    NotFound,
    PermissionDenied,
    InvalidArgument,
    InvalidState,
    OutOfMemory,
    ResourceBusy,
    IoError(String),
    NetworkError(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENDED TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod extended_tests {
    use super::*;

    #[test]
    fn test_container_runtime_creation() {
        let config = ContainerConfig {
            root_dir: PathBuf::from("/var/lib/containers"),
            state_dir: PathBuf::from("/run/containers"),
            default_runtime: "quanta".to_string(),
            cgroup_driver: CgroupDriver::Cgroupfs,
            enable_seccomp: true,
            enable_apparmor: true,
            default_ulimits: HashMap::new(),
        };

        let runtime = ContainerRuntime::new(config);
        assert!(runtime.containers.is_empty());
    }

    #[test]
    fn test_container_lifecycle() {
        let config = ContainerConfig {
            root_dir: PathBuf::from("/var/lib/containers"),
            state_dir: PathBuf::from("/run/containers"),
            default_runtime: "quanta".to_string(),
            cgroup_driver: CgroupDriver::Cgroupfs,
            enable_seccomp: true,
            enable_apparmor: true,
            default_ulimits: HashMap::new(),
        };

        let mut runtime = ContainerRuntime::new(config);

        // Create container
        let id = runtime.create_container(
            "test",
            "alpine:latest",
            vec!["sh".to_string()],
            HashMap::new(),
        );
        assert!(id.is_ok());

        let id = id.unwrap();

        // Start container
        let result = runtime.start_container(id);
        assert!(result.is_ok());

        // Check state
        let container = runtime.containers.get(&id).unwrap();
        assert_eq!(container.state, ContainerState::Running);

        // Stop container
        let result = runtime.stop_container(id, Duration::from_secs(10));
        assert!(result.is_ok());

        // Remove container
        let result = runtime.remove_container(id);
        assert!(result.is_ok());
    }

    #[test]
    fn test_container_cgroups() {
        let cgroups = ContainerCgroups::new();

        assert_eq!(cgroups.cpu.shares, 1024);
        assert_eq!(cgroups.cpu.quota, -1);
        assert_eq!(cgroups.memory.limit, u64::MAX);
    }

    #[test]
    fn test_power_manager() {
        let mut pm = PowerManager::new(4);

        assert_eq!(pm.cpu_states.len(), 4);
        assert_eq!(pm.active_policy, "balanced");

        // Set CPU frequency
        let result = pm.set_cpu_frequency(0, 2_000_000_000);
        assert!(result.is_ok());

        // Set policy
        let result = pm.set_policy("performance");
        assert!(result.is_ok());
        assert_eq!(pm.active_policy, "performance");
    }

    #[test]
    fn test_power_policy() {
        let balanced = PowerPolicy::balanced();
        let perf = PowerPolicy::performance();
        let save = PowerPolicy::powersave();

        assert!(perf.max_frequency > balanced.max_frequency);
        assert!(save.max_frequency < balanced.max_frequency);
    }

    #[test]
    fn test_device_power_management() {
        let mut pm = PowerManager::new(2);

        // Register device
        pm.register_device(1, "eth0");
        pm.register_device(2, "sda");

        // Set device state
        let result = pm.set_device_state(1, DeviceState::D3Hot);
        assert!(result.is_ok());

        let device = pm.device_states.get(&1).unwrap();
        assert_eq!(device.state, DeviceState::D3Hot);
    }

    #[test]
    fn test_security_module() {
        let config = SecurityModuleConfig::default();
        let mut sec = SecurityModule::new(config);

        // Set subject label
        sec.set_subject_label(1, SecurityLabel {
            user: "system_u".to_string(),
            role: "system_r".to_string(),
            label_type: "init_t".to_string(),
            level: SecurityLevel { sensitivity: 0, categories: vec![] },
            categories: HashSet::new(),
        });

        // Set object label
        sec.set_object_label(100, SecurityLabel {
            user: "system_u".to_string(),
            role: "object_r".to_string(),
            label_type: "etc_t".to_string(),
            level: SecurityLevel { sensitivity: 0, categories: vec![] },
            categories: HashSet::new(),
        });

        assert!(sec.subject_labels.contains_key(&1));
        assert!(sec.object_labels.contains_key(&100));
    }

    #[test]
    fn test_rbac_manager() {
        let mut rbac = RbacManager::new();

        rbac.assign_role("alice", "admin");
        rbac.add_permission("admin", "read_sensitive");
        rbac.add_permission("admin", "write_config");

        assert!(rbac.has_permission("alice", "read_sensitive"));
        assert!(rbac.has_permission("alice", "write_config"));
        assert!(!rbac.has_permission("alice", "delete_users"));
        assert!(!rbac.has_permission("bob", "read_sensitive"));
    }

    #[test]
    fn test_security_level_ordering() {
        let low = SecurityLevel { sensitivity: 0, categories: vec![] };
        let mid = SecurityLevel { sensitivity: 5, categories: vec![] };
        let high = SecurityLevel { sensitivity: 10, categories: vec![] };

        assert!(low < mid);
        assert!(mid < high);
        assert!(low < high);
    }

    #[test]
    fn test_container_namespaces() {
        let ns = ContainerNamespaces::new();

        assert!(ns.pid.is_none());
        assert!(ns.net.is_none());
        assert!(ns.mnt.is_none());
    }

    #[test]
    fn test_security_context_default() {
        let ctx = SecurityContext::default();

        assert!(!ctx.privileged);
        assert!(ctx.capabilities_add.is_empty());
        assert!(!ctx.read_only_root_fs);
    }

    #[test]
    fn test_power_stats() {
        let stats = PowerStats::new();

        assert_eq!(stats.suspend_count, 0);
        assert_eq!(stats.resume_count, 0);
        assert_eq!(stats.total_energy, 0.0);
    }

    #[test]
    fn test_container_stats() {
        let stats = ContainerStats {
            cpu_usage: 25.5,
            memory_usage: 1024 * 1024 * 100,
            memory_limit: 1024 * 1024 * 512,
            network_rx_bytes: 1000,
            network_tx_bytes: 500,
            block_read_bytes: 2000,
            block_write_bytes: 1500,
            pids: 10,
        };

        assert!(stats.memory_usage < stats.memory_limit);
        assert_eq!(stats.pids, 10);
    }
}
