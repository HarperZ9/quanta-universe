// VIRTUAL MEMORY MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Page table entry flags
#[derive(Debug, Clone, Copy)]
pub struct PageFlags(u64);

impl PageFlags {
    pub const PRESENT: u64 = 1 << 0;
    pub const WRITABLE: u64 = 1 << 1;
    pub const USER: u64 = 1 << 2;
    pub const WRITE_THROUGH: u64 = 1 << 3;
    pub const NO_CACHE: u64 = 1 << 4;
    pub const ACCESSED: u64 = 1 << 5;
    pub const DIRTY: u64 = 1 << 6;
    pub const HUGE_PAGE: u64 = 1 << 7;
    pub const GLOBAL: u64 = 1 << 8;
    pub const NO_EXECUTE: u64 = 1 << 63;

    pub fn new() -> Self {
        PageFlags(0)
    }

    pub fn present(mut self) -> Self {
        self.0 |= Self::PRESENT;
        self
    }

    pub fn writable(mut self) -> Self {
        self.0 |= Self::WRITABLE;
        self
    }

    pub fn user(mut self) -> Self {
        self.0 |= Self::USER;
        self
    }

    pub fn no_execute(mut self) -> Self {
        self.0 |= Self::NO_EXECUTE;
        self
    }

    pub fn as_u64(&self) -> u64 {
        self.0
    }

    pub fn is_present(&self) -> bool {
        self.0 & Self::PRESENT != 0
    }

    pub fn is_writable(&self) -> bool {
        self.0 & Self::WRITABLE != 0
    }

    pub fn is_user(&self) -> bool {
        self.0 & Self::USER != 0
    }
}

/// Page table entry
#[derive(Debug, Clone, Copy)]
pub struct PageTableEntry(u64);

impl PageTableEntry {
    pub fn new() -> Self {
        PageTableEntry(0)
    }

    pub fn from_addr(addr: PhysAddr, flags: PageFlags) -> Self {
        PageTableEntry(addr.as_u64() | flags.as_u64())
    }

    pub fn address(&self) -> PhysAddr {
        PhysAddr::new(self.0 & 0x000F_FFFF_FFFF_F000)
    }

    pub fn flags(&self) -> PageFlags {
        PageFlags(self.0 & 0xFFF)
    }

    pub fn is_present(&self) -> bool {
        self.0 & PageFlags::PRESENT != 0
    }

    pub fn set_address(&mut self, addr: PhysAddr) {
        self.0 = (self.0 & 0xFFF) | addr.as_u64();
    }

    pub fn set_flags(&mut self, flags: PageFlags) {
        self.0 = (self.0 & !0xFFF) | flags.as_u64();
    }
}

/// Page table (512 entries)
#[repr(C, align(4096))]
pub struct PageTable {
    entries: [PageTableEntry; 512],
}

impl PageTable {
    pub fn new() -> Self {
        PageTable {
            entries: [PageTableEntry::new(); 512],
        }
    }

    pub fn entry(&self, index: usize) -> &PageTableEntry {
        &self.entries[index]
    }

    pub fn entry_mut(&mut self, index: usize) -> &mut PageTableEntry {
        &mut self.entries[index]
    }
}

/// Virtual address space for a process
pub struct AddressSpace {
    /// Root page table physical address
    pub root: PhysAddr,
    /// VMA (Virtual Memory Area) list
    pub vmas: Vec<VirtualMemoryArea>,
    /// Architecture
    pub arch: Architecture,
}

/// Virtual Memory Area descriptor
#[derive(Debug, Clone)]
pub struct VirtualMemoryArea {
    pub start: VirtAddr,
    pub end: VirtAddr,
    pub flags: VmaFlags,
    pub name: String,
}

#[derive(Debug, Clone, Copy)]
pub struct VmaFlags(u32);

impl VmaFlags {
    pub const READ: u32 = 1 << 0;
    pub const WRITE: u32 = 1 << 1;
    pub const EXECUTE: u32 = 1 << 2;
    pub const SHARED: u32 = 1 << 3;
    pub const GROWSDOWN: u32 = 1 << 4; // Stack

    pub fn new() -> Self {
        VmaFlags(0)
    }

    pub fn read(mut self) -> Self {
        self.0 |= Self::READ;
        self
    }

    pub fn write(mut self) -> Self {
        self.0 |= Self::WRITE;
        self
    }

    pub fn execute(mut self) -> Self {
        self.0 |= Self::EXECUTE;
        self
    }
}

impl AddressSpace {
    pub fn new(arch: Architecture, root: PhysAddr) -> Self {
        AddressSpace {
            root,
            vmas: Vec::new(),
            arch,
        }
    }

    /// Map a virtual address to a physical address
    pub fn map(
        &mut self,
        virt: VirtAddr,
        phys: PhysAddr,
        flags: PageFlags,
        allocator: &mut BuddyAllocator,
    ) -> KernelResult<()> {
        // This would walk the page tables and set up the mapping
        // Simplified for demonstration
        Ok(())
    }

    /// Unmap a virtual address
    pub fn unmap(&mut self, virt: VirtAddr) -> KernelResult<PhysAddr> {
        // Would walk page tables and clear the mapping
        Ok(PhysAddr::new(0))
    }

    /// Add a VMA
    pub fn add_vma(&mut self, vma: VirtualMemoryArea) {
        self.vmas.push(vma);
        self.vmas.sort_by_key(|v| v.start);
    }

    /// Find VMA containing address
    pub fn find_vma(&self, addr: VirtAddr) -> Option<&VirtualMemoryArea> {
        self.vmas.iter().find(|vma| addr.0 >= vma.start.0 && addr.0 < vma.end.0)
    }
}

