// NEURAL PROCESS SCHEDULER™
// ═══════════════════════════════════════════════════════════════════════════════

/// Scheduling policy
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SchedulingPolicy {
    Normal,          // Time-sharing
    Fifo,            // First-in-first-out real-time
    RoundRobin,      // Round-robin real-time
    Deadline,        // Earliest deadline first
    AIOptimized,     // ML-based scheduling (Neural Scheduler)
}

/// Priority class for the Neural Scheduler
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum PriorityClass {
    Idle = 0,
    Background = 1,
    Normal = 2,
    Interactive = 3,
    AIInference = 4,
    RealTime = 5,
    Critical = 6,
}

/// Neural Scheduler™ - ML-based process scheduling
pub struct NeuralScheduler {
    /// Ready queues for each priority class
    ready_queues: [VecDeque<Tid>; 7],
    /// All processes
    processes: HashMap<Pid, Process>,
    /// All threads
    threads: HashMap<Tid, Thread>,
    /// Running threads per CPU
    running: HashMap<u32, Tid>,
    /// Next PID/TID
    next_pid: Pid,
    next_tid: Tid,
    /// Scheduling statistics for ML
    stats: SchedulerStats,
    /// ML model for priority prediction
    priority_predictor: PriorityPredictor,
    /// Time quantum (microseconds)
    time_quantum: u64,
    /// Current tick
    current_tick: u64,
}

/// Scheduler statistics for ML training
#[derive(Debug, Default)]
pub struct SchedulerStats {
    pub total_context_switches: u64,
    pub total_processes_created: u64,
    pub total_processes_terminated: u64,
    pub avg_wait_time: f64,
    pub avg_turnaround_time: f64,
    pub cpu_utilization: f64,
    pub throughput: f64,
    pub ai_inference_count: u64,
}

/// ML-based priority predictor
pub struct PriorityPredictor {
    /// Feature weights for priority prediction
    weights: Vec<f64>,
    /// Learning rate
    learning_rate: f64,
    /// Training samples
    samples: Vec<PrioritySample>,
}

#[derive(Debug, Clone)]
struct PrioritySample {
    features: Vec<f64>,
    actual_priority: f32,
}

impl PriorityPredictor {
    pub fn new() -> Self {
        PriorityPredictor {
            weights: vec![0.0; 10], // 10 features
            learning_rate: 0.01,
            samples: Vec::new(),
        }
    }

    /// Predict optimal priority for a process
    pub fn predict(&self, process: &Process, thread: &Thread) -> f32 {
        let features = self.extract_features(process, thread);

        // Linear model prediction
        let mut score: f64 = 0.0;
        for (i, &f) in features.iter().enumerate() {
            if i < self.weights.len() {
                score += f * self.weights[i];
            }
        }

        // Sigmoid to bound between 0 and 1
        (1.0 / (1.0 + (-score).exp())) as f32
    }

    fn extract_features(&self, process: &Process, thread: &Thread) -> Vec<f64> {
        vec![
            process.cpu_time as f64 / 1_000_000.0,           // CPU time (normalized)
            process.priority as f64 / 20.0,                   // Static priority
            process.ai_priority as f64,                       // AI priority
            thread.time_slice as f64 / 100.0,                // Time slice remaining
            process.threads.len() as f64 / 10.0,             // Thread count
            if process.state == ProcessState::AIInference { 1.0 } else { 0.0 },
            process.memory_limit as f64 / (1024.0 * 1024.0 * 1024.0),
            process.ai_models.len() as f64 / 5.0,            // AI model count
            process.children.len() as f64 / 10.0,            // Child process count
            thread.priority as f64 / 20.0,                    // Thread priority
        ]
    }

    /// Update model with feedback
    pub fn update(&mut self, process: &Process, thread: &Thread, actual_performance: f32) {
        let features = self.extract_features(process, thread);
        let predicted = self.predict(process, thread);
        let error = actual_performance - predicted;

        // Gradient descent update
        for (i, &f) in features.iter().enumerate() {
            if i < self.weights.len() {
                self.weights[i] += self.learning_rate * error as f64 * f;
            }
        }

        self.samples.push(PrioritySample {
            features,
            actual_priority: actual_performance,
        });

        // Keep only recent samples
        if self.samples.len() > 10000 {
            self.samples.remove(0);
        }
    }
}

impl NeuralScheduler {
    pub fn new() -> Self {
        NeuralScheduler {
            ready_queues: Default::default(),
            processes: HashMap::new(),
            threads: HashMap::new(),
            running: HashMap::new(),
            next_pid: 1,
            next_tid: 1,
            stats: SchedulerStats::default(),
            priority_predictor: PriorityPredictor::new(),
            time_quantum: 10000, // 10ms
            current_tick: 0,
        }
    }

    /// Create a new process
    pub fn spawn_process(&mut self, name: &str, parent: Option<Pid>) -> KernelResult<Pid> {
        let pid = self.next_pid;
        self.next_pid += 1;

        // Create address space (would allocate root page table)
        let address_space = AddressSpace::new(Architecture::X86_64, PhysAddr::new(0));

        let process = Process::new(pid, parent, name, address_space);
        self.processes.insert(pid, process);

        // Create main thread
        let tid = self.spawn_thread(pid)?;

        // Update parent's children list
        if let Some(parent_pid) = parent {
            if let Some(parent_proc) = self.processes.get_mut(&parent_pid) {
                parent_proc.children.push(pid);
            }
        }

        self.stats.total_processes_created += 1;

        Ok(pid)
    }

    /// Create a new thread in a process
    pub fn spawn_thread(&mut self, pid: Pid) -> KernelResult<Tid> {
        let tid = self.next_tid;
        self.next_tid += 1;

        let thread = Thread {
            tid,
            pid,
            state: ThreadState::Ready,
            context: CpuContext::default(),
            kernel_stack: VirtAddr::new(0),
            user_stack: VirtAddr::new(0),
            priority: 0,
            time_slice: 100,
            cpu_affinity: u64::MAX, // All CPUs
            blocked_on: None,
        };

        self.threads.insert(tid, thread);

        if let Some(process) = self.processes.get_mut(&pid) {
            process.add_thread(tid);
            process.state = ProcessState::Ready;

            // Use ML to determine priority queue
            let priority_class = self.compute_priority_class(pid, tid);
            self.ready_queues[priority_class as usize].push_back(tid);
        } else {
            return Err(KernelError::ProcessNotFound);
        }

        Ok(tid)
    }

    /// Compute priority class using Neural Scheduler ML model
    fn compute_priority_class(&self, pid: Pid, tid: Tid) -> PriorityClass {
        let process = match self.processes.get(&pid) {
            Some(p) => p,
            None => return PriorityClass::Normal,
        };

        let thread = match self.threads.get(&tid) {
            Some(t) => t,
            None => return PriorityClass::Normal,
        };

        // AI inference processes get priority boost
        if process.state == ProcessState::AIInference {
            return PriorityClass::AIInference;
        }

        // Use ML model to predict optimal priority
        let ai_priority = self.priority_predictor.predict(process, thread);

        match ai_priority {
            p if p < 0.15 => PriorityClass::Idle,
            p if p < 0.30 => PriorityClass::Background,
            p if p < 0.50 => PriorityClass::Normal,
            p if p < 0.70 => PriorityClass::Interactive,
            p if p < 0.85 => PriorityClass::AIInference,
            _ => PriorityClass::RealTime,
        }
    }

    /// Select next thread to run (main scheduling decision)
    pub fn schedule(&mut self, cpu_id: u32) -> Option<Tid> {
        // Check highest priority queues first
        for priority in (0..7).rev() {
            if let Some(tid) = self.ready_queues[priority].pop_front() {
                if let Some(thread) = self.threads.get_mut(&tid) {
                    thread.state = ThreadState::Running;
                }
                self.running.insert(cpu_id, tid);
                self.stats.total_context_switches += 1;
                return Some(tid);
            }
        }
        None
    }

    /// Yield current thread
    pub fn yield_thread(&mut self, cpu_id: u32) {
        if let Some(tid) = self.running.remove(&cpu_id) {
            if let Some(thread) = self.threads.get_mut(&tid) {
                thread.state = ThreadState::Ready;

                // Re-evaluate priority with ML
                let priority_class = self.compute_priority_class(thread.pid, tid);
                self.ready_queues[priority_class as usize].push_back(tid);
            }
        }
    }

    /// Block a thread
    pub fn block_thread(&mut self, tid: Tid, reason: WaitReason) -> KernelResult<()> {
        if let Some(thread) = self.threads.get_mut(&tid) {
            thread.state = ThreadState::Blocked;
            thread.blocked_on = Some(reason);
            Ok(())
        } else {
            Err(KernelError::ThreadNotFound)
        }
    }

    /// Wake up a thread
    pub fn wake_thread(&mut self, tid: Tid) -> KernelResult<()> {
        if let Some(thread) = self.threads.get_mut(&tid) {
            thread.state = ThreadState::Ready;
            thread.blocked_on = None;

            let priority_class = self.compute_priority_class(thread.pid, tid);
            self.ready_queues[priority_class as usize].push_back(tid);
            Ok(())
        } else {
            Err(KernelError::ThreadNotFound)
        }
    }

    /// Timer tick handler
    pub fn tick(&mut self) {
        self.current_tick += 1;

        // Decrement time slices for running threads
        for (&cpu_id, &tid) in &self.running.clone() {
            if let Some(thread) = self.threads.get_mut(&tid) {
                if thread.time_slice > 0 {
                    thread.time_slice -= 1;
                }

                // Preempt if time slice exhausted
                if thread.time_slice == 0 {
                    thread.time_slice = 100; // Reset
                    self.yield_thread(cpu_id);
                }
            }
        }

        // Update statistics
        let total_threads = self.threads.len();
        let running_threads = self.running.len();
        if total_threads > 0 {
            self.stats.cpu_utilization =
                running_threads as f64 / total_threads as f64;
        }
    }

    /// Exit a process
    pub fn exit_process(&mut self, pid: Pid, exit_code: i32) -> KernelResult<()> {
        if let Some(process) = self.processes.get_mut(&pid) {
            process.state = ProcessState::Zombie;
            process.exit_code = Some(exit_code);

            // Terminate all threads
            for &tid in &process.threads.clone() {
                if let Some(thread) = self.threads.get_mut(&tid) {
                    thread.state = ThreadState::Terminated;
                }
            }

            // Reparent children to init (PID 1)
            for &child_pid in &process.children.clone() {
                if let Some(child) = self.processes.get_mut(&child_pid) {
                    child.parent_pid = Some(1);
                }
            }

            self.stats.total_processes_terminated += 1;
            Ok(())
        } else {
            Err(KernelError::ProcessNotFound)
        }
    }

    /// Get process by PID
    pub fn get_process(&self, pid: Pid) -> Option<&Process> {
        self.processes.get(&pid)
    }

    /// Get thread by TID
    pub fn get_thread(&self, tid: Tid) -> Option<&Thread> {
        self.threads.get(&tid)
    }

    /// Set AI priority for a process
    pub fn set_ai_priority(&mut self, pid: Pid, priority: f32) -> KernelResult<()> {
        if let Some(process) = self.processes.get_mut(&pid) {
            process.ai_priority = priority.clamp(0.0, 1.0);

            // Re-queue threads with new priority
            for &tid in &process.threads {
                // Remove from current queue and re-add
                for queue in &mut self.ready_queues {
                    queue.retain(|&t| t != tid);
                }

                if let Some(thread) = self.threads.get(&tid) {
                    if thread.state == ThreadState::Ready {
                        let priority_class = self.compute_priority_class(pid, tid);
                        self.ready_queues[priority_class as usize].push_back(tid);
                    }
                }
            }

            Ok(())
        } else {
            Err(KernelError::ProcessNotFound)
        }
    }
}

