// PROCESS MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Process identifier
pub type Pid = u64;

/// Thread identifier
pub type Tid = u64;

/// Process state
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ProcessState {
    Created,
    Ready,
    Running,
    Blocked,
    Sleeping,
    Zombie,
    AIInference,   // Waiting for AI inference completion
    Checkpointing, // Being checkpointed
}

/// Thread state
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ThreadState {
    Ready,
    Running,
    Blocked,
    Sleeping,
    Terminated,
}

/// CPU context for context switching
#[derive(Debug, Clone, Default)]
pub struct CpuContext {
    // General purpose registers (x86_64)
    pub rax: u64,
    pub rbx: u64,
    pub rcx: u64,
    pub rdx: u64,
    pub rsi: u64,
    pub rdi: u64,
    pub rbp: u64,
    pub rsp: u64,
    pub r8: u64,
    pub r9: u64,
    pub r10: u64,
    pub r11: u64,
    pub r12: u64,
    pub r13: u64,
    pub r14: u64,
    pub r15: u64,
    // Instruction pointer
    pub rip: u64,
    // Flags
    pub rflags: u64,
    // Segment selectors
    pub cs: u64,
    pub ss: u64,
    pub fs_base: u64,
    pub gs_base: u64,
    // FPU/SSE state (simplified)
    pub fpu_state: [u8; 512],
}

/// Thread Control Block
pub struct Thread {
    pub tid: Tid,
    pub pid: Pid,
    pub state: ThreadState,
    pub context: CpuContext,
    pub kernel_stack: VirtAddr,
    pub user_stack: VirtAddr,
    pub priority: i8,
    pub time_slice: u32,
    pub cpu_affinity: u64,
    pub blocked_on: Option<WaitReason>,
}

#[derive(Debug, Clone)]
pub enum WaitReason {
    IO(u64),           // Waiting on file descriptor
    Sleep(u64),        // Sleep until timestamp
    Mutex(u64),        // Waiting on mutex
    Semaphore(u64),    // Waiting on semaphore
    ChildProcess(Pid), // Waiting for child
    AIInference(u64),  // Waiting for AI inference
}

/// Process Control Block
pub struct Process {
    pub pid: Pid,
    pub parent_pid: Option<Pid>,
    pub state: ProcessState,
    pub name: String,
    pub address_space: AddressSpace,
    pub threads: Vec<Tid>,
    pub children: Vec<Pid>,
    pub file_descriptors: HashMap<u32, FileDescriptor>,
    pub exit_code: Option<i32>,
    // Scheduling
    pub priority: i8,
    pub ai_priority: f32,
    pub cpu_time: u64,
    pub creation_time: u64,
    // Resource limits
    pub memory_limit: usize,
    pub fd_limit: usize,
    // AI-specific
    pub ai_models: Vec<AIModelHandle>,
    pub tensor_pool: Option<TensorPoolHandle>,
    // Checkpointing
    pub last_checkpoint: Option<u64>,
    pub checkpoint_interval: Option<u64>,
}

/// File descriptor
#[derive(Debug, Clone)]
pub struct FileDescriptor {
    pub fd: u32,
    pub file_type: FileType,
    pub flags: u32,
    pub offset: u64,
    pub inode: u64,
}

#[derive(Debug, Clone, Copy)]
pub enum FileType {
    Regular,
    Directory,
    CharDevice,
    BlockDevice,
    Pipe,
    Socket,
    Symlink,
}

/// AI model handle
#[derive(Debug, Clone)]
pub struct AIModelHandle {
    pub id: u64,
    pub name: String,
    pub memory_usage: usize,
    pub loaded: bool,
}

/// Tensor pool handle for zero-copy sharing
#[derive(Debug, Clone)]
pub struct TensorPoolHandle {
    pub id: u64,
    pub size: usize,
    pub shared_with: Vec<Pid>,
}

impl Process {
    pub fn new(
        pid: Pid,
        parent: Option<Pid>,
        name: &str,
        address_space: AddressSpace,
    ) -> Self {
        Process {
            pid,
            parent_pid: parent,
            state: ProcessState::Created,
            name: name.to_string(),
            address_space,
            threads: Vec::new(),
            children: Vec::new(),
            file_descriptors: HashMap::new(),
            exit_code: None,
            priority: 0,
            ai_priority: 0.5,
            cpu_time: 0,
            creation_time: 0,
            memory_limit: 1024 * 1024 * 1024, // 1GB default
            fd_limit: MAX_FDS_PER_PROCESS,
            ai_models: Vec::new(),
            tensor_pool: None,
            last_checkpoint: None,
            checkpoint_interval: None,
        }
    }

    pub fn add_thread(&mut self, tid: Tid) {
        self.threads.push(tid);
    }

    pub fn remove_thread(&mut self, tid: Tid) {
        self.threads.retain(|&t| t != tid);
    }
}

