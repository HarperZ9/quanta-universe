// INTER-PROCESS COMMUNICATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Shared memory region
pub struct SharedMemory {
    pub id: u64,
    pub key: u64,
    pub size: usize,
    pub phys_addr: PhysAddr,
    pub owner_pid: Pid,
    pub permissions: u32,
    pub attached: HashMap<Pid, VirtAddr>,
    pub created: u64,
    pub last_attach: u64,
    pub last_detach: u64,
}

/// Message queue
pub struct MessageQueue {
    pub id: u64,
    pub key: u64,
    pub messages: VecDeque<Message>,
    pub max_messages: usize,
    pub max_size: usize,
    pub current_size: usize,
    pub owner_pid: Pid,
    pub permissions: u32,
    pub senders_waiting: VecDeque<Tid>,
    pub receivers_waiting: VecDeque<Tid>,
}

/// IPC message
#[derive(Clone)]
pub struct Message {
    pub msg_type: i64,
    pub data: Vec<u8>,
    pub sender_pid: Pid,
    pub timestamp: u64,
}

/// Semaphore
pub struct Semaphore {
    pub id: u64,
    pub key: u64,
    pub value: i32,
    pub max_value: i32,
    pub owner_pid: Pid,
    pub permissions: u32,
    pub waiters: VecDeque<Tid>,
}

/// Named pipe (FIFO)
pub struct NamedPipe {
    pub path: String,
    pub buffer: VecDeque<u8>,
    pub buffer_size: usize,
    pub readers: Vec<(Pid, u32)>,  // (pid, fd)
    pub writers: Vec<(Pid, u32)>,
    pub read_waiters: VecDeque<Tid>,
    pub write_waiters: VecDeque<Tid>,
}

/// Unix domain socket
pub struct UnixSocket {
    pub path: Option<String>,
    pub socket_type: SocketType,
    pub state: SocketState,
    pub peer: Option<u64>,
    pub recv_buffer: VecDeque<u8>,
    pub send_buffer: VecDeque<u8>,
    pub credentials: Credentials,
    pub ancillary: VecDeque<AncillaryData>,
}

#[derive(Clone, Debug)]
pub struct Credentials {
    pub pid: Pid,
    pub uid: u32,
    pub gid: u32,
}

#[derive(Clone)]
pub enum AncillaryData {
    FileDescriptors(Vec<u32>),
    Credentials(Credentials),
}

/// Signal
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum Signal {
    SIGHUP = 1,
    SIGINT = 2,
    SIGQUIT = 3,
    SIGILL = 4,
    SIGTRAP = 5,
    SIGABRT = 6,
    SIGBUS = 7,
    SIGFPE = 8,
    SIGKILL = 9,
    SIGUSR1 = 10,
    SIGSEGV = 11,
    SIGUSR2 = 12,
    SIGPIPE = 13,
    SIGALRM = 14,
    SIGTERM = 15,
    SIGCHLD = 17,
    SIGCONT = 18,
    SIGSTOP = 19,
    SIGTSTP = 20,
}

/// Signal handler
pub enum SignalHandler {
    Default,
    Ignore,
    Custom(VirtAddr),
}

/// Signal mask
#[derive(Clone, Copy, Default)]
pub struct SignalMask(pub u64);

impl SignalMask {
    pub fn block(&mut self, sig: Signal) {
        self.0 |= 1 << (sig as u64);
    }

    pub fn unblock(&mut self, sig: Signal) {
        self.0 &= !(1 << (sig as u64));
    }

    pub fn is_blocked(&self, sig: Signal) -> bool {
        self.0 & (1 << (sig as u64)) != 0
    }
}

/// IPC Manager
pub struct IpcManager {
    shared_memory: HashMap<u64, SharedMemory>,
    message_queues: HashMap<u64, MessageQueue>,
    semaphores: HashMap<u64, Semaphore>,
    pipes: HashMap<String, NamedPipe>,
    unix_sockets: HashMap<u64, UnixSocket>,
    next_ipc_id: u64,
    key_to_shm: HashMap<u64, u64>,
    key_to_mq: HashMap<u64, u64>,
    key_to_sem: HashMap<u64, u64>,
}

impl IpcManager {
    pub fn new() -> Self {
        IpcManager {
            shared_memory: HashMap::new(),
            message_queues: HashMap::new(),
            semaphores: HashMap::new(),
            pipes: HashMap::new(),
            unix_sockets: HashMap::new(),
            next_ipc_id: 1,
            key_to_shm: HashMap::new(),
            key_to_mq: HashMap::new(),
            key_to_sem: HashMap::new(),
        }
    }

    /// Create shared memory segment
    pub fn shmget(&mut self, key: u64, size: usize, flags: u32, pid: Pid) -> KernelResult<u64> {
        if let Some(&id) = self.key_to_shm.get(&key) {
            return Ok(id);
        }

        let id = self.next_ipc_id;
        self.next_ipc_id += 1;

        let shm = SharedMemory {
            id,
            key,
            size,
            phys_addr: PhysAddr::new(0), // Would allocate physical memory
            owner_pid: pid,
            permissions: flags & 0o777,
            attached: HashMap::new(),
            created: 0,
            last_attach: 0,
            last_detach: 0,
        };

        self.shared_memory.insert(id, shm);
        self.key_to_shm.insert(key, id);

        Ok(id)
    }

    /// Attach shared memory
    pub fn shmat(&mut self, id: u64, pid: Pid, addr: Option<VirtAddr>) -> KernelResult<VirtAddr> {
        let shm = self.shared_memory.get_mut(&id).ok_or(KernelError::InvalidAddress)?;

        let virt = addr.unwrap_or(VirtAddr::new(0x7F000000)); // Would find free region
        shm.attached.insert(pid, virt);
        shm.last_attach = 0; // Would use current time

        Ok(virt)
    }

    /// Detach shared memory
    pub fn shmdt(&mut self, id: u64, pid: Pid) -> KernelResult<()> {
        let shm = self.shared_memory.get_mut(&id).ok_or(KernelError::InvalidAddress)?;
        shm.attached.remove(&pid);
        shm.last_detach = 0;
        Ok(())
    }

    /// Create message queue
    pub fn msgget(&mut self, key: u64, flags: u32, pid: Pid) -> KernelResult<u64> {
        if let Some(&id) = self.key_to_mq.get(&key) {
            return Ok(id);
        }

        let id = self.next_ipc_id;
        self.next_ipc_id += 1;

        let mq = MessageQueue {
            id,
            key,
            messages: VecDeque::new(),
            max_messages: 1024,
            max_size: 1024 * 1024,
            current_size: 0,
            owner_pid: pid,
            permissions: flags & 0o777,
            senders_waiting: VecDeque::new(),
            receivers_waiting: VecDeque::new(),
        };

        self.message_queues.insert(id, mq);
        self.key_to_mq.insert(key, id);

        Ok(id)
    }

    /// Send message
    pub fn msgsnd(&mut self, id: u64, msg_type: i64, data: &[u8], pid: Pid) -> KernelResult<()> {
        let mq = self.message_queues.get_mut(&id).ok_or(KernelError::InvalidAddress)?;

        if mq.current_size + data.len() > mq.max_size {
            return Err(KernelError::ResourceBusy);
        }

        mq.messages.push_back(Message {
            msg_type,
            data: data.to_vec(),
            sender_pid: pid,
            timestamp: 0,
        });
        mq.current_size += data.len();

        // Wake up receivers
        if let Some(tid) = mq.receivers_waiting.pop_front() {
            // Would wake thread
        }

        Ok(())
    }

    /// Receive message
    pub fn msgrcv(&mut self, id: u64, msg_type: i64) -> KernelResult<Message> {
        let mq = self.message_queues.get_mut(&id).ok_or(KernelError::InvalidAddress)?;

        let idx = mq.messages.iter().position(|m| {
            if msg_type == 0 {
                true
            } else if msg_type > 0 {
                m.msg_type == msg_type
            } else {
                m.msg_type <= -msg_type
            }
        });

        if let Some(i) = idx {
            let msg = mq.messages.remove(i).unwrap();
            mq.current_size -= msg.data.len();
            Ok(msg)
        } else {
            Err(KernelError::ResourceBusy)
        }
    }

    /// Create semaphore
    pub fn semget(&mut self, key: u64, value: i32, flags: u32, pid: Pid) -> KernelResult<u64> {
        if let Some(&id) = self.key_to_sem.get(&key) {
            return Ok(id);
        }

        let id = self.next_ipc_id;
        self.next_ipc_id += 1;

        let sem = Semaphore {
            id,
            key,
            value,
            max_value: i32::MAX,
            owner_pid: pid,
            permissions: flags & 0o777,
            waiters: VecDeque::new(),
        };

        self.semaphores.insert(id, sem);
        self.key_to_sem.insert(key, id);

        Ok(id)
    }

    /// Semaphore wait (P operation)
    pub fn sem_wait(&mut self, id: u64, tid: Tid) -> KernelResult<bool> {
        let sem = self.semaphores.get_mut(&id).ok_or(KernelError::InvalidAddress)?;

        if sem.value > 0 {
            sem.value -= 1;
            Ok(true)
        } else {
            sem.waiters.push_back(tid);
            Ok(false)
        }
    }

    /// Semaphore signal (V operation)
    pub fn sem_signal(&mut self, id: u64) -> KernelResult<Option<Tid>> {
        let sem = self.semaphores.get_mut(&id).ok_or(KernelError::InvalidAddress)?;

        if let Some(tid) = sem.waiters.pop_front() {
            Ok(Some(tid))
        } else {
            sem.value += 1;
            Ok(None)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYNCHRONIZATION PRIMITIVES
// ═══════════════════════════════════════════════════════════════════════════════

/// Kernel mutex
pub struct KMutex {
    locked: AtomicBool,
    owner: Mutex<Option<Tid>>,
    waiters: Mutex<VecDeque<Tid>>,
    priority_ceiling: Option<i8>,
}

impl KMutex {
    pub fn new() -> Self {
        KMutex {
            locked: AtomicBool::new(false),
            owner: Mutex::new(None),
            waiters: Mutex::new(VecDeque::new()),
            priority_ceiling: None,
        }
    }

    pub fn with_priority_ceiling(ceiling: i8) -> Self {
        let mut m = Self::new();
        m.priority_ceiling = Some(ceiling);
        m
    }

    pub fn try_lock(&self, tid: Tid) -> bool {
        if self.locked.compare_exchange(
            false,
            true,
            std::sync::atomic::Ordering::Acquire,
            std::sync::atomic::Ordering::Relaxed,
        ).is_ok() {
            *self.owner.lock().unwrap() = Some(tid);
            true
        } else {
            false
        }
    }

    pub fn lock(&self, tid: Tid) -> bool {
        if self.try_lock(tid) {
            return true;
        }

        self.waiters.lock().unwrap().push_back(tid);
        false
    }

    pub fn unlock(&self) -> Option<Tid> {
        let mut owner = self.owner.lock().unwrap();
        *owner = None;

        let mut waiters = self.waiters.lock().unwrap();
        if let Some(next_tid) = waiters.pop_front() {
            *owner = Some(next_tid);
            Some(next_tid)
        } else {
            self.locked.store(false, std::sync::atomic::Ordering::Release);
            None
        }
    }
}

/// Read-write lock
pub struct KRwLock {
    readers: AtomicU64,
    writer: AtomicBool,
    writer_tid: Mutex<Option<Tid>>,
    read_waiters: Mutex<VecDeque<Tid>>,
    write_waiters: Mutex<VecDeque<Tid>>,
}

impl KRwLock {
    pub fn new() -> Self {
        KRwLock {
            readers: AtomicU64::new(0),
            writer: AtomicBool::new(false),
            writer_tid: Mutex::new(None),
            read_waiters: Mutex::new(VecDeque::new()),
            write_waiters: Mutex::new(VecDeque::new()),
        }
    }

    pub fn read_lock(&self, tid: Tid) -> bool {
        if !self.writer.load(std::sync::atomic::Ordering::Acquire) {
            self.readers.fetch_add(1, std::sync::atomic::Ordering::Acquire);
            true
        } else {
            self.read_waiters.lock().unwrap().push_back(tid);
            false
        }
    }

    pub fn read_unlock(&self) {
        self.readers.fetch_sub(1, std::sync::atomic::Ordering::Release);
    }

    pub fn write_lock(&self, tid: Tid) -> bool {
        if self.readers.load(std::sync::atomic::Ordering::Acquire) == 0 {
            if self.writer.compare_exchange(
                false,
                true,
                std::sync::atomic::Ordering::Acquire,
                std::sync::atomic::Ordering::Relaxed,
            ).is_ok() {
                *self.writer_tid.lock().unwrap() = Some(tid);
                return true;
            }
        }
        self.write_waiters.lock().unwrap().push_back(tid);
        false
    }

    pub fn write_unlock(&self) -> Vec<Tid> {
        *self.writer_tid.lock().unwrap() = None;
        self.writer.store(false, std::sync::atomic::Ordering::Release);

        // Wake all waiting readers or one writer
        let mut to_wake = Vec::new();
        let mut write_waiters = self.write_waiters.lock().unwrap();

        if let Some(tid) = write_waiters.pop_front() {
            to_wake.push(tid);
        } else {
            let mut read_waiters = self.read_waiters.lock().unwrap();
            to_wake.extend(read_waiters.drain(..));
        }

        to_wake
    }
}

/// Condition variable
pub struct KCondVar {
    waiters: Mutex<VecDeque<Tid>>,
}

impl KCondVar {
    pub fn new() -> Self {
        KCondVar {
            waiters: Mutex::new(VecDeque::new()),
        }
    }

    pub fn wait(&self, tid: Tid) {
        self.waiters.lock().unwrap().push_back(tid);
    }

    pub fn signal(&self) -> Option<Tid> {
        self.waiters.lock().unwrap().pop_front()
    }

    pub fn broadcast(&self) -> Vec<Tid> {
        self.waiters.lock().unwrap().drain(..).collect()
    }
}

/// Barrier
pub struct KBarrier {
    count: u32,
    waiting: AtomicU64,
    waiters: Mutex<Vec<Tid>>,
    generation: AtomicU64,
}

impl KBarrier {
    pub fn new(count: u32) -> Self {
        KBarrier {
            count,
            waiting: AtomicU64::new(0),
            waiters: Mutex::new(Vec::new()),
            generation: AtomicU64::new(0),
        }
    }

    pub fn wait(&self, tid: Tid) -> Option<Vec<Tid>> {
        let n = self.waiting.fetch_add(1, std::sync::atomic::Ordering::SeqCst) + 1;

        if n as u32 == self.count {
            self.waiting.store(0, std::sync::atomic::Ordering::SeqCst);
            self.generation.fetch_add(1, std::sync::atomic::Ordering::SeqCst);
            Some(self.waiters.lock().unwrap().drain(..).collect())
        } else {
            self.waiters.lock().unwrap().push(tid);
            None
        }
    }
}

/// Spinlock for interrupt handlers
pub struct Spinlock {
    locked: AtomicBool,
}

impl Spinlock {
    pub const fn new() -> Self {
        Spinlock {
            locked: AtomicBool::new(false),
        }
    }

    pub fn lock(&self) {
        while self.locked.compare_exchange_weak(
            false,
            true,
            std::sync::atomic::Ordering::Acquire,
            std::sync::atomic::Ordering::Relaxed,
        ).is_err() {
            std::hint::spin_loop();
        }
    }

    pub fn unlock(&self) {
        self.locked.store(false, std::sync::atomic::Ordering::Release);
    }

    pub fn try_lock(&self) -> bool {
        self.locked.compare_exchange(
            false,
            true,
            std::sync::atomic::Ordering::Acquire,
            std::sync::atomic::Ordering::Relaxed,
        ).is_ok()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECURITY SUBSYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// User ID
pub type Uid = u32;
/// Group ID
pub type Gid = u32;

/// Process credentials
#[derive(Clone, Debug)]
pub struct ProcessCredentials {
    pub uid: Uid,
    pub gid: Gid,
    pub euid: Uid,  // Effective UID
    pub egid: Gid,  // Effective GID
    pub suid: Uid,  // Saved UID
    pub sgid: Gid,  // Saved GID
    pub fsuid: Uid, // Filesystem UID
    pub fsgid: Gid, // Filesystem GID
    pub groups: Vec<Gid>,
    pub capabilities: CapabilitySet,
    pub securebits: u32,
}

/// Linux-style capabilities
#[derive(Clone, Copy, Debug, Default)]
pub struct CapabilitySet {
    pub effective: u64,
    pub permitted: u64,
    pub inheritable: u64,
    pub bounding: u64,
    pub ambient: u64,
}

impl CapabilitySet {
    pub const CAP_CHOWN: u64 = 1 << 0;
    pub const CAP_DAC_OVERRIDE: u64 = 1 << 1;
    pub const CAP_DAC_READ_SEARCH: u64 = 1 << 2;
    pub const CAP_FOWNER: u64 = 1 << 3;
    pub const CAP_FSETID: u64 = 1 << 4;
    pub const CAP_KILL: u64 = 1 << 5;
    pub const CAP_SETGID: u64 = 1 << 6;
    pub const CAP_SETUID: u64 = 1 << 7;
    pub const CAP_SETPCAP: u64 = 1 << 8;
    pub const CAP_NET_BIND_SERVICE: u64 = 1 << 10;
    pub const CAP_NET_RAW: u64 = 1 << 13;
    pub const CAP_SYS_CHROOT: u64 = 1 << 18;
    pub const CAP_SYS_PTRACE: u64 = 1 << 19;
    pub const CAP_SYS_ADMIN: u64 = 1 << 21;
    pub const CAP_SYS_BOOT: u64 = 1 << 22;
    pub const CAP_SYS_RESOURCE: u64 = 1 << 24;
    pub const CAP_MKNOD: u64 = 1 << 27;

    pub fn has(&self, cap: u64) -> bool {
        self.effective & cap != 0
    }

    pub fn grant(&mut self, cap: u64) {
        self.effective |= cap;
        self.permitted |= cap;
    }

    pub fn revoke(&mut self, cap: u64) {
        self.effective &= !cap;
    }
}

/// Mandatory Access Control (MAC) label
#[derive(Clone, Debug)]
pub struct SecurityLabel {
    pub user: String,
    pub role: String,
    pub type_: String,
    pub level: SecurityLevel,
}

#[derive(Clone, Debug)]
pub struct SecurityLevel {
    pub sensitivity: u16,
    pub categories: Vec<u16>,
}

/// Seccomp filter mode
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum SeccompMode {
    Disabled,
    Strict,
    Filter,
}

/// Seccomp BPF filter
#[derive(Clone)]
pub struct SeccompFilter {
    pub mode: SeccompMode,
    pub rules: Vec<SeccompRule>,
}

#[derive(Clone)]
pub struct SeccompRule {
    pub syscall: u64,
    pub action: SeccompAction,
    pub args: Vec<SeccompArg>,
}

#[derive(Clone, Copy, Debug)]
pub enum SeccompAction {
    Allow,
    Kill,
    Trap,
    Errno(i32),
    Trace,
    Log,
}

#[derive(Clone)]
pub struct SeccompArg {
    pub index: u8,
    pub op: SeccompOp,
    pub value: u64,
}

#[derive(Clone, Copy)]
pub enum SeccompOp {
    Eq,
    Ne,
    Lt,
    Le,
    Gt,
    Ge,
    MaskedEq(u64),
}

impl SeccompFilter {
    pub fn new(mode: SeccompMode) -> Self {
        SeccompFilter {
            mode,
            rules: Vec::new(),
        }
    }

    pub fn add_rule(&mut self, rule: SeccompRule) {
        self.rules.push(rule);
    }

    pub fn check(&self, syscall: u64, args: &[u64]) -> SeccompAction {
        if self.mode == SeccompMode::Disabled {
            return SeccompAction::Allow;
        }

        if self.mode == SeccompMode::Strict {
            return match syscall {
                SYS_READ | SYS_WRITE | SYS_EXIT => SeccompAction::Allow,
                _ => SeccompAction::Kill,
            };
        }

        for rule in &self.rules {
            if rule.syscall == syscall && self.match_args(&rule.args, args) {
                return rule.action;
            }
        }

        SeccompAction::Allow
    }

    fn match_args(&self, rule_args: &[SeccompArg], actual_args: &[u64]) -> bool {
        for arg in rule_args {
            if arg.index as usize >= actual_args.len() {
                return false;
            }

            let val = actual_args[arg.index as usize];
            let matches = match arg.op {
                SeccompOp::Eq => val == arg.value,
                SeccompOp::Ne => val != arg.value,
                SeccompOp::Lt => val < arg.value,
                SeccompOp::Le => val <= arg.value,
                SeccompOp::Gt => val > arg.value,
                SeccompOp::Ge => val >= arg.value,
                SeccompOp::MaskedEq(mask) => (val & mask) == arg.value,
            };

            if !matches {
                return false;
            }
        }
        true
    }
}

/// Security manager
pub struct SecurityManager {
    mac_enabled: bool,
    audit_enabled: bool,
    audit_log: Vec<AuditEvent>,
}

#[derive(Clone, Debug)]
pub struct AuditEvent {
    pub timestamp: u64,
    pub pid: Pid,
    pub uid: Uid,
    pub event_type: AuditEventType,
    pub result: AuditResult,
    pub details: String,
}

#[derive(Clone, Copy, Debug)]
pub enum AuditEventType {
    Syscall,
    FileAccess,
    NetworkAccess,
    ProcessCreate,
    ProcessExit,
    CapabilityUse,
    SecurityViolation,
}

#[derive(Clone, Copy, Debug)]
pub enum AuditResult {
    Success,
    Denied,
    Failed,
}

impl SecurityManager {
    pub fn new() -> Self {
        SecurityManager {
            mac_enabled: false,
            audit_enabled: false,
            audit_log: Vec::new(),
        }
    }

    pub fn enable_mac(&mut self) {
        self.mac_enabled = true;
    }

    pub fn enable_audit(&mut self) {
        self.audit_enabled = true;
    }

    pub fn check_permission(
        &mut self,
        creds: &ProcessCredentials,
        resource: &str,
        action: &str,
    ) -> bool {
        // Check capabilities
        let allowed = match action {
            "chown" => creds.capabilities.has(CapabilitySet::CAP_CHOWN),
            "kill" => creds.capabilities.has(CapabilitySet::CAP_KILL),
            "bind_low_port" => creds.capabilities.has(CapabilitySet::CAP_NET_BIND_SERVICE),
            _ => true,
        };

        if self.audit_enabled {
            self.audit_log.push(AuditEvent {
                timestamp: 0,
                pid: 0,
                uid: creds.uid,
                event_type: AuditEventType::FileAccess,
                result: if allowed { AuditResult::Success } else { AuditResult::Denied },
                details: format!("{} on {}", action, resource),
            });
        }

        allowed
    }
}

