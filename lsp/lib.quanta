            None => self.make_result_response(id, JsonValue::Null),
        }
    }

    fn handle_folding_range(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let ranges = self.folding_range_provider.provide_folding_ranges(&doc);

        let json_ranges: Vec<JsonValue> = ranges.iter().map(|r| {
            let mut fr = HashMap::new();
            fr.insert("startLine".to_string(), JsonValue::Number(r.start_line as f64));
            fr.insert("endLine".to_string(), JsonValue::Number(r.end_line as f64));
            if let Some(sc) = r.start_character {
                fr.insert("startCharacter".to_string(), JsonValue::Number(sc as f64));
            }
            if let Some(ec) = r.end_character {
                fr.insert("endCharacter".to_string(), JsonValue::Number(ec as f64));
            }
            fr.insert("kind".to_string(), JsonValue::String(
                match r.kind {
                    FoldingRangeKind::Comment => "comment",
                    FoldingRangeKind::Imports => "imports",
                    FoldingRangeKind::Region => "region",
                }.to_string()
            ));
            JsonValue::Object(fr)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_ranges))
    }

    fn handle_selection_range(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let positions: Vec<Position> = params.and_then(|p| p.get("positions"))
            .and_then(|ps| ps.as_array())
            .map(|arr| arr.iter().filter_map(|p| self.parse_position(p)).collect())
            .unwrap_or_default();

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let ranges = self.selection_range_provider.provide_selection_ranges(&doc, &positions);

        let json_ranges: Vec<JsonValue> = ranges.iter().map(|r| {
            match r {
                Some(sr) => self.selection_range_to_json(sr),
                None => JsonValue::Null,
            }
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_ranges))
    }

    fn handle_semantic_tokens(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        if !self.configuration.semantic_tokens_enabled {
            return self.make_result_response(id, JsonValue::Object({
                let mut r = HashMap::new();
                r.insert("data".to_string(), JsonValue::Array(Vec::new()));
                r
            }));
        }

        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Object({
                let mut r = HashMap::new();
                r.insert("data".to_string(), JsonValue::Array(Vec::new()));
                r
            })),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Object({
                let mut r = HashMap::new();
                r.insert("data".to_string(), JsonValue::Array(Vec::new()));
                r
            })),
        };

        let mut tokenizer = SemanticTokenizer::new();
        tokenizer.tokenize(&doc);
        let data = tokenizer.get_data();

        let json_data: Vec<JsonValue> = data.iter().map(|n| JsonValue::Number(*n as f64)).collect();

        self.make_result_response(id, JsonValue::Object({
            let mut r = HashMap::new();
            r.insert("data".to_string(), JsonValue::Array(json_data));
            r
        }))
    }

    fn handle_inlay_hint(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        if !self.configuration.inlay_hints_enabled {
            return self.make_result_response(id, JsonValue::Array(Vec::new()));
        }

        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let range = match params.and_then(|p| p.get("range")).and_then(|r| self.parse_range(r)) {
            Some(r) => r,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let scope_mgr = self.scope_manager.lock().unwrap();
        let hints = self.inlay_hint_provider.provide_hints(&doc, range, &scope_mgr);

        let json_hints: Vec<JsonValue> = hints.iter().map(|hint| {
            let mut h = HashMap::new();
            h.insert("position".to_string(), self.position_to_json(&hint.position));
            h.insert("label".to_string(), JsonValue::String(hint.label.clone()));
            h.insert("kind".to_string(), JsonValue::Number(hint.kind as i32 as f64));
            h.insert("paddingLeft".to_string(), JsonValue::Bool(hint.padding_left));
            h.insert("paddingRight".to_string(), JsonValue::Bool(hint.padding_right));
            if let Some(tooltip) = &hint.tooltip {
                h.insert("tooltip".to_string(), JsonValue::String(tooltip.clone()));
            }
            JsonValue::Object(h)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_hints))
    }

    fn handle_linked_editing_range(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        match self.linked_editing_provider.provide_ranges(&doc, pos) {
            Some(ranges) => {
                let json_ranges: Vec<JsonValue> = ranges.iter().map(|r| self.range_to_json(r)).collect();
                self.make_result_response(id, JsonValue::Object({
                    let mut r = HashMap::new();
                    r.insert("ranges".to_string(), JsonValue::Array(json_ranges));
                    r
                }))
            }
            None => self.make_result_response(id, JsonValue::Null),
        }
    }

    fn handle_prepare_call_hierarchy(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let provider = self.call_hierarchy_provider.lock().unwrap();
        match provider.prepare(&doc, pos) {
            Some(item) => {
                let json_item = self.call_hierarchy_item_to_json(&item);
                self.make_result_response(id, JsonValue::Array(vec![json_item]))
            }
            None => self.make_result_response(id, JsonValue::Array(Vec::new())),
        }
    }

    fn handle_incoming_calls(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        // Parse the item from params
        let item_json = match params.and_then(|p| p.get("item")) {
            Some(i) => i,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let name = item_json.get("name").and_then(|n| n.as_str()).unwrap_or("");
        let uri = item_json.get("uri").and_then(|u| u.as_str()).unwrap_or("");

        let item = CallHierarchyItem {
            name: name.to_string(),
            kind: SymbolKind::Function,
            uri: uri.to_string(),
            range: Range {
                start: Position { line: 0, character: 0 },
                end: Position { line: 0, character: 0 },
            },
            selection_range: Range {
                start: Position { line: 0, character: 0 },
                end: Position { line: 0, character: 0 },
            },
            detail: None,
        };

        let provider = self.call_hierarchy_provider.lock().unwrap();
        let calls = provider.incoming_calls(&item);

        let json_calls: Vec<JsonValue> = calls.iter().map(|call| {
            let mut c = HashMap::new();
            c.insert("from".to_string(), self.call_hierarchy_item_to_json(&call.from));
            c.insert("fromRanges".to_string(), JsonValue::Array(
                call.from_ranges.iter().map(|r| self.range_to_json(r)).collect()
            ));
            JsonValue::Object(c)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_calls))
    }

    fn handle_outgoing_calls(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let item_json = match params.and_then(|p| p.get("item")) {
            Some(i) => i,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let name = item_json.get("name").and_then(|n| n.as_str()).unwrap_or("");
        let uri = item_json.get("uri").and_then(|u| u.as_str()).unwrap_or("");

        let item = CallHierarchyItem {
            name: name.to_string(),
            kind: SymbolKind::Function,
            uri: uri.to_string(),
            range: Range {
                start: Position { line: 0, character: 0 },
                end: Position { line: 0, character: 0 },
            },
            selection_range: Range {
                start: Position { line: 0, character: 0 },
                end: Position { line: 0, character: 0 },
            },
            detail: None,
        };

        let provider = self.call_hierarchy_provider.lock().unwrap();
        let calls = provider.outgoing_calls(&item);

        let json_calls: Vec<JsonValue> = calls.iter().map(|call| {
            let mut c = HashMap::new();
            c.insert("to".to_string(), self.call_hierarchy_item_to_json(&call.to));
            c.insert("fromRanges".to_string(), JsonValue::Array(
                call.from_ranges.iter().map(|r| self.range_to_json(r)).collect()
            ));
            JsonValue::Object(c)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_calls))
    }

    fn handle_workspace_symbol(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let query = params.and_then(|p| p.get("query")).and_then(|q| q.as_str()).unwrap_or("");

        let index = self.project_index.read().unwrap();
        let symbols = index.workspace_symbols(query);

        let json_symbols: Vec<JsonValue> = symbols.iter().map(|sym| {
            let mut s = HashMap::new();
            s.insert("name".to_string(), JsonValue::String(sym.name.clone()));
            s.insert("kind".to_string(), JsonValue::Number(sym.kind as i32 as f64));
            s.insert("location".to_string(), JsonValue::Object({
                let mut l = HashMap::new();
                l.insert("uri".to_string(), JsonValue::String(sym.definition_uri.clone()));
                l.insert("range".to_string(), self.range_to_json(&sym.range));
                l
            }));
            JsonValue::Object(s)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_symbols))
    }

    fn handle_configuration_change(&mut self, params: Option<&JsonValue>) {
        if let Some(settings) = params.and_then(|p| p.get("settings")) {
            if let Some(quanta) = settings.get("quanta") {
                if let Some(hints) = quanta.get("inlayHints").and_then(|h| h.as_bool()) {
                    self.configuration.inlay_hints_enabled = hints;
                }
                if let Some(tokens) = quanta.get("semanticTokens").and_then(|t| t.as_bool()) {
                    self.configuration.semantic_tokens_enabled = tokens;
                }
                if let Some(fmt) = quanta.get("formatOnSave").and_then(|f| f.as_bool()) {
                    self.configuration.format_on_save = fmt;
                }
                if let Some(fmt) = quanta.get("formatOnType").and_then(|f| f.as_bool()) {
                    self.configuration.format_on_type = fmt;
                }
                if let Some(lens) = quanta.get("codeLens").and_then(|l| l.as_bool()) {
                    self.configuration.code_lens_enabled = lens;
                }
            }
        }
    }

    fn handle_watched_files_change(&mut self, params: Option<&JsonValue>) {
        if let Some(changes) = params.and_then(|p| p.get("changes")).and_then(|c| c.as_array()) {
            for change in changes {
                let uri = change.get("uri").and_then(|u| u.as_str()).unwrap_or("");
                let change_type = change.get("type").and_then(|t| t.as_i64()).unwrap_or(0);

                match change_type {
                    1 | 2 => { // Created or Changed
                        self.analyze_document(uri);
                    }
                    3 => { // Deleted
                        // Remove from index
                    }
                    _ => {}
                }
            }
        }
    }

    fn analyze_document(&mut self, uri: &str) {
        if let Some(doc) = self.documents.get(uri) {
            // Analyze symbols
            let symbols = self.analyzer.analyze_symbols(&doc);

            // Update project index
            let mut index = self.project_index.write().unwrap();
            index.index_file(uri, &doc, &symbols);

            // Analyze call hierarchy
            let mut ch_provider = self.call_hierarchy_provider.lock().unwrap();
            ch_provider.analyze_file(uri, &doc);
        }
    }

    // Helper methods
    fn extract_text_document_position(&self, params: Option<&JsonValue>) -> Option<(String, Position)> {
        let params = params?;
        let uri = params.get("textDocument")?.get("uri")?.as_str()?.to_string();
        let pos = self.parse_position(params.get("position")?)?;
        Some((uri, pos))
    }

    fn parse_position(&self, pos: &JsonValue) -> Option<Position> {
        Some(Position {
            line: pos.get("line")?.as_i64()? as u32,
            character: pos.get("character")?.as_i64()? as u32,
        })
    }

    fn parse_range(&self, range: &JsonValue) -> Option<Range> {
        Some(Range {
            start: self.parse_position(range.get("start")?)?,
            end: self.parse_position(range.get("end")?)?,
        })
    }

    fn get_word_at(&self, line: &str, pos: usize) -> Option<String> {
        let chars: Vec<char> = line.chars().collect();
        if pos >= chars.len() {
            return None;
        }

        let mut start = pos;
        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        let mut end = pos;
        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            None
        } else {
            Some(chars[start..end].iter().collect())
        }
    }

    fn position_to_json(&self, pos: &Position) -> JsonValue {
        JsonValue::Object({
            let mut p = HashMap::new();
            p.insert("line".to_string(), JsonValue::Number(pos.line as f64));
            p.insert("character".to_string(), JsonValue::Number(pos.character as f64));
            p
        })
    }

    fn range_to_json(&self, range: &Range) -> JsonValue {
        JsonValue::Object({
            let mut r = HashMap::new();
            r.insert("start".to_string(), self.position_to_json(&range.start));
            r.insert("end".to_string(), self.position_to_json(&range.end));
            r
        })
    }

    fn text_edit_to_json(&self, edit: &TextEdit) -> JsonValue {
        JsonValue::Object({
            let mut e = HashMap::new();
            e.insert("range".to_string(), self.range_to_json(&edit.range));
            e.insert("newText".to_string(), JsonValue::String(edit.new_text.clone()));
            e
        })
    }

    fn workspace_edit_to_json(&self, edit: &WorkspaceEdit) -> JsonValue {
        let mut changes = HashMap::new();
        for (uri, edits) in &edit.changes {
            changes.insert(uri.clone(), JsonValue::Array(
                edits.iter().map(|e| self.text_edit_to_json(e)).collect()
            ));
        }
        JsonValue::Object({
            let mut e = HashMap::new();
            e.insert("changes".to_string(), JsonValue::Object(changes));
            e
        })
    }

    fn command_to_json(&self, cmd: &Command) -> JsonValue {
        JsonValue::Object({
            let mut c = HashMap::new();
            c.insert("title".to_string(), JsonValue::String(cmd.title.clone()));
            c.insert("command".to_string(), JsonValue::String(cmd.command.clone()));
            c.insert("arguments".to_string(), JsonValue::Array(
                cmd.arguments.iter().map(|a| JsonValue::String(a.clone())).collect()
            ));
            c
        })
    }

    fn document_symbol_to_json(&self, symbol: &DocumentSymbol) -> JsonValue {
        let mut s = HashMap::new();
        s.insert("name".to_string(), JsonValue::String(symbol.name.clone()));
        s.insert("kind".to_string(), JsonValue::Number(symbol.kind as i32 as f64));
        s.insert("range".to_string(), self.range_to_json(&symbol.range));
        s.insert("selectionRange".to_string(), self.range_to_json(&symbol.selection_range));
        if let Some(detail) = &symbol.detail {
            s.insert("detail".to_string(), JsonValue::String(detail.clone()));
        }
        if !symbol.children.is_empty() {
            s.insert("children".to_string(), JsonValue::Array(
                symbol.children.iter().map(|c| self.document_symbol_to_json(c)).collect()
            ));
        }
        JsonValue::Object(s)
    }

    fn selection_range_to_json(&self, sr: &SelectionRange) -> JsonValue {
        let mut s = HashMap::new();
        s.insert("range".to_string(), self.range_to_json(&sr.range));
        if let Some(parent) = &sr.parent {
            s.insert("parent".to_string(), self.selection_range_to_json(parent));
        }
        JsonValue::Object(s)
    }

    fn call_hierarchy_item_to_json(&self, item: &CallHierarchyItem) -> JsonValue {
        let mut i = HashMap::new();
        i.insert("name".to_string(), JsonValue::String(item.name.clone()));
        i.insert("kind".to_string(), JsonValue::Number(item.kind as i32 as f64));
        i.insert("uri".to_string(), JsonValue::String(item.uri.clone()));
        i.insert("range".to_string(), self.range_to_json(&item.range));
        i.insert("selectionRange".to_string(), self.range_to_json(&item.selection_range));
        if let Some(detail) = &item.detail {
            i.insert("detail".to_string(), JsonValue::String(detail.clone()));
        }
        JsonValue::Object(i)
    }

    fn code_action_kind_to_string(&self, kind: &CodeActionKind) -> String {
        match kind {
            CodeActionKind::QuickFix => "quickfix",
            CodeActionKind::Refactor => "refactor",
            CodeActionKind::RefactorExtract => "refactor.extract",
            CodeActionKind::RefactorInline => "refactor.inline",
            CodeActionKind::RefactorRewrite => "refactor.rewrite",
            CodeActionKind::Source => "source",
            CodeActionKind::SourceOrganizeImports => "source.organizeImports",
            CodeActionKind::SourceFixAll => "source.fixAll",
        }.to_string()
    }

    fn make_result_response(&self, id: Option<i64>, result: JsonValue) -> String {
        let mut response = HashMap::new();
        response.insert("jsonrpc".to_string(), JsonValue::String("2.0".to_string()));
        if let Some(id) = id {
            response.insert("id".to_string(), JsonValue::Number(id as f64));
        }
        response.insert("result".to_string(), result);
        JsonSerializer::serialize(&JsonValue::Object(response))
    }

    fn send_response(&self, response: &str) {
        let header = format!("Content-Length: {}\r\n\r\n", response.len());
        let _ = write(stdout(), header.as_bytes());
        let _ = write(stdout(), response.as_bytes());
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEMANTIC TOKENS PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Semantic token types
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum SemanticTokenType {
    Namespace = 0,
    Type = 1,
    Class = 2,
    Enum = 3,
    Interface = 4,
    Struct = 5,
    TypeParameter = 6,
    Parameter = 7,
    Variable = 8,
    Property = 9,
    EnumMember = 10,
    Event = 11,
    Function = 12,
    Method = 13,
    Macro = 14,
    Keyword = 15,
    Modifier = 16,
    Comment = 17,
    String = 18,
    Number = 19,
    Regexp = 20,
    Operator = 21,
    Decorator = 22,
    Label = 23,
}

impl SemanticTokenType {
    pub fn legend() -> Vec<&'static str> {
        vec![
            "namespace", "type", "class", "enum", "interface", "struct",
            "typeParameter", "parameter", "variable", "property", "enumMember",
            "event", "function", "method", "macro", "keyword", "modifier",
            "comment", "string", "number", "regexp", "operator", "decorator", "label",
        ]
    }
}

/// Semantic token modifiers (bitmask)
#[derive(Clone, Copy, Debug)]
pub struct SemanticTokenModifiers(pub u32);

impl SemanticTokenModifiers {
    pub const DECLARATION: u32 = 0b00000001;
    pub const DEFINITION: u32 = 0b00000010;
    pub const READONLY: u32 = 0b00000100;
    pub const STATIC: u32 = 0b00001000;
    pub const DEPRECATED: u32 = 0b00010000;
    pub const ABSTRACT: u32 = 0b00100000;
    pub const ASYNC: u32 = 0b01000000;
    pub const MODIFICATION: u32 = 0b10000000;
    pub const DOCUMENTATION: u32 = 0b100000000;
    pub const DEFAULT_LIBRARY: u32 = 0b1000000000;

    pub fn legend() -> Vec<&'static str> {
        vec![
            "declaration", "definition", "readonly", "static", "deprecated",
            "abstract", "async", "modification", "documentation", "defaultLibrary",
        ]
    }
}

/// A semantic token
#[derive(Clone, Debug)]
pub struct SemanticToken {
    pub line: u32,
    pub start_char: u32,
    pub length: u32,
    pub token_type: SemanticTokenType,
    pub modifiers: SemanticTokenModifiers,
}

/// Semantic tokens result (delta-encoded)
#[derive(Clone, Debug)]
pub struct SemanticTokensData {
    /// Result ID for delta updates
    pub result_id: Option<String>,
    /// Delta-encoded tokens: [deltaLine, deltaStartChar, length, tokenType, tokenModifiers]
    pub data: Vec<u32>,
}

/// Semantic tokens provider
pub struct SemanticTokensProvider {
    cache: RwLock<HashMap<String, SemanticTokensData>>,
    next_result_id: Mutex<u64>,
}

impl SemanticTokensProvider {
    pub fn new() -> Self {
        SemanticTokensProvider {
            cache: RwLock::new(HashMap::new()),
            next_result_id: Mutex::new(0),
        }
    }

    /// Tokenize a document for semantic highlighting
    pub fn tokenize(&self, uri: &str, text: &str) -> SemanticTokensData {
        let tokens = self.extract_tokens(text);
        let data = self.encode_tokens(&tokens);

        let mut id_counter = self.next_result_id.lock().unwrap();
        *id_counter += 1;
        let result_id = format!("{}", *id_counter);

        let result = SemanticTokensData {
            result_id: Some(result_id.clone()),
            data,
        };

        // Cache the result
        let mut cache = self.cache.write().unwrap();
        cache.insert(uri.to_string(), result.clone());

        result
    }

    /// Get delta tokens since previous result
    pub fn tokenize_delta(&self, uri: &str, text: &str, prev_result_id: &str) -> Option<SemanticTokensData> {
        // For simplicity, return full tokens if cache miss
        // A real implementation would compute actual deltas
        Some(self.tokenize(uri, text))
    }

    /// Extract tokens from source text
    fn extract_tokens(&self, text: &str) -> Vec<SemanticToken> {
        let mut tokens = Vec::new();
        let lines: Vec<&str> = text.lines().collect();

        for (line_num, line) in lines.iter().enumerate() {
            self.tokenize_line(line_num as u32, line, &mut tokens);
        }

        tokens
    }

    /// Tokenize a single line
    fn tokenize_line(&self, line: u32, text: &str, tokens: &mut Vec<SemanticToken>) {
        let chars: Vec<char> = text.chars().collect();
        let mut i = 0;

        while i < chars.len() {
            // Skip whitespace
            if chars[i].is_whitespace() {
                i += 1;
                continue;
            }

            // Comments
            if i + 1 < chars.len() && chars[i] == '/' && chars[i + 1] == '/' {
                let start = i;
                let length = chars.len() - i;
                tokens.push(SemanticToken {
                    line,
                    start_char: start as u32,
                    length: length as u32,
                    token_type: SemanticTokenType::Comment,
                    modifiers: SemanticTokenModifiers(0),
                });
                break;
            }

            // String literals
            if chars[i] == '"' {
                let start = i;
                i += 1;
                while i < chars.len() && chars[i] != '"' {
                    if chars[i] == '\\' && i + 1 < chars.len() {
                        i += 2;
                    } else {
                        i += 1;
                    }
                }
                if i < chars.len() {
                    i += 1;
                }
                tokens.push(SemanticToken {
                    line,
                    start_char: start as u32,
                    length: (i - start) as u32,
                    token_type: SemanticTokenType::String,
                    modifiers: SemanticTokenModifiers(0),
                });
                continue;
            }

            // Numbers
            if chars[i].is_ascii_digit() {
                let start = i;
                while i < chars.len() && (chars[i].is_ascii_alphanumeric() || chars[i] == '.' || chars[i] == '_') {
                    i += 1;
                }
                tokens.push(SemanticToken {
                    line,
                    start_char: start as u32,
                    length: (i - start) as u32,
                    token_type: SemanticTokenType::Number,
                    modifiers: SemanticTokenModifiers(0),
                });
                continue;
            }

            // Identifiers and keywords
            if chars[i].is_alphabetic() || chars[i] == '_' {
                let start = i;
                while i < chars.len() && (chars[i].is_alphanumeric() || chars[i] == '_') {
                    i += 1;
                }
                let word: String = chars[start..i].iter().collect();
                let (token_type, modifiers) = self.classify_identifier(&word);
                tokens.push(SemanticToken {
                    line,
                    start_char: start as u32,
                    length: (i - start) as u32,
                    token_type,
                    modifiers,
                });
                continue;
            }

            // Operators
            if self.is_operator(chars[i]) {
                let start = i;
                while i < chars.len() && self.is_operator(chars[i]) {
                    i += 1;
                }
                tokens.push(SemanticToken {
                    line,
                    start_char: start as u32,
                    length: (i - start) as u32,
                    token_type: SemanticTokenType::Operator,
                    modifiers: SemanticTokenModifiers(0),
                });
                continue;
            }

            i += 1;
        }
    }

    fn is_operator(&self, c: char) -> bool {
        matches!(c, '+' | '-' | '*' | '/' | '%' | '=' | '<' | '>' | '!' | '&' | '|' | '^' | '~')
    }

    fn classify_identifier(&self, word: &str) -> (SemanticTokenType, SemanticTokenModifiers) {
        // Keywords
        let keywords = [
            "fn", "let", "mut", "const", "static", "pub", "priv", "mod", "use",
            "struct", "enum", "trait", "impl", "type", "where", "for", "while",
            "loop", "if", "else", "match", "return", "break", "continue", "async",
            "await", "move", "ref", "self", "Self", "super", "crate", "as", "in",
            "dyn", "unsafe", "extern", "true", "false", "None", "Some",
        ];

        if keywords.contains(&word) {
            return (SemanticTokenType::Keyword, SemanticTokenModifiers(0));
        }

        // Type names (PascalCase)
        if word.chars().next().map(|c| c.is_uppercase()).unwrap_or(false) {
            return (SemanticTokenType::Type, SemanticTokenModifiers(0));
        }

        // Constants (SCREAMING_SNAKE_CASE)
        if word.chars().all(|c| c.is_uppercase() || c == '_') && word.len() > 1 {
            return (
                SemanticTokenType::Variable,
                SemanticTokenModifiers(SemanticTokenModifiers::READONLY),
            );
        }

        // Default to variable
        (SemanticTokenType::Variable, SemanticTokenModifiers(0))
    }

    /// Encode tokens in LSP delta format
    fn encode_tokens(&self, tokens: &[SemanticToken]) -> Vec<u32> {
        let mut data = Vec::new();
        let mut prev_line = 0u32;
        let mut prev_char = 0u32;

        for token in tokens {
            let delta_line = token.line - prev_line;
            let delta_char = if delta_line == 0 {
                token.start_char - prev_char
            } else {
                token.start_char
            };

            data.push(delta_line);
            data.push(delta_char);
            data.push(token.length);
            data.push(token.token_type as u32);
            data.push(token.modifiers.0);

            prev_line = token.line;
            prev_char = token.start_char;
        }

        data
    }

    /// Get capabilities for client
    pub fn capabilities() -> JsonValue {
        let mut caps = HashMap::new();

        caps.insert("tokenTypes".to_string(), JsonValue::Array(
            SemanticTokenType::legend().into_iter()
                .map(|s| JsonValue::String(s.to_string()))
                .collect()
        ));

        caps.insert("tokenModifiers".to_string(), JsonValue::Array(
            SemanticTokenModifiers::legend().into_iter()
                .map(|s| JsonValue::String(s.to_string()))
                .collect()
        ));

        JsonValue::Object(caps)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TYPE HIERARCHY PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Type hierarchy item
#[derive(Clone, Debug)]
pub struct TypeHierarchyItem {
    pub name: String,
    pub kind: SymbolKind,
    pub uri: String,
    pub range: Range,
    pub selection_range: Range,
    pub detail: Option<String>,
    pub tags: Vec<SymbolTag>,
    pub data: Option<String>,
}

#[derive(Clone, Copy, Debug)]
pub enum SymbolTag {
    Deprecated = 1,
}

/// Type hierarchy call
#[derive(Clone, Debug)]
pub struct TypeHierarchyCall {
    pub item: TypeHierarchyItem,
    pub from_ranges: Vec<Range>,
}

/// Type hierarchy provider
pub struct TypeHierarchyProvider {
    /// Type inheritance map: type name -> parent types
    supertypes: RwLock<HashMap<String, Vec<String>>>,
    /// Type inheritance map: type name -> child types
    subtypes: RwLock<HashMap<String, Vec<String>>>,
    /// Type locations
    type_locations: RwLock<HashMap<String, TypeHierarchyItem>>,
}

impl TypeHierarchyProvider {
    pub fn new() -> Self {
        TypeHierarchyProvider {
            supertypes: RwLock::new(HashMap::new()),
            subtypes: RwLock::new(HashMap::new()),
            type_locations: RwLock::new(HashMap::new()),
        }
    }

    /// Index type hierarchy from source
    pub fn index_types(&self, uri: &str, text: &str) {
        let lines: Vec<&str> = text.lines().collect();

        for (line_num, line) in lines.iter().enumerate() {
            // Look for struct/enum/trait definitions
            if let Some(type_info) = self.parse_type_definition(line, line_num, uri) {
                let mut locations = self.type_locations.write().unwrap();
                locations.insert(type_info.name.clone(), type_info);
            }

            // Look for impl blocks
            if let Some((impl_type, for_trait)) = self.parse_impl(line) {
                if let Some(trait_name) = for_trait {
                    // Record trait implementation
                    let mut supers = self.supertypes.write().unwrap();
                    supers.entry(impl_type.clone())
                        .or_insert_with(Vec::new)
                        .push(trait_name.clone());

                    let mut subs = self.subtypes.write().unwrap();
                    subs.entry(trait_name)
                        .or_insert_with(Vec::new)
                        .push(impl_type);
                }
            }
        }
    }

    /// Parse type definition from line
    fn parse_type_definition(&self, line: &str, line_num: usize, uri: &str) -> Option<TypeHierarchyItem> {
        let trimmed = line.trim();

        let patterns = [
            ("struct ", SymbolKind::Struct),
            ("enum ", SymbolKind::Enum),
            ("trait ", SymbolKind::Interface),
            ("type ", SymbolKind::TypeParameter),
        ];

        for (pattern, kind) in patterns {
            if let Some(rest) = trimmed.strip_prefix("pub ").or(Some(trimmed)).and_then(|s| s.strip_prefix(pattern)) {
                let name: String = rest.chars()
                    .take_while(|c| c.is_alphanumeric() || *c == '_')
                    .collect();

                if !name.is_empty() {
                    let start_char = line.find(&name).unwrap_or(0) as u32;
                    return Some(TypeHierarchyItem {
                        name: name.clone(),
                        kind,
                        uri: uri.to_string(),
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        selection_range: Range {
                            start: Position { line: line_num as u32, character: start_char },
                            end: Position { line: line_num as u32, character: start_char + name.len() as u32 },
                        },
                        detail: Some(format!("{:?}", kind)),
                        tags: Vec::new(),
                        data: None,
                    });
                }
            }
        }

        None
    }

    /// Parse impl block
    fn parse_impl(&self, line: &str) -> Option<(String, Option<String>)> {
        let trimmed = line.trim();

        if !trimmed.starts_with("impl") {
            return None;
        }

        let rest = trimmed.strip_prefix("impl").unwrap().trim();

        // impl Trait for Type
        if let Some(for_idx) = rest.find(" for ") {
            let trait_name: String = rest[..for_idx].trim()
                .chars()
                .take_while(|c| c.is_alphanumeric() || *c == '_')
                .collect();
            let type_name: String = rest[for_idx + 5..].trim()
                .chars()
                .take_while(|c| c.is_alphanumeric() || *c == '_')
                .collect();

            return Some((type_name, Some(trait_name)));
        }

        // impl Type
        let type_name: String = rest
            .chars()
            .take_while(|c| c.is_alphanumeric() || *c == '_')
            .collect();

        if !type_name.is_empty() {
            Some((type_name, None))
        } else {
            None
        }
    }

    /// Prepare type hierarchy for position
    pub fn prepare(&self, uri: &str, position: Position, text: &str) -> Option<TypeHierarchyItem> {
        // Get the type name at position
        let word = self.word_at_position(text, position)?;

        let locations = self.type_locations.read().unwrap();
        locations.get(&word).cloned()
    }

    /// Get supertypes
    pub fn supertypes(&self, item: &TypeHierarchyItem) -> Vec<TypeHierarchyItem> {
        let supers = self.supertypes.read().unwrap();
        let locations = self.type_locations.read().unwrap();

        supers.get(&item.name)
            .map(|names| {
                names.iter()
                    .filter_map(|n| locations.get(n).cloned())
                    .collect()
            })
            .unwrap_or_default()
    }

    /// Get subtypes
    pub fn subtypes(&self, item: &TypeHierarchyItem) -> Vec<TypeHierarchyItem> {
        let subs = self.subtypes.read().unwrap();
        let locations = self.type_locations.read().unwrap();

        subs.get(&item.name)
            .map(|names| {
                names.iter()
                    .filter_map(|n| locations.get(n).cloned())
                    .collect()
            })
            .unwrap_or_default()
    }

    fn word_at_position(&self, text: &str, pos: Position) -> Option<String> {
        let lines: Vec<&str> = text.lines().collect();
        let line = lines.get(pos.line as usize)?;
        let chars: Vec<char> = line.chars().collect();
        let char_pos = pos.character as usize;

        if char_pos >= chars.len() {
            return None;
        }

        let mut start = char_pos;
        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        let mut end = char_pos;
        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            None
        } else {
            Some(chars[start..end].iter().collect())
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE SYMBOLS PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Workspace symbol for cross-file search
#[derive(Clone, Debug)]
pub struct WorkspaceSymbol {
    pub name: String,
    pub kind: SymbolKind,
    pub location: Location,
    pub container_name: Option<String>,
}

/// Workspace symbols provider
pub struct WorkspaceSymbolsProvider {
    /// All symbols indexed by name
    symbols: RwLock<HashMap<String, Vec<WorkspaceSymbol>>>,
    /// File-to-symbols mapping
    file_symbols: RwLock<HashMap<String, Vec<String>>>,
}

impl WorkspaceSymbolsProvider {
    pub fn new() -> Self {
        WorkspaceSymbolsProvider {
            symbols: RwLock::new(HashMap::new()),
            file_symbols: RwLock::new(HashMap::new()),
        }
    }

    /// Index a file
    pub fn index_file(&self, uri: &str, text: &str) {
        let mut new_symbols = Vec::new();

        // Remove old symbols for this file
        {
            let mut file_symbols = self.file_symbols.write().unwrap();
            if let Some(old_names) = file_symbols.remove(uri) {
                let mut symbols = self.symbols.write().unwrap();
                for name in old_names {
                    if let Some(list) = symbols.get_mut(&name) {
                        list.retain(|s| s.location.uri != uri);
                        if list.is_empty() {
                            symbols.remove(&name);
                        }
                    }
                }
            }
        }

        // Parse symbols
        let lines: Vec<&str> = text.lines().collect();
        let mut current_container: Option<String> = None;

        for (line_num, line) in lines.iter().enumerate() {
            let trimmed = line.trim();

            // Module/namespace
            if trimmed.starts_with("mod ") || trimmed.starts_with("pub mod ") {
                let name = self.extract_name(trimmed, "mod ");
                if !name.is_empty() {
                    current_container = Some(name.clone());
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Module,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: None,
                    });
                }
            }

            // Functions
            if trimmed.starts_with("fn ") || trimmed.starts_with("pub fn ") || trimmed.starts_with("async fn ") {
                let name = self.extract_fn_name(trimmed);
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Function,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }

            // Structs
            if trimmed.starts_with("struct ") || trimmed.starts_with("pub struct ") {
                let name = self.extract_name(trimmed, "struct ");
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Struct,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }

            // Enums
            if trimmed.starts_with("enum ") || trimmed.starts_with("pub enum ") {
                let name = self.extract_name(trimmed, "enum ");
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Enum,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }

            // Traits
            if trimmed.starts_with("trait ") || trimmed.starts_with("pub trait ") {
                let name = self.extract_name(trimmed, "trait ");
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Interface,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }

            // Constants
            if trimmed.starts_with("const ") || trimmed.starts_with("pub const ") {
                let name = self.extract_const_name(trimmed);
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Constant,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }

            // Static variables
            if trimmed.starts_with("static ") || trimmed.starts_with("pub static ") {
                let name = self.extract_const_name(trimmed);
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::Variable,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }

            // Type aliases
            if trimmed.starts_with("type ") || trimmed.starts_with("pub type ") {
                let name = self.extract_name(trimmed, "type ");
                if !name.is_empty() {
                    new_symbols.push(WorkspaceSymbol {
                        name: name.clone(),
                        kind: SymbolKind::TypeParameter,
                        location: self.make_location(uri, line_num, line, &name),
                        container_name: current_container.clone(),
                    });
                }
            }
        }

        // Add new symbols
        {
            let mut symbols = self.symbols.write().unwrap();
            let mut file_symbols = self.file_symbols.write().unwrap();
            let mut file_names = Vec::new();

            for sym in new_symbols {
                file_names.push(sym.name.clone());
                symbols.entry(sym.name.clone())
                    .or_insert_with(Vec::new)
                    .push(sym);
            }

            file_symbols.insert(uri.to_string(), file_names);
        }
    }

    /// Search workspace symbols
    pub fn search(&self, query: &str) -> Vec<WorkspaceSymbol> {
        let symbols = self.symbols.read().unwrap();
        let query_lower = query.to_lowercase();
        let mut results = Vec::new();

        for (name, syms) in symbols.iter() {
            if self.fuzzy_match(&name.to_lowercase(), &query_lower) {
                results.extend(syms.iter().cloned());
            }
        }

        // Sort by relevance
        results.sort_by(|a, b| {
            let a_exact = a.name.to_lowercase() == query_lower;
            let b_exact = b.name.to_lowercase() == query_lower;

            if a_exact && !b_exact {
                std::cmp::Ordering::Less
            } else if !a_exact && b_exact {
                std::cmp::Ordering::Greater
            } else {
                a.name.len().cmp(&b.name.len())
            }
        });

        // Limit results
        results.truncate(100);
        results
    }

    fn fuzzy_match(&self, name: &str, query: &str) -> bool {
        if query.is_empty() {
            return true;
        }

        let mut query_chars = query.chars().peekable();
        for c in name.chars() {
            if let Some(&q) = query_chars.peek() {
                if c == q {
                    query_chars.next();
                }
            }
            if query_chars.peek().is_none() {
                return true;
            }
        }

        query_chars.peek().is_none()
    }

    fn extract_name(&self, line: &str, keyword: &str) -> String {
        let after_pub = line.strip_prefix("pub ").unwrap_or(line);
        if let Some(after_keyword) = after_pub.strip_prefix(keyword) {
            after_keyword.trim()
                .chars()
                .take_while(|c| c.is_alphanumeric() || *c == '_')
                .collect()
        } else {
            String::new()
        }
    }

    fn extract_fn_name(&self, line: &str) -> String {
        let trimmed = line.trim();
        let after_pub = trimmed.strip_prefix("pub ").unwrap_or(trimmed);
        let after_async = after_pub.strip_prefix("async ").unwrap_or(after_pub);
        if let Some(after_fn) = after_async.strip_prefix("fn ") {
            after_fn.trim()
                .chars()
                .take_while(|c| c.is_alphanumeric() || *c == '_')
                .collect()
        } else {
            String::new()
        }
    }

    fn extract_const_name(&self, line: &str) -> String {
        let trimmed = line.trim();
        let after_pub = trimmed.strip_prefix("pub ").unwrap_or(trimmed);
        let after_keyword = after_pub.strip_prefix("const ")
            .or_else(|| after_pub.strip_prefix("static "));

        if let Some(rest) = after_keyword {
            let mut_stripped = rest.strip_prefix("mut ").unwrap_or(rest);
            mut_stripped.trim()
                .chars()
                .take_while(|c| c.is_alphanumeric() || *c == '_')
                .collect()
        } else {
            String::new()
        }
    }

    fn make_location(&self, uri: &str, line_num: usize, line: &str, name: &str) -> Location {
        let start_char = line.find(name).unwrap_or(0) as u32;
        Location {
            uri: uri.to_string(),
            range: Range {
                start: Position { line: line_num as u32, character: start_char },
                end: Position { line: line_num as u32, character: start_char + name.len() as u32 },
            },
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINKED EDITING RANGES PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Linked editing ranges for simultaneous editing
#[derive(Clone, Debug)]
pub struct LinkedEditingRanges {
    pub ranges: Vec<Range>,
    pub word_pattern: Option<String>,
}

/// Provider for linked editing (e.g., rename HTML tags, string interpolation)
pub struct LinkedEditingRangesProvider;

impl LinkedEditingRangesProvider {
    pub fn new() -> Self {
        LinkedEditingRangesProvider
    }

    /// Get linked editing ranges at position
    pub fn get_ranges(&self, text: &str, position: Position) -> Option<LinkedEditingRanges> {
        let lines: Vec<&str> = text.lines().collect();
        let line = lines.get(position.line as usize)?;

        // Check for string interpolation: ${...}
        if let Some(ranges) = self.find_interpolation_links(text, position) {
            return Some(ranges);
        }

        // Check for matching HTML/XML tags
        if let Some(ranges) = self.find_tag_links(text, position) {
            return Some(ranges);
        }

        // Check for matching brackets
        if let Some(ranges) = self.find_bracket_links(text, position) {
            return Some(ranges);
        }

        None
    }

    fn find_interpolation_links(&self, text: &str, _position: Position) -> Option<LinkedEditingRanges> {
        // Find ${var} style interpolation and link to variable definition
        // Simplified implementation
        None
    }

    fn find_tag_links(&self, text: &str, position: Position) -> Option<LinkedEditingRanges> {
        let lines: Vec<&str> = text.lines().collect();
        let line = lines.get(position.line as usize)?;
        let pos = position.character as usize;

        // Check if we're in a tag
        if !line.contains('<') {
            return None;
        }

        // Find opening tag
        let chars: Vec<char> = line.chars().collect();
        let mut tag_start = None;
        let mut in_tag = false;

        for i in 0..chars.len() {
            if chars[i] == '<' && i + 1 < chars.len() && chars[i + 1] != '/' {
                tag_start = Some(i + 1);
                in_tag = true;
            } else if in_tag && (chars[i].is_whitespace() || chars[i] == '>') {
                if pos > tag_start.unwrap_or(0) && pos <= i {
                    // We're in the tag name
                    let tag_name: String = chars[tag_start.unwrap()..i].iter().collect();

                    // Find closing tag
                    let closing_pattern = format!("</{}>", tag_name);
                    if let Some(closing_idx) = text.find(&closing_pattern) {
                        // Find line/char of closing tag
                        let mut current_pos = 0;
                        for (line_num, l) in lines.iter().enumerate() {
                            let line_end = current_pos + l.len() + 1;
                            if closing_idx >= current_pos && closing_idx < line_end {
                                let char_in_line = closing_idx - current_pos + 2; // +2 for </
                                return Some(LinkedEditingRanges {
                                    ranges: vec![
                                        Range {
                                            start: Position { line: position.line, character: tag_start.unwrap() as u32 },
                                            end: Position { line: position.line, character: i as u32 },
                                        },
                                        Range {
                                            start: Position { line: line_num as u32, character: char_in_line as u32 },
                                            end: Position { line: line_num as u32, character: (char_in_line + tag_name.len()) as u32 },
                                        },
                                    ],
                                    word_pattern: Some(r"[a-zA-Z][a-zA-Z0-9-]*".to_string()),
                                });
                            }
                            current_pos = line_end;
                        }
                    }
                }
                in_tag = false;
            }
        }

        None
    }

    fn find_bracket_links(&self, text: &str, position: Position) -> Option<LinkedEditingRanges> {
        // Find matching brackets/parens
        None
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INLINE VALUES PROVIDER (FOR DEBUGGING)
// ═══════════════════════════════════════════════════════════════════════════════

/// Inline value (for debugger)
#[derive(Clone, Debug)]
pub enum InlineValue {
    Text { range: Range, text: String },
    VariableLookup { range: Range, variable_name: String, case_sensitive_lookup: bool },
    EvaluatableExpression { range: Range, expression: Option<String> },
}

/// Inline value context
#[derive(Clone, Debug)]
pub struct InlineValueContext {
    pub frame_id: i64,
    pub stopped_location: Range,
}

/// Inline values provider for debugging
pub struct InlineValuesProvider;

impl InlineValuesProvider {
    pub fn new() -> Self {
        InlineValuesProvider
    }

    /// Get inline values for debugging
    pub fn get_values(&self, text: &str, viewport: Range, context: InlineValueContext) -> Vec<InlineValue> {
        let mut values = Vec::new();
        let lines: Vec<&str> = text.lines().collect();

        // Only process lines in viewport that are before stopped location
        let start_line = viewport.start.line as usize;
        let end_line = (viewport.end.line as usize).min(context.stopped_location.end.line as usize);

        for line_num in start_line..=end_line {
            if let Some(line) = lines.get(line_num) {
                self.extract_values(line, line_num as u32, &mut values);
            }
        }

        values
    }

    fn extract_values(&self, line: &str, line_num: u32, values: &mut Vec<InlineValue>) {
        let trimmed = line.trim();

        // Look for variable assignments
        if trimmed.starts_with("let ") || trimmed.starts_with("let mut ") {
            if let Some(eq_idx) = trimmed.find('=') {
                let decl_part = &trimmed[..eq_idx];
                let var_name = self.extract_var_name(decl_part);

                if !var_name.is_empty() {
                    if let Some(start) = line.find(&var_name) {
                        values.push(InlineValue::VariableLookup {
                            range: Range {
                                start: Position { line: line_num, character: start as u32 },
                                end: Position { line: line_num, character: (start + var_name.len()) as u32 },
                            },
                            variable_name: var_name,
                            case_sensitive_lookup: true,
                        });
                    }
                }
            }
        }

        // Look for function parameters
        if trimmed.starts_with("fn ") && trimmed.contains('(') {
            if let (Some(open), Some(close)) = (trimmed.find('('), trimmed.find(')')) {
                let params = &trimmed[open + 1..close];
                for param in params.split(',') {
                    let param_name = self.extract_param_name(param.trim());
                    if !param_name.is_empty() {
                        if let Some(start) = line.find(&param_name) {
                            values.push(InlineValue::VariableLookup {
                                range: Range {
                                    start: Position { line: line_num, character: start as u32 },
                                    end: Position { line: line_num, character: (start + param_name.len()) as u32 },
                                },
                                variable_name: param_name,
                                case_sensitive_lookup: true,
                            });
                        }
                    }
                }
            }
        }
    }

    fn extract_var_name(&self, decl: &str) -> String {
        let after_let = decl.strip_prefix("let ")
            .map(|s| s.strip_prefix("mut ").unwrap_or(s))
            .unwrap_or(decl);

        after_let.trim()
            .chars()
            .take_while(|c| c.is_alphanumeric() || *c == '_')
            .collect()
    }

    fn extract_param_name(&self, param: &str) -> String {
        param.chars()
            .take_while(|c| c.is_alphanumeric() || *c == '_')
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEBUG ADAPTER PROTOCOL INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Debug session state
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum DebugState {
    NotStarted,
    Initializing,
    Running,
    Paused,
    Terminated,
}

/// Breakpoint
#[derive(Clone, Debug)]
pub struct Breakpoint {
    pub id: i64,
    pub verified: bool,
    pub line: u32,
    pub column: Option<u32>,
    pub source_path: String,
    pub condition: Option<String>,
    pub hit_condition: Option<String>,
    pub log_message: Option<String>,
}

/// Stack frame
#[derive(Clone, Debug)]
pub struct StackFrame {
    pub id: i64,
    pub name: String,
    pub source: Option<String>,
    pub line: u32,
    pub column: u32,
    pub end_line: Option<u32>,
    pub end_column: Option<u32>,
}

/// Variable
#[derive(Clone, Debug)]
pub struct Variable {
    pub name: String,
    pub value: String,
    pub type_name: Option<String>,
    pub variables_reference: i64,
    pub named_variables: Option<i64>,
    pub indexed_variables: Option<i64>,
}

/// Scope
#[derive(Clone, Debug)]
pub struct Scope {
    pub name: String,
    pub variables_reference: i64,
    pub expensive: bool,
}

/// Debug adapter for DAP protocol
pub struct DebugAdapter {
    state: RwLock<DebugState>,
    breakpoints: RwLock<HashMap<String, Vec<Breakpoint>>>,
    stack_frames: RwLock<Vec<StackFrame>>,
    variables: RwLock<HashMap<i64, Vec<Variable>>>,
    scopes: RwLock<HashMap<i64, Vec<Scope>>>,
    next_id: Mutex<i64>,
    sequence: Mutex<i64>,
}

impl DebugAdapter {
    pub fn new() -> Self {
        DebugAdapter {
            state: RwLock::new(DebugState::NotStarted),
            breakpoints: RwLock::new(HashMap::new()),
            stack_frames: RwLock::new(Vec::new()),
            variables: RwLock::new(HashMap::new()),
            scopes: RwLock::new(HashMap::new()),
            next_id: Mutex::new(1),
            sequence: Mutex::new(1),
        }
    }

    fn next_id(&self) -> i64 {
        let mut id = self.next_id.lock().unwrap();
        *id += 1;
        *id
    }

    fn next_seq(&self) -> i64 {
        let mut seq = self.sequence.lock().unwrap();
        *seq += 1;
        *seq
    }

    /// Handle initialize request
    pub fn initialize(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Initializing;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "initialize".to_string(),
            body: Some(DapCapabilities {
                supports_configuration_done: true,
                supports_function_breakpoints: true,
                supports_conditional_breakpoints: true,
                supports_hit_conditional_breakpoints: true,
                supports_evaluate_for_hovers: true,
                supports_step_back: false,
                supports_set_variable: true,
                supports_restart_frame: false,
                supports_goto_targets: false,
                supports_step_in_targets: true,
                supports_completions: true,
                supports_modules: true,
                supports_restart: true,
                supports_exception_options: true,
                supports_value_formatting: true,
                supports_exception_info: true,
                supports_delayed_stack_trace_loading: true,
                supports_loaded_sources: true,
                supports_log_points: true,
                supports_terminate_threads: false,
                supports_data_breakpoints: true,
                supports_read_memory: true,
                supports_write_memory: true,
                supports_disassemble: true,
                supports_cancel: true,
                supports_breakpoint_locations: true,
                supports_clipboard_context: false,
                supports_stepping_granularity: true,
                supports_instruction_breakpoints: true,
                supports_exception_filter_options: true,
                supports_single_thread_execution_requests: true,
            }),
        }
    }

    /// Handle launch request
    pub fn launch(&self, program: &str, args: &[String]) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Running;

        // Simulate starting the program
        println!("Launching: {} {:?}", program, args);

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "launch".to_string(),
            body: None,
        }
    }

    /// Handle attach request
    pub fn attach(&self, pid: i64) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Running;

        println!("Attaching to PID: {}", pid);

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "attach".to_string(),
            body: None,
        }
    }

    /// Set breakpoints
    pub fn set_breakpoints(&self, source_path: &str, breakpoints: Vec<SourceBreakpoint>) -> Vec<Breakpoint> {
        let mut result = Vec::new();

        for bp in breakpoints {
            let breakpoint = Breakpoint {
                id: self.next_id(),
                verified: true,
                line: bp.line,
                column: bp.column,
                source_path: source_path.to_string(),
                condition: bp.condition,
                hit_condition: bp.hit_condition,
                log_message: bp.log_message,
            };
            result.push(breakpoint);
        }

        let mut bps = self.breakpoints.write().unwrap();
        bps.insert(source_path.to_string(), result.clone());

        result
    }

    /// Continue execution
    pub fn continue_execution(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Running;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "continue".to_string(),
            body: None,
        }
    }

    /// Step over
    pub fn step_over(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Running;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "next".to_string(),
            body: None,
        }
    }

    /// Step into
    pub fn step_into(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Running;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "stepIn".to_string(),
            body: None,
        }
    }

    /// Step out
    pub fn step_out(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Running;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "stepOut".to_string(),
            body: None,
        }
    }

    /// Pause execution
    pub fn pause(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Paused;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "pause".to_string(),
            body: None,
        }
    }

    /// Terminate debugging
    pub fn terminate(&self) -> DapResponse {
        *self.state.write().unwrap() = DebugState::Terminated;

        DapResponse {
            seq: self.next_seq(),
            request_seq: 0,
            success: true,
            command: "terminate".to_string(),
            body: None,
        }
    }

    /// Get stack trace
    pub fn stack_trace(&self) -> Vec<StackFrame> {
        self.stack_frames.read().unwrap().clone()
    }

    /// Get scopes for frame
    pub fn scopes(&self, frame_id: i64) -> Vec<Scope> {
        self.scopes.read().unwrap()
            .get(&frame_id)
            .cloned()
            .unwrap_or_default()
    }

    /// Get variables for reference
    pub fn variables(&self, reference: i64) -> Vec<Variable> {
        self.variables.read().unwrap()
            .get(&reference)
            .cloned()
            .unwrap_or_default()
    }

    /// Evaluate expression
    pub fn evaluate(&self, expression: &str, frame_id: Option<i64>) -> Result<String, String> {
        // Simplified evaluation
        Ok(format!("[Evaluated: {}]", expression))
    }
}

/// Source breakpoint request
#[derive(Clone, Debug)]
pub struct SourceBreakpoint {
    pub line: u32,
    pub column: Option<u32>,
    pub condition: Option<String>,
    pub hit_condition: Option<String>,
    pub log_message: Option<String>,
}

/// DAP response
#[derive(Clone, Debug)]
pub struct DapResponse {
    pub seq: i64,
    pub request_seq: i64,
    pub success: bool,
    pub command: String,
    pub body: Option<DapCapabilities>,
}

/// DAP capabilities
#[derive(Clone, Debug)]
pub struct DapCapabilities {
    pub supports_configuration_done: bool,
    pub supports_function_breakpoints: bool,
    pub supports_conditional_breakpoints: bool,
    pub supports_hit_conditional_breakpoints: bool,
    pub supports_evaluate_for_hovers: bool,
    pub supports_step_back: bool,
    pub supports_set_variable: bool,
    pub supports_restart_frame: bool,
    pub supports_goto_targets: bool,
    pub supports_step_in_targets: bool,
    pub supports_completions: bool,
    pub supports_modules: bool,
    pub supports_restart: bool,
    pub supports_exception_options: bool,
    pub supports_value_formatting: bool,
    pub supports_exception_info: bool,
    pub supports_delayed_stack_trace_loading: bool,
    pub supports_loaded_sources: bool,
    pub supports_log_points: bool,
    pub supports_terminate_threads: bool,
    pub supports_data_breakpoints: bool,
    pub supports_read_memory: bool,
    pub supports_write_memory: bool,
    pub supports_disassemble: bool,
    pub supports_cancel: bool,
    pub supports_breakpoint_locations: bool,
    pub supports_clipboard_context: bool,
    pub supports_stepping_granularity: bool,
    pub supports_instruction_breakpoints: bool,
    pub supports_exception_filter_options: bool,
    pub supports_single_thread_execution_requests: bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST FRAMEWORK INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Test item (discovered test)
#[derive(Clone, Debug)]
pub struct TestItem {
    pub id: String,
    pub label: String,
    pub uri: String,
    pub range: Range,
    pub children: Vec<TestItem>,
    pub tags: Vec<String>,
}

/// Test run result
#[derive(Clone, Debug)]
pub struct TestRunResult {
    pub test_id: String,
    pub state: TestState,
    pub duration_ms: Option<u64>,
    pub message: Option<String>,
    pub expected: Option<String>,
    pub actual: Option<String>,
    pub location: Option<Location>,
}

/// Test state
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum TestState {
    Queued,
    Running,
    Passed,
    Failed,
    Skipped,
    Errored,
}

/// Test discovery and execution
pub struct TestController {
    tests: RwLock<HashMap<String, TestItem>>,
    results: RwLock<HashMap<String, TestRunResult>>,
}

impl TestController {
    pub fn new() -> Self {
        TestController {
            tests: RwLock::new(HashMap::new()),
            results: RwLock::new(HashMap::new()),
        }
    }

    /// Discover tests in a file
    pub fn discover_tests(&self, uri: &str, text: &str) -> Vec<TestItem> {
        let mut tests = Vec::new();
        let lines: Vec<&str> = text.lines().collect();

        for (line_num, line) in lines.iter().enumerate() {
            let trimmed = line.trim();

            // Look for #[test] attribute
            if trimmed == "#[test]" {
                // Next line should be fn
                if let Some(next_line) = lines.get(line_num + 1) {
                    if let Some(fn_name) = self.extract_test_fn_name(next_line) {
                        let test_id = format!("{}::{}", uri, fn_name);
                        tests.push(TestItem {
                            id: test_id,
                            label: fn_name.clone(),
                            uri: uri.to_string(),
                            range: Range {
                                start: Position { line: line_num as u32, character: 0 },
                                end: Position { line: (line_num + 1) as u32, character: next_line.len() as u32 },
                            },
                            children: Vec::new(),
                            tags: vec!["unit".to_string()],
                        });
                    }
                }
            }

            // Look for #[bench] attribute
            if trimmed == "#[bench]" {
                if let Some(next_line) = lines.get(line_num + 1) {
                    if let Some(fn_name) = self.extract_test_fn_name(next_line) {
                        let test_id = format!("{}::{}", uri, fn_name);
                        tests.push(TestItem {
                            id: test_id,
                            label: fn_name.clone(),
                            uri: uri.to_string(),
                            range: Range {
                                start: Position { line: line_num as u32, character: 0 },
                                end: Position { line: (line_num + 1) as u32, character: next_line.len() as u32 },
                            },
                            children: Vec::new(),
                            tags: vec!["benchmark".to_string()],
                        });
                    }
                }
            }
        }

        // Cache tests
        {
            let mut all_tests = self.tests.write().unwrap();
            for test in &tests {
                all_tests.insert(test.id.clone(), test.clone());
            }
        }

        tests
    }

    fn extract_test_fn_name(&self, line: &str) -> Option<String> {
        let trimmed = line.trim();
        let after_pub = trimmed.strip_prefix("pub ").unwrap_or(trimmed);
        let after_async = after_pub.strip_prefix("async ").unwrap_or(after_pub);

        after_async.strip_prefix("fn ").map(|rest| {
            rest.chars()
                .take_while(|c| c.is_alphanumeric() || *c == '_')
                .collect()
        })
    }

    /// Run a single test
    pub fn run_test(&self, test_id: &str) -> TestRunResult {
        // Mark as running
        let result = TestRunResult {
            test_id: test_id.to_string(),
            state: TestState::Running,
            duration_ms: None,
            message: None,
            expected: None,
            actual: None,
            location: None,
        };

        let mut results = self.results.write().unwrap();
        results.insert(test_id.to_string(), result.clone());

        // Simulate test execution
        // In real implementation, would spawn test process and capture output
        let final_result = TestRunResult {
            test_id: test_id.to_string(),
            state: TestState::Passed,
            duration_ms: Some(42),
            message: None,
            expected: None,
            actual: None,
            location: None,
        };

        results.insert(test_id.to_string(), final_result.clone());
        final_result
    }

    /// Run all tests
    pub fn run_all_tests(&self) -> Vec<TestRunResult> {
        let tests = self.tests.read().unwrap();
        let mut results = Vec::new();

        for test_id in tests.keys() {
            results.push(self.run_test(test_id));
        }

        results
    }

    /// Get test result
    pub fn get_result(&self, test_id: &str) -> Option<TestRunResult> {
        self.results.read().unwrap().get(test_id).cloned()
    }

    /// Cancel running tests
    pub fn cancel(&self) {
        // In real implementation, would terminate test processes
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CODE COVERAGE OVERLAY
// ═══════════════════════════════════════════════════════════════════════════════

/// Line coverage status
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum LineCoverage {
    /// Line not covered by tests
    NotCovered,
    /// Line fully covered
    Covered,
    /// Line partially covered (e.g., branch not taken)
    Partial,
    /// Line not executable (comments, blank)
    NotExecutable,
}

/// Coverage data for a file
#[derive(Clone, Debug)]
pub struct FileCoverage {
    pub uri: String,
    pub lines: Vec<LineCoverage>,
    pub branches: Vec<BranchCoverage>,
    pub line_hit_counts: Vec<u64>,
    pub line_covered: u64,
    pub line_total: u64,
    pub branch_covered: u64,
    pub branch_total: u64,
}

impl FileCoverage {
    pub fn coverage_percent(&self) -> f64 {
        if self.line_total == 0 {
            100.0
        } else {
            (self.line_covered as f64 / self.line_total as f64) * 100.0
        }
    }
}

/// Branch coverage
#[derive(Clone, Debug)]
pub struct BranchCoverage {
    pub line: u32,
    pub branches: Vec<bool>,
}

/// Coverage provider
pub struct CoverageProvider {
    coverage: RwLock<HashMap<String, FileCoverage>>,
    overall_line_covered: Mutex<u64>,
    overall_line_total: Mutex<u64>,
}

impl CoverageProvider {
    pub fn new() -> Self {
        CoverageProvider {
            coverage: RwLock::new(HashMap::new()),
            overall_line_covered: Mutex::new(0),
            overall_line_total: Mutex::new(0),
        }
    }

    /// Load coverage from LLVM coverage format
    pub fn load_llvm_coverage(&self, json_data: &str) -> Result<(), String> {
        // Parse LLVM coverage JSON format
        // In real implementation, would parse actual coverage data
        Ok(())
    }

    /// Load coverage from lcov format
    pub fn load_lcov(&self, lcov_data: &str) -> Result<(), String> {
        // Parse lcov format
        let mut current_file: Option<String> = None;
        let mut lines: Vec<LineCoverage> = Vec::new();
        let mut hit_counts: Vec<u64> = Vec::new();
        let mut covered = 0u64;
        let mut total = 0u64;

        for line in lcov_data.lines() {
            if line.starts_with("SF:") {
                // Source file
                if let Some(uri) = current_file.take() {
                    self.store_file_coverage(&uri, &lines, &hit_counts, covered, total);
                }
                current_file = Some(line[3..].to_string());
                lines.clear();
                hit_counts.clear();
                covered = 0;
                total = 0;
            } else if line.starts_with("DA:") {
                // Line data: DA:line_number,hit_count
                let parts: Vec<&str> = line[3..].split(',').collect();
                if parts.len() == 2 {
                    if let (Ok(line_num), Ok(hits)) = (parts[0].parse::<usize>(), parts[1].parse::<u64>()) {
                        while lines.len() < line_num {
                            lines.push(LineCoverage::NotExecutable);
                            hit_counts.push(0);
                        }
                        if line_num > 0 {
                            let idx = line_num - 1;
                            if idx < lines.len() {
                                lines[idx] = if hits > 0 { LineCoverage::Covered } else { LineCoverage::NotCovered };
                                hit_counts[idx] = hits;
                            }
                        }
                        total += 1;
                        if hits > 0 {
                            covered += 1;
                        }
                    }
                }
            } else if line == "end_of_record" {
                if let Some(uri) = current_file.take() {
                    self.store_file_coverage(&uri, &lines, &hit_counts, covered, total);
                }
                lines.clear();
                hit_counts.clear();
                covered = 0;
                total = 0;
            }
        }

        // Handle last file
        if let Some(uri) = current_file.take() {
            self.store_file_coverage(&uri, &lines, &hit_counts, covered, total);
        }

        Ok(())
    }

    fn store_file_coverage(&self, uri: &str, lines: &[LineCoverage], hit_counts: &[u64], covered: u64, total: u64) {
        let file_cov = FileCoverage {
            uri: uri.to_string(),
            lines: lines.to_vec(),
            branches: Vec::new(),
            line_hit_counts: hit_counts.to_vec(),
            line_covered: covered,
            line_total: total,
            branch_covered: 0,
            branch_total: 0,
        };

        let mut cov = self.coverage.write().unwrap();
        cov.insert(uri.to_string(), file_cov);

        let mut overall_covered = self.overall_line_covered.lock().unwrap();
        *overall_covered += covered;

        let mut overall_total = self.overall_line_total.lock().unwrap();
        *overall_total += total;
    }

    /// Get coverage for a file
    pub fn get_coverage(&self, uri: &str) -> Option<FileCoverage> {
        self.coverage.read().unwrap().get(uri).cloned()
    }

    /// Get overall coverage percentage
    pub fn overall_coverage(&self) -> f64 {
        let total = *self.overall_line_total.lock().unwrap();
        let covered = *self.overall_line_covered.lock().unwrap();

        if total == 0 {
            100.0
        } else {
            (covered as f64 / total as f64) * 100.0
        }
    }

    /// Generate decorations for IDE
    pub fn generate_decorations(&self, uri: &str) -> Vec<CoverageDecoration> {
        let cov = match self.get_coverage(uri) {
            Some(c) => c,
            None => return Vec::new(),
        };

        let mut decorations = Vec::new();

        for (line_num, &status) in cov.lines.iter().enumerate() {
            match status {
                LineCoverage::Covered => {
                    let hits = cov.line_hit_counts.get(line_num).copied().unwrap_or(0);
                    decorations.push(CoverageDecoration {
                        line: line_num as u32,
                        kind: CoverageDecorationKind::Covered,
                        message: Some(format!("Hit {} time(s)", hits)),
                    });
                }
                LineCoverage::NotCovered => {
                    decorations.push(CoverageDecoration {
                        line: line_num as u32,
                        kind: CoverageDecorationKind::NotCovered,
                        message: Some("Not covered".to_string()),
                    });
                }
                LineCoverage::Partial => {
                    decorations.push(CoverageDecoration {
                        line: line_num as u32,
                        kind: CoverageDecorationKind::Partial,
                        message: Some("Partially covered".to_string()),
                    });
                }
                LineCoverage::NotExecutable => {
                    // No decoration
                }
            }
        }

        decorations
    }

    /// Clear all coverage data
    pub fn clear(&self) {
        self.coverage.write().unwrap().clear();
        *self.overall_line_covered.lock().unwrap() = 0;
        *self.overall_line_total.lock().unwrap() = 0;
    }
}

/// Coverage decoration for IDE display
