    fn handle_on_type_formatting(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        if !self.configuration.format_on_type {
            return self.make_result_response(id, JsonValue::Array(Vec::new()));
        }

        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let pos = match params.and_then(|p| p.get("position")).and_then(|p| self.parse_position(p)) {
            Some(p) => p,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let trigger = params.and_then(|p| p.get("ch")).and_then(|c| c.as_str())
            .and_then(|s| s.chars().next())
            .unwrap_or(' ');

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let edits = self.formatter.format_on_type(&doc, pos, trigger);
        let json_edits: Vec<JsonValue> = edits.iter().map(|e| self.text_edit_to_json(e)).collect();

        self.make_result_response(id, JsonValue::Array(json_edits))
    }

    fn handle_rename(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let new_name = match params.and_then(|p| p.get("newName")).and_then(|n| n.as_str()) {
            Some(n) => n,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        match self.rename_provider.rename(&doc, pos, new_name) {
            Some(edit) => self.make_result_response(id, self.workspace_edit_to_json(&edit)),
            None => self.make_result_response(id, JsonValue::Null),
        }
    }

    fn handle_prepare_rename(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        match self.rename_provider.prepare_rename(&doc, pos) {
