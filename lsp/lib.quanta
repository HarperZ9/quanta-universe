module lsp

use foundation::io::{println, stdin, stdout, read_line, write}
use foundation::collections::{Vec, HashMap}
use foundation::sync::{Arc, RwLock, Mutex}
use foundation::net::{TcpListener, TcpStream}
use foundation::thread::spawn

// ═══════════════════════════════════════════════════════════════════════════════
// LSP TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Position in a text document
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub struct Position {
    pub line: u32,
    pub character: u32,
}

/// Range in a text document
#[derive(Clone, Copy, Debug)]
pub struct Range {
    pub start: Position,
    pub end: Position,
}

/// Location in a document
#[derive(Clone, Debug)]
pub struct Location {
    pub uri: String,
    pub range: Range,
}

/// Text document identifier
#[derive(Clone, Debug)]
pub struct TextDocumentIdentifier {
    pub uri: String,
}

/// Versioned text document identifier
#[derive(Clone, Debug)]
pub struct VersionedTextDocumentIdentifier {
    pub uri: String,
    pub version: i32,
}

/// Text document item
#[derive(Clone, Debug)]
pub struct TextDocumentItem {
    pub uri: String,
    pub language_id: String,
    pub version: i32,
    pub text: String,
}

/// Text document content change
#[derive(Clone, Debug)]
pub struct TextDocumentContentChangeEvent {
    pub range: Option<Range>,
    pub text: String,
}

/// Diagnostic severity
#[derive(Clone, Copy, Debug)]
pub enum DiagnosticSeverity {
    Error = 1,
    Warning = 2,
    Information = 3,
    Hint = 4,
}

/// Diagnostic
#[derive(Clone, Debug)]
pub struct Diagnostic {
    pub range: Range,
    pub severity: DiagnosticSeverity,
    pub code: Option<String>,
    pub source: String,
    pub message: String,
    pub related_information: Vec<DiagnosticRelatedInformation>,
}

#[derive(Clone, Debug)]
pub struct DiagnosticRelatedInformation {
    pub location: Location,
    pub message: String,
}

/// Completion item kind
#[derive(Clone, Copy, Debug)]
pub enum CompletionItemKind {
    Text = 1,
    Method = 2,
    Function = 3,
    Constructor = 4,
    Field = 5,
    Variable = 6,
    Class = 7,
    Interface = 8,
    Module = 9,
    Property = 10,
    Unit = 11,
    Value = 12,
    Enum = 13,
    Keyword = 14,
    Snippet = 15,
    Color = 16,
    File = 17,
    Reference = 18,
    Folder = 19,
    EnumMember = 20,
    Constant = 21,
    Struct = 22,
    Event = 23,
    Operator = 24,
    TypeParameter = 25,
}

/// Completion item
#[derive(Clone, Debug)]
pub struct CompletionItem {
    pub label: String,
    pub kind: CompletionItemKind,
    pub detail: Option<String>,
    pub documentation: Option<String>,
    pub insert_text: Option<String>,
    pub insert_text_format: InsertTextFormat,
}

#[derive(Clone, Copy, Debug)]
pub enum InsertTextFormat {
    PlainText = 1,
    Snippet = 2,
}

/// Hover information
#[derive(Clone, Debug)]
pub struct Hover {
    pub contents: MarkupContent,
    pub range: Option<Range>,
}

#[derive(Clone, Debug)]
pub struct MarkupContent {
    pub kind: MarkupKind,
    pub value: String,
}

#[derive(Clone, Copy, Debug)]
pub enum MarkupKind {
    PlainText,
    Markdown,
}

/// Symbol kind
#[derive(Clone, Copy, Debug)]
pub enum SymbolKind {
    File = 1,
    Module = 2,
    Namespace = 3,
    Package = 4,
    Class = 5,
    Method = 6,
    Property = 7,
    Field = 8,
    Constructor = 9,
    Enum = 10,
    Interface = 11,
    Function = 12,
    Variable = 13,
    Constant = 14,
    String = 15,
    Number = 16,
    Boolean = 17,
    Array = 18,
    Object = 19,
    Key = 20,
    Null = 21,
    EnumMember = 22,
    Struct = 23,
    Event = 24,
    Operator = 25,
    TypeParameter = 26,
}

/// Document symbol
#[derive(Clone, Debug)]
pub struct DocumentSymbol {
    pub name: String,
    pub detail: Option<String>,
    pub kind: SymbolKind,
    pub range: Range,
    pub selection_range: Range,
    pub children: Vec<DocumentSymbol>,
}

/// Text edit
#[derive(Clone, Debug)]
pub struct TextEdit {
    pub range: Range,
    pub new_text: String,
}

/// Code action
#[derive(Clone, Debug)]
pub struct CodeAction {
    pub title: String,
    pub kind: CodeActionKind,
    pub diagnostics: Vec<Diagnostic>,
    pub edit: Option<WorkspaceEdit>,
    pub command: Option<Command>,
}

#[derive(Clone, Debug)]
pub enum CodeActionKind {
    QuickFix,
    Refactor,
    RefactorExtract,
    RefactorInline,
    RefactorRewrite,
    Source,
    SourceOrganizeImports,
    SourceFixAll,
}

#[derive(Clone, Debug)]
pub struct Command {
    pub title: String,
    pub command: String,
    pub arguments: Vec<String>,
}

#[derive(Clone, Debug)]
pub struct WorkspaceEdit {
    pub changes: HashMap<String, Vec<TextEdit>>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENT MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

/// Manages open documents
pub struct DocumentManager {
    documents: RwLock<HashMap<String, Document>>,
}

pub struct Document {
    pub uri: String,
    pub version: i32,
    pub text: String,
    pub lines: Vec<String>,
    pub symbols: Vec<DocumentSymbol>,
    pub diagnostics: Vec<Diagnostic>,
}

impl DocumentManager {
    pub fn new() -> Self {
        DocumentManager {
            documents: RwLock::new(HashMap::new()),
        }
    }

    pub fn open(&self, item: TextDocumentItem) {
        let lines: Vec<String> = item.text.lines().map(String::from).collect();

        let doc = Document {
            uri: item.uri.clone(),
            version: item.version,
            text: item.text.clone(),
            lines,
            symbols: Vec::new(),
            diagnostics: Vec::new(),
        };

        let mut docs = self.documents.write().unwrap();
        docs.insert(item.uri, doc);
    }

    pub fn close(&self, uri: &str) {
        let mut docs = self.documents.write().unwrap();
        docs.remove(uri);
    }

    pub fn update(&self, uri: &str, version: i32, changes: Vec<TextDocumentContentChangeEvent>) {
        let mut docs = self.documents.write().unwrap();

        if let Some(doc) = docs.get_mut(uri) {
            doc.version = version;

            for change in changes {
                if let Some(range) = change.range {
                    // Incremental update
                    let start = self.offset_at(&doc.text, range.start);
                    let end = self.offset_at(&doc.text, range.end);
                    doc.text = format!("{}{}{}", &doc.text[..start], change.text, &doc.text[end..]);
                } else {
                    // Full update
                    doc.text = change.text;
                }
            }

            doc.lines = doc.text.lines().map(String::from).collect();
        }
    }

    pub fn get(&self, uri: &str) -> Option<Document> {
        let docs = self.documents.read().unwrap();
        docs.get(uri).cloned()
    }

    fn offset_at(&self, text: &str, pos: Position) -> usize {
        let mut offset = 0;
        let mut line = 0;

        for (i, c) in text.char_indices() {
            if line == pos.line as usize {
                offset = i + pos.character as usize;
                break;
            }
            if c == '\n' {
                line += 1;
            }
        }

        offset.min(text.len())
    }
}

impl Clone for Document {
    fn clone(&self) -> Self {
        Document {
            uri: self.uri.clone(),
            version: self.version,
            text: self.text.clone(),
            lines: self.lines.clone(),
            symbols: self.symbols.clone(),
            diagnostics: self.diagnostics.clone(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LANGUAGE ANALYZER
// ═══════════════════════════════════════════════════════════════════════════════

/// Analyzes QuantaLang source code
pub struct Analyzer {
    keywords: Vec<&'static str>,
    builtins: Vec<&'static str>,
    types: Vec<&'static str>,
}

impl Analyzer {
    pub fn new() -> Self {
        Analyzer {
            keywords: vec![
                "let", "mut", "fn", "pub", "struct", "enum", "impl", "trait",
                "if", "else", "match", "for", "while", "loop", "break", "continue",
                "return", "use", "mod", "type", "where", "async", "await",
                "true", "false", "self", "Self", "super", "crate", "const", "static",
            ],
            builtins: vec![
                "println!", "print!", "format!", "vec!", "assert!", "assert_eq!",
                "dbg!", "todo!", "unimplemented!", "panic!",
            ],
            types: vec![
                "i8", "i16", "i32", "i64", "i128", "isize",
                "u8", "u16", "u32", "u64", "u128", "usize",
                "f32", "f64", "bool", "char", "str", "String",
                "Vec", "HashMap", "HashSet", "Option", "Result",
                "Box", "Rc", "Arc", "Mutex", "RwLock",
            ],
        }
    }

    /// Analyze a document for symbols
    pub fn analyze_symbols(&self, doc: &Document) -> Vec<DocumentSymbol> {
        let mut symbols = Vec::new();

        for (line_num, line) in doc.lines.iter().enumerate() {
            let line = line.trim();

            // Function definition
            if line.starts_with("fn ") || line.starts_with("pub fn ") ||
               line.starts_with("async fn ") || line.starts_with("pub async fn ") {
                if let Some(symbol) = self.parse_function_symbol(line, line_num) {
                    symbols.push(symbol);
                }
            }

            // Struct definition
            if line.starts_with("struct ") || line.starts_with("pub struct ") {
                if let Some(symbol) = self.parse_struct_symbol(line, line_num) {
                    symbols.push(symbol);
                }
            }

            // Enum definition
            if line.starts_with("enum ") || line.starts_with("pub enum ") {
                if let Some(symbol) = self.parse_enum_symbol(line, line_num) {
                    symbols.push(symbol);
                }
            }

            // Trait definition
            if line.starts_with("trait ") || line.starts_with("pub trait ") {
                if let Some(symbol) = self.parse_trait_symbol(line, line_num) {
                    symbols.push(symbol);
                }
            }

            // Const/Static
            if line.starts_with("const ") || line.starts_with("pub const ") ||
               line.starts_with("static ") || line.starts_with("pub static ") {
                if let Some(symbol) = self.parse_const_symbol(line, line_num) {
                    symbols.push(symbol);
                }
            }
        }

        symbols
    }

    fn parse_function_symbol(&self, line: &str, line_num: usize) -> Option<DocumentSymbol> {
        let line = line.trim_start_matches("pub ")
            .trim_start_matches("async ")
            .trim_start_matches("fn ");

        let name_end = line.find('(')?;
        let name = line[..name_end].trim().to_string();

        Some(DocumentSymbol {
            name,
            detail: Some(line.to_string()),
            kind: SymbolKind::Function,
            range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: line.len() as u32 },
            },
            selection_range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: name_end as u32 },
            },
            children: Vec::new(),
        })
    }

    fn parse_struct_symbol(&self, line: &str, line_num: usize) -> Option<DocumentSymbol> {
        let line = line.trim_start_matches("pub ").trim_start_matches("struct ");
        let name_end = line.find(|c| c == '<' || c == '{' || c == '(').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        Some(DocumentSymbol {
            name,
            detail: None,
            kind: SymbolKind::Struct,
            range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: line.len() as u32 },
            },
            selection_range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: name_end as u32 },
            },
            children: Vec::new(),
        })
    }

    fn parse_enum_symbol(&self, line: &str, line_num: usize) -> Option<DocumentSymbol> {
        let line = line.trim_start_matches("pub ").trim_start_matches("enum ");
        let name_end = line.find(|c| c == '<' || c == '{').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        Some(DocumentSymbol {
            name,
            detail: None,
            kind: SymbolKind::Enum,
            range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: line.len() as u32 },
            },
            selection_range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: name_end as u32 },
            },
            children: Vec::new(),
        })
    }

    fn parse_trait_symbol(&self, line: &str, line_num: usize) -> Option<DocumentSymbol> {
        let line = line.trim_start_matches("pub ").trim_start_matches("trait ");
        let name_end = line.find(|c| c == '<' || c == '{' || c == ':').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        Some(DocumentSymbol {
            name,
            detail: None,
            kind: SymbolKind::Interface,
            range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: line.len() as u32 },
            },
            selection_range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: name_end as u32 },
            },
            children: Vec::new(),
        })
    }

    fn parse_const_symbol(&self, line: &str, line_num: usize) -> Option<DocumentSymbol> {
        let is_static = line.contains("static");
        let line = line.trim_start_matches("pub ")
            .trim_start_matches("const ")
            .trim_start_matches("static ")
            .trim_start_matches("mut ");

        let name_end = line.find(':').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        Some(DocumentSymbol {
            name,
            detail: None,
            kind: if is_static { SymbolKind::Variable } else { SymbolKind::Constant },
            range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: line.len() as u32 },
            },
            selection_range: Range {
                start: Position { line: line_num as u32, character: 0 },
                end: Position { line: line_num as u32, character: name_end as u32 },
            },
            children: Vec::new(),
        })
    }

    /// Get completions at a position
    pub fn completions(&self, doc: &Document, pos: Position) -> Vec<CompletionItem> {
        let mut items = Vec::new();

        // Get the current word being typed
        let line = doc.lines.get(pos.line as usize).map(|s| s.as_str()).unwrap_or("");
        let prefix = &line[..pos.character as usize];
        let word_start = prefix.rfind(|c: char| !c.is_alphanumeric() && c != '_')
            .map(|i| i + 1)
            .unwrap_or(0);
        let current_word = &prefix[word_start..];

        // Add keywords
        for kw in &self.keywords {
            if kw.starts_with(current_word) {
                items.push(CompletionItem {
                    label: kw.to_string(),
                    kind: CompletionItemKind::Keyword,
                    detail: Some("keyword".to_string()),
                    documentation: None,
                    insert_text: None,
                    insert_text_format: InsertTextFormat::PlainText,
                });
            }
        }

        // Add types
        for typ in &self.types {
            if typ.starts_with(current_word) {
                items.push(CompletionItem {
                    label: typ.to_string(),
                    kind: CompletionItemKind::Class,
                    detail: Some("type".to_string()),
                    documentation: None,
                    insert_text: None,
                    insert_text_format: InsertTextFormat::PlainText,
                });
            }
        }

        // Add builtins
        for builtin in &self.builtins {
            if builtin.starts_with(current_word) {
                items.push(CompletionItem {
                    label: builtin.to_string(),
                    kind: CompletionItemKind::Function,
                    detail: Some("macro".to_string()),
                    documentation: None,
                    insert_text: None,
                    insert_text_format: InsertTextFormat::PlainText,
                });
            }
        }

        // Add document symbols
        for symbol in &doc.symbols {
            if symbol.name.starts_with(current_word) {
                items.push(CompletionItem {
                    label: symbol.name.clone(),
                    kind: symbol_kind_to_completion_kind(symbol.kind),
                    detail: symbol.detail.clone(),
                    documentation: None,
                    insert_text: None,
                    insert_text_format: InsertTextFormat::PlainText,
                });
            }
        }

        // Add snippets
        items.extend(self.get_snippets(current_word));

        items
    }

    fn get_snippets(&self, prefix: &str) -> Vec<CompletionItem> {
        let mut snippets = Vec::new();

        let snippet_defs = [
            ("fn", "fn ${1:name}(${2:params}) -> ${3:ReturnType} {\n\t$0\n}", "Function definition"),
            ("struct", "struct ${1:Name} {\n\t${2:field}: ${3:Type},\n}", "Struct definition"),
            ("enum", "enum ${1:Name} {\n\t${2:Variant},\n}", "Enum definition"),
            ("impl", "impl ${1:Type} {\n\t$0\n}", "Impl block"),
            ("trait", "trait ${1:Name} {\n\t$0\n}", "Trait definition"),
            ("match", "match ${1:expr} {\n\t${2:pattern} => ${3:expr},\n}", "Match expression"),
            ("if", "if ${1:condition} {\n\t$0\n}", "If statement"),
            ("for", "for ${1:item} in ${2:iter} {\n\t$0\n}", "For loop"),
            ("while", "while ${1:condition} {\n\t$0\n}", "While loop"),
            ("test", "#[test]\nfn ${1:test_name}() {\n\t$0\n}", "Test function"),
        ];

        for (trigger, body, desc) in snippet_defs {
            if trigger.starts_with(prefix) {
                snippets.push(CompletionItem {
                    label: trigger.to_string(),
                    kind: CompletionItemKind::Snippet,
                    detail: Some(desc.to_string()),
                    documentation: None,
                    insert_text: Some(body.to_string()),
                    insert_text_format: InsertTextFormat::Snippet,
                });
            }
        }

        snippets
    }

    /// Get hover information
    pub fn hover(&self, doc: &Document, pos: Position) -> Option<Hover> {
        let line = doc.lines.get(pos.line as usize)?;
        let word = self.get_word_at(line, pos.character as usize)?;

        // Check if it's a keyword
        if self.keywords.contains(&word.as_str()) {
            return Some(Hover {
                contents: MarkupContent {
                    kind: MarkupKind::Markdown,
                    value: format!("**{}** - QuantaLang keyword", word),
                },
                range: None,
            });
        }

        // Check if it's a type
        if self.types.contains(&word.as_str()) {
            return Some(Hover {
                contents: MarkupContent {
                    kind: MarkupKind::Markdown,
                    value: format!("**{}** - Built-in type", word),
                },
                range: None,
            });
        }

        // Check document symbols
        for symbol in &doc.symbols {
            if symbol.name == word {
                return Some(Hover {
                    contents: MarkupContent {
                        kind: MarkupKind::Markdown,
                        value: format!("**{}** ({:?})\n\n{}",
                            symbol.name,
                            symbol.kind,
                            symbol.detail.as_deref().unwrap_or("")),
                    },
                    range: Some(symbol.range),
                });
            }
        }

        None
    }

    fn get_word_at(&self, line: &str, pos: usize) -> Option<String> {
        let chars: Vec<char> = line.chars().collect();
        if pos >= chars.len() {
            return None;
        }

        let mut start = pos;
        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        let mut end = pos;
        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            None
        } else {
            Some(chars[start..end].iter().collect())
        }
    }

    /// Analyze document for diagnostics
    pub fn diagnostics(&self, doc: &Document) -> Vec<Diagnostic> {
        let mut diagnostics = Vec::new();

        for (line_num, line) in doc.lines.iter().enumerate() {
            // Check for unclosed braces
            let open_braces = line.matches('{').count();
            let close_braces = line.matches('}').count();
            if open_braces > close_braces + 1 {
                diagnostics.push(Diagnostic {
                    range: Range {
                        start: Position { line: line_num as u32, character: 0 },
                        end: Position { line: line_num as u32, character: line.len() as u32 },
                    },
                    severity: DiagnosticSeverity::Warning,
                    code: Some("E001".to_string()),
                    source: "quanta".to_string(),
                    message: "Possibly unclosed brace".to_string(),
                    related_information: Vec::new(),
                });
            }

            // Check for TODO/FIXME comments
            if line.contains("TODO") || line.contains("FIXME") {
                let col = line.find("TODO").or_else(|| line.find("FIXME")).unwrap_or(0);
                diagnostics.push(Diagnostic {
                    range: Range {
                        start: Position { line: line_num as u32, character: col as u32 },
                        end: Position { line: line_num as u32, character: line.len() as u32 },
                    },
                    severity: DiagnosticSeverity::Information,
                    code: Some("TODO".to_string()),
                    source: "quanta".to_string(),
                    message: "TODO comment found".to_string(),
                    related_information: Vec::new(),
                });
            }
        }

        diagnostics
    }
}

fn symbol_kind_to_completion_kind(kind: SymbolKind) -> CompletionItemKind {
    match kind {
        SymbolKind::Function | SymbolKind::Method => CompletionItemKind::Function,
        SymbolKind::Variable => CompletionItemKind::Variable,
        SymbolKind::Constant => CompletionItemKind::Constant,
        SymbolKind::Class | SymbolKind::Struct => CompletionItemKind::Struct,
        SymbolKind::Enum => CompletionItemKind::Enum,
        SymbolKind::Interface => CompletionItemKind::Interface,
        SymbolKind::Module => CompletionItemKind::Module,
        _ => CompletionItemKind::Text,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LSP SERVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Language Server Protocol server
pub struct LanguageServer {
    documents: Arc<DocumentManager>,
    analyzer: Analyzer,
    initialized: bool,
    shutdown_requested: bool,
}

impl LanguageServer {
    pub fn new() -> Self {
        LanguageServer {
            documents: Arc::new(DocumentManager::new()),
            analyzer: Analyzer::new(),
            initialized: false,
            shutdown_requested: false,
        }
    }

    /// Run the server using stdio
    pub fn run_stdio(&mut self) {
        println!("Quanta LSP Server starting...");

        loop {
            // Read header
            let mut header = String::new();
            read_line(&mut header).unwrap();

            if header.is_empty() || self.shutdown_requested {
                break;
            }

            // Parse content length
            let content_length = self.parse_content_length(&header);
            if content_length == 0 {
                continue;
            }

            // Read content
            let mut content = vec![0u8; content_length];
            stdin().read_exact(&mut content).unwrap();

            // Parse and handle request
            let request_str = String::from_utf8_lossy(&content);
            if let Some(response) = self.handle_request(&request_str) {
                self.send_response(&response);
            }
        }
    }

    fn parse_content_length(&self, header: &str) -> usize {
        header.lines()
            .find(|line| line.starts_with("Content-Length:"))
            .and_then(|line| line.split(':').nth(1))
            .and_then(|s| s.trim().parse().ok())
            .unwrap_or(0)
    }

    fn handle_request(&mut self, request: &str) -> Option<String> {
        // Parse JSON-RPC request (simplified)
        let method = self.extract_method(request)?;
        let id = self.extract_id(request);

        match method.as_str() {
            "initialize" => Some(self.handle_initialize(id)),
            "initialized" => {
                self.initialized = true;
                None
            }
            "shutdown" => {
                self.shutdown_requested = true;
                Some(self.make_response(id, "null"))
            }
            "textDocument/didOpen" => {
                self.handle_did_open(request);
                None
            }
            "textDocument/didClose" => {
                self.handle_did_close(request);
                None
            }
            "textDocument/didChange" => {
                self.handle_did_change(request);
                None
            }
            "textDocument/completion" => Some(self.handle_completion(request, id)),
            "textDocument/hover" => Some(self.handle_hover(request, id)),
            "textDocument/documentSymbol" => Some(self.handle_document_symbol(request, id)),
            _ => None,
        }
    }

    fn extract_method(&self, request: &str) -> Option<String> {
        // Simplified JSON parsing
        request.find("\"method\":")
            .and_then(|i| {
                let start = request[i..].find('"').map(|j| i + j + 1)?;
                let rest = &request[start..];
                let end = rest.find('"')?;
                Some(rest[..end].to_string())
            })
    }

    fn extract_id(&self, request: &str) -> Option<i32> {
        request.find("\"id\":")
            .and_then(|i| {
                let num_start = i + 5;
                let num_str: String = request[num_start..].chars()
                    .skip_while(|c| c.is_whitespace())
                    .take_while(|c| c.is_digit(10))
                    .collect();
                num_str.parse().ok()
            })
    }

    fn handle_initialize(&self, id: Option<i32>) -> String {
        let capabilities = r#"{
            "capabilities": {
                "textDocumentSync": 1,
                "completionProvider": {
                    "triggerCharacters": [".", ":", "<"]
                },
                "hoverProvider": true,
                "documentSymbolProvider": true,
                "definitionProvider": true,
                "referencesProvider": true,
                "codeActionProvider": true,
                "documentFormattingProvider": true
            },
            "serverInfo": {
                "name": "Quanta LSP",
                "version": "2.0.0"
            }
        }"#;

        self.make_response(id, capabilities)
    }

    fn handle_did_open(&self, request: &str) {
        // Parse textDocument from request and open it
        // Simplified - would parse JSON properly
    }

    fn handle_did_close(&self, request: &str) {
        // Parse uri and close document
    }

    fn handle_did_change(&self, request: &str) {
        // Parse changes and update document
    }

    fn handle_completion(&self, request: &str, id: Option<i32>) -> String {
        // Would parse position and document uri, then get completions
        let completions = r#"{"items": []}"#;
        self.make_response(id, completions)
    }

    fn handle_hover(&self, request: &str, id: Option<i32>) -> String {
        // Would parse position and document uri, then get hover info
        self.make_response(id, "null")
    }

    fn handle_document_symbol(&self, request: &str, id: Option<i32>) -> String {
        // Would parse document uri and return symbols
        self.make_response(id, "[]")
    }

    fn make_response(&self, id: Option<i32>, result: &str) -> String {
        if let Some(id) = id {
            format!(r#"{{"jsonrpc":"2.0","id":{},"result":{}}}"#, id, result)
        } else {
            format!(r#"{{"jsonrpc":"2.0","result":{}}}"#, result)
        }
    }

    fn send_response(&self, response: &str) {
        let header = format!("Content-Length: {}\r\n\r\n", response.len());
        write(stdout(), header.as_bytes()).unwrap();
        write(stdout(), response.as_bytes()).unwrap();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// JSON-RPC PROTOCOL
// ═══════════════════════════════════════════════════════════════════════════════

/// JSON-RPC 2.0 message types
#[derive(Clone, Debug)]
pub struct JsonRpcRequest {
    pub jsonrpc: String,
    pub id: Option<JsonRpcId>,
    pub method: String,
    pub params: Option<JsonValue>,
}

#[derive(Clone, Debug)]
pub struct JsonRpcResponse {
    pub jsonrpc: String,
    pub id: Option<JsonRpcId>,
    pub result: Option<JsonValue>,
    pub error: Option<JsonRpcError>,
}

#[derive(Clone, Debug)]
pub struct JsonRpcError {
    pub code: i32,
    pub message: String,
    pub data: Option<JsonValue>,
}

#[derive(Clone, Debug)]
pub enum JsonRpcId {
    Number(i64),
    String(String),
}

/// Simple JSON value representation
#[derive(Clone, Debug)]
pub enum JsonValue {
    Null,
    Bool(bool),
    Number(f64),
    String(String),
    Array(Vec<JsonValue>),
    Object(HashMap<String, JsonValue>),
}

impl JsonValue {
    pub fn as_str(&self) -> Option<&str> {
        match self {
            JsonValue::String(s) => Some(s),
            _ => None,
        }
    }

    pub fn as_i64(&self) -> Option<i64> {
        match self {
            JsonValue::Number(n) => Some(*n as i64),
            _ => None,
        }
    }

    pub fn as_f64(&self) -> Option<f64> {
        match self {
            JsonValue::Number(n) => Some(*n),
            _ => None,
        }
    }

    pub fn as_bool(&self) -> Option<bool> {
        match self {
            JsonValue::Bool(b) => Some(*b),
            _ => None,
        }
    }

    pub fn as_array(&self) -> Option<&Vec<JsonValue>> {
        match self {
            JsonValue::Array(a) => Some(a),
            _ => None,
        }
    }

    pub fn as_object(&self) -> Option<&HashMap<String, JsonValue>> {
        match self {
            JsonValue::Object(o) => Some(o),
            _ => None,
        }
    }

    pub fn get(&self, key: &str) -> Option<&JsonValue> {
        match self {
            JsonValue::Object(o) => o.get(key),
            _ => None,
        }
    }
}

/// JSON parser
pub struct JsonParser;

impl JsonParser {
    pub fn parse(input: &str) -> Result<JsonValue, String> {
        let chars: Vec<char> = input.chars().collect();
        let mut pos = 0;
        Self::parse_value(&chars, &mut pos)
    }

    fn parse_value(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        Self::skip_whitespace(chars, pos);

        if *pos >= chars.len() {
            return Err("Unexpected end of input".to_string());
        }

        match chars[*pos] {
            'n' => Self::parse_null(chars, pos),
            't' | 'f' => Self::parse_bool(chars, pos),
            '"' => Self::parse_string(chars, pos),
            '[' => Self::parse_array(chars, pos),
            '{' => Self::parse_object(chars, pos),
            c if c == '-' || c.is_digit(10) => Self::parse_number(chars, pos),
            c => Err(format!("Unexpected character: {}", c)),
        }
    }

    fn skip_whitespace(chars: &[char], pos: &mut usize) {
        while *pos < chars.len() && chars[*pos].is_whitespace() {
            *pos += 1;
        }
    }

    fn parse_null(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        if chars[*pos..].starts_with(&['n', 'u', 'l', 'l']) {
            *pos += 4;
            Ok(JsonValue::Null)
        } else {
            Err("Invalid null".to_string())
        }
    }

    fn parse_bool(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        if chars[*pos..].starts_with(&['t', 'r', 'u', 'e']) {
            *pos += 4;
            Ok(JsonValue::Bool(true))
        } else if chars[*pos..].starts_with(&['f', 'a', 'l', 's', 'e']) {
            *pos += 5;
            Ok(JsonValue::Bool(false))
        } else {
            Err("Invalid boolean".to_string())
        }
    }

    fn parse_string(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        *pos += 1; // Skip opening quote
        let mut result = String::new();

        while *pos < chars.len() {
            match chars[*pos] {
                '"' => {
                    *pos += 1;
                    return Ok(JsonValue::String(result));
                }
                '\\' => {
                    *pos += 1;
                    if *pos < chars.len() {
                        match chars[*pos] {
                            'n' => result.push('\n'),
                            'r' => result.push('\r'),
                            't' => result.push('\t'),
                            '"' => result.push('"'),
                            '\\' => result.push('\\'),
                            _ => result.push(chars[*pos]),
                        }
                        *pos += 1;
                    }
                }
                c => {
                    result.push(c);
                    *pos += 1;
                }
            }
        }

        Err("Unterminated string".to_string())
    }

    fn parse_number(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        let start = *pos;

        if chars[*pos] == '-' {
            *pos += 1;
        }

        while *pos < chars.len() && (chars[*pos].is_digit(10) || chars[*pos] == '.' || chars[*pos] == 'e' || chars[*pos] == 'E' || chars[*pos] == '+' || chars[*pos] == '-') {
            *pos += 1;
        }

        let num_str: String = chars[start..*pos].iter().collect();
        num_str.parse::<f64>()
            .map(JsonValue::Number)
            .map_err(|_| "Invalid number".to_string())
    }

    fn parse_array(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        *pos += 1; // Skip [
        let mut arr = Vec::new();

        Self::skip_whitespace(chars, pos);

        if *pos < chars.len() && chars[*pos] == ']' {
            *pos += 1;
            return Ok(JsonValue::Array(arr));
        }

        loop {
            arr.push(Self::parse_value(chars, pos)?);
            Self::skip_whitespace(chars, pos);

            if *pos >= chars.len() {
                return Err("Unterminated array".to_string());
            }

            match chars[*pos] {
                ']' => {
                    *pos += 1;
                    return Ok(JsonValue::Array(arr));
                }
                ',' => {
                    *pos += 1;
                }
                _ => return Err("Expected , or ]".to_string()),
            }
        }
    }

    fn parse_object(chars: &[char], pos: &mut usize) -> Result<JsonValue, String> {
        *pos += 1; // Skip {
        let mut obj = HashMap::new();

        Self::skip_whitespace(chars, pos);

        if *pos < chars.len() && chars[*pos] == '}' {
            *pos += 1;
            return Ok(JsonValue::Object(obj));
        }

        loop {
            Self::skip_whitespace(chars, pos);

            let key = match Self::parse_string(chars, pos)? {
                JsonValue::String(s) => s,
                _ => return Err("Expected string key".to_string()),
            };

            Self::skip_whitespace(chars, pos);

            if *pos >= chars.len() || chars[*pos] != ':' {
                return Err("Expected :".to_string());
            }
            *pos += 1;

            let value = Self::parse_value(chars, pos)?;
            obj.insert(key, value);

            Self::skip_whitespace(chars, pos);

            if *pos >= chars.len() {
                return Err("Unterminated object".to_string());
            }

            match chars[*pos] {
                '}' => {
                    *pos += 1;
                    return Ok(JsonValue::Object(obj));
                }
                ',' => {
                    *pos += 1;
                }
                _ => return Err("Expected , or }".to_string()),
            }
        }
    }
}

/// JSON serializer
pub struct JsonSerializer;

impl JsonSerializer {
    pub fn serialize(value: &JsonValue) -> String {
        match value {
            JsonValue::Null => "null".to_string(),
            JsonValue::Bool(b) => if *b { "true" } else { "false" }.to_string(),
            JsonValue::Number(n) => format!("{}", n),
            JsonValue::String(s) => format!("\"{}\"", Self::escape_string(s)),
            JsonValue::Array(arr) => {
                let items: Vec<String> = arr.iter().map(|v| Self::serialize(v)).collect();
                format!("[{}]", items.join(","))
            }
            JsonValue::Object(obj) => {
                let items: Vec<String> = obj.iter()
                    .map(|(k, v)| format!("\"{}\":{}", Self::escape_string(k), Self::serialize(v)))
                    .collect();
                format!("{{{}}}", items.join(","))
            }
        }
    }

    fn escape_string(s: &str) -> String {
        let mut result = String::new();
        for c in s.chars() {
            match c {
                '"' => result.push_str("\\\""),
                '\\' => result.push_str("\\\\"),
                '\n' => result.push_str("\\n"),
                '\r' => result.push_str("\\r"),
                '\t' => result.push_str("\\t"),
                c => result.push(c),
            }
        }
        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TYPE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// QuantaLang type representation
#[derive(Clone, Debug, PartialEq)]
pub enum Type {
    /// Unknown type (needs inference)
    Unknown,
    /// Never type (!)
    Never,
    /// Unit type ()
    Unit,
    /// Boolean
    Bool,
    /// Signed integers
    I8, I16, I32, I64, I128, Isize,
    /// Unsigned integers
    U8, U16, U32, U64, U128, Usize,
    /// Floating point
    F32, F64,
    /// Character
    Char,
    /// String slice
    Str,
    /// Owned string
    String,
    /// Array with element type and optional size
    Array(Box<Type>, Option<usize>),
    /// Slice
    Slice(Box<Type>),
    /// Tuple
    Tuple(Vec<Type>),
    /// Reference
    Reference { mutable: bool, inner: Box<Type>, lifetime: Option<String> },
    /// Pointer
    Pointer { mutable: bool, inner: Box<Type> },
    /// Option<T>
    Option(Box<Type>),
    /// Result<T, E>
    Result(Box<Type>, Box<Type>),
    /// Vec<T>
    Vec(Box<Type>),
    /// HashMap<K, V>
    HashMap(Box<Type>, Box<Type>),
    /// HashSet<T>
    HashSet(Box<Type>),
    /// Box<T>
    Box(Box<Type>),
    /// Rc<T>
    Rc(Box<Type>),
    /// Arc<T>
    Arc(Box<Type>),
    /// Function type
    Function { params: Vec<Type>, return_type: Box<Type>, is_async: bool },
    /// Closure type
    Closure { captures: Vec<(String, Type)>, params: Vec<Type>, return_type: Box<Type> },
    /// Named type (struct, enum, type alias)
    Named { name: String, module: Option<String>, generics: Vec<Type> },
    /// Trait object
    TraitObject { traits: Vec<String>, lifetime: Option<String> },
    /// impl Trait
    ImplTrait(Vec<String>),
    /// Generic type parameter
    TypeParam { name: String, bounds: Vec<String> },
    /// Associated type
    Associated { base: Box<Type>, name: String },
    /// Inferred placeholder
    Infer(u32),
}

impl Type {
    pub fn display(&self) -> String {
        match self {
            Type::Unknown => "_".to_string(),
            Type::Never => "!".to_string(),
            Type::Unit => "()".to_string(),
            Type::Bool => "bool".to_string(),
            Type::I8 => "i8".to_string(),
            Type::I16 => "i16".to_string(),
            Type::I32 => "i32".to_string(),
            Type::I64 => "i64".to_string(),
            Type::I128 => "i128".to_string(),
            Type::Isize => "isize".to_string(),
            Type::U8 => "u8".to_string(),
            Type::U16 => "u16".to_string(),
            Type::U32 => "u32".to_string(),
            Type::U64 => "u64".to_string(),
            Type::U128 => "u128".to_string(),
            Type::Usize => "usize".to_string(),
            Type::F32 => "f32".to_string(),
            Type::F64 => "f64".to_string(),
            Type::Char => "char".to_string(),
            Type::Str => "str".to_string(),
            Type::String => "String".to_string(),
            Type::Array(inner, size) => {
                if let Some(n) = size {
                    format!("[{}; {}]", inner.display(), n)
                } else {
                    format!("[{}]", inner.display())
                }
            }
            Type::Slice(inner) => format!("[{}]", inner.display()),
            Type::Tuple(types) => {
                let inner: Vec<String> = types.iter().map(|t| t.display()).collect();
                format!("({})", inner.join(", "))
            }
            Type::Reference { mutable, inner, lifetime } => {
                let lt = lifetime.as_ref().map(|l| format!("'{} ", l)).unwrap_or_default();
                if *mutable {
                    format!("&{}mut {}", lt, inner.display())
                } else {
                    format!("&{}{}", lt, inner.display())
                }
            }
            Type::Option(inner) => format!("Option<{}>", inner.display()),
            Type::Result(ok, err) => format!("Result<{}, {}>", ok.display(), err.display()),
            Type::Vec(inner) => format!("Vec<{}>", inner.display()),
            Type::HashMap(k, v) => format!("HashMap<{}, {}>", k.display(), v.display()),
            Type::HashSet(inner) => format!("HashSet<{}>", inner.display()),
            Type::Box(inner) => format!("Box<{}>", inner.display()),
            Type::Rc(inner) => format!("Rc<{}>", inner.display()),
            Type::Arc(inner) => format!("Arc<{}>", inner.display()),
            Type::Function { params, return_type, is_async } => {
                let async_str = if *is_async { "async " } else { "" };
                let params_str: Vec<String> = params.iter().map(|t| t.display()).collect();
                format!("{}fn({}) -> {}", async_str, params_str.join(", "), return_type.display())
            }
            Type::Named { name, generics, .. } => {
                if generics.is_empty() {
                    name.clone()
                } else {
                    let gen_str: Vec<String> = generics.iter().map(|t| t.display()).collect();
                    format!("{}<{}>", name, gen_str.join(", "))
                }
            }
            Type::TraitObject { traits, lifetime } => {
                let lt = lifetime.as_ref().map(|l| format!("'{} + ", l)).unwrap_or_default();
                format!("dyn {}{}", lt, traits.join(" + "))
            }
            Type::ImplTrait(traits) => format!("impl {}", traits.join(" + ")),
            Type::TypeParam { name, bounds } => {
                if bounds.is_empty() {
                    name.clone()
                } else {
                    format!("{}: {}", name, bounds.join(" + "))
                }
            }
            _ => "?".to_string(),
        }
    }

    pub fn is_numeric(&self) -> bool {
        matches!(self,
            Type::I8 | Type::I16 | Type::I32 | Type::I64 | Type::I128 | Type::Isize |
            Type::U8 | Type::U16 | Type::U32 | Type::U64 | Type::U128 | Type::Usize |
            Type::F32 | Type::F64
        )
    }

    pub fn is_integer(&self) -> bool {
        matches!(self,
            Type::I8 | Type::I16 | Type::I32 | Type::I64 | Type::I128 | Type::Isize |
            Type::U8 | Type::U16 | Type::U32 | Type::U64 | Type::U128 | Type::Usize
        )
    }

    pub fn is_float(&self) -> bool {
        matches!(self, Type::F32 | Type::F64)
    }
}

/// Type inference context
pub struct TypeInference {
    substitutions: HashMap<u32, Type>,
    next_var: u32,
    errors: Vec<TypeError>,
}

#[derive(Clone, Debug)]
pub struct TypeError {
    pub range: Range,
    pub expected: Type,
    pub actual: Type,
    pub message: String,
}

impl TypeInference {
    pub fn new() -> Self {
        TypeInference {
            substitutions: HashMap::new(),
            next_var: 0,
            errors: Vec::new(),
        }
    }

    pub fn fresh_var(&mut self) -> Type {
        let var = self.next_var;
        self.next_var += 1;
        Type::Infer(var)
    }

    pub fn unify(&mut self, t1: &Type, t2: &Type, range: Range) -> bool {
        let t1 = self.resolve(t1);
        let t2 = self.resolve(t2);

        match (&t1, &t2) {
            (Type::Infer(v1), Type::Infer(v2)) if v1 == v2 => true,
            (Type::Infer(v), t) | (t, Type::Infer(v)) => {
                if self.occurs_check(*v, t) {
                    self.errors.push(TypeError {
                        range,
                        expected: t1.clone(),
                        actual: t2.clone(),
                        message: "Recursive type detected".to_string(),
                    });
                    false
                } else {
                    self.substitutions.insert(*v, t.clone());
                    true
                }
            }
            (Type::Unknown, _) | (_, Type::Unknown) => true,
            (Type::Unit, Type::Unit) => true,
            (Type::Bool, Type::Bool) => true,
            (Type::I32, Type::I32) => true,
            (Type::I64, Type::I64) => true,
            (Type::F32, Type::F32) => true,
            (Type::F64, Type::F64) => true,
            (Type::String, Type::String) => true,
            (Type::Str, Type::Str) => true,
            (Type::Option(a), Type::Option(b)) => self.unify(a, b, range),
            (Type::Result(a1, a2), Type::Result(b1, b2)) => {
                self.unify(a1, b1, range) && self.unify(a2, b2, range)
            }
            (Type::Vec(a), Type::Vec(b)) => self.unify(a, b, range),
            (Type::Reference { mutable: m1, inner: i1, .. }, Type::Reference { mutable: m2, inner: i2, .. }) => {
                m1 == m2 && self.unify(i1, i2, range)
            }
            (Type::Tuple(ts1), Type::Tuple(ts2)) if ts1.len() == ts2.len() => {
                ts1.iter().zip(ts2.iter()).all(|(a, b)| self.unify(a, b, range))
            }
            (Type::Function { params: p1, return_type: r1, .. },
             Type::Function { params: p2, return_type: r2, .. }) if p1.len() == p2.len() => {
                p1.iter().zip(p2.iter()).all(|(a, b)| self.unify(a, b, range)) &&
                self.unify(r1, r2, range)
            }
            (Type::Named { name: n1, generics: g1, .. }, Type::Named { name: n2, generics: g2, .. }) => {
                n1 == n2 && g1.len() == g2.len() &&
                g1.iter().zip(g2.iter()).all(|(a, b)| self.unify(a, b, range))
            }
            _ => {
                if t1 != t2 {
                    self.errors.push(TypeError {
                        range,
                        expected: t1.clone(),
                        actual: t2.clone(),
                        message: format!("Type mismatch: expected {}, found {}", t1.display(), t2.display()),
                    });
                    false
                } else {
                    true
                }
            }
        }
    }

    fn resolve(&self, ty: &Type) -> Type {
        match ty {
            Type::Infer(v) => {
                if let Some(t) = self.substitutions.get(v) {
                    self.resolve(t)
                } else {
                    ty.clone()
                }
            }
            Type::Option(inner) => Type::Option(Box::new(self.resolve(inner))),
            Type::Result(ok, err) => Type::Result(Box::new(self.resolve(ok)), Box::new(self.resolve(err))),
            Type::Vec(inner) => Type::Vec(Box::new(self.resolve(inner))),
            Type::Reference { mutable, inner, lifetime } => Type::Reference {
                mutable: *mutable,
                inner: Box::new(self.resolve(inner)),
                lifetime: lifetime.clone(),
            },
            Type::Tuple(types) => Type::Tuple(types.iter().map(|t| self.resolve(t)).collect()),
            Type::Function { params, return_type, is_async } => Type::Function {
                params: params.iter().map(|t| self.resolve(t)).collect(),
                return_type: Box::new(self.resolve(return_type)),
                is_async: *is_async,
            },
            _ => ty.clone(),
        }
    }

    fn occurs_check(&self, var: u32, ty: &Type) -> bool {
        match ty {
            Type::Infer(v) if *v == var => true,
            Type::Infer(v) => {
                if let Some(t) = self.substitutions.get(v) {
                    self.occurs_check(var, t)
                } else {
                    false
                }
            }
            Type::Option(inner) | Type::Vec(inner) | Type::Box(inner) |
            Type::Rc(inner) | Type::Arc(inner) | Type::HashSet(inner) => {
                self.occurs_check(var, inner)
            }
            Type::Result(ok, err) | Type::HashMap(ok, err) => {
                self.occurs_check(var, ok) || self.occurs_check(var, err)
            }
            Type::Tuple(types) => types.iter().any(|t| self.occurs_check(var, t)),
            Type::Reference { inner, .. } => self.occurs_check(var, inner),
            Type::Function { params, return_type, .. } => {
                params.iter().any(|t| self.occurs_check(var, t)) ||
                self.occurs_check(var, return_type)
            }
            _ => false,
        }
    }

    pub fn get_errors(&self) -> &[TypeError] {
        &self.errors
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEMANTIC TOKENS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum SemanticTokenType {
    Namespace = 0,
    Type = 1,
    Class = 2,
    Enum = 3,
    Interface = 4,
    Struct = 5,
    TypeParameter = 6,
    Parameter = 7,
    Variable = 8,
    Property = 9,
    EnumMember = 10,
    Event = 11,
    Function = 12,
    Method = 13,
    Macro = 14,
    Keyword = 15,
    Modifier = 16,
    Comment = 17,
    String = 18,
    Number = 19,
    Regexp = 20,
    Operator = 21,
    Decorator = 22,
    Label = 23,
    Lifetime = 24,
    SelfKeyword = 25,
    Attribute = 26,
}

#[derive(Clone, Copy, Debug)]
pub struct SemanticTokenModifiers {
    bits: u32,
}

impl SemanticTokenModifiers {
    pub const DECLARATION: u32 = 1 << 0;
    pub const DEFINITION: u32 = 1 << 1;
    pub const READONLY: u32 = 1 << 2;
    pub const STATIC: u32 = 1 << 3;
    pub const DEPRECATED: u32 = 1 << 4;
    pub const ABSTRACT: u32 = 1 << 5;
    pub const ASYNC: u32 = 1 << 6;
    pub const MODIFICATION: u32 = 1 << 7;
    pub const DOCUMENTATION: u32 = 1 << 8;
    pub const DEFAULT_LIBRARY: u32 = 1 << 9;
    pub const MUTABLE: u32 = 1 << 10;
    pub const PUBLIC: u32 = 1 << 11;
    pub const UNSAFE: u32 = 1 << 12;

    pub fn new() -> Self {
        SemanticTokenModifiers { bits: 0 }
    }

    pub fn with(mut self, modifier: u32) -> Self {
        self.bits |= modifier;
        self
    }

    pub fn bits(&self) -> u32 {
        self.bits
    }
}

#[derive(Clone, Debug)]
pub struct SemanticToken {
    pub delta_line: u32,
    pub delta_start: u32,
    pub length: u32,
    pub token_type: SemanticTokenType,
    pub modifiers: SemanticTokenModifiers,
}

pub struct SemanticTokenizer {
    tokens: Vec<SemanticToken>,
    last_line: u32,
    last_start: u32,
}

impl SemanticTokenizer {
    pub fn new() -> Self {
        SemanticTokenizer {
            tokens: Vec::new(),
            last_line: 0,
            last_start: 0,
        }
    }

    pub fn add_token(&mut self, line: u32, start: u32, length: u32,
                     token_type: SemanticTokenType, modifiers: SemanticTokenModifiers) {
        let delta_line = line - self.last_line;
        let delta_start = if delta_line == 0 {
            start - self.last_start
        } else {
            start
        };

        self.tokens.push(SemanticToken {
            delta_line,
            delta_start,
            length,
            token_type,
            modifiers,
        });

        self.last_line = line;
        self.last_start = start;
    }

    pub fn tokenize(&mut self, doc: &Document) {
        for (line_num, line) in doc.lines.iter().enumerate() {
            self.tokenize_line(line_num as u32, line);
        }
    }

    fn tokenize_line(&mut self, line_num: u32, line: &str) {
        let chars: Vec<char> = line.chars().collect();
        let mut pos = 0;

        while pos < chars.len() {
            // Skip whitespace
            if chars[pos].is_whitespace() {
                pos += 1;
                continue;
            }

            // Comments
            if pos + 1 < chars.len() && chars[pos] == '/' && chars[pos + 1] == '/' {
                let start = pos;
                let length = chars.len() - pos;
                self.add_token(line_num, start as u32, length as u32,
                    SemanticTokenType::Comment, SemanticTokenModifiers::new());
                break;
            }

            // Strings
            if chars[pos] == '"' {
                let start = pos;
                pos += 1;
                while pos < chars.len() && chars[pos] != '"' {
                    if chars[pos] == '\\' { pos += 1; }
                    pos += 1;
                }
                pos += 1;
                let length = pos - start;
                self.add_token(line_num, start as u32, length as u32,
                    SemanticTokenType::String, SemanticTokenModifiers::new());
                continue;
            }

            // Lifetimes
            if chars[pos] == '\'' && pos + 1 < chars.len() && chars[pos + 1].is_alphabetic() {
                let start = pos;
                pos += 1;
                while pos < chars.len() && (chars[pos].is_alphanumeric() || chars[pos] == '_') {
                    pos += 1;
                }
                let length = pos - start;
                self.add_token(line_num, start as u32, length as u32,
                    SemanticTokenType::Lifetime, SemanticTokenModifiers::new());
                continue;
            }

            // Numbers
            if chars[pos].is_digit(10) {
                let start = pos;
                while pos < chars.len() && (chars[pos].is_alphanumeric() || chars[pos] == '.' || chars[pos] == '_') {
                    pos += 1;
                }
                let length = pos - start;
                self.add_token(line_num, start as u32, length as u32,
                    SemanticTokenType::Number, SemanticTokenModifiers::new());
                continue;
            }

            // Identifiers and keywords
            if chars[pos].is_alphabetic() || chars[pos] == '_' {
                let start = pos;
                while pos < chars.len() && (chars[pos].is_alphanumeric() || chars[pos] == '_' || chars[pos] == '!') {
                    pos += 1;
                }
                let word: String = chars[start..pos].iter().collect();
                let length = pos - start;

                let (token_type, modifiers) = self.classify_word(&word);
                self.add_token(line_num, start as u32, length as u32, token_type, modifiers);
                continue;
            }

            // Attributes
            if chars[pos] == '#' && pos + 1 < chars.len() && chars[pos + 1] == '[' {
                let start = pos;
                while pos < chars.len() && chars[pos] != ']' {
                    pos += 1;
                }
                pos += 1;
                let length = pos - start;
                self.add_token(line_num, start as u32, length as u32,
                    SemanticTokenType::Attribute, SemanticTokenModifiers::new());
                continue;
            }

            // Operators
            if "+-*/%&|^!<>=@?".contains(chars[pos]) {
                let start = pos;
                while pos < chars.len() && "+-*/%&|^!<>=@?".contains(chars[pos]) {
                    pos += 1;
                }
                let length = pos - start;
                self.add_token(line_num, start as u32, length as u32,
                    SemanticTokenType::Operator, SemanticTokenModifiers::new());
                continue;
            }

            pos += 1;
        }
    }

    fn classify_word(&self, word: &str) -> (SemanticTokenType, SemanticTokenModifiers) {
        let keywords = ["let", "mut", "fn", "pub", "struct", "enum", "impl", "trait",
            "if", "else", "match", "for", "while", "loop", "break", "continue",
            "return", "use", "mod", "type", "where", "async", "await",
            "true", "false", "const", "static", "unsafe", "extern", "crate", "super",
            "dyn", "move", "ref", "in", "as"];

        let modifiers_words = ["pub", "mut", "const", "static", "async", "unsafe", "extern"];

        let types = ["i8", "i16", "i32", "i64", "i128", "isize",
            "u8", "u16", "u32", "u64", "u128", "usize",
            "f32", "f64", "bool", "char", "str", "String",
            "Vec", "HashMap", "HashSet", "Option", "Result",
            "Box", "Rc", "Arc", "Mutex", "RwLock", "Self"];

        if word == "self" {
            return (SemanticTokenType::SelfKeyword, SemanticTokenModifiers::new());
        }

        if word.ends_with('!') {
            return (SemanticTokenType::Macro, SemanticTokenModifiers::new());
        }

        if keywords.contains(&word) {
            let mut mods = SemanticTokenModifiers::new();
            if modifiers_words.contains(&word) {
                mods = mods.with(SemanticTokenModifiers::MODIFICATION);
            }
            return (SemanticTokenType::Keyword, mods);
        }

        if types.contains(&word) {
            return (SemanticTokenType::Type, SemanticTokenModifiers::new().with(SemanticTokenModifiers::DEFAULT_LIBRARY));
        }

        // Check if it starts with uppercase (likely a type)
        if word.chars().next().map(|c| c.is_uppercase()).unwrap_or(false) {
            return (SemanticTokenType::Type, SemanticTokenModifiers::new());
        }

        (SemanticTokenType::Variable, SemanticTokenModifiers::new())
    }

    pub fn get_data(&self) -> Vec<u32> {
        let mut data = Vec::with_capacity(self.tokens.len() * 5);
        for token in &self.tokens {
            data.push(token.delta_line);
            data.push(token.delta_start);
            data.push(token.length);
            data.push(token.token_type as u32);
            data.push(token.modifiers.bits());
        }
        data
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYMBOL TABLE & SCOPE ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Symbol information
#[derive(Clone, Debug)]
pub struct Symbol {
    pub name: String,
    pub kind: SymbolKind,
    pub ty: Type,
    pub range: Range,
    pub selection_range: Range,
    pub definition_uri: String,
    pub visibility: Visibility,
    pub documentation: Option<String>,
    pub signature: Option<String>,
    pub children: Vec<Symbol>,
}

#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum Visibility {
    Private,
    Crate,
    Super,
    Public,
    PubCrate,
    PubSuper,
    PubIn(/* path would go here */),
}

/// Scope for variable resolution
#[derive(Clone, Debug)]
pub struct Scope {
    pub id: u32,
    pub parent: Option<u32>,
    pub kind: ScopeKind,
    pub range: Range,
    pub symbols: HashMap<String, LocalSymbol>,
}

#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum ScopeKind {
    Module,
    Function,
    Block,
    Loop,
    Match,
    Closure,
    Impl,
    Trait,
}

#[derive(Clone, Debug)]
pub struct LocalSymbol {
    pub name: String,
    pub ty: Type,
    pub range: Range,
    pub mutable: bool,
    pub used: bool,
    pub reassigned: bool,
}

/// Manages scopes and symbol resolution
pub struct ScopeManager {
    scopes: Vec<Scope>,
    current_scope: u32,
    next_scope_id: u32,
}

impl ScopeManager {
    pub fn new() -> Self {
        let root_scope = Scope {
            id: 0,
            parent: None,
            kind: ScopeKind::Module,
            range: Range {
                start: Position { line: 0, character: 0 },
                end: Position { line: u32::MAX, character: u32::MAX },
            },
            symbols: HashMap::new(),
        };

        ScopeManager {
            scopes: vec![root_scope],
            current_scope: 0,
            next_scope_id: 1,
        }
    }

    pub fn push_scope(&mut self, kind: ScopeKind, range: Range) {
        let new_scope = Scope {
            id: self.next_scope_id,
            parent: Some(self.current_scope),
            kind,
            range,
            symbols: HashMap::new(),
        };
        self.current_scope = self.next_scope_id;
        self.next_scope_id += 1;
        self.scopes.push(new_scope);
    }

    pub fn pop_scope(&mut self) {
        if let Some(scope) = self.scopes.get(self.current_scope as usize) {
            if let Some(parent) = scope.parent {
                self.current_scope = parent;
            }
        }
    }

    pub fn define(&mut self, name: String, ty: Type, range: Range, mutable: bool) {
        let symbol = LocalSymbol {
            name: name.clone(),
            ty,
            range,
            mutable,
            used: false,
            reassigned: false,
        };

        if let Some(scope) = self.scopes.get_mut(self.current_scope as usize) {
            scope.symbols.insert(name, symbol);
        }
    }

    pub fn lookup(&self, name: &str) -> Option<&LocalSymbol> {
        let mut scope_id = Some(self.current_scope);

        while let Some(id) = scope_id {
            if let Some(scope) = self.scopes.get(id as usize) {
                if let Some(symbol) = scope.symbols.get(name) {
                    return Some(symbol);
                }
                scope_id = scope.parent;
            } else {
                break;
            }
        }

        None
    }

    pub fn mark_used(&mut self, name: &str) {
        let mut scope_id = Some(self.current_scope);

        while let Some(id) = scope_id {
            if let Some(scope) = self.scopes.get_mut(id as usize) {
                if let Some(symbol) = scope.symbols.get_mut(name) {
                    symbol.used = true;
                    return;
                }
                scope_id = scope.parent;
            } else {
                break;
            }
        }
    }

    pub fn get_unused_symbols(&self) -> Vec<&LocalSymbol> {
        self.scopes.iter()
            .flat_map(|s| s.symbols.values())
            .filter(|s| !s.used && !s.name.starts_with('_'))
            .collect()
    }

    pub fn scope_at(&self, pos: Position) -> Option<&Scope> {
        self.scopes.iter()
            .filter(|s| self.position_in_range(pos, &s.range))
            .max_by_key(|s| s.id) // Innermost scope
    }

    fn position_in_range(&self, pos: Position, range: &Range) -> bool {
        if pos.line < range.start.line || pos.line > range.end.line {
            return false;
        }
        if pos.line == range.start.line && pos.character < range.start.character {
            return false;
        }
        if pos.line == range.end.line && pos.character > range.end.character {
            return false;
        }
        true
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CROSS-FILE ANALYSIS & PROJECT INDEX
// ═══════════════════════════════════════════════════════════════════════════════

/// Project-wide index for cross-file navigation
pub struct ProjectIndex {
    /// All symbols indexed by fully qualified name
    symbols: HashMap<String, Symbol>,
    /// Symbols indexed by file URI
    file_symbols: HashMap<String, Vec<String>>,
    /// Import graph
    imports: HashMap<String, Vec<Import>>,
    /// Export map
    exports: HashMap<String, Vec<String>>,
    /// Type definitions
    type_definitions: HashMap<String, TypeDefinition>,
    /// Trait implementations
    impl_map: HashMap<String, Vec<ImplBlock>>,
    /// References for find-all-references
    references: HashMap<String, Vec<Location>>,
}

#[derive(Clone, Debug)]
pub struct Import {
    pub path: Vec<String>,
    pub alias: Option<String>,
    pub items: Vec<String>,
    pub glob: bool,
    pub range: Range,
}

#[derive(Clone, Debug)]
pub struct TypeDefinition {
    pub name: String,
    pub kind: TypeDefKind,
    pub generics: Vec<GenericParam>,
    pub fields: Vec<FieldInfo>,
    pub methods: Vec<MethodInfo>,
    pub traits: Vec<String>,
    pub range: Range,
    pub uri: String,
}

#[derive(Clone, Debug)]
pub enum TypeDefKind {
    Struct,
    Enum,
    Trait,
    TypeAlias,
    Union,
}

#[derive(Clone, Debug)]
pub struct GenericParam {
    pub name: String,
    pub bounds: Vec<String>,
    pub default: Option<String>,
}

#[derive(Clone, Debug)]
pub struct FieldInfo {
    pub name: String,
    pub ty: Type,
    pub visibility: Visibility,
    pub documentation: Option<String>,
}

#[derive(Clone, Debug)]
pub struct MethodInfo {
    pub name: String,
    pub params: Vec<(String, Type)>,
    pub return_type: Type,
    pub visibility: Visibility,
    pub is_async: bool,
    pub is_unsafe: bool,
    pub documentation: Option<String>,
    pub range: Range,
}

#[derive(Clone, Debug)]
pub struct ImplBlock {
    pub target_type: String,
    pub trait_name: Option<String>,
    pub generics: Vec<GenericParam>,
    pub methods: Vec<MethodInfo>,
    pub range: Range,
    pub uri: String,
}

impl ProjectIndex {
    pub fn new() -> Self {
        ProjectIndex {
            symbols: HashMap::new(),
            file_symbols: HashMap::new(),
            imports: HashMap::new(),
            exports: HashMap::new(),
            type_definitions: HashMap::new(),
            impl_map: HashMap::new(),
            references: HashMap::new(),
        }
    }

    pub fn index_file(&mut self, uri: &str, doc: &Document, symbols: &[DocumentSymbol]) {
        // Clear old data for this file
        if let Some(old_symbols) = self.file_symbols.remove(uri) {
            for name in old_symbols {
                self.symbols.remove(&name);
            }
        }
        self.imports.remove(uri);

        let mut file_symbol_names = Vec::new();

        // Index symbols
        for symbol in symbols {
            let fq_name = format!("{}::{}", uri, symbol.name);
            file_symbol_names.push(fq_name.clone());

            self.symbols.insert(fq_name, Symbol {
                name: symbol.name.clone(),
                kind: symbol.kind,
                ty: Type::Unknown,
                range: symbol.range,
                selection_range: symbol.selection_range,
                definition_uri: uri.to_string(),
                visibility: Visibility::Private,
                documentation: symbol.detail.clone(),
                signature: symbol.detail.clone(),
                children: Vec::new(),
            });
        }

        // Parse imports
        let imports = self.parse_imports(doc);
        self.imports.insert(uri.to_string(), imports);

        self.file_symbols.insert(uri.to_string(), file_symbol_names);
    }

    fn parse_imports(&self, doc: &Document) -> Vec<Import> {
        let mut imports = Vec::new();

        for (line_num, line) in doc.lines.iter().enumerate() {
            let trimmed = line.trim();
            if trimmed.starts_with("use ") {
                if let Some(import) = self.parse_use_statement(trimmed, line_num as u32) {
                    imports.push(import);
                }
            }
        }

        imports
    }

    fn parse_use_statement(&self, line: &str, line_num: u32) -> Option<Import> {
        let line = line.trim_start_matches("use ").trim_end_matches(';').trim();

        let (path_str, alias) = if let Some(as_pos) = line.find(" as ") {
            (&line[..as_pos], Some(line[as_pos + 4..].trim().to_string()))
        } else {
            (line, None)
        };

        let path: Vec<String> = path_str.split("::").map(String::from).collect();
        let glob = path.last().map(|s| s == "*").unwrap_or(false);

        Some(Import {
            path,
            alias,
            items: Vec::new(),
            glob,
            range: Range {
                start: Position { line: line_num, character: 0 },
                end: Position { line: line_num, character: line.len() as u32 },
            },
        })
    }

    pub fn find_definition(&self, name: &str, from_uri: &str) -> Option<&Symbol> {
        // Check local file first
        let local_fq = format!("{}::{}", from_uri, name);
        if let Some(sym) = self.symbols.get(&local_fq) {
            return Some(sym);
        }

        // Check imports
        if let Some(imports) = self.imports.get(from_uri) {
            for import in imports {
                if import.alias.as_ref().map(|a| a == name).unwrap_or(false) {
                    let fq = import.path.join("::");
                    if let Some(sym) = self.symbols.get(&fq) {
                        return Some(sym);
                    }
                }

                if import.path.last().map(|l| l == name).unwrap_or(false) {
                    let fq = import.path.join("::");
                    if let Some(sym) = self.symbols.get(&fq) {
                        return Some(sym);
                    }
                }
            }
        }

        // Global search
        self.symbols.values().find(|s| s.name == name)
    }

    pub fn find_all_references(&self, name: &str) -> Vec<&Location> {
        self.references.get(name)
            .map(|locs| locs.iter().collect())
            .unwrap_or_default()
    }

    pub fn add_reference(&mut self, name: String, location: Location) {
        self.references.entry(name).or_insert_with(Vec::new).push(location);
    }

    pub fn workspace_symbols(&self, query: &str) -> Vec<&Symbol> {
        let query_lower = query.to_lowercase();
        self.symbols.values()
            .filter(|s| s.name.to_lowercase().contains(&query_lower))
            .collect()
    }

    pub fn get_type_definition(&self, name: &str) -> Option<&TypeDefinition> {
        self.type_definitions.get(name)
    }

    pub fn get_impls_for_type(&self, type_name: &str) -> Vec<&ImplBlock> {
        self.impl_map.get(type_name)
            .map(|impls| impls.iter().collect())
            .unwrap_or_default()
    }

    pub fn get_trait_implementors(&self, trait_name: &str) -> Vec<&ImplBlock> {
        self.impl_map.values()
            .flatten()
            .filter(|imp| imp.trait_name.as_ref().map(|t| t == trait_name).unwrap_or(false))
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INLAY HINTS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone, Debug)]
pub struct InlayHint {
    pub position: Position,
    pub label: String,
    pub kind: InlayHintKind,
    pub padding_left: bool,
    pub padding_right: bool,
    pub tooltip: Option<String>,
}

#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum InlayHintKind {
    Type = 1,
    Parameter = 2,
    Chaining = 3,
}

pub struct InlayHintProvider {
    show_type_hints: bool,
    show_parameter_hints: bool,
    show_chaining_hints: bool,
    max_length: usize,
}

impl InlayHintProvider {
    pub fn new() -> Self {
        InlayHintProvider {
            show_type_hints: true,
            show_parameter_hints: true,
            show_chaining_hints: true,
            max_length: 25,
        }
    }

    pub fn provide_hints(&self, doc: &Document, range: Range, scope_mgr: &ScopeManager) -> Vec<InlayHint> {
        let mut hints = Vec::new();

        for (line_num, line) in doc.lines.iter().enumerate() {
            let line_num = line_num as u32;
            if line_num < range.start.line || line_num > range.end.line {
                continue;
            }

            // Type hints for let bindings
            if self.show_type_hints {
                hints.extend(self.find_let_type_hints(line, line_num, scope_mgr));
            }

            // Parameter hints for function calls
            if self.show_parameter_hints {
                hints.extend(self.find_parameter_hints(line, line_num));
            }

            // Chaining hints for method chains
            if self.show_chaining_hints {
                hints.extend(self.find_chaining_hints(line, line_num));
            }
        }

        hints
    }

    fn find_let_type_hints(&self, line: &str, line_num: u32, scope_mgr: &ScopeManager) -> Vec<InlayHint> {
        let mut hints = Vec::new();
        let trimmed = line.trim();

        // Look for `let name = ` patterns without explicit type
        if let Some(let_pos) = trimmed.find("let ") {
            let rest = &trimmed[let_pos + 4..];
            let rest = rest.trim_start_matches("mut ");

            // Find the variable name
            if let Some(eq_pos) = rest.find('=') {
                let name_part = rest[..eq_pos].trim();

                // Skip if there's already a type annotation
                if !name_part.contains(':') {
                    // Try to infer type from RHS
                    let rhs = rest[eq_pos + 1..].trim();
                    if let Some(inferred_type) = self.infer_type_from_expr(rhs) {
                        let type_str = if inferred_type.len() > self.max_length {
                            format!("{}…", &inferred_type[..self.max_length])
                        } else {
                            inferred_type
                        };

                        let hint_pos = line.find(name_part).unwrap_or(0) + name_part.len();
                        hints.push(InlayHint {
                            position: Position { line: line_num, character: hint_pos as u32 },
                            label: format!(": {}", type_str),
                            kind: InlayHintKind::Type,
                            padding_left: false,
                            padding_right: true,
                            tooltip: Some(format!("Inferred type: {}", type_str)),
                        });
                    }
                }
            }
        }

        hints
    }

    fn find_parameter_hints(&self, line: &str, line_num: u32) -> Vec<InlayHint> {
        let mut hints = Vec::new();

        // Simple heuristic: look for function calls with arguments
        let chars: Vec<char> = line.chars().collect();
        let mut pos = 0;

        while pos < chars.len() {
            // Find function call pattern: identifier(
            if chars[pos].is_alphabetic() || chars[pos] == '_' {
                let start = pos;
                while pos < chars.len() && (chars[pos].is_alphanumeric() || chars[pos] == '_') {
                    pos += 1;
                }

                if pos < chars.len() && chars[pos] == '(' {
                    let func_name: String = chars[start..pos].iter().collect();
                    pos += 1; // Skip (

                    // Parse arguments
                    let mut arg_start = pos;
                    let mut depth = 1;
                    let mut arg_num = 0;

                    while pos < chars.len() && depth > 0 {
                        match chars[pos] {
                            '(' | '[' | '{' => depth += 1,
                            ')' | ']' | '}' => depth -= 1,
                            ',' if depth == 1 => {
                                // Found an argument
                                if let Some(param_name) = self.get_parameter_name(&func_name, arg_num) {
                                    hints.push(InlayHint {
                                        position: Position { line: line_num, character: arg_start as u32 },
                                        label: format!("{}: ", param_name),
                                        kind: InlayHintKind::Parameter,
                                        padding_left: false,
                                        padding_right: false,
                                        tooltip: Some(format!("Parameter: {}", param_name)),
                                    });
                                }
                                arg_num += 1;
                                arg_start = pos + 1;
                            }
                            _ => {}
                        }
                        pos += 1;
                    }

                    // Last argument
                    if arg_num > 0 || pos > arg_start + 1 {
                        if let Some(param_name) = self.get_parameter_name(&func_name, arg_num) {
                            hints.push(InlayHint {
                                position: Position { line: line_num, character: arg_start as u32 },
                                label: format!("{}: ", param_name),
                                kind: InlayHintKind::Parameter,
                                padding_left: false,
                                padding_right: false,
                                tooltip: Some(format!("Parameter: {}", param_name)),
                            });
                        }
                    }
                }
            } else {
                pos += 1;
            }
        }

        hints
    }

    fn find_chaining_hints(&self, line: &str, line_num: u32) -> Vec<InlayHint> {
        let mut hints = Vec::new();

        // Look for method chains
        let chars: Vec<char> = line.chars().collect();
        let mut pos = 0;

        while pos < chars.len() {
            if chars[pos] == '.' && pos + 1 < chars.len() && chars[pos + 1].is_alphabetic() {
                // Method call after .
                let method_start = pos + 1;
                pos += 1;

                while pos < chars.len() && (chars[pos].is_alphanumeric() || chars[pos] == '_') {
                    pos += 1;
                }

                if pos < chars.len() && chars[pos] == '(' {
                    let method_name: String = chars[method_start..pos].iter().collect();

                    // Try to infer return type
                    if let Some(return_type) = self.infer_method_return_type(&method_name) {
                        // Find end of method call
                        let mut depth = 1;
                        pos += 1;
                        while pos < chars.len() && depth > 0 {
                            match chars[pos] {
                                '(' => depth += 1,
                                ')' => depth -= 1,
                                _ => {}
                            }
                            pos += 1;
                        }

                        // Only add hint if this is part of a chain
                        if pos < chars.len() && chars[pos] == '.' {
                            hints.push(InlayHint {
                                position: Position { line: line_num, character: pos as u32 },
                                label: format!(" -> {}", return_type),
                                kind: InlayHintKind::Chaining,
                                padding_left: true,
                                padding_right: false,
                                tooltip: Some(format!("Returns: {}", return_type)),
                            });
                        }
                    }
                }
            } else {
                pos += 1;
            }
        }

        hints
    }

    fn infer_type_from_expr(&self, expr: &str) -> Option<String> {
        let expr = expr.trim().trim_end_matches(';');

        // Literal inference
        if expr == "true" || expr == "false" {
            return Some("bool".to_string());
        }
        if expr.starts_with('"') && expr.ends_with('"') {
            return Some("&str".to_string());
        }
        if expr.parse::<i64>().is_ok() {
            return Some("i32".to_string());
        }
        if expr.parse::<f64>().is_ok() {
            return Some("f64".to_string());
        }
        if expr.starts_with("vec!") {
            return Some("Vec<_>".to_string());
        }
        if expr.starts_with("HashMap::new()") {
            return Some("HashMap<_, _>".to_string());
        }
        if expr.starts_with("Some(") {
            return Some("Option<_>".to_string());
        }
        if expr.starts_with("Ok(") || expr.starts_with("Err(") {
            return Some("Result<_, _>".to_string());
        }

        // Constructor patterns
        if let Some(struct_pos) = expr.find("::new()") {
            let struct_name = &expr[..struct_pos];
            return Some(struct_name.to_string());
        }
        if expr.contains(" { ") || expr.ends_with(" }") {
            if let Some(space_pos) = expr.find(' ') {
                return Some(expr[..space_pos].to_string());
            }
        }

        None
    }

    fn get_parameter_name(&self, _func: &str, index: usize) -> Option<String> {
        // This would ideally look up the function signature
        // For now, return generic parameter names
        match index {
            0 => Some("arg0".to_string()),
            1 => Some("arg1".to_string()),
            2 => Some("arg2".to_string()),
            _ => None,
        }
    }

    fn infer_method_return_type(&self, method: &str) -> Option<String> {
        // Common method return types
        match method {
            "map" | "filter" | "take" | "skip" | "chain" | "zip" => Some("Iterator".to_string()),
            "collect" => Some("Collection".to_string()),
            "unwrap" | "expect" => Some("T".to_string()),
            "ok" => Some("Option<T>".to_string()),
            "err" => Some("Option<E>".to_string()),
            "is_some" | "is_none" | "is_ok" | "is_err" => Some("bool".to_string()),
            "len" | "count" => Some("usize".to_string()),
            "to_string" | "to_owned" => Some("String".to_string()),
            "as_str" | "as_ref" => Some("&str".to_string()),
            "clone" => Some("Self".to_string()),
            "iter" | "iter_mut" => Some("Iterator".to_string()),
            "into_iter" => Some("IntoIterator".to_string()),
            _ => None,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CODE ACTIONS & REFACTORING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct CodeActionProvider {
    extract_enabled: bool,
    inline_enabled: bool,
    organize_imports_enabled: bool,
}

impl CodeActionProvider {
    pub fn new() -> Self {
        CodeActionProvider {
            extract_enabled: true,
            inline_enabled: true,
            organize_imports_enabled: true,
        }
    }

    pub fn provide_actions(&self, doc: &Document, range: Range, diagnostics: &[Diagnostic]) -> Vec<CodeAction> {
        let mut actions = Vec::new();

        // Quick fixes for diagnostics
        for diagnostic in diagnostics {
            if self.ranges_overlap(&diagnostic.range, &range) {
                actions.extend(self.quick_fixes_for_diagnostic(doc, diagnostic));
            }
        }

        // Refactoring actions
        if !self.is_empty_range(&range) {
            // Extract function
            if self.extract_enabled {
                if let Some(action) = self.extract_function_action(doc, range) {
                    actions.push(action);
                }
                if let Some(action) = self.extract_variable_action(doc, range) {
                    actions.push(action);
                }
                if let Some(action) = self.extract_constant_action(doc, range) {
                    actions.push(action);
                }
            }

            // Inline
            if self.inline_enabled {
                if let Some(action) = self.inline_variable_action(doc, range) {
                    actions.push(action);
                }
            }
        }

        // Source actions
        if self.organize_imports_enabled {
            actions.push(self.organize_imports_action(doc));
        }

        // Add common refactorings
        actions.push(self.convert_if_to_match_action(doc, range));
        actions.push(self.add_derive_action(doc, range));
        actions.push(self.add_documentation_action(doc, range));

        actions.into_iter().filter_map(|a| a).collect()
    }

    fn quick_fixes_for_diagnostic(&self, doc: &Document, diagnostic: &Diagnostic) -> Vec<CodeAction> {
        let mut fixes = Vec::new();

        let code = diagnostic.code.as_deref().unwrap_or("");
        let message = &diagnostic.message;

        // Unused variable - add underscore prefix
        if message.contains("unused") && message.contains("variable") {
            let line = doc.lines.get(diagnostic.range.start.line as usize);
            if let Some(line) = line {
                let start = diagnostic.range.start.character as usize;
                let end = diagnostic.range.end.character as usize;
                if end <= line.len() {
                    let var_name = &line[start..end];

                    fixes.push(CodeAction {
                        title: format!("Prefix with underscore: _{}", var_name),
                        kind: CodeActionKind::QuickFix,
                        diagnostics: vec![diagnostic.clone()],
                        edit: Some(WorkspaceEdit {
                            changes: {
                                let mut map = HashMap::new();
                                map.insert(doc.uri.clone(), vec![TextEdit {
                                    range: diagnostic.range,
                                    new_text: format!("_{}", var_name),
                                }]);
                                map
                            },
                        }),
                        command: None,
                    });
                }
            }
        }

        // Missing import
        if message.contains("unresolved") || message.contains("not found") {
            // Extract the symbol name and suggest imports
            if let Some(name) = self.extract_symbol_name(message) {
                if let Some(import) = self.suggest_import(&name) {
                    fixes.push(CodeAction {
                        title: format!("Import `{}`", name),
                        kind: CodeActionKind::QuickFix,
                        diagnostics: vec![diagnostic.clone()],
                        edit: Some(WorkspaceEdit {
                            changes: {
                                let mut map = HashMap::new();
                                map.insert(doc.uri.clone(), vec![TextEdit {
                                    range: Range {
                                        start: Position { line: 0, character: 0 },
                                        end: Position { line: 0, character: 0 },
                                    },
                                    new_text: format!("{}\n", import),
                                }]);
                                map
                            },
                        }),
                        command: None,
                    });
                }
            }
        }

        // Missing semicolon
        if message.contains("semicolon") || code == "E0308" {
            fixes.push(CodeAction {
                title: "Add semicolon".to_string(),
                kind: CodeActionKind::QuickFix,
                diagnostics: vec![diagnostic.clone()],
                edit: Some(WorkspaceEdit {
                    changes: {
                        let mut map = HashMap::new();
                        map.insert(doc.uri.clone(), vec![TextEdit {
                            range: Range {
                                start: diagnostic.range.end,
                                end: diagnostic.range.end,
                            },
                            new_text: ";".to_string(),
                        }]);
                        map
                    },
                }),
                command: None,
            });
        }

        // Type mismatch - add type conversion
        if message.contains("expected") && message.contains("found") {
            if let (Some(expected), Some(found)) = (self.extract_type("expected", message), self.extract_type("found", message)) {
                if let Some(conversion) = self.get_type_conversion(&found, &expected) {
                    fixes.push(CodeAction {
                        title: format!("Convert {} to {}", found, expected),
                        kind: CodeActionKind::QuickFix,
                        diagnostics: vec![diagnostic.clone()],
                        edit: Some(WorkspaceEdit {
                            changes: {
                                let mut map = HashMap::new();
                                map.insert(doc.uri.clone(), vec![TextEdit {
                                    range: Range {
                                        start: diagnostic.range.end,
                                        end: diagnostic.range.end,
                                    },
                                    new_text: conversion,
                                }]);
                                map
                            },
                        }),
                        command: None,
                    });
                }
            }
        }

        fixes
    }

    fn extract_function_action(&self, doc: &Document, range: Range) -> Option<CodeAction> {
        // Check if selection is valid for extraction
        let selected_text = self.get_text_in_range(doc, range)?;

        if selected_text.trim().is_empty() {
            return None;
        }

        Some(CodeAction {
            title: "Extract function".to_string(),
            kind: CodeActionKind::RefactorExtract,
            diagnostics: Vec::new(),
            edit: None, // Would need command to prompt for function name
            command: Some(Command {
                title: "Extract function".to_string(),
                command: "quanta.extractFunction".to_string(),
                arguments: vec![
                    doc.uri.clone(),
                    format!("{},{},{},{}", range.start.line, range.start.character, range.end.line, range.end.character),
                ],
            }),
        })
    }

    fn extract_variable_action(&self, doc: &Document, range: Range) -> Option<CodeAction> {
        let selected_text = self.get_text_in_range(doc, range)?;

        if selected_text.trim().is_empty() || selected_text.contains('\n') {
            return None;
        }

        Some(CodeAction {
            title: "Extract variable".to_string(),
            kind: CodeActionKind::RefactorExtract,
            diagnostics: Vec::new(),
            edit: None,
            command: Some(Command {
                title: "Extract variable".to_string(),
                command: "quanta.extractVariable".to_string(),
                arguments: vec![doc.uri.clone()],
            }),
        })
    }

    fn extract_constant_action(&self, doc: &Document, range: Range) -> Option<CodeAction> {
        let selected_text = self.get_text_in_range(doc, range)?;

        // Check if it's a literal value
        let trimmed = selected_text.trim();
        let is_literal = trimmed.parse::<i64>().is_ok() ||
            trimmed.parse::<f64>().is_ok() ||
            (trimmed.starts_with('"') && trimmed.ends_with('"'));

        if !is_literal {
            return None;
        }

        Some(CodeAction {
            title: "Extract constant".to_string(),
            kind: CodeActionKind::RefactorExtract,
            diagnostics: Vec::new(),
            edit: None,
            command: Some(Command {
                title: "Extract constant".to_string(),
                command: "quanta.extractConstant".to_string(),
                arguments: vec![doc.uri.clone()],
            }),
        })
    }

    fn inline_variable_action(&self, _doc: &Document, _range: Range) -> Option<CodeAction> {
        Some(CodeAction {
            title: "Inline variable".to_string(),
            kind: CodeActionKind::RefactorInline,
            diagnostics: Vec::new(),
            edit: None,
            command: Some(Command {
                title: "Inline variable".to_string(),
                command: "quanta.inlineVariable".to_string(),
                arguments: Vec::new(),
            }),
        })
    }

    fn organize_imports_action(&self, doc: &Document) -> Option<CodeAction> {
        // Collect all imports
        let mut imports: Vec<(usize, String)> = Vec::new();
        let mut first_import_line = None;
        let mut last_import_line = None;

        for (i, line) in doc.lines.iter().enumerate() {
            if line.trim().starts_with("use ") {
                if first_import_line.is_none() {
                    first_import_line = Some(i);
                }
                last_import_line = Some(i);
                imports.push((i, line.clone()));
            }
        }

        if imports.len() <= 1 {
            return None;
        }

        // Sort imports
        let mut sorted_imports = imports.clone();
        sorted_imports.sort_by(|a, b| {
            let a_std = a.1.contains("std::");
            let b_std = b.1.contains("std::");
            match (a_std, b_std) {
                (true, false) => std::cmp::Ordering::Less,
                (false, true) => std::cmp::Ordering::Greater,
                _ => a.1.cmp(&b.1),
            }
        });

        let first = first_import_line?;
        let last = last_import_line?;

        let new_text = sorted_imports.iter()
            .map(|(_, s)| s.as_str())
            .collect::<Vec<_>>()
            .join("\n");

        Some(CodeAction {
            title: "Organize imports".to_string(),
            kind: CodeActionKind::SourceOrganizeImports,
            diagnostics: Vec::new(),
            edit: Some(WorkspaceEdit {
                changes: {
                    let mut map = HashMap::new();
                    map.insert(doc.uri.clone(), vec![TextEdit {
                        range: Range {
                            start: Position { line: first as u32, character: 0 },
                            end: Position { line: (last + 1) as u32, character: 0 },
                        },
                        new_text: format!("{}\n", new_text),
                    }]);
                    map
                },
            }),
            command: None,
        })
    }

    fn convert_if_to_match_action(&self, _doc: &Document, _range: Range) -> Option<CodeAction> {
        Some(CodeAction {
            title: "Convert if-else to match".to_string(),
            kind: CodeActionKind::RefactorRewrite,
            diagnostics: Vec::new(),
            edit: None,
            command: Some(Command {
                title: "Convert if-else to match".to_string(),
                command: "quanta.convertIfToMatch".to_string(),
                arguments: Vec::new(),
            }),
        })
    }

    fn add_derive_action(&self, _doc: &Document, _range: Range) -> Option<CodeAction> {
        Some(CodeAction {
            title: "Add derive macro".to_string(),
            kind: CodeActionKind::Refactor,
            diagnostics: Vec::new(),
            edit: None,
            command: Some(Command {
                title: "Add derive macro".to_string(),
                command: "quanta.addDerive".to_string(),
                arguments: Vec::new(),
            }),
        })
    }

    fn add_documentation_action(&self, _doc: &Document, _range: Range) -> Option<CodeAction> {
        Some(CodeAction {
            title: "Generate documentation".to_string(),
            kind: CodeActionKind::Refactor,
            diagnostics: Vec::new(),
            edit: None,
            command: Some(Command {
                title: "Generate documentation".to_string(),
                command: "quanta.generateDocs".to_string(),
                arguments: Vec::new(),
            }),
        })
    }

    fn ranges_overlap(&self, r1: &Range, r2: &Range) -> bool {
        !(r1.end.line < r2.start.line ||
          (r1.end.line == r2.start.line && r1.end.character < r2.start.character) ||
          r2.end.line < r1.start.line ||
          (r2.end.line == r1.start.line && r2.end.character < r1.start.character))
    }

    fn is_empty_range(&self, range: &Range) -> bool {
        range.start.line == range.end.line && range.start.character == range.end.character
    }

    fn get_text_in_range(&self, doc: &Document, range: Range) -> Option<String> {
        if range.start.line == range.end.line {
            let line = doc.lines.get(range.start.line as usize)?;
            let start = range.start.character as usize;
            let end = range.end.character as usize;
            if end <= line.len() {
                return Some(line[start..end].to_string());
            }
        } else {
            let mut result = String::new();
            for line_num in range.start.line..=range.end.line {
                if let Some(line) = doc.lines.get(line_num as usize) {
                    if line_num == range.start.line {
                        result.push_str(&line[range.start.character as usize..]);
                    } else if line_num == range.end.line {
                        result.push_str(&line[..range.end.character as usize]);
                    } else {
                        result.push_str(line);
                    }
                    result.push('\n');
                }
            }
            return Some(result);
        }
        None
    }

    fn extract_symbol_name(&self, message: &str) -> Option<String> {
        // Try to extract backtick-quoted names
        if let Some(start) = message.find('`') {
            if let Some(end) = message[start + 1..].find('`') {
                return Some(message[start + 1..start + 1 + end].to_string());
            }
        }
        None
    }

    fn suggest_import(&self, name: &str) -> Option<String> {
        // Common imports mapping
        let common = [
            ("Vec", "use std::vec::Vec;"),
            ("HashMap", "use std::collections::HashMap;"),
            ("HashSet", "use std::collections::HashSet;"),
            ("Arc", "use std::sync::Arc;"),
            ("Mutex", "use std::sync::Mutex;"),
            ("RwLock", "use std::sync::RwLock;"),
            ("Rc", "use std::rc::Rc;"),
            ("RefCell", "use std::cell::RefCell;"),
            ("Path", "use std::path::Path;"),
            ("PathBuf", "use std::path::PathBuf;"),
            ("File", "use std::fs::File;"),
            ("Read", "use std::io::Read;"),
            ("Write", "use std::io::Write;"),
            ("BufReader", "use std::io::BufReader;"),
            ("BufWriter", "use std::io::BufWriter;"),
        ];

        for (sym, import) in common {
            if sym == name {
                return Some(import.to_string());
            }
        }

        None
    }

    fn extract_type(&self, label: &str, message: &str) -> Option<String> {
        let pattern = format!("{} `", label);
        if let Some(start) = message.find(&pattern) {
            let rest = &message[start + pattern.len()..];
            if let Some(end) = rest.find('`') {
                return Some(rest[..end].to_string());
            }
        }
        None
    }

    fn get_type_conversion(&self, from: &str, to: &str) -> Option<String> {
        match (from, to) {
            ("i32", "i64") => Some(".into()".to_string()),
            ("i64", "i32") => Some(" as i32".to_string()),
            ("&str", "String") => Some(".to_string()".to_string()),
            ("String", "&str") => Some(".as_str()".to_string()),
            ("Option<_>", "_") => Some(".unwrap()".to_string()),
            ("Result<_, _>", "_") => Some(".unwrap()".to_string()),
            _ => None,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNATURE HELP
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone, Debug)]
pub struct SignatureHelp {
    pub signatures: Vec<SignatureInformation>,
    pub active_signature: u32,
    pub active_parameter: u32,
}

#[derive(Clone, Debug)]
pub struct SignatureInformation {
    pub label: String,
    pub documentation: Option<String>,
    pub parameters: Vec<ParameterInformation>,
}

#[derive(Clone, Debug)]
pub struct ParameterInformation {
    pub label: (u32, u32), // Start and end offsets in signature label
    pub documentation: Option<String>,
}

pub struct SignatureHelpProvider {
    /// Known function signatures
    signatures: HashMap<String, Vec<SignatureInformation>>,
}

impl SignatureHelpProvider {
    pub fn new() -> Self {
        let mut provider = SignatureHelpProvider {
            signatures: HashMap::new(),
        };

        // Add built-in signatures
        provider.add_builtin_signatures();

        provider
    }

    fn add_builtin_signatures(&mut self) {
        // Vec methods
        self.signatures.insert("push".to_string(), vec![
            SignatureInformation {
                label: "fn push(&mut self, value: T)".to_string(),
                documentation: Some("Appends an element to the back of the collection.".to_string()),
                parameters: vec![
                    ParameterInformation {
                        label: (24, 32),
                        documentation: Some("The value to append".to_string()),
                    },
                ],
            },
        ]);

        self.signatures.insert("pop".to_string(), vec![
            SignatureInformation {
                label: "fn pop(&mut self) -> Option<T>".to_string(),
                documentation: Some("Removes the last element and returns it, or None if empty.".to_string()),
                parameters: Vec::new(),
            },
        ]);

        self.signatures.insert("get".to_string(), vec![
            SignatureInformation {
                label: "fn get(&self, index: usize) -> Option<&T>".to_string(),
                documentation: Some("Returns a reference to an element at the given index.".to_string()),
                parameters: vec![
                    ParameterInformation {
                        label: (18, 30),
                        documentation: Some("The index to get".to_string()),
                    },
                ],
            },
        ]);

        self.signatures.insert("map".to_string(), vec![
            SignatureInformation {
                label: "fn map<B, F>(self, f: F) -> Map<Self, F> where F: FnMut(Self::Item) -> B".to_string(),
                documentation: Some("Takes a closure and creates an iterator which calls that closure on each element.".to_string()),
                parameters: vec![
                    ParameterInformation {
                        label: (20, 24),
                        documentation: Some("The mapping function".to_string()),
                    },
                ],
            },
        ]);

        self.signatures.insert("filter".to_string(), vec![
            SignatureInformation {
                label: "fn filter<P>(self, predicate: P) -> Filter<Self, P> where P: FnMut(&Self::Item) -> bool".to_string(),
                documentation: Some("Creates an iterator which yields elements based on a predicate.".to_string()),
                parameters: vec![
                    ParameterInformation {
                        label: (21, 34),
                        documentation: Some("The filter predicate".to_string()),
                    },
                ],
            },
        ]);

        self.signatures.insert("collect".to_string(), vec![
            SignatureInformation {
                label: "fn collect<B>(self) -> B where B: FromIterator<Self::Item>".to_string(),
                documentation: Some("Transforms an iterator into a collection.".to_string()),
                parameters: Vec::new(),
            },
        ]);
    }

    pub fn provide_signature_help(&self, doc: &Document, pos: Position) -> Option<SignatureHelp> {
        let line = doc.lines.get(pos.line as usize)?;
        let prefix = &line[..pos.character as usize];

        // Find the function being called
        let (func_name, active_param) = self.find_function_context(prefix)?;

        let signatures = self.signatures.get(&func_name)?;

        Some(SignatureHelp {
            signatures: signatures.clone(),
            active_signature: 0,
            active_parameter: active_param as u32,
        })
    }

    fn find_function_context(&self, text: &str) -> Option<(String, usize)> {
        let chars: Vec<char> = text.chars().collect();
        let mut depth = 0;
        let mut comma_count = 0;
        let mut paren_pos = None;

        // Walk backwards to find the opening paren
        for i in (0..chars.len()).rev() {
            match chars[i] {
                ')' | ']' | '}' => depth += 1,
                '(' => {
                    if depth == 0 {
                        paren_pos = Some(i);
                        break;
                    }
                    depth -= 1;
                }
                '[' | '{' => {
                    if depth > 0 {
                        depth -= 1;
                    }
                }
                ',' if depth == 0 => comma_count += 1,
                _ => {}
            }
        }

        let paren_pos = paren_pos?;

        // Find function name before the paren
        let mut end = paren_pos;
        while end > 0 && chars[end - 1].is_whitespace() {
            end -= 1;
        }

        let mut start = end;
        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        if start < end {
            let func_name: String = chars[start..end].iter().collect();
            Some((func_name, comma_count))
        } else {
            None
        }
    }

    pub fn add_signature(&mut self, name: String, sig: SignatureInformation) {
        self.signatures.entry(name).or_insert_with(Vec::new).push(sig);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CALL HIERARCHY
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone, Debug)]
pub struct CallHierarchyItem {
    pub name: String,
    pub kind: SymbolKind,
    pub uri: String,
    pub range: Range,
    pub selection_range: Range,
    pub detail: Option<String>,
}

#[derive(Clone, Debug)]
pub struct CallHierarchyIncomingCall {
    pub from: CallHierarchyItem,
    pub from_ranges: Vec<Range>,
}

#[derive(Clone, Debug)]
pub struct CallHierarchyOutgoingCall {
    pub to: CallHierarchyItem,
    pub from_ranges: Vec<Range>,
}

pub struct CallHierarchyProvider {
    /// Function call graph
    call_graph: HashMap<String, Vec<String>>,
    /// Reverse call graph (callers)
    reverse_graph: HashMap<String, Vec<String>>,
    /// Function locations
    function_locations: HashMap<String, CallHierarchyItem>,
}

impl CallHierarchyProvider {
    pub fn new() -> Self {
        CallHierarchyProvider {
            call_graph: HashMap::new(),
            reverse_graph: HashMap::new(),
            function_locations: HashMap::new(),
        }
    }

    pub fn prepare(&self, doc: &Document, pos: Position) -> Option<CallHierarchyItem> {
        let line = doc.lines.get(pos.line as usize)?;
        let word = self.get_word_at(line, pos.character as usize)?;

        // Check if it's a function
        self.function_locations.get(&word).cloned()
    }

    pub fn incoming_calls(&self, item: &CallHierarchyItem) -> Vec<CallHierarchyIncomingCall> {
        let callers = self.reverse_graph.get(&item.name);

        callers.map(|names| {
            names.iter()
                .filter_map(|name| {
                    self.function_locations.get(name).map(|loc| {
                        CallHierarchyIncomingCall {
                            from: loc.clone(),
                            from_ranges: Vec::new(), // Would need actual call sites
                        }
                    })
                })
                .collect()
        }).unwrap_or_default()
    }

    pub fn outgoing_calls(&self, item: &CallHierarchyItem) -> Vec<CallHierarchyOutgoingCall> {
        let callees = self.call_graph.get(&item.name);

        callees.map(|names| {
            names.iter()
                .filter_map(|name| {
                    self.function_locations.get(name).map(|loc| {
                        CallHierarchyOutgoingCall {
                            to: loc.clone(),
                            from_ranges: Vec::new(),
                        }
                    })
                })
                .collect()
        }).unwrap_or_default()
    }

    pub fn analyze_file(&mut self, uri: &str, doc: &Document) {
        let mut current_function: Option<String> = None;
        let mut function_start: Option<u32> = None;

        for (line_num, line) in doc.lines.iter().enumerate() {
            let trimmed = line.trim();

            // Detect function definitions
            if trimmed.starts_with("fn ") || trimmed.starts_with("pub fn ") ||
               trimmed.starts_with("async fn ") || trimmed.starts_with("pub async fn ") {
                if let Some(name) = self.extract_function_name(trimmed) {
                    // Store previous function
                    if let Some(prev_name) = current_function.take() {
                        if let Some(start) = function_start {
                            self.function_locations.insert(prev_name.clone(), CallHierarchyItem {
                                name: prev_name,
                                kind: SymbolKind::Function,
                                uri: uri.to_string(),
                                range: Range {
                                    start: Position { line: start, character: 0 },
                                    end: Position { line: line_num as u32, character: 0 },
                                },
                                selection_range: Range {
                                    start: Position { line: start, character: 0 },
                                    end: Position { line: start, character: 10 },
                                },
                                detail: None,
                            });
                        }
                    }

                    current_function = Some(name.clone());
                    function_start = Some(line_num as u32);
                    self.call_graph.entry(name).or_insert_with(Vec::new);
                }
            }

            // Detect function calls within current function
            if let Some(ref func_name) = current_function {
                let calls = self.find_function_calls(line);
                for call in calls {
                    if call != *func_name { // Avoid self-references
                        self.call_graph.get_mut(func_name).unwrap().push(call.clone());
                        self.reverse_graph.entry(call).or_insert_with(Vec::new).push(func_name.clone());
                    }
                }
            }
        }

        // Store last function
        if let Some(name) = current_function {
            if let Some(start) = function_start {
                self.function_locations.insert(name.clone(), CallHierarchyItem {
                    name,
                    kind: SymbolKind::Function,
                    uri: uri.to_string(),
                    range: Range {
                        start: Position { line: start, character: 0 },
                        end: Position { line: doc.lines.len() as u32, character: 0 },
                    },
                    selection_range: Range {
                        start: Position { line: start, character: 0 },
                        end: Position { line: start, character: 10 },
                    },
                    detail: None,
                });
            }
        }
    }

    fn extract_function_name(&self, line: &str) -> Option<String> {
        let line = line.trim_start_matches("pub ")
            .trim_start_matches("async ")
            .trim_start_matches("fn ");

        let end = line.find('(')?;
        Some(line[..end].trim().to_string())
    }

    fn find_function_calls(&self, line: &str) -> Vec<String> {
        let mut calls = Vec::new();
        let chars: Vec<char> = line.chars().collect();
        let mut pos = 0;

        while pos < chars.len() {
            if chars[pos].is_alphabetic() || chars[pos] == '_' {
                let start = pos;
                while pos < chars.len() && (chars[pos].is_alphanumeric() || chars[pos] == '_') {
                    pos += 1;
                }

                // Skip whitespace
                while pos < chars.len() && chars[pos].is_whitespace() {
                    pos += 1;
                }

                // Check for function call
                if pos < chars.len() && chars[pos] == '(' {
                    let name: String = chars[start..pos].iter().collect();
                    let name = name.trim().to_string();

                    // Filter out keywords
                    if !["if", "while", "for", "match", "fn", "let", "return"].contains(&name.as_str()) {
                        calls.push(name);
                    }
                }
            } else {
                pos += 1;
            }
        }

        calls
    }

    fn get_word_at(&self, line: &str, pos: usize) -> Option<String> {
        let chars: Vec<char> = line.chars().collect();
        if pos >= chars.len() {
            return None;
        }

        let mut start = pos;
        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        let mut end = pos;
        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            None
        } else {
            Some(chars[start..end].iter().collect())
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FOLDING RANGES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone, Debug)]
pub struct FoldingRange {
    pub start_line: u32,
    pub start_character: Option<u32>,
    pub end_line: u32,
    pub end_character: Option<u32>,
    pub kind: FoldingRangeKind,
    pub collapsed_text: Option<String>,
}

#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum FoldingRangeKind {
    Comment,
    Imports,
    Region,
}

pub struct FoldingRangeProvider;

impl FoldingRangeProvider {
    pub fn new() -> Self {
        FoldingRangeProvider
    }

    pub fn provide_folding_ranges(&self, doc: &Document) -> Vec<FoldingRange> {
        let mut ranges = Vec::new();

        // Track brace-based folding
        let mut brace_stack: Vec<(u32, char)> = Vec::new();

        // Track imports
        let mut import_start: Option<u32> = None;
        let mut last_import_line: Option<u32> = None;

        // Track comments
        let mut comment_start: Option<u32> = None;

        for (line_num, line) in doc.lines.iter().enumerate() {
            let line_num = line_num as u32;
            let trimmed = line.trim();

            // Track imports
            if trimmed.starts_with("use ") {
                if import_start.is_none() {
                    import_start = Some(line_num);
                }
                last_import_line = Some(line_num);
            } else if import_start.is_some() && !trimmed.is_empty() && !trimmed.starts_with("//") {
                // End of import block
                if let (Some(start), Some(end)) = (import_start, last_import_line) {
                    if end > start {
                        ranges.push(FoldingRange {
                            start_line: start,
                            start_character: None,
                            end_line: end,
                            end_character: None,
                            kind: FoldingRangeKind::Imports,
                            collapsed_text: Some("use ...".to_string()),
                        });
                    }
                }
                import_start = None;
                last_import_line = None;
            }

            // Track comments
            if trimmed.starts_with("//") || trimmed.starts_with("///") {
                if comment_start.is_none() {
                    comment_start = Some(line_num);
                }
            } else if comment_start.is_some() {
                if let Some(start) = comment_start {
                    if line_num > start + 1 {
                        ranges.push(FoldingRange {
                            start_line: start,
                            start_character: None,
                            end_line: line_num - 1,
                            end_character: None,
                            kind: FoldingRangeKind::Comment,
                            collapsed_text: Some("// ...".to_string()),
                        });
                    }
                }
                comment_start = None;
            }

            // Track braces
            for (i, c) in line.chars().enumerate() {
                match c {
                    '{' | '[' | '(' => {
                        brace_stack.push((line_num, c));
                    }
                    '}' | ']' | ')' => {
                        let expected = match c {
                            '}' => '{',
                            ']' => '[',
                            ')' => '(',
                            _ => unreachable!(),
                        };

                        if let Some((start_line, open_brace)) = brace_stack.pop() {
                            if open_brace == expected && line_num > start_line {
                                ranges.push(FoldingRange {
                                    start_line,
                                    start_character: Some(i as u32),
                                    end_line: line_num,
                                    end_character: Some(i as u32),
                                    kind: FoldingRangeKind::Region,
                                    collapsed_text: Some(format!("{}...{}", open_brace, c)),
                                });
                            }
                        }
                    }
                    _ => {}
                }
            }

            // Region markers
            if trimmed.starts_with("// region:") || trimmed.starts_with("//#region") {
                let label = trimmed.trim_start_matches("// region:")
                    .trim_start_matches("//#region")
                    .trim();
                brace_stack.push((line_num, 'R'));
            }

            if trimmed.starts_with("// endregion") || trimmed.starts_with("//#endregion") {
                if let Some((start_line, marker)) = brace_stack.pop() {
                    if marker == 'R' && line_num > start_line {
                        ranges.push(FoldingRange {
                            start_line,
                            start_character: None,
                            end_line: line_num,
                            end_character: None,
                            kind: FoldingRangeKind::Region,
                            collapsed_text: Some("region".to_string()),
                        });
                    }
                }
            }
        }

        // Handle unclosed comment at end of file
        if let Some(start) = comment_start {
            let end = doc.lines.len() as u32 - 1;
            if end > start {
                ranges.push(FoldingRange {
                    start_line: start,
                    start_character: None,
                    end_line: end,
                    end_character: None,
                    kind: FoldingRangeKind::Comment,
                    collapsed_text: Some("// ...".to_string()),
                });
            }
        }

        ranges
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENT FORMATTING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct DocumentFormatter {
    indent_size: usize,
    use_tabs: bool,
    max_line_width: usize,
    insert_final_newline: bool,
    trim_trailing_whitespace: bool,
}

impl DocumentFormatter {
    pub fn new() -> Self {
        DocumentFormatter {
            indent_size: 4,
            use_tabs: false,
            max_line_width: 100,
            insert_final_newline: true,
            trim_trailing_whitespace: true,
        }
    }

    pub fn with_options(indent_size: usize, use_tabs: bool, max_width: usize) -> Self {
        DocumentFormatter {
            indent_size,
            use_tabs,
            max_line_width: max_width,
            insert_final_newline: true,
            trim_trailing_whitespace: true,
        }
    }

    pub fn format(&self, doc: &Document) -> Vec<TextEdit> {
        let mut edits = Vec::new();
        let formatted = self.format_text(&doc.text);

        if formatted != doc.text {
            edits.push(TextEdit {
                range: Range {
                    start: Position { line: 0, character: 0 },
                    end: Position {
                        line: doc.lines.len() as u32,
                        character: 0,
                    },
                },
                new_text: formatted,
            });
        }

        edits
    }

    pub fn format_range(&self, doc: &Document, range: Range) -> Vec<TextEdit> {
        let mut edits = Vec::new();

        let start_line = range.start.line as usize;
        let end_line = range.end.line as usize;

        for line_num in start_line..=end_line {
            if let Some(line) = doc.lines.get(line_num) {
                let formatted = self.format_line(line, 0);
                if formatted != *line {
                    edits.push(TextEdit {
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        new_text: formatted,
                    });
                }
            }
        }

        edits
    }

    fn format_text(&self, text: &str) -> String {
        let mut result = String::new();
        let mut indent_level: i32 = 0;
        let indent_str = self.get_indent();

        for line in text.lines() {
            let trimmed = line.trim();

            // Decrease indent for closing braces
            if trimmed.starts_with('}') || trimmed.starts_with(']') || trimmed.starts_with(')') {
                indent_level = (indent_level - 1).max(0);
            }

            // Format the line
            let formatted = if trimmed.is_empty() {
                String::new()
            } else {
                format!("{}{}", indent_str.repeat(indent_level as usize),
                    if self.trim_trailing_whitespace { trimmed.trim_end() } else { trimmed })
            };

            result.push_str(&formatted);
            result.push('\n');

            // Increase indent for opening braces
            let opens = trimmed.matches('{').count() + trimmed.matches('[').count();
            let closes = trimmed.matches('}').count() + trimmed.matches(']').count();

            indent_level += opens as i32 - closes as i32;
            indent_level = indent_level.max(0);

            // Special case: don't indent if brace on same line
            if trimmed.ends_with('{') && !trimmed.ends_with("{}") {
                // Keep current indent increase
            }
        }

        if self.insert_final_newline && !result.ends_with('\n') {
            result.push('\n');
        }

        result
    }

    fn format_line(&self, line: &str, indent_level: usize) -> String {
        let trimmed = line.trim();

        if trimmed.is_empty() {
            return String::new();
        }

        let indent_str = self.get_indent();
        format!("{}{}", indent_str.repeat(indent_level), trimmed)
    }

    fn get_indent(&self) -> String {
        if self.use_tabs {
            "\t".to_string()
        } else {
            " ".repeat(self.indent_size)
        }
    }

    /// Format a range of on-type triggered formatting
    pub fn format_on_type(&self, doc: &Document, pos: Position, trigger: char) -> Vec<TextEdit> {
        let mut edits = Vec::new();

        match trigger {
            '}' | ')' | ']' => {
                // Auto-indent closing brace
                if let Some(line) = doc.lines.get(pos.line as usize) {
                    let trimmed = line.trim();
                    if trimmed.len() == 1 && trimmed.chars().next() == Some(trigger) {
                        // Find matching opening brace to determine indent
                        if let Some(indent) = self.find_matching_indent(doc, pos.line, trigger) {
                            let new_line = format!("{}{}", " ".repeat(indent), trigger);
                            if new_line != *line {
                                edits.push(TextEdit {
                                    range: Range {
                                        start: Position { line: pos.line, character: 0 },
                                        end: Position { line: pos.line, character: line.len() as u32 },
                                    },
                                    new_text: new_line,
                                });
                            }
                        }
                    }
                }
            }
            ';' => {
                // Trim trailing spaces before semicolon
                if let Some(line) = doc.lines.get(pos.line as usize) {
                    let without_semi = &line[..line.len() - 1];
                    let trimmed = without_semi.trim_end();
                    if trimmed.len() < without_semi.len() {
                        edits.push(TextEdit {
                            range: Range {
                                start: Position { line: pos.line, character: 0 },
                                end: Position { line: pos.line, character: line.len() as u32 },
                            },
                            new_text: format!("{};", trimmed),
                        });
                    }
                }
            }
            '\n' => {
                // Auto-indent new line based on previous line
                if pos.line > 0 {
                    if let Some(prev_line) = doc.lines.get((pos.line - 1) as usize) {
                        let base_indent = prev_line.len() - prev_line.trim_start().len();
                        let additional = if prev_line.trim_end().ends_with('{') { self.indent_size } else { 0 };
                        let new_indent = base_indent + additional;

                        if let Some(curr_line) = doc.lines.get(pos.line as usize) {
                            let curr_indent = curr_line.len() - curr_line.trim_start().len();
                            if curr_indent != new_indent {
                                edits.push(TextEdit {
                                    range: Range {
                                        start: Position { line: pos.line, character: 0 },
                                        end: Position { line: pos.line, character: curr_indent as u32 },
                                    },
                                    new_text: " ".repeat(new_indent),
                                });
                            }
                        }
                    }
                }
            }
            _ => {}
        }

        edits
    }

    fn find_matching_indent(&self, doc: &Document, line: u32, closing: char) -> Option<usize> {
        let opening = match closing {
            '}' => '{',
            ')' => '(',
            ']' => '[',
            _ => return None,
        };

        let mut depth = 1;

        for i in (0..line as usize).rev() {
            if let Some(line_text) = doc.lines.get(i) {
                for c in line_text.chars().rev() {
                    if c == closing {
                        depth += 1;
                    } else if c == opening {
                        depth -= 1;
                        if depth == 0 {
                            return Some(line_text.len() - line_text.trim_start().len());
                        }
                    }
                }
            }
        }

        None
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// RENAME PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

pub struct RenameProvider;

impl RenameProvider {
    pub fn new() -> Self {
        RenameProvider
    }

    pub fn prepare_rename(&self, doc: &Document, pos: Position) -> Option<Range> {
        let line = doc.lines.get(pos.line as usize)?;
        let chars: Vec<char> = line.chars().collect();

        if pos.character as usize >= chars.len() {
            return None;
        }

        let mut start = pos.character as usize;
        let mut end = pos.character as usize;

        // Expand to word boundaries
        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            return None;
        }

        let word: String = chars[start..end].iter().collect();

        // Check if it's a valid identifier to rename
        if self.is_keyword(&word) {
            return None;
        }

        Some(Range {
            start: Position { line: pos.line, character: start as u32 },
            end: Position { line: pos.line, character: end as u32 },
        })
    }

    pub fn rename(&self, doc: &Document, pos: Position, new_name: &str) -> Option<WorkspaceEdit> {
        let range = self.prepare_rename(doc, pos)?;
        let line = doc.lines.get(pos.line as usize)?;
        let old_name: String = line[range.start.character as usize..range.end.character as usize].to_string();

        // Find all occurrences
        let mut edits = Vec::new();

        for (line_num, line) in doc.lines.iter().enumerate() {
            let mut offset = 0;
            while let Some(idx) = line[offset..].find(&old_name) {
                let abs_idx = offset + idx;

                // Check word boundaries
                let before_ok = abs_idx == 0 ||
                    !line.chars().nth(abs_idx - 1).map(|c| c.is_alphanumeric() || c == '_').unwrap_or(false);
                let after_ok = abs_idx + old_name.len() >= line.len() ||
                    !line.chars().nth(abs_idx + old_name.len()).map(|c| c.is_alphanumeric() || c == '_').unwrap_or(false);

                if before_ok && after_ok {
                    edits.push(TextEdit {
                        range: Range {
                            start: Position { line: line_num as u32, character: abs_idx as u32 },
                            end: Position { line: line_num as u32, character: (abs_idx + old_name.len()) as u32 },
                        },
                        new_text: new_name.to_string(),
                    });
                }

                offset = abs_idx + 1;
            }
        }

        if edits.is_empty() {
            return None;
        }

        let mut changes = HashMap::new();
        changes.insert(doc.uri.clone(), edits);

        Some(WorkspaceEdit { changes })
    }

    fn is_keyword(&self, word: &str) -> bool {
        let keywords = ["let", "mut", "fn", "pub", "struct", "enum", "impl", "trait",
            "if", "else", "match", "for", "while", "loop", "break", "continue",
            "return", "use", "mod", "type", "where", "async", "await",
            "true", "false", "self", "Self", "super", "crate", "const", "static"];
        keywords.contains(&word)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SELECTION RANGE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SelectionRangeProvider;

impl SelectionRangeProvider {
    pub fn new() -> Self {
        SelectionRangeProvider
    }

    pub fn provide_selection_ranges(&self, doc: &Document, positions: &[Position]) -> Vec<Option<SelectionRange>> {
        positions.iter().map(|pos| self.selection_range_at(doc, *pos)).collect()
    }

    fn selection_range_at(&self, doc: &Document, pos: Position) -> Option<SelectionRange> {
        let mut ranges = Vec::new();

        // Word level
        if let Some(word_range) = self.word_range_at(doc, pos) {
            ranges.push(word_range);
        }

        // Expression level (simple heuristic: to end of statement)
        if let Some(expr_range) = self.expression_range_at(doc, pos) {
            ranges.push(expr_range);
        }

        // Statement level
        if let Some(stmt_range) = self.statement_range_at(doc, pos) {
            ranges.push(stmt_range);
        }

        // Block level
        if let Some(block_range) = self.block_range_at(doc, pos) {
            ranges.push(block_range);
        }

        // Function level
        if let Some(func_range) = self.function_range_at(doc, pos) {
            ranges.push(func_range);
        }

        // Build hierarchy
        if ranges.is_empty() {
            return None;
        }

        let mut current: Option<Box<SelectionRange>> = None;

        for range in ranges.into_iter().rev() {
            current = Some(Box::new(SelectionRange {
                range,
                parent: current,
            }));
        }

        current.map(|b| *b)
    }

    fn word_range_at(&self, doc: &Document, pos: Position) -> Option<Range> {
        let line = doc.lines.get(pos.line as usize)?;
        let chars: Vec<char> = line.chars().collect();

        if pos.character as usize >= chars.len() {
            return None;
        }

        let mut start = pos.character as usize;
        let mut end = pos.character as usize;

        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            None
        } else {
            Some(Range {
                start: Position { line: pos.line, character: start as u32 },
                end: Position { line: pos.line, character: end as u32 },
            })
        }
    }

    fn expression_range_at(&self, doc: &Document, pos: Position) -> Option<Range> {
        let line = doc.lines.get(pos.line as usize)?;

        // Simple: from current position to next delimiter
        let start = pos.character as usize;
        let rest = &line[start..];

        let end = rest.find(|c| c == ';' || c == ',' || c == ')' || c == '}')
            .map(|i| start + i)
            .unwrap_or(line.len());

        Some(Range {
            start: Position { line: pos.line, character: start as u32 },
            end: Position { line: pos.line, character: end as u32 },
        })
    }

    fn statement_range_at(&self, doc: &Document, pos: Position) -> Option<Range> {
        let line = doc.lines.get(pos.line as usize)?;
        let trimmed = line.trim();
        let indent = line.len() - line.trim_start().len();

        Some(Range {
            start: Position { line: pos.line, character: indent as u32 },
            end: Position { line: pos.line, character: line.len() as u32 },
        })
    }

    fn block_range_at(&self, doc: &Document, pos: Position) -> Option<Range> {
        // Find enclosing braces
        let mut open_line = None;
        let mut depth = 0;

        for i in (0..=pos.line as usize).rev() {
            if let Some(line) = doc.lines.get(i) {
                for c in line.chars().rev() {
                    if c == '}' { depth += 1; }
                    if c == '{' {
                        if depth == 0 {
                            open_line = Some(i);
                            break;
                        }
                        depth -= 1;
                    }
                }
                if open_line.is_some() { break; }
            }
        }

        let start_line = open_line?;

        // Find closing brace
        depth = 1;
        for i in start_line..doc.lines.len() {
            if let Some(line) = doc.lines.get(i) {
                for c in line.chars() {
                    if i > start_line || c != '{' {
                        if c == '{' { depth += 1; }
                        if c == '}' {
                            depth -= 1;
                            if depth == 0 {
                                return Some(Range {
                                    start: Position { line: start_line as u32, character: 0 },
                                    end: Position { line: i as u32, character: line.len() as u32 },
                                });
                            }
                        }
                    }
                }
            }
        }

        None
    }

    fn function_range_at(&self, doc: &Document, pos: Position) -> Option<Range> {
        // Find function start
        let mut func_start = None;

        for i in (0..=pos.line as usize).rev() {
            if let Some(line) = doc.lines.get(i) {
                let trimmed = line.trim();
                if trimmed.starts_with("fn ") || trimmed.starts_with("pub fn ") ||
                   trimmed.starts_with("async fn ") || trimmed.starts_with("pub async fn ") {
                    func_start = Some(i);
                    break;
                }
            }
        }

        let start = func_start?;

        // Find function end
        let mut depth = 0;
        let mut found_open = false;

        for i in start..doc.lines.len() {
            if let Some(line) = doc.lines.get(i) {
                for c in line.chars() {
                    if c == '{' {
                        depth += 1;
                        found_open = true;
                    }
                    if c == '}' {
                        depth -= 1;
                        if found_open && depth == 0 {
                            return Some(Range {
                                start: Position { line: start as u32, character: 0 },
                                end: Position { line: i as u32, character: line.len() as u32 },
                            });
                        }
                    }
                }
            }
        }

        None
    }
}

#[derive(Clone, Debug)]
pub struct SelectionRange {
    pub range: Range,
    pub parent: Option<Box<SelectionRange>>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CODE LENS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone, Debug)]
pub struct CodeLens {
    pub range: Range,
    pub command: Option<Command>,
    pub data: Option<JsonValue>,
}

pub struct CodeLensProvider {
    show_run: bool,
    show_debug: bool,
    show_references: bool,
    show_implementations: bool,
}

impl CodeLensProvider {
    pub fn new() -> Self {
        CodeLensProvider {
            show_run: true,
            show_debug: true,
            show_references: true,
            show_implementations: true,
        }
    }

    pub fn provide_lenses(&self, doc: &Document) -> Vec<CodeLens> {
        let mut lenses = Vec::new();

        for (line_num, line) in doc.lines.iter().enumerate() {
            let trimmed = line.trim();

            // Main function
            if trimmed.starts_with("fn main(") || trimmed.starts_with("pub fn main(") {
                if self.show_run {
                    lenses.push(CodeLens {
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        command: Some(Command {
                            title: "▶ Run".to_string(),
                            command: "quanta.run".to_string(),
                            arguments: Vec::new(),
                        }),
                        data: None,
                    });
                }
                if self.show_debug {
                    lenses.push(CodeLens {
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        command: Some(Command {
                            title: "🔧 Debug".to_string(),
                            command: "quanta.debug".to_string(),
                            arguments: Vec::new(),
                        }),
                        data: None,
                    });
                }
            }

            // Test functions
            if trimmed.contains("#[test]") {
                if let Some(next_line) = doc.lines.get(line_num + 1) {
                    if self.show_run {
                        lenses.push(CodeLens {
                            range: Range {
                                start: Position { line: (line_num + 1) as u32, character: 0 },
                                end: Position { line: (line_num + 1) as u32, character: next_line.len() as u32 },
                            },
                            command: Some(Command {
                                title: "▶ Run Test".to_string(),
                                command: "quanta.runTest".to_string(),
                                arguments: vec![format!("{}", line_num + 1)],
                            }),
                            data: None,
                        });
                    }
                }
            }

            // Struct/Trait definitions - show implementations
            if self.show_implementations {
                if (trimmed.starts_with("struct ") || trimmed.starts_with("pub struct ")) &&
                   !trimmed.contains(';') {
                    lenses.push(CodeLens {
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        command: Some(Command {
                            title: "impl".to_string(),
                            command: "quanta.showImplementations".to_string(),
                            arguments: vec![format!("{}", line_num)],
                        }),
                        data: None,
                    });
                }

                if trimmed.starts_with("trait ") || trimmed.starts_with("pub trait ") {
                    lenses.push(CodeLens {
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        command: Some(Command {
                            title: "implementors".to_string(),
                            command: "quanta.showImplementors".to_string(),
                            arguments: vec![format!("{}", line_num)],
                        }),
                        data: None,
                    });
                }
            }

            // Function definitions - show references
            if self.show_references {
                if (trimmed.starts_with("fn ") || trimmed.starts_with("pub fn ") ||
                    trimmed.starts_with("async fn ") || trimmed.starts_with("pub async fn ")) &&
                   !trimmed.contains("main(") {
                    lenses.push(CodeLens {
                        range: Range {
                            start: Position { line: line_num as u32, character: 0 },
                            end: Position { line: line_num as u32, character: line.len() as u32 },
                        },
                        command: Some(Command {
                            title: "references".to_string(),
                            command: "quanta.findReferences".to_string(),
                            arguments: vec![format!("{}", line_num)],
                        }),
                        data: None,
                    });
                }
            }
        }

        lenses
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINKED EDITING RANGES
// ═══════════════════════════════════════════════════════════════════════════════

pub struct LinkedEditingRangeProvider;

impl LinkedEditingRangeProvider {
    pub fn new() -> Self {
        LinkedEditingRangeProvider
    }

    pub fn provide_ranges(&self, doc: &Document, pos: Position) -> Option<Vec<Range>> {
        let line = doc.lines.get(pos.line as usize)?;
        let chars: Vec<char> = line.chars().collect();

        if pos.character as usize >= chars.len() {
            return None;
        }

        // Get the word at position
        let mut start = pos.character as usize;
        let mut end = pos.character as usize;

        while start > 0 && (chars[start - 1].is_alphanumeric() || chars[start - 1] == '_') {
            start -= 1;
        }

        while end < chars.len() && (chars[end].is_alphanumeric() || chars[end] == '_') {
            end += 1;
        }

        if start == end {
            return None;
        }

        let word: String = chars[start..end].iter().collect();

        // Find all occurrences in the document
        let mut ranges = Vec::new();

        for (line_num, line_text) in doc.lines.iter().enumerate() {
            let mut offset = 0;
            while let Some(idx) = line_text[offset..].find(&word) {
                let abs_idx = offset + idx;

                // Check word boundaries
                let before_ok = abs_idx == 0 ||
                    !line_text.chars().nth(abs_idx - 1).map(|c| c.is_alphanumeric() || c == '_').unwrap_or(false);
                let after_ok = abs_idx + word.len() >= line_text.len() ||
                    !line_text.chars().nth(abs_idx + word.len()).map(|c| c.is_alphanumeric() || c == '_').unwrap_or(false);

                if before_ok && after_ok {
                    ranges.push(Range {
                        start: Position { line: line_num as u32, character: abs_idx as u32 },
                        end: Position { line: line_num as u32, character: (abs_idx + word.len()) as u32 },
                    });
                }

                offset = abs_idx + 1;
            }
        }

        if ranges.len() > 1 {
            Some(ranges)
        } else {
            None
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENHANCED LANGUAGE SERVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Enhanced Language Server with all features
pub struct EnhancedLanguageServer {
    documents: Arc<DocumentManager>,
    analyzer: Analyzer,
    project_index: Arc<RwLock<ProjectIndex>>,
    type_inference: Mutex<TypeInference>,
    scope_manager: Mutex<ScopeManager>,
    inlay_hint_provider: InlayHintProvider,
    code_action_provider: CodeActionProvider,
    signature_help_provider: SignatureHelpProvider,
    call_hierarchy_provider: Mutex<CallHierarchyProvider>,
    folding_range_provider: FoldingRangeProvider,
    formatter: DocumentFormatter,
    rename_provider: RenameProvider,
    selection_range_provider: SelectionRangeProvider,
    code_lens_provider: CodeLensProvider,
    linked_editing_provider: LinkedEditingRangeProvider,
    initialized: bool,
    shutdown_requested: bool,
    workspace_folders: Vec<String>,
    configuration: ServerConfiguration,
}

#[derive(Clone, Debug)]
pub struct ServerConfiguration {
    pub inlay_hints_enabled: bool,
    pub semantic_tokens_enabled: bool,
    pub format_on_save: bool,
    pub format_on_type: bool,
    pub code_lens_enabled: bool,
}

impl Default for ServerConfiguration {
    fn default() -> Self {
        ServerConfiguration {
            inlay_hints_enabled: true,
            semantic_tokens_enabled: true,
            format_on_save: true,
            format_on_type: true,
            code_lens_enabled: true,
        }
    }
}

impl EnhancedLanguageServer {
    pub fn new() -> Self {
        EnhancedLanguageServer {
            documents: Arc::new(DocumentManager::new()),
            analyzer: Analyzer::new(),
            project_index: Arc::new(RwLock::new(ProjectIndex::new())),
            type_inference: Mutex::new(TypeInference::new()),
            scope_manager: Mutex::new(ScopeManager::new()),
            inlay_hint_provider: InlayHintProvider::new(),
            code_action_provider: CodeActionProvider::new(),
            signature_help_provider: SignatureHelpProvider::new(),
            call_hierarchy_provider: Mutex::new(CallHierarchyProvider::new()),
            folding_range_provider: FoldingRangeProvider::new(),
            formatter: DocumentFormatter::new(),
            rename_provider: RenameProvider::new(),
            selection_range_provider: SelectionRangeProvider::new(),
            code_lens_provider: CodeLensProvider::new(),
            linked_editing_provider: LinkedEditingRangeProvider::new(),
            initialized: false,
            shutdown_requested: false,
            workspace_folders: Vec::new(),
            configuration: ServerConfiguration::default(),
        }
    }

    pub fn run_stdio(&mut self) {
        println!("Quanta LSP Server v3.0.0 starting...");

        loop {
            // Read header
            let mut header = String::new();
            if read_line(&mut header).is_err() {
                break;
            }

            if header.is_empty() || self.shutdown_requested {
                break;
            }

            // Parse content length
            let content_length = self.parse_content_length(&header);
            if content_length == 0 {
                continue;
            }

            // Read content
            let mut content = vec![0u8; content_length];
            if stdin().read_exact(&mut content).is_err() {
                continue;
            }

            // Parse and handle request
            let request_str = String::from_utf8_lossy(&content);
            if let Ok(json) = JsonParser::parse(&request_str) {
                if let Some(response) = self.handle_message(&json) {
                    self.send_response(&response);
                }
            }
        }
    }

    fn parse_content_length(&self, header: &str) -> usize {
        header.lines()
            .find(|line| line.starts_with("Content-Length:"))
            .and_then(|line| line.split(':').nth(1))
            .and_then(|s| s.trim().parse().ok())
            .unwrap_or(0)
    }

    fn handle_message(&mut self, msg: &JsonValue) -> Option<String> {
        let method = msg.get("method")?.as_str()?;
        let id = msg.get("id").and_then(|v| v.as_i64());
        let params = msg.get("params");

        match method {
            "initialize" => Some(self.handle_initialize(id, params)),
            "initialized" => {
                self.initialized = true;
                None
            }
            "shutdown" => {
                self.shutdown_requested = true;
                Some(self.make_result_response(id, JsonValue::Null))
            }

            // Document synchronization
            "textDocument/didOpen" => {
                self.handle_did_open(params);
                None
            }
            "textDocument/didClose" => {
                self.handle_did_close(params);
                None
            }
            "textDocument/didChange" => {
                self.handle_did_change(params);
                None
            }
            "textDocument/didSave" => {
                self.handle_did_save(params);
                None
            }

            // Language features
            "textDocument/completion" => Some(self.handle_completion(id, params)),
            "textDocument/hover" => Some(self.handle_hover(id, params)),
            "textDocument/signatureHelp" => Some(self.handle_signature_help(id, params)),
            "textDocument/declaration" => Some(self.handle_goto_declaration(id, params)),
            "textDocument/definition" => Some(self.handle_goto_definition(id, params)),
            "textDocument/typeDefinition" => Some(self.handle_goto_type_definition(id, params)),
            "textDocument/implementation" => Some(self.handle_goto_implementation(id, params)),
            "textDocument/references" => Some(self.handle_references(id, params)),
            "textDocument/documentHighlight" => Some(self.handle_document_highlight(id, params)),
            "textDocument/documentSymbol" => Some(self.handle_document_symbol(id, params)),
            "textDocument/codeAction" => Some(self.handle_code_action(id, params)),
            "textDocument/codeLens" => Some(self.handle_code_lens(id, params)),
            "textDocument/formatting" => Some(self.handle_formatting(id, params)),
            "textDocument/rangeFormatting" => Some(self.handle_range_formatting(id, params)),
            "textDocument/onTypeFormatting" => Some(self.handle_on_type_formatting(id, params)),
            "textDocument/rename" => Some(self.handle_rename(id, params)),
            "textDocument/prepareRename" => Some(self.handle_prepare_rename(id, params)),
            "textDocument/foldingRange" => Some(self.handle_folding_range(id, params)),
            "textDocument/selectionRange" => Some(self.handle_selection_range(id, params)),
            "textDocument/semanticTokens/full" => Some(self.handle_semantic_tokens(id, params)),
            "textDocument/inlayHint" => Some(self.handle_inlay_hint(id, params)),
            "textDocument/linkedEditingRange" => Some(self.handle_linked_editing_range(id, params)),

            // Call hierarchy
            "textDocument/prepareCallHierarchy" => Some(self.handle_prepare_call_hierarchy(id, params)),
            "callHierarchy/incomingCalls" => Some(self.handle_incoming_calls(id, params)),
            "callHierarchy/outgoingCalls" => Some(self.handle_outgoing_calls(id, params)),

            // Workspace features
            "workspace/symbol" => Some(self.handle_workspace_symbol(id, params)),
            "workspace/didChangeConfiguration" => {
                self.handle_configuration_change(params);
                None
            }
            "workspace/didChangeWatchedFiles" => {
                self.handle_watched_files_change(params);
                None
            }

            _ => None,
        }
    }

    fn handle_initialize(&mut self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        // Parse workspace folders
        if let Some(params) = params {
            if let Some(folders) = params.get("workspaceFolders").and_then(|f| f.as_array()) {
                for folder in folders {
                    if let Some(uri) = folder.get("uri").and_then(|u| u.as_str()) {
                        self.workspace_folders.push(uri.to_string());
                    }
                }
            }
        }

        let capabilities = JsonValue::Object({
            let mut cap = HashMap::new();

            // Text document sync
            cap.insert("textDocumentSync".to_string(), JsonValue::Object({
                let mut sync = HashMap::new();
                sync.insert("openClose".to_string(), JsonValue::Bool(true));
                sync.insert("change".to_string(), JsonValue::Number(2.0)); // Incremental
                sync.insert("save".to_string(), JsonValue::Object({
                    let mut save = HashMap::new();
                    save.insert("includeText".to_string(), JsonValue::Bool(true));
                    save
                }));
                sync
            }));

            // Completion
            cap.insert("completionProvider".to_string(), JsonValue::Object({
                let mut comp = HashMap::new();
                comp.insert("triggerCharacters".to_string(), JsonValue::Array(vec![
                    JsonValue::String(".".to_string()),
                    JsonValue::String(":".to_string()),
                    JsonValue::String("<".to_string()),
                ]));
                comp.insert("resolveProvider".to_string(), JsonValue::Bool(true));
                comp
            }));

            // Hover
            cap.insert("hoverProvider".to_string(), JsonValue::Bool(true));

            // Signature help
            cap.insert("signatureHelpProvider".to_string(), JsonValue::Object({
                let mut sig = HashMap::new();
                sig.insert("triggerCharacters".to_string(), JsonValue::Array(vec![
                    JsonValue::String("(".to_string()),
                    JsonValue::String(",".to_string()),
                ]));
                sig
            }));

            // Navigation
            cap.insert("declarationProvider".to_string(), JsonValue::Bool(true));
            cap.insert("definitionProvider".to_string(), JsonValue::Bool(true));
            cap.insert("typeDefinitionProvider".to_string(), JsonValue::Bool(true));
            cap.insert("implementationProvider".to_string(), JsonValue::Bool(true));
            cap.insert("referencesProvider".to_string(), JsonValue::Bool(true));
            cap.insert("documentHighlightProvider".to_string(), JsonValue::Bool(true));
            cap.insert("documentSymbolProvider".to_string(), JsonValue::Bool(true));
            cap.insert("workspaceSymbolProvider".to_string(), JsonValue::Bool(true));

            // Code actions
            cap.insert("codeActionProvider".to_string(), JsonValue::Object({
                let mut ca = HashMap::new();
                ca.insert("codeActionKinds".to_string(), JsonValue::Array(vec![
                    JsonValue::String("quickfix".to_string()),
                    JsonValue::String("refactor".to_string()),
                    JsonValue::String("refactor.extract".to_string()),
                    JsonValue::String("refactor.inline".to_string()),
                    JsonValue::String("refactor.rewrite".to_string()),
                    JsonValue::String("source".to_string()),
                    JsonValue::String("source.organizeImports".to_string()),
                    JsonValue::String("source.fixAll".to_string()),
                ]));
                ca
            }));

            // Code lens
            cap.insert("codeLensProvider".to_string(), JsonValue::Object({
                let mut cl = HashMap::new();
                cl.insert("resolveProvider".to_string(), JsonValue::Bool(true));
                cl
            }));

            // Formatting
            cap.insert("documentFormattingProvider".to_string(), JsonValue::Bool(true));
            cap.insert("documentRangeFormattingProvider".to_string(), JsonValue::Bool(true));
            cap.insert("documentOnTypeFormattingProvider".to_string(), JsonValue::Object({
                let mut otf = HashMap::new();
                otf.insert("firstTriggerCharacter".to_string(), JsonValue::String("}".to_string()));
                otf.insert("moreTriggerCharacter".to_string(), JsonValue::Array(vec![
                    JsonValue::String(";".to_string()),
                    JsonValue::String("\n".to_string()),
                ]));
                otf
            }));

            // Rename
            cap.insert("renameProvider".to_string(), JsonValue::Object({
                let mut rn = HashMap::new();
                rn.insert("prepareProvider".to_string(), JsonValue::Bool(true));
                rn
            }));

            // Folding
            cap.insert("foldingRangeProvider".to_string(), JsonValue::Bool(true));

            // Selection range
            cap.insert("selectionRangeProvider".to_string(), JsonValue::Bool(true));

            // Semantic tokens
            cap.insert("semanticTokensProvider".to_string(), JsonValue::Object({
                let mut st = HashMap::new();
                st.insert("full".to_string(), JsonValue::Bool(true));
                st.insert("legend".to_string(), JsonValue::Object({
                    let mut legend = HashMap::new();
                    legend.insert("tokenTypes".to_string(), JsonValue::Array(vec![
                        JsonValue::String("namespace".to_string()),
                        JsonValue::String("type".to_string()),
                        JsonValue::String("class".to_string()),
                        JsonValue::String("enum".to_string()),
                        JsonValue::String("interface".to_string()),
                        JsonValue::String("struct".to_string()),
                        JsonValue::String("typeParameter".to_string()),
                        JsonValue::String("parameter".to_string()),
                        JsonValue::String("variable".to_string()),
                        JsonValue::String("property".to_string()),
                        JsonValue::String("enumMember".to_string()),
                        JsonValue::String("event".to_string()),
                        JsonValue::String("function".to_string()),
                        JsonValue::String("method".to_string()),
                        JsonValue::String("macro".to_string()),
                        JsonValue::String("keyword".to_string()),
                        JsonValue::String("modifier".to_string()),
                        JsonValue::String("comment".to_string()),
                        JsonValue::String("string".to_string()),
                        JsonValue::String("number".to_string()),
                        JsonValue::String("regexp".to_string()),
                        JsonValue::String("operator".to_string()),
                        JsonValue::String("decorator".to_string()),
                        JsonValue::String("label".to_string()),
                        JsonValue::String("lifetime".to_string()),
                        JsonValue::String("selfKeyword".to_string()),
                        JsonValue::String("attribute".to_string()),
                    ]));
                    legend.insert("tokenModifiers".to_string(), JsonValue::Array(vec![
                        JsonValue::String("declaration".to_string()),
                        JsonValue::String("definition".to_string()),
                        JsonValue::String("readonly".to_string()),
                        JsonValue::String("static".to_string()),
                        JsonValue::String("deprecated".to_string()),
                        JsonValue::String("abstract".to_string()),
                        JsonValue::String("async".to_string()),
                        JsonValue::String("modification".to_string()),
                        JsonValue::String("documentation".to_string()),
                        JsonValue::String("defaultLibrary".to_string()),
                        JsonValue::String("mutable".to_string()),
                        JsonValue::String("public".to_string()),
                        JsonValue::String("unsafe".to_string()),
                    ]));
                    legend
                }));
                st
            }));

            // Inlay hints
            cap.insert("inlayHintProvider".to_string(), JsonValue::Bool(true));

            // Linked editing
            cap.insert("linkedEditingRangeProvider".to_string(), JsonValue::Bool(true));

            // Call hierarchy
            cap.insert("callHierarchyProvider".to_string(), JsonValue::Bool(true));

            cap
        });

        let result = JsonValue::Object({
            let mut result = HashMap::new();
            result.insert("capabilities".to_string(), capabilities);
            result.insert("serverInfo".to_string(), JsonValue::Object({
                let mut info = HashMap::new();
                info.insert("name".to_string(), JsonValue::String("Quanta LSP".to_string()));
                info.insert("version".to_string(), JsonValue::String("3.0.0".to_string()));
                info
            }));
            result
        });

        self.make_result_response(id, result)
    }

    fn handle_did_open(&mut self, params: Option<&JsonValue>) {
        if let Some(params) = params {
            if let Some(text_doc) = params.get("textDocument") {
                let uri = text_doc.get("uri").and_then(|u| u.as_str()).unwrap_or("");
                let language_id = text_doc.get("languageId").and_then(|l| l.as_str()).unwrap_or("quanta");
                let version = text_doc.get("version").and_then(|v| v.as_i64()).unwrap_or(0) as i32;
                let text = text_doc.get("text").and_then(|t| t.as_str()).unwrap_or("");

                let item = TextDocumentItem {
                    uri: uri.to_string(),
                    language_id: language_id.to_string(),
                    version,
                    text: text.to_string(),
                };

                self.documents.open(item);
                self.analyze_document(uri);
            }
        }
    }

    fn handle_did_close(&self, params: Option<&JsonValue>) {
        if let Some(params) = params {
            if let Some(text_doc) = params.get("textDocument") {
                if let Some(uri) = text_doc.get("uri").and_then(|u| u.as_str()) {
                    self.documents.close(uri);
                }
            }
        }
    }

    fn handle_did_change(&self, params: Option<&JsonValue>) {
        if let Some(params) = params {
            if let Some(text_doc) = params.get("textDocument") {
                let uri = text_doc.get("uri").and_then(|u| u.as_str()).unwrap_or("");
                let version = text_doc.get("version").and_then(|v| v.as_i64()).unwrap_or(0) as i32;

                if let Some(changes) = params.get("contentChanges").and_then(|c| c.as_array()) {
                    let change_events: Vec<TextDocumentContentChangeEvent> = changes.iter()
                        .filter_map(|c| {
                            let text = c.get("text").and_then(|t| t.as_str())?;
                            let range = c.get("range").and_then(|r| self.parse_range(r));
                            Some(TextDocumentContentChangeEvent {
                                range,
                                text: text.to_string(),
                            })
                        })
                        .collect();

                    self.documents.update(uri, version, change_events);
                }
            }
        }
    }

    fn handle_did_save(&mut self, params: Option<&JsonValue>) {
        if let Some(params) = params {
            if let Some(text_doc) = params.get("textDocument") {
                if let Some(uri) = text_doc.get("uri").and_then(|u| u.as_str()) {
                    self.analyze_document(uri);
                }
            }
        }
    }

    fn handle_completion(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let completions = self.analyzer.completions(&doc, pos);

        let items: Vec<JsonValue> = completions.iter().map(|item| {
            let mut obj = HashMap::new();
            obj.insert("label".to_string(), JsonValue::String(item.label.clone()));
            obj.insert("kind".to_string(), JsonValue::Number(item.kind as i32 as f64));
            if let Some(detail) = &item.detail {
                obj.insert("detail".to_string(), JsonValue::String(detail.clone()));
            }
            if let Some(doc) = &item.documentation {
                obj.insert("documentation".to_string(), JsonValue::String(doc.clone()));
            }
            if let Some(insert) = &item.insert_text {
                obj.insert("insertText".to_string(), JsonValue::String(insert.clone()));
                obj.insert("insertTextFormat".to_string(), JsonValue::Number(item.insert_text_format as i32 as f64));
            }
            JsonValue::Object(obj)
        }).collect();

        let result = JsonValue::Object({
            let mut r = HashMap::new();
            r.insert("isIncomplete".to_string(), JsonValue::Bool(false));
            r.insert("items".to_string(), JsonValue::Array(items));
            r
        });

        self.make_result_response(id, result)
    }

    fn handle_hover(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        match self.analyzer.hover(&doc, pos) {
            Some(hover) => {
                let result = JsonValue::Object({
                    let mut r = HashMap::new();
                    r.insert("contents".to_string(), JsonValue::Object({
                        let mut c = HashMap::new();
                        c.insert("kind".to_string(), JsonValue::String(
                            match hover.contents.kind {
                                MarkupKind::PlainText => "plaintext",
                                MarkupKind::Markdown => "markdown",
                            }.to_string()
                        ));
                        c.insert("value".to_string(), JsonValue::String(hover.contents.value));
                        c
                    }));
                    if let Some(range) = hover.range {
                        r.insert("range".to_string(), self.range_to_json(&range));
                    }
                    r
                });
                self.make_result_response(id, result)
            }
            None => self.make_result_response(id, JsonValue::Null),
        }
    }

    fn handle_signature_help(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        match self.signature_help_provider.provide_signature_help(&doc, pos) {
            Some(help) => {
                let signatures: Vec<JsonValue> = help.signatures.iter().map(|sig| {
                    let mut s = HashMap::new();
                    s.insert("label".to_string(), JsonValue::String(sig.label.clone()));
                    if let Some(doc) = &sig.documentation {
                        s.insert("documentation".to_string(), JsonValue::String(doc.clone()));
                    }
                    let params: Vec<JsonValue> = sig.parameters.iter().map(|p| {
                        let mut param = HashMap::new();
                        param.insert("label".to_string(), JsonValue::Array(vec![
                            JsonValue::Number(p.label.0 as f64),
                            JsonValue::Number(p.label.1 as f64),
                        ]));
                        if let Some(doc) = &p.documentation {
                            param.insert("documentation".to_string(), JsonValue::String(doc.clone()));
                        }
                        JsonValue::Object(param)
                    }).collect();
                    s.insert("parameters".to_string(), JsonValue::Array(params));
                    JsonValue::Object(s)
                }).collect();

                let result = JsonValue::Object({
                    let mut r = HashMap::new();
                    r.insert("signatures".to_string(), JsonValue::Array(signatures));
                    r.insert("activeSignature".to_string(), JsonValue::Number(help.active_signature as f64));
                    r.insert("activeParameter".to_string(), JsonValue::Number(help.active_parameter as f64));
                    r
                });

                self.make_result_response(id, result)
            }
            None => self.make_result_response(id, JsonValue::Null),
        }
    }

    fn handle_goto_declaration(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        self.handle_goto_definition(id, params) // Same as definition for now
    }

    fn handle_goto_definition(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        // Get word at position
        let line = match doc.lines.get(pos.line as usize) {
            Some(l) => l,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        let word = match self.get_word_at(line, pos.character as usize) {
            Some(w) => w,
            None => return self.make_result_response(id, JsonValue::Null),
        };

        // Look up in project index
        let index = self.project_index.read().unwrap();
        match index.find_definition(&word, &uri) {
            Some(symbol) => {
                let location = JsonValue::Object({
                    let mut l = HashMap::new();
                    l.insert("uri".to_string(), JsonValue::String(symbol.definition_uri.clone()));
                    l.insert("range".to_string(), self.range_to_json(&symbol.range));
                    l
                });
                self.make_result_response(id, location)
            }
            None => self.make_result_response(id, JsonValue::Null),
        }
    }

    fn handle_goto_type_definition(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        self.handle_goto_definition(id, params) // Simplified
    }

    fn handle_goto_implementation(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        self.handle_goto_definition(id, params) // Simplified
    }

    fn handle_references(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let line = match doc.lines.get(pos.line as usize) {
            Some(l) => l,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let word = match self.get_word_at(line, pos.character as usize) {
            Some(w) => w,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        // Find all occurrences in document
        let mut locations = Vec::new();
        for (line_num, line_text) in doc.lines.iter().enumerate() {
            let mut offset = 0;
            while let Some(idx) = line_text[offset..].find(&word) {
                let abs_idx = offset + idx;

                let before_ok = abs_idx == 0 ||
                    !line_text.chars().nth(abs_idx - 1).map(|c| c.is_alphanumeric() || c == '_').unwrap_or(false);
                let after_ok = abs_idx + word.len() >= line_text.len() ||
                    !line_text.chars().nth(abs_idx + word.len()).map(|c| c.is_alphanumeric() || c == '_').unwrap_or(false);

                if before_ok && after_ok {
                    locations.push(JsonValue::Object({
                        let mut l = HashMap::new();
                        l.insert("uri".to_string(), JsonValue::String(uri.clone()));
                        l.insert("range".to_string(), self.range_to_json(&Range {
                            start: Position { line: line_num as u32, character: abs_idx as u32 },
                            end: Position { line: line_num as u32, character: (abs_idx + word.len()) as u32 },
                        }));
                        l
                    }));
                }

                offset = abs_idx + 1;
            }
        }

        self.make_result_response(id, JsonValue::Array(locations))
    }

    fn handle_document_highlight(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let (uri, pos) = match self.extract_text_document_position(params) {
            Some(v) => v,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(&uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        match self.linked_editing_provider.provide_ranges(&doc, pos) {
            Some(ranges) => {
                let highlights: Vec<JsonValue> = ranges.iter().map(|range| {
                    let mut h = HashMap::new();
                    h.insert("range".to_string(), self.range_to_json(range));
                    h.insert("kind".to_string(), JsonValue::Number(1.0)); // Text
                    JsonValue::Object(h)
                }).collect();
                self.make_result_response(id, JsonValue::Array(highlights))
            }
            None => self.make_result_response(id, JsonValue::Array(Vec::new())),
        }
    }

    fn handle_document_symbol(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let symbols = self.analyzer.analyze_symbols(&doc);

        let json_symbols: Vec<JsonValue> = symbols.iter().map(|s| self.document_symbol_to_json(s)).collect();

        self.make_result_response(id, JsonValue::Array(json_symbols))
    }

    fn handle_code_action(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let range = match params.and_then(|p| p.get("range")).and_then(|r| self.parse_range(r)) {
            Some(r) => r,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let actions = self.code_action_provider.provide_actions(&doc, range, &doc.diagnostics);

        let json_actions: Vec<JsonValue> = actions.iter().map(|action| {
            let mut a = HashMap::new();
            a.insert("title".to_string(), JsonValue::String(action.title.clone()));
            a.insert("kind".to_string(), JsonValue::String(self.code_action_kind_to_string(&action.kind)));

            if let Some(edit) = &action.edit {
                a.insert("edit".to_string(), self.workspace_edit_to_json(edit));
            }

            if let Some(cmd) = &action.command {
                a.insert("command".to_string(), self.command_to_json(cmd));
            }

            JsonValue::Object(a)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_actions))
    }

    fn handle_code_lens(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        if !self.configuration.code_lens_enabled {
            return self.make_result_response(id, JsonValue::Array(Vec::new()));
        }

        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let lenses = self.code_lens_provider.provide_lenses(&doc);

        let json_lenses: Vec<JsonValue> = lenses.iter().map(|lens| {
            let mut l = HashMap::new();
            l.insert("range".to_string(), self.range_to_json(&lens.range));
            if let Some(cmd) = &lens.command {
                l.insert("command".to_string(), self.command_to_json(cmd));
            }
            JsonValue::Object(l)
        }).collect();

        self.make_result_response(id, JsonValue::Array(json_lenses))
    }

    fn handle_formatting(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let edits = self.formatter.format(&doc);
        let json_edits: Vec<JsonValue> = edits.iter().map(|e| self.text_edit_to_json(e)).collect();

        self.make_result_response(id, JsonValue::Array(json_edits))
    }

    fn handle_range_formatting(&self, id: Option<i64>, params: Option<&JsonValue>) -> String {
        let uri = match params.and_then(|p| p.get("textDocument")).and_then(|t| t.get("uri")).and_then(|u| u.as_str()) {
            Some(u) => u,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let range = match params.and_then(|p| p.get("range")).and_then(|r| self.parse_range(r)) {
            Some(r) => r,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.make_result_response(id, JsonValue::Array(Vec::new())),
        };

        let edits = self.formatter.format_range(&doc, range);
        let json_edits: Vec<JsonValue> = edits.iter().map(|e| self.text_edit_to_json(e)).collect();

        self.make_result_response(id, JsonValue::Array(json_edits))
