/// Project configuration
#[derive(Clone, Debug)]
pub struct ProjectConfig {
    pub name: String,
    pub version: String,
    pub edition: String,
    pub dependencies: HashMap<String, DependencyConfig>,
    pub dev_dependencies: HashMap<String, DependencyConfig>,
    pub features: HashMap<String, Vec<String>>,
    pub profile: HashMap<String, ProfileConfig>,
    pub workspace_members: Vec<String>,
}

#[derive(Clone, Debug)]
pub struct DependencyConfig {
    pub version: Option<String>,
    pub path: Option<String>,
    pub git: Option<String>,
    pub branch: Option<String>,
    pub features: Vec<String>,
    pub optional: bool,
}

#[derive(Clone, Debug)]
pub struct ProfileConfig {
    pub opt_level: u8,
    pub debug: bool,
    pub lto: bool,
    pub panic: String,
}

impl Default for ProjectConfig {
    fn default() -> Self {
        ProjectConfig {
            name: String::new(),
            version: "0.1.0".to_string(),
            edition: "2024".to_string(),
            dependencies: HashMap::new(),
            dev_dependencies: HashMap::new(),
            features: HashMap::new(),
            profile: HashMap::new(),
            workspace_members: Vec::new(),
        }
    }
}

/// Project configuration manager
pub struct ProjectConfigManager {
    configs: RwLock<HashMap<String, ProjectConfig>>,
}

impl ProjectConfigManager {
    pub fn new() -> Self {
        ProjectConfigManager {
            configs: RwLock::new(HashMap::new()),
        }
    }

    /// Load project configuration from Quanta.toml
    pub fn load(&self, workspace_root: &str) -> Result<ProjectConfig, String> {
        let config_path = format!("{}/Quanta.toml", workspace_root);

        // In real implementation, would read and parse TOML file
        let config = ProjectConfig {
            name: "project".to_string(),
            ..Default::default()
        };

        let mut configs = self.configs.write().unwrap();
        configs.insert(workspace_root.to_string(), config.clone());

        Ok(config)
    }

    /// Get project configuration
    pub fn get(&self, workspace_root: &str) -> Option<ProjectConfig> {
        self.configs.read().unwrap().get(workspace_root).cloned()
    }

    /// Update project configuration
    pub fn update(&self, workspace_root: &str, config: ProjectConfig) -> Result<(), String> {
        let mut configs = self.configs.write().unwrap();
        configs.insert(workspace_root.to_string(), config);
        Ok(())
    }

    /// Get dependency graph
    pub fn dependency_graph(&self, workspace_root: &str) -> Vec<DependencyNode> {
        let config = match self.get(workspace_root) {
            Some(c) => c,
            None => return Vec::new(),
        };

        let mut nodes = Vec::new();

        // Root node
        nodes.push(DependencyNode {
            name: config.name.clone(),
            version: config.version.clone(),
            is_dev: false,
            dependencies: config.dependencies.keys().cloned().collect(),
        });

        // Dependency nodes
        for (name, dep) in &config.dependencies {
            nodes.push(DependencyNode {
                name: name.clone(),
                version: dep.version.clone().unwrap_or_else(|| "*".to_string()),
                is_dev: false,
                dependencies: Vec::new(),
            });
        }

        for (name, dep) in &config.dev_dependencies {
            nodes.push(DependencyNode {
                name: name.clone(),
                version: dep.version.clone().unwrap_or_else(|| "*".to_string()),
                is_dev: true,
                dependencies: Vec::new(),
            });
        }

        nodes
    }
}

#[derive(Clone, Debug)]
pub struct DependencyNode {
    pub name: String,
    pub version: String,
    pub is_dev: bool,
    pub dependencies: Vec<String>,
}

