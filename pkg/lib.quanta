/// Monorepo workspace manager
pub struct MonorepoManager {
    root_path: String,
    packages: Vec<MonorepoPackage>,
    workspace_config: WorkspaceConfig,
}

#[derive(Clone)]
pub struct MonorepoPackage {
    name: String,
    path: String,
    manifest: Manifest,
    local_deps: Vec<String>,
    changed: bool,
}

#[derive(Clone)]
pub struct WorkspaceConfig {
    packages: Vec<String>, // Glob patterns
    shared_deps: HashMap<String, String>,
    hoist_dependencies: bool,
    link_protocol: LinkProtocol,
}

#[derive(Clone, Copy)]
pub enum LinkProtocol {
    Symlink,
    HardLink,
    Copy,
}

impl MonorepoManager {
    pub fn new(root_path: &str) -> Result<Self, PackageError> {
        let workspace_config = Self::load_workspace_config(root_path)?;

        Ok(MonorepoManager {
            root_path: root_path.to_string(),
            packages: Vec::new(),
            workspace_config,
        })
    }

    fn load_workspace_config(root_path: &str) -> Result<WorkspaceConfig, PackageError> {
        let config_path = format!("{}/quark-workspace.toml", root_path);

        if std::path::Path::new(&config_path).exists() {
            // Parse workspace config
            Ok(WorkspaceConfig {
                packages: vec!["packages/*".to_string()],
                shared_deps: HashMap::new(),
                hoist_dependencies: true,
                link_protocol: LinkProtocol::Symlink,
            })
        } else {
            Err(PackageError::InvalidManifest("Not a workspace root".to_string()))
        }
    }

    pub fn discover_packages(&mut self) -> Result<(), PackageError> {
        self.packages.clear();

        for pattern in &self.workspace_config.packages {
            let full_pattern = format!("{}/{}/quark.toml", self.root_path, pattern);

            // In real implementation, use glob matching
            // For now, just check direct directories
            if let Ok(entries) = std::fs::read_dir(&self.root_path) {
                for entry in entries.flatten() {
                    let path = entry.path();
                    if path.is_dir() {
                        let manifest_path = path.join("quark.toml");
                        if manifest_path.exists() {
                            let manifest = Manifest::load(manifest_path.to_str().unwrap())?;
                            let package = MonorepoPackage {
                                name: manifest.package.name.clone(),
                                path: path.to_string_lossy().to_string(),
                                manifest,
                                local_deps: Vec::new(),
                                changed: false,
                            };
                            self.packages.push(package);
                        }
                    }
                }
            }
        }

        self.resolve_local_deps()?;
        Ok(())
    }

    fn resolve_local_deps(&mut self) -> Result<(), PackageError> {
        let package_names: Vec<String> = self.packages.iter()
            .map(|p| p.name.clone())
            .collect();

        for package in &mut self.packages {
            package.local_deps.clear();
            for dep in package.manifest.dependencies.keys() {
                if package_names.contains(dep) {
                    package.local_deps.push(dep.clone());
                }
            }
        }

        Ok(())
    }

    pub fn list_packages(&self) -> &[MonorepoPackage] {
        &self.packages
    }

    pub fn get_package(&self, name: &str) -> Option<&MonorepoPackage> {
        self.packages.iter().find(|p| p.name == name)
    }

    pub fn build_order(&self) -> Result<Vec<&str>, PackageError> {
        // Topological sort based on local dependencies
        let mut order = Vec::new();
        let mut visited = std::collections::HashSet::new();
        let mut in_progress = std::collections::HashSet::new();

        for package in &self.packages {
            self.visit_package(&package.name, &mut order, &mut visited, &mut in_progress)?;
        }

        Ok(order)
    }

    fn visit_package<'a>(
        &'a self,
        name: &str,
        order: &mut Vec<&'a str>,
        visited: &mut std::collections::HashSet<String>,
        in_progress: &mut std::collections::HashSet<String>,
    ) -> Result<(), PackageError> {
        if visited.contains(name) {
            return Ok(());
        }

        if in_progress.contains(name) {
            return Err(PackageError::DependencyCycle(name.to_string()));
        }

        in_progress.insert(name.to_string());

        if let Some(package) = self.get_package(name) {
            for dep in &package.local_deps {
                self.visit_package(dep, order, visited, in_progress)?;
            }
        }

        in_progress.remove(name);
        visited.insert(name.to_string());

        if let Some(package) = self.get_package(name) {
            order.push(&package.name);
        }

        Ok(())
    }

    pub fn install_all(&self) -> Result<(), PackageError> {
        let order = self.build_order()?;

        for name in order {
            println!("Installing {}...", name);
            if let Some(package) = self.get_package(name) {
                // Install external dependencies
                // Link local dependencies
            }
        }

        Ok(())
    }

    pub fn build_all(&self) -> Result<(), PackageError> {
        let order = self.build_order()?;

        for name in order {
            println!("Building {}...", name);
            if let Some(package) = self.get_package(name) {
                // Run build command
            }
        }

        Ok(())
    }

    pub fn find_changed(&mut self, since: &str) -> Result<Vec<String>, PackageError> {
        let mut changed = Vec::new();

        // In real implementation, use git to find changed files
        // and map them to packages

        for package in &mut self.packages {
            // Check if any files in package directory changed
            package.changed = false; // Simplified
            if package.changed {
                changed.push(package.name.clone());
            }
        }

        // Also mark packages that depend on changed packages
        self.propagate_changes(&changed)?;

        Ok(self.packages.iter()
            .filter(|p| p.changed)
            .map(|p| p.name.clone())
            .collect())
    }

    fn propagate_changes(&mut self, changed: &[String]) -> Result<(), PackageError> {
        let mut to_mark: Vec<String> = changed.to_vec();

        while let Some(name) = to_mark.pop() {
            for package in &mut self.packages {
                if !package.changed && package.local_deps.contains(&name) {
                    package.changed = true;
                    to_mark.push(package.name.clone());
                }
            }
        }

        Ok(())
    }

    pub fn run_in_packages<F>(&self, packages: &[&str], f: F) -> Result<(), PackageError>
    where
        F: Fn(&MonorepoPackage) -> Result<(), PackageError>
    {
        for name in packages {
            if let Some(package) = self.get_package(name) {
                f(package)?;
            }
        }
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECURITY POLICY ENFORCEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Security policy for package management
pub struct SecurityPolicy {
    rules: Vec<PolicyRule>,
    blocked_packages: Vec<BlockedPackage>,
    vulnerability_threshold: VulnerabilitySeverity,
    require_signatures: bool,
    allowed_registries: Vec<String>,
    max_dependency_depth: Option<usize>,
}

#[derive(Clone)]
pub struct PolicyRule {
    name: String,
    description: String,
    condition: PolicyCondition,
    action: PolicyAction,
    severity: PolicySeverity,
}

#[derive(Clone)]
pub enum PolicyCondition {
    PackageName(String),
    PackageVersion { name: String, version_pattern: String },
    License(String),
    Vulnerability(VulnerabilitySeverity),
    Dependency { name: String, transitive: bool },
    Registry(String),
    Custom(String), // Custom expression
}

#[derive(Clone, Copy)]
pub enum PolicyAction {
    Allow,
    Warn,
    Block,
    RequireApproval,
}

#[derive(Clone, Copy)]
pub enum PolicySeverity {
    Low,
    Medium,
    High,
    Critical,
}

#[derive(Clone)]
pub struct BlockedPackage {
    name: String,
    versions: Option<String>,
    reason: String,
    blocked_at: u64,
    blocked_by: String,
}

impl SecurityPolicy {
    pub fn new() -> Self {
        SecurityPolicy {
            rules: Vec::new(),
            blocked_packages: Vec::new(),
            vulnerability_threshold: VulnerabilitySeverity::High,
            require_signatures: false,
            allowed_registries: Vec::new(),
            max_dependency_depth: None,
        }
    }

    pub fn load(path: &str) -> Result<Self, PackageError> {
        let content = std::fs::read_to_string(path)
            .map_err(|e| PackageError::NetworkError(e.to_string()))?;

        // Parse policy file
        Ok(SecurityPolicy::new())
    }

    pub fn add_rule(&mut self, rule: PolicyRule) {
        self.rules.push(rule);
    }

    pub fn block_package(&mut self, name: &str, versions: Option<&str>, reason: &str) {
        self.blocked_packages.push(BlockedPackage {
            name: name.to_string(),
            versions: versions.map(|s| s.to_string()),
            reason: reason.to_string(),
            blocked_at: current_timestamp(),
            blocked_by: "policy".to_string(),
        });
    }

    pub fn evaluate(&self, manifest: &Manifest, resolution: &Resolution) -> PolicyEvaluationResult {
        let mut result = PolicyEvaluationResult {
            passed: true,
            violations: Vec::new(),
            warnings: Vec::new(),
        };

        // Check blocked packages
        for blocked in &self.blocked_packages {
            if resolution.packages.iter().any(|p| p.name == blocked.name) {
                result.passed = false;
                result.violations.push(PolicyViolation {
                    rule: "blocked_package".to_string(),
                    package: blocked.name.clone(),
                    message: format!("Blocked: {}", blocked.reason),
                    severity: PolicySeverity::Critical,
                });
            }
        }

        // Check each rule
        for rule in &self.rules {
            self.evaluate_rule(&rule, manifest, resolution, &mut result);
        }

        // Check dependency depth
        if let Some(max_depth) = self.max_dependency_depth {
            for pkg in &resolution.packages {
                if pkg.depth > max_depth {
                    result.warnings.push(PolicyViolation {
                        rule: "max_depth".to_string(),
                        package: pkg.name.clone(),
                        message: format!("Dependency depth {} exceeds maximum {}", pkg.depth, max_depth),
                        severity: PolicySeverity::Medium,
                    });
                }
            }
        }

        result
    }

    fn evaluate_rule(&self, rule: &PolicyRule, manifest: &Manifest, resolution: &Resolution, result: &mut PolicyEvaluationResult) {
        match &rule.condition {
            PolicyCondition::PackageName(name) => {
                if resolution.packages.iter().any(|p| &p.name == name) {
                    self.apply_action(rule, name, result);
                }
            }
            PolicyCondition::License(license) => {
                for pkg in &resolution.packages {
                    if pkg.license.as_ref().map(|l| l == license).unwrap_or(false) {
                        self.apply_action(rule, &pkg.name, result);
                    }
                }
            }
            _ => {}
        }
    }

    fn apply_action(&self, rule: &PolicyRule, package: &str, result: &mut PolicyEvaluationResult) {
        let violation = PolicyViolation {
            rule: rule.name.clone(),
            package: package.to_string(),
            message: rule.description.clone(),
            severity: rule.severity,
        };

        match rule.action {
            PolicyAction::Block => {
                result.passed = false;
                result.violations.push(violation);
            }
            PolicyAction::Warn => {
                result.warnings.push(violation);
            }
            PolicyAction::RequireApproval => {
                result.passed = false;
                result.violations.push(violation);
            }
            PolicyAction::Allow => {}
        }
    }
}

#[derive(Clone)]
pub struct PolicyEvaluationResult {
    pub passed: bool,
    pub violations: Vec<PolicyViolation>,
    pub warnings: Vec<PolicyViolation>,
}

#[derive(Clone)]
pub struct PolicyViolation {
    pub rule: String,
    pub package: String,
    pub message: String,
    pub severity: PolicySeverity,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPENDENCY GRAPH ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Dependency graph analyzer
pub struct DependencyGraphAnalyzer {
    graph: DependencyGraph,
}

#[derive(Clone)]
pub struct DependencyGraph {
    nodes: HashMap<String, GraphNode>,
    edges: Vec<GraphEdge>,
}

#[derive(Clone)]
pub struct GraphNode {
    name: String,
    version: String,
    depth: usize,
    size: u64,
    license: Option<String>,
}

#[derive(Clone)]
pub struct GraphEdge {
    from: String,
    to: String,
    dependency_type: DependencyType,
    version_constraint: String,
}

#[derive(Clone, Copy)]
pub enum DependencyType {
    Direct,
    Transitive,
    Dev,
    Peer,
    Optional,
}

impl DependencyGraphAnalyzer {
    pub fn new() -> Self {
        DependencyGraphAnalyzer {
            graph: DependencyGraph {
                nodes: HashMap::new(),
                edges: Vec::new(),
            },
        }
    }

    pub fn build_graph(&mut self, resolution: &Resolution) -> Result<(), PackageError> {
        self.graph.nodes.clear();
        self.graph.edges.clear();

        for pkg in &resolution.packages {
            let node = GraphNode {
                name: pkg.name.clone(),
                version: pkg.version.to_string(),
                depth: pkg.depth,
                size: 0,
                license: pkg.license.clone(),
            };
            self.graph.nodes.insert(pkg.name.clone(), node);

            for dep in &pkg.dependencies {
                self.graph.edges.push(GraphEdge {
                    from: pkg.name.clone(),
                    to: dep.name.clone(),
                    dependency_type: DependencyType::Direct,
                    version_constraint: dep.constraint.to_string(),
                });
            }
        }

        Ok(())
    }

    pub fn find_cycles(&self) -> Vec<Vec<String>> {
        let mut cycles = Vec::new();
        let mut visited = std::collections::HashSet::new();
        let mut path = Vec::new();

        for node in self.graph.nodes.keys() {
            self.find_cycles_from(node, &mut visited, &mut path, &mut cycles);
        }

        cycles
    }

    fn find_cycles_from(
        &self,
        node: &str,
        visited: &mut std::collections::HashSet<String>,
        path: &mut Vec<String>,
        cycles: &mut Vec<Vec<String>>,
    ) {
        if path.contains(&node.to_string()) {
            // Found a cycle
            let cycle_start = path.iter().position(|n| n == node).unwrap();
            cycles.push(path[cycle_start..].to_vec());
            return;
        }

        if visited.contains(node) {
            return;
        }

        path.push(node.to_string());

        for edge in &self.graph.edges {
            if edge.from == node {
                self.find_cycles_from(&edge.to, visited, path, cycles);
            }
        }

        path.pop();
        visited.insert(node.to_string());
    }

    pub fn find_duplicates(&self) -> HashMap<String, Vec<String>> {
        let mut package_versions: HashMap<String, Vec<String>> = HashMap::new();

        for node in self.graph.nodes.values() {
            package_versions
                .entry(node.name.clone())
                .or_insert_with(Vec::new)
                .push(node.version.clone());
        }

        // Only return packages with multiple versions
        package_versions.into_iter()
            .filter(|(_, versions)| versions.len() > 1)
            .collect()
    }

    pub fn calculate_metrics(&self) -> GraphMetrics {
        let node_count = self.graph.nodes.len();
        let edge_count = self.graph.edges.len();

        let max_depth = self.graph.nodes.values()
            .map(|n| n.depth)
            .max()
            .unwrap_or(0);

        let total_size: u64 = self.graph.nodes.values()
            .map(|n| n.size)
            .sum();

        let direct_deps = self.graph.nodes.values()
            .filter(|n| n.depth == 1)
            .count();

        GraphMetrics {
            total_packages: node_count,
            total_dependencies: edge_count,
            max_depth,
            total_size,
            direct_dependencies: direct_deps,
            transitive_dependencies: node_count.saturating_sub(direct_deps),
            duplicate_packages: self.find_duplicates().len(),
        }
    }

    pub fn find_paths(&self, from: &str, to: &str) -> Vec<Vec<String>> {
        let mut paths = Vec::new();
        let mut current_path = vec![from.to_string()];

        self.dfs_paths(from, to, &mut current_path, &mut paths);

        paths
    }

    fn dfs_paths(&self, current: &str, target: &str, path: &mut Vec<String>, paths: &mut Vec<Vec<String>>) {
        if current == target {
            paths.push(path.clone());
            return;
        }

        for edge in &self.graph.edges {
            if edge.from == current && !path.contains(&edge.to) {
                path.push(edge.to.clone());
                self.dfs_paths(&edge.to, target, path, paths);
                path.pop();
            }
        }
    }

    pub fn export_dot(&self) -> String {
        let mut dot = String::from("digraph dependencies {\n");
        dot.push_str("  rankdir=LR;\n");
        dot.push_str("  node [shape=box];\n\n");

        for node in self.graph.nodes.values() {
            dot.push_str(&format!("  \"{}\" [label=\"{}@{}\"];\n",
                node.name, node.name, node.version));
        }

        dot.push_str("\n");

        for edge in &self.graph.edges {
            dot.push_str(&format!("  \"{}\" -> \"{}\";\n", edge.from, edge.to));
        }

        dot.push_str("}\n");
        dot
    }
}

#[derive(Clone)]
pub struct GraphMetrics {
    pub total_packages: usize,
    pub total_dependencies: usize,
    pub max_depth: usize,
    pub total_size: u64,
    pub direct_dependencies: usize,
    pub transitive_dependencies: usize,
    pub duplicate_packages: usize,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE ANALYTICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Package usage analytics
pub struct PackageAnalytics {
    events: Vec<AnalyticsEvent>,
    aggregates: AnalyticsAggregates,
}

#[derive(Clone)]
pub struct AnalyticsEvent {
    event_type: AnalyticsEventType,
    package: String,
    version: String,
    timestamp: u64,
    metadata: HashMap<String, String>,
}

#[derive(Clone, Copy)]
pub enum AnalyticsEventType {
    Install,
    Update,
    Remove,
    Build,
    Publish,
    Download,
}

#[derive(Clone, Default)]
pub struct AnalyticsAggregates {
    total_installs: u64,
    total_downloads: u64,
    unique_packages: usize,
    builds_today: u64,
    avg_build_time_ms: u64,
}

impl PackageAnalytics {
    pub fn new() -> Self {
        PackageAnalytics {
            events: Vec::new(),
            aggregates: AnalyticsAggregates::default(),
        }
    }

    pub fn track(&mut self, event_type: AnalyticsEventType, package: &str, version: &str) {
        self.events.push(AnalyticsEvent {
            event_type,
            package: package.to_string(),
            version: version.to_string(),
            timestamp: current_timestamp(),
            metadata: HashMap::new(),
        });

        self.update_aggregates();
    }

    fn update_aggregates(&mut self) {
        self.aggregates.total_installs = self.events.iter()
            .filter(|e| matches!(e.event_type, AnalyticsEventType::Install))
            .count() as u64;

        self.aggregates.total_downloads = self.events.iter()
            .filter(|e| matches!(e.event_type, AnalyticsEventType::Download))
            .count() as u64;

        let packages: std::collections::HashSet<_> = self.events.iter()
            .map(|e| &e.package)
            .collect();
        self.aggregates.unique_packages = packages.len();
    }

    pub fn get_most_installed(&self, limit: usize) -> Vec<(String, u64)> {
        let mut counts: HashMap<String, u64> = HashMap::new();

        for event in &self.events {
            if matches!(event.event_type, AnalyticsEventType::Install) {
                *counts.entry(event.package.clone()).or_insert(0) += 1;
            }
        }

        let mut sorted: Vec<_> = counts.into_iter().collect();
        sorted.sort_by(|a, b| b.1.cmp(&a.1));
        sorted.truncate(limit);
        sorted
    }

    pub fn get_install_trend(&self, days: u32) -> Vec<(u64, u64)> {
        let now = current_timestamp();
        let day_ms = 86400 * 1000;
        let start = now - (days as u64 * day_ms);

        let mut daily_counts: Vec<(u64, u64)> = Vec::new();

        for day in 0..days {
            let day_start = start + (day as u64 * day_ms);
            let day_end = day_start + day_ms;

            let count = self.events.iter()
                .filter(|e| {
                    matches!(e.event_type, AnalyticsEventType::Install) &&
                    e.timestamp >= day_start &&
                    e.timestamp < day_end
                })
                .count() as u64;

            daily_counts.push((day_start, count));
        }

        daily_counts
    }

    pub fn summary(&self) -> &AnalyticsAggregates {
        &self.aggregates
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CI/CD INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// CI/CD integration for package management
pub struct CiCdIntegration {
    provider: CiProvider,
    config: CiConfig,
}

#[derive(Clone)]
pub enum CiProvider {
    GitHub,
    GitLab,
    Jenkins,
    CircleCI,
    Travis,
    Custom(String),
}

#[derive(Clone)]
pub struct CiConfig {
    cache_enabled: bool,
    cache_key: String,
    parallel_jobs: usize,
    fail_fast: bool,
}

impl CiCdIntegration {
    pub fn detect() -> Option<CiProvider> {
        if std::env::var("GITHUB_ACTIONS").is_ok() {
            return Some(CiProvider::GitHub);
        }
        if std::env::var("GITLAB_CI").is_ok() {
            return Some(CiProvider::GitLab);
        }
        if std::env::var("JENKINS_URL").is_ok() {
            return Some(CiProvider::Jenkins);
        }
        if std::env::var("CIRCLECI").is_ok() {
            return Some(CiProvider::CircleCI);
        }
        if std::env::var("TRAVIS").is_ok() {
            return Some(CiProvider::Travis);
        }
        None
    }

    pub fn new(provider: CiProvider) -> Self {
        CiCdIntegration {
            provider,
            config: CiConfig {
                cache_enabled: true,
                cache_key: "quark-cache".to_string(),
                parallel_jobs: 4,
                fail_fast: true,
            },
        }
    }

    pub fn generate_config(&self, manifest_path: &str) -> String {
        match self.provider {
            CiProvider::GitHub => self.generate_github_actions(manifest_path),
            CiProvider::GitLab => self.generate_gitlab_ci(manifest_path),
            _ => String::new(),
        }
    }

    fn generate_github_actions(&self, manifest_path: &str) -> String {
        r#"name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Cache dependencies
        uses: actions/cache@v3
        with:
          path: .quark/cache
          key: quark-${{ hashFiles('quark.lock') }}

      - name: Install dependencies
        run: quark install --frozen

      - name: Build
        run: quark build

      - name: Test
        run: quark test

      - name: Audit
        run: quark audit
"#.to_string()
    }

    fn generate_gitlab_ci(&self, manifest_path: &str) -> String {
        r#"stages:
  - build
  - test
  - audit

cache:
  key: quark-cache
  paths:
    - .quark/cache

install:
  stage: build
  script:
    - quark install --frozen

build:
  stage: build
  script:
    - quark build

test:
  stage: test
  script:
    - quark test

audit:
  stage: audit
  script:
    - quark audit
  allow_failure: true
"#.to_string()
    }

    pub fn setup_cache(&self) -> Result<(), PackageError> {
        match self.provider {
            CiProvider::GitHub => {
                // GitHub Actions handles caching via actions/cache
                println!("::set-output name=cache-key::quark-{}",
                    std::env::var("GITHUB_SHA").unwrap_or_default());
            }
            CiProvider::GitLab => {
                // GitLab CI handles caching via .gitlab-ci.yml
            }
            _ => {}
        }
        Ok(())
    }

    pub fn report_status(&self, status: &str, message: &str) {
        match self.provider {
            CiProvider::GitHub => {
                println!("::notice::{}: {}", status, message);
            }
            CiProvider::GitLab => {
                println!("[{}] {}", status, message);
            }
            _ => {
                println!("{}: {}", status, message);
            }
        }
    }

    pub fn create_annotations(&self, violations: &[PolicyViolation]) {
        for violation in violations {
            match self.provider {
                CiProvider::GitHub => {
                    let level = match violation.severity {
                        PolicySeverity::Critical | PolicySeverity::High => "error",
                        PolicySeverity::Medium => "warning",
                        PolicySeverity::Low => "notice",
                    };
                    println!("::{}::Package {}: {}", level, violation.package, violation.message);
                }
                _ => {
                    println!("[{}] {}: {}",
                        format!("{:?}", violation.severity),
                        violation.package,
                        violation.message);
                }
            }
        }
    }
}

