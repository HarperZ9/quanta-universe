module pkg

use foundation::io::{println, print, File, read_to_string, write_string}
use foundation::collections::{Vec, HashMap, HashSet}
use foundation::fs::{create_dir_all, remove_dir_all, exists, copy_dir}
use foundation::net::{HttpClient, Response}
use foundation::crypto::{sha256, verify_signature}
use foundation::archive::{TarGz, extract}
use foundation::semver::{Version, VersionReq}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE MANIFEST
// ═══════════════════════════════════════════════════════════════════════════════

/// Package manifest (quark.toml)
#[derive(Clone, Debug)]
pub struct Manifest {
    pub package: PackageInfo,
    pub dependencies: HashMap<String, Dependency>,
    pub dev_dependencies: HashMap<String, Dependency>,
    pub build_dependencies: HashMap<String, Dependency>,
    pub features: HashMap<String, Vec<String>>,
    pub targets: Vec<Target>,
    pub metadata: HashMap<String, String>,
}

#[derive(Clone, Debug)]
pub struct PackageInfo {
    pub name: String,
    pub version: Version,
    pub authors: Vec<String>,
    pub edition: String,
    pub description: Option<String>,
    pub license: Option<String>,
    pub repository: Option<String>,
    pub homepage: Option<String>,
    pub documentation: Option<String>,
    pub keywords: Vec<String>,
    pub categories: Vec<String>,
}

#[derive(Clone, Debug)]
pub struct Dependency {
    pub version: VersionReq,
    pub registry: Option<String>,
    pub git: Option<String>,
    pub branch: Option<String>,
    pub tag: Option<String>,
    pub path: Option<String>,
    pub optional: bool,
    pub features: Vec<String>,
    pub default_features: bool,
}

#[derive(Clone, Debug)]
pub struct Target {
    pub name: String,
    pub target_type: TargetType,
    pub path: String,
    pub required_features: Vec<String>,
}

#[derive(Clone, Debug, PartialEq)]
pub enum TargetType {
    Library,
    Binary,
    Example,
    Test,
    Benchmark,
}

impl Manifest {
    /// Parse manifest from TOML string
    pub fn from_toml(content: &str) -> Result<Self, ManifestError> {
        // TOML parsing implementation
        let mut manifest = Manifest {
            package: PackageInfo {
                name: String::new(),
                version: Version::new(0, 1, 0),
                authors: Vec::new(),
                edition: "2024".to_string(),
                description: None,
                license: None,
                repository: None,
                homepage: None,
                documentation: None,
                keywords: Vec::new(),
                categories: Vec::new(),
            },
            dependencies: HashMap::new(),
            dev_dependencies: HashMap::new(),
            build_dependencies: HashMap::new(),
            features: HashMap::new(),
            targets: Vec::new(),
            metadata: HashMap::new(),
        };

        // Parse TOML sections
        for line in content.lines() {
            let line = line.trim();
            if line.starts_with("name = ") {
                manifest.package.name = parse_string_value(line);
            } else if line.starts_with("version = ") {
                manifest.package.version = Version::parse(&parse_string_value(line))?;
            }
            // ... additional parsing
        }

        Ok(manifest)
    }

    /// Serialize manifest to TOML string
    pub fn to_toml(&self) -> String {
        let mut output = String::new();

        output.push_str("[package]\n");
        output.push_str(&format!("name = \"{}\"\n", self.package.name));
        output.push_str(&format!("version = \"{}\"\n", self.package.version));
        output.push_str(&format!("edition = \"{}\"\n", self.package.edition));

        if !self.package.authors.is_empty() {
            output.push_str(&format!("authors = {:?}\n", self.package.authors));
        }

        if let Some(ref desc) = self.package.description {
            output.push_str(&format!("description = \"{}\"\n", desc));
        }

        if let Some(ref license) = self.package.license {
            output.push_str(&format!("license = \"{}\"\n", license));
        }

        if !self.dependencies.is_empty() {
            output.push_str("\n[dependencies]\n");
            for (name, dep) in &self.dependencies {
                output.push_str(&format!("{} = \"{}\"\n", name, dep.version));
            }
        }

        output
    }

    /// Load manifest from file
    pub fn load(path: &str) -> Result<Self, ManifestError> {
        let content = read_to_string(path)?;
        Self::from_toml(&content)
    }

    /// Save manifest to file
    pub fn save(&self, path: &str) -> Result<(), ManifestError> {
        let content = self.to_toml();
        write_string(path, &content)?;
        Ok(())
    }
}

fn parse_string_value(line: &str) -> String {
    line.split('=')
        .nth(1)
        .map(|s| s.trim().trim_matches('"').to_string())
        .unwrap_or_default()
}

#[derive(Debug)]
pub enum ManifestError {
    ParseError(String),
    IoError(String),
    VersionError(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE REGISTRY
// ═══════════════════════════════════════════════════════════════════════════════

/// Package registry client
pub struct Registry {
    url: String,
    client: HttpClient,
    cache: RegistryCache,
    config: RegistryConfig,
}

#[derive(Clone)]
pub struct RegistryConfig {
    pub index_url: String,
    pub api_url: String,
    pub download_url: String,
    pub auth_token: Option<String>,
    pub cache_dir: String,
}

impl Default for RegistryConfig {
    fn default() -> Self {
        RegistryConfig {
            index_url: "https://index.quark.quanta-universe.dev".to_string(),
            api_url: "https://api.quark.quanta-universe.dev".to_string(),
            download_url: "https://dl.quark.quanta-universe.dev".to_string(),
            auth_token: None,
            cache_dir: "~/.quark/cache".to_string(),
        }
    }
}

pub struct RegistryCache {
    index: HashMap<String, Vec<PackageVersion>>,
    packages: HashMap<String, CachedPackage>,
}

#[derive(Clone)]
pub struct PackageVersion {
    pub version: Version,
    pub checksum: String,
    pub yanked: bool,
    pub dependencies: Vec<(String, VersionReq)>,
    pub features: HashMap<String, Vec<String>>,
}

pub struct CachedPackage {
    pub name: String,
    pub version: Version,
    pub path: String,
    pub cached_at: u64,
}

impl Registry {
    pub fn new(config: RegistryConfig) -> Self {
        Registry {
            url: config.api_url.clone(),
            client: HttpClient::new(),
            cache: RegistryCache {
                index: HashMap::new(),
                packages: HashMap::new(),
            },
            config,
        }
    }

    /// Search for packages
    pub fn search(&self, query: &str) -> Result<Vec<SearchResult>, RegistryError> {
        let url = format!("{}/search?q={}", self.url, query);
        let response = self.client.get(&url)?;

        // Parse JSON response
        let results: Vec<SearchResult> = parse_search_results(&response.body)?;
        Ok(results)
    }

    /// Get package info
    pub fn get_package(&self, name: &str) -> Result<PackageInfo, RegistryError> {
        let url = format!("{}/packages/{}", self.url, name);
        let response = self.client.get(&url)?;

        // Parse JSON response
        let info = parse_package_info(&response.body)?;
        Ok(info)
    }

    /// Get all versions of a package
    pub fn get_versions(&self, name: &str) -> Result<Vec<PackageVersion>, RegistryError> {
        // Check cache first
        if let Some(versions) = self.cache.index.get(name) {
            return Ok(versions.clone());
        }

        let url = format!("{}/packages/{}/versions", self.url, name);
        let response = self.client.get(&url)?;

        let versions = parse_versions(&response.body)?;
        Ok(versions)
    }

    /// Download a package
    pub fn download(&self, name: &str, version: &Version) -> Result<String, RegistryError> {
        let cache_key = format!("{}-{}", name, version);

        // Check cache
        if let Some(cached) = self.cache.packages.get(&cache_key) {
            if exists(&cached.path) {
                return Ok(cached.path.clone());
            }
        }

        // Download package
        let url = format!("{}/{}/{}/download", self.config.download_url, name, version);
        let response = self.client.get(&url)?;

        // Verify checksum
        let checksum = sha256(&response.body);
        let expected = self.get_checksum(name, version)?;
        if checksum != expected {
            return Err(RegistryError::ChecksumMismatch);
        }

        // Extract to cache directory
        let cache_path = format!("{}/{}-{}", self.config.cache_dir, name, version);
        create_dir_all(&cache_path)?;

        let archive = TarGz::from_bytes(&response.body)?;
        archive.extract(&cache_path)?;

        Ok(cache_path)
    }

    /// Publish a package
    pub fn publish(&self, tarball: &[u8], manifest: &Manifest) -> Result<(), RegistryError> {
        let token = self.config.auth_token.as_ref()
            .ok_or(RegistryError::AuthRequired)?;

        let url = format!("{}/publish", self.url);
        let _response = self.client.post(&url)
            .header("Authorization", &format!("Bearer {}", token))
            .body(tarball)
            .send()?;

        println!("Published {} v{}", manifest.package.name, manifest.package.version);
        Ok(())
    }

    /// Yank a version (mark as not recommended)
    pub fn yank(&self, name: &str, version: &Version) -> Result<(), RegistryError> {
        let token = self.config.auth_token.as_ref()
            .ok_or(RegistryError::AuthRequired)?;

        let url = format!("{}/packages/{}/{}/yank", self.url, name, version);
        self.client.delete(&url)
            .header("Authorization", &format!("Bearer {}", token))
            .send()?;

        println!("Yanked {} v{}", name, version);
        Ok(())
    }

    fn get_checksum(&self, name: &str, version: &Version) -> Result<String, RegistryError> {
        let versions = self.get_versions(name)?;
        versions.iter()
            .find(|v| &v.version == version)
            .map(|v| v.checksum.clone())
            .ok_or(RegistryError::VersionNotFound)
    }
}

#[derive(Clone)]
pub struct SearchResult {
    pub name: String,
    pub description: String,
    pub max_version: Version,
    pub downloads: u64,
}

#[derive(Debug)]
pub enum RegistryError {
    NetworkError(String),
    ParseError(String),
    PackageNotFound,
    VersionNotFound,
    ChecksumMismatch,
    AuthRequired,
    Unauthorized,
}

fn parse_search_results(_body: &[u8]) -> Result<Vec<SearchResult>, RegistryError> {
    // JSON parsing implementation
    Ok(Vec::new())
}

fn parse_package_info(_body: &[u8]) -> Result<PackageInfo, RegistryError> {
    // JSON parsing implementation
    Ok(PackageInfo {
        name: String::new(),
        version: Version::new(0, 1, 0),
        authors: Vec::new(),
        edition: "2024".to_string(),
        description: None,
        license: None,
        repository: None,
        homepage: None,
        documentation: None,
        keywords: Vec::new(),
        categories: Vec::new(),
    })
}

fn parse_versions(_body: &[u8]) -> Result<Vec<PackageVersion>, RegistryError> {
    // JSON parsing implementation
    Ok(Vec::new())
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPENDENCY RESOLVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Dependency resolver using PubGrub algorithm
pub struct Resolver {
    registry: Registry,
    cache: ResolverCache,
}

pub struct ResolverCache {
    resolutions: HashMap<String, Resolution>,
}

pub struct Resolution {
    pub packages: Vec<ResolvedPackage>,
    pub features: HashMap<String, HashSet<String>>,
}

#[derive(Clone)]
pub struct ResolvedPackage {
    pub name: String,
    pub version: Version,
    pub source: PackageSource,
    pub dependencies: Vec<String>,
    pub features: HashSet<String>,
}

#[derive(Clone)]
pub enum PackageSource {
    Registry(String),
    Git { url: String, rev: String },
    Path(String),
}

impl Resolver {
    pub fn new(registry: Registry) -> Self {
        Resolver {
            registry,
            cache: ResolverCache {
                resolutions: HashMap::new(),
            },
        }
    }

    /// Resolve all dependencies
    pub fn resolve(&mut self, manifest: &Manifest) -> Result<Resolution, ResolveError> {
        println!("Resolving dependencies...");

        let mut resolution = Resolution {
            packages: Vec::new(),
            features: HashMap::new(),
        };

        // Build dependency graph
        let mut pending: Vec<(String, VersionReq)> = manifest.dependencies.iter()
            .map(|(name, dep)| (name.clone(), dep.version.clone()))
            .collect();

        let mut resolved: HashMap<String, Version> = HashMap::new();

        while let Some((name, req)) = pending.pop() {
            if resolved.contains_key(&name) {
                continue;
            }

            // Find best matching version
            let version = self.find_best_version(&name, &req)?;
            resolved.insert(name.clone(), version.clone());

            // Get transitive dependencies
            let versions = self.registry.get_versions(&name)?;
            if let Some(pkg_ver) = versions.iter().find(|v| v.version == version) {
                for (dep_name, dep_req) in &pkg_ver.dependencies {
                    if !resolved.contains_key(dep_name) {
                        pending.push((dep_name.clone(), dep_req.clone()));
                    }
                }
            }

            resolution.packages.push(ResolvedPackage {
                name: name.clone(),
                version,
                source: PackageSource::Registry(self.registry.url.clone()),
                dependencies: Vec::new(),
                features: HashSet::new(),
            });

            println!("  Resolved {} v{}", name, resolved.get(&name).unwrap());
        }

        Ok(resolution)
    }

    fn find_best_version(&self, name: &str, req: &VersionReq) -> Result<Version, ResolveError> {
        let versions = self.registry.get_versions(name)
            .map_err(|_| ResolveError::PackageNotFound(name.to_string()))?;

        versions.iter()
            .filter(|v| !v.yanked && req.matches(&v.version))
            .map(|v| v.version.clone())
            .max()
            .ok_or(ResolveError::NoMatchingVersion(name.to_string(), req.clone()))
    }
}

#[derive(Debug)]
pub enum ResolveError {
    PackageNotFound(String),
    NoMatchingVersion(String, VersionReq),
    ConflictingVersions(String, Version, Version),
    CyclicDependency(Vec<String>),
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

/// Main package manager interface
pub struct PackageManager {
    registry: Registry,
    resolver: Resolver,
    config: PackageManagerConfig,
}

#[derive(Clone)]
pub struct PackageManagerConfig {
    pub registry: RegistryConfig,
    pub install_dir: String,
    pub global_dir: String,
    pub offline: bool,
    pub locked: bool,
}

impl Default for PackageManagerConfig {
    fn default() -> Self {
        PackageManagerConfig {
            registry: RegistryConfig::default(),
            install_dir: "./quark_modules".to_string(),
            global_dir: "~/.quark/global".to_string(),
            offline: false,
            locked: false,
        }
    }
}

impl PackageManager {
    pub fn new(config: PackageManagerConfig) -> Self {
        let registry = Registry::new(config.registry.clone());
        let resolver = Resolver::new(Registry::new(config.registry.clone()));

        PackageManager {
            registry,
            resolver,
            config,
        }
    }

    /// Initialize a new package
    pub fn init(&self, name: &str, path: &str) -> Result<(), PackageError> {
        println!("Creating package '{}'...", name);

        create_dir_all(path)?;
        create_dir_all(&format!("{}/src", path))?;

        // Create quark.toml
        let manifest = Manifest {
            package: PackageInfo {
                name: name.to_string(),
                version: Version::new(0, 1, 0),
                authors: Vec::new(),
                edition: "2024".to_string(),
                description: Some(format!("A QUANTA-UNIVERSE package: {}", name)),
                license: Some("MIT".to_string()),
                repository: None,
                homepage: None,
                documentation: None,
                keywords: Vec::new(),
                categories: Vec::new(),
            },
            dependencies: HashMap::new(),
            dev_dependencies: HashMap::new(),
            build_dependencies: HashMap::new(),
            features: HashMap::new(),
            targets: Vec::new(),
            metadata: HashMap::new(),
        };

        manifest.save(&format!("{}/quark.toml", path))?;

        // Create lib.quanta
        let lib_content = format!(r#"// ═══════════════════════════════════════════════════════════════════════════════
// {} - A QUANTA-UNIVERSE Package
// ═══════════════════════════════════════════════════════════════════════════════

module {}

pub fn hello() {{
    println!("Hello from {}!");
}}

#[cfg(test)]
mod tests {{
    use super::*;

    #[test]
    fn test_hello() {{
        hello();
    }}
}}
"#, name, name, name);

        write_string(&format!("{}/src/lib.quanta", path), &lib_content)?;

        // Create .gitignore
        let gitignore = "quark_modules/\ntarget/\n*.lock\n";
        write_string(&format!("{}/.gitignore", path), gitignore)?;

        println!("  Created {}/quark.toml", path);
        println!("  Created {}/src/lib.quanta", path);
        println!("  ✓ Package initialized");

        Ok(())
    }

    /// Add a dependency
    pub fn add(&self, manifest_path: &str, name: &str, version: Option<&str>) -> Result<(), PackageError> {
        let mut manifest = Manifest::load(manifest_path)?;

        // Get latest version if not specified
        let version_req = if let Some(v) = version {
            VersionReq::parse(v)?
        } else {
            let versions = self.registry.get_versions(name)?;
            let latest = versions.iter()
                .filter(|v| !v.yanked)
                .map(|v| &v.version)
                .max()
                .ok_or(PackageError::PackageNotFound(name.to_string()))?;
            VersionReq::parse(&format!("^{}", latest))?
        };

        manifest.dependencies.insert(name.to_string(), Dependency {
            version: version_req.clone(),
            registry: None,
            git: None,
            branch: None,
            tag: None,
            path: None,
            optional: false,
            features: Vec::new(),
            default_features: true,
        });

        manifest.save(manifest_path)?;
        println!("Added {} {} to dependencies", name, version_req);

        Ok(())
    }

    /// Remove a dependency
    pub fn remove(&self, manifest_path: &str, name: &str) -> Result<(), PackageError> {
        let mut manifest = Manifest::load(manifest_path)?;

        if manifest.dependencies.remove(name).is_some() {
            manifest.save(manifest_path)?;
            println!("Removed {} from dependencies", name);
            Ok(())
        } else {
            Err(PackageError::DependencyNotFound(name.to_string()))
        }
    }

    /// Install all dependencies
    pub fn install(&mut self, manifest_path: &str) -> Result<(), PackageError> {
        let manifest = Manifest::load(manifest_path)?;

        println!("Installing dependencies for {}...", manifest.package.name);

        // Resolve dependencies
        let resolution = self.resolver.resolve(&manifest)?;

        // Download and install each package
        for pkg in &resolution.packages {
            let path = self.registry.download(&pkg.name, &pkg.version)?;
            let install_path = format!("{}/{}", self.config.install_dir, pkg.name);

            if exists(&install_path) {
                remove_dir_all(&install_path)?;
            }

            copy_dir(&path, &install_path)?;
            println!("  Installed {} v{}", pkg.name, pkg.version);
        }

        // Generate lockfile
        self.generate_lockfile(&resolution, manifest_path)?;

        println!("  ✓ Installed {} packages", resolution.packages.len());
        Ok(())
    }

    /// Update dependencies
    pub fn update(&mut self, manifest_path: &str, name: Option<&str>) -> Result<(), PackageError> {
        let manifest = Manifest::load(manifest_path)?;

        if let Some(pkg_name) = name {
            println!("Updating {}...", pkg_name);
            // Update specific package
        } else {
            println!("Updating all dependencies...");
            // Update all packages
        }

        let resolution = self.resolver.resolve(&manifest)?;
        self.generate_lockfile(&resolution, manifest_path)?;

        Ok(())
    }

    /// Search for packages
    pub fn search(&self, query: &str) -> Result<(), PackageError> {
        let results = self.registry.search(query)?;

        println!("Search results for '{}':", query);
        println!();

        for result in results {
            println!("  {} v{}", result.name, result.max_version);
            if !result.description.is_empty() {
                println!("    {}", result.description);
            }
            println!("    Downloads: {}", result.downloads);
            println!();
        }

        Ok(())
    }

    /// Publish the package
    pub fn publish(&self, manifest_path: &str) -> Result<(), PackageError> {
        let manifest = Manifest::load(manifest_path)?;

        println!("Publishing {} v{}...", manifest.package.name, manifest.package.version);

        // Create tarball
        let tarball = self.create_tarball(manifest_path)?;

        // Verify package
        self.verify_package(&manifest)?;

        // Publish to registry
        self.registry.publish(&tarball, &manifest)?;

        println!("  ✓ Published successfully");
        Ok(())
    }

    fn generate_lockfile(&self, resolution: &Resolution, manifest_path: &str) -> Result<(), PackageError> {
        let lock_path = manifest_path.replace("quark.toml", "quark.lock");
        let mut content = String::new();

        content.push_str("# This file is auto-generated by quark\n");
        content.push_str("# Do not edit manually\n\n");

        for pkg in &resolution.packages {
            content.push_str(&format!("[[package]]\n"));
            content.push_str(&format!("name = \"{}\"\n", pkg.name));
            content.push_str(&format!("version = \"{}\"\n", pkg.version));
            match &pkg.source {
                PackageSource::Registry(url) => {
                    content.push_str(&format!("source = \"registry+{}\"\n", url));
                }
                PackageSource::Git { url, rev } => {
                    content.push_str(&format!("source = \"git+{}#{}\"\n", url, rev));
                }
                PackageSource::Path(path) => {
                    content.push_str(&format!("source = \"path+{}\"\n", path));
                }
            }
            content.push_str("\n");
        }

        write_string(&lock_path, &content)?;
        Ok(())
    }

    fn create_tarball(&self, _manifest_path: &str) -> Result<Vec<u8>, PackageError> {
        // Create tarball of package
        Ok(Vec::new())
    }

    fn verify_package(&self, manifest: &Manifest) -> Result<(), PackageError> {
        // Verify package is ready for publishing
        if manifest.package.name.is_empty() {
            return Err(PackageError::InvalidManifest("Package name is required".to_string()));
        }

        if manifest.package.version == Version::new(0, 0, 0) {
            return Err(PackageError::InvalidManifest("Package version is required".to_string()));
        }

        Ok(())
    }
}

#[derive(Debug)]
pub enum PackageError {
    ManifestError(ManifestError),
    RegistryError(RegistryError),
    ResolveError(ResolveError),
    PackageNotFound(String),
    DependencyNotFound(String),
    InvalidManifest(String),
    IoError(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// CLI COMMANDS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn run_cli(args: Vec<String>) -> Result<(), PackageError> {
    let config = PackageManagerConfig::default();
    let mut pm = PackageManager::new(config);

    if args.len() < 2 {
        print_help();
        return Ok(());
    }

    match args[1].as_str() {
        "init" => {
            let name = args.get(2).map(|s| s.as_str()).unwrap_or("my-package");
            let path = args.get(3).map(|s| s.as_str()).unwrap_or(".");
            pm.init(name, path)?;
        }
        "add" => {
            let name = args.get(2).ok_or(PackageError::InvalidManifest("Package name required".to_string()))?;
            let version = args.get(3).map(|s| s.as_str());
            pm.add("quark.toml", name, version)?;
        }
        "remove" | "rm" => {
            let name = args.get(2).ok_or(PackageError::InvalidManifest("Package name required".to_string()))?;
            pm.remove("quark.toml", name)?;
        }
        "install" | "i" => {
            pm.install("quark.toml")?;
        }
        "update" | "up" => {
            let name = args.get(2).map(|s| s.as_str());
            pm.update("quark.toml", name)?;
        }
        "search" | "s" => {
            let query = args.get(2).ok_or(PackageError::InvalidManifest("Search query required".to_string()))?;
            pm.search(query)?;
        }
        "publish" => {
            pm.publish("quark.toml")?;
        }
        "help" | "--help" | "-h" => {
            print_help();
        }
        cmd => {
            println!("Unknown command: {}", cmd);
            print_help();
        }
    }

    Ok(())
}

fn print_help() {
    println!("╔═══════════════════════════════════════════════════════════════╗");
    println!("║  Quark - QUANTA-UNIVERSE Package Manager                      ║");
    println!("╚═══════════════════════════════════════════════════════════════╝");
    println!();
    println!("Usage: quark <command> [options]");
    println!();
    println!("Commands:");
    println!("  init <name> [path]    Create a new package");
    println!("  add <pkg> [version]   Add a dependency");
    println!("  remove <pkg>          Remove a dependency");
    println!("  install               Install all dependencies");
    println!("  update [pkg]          Update dependencies");
    println!("  search <query>        Search for packages");
    println!("  publish               Publish package to registry");
    println!("  help                  Show this help message");
    println!();
}

// ═══════════════════════════════════════════════════════════════════════════════
// PUBGRUB SAT-SOLVER FOR DEPENDENCY RESOLUTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Version set representing a range of acceptable versions
#[derive(Clone, Debug)]
pub struct VersionSet {
    ranges: Vec<VersionRange>,
}

#[derive(Clone, Debug)]
pub struct VersionRange {
    pub start: Option<Version>,
    pub end: Option<Version>,
    pub start_inclusive: bool,
    pub end_inclusive: bool,
}

impl VersionSet {
    pub fn any() -> Self {
        VersionSet {
            ranges: vec![VersionRange {
                start: None,
                end: None,
                start_inclusive: true,
                end_inclusive: true,
            }],
        }
    }

    pub fn none() -> Self {
        VersionSet { ranges: Vec::new() }
    }

    pub fn exact(version: Version) -> Self {
        VersionSet {
            ranges: vec![VersionRange {
                start: Some(version.clone()),
                end: Some(version),
                start_inclusive: true,
                end_inclusive: true,
            }],
        }
    }

    pub fn at_least(version: Version) -> Self {
        VersionSet {
            ranges: vec![VersionRange {
                start: Some(version),
                end: None,
                start_inclusive: true,
                end_inclusive: true,
            }],
        }
    }

    pub fn less_than(version: Version) -> Self {
        VersionSet {
            ranges: vec![VersionRange {
                start: None,
                end: Some(version),
                start_inclusive: true,
                end_inclusive: false,
            }],
        }
    }

    pub fn union(&self, other: &VersionSet) -> VersionSet {
        let mut ranges = self.ranges.clone();
        ranges.extend(other.ranges.clone());
        VersionSet::normalize(ranges)
    }

    pub fn intersection(&self, other: &VersionSet) -> VersionSet {
        let mut result = Vec::new();
        for r1 in &self.ranges {
            for r2 in &other.ranges {
                if let Some(intersection) = r1.intersect(r2) {
                    result.push(intersection);
                }
            }
        }
        VersionSet::normalize(result)
    }

    pub fn complement(&self) -> VersionSet {
        if self.ranges.is_empty() {
            return VersionSet::any();
        }

        let mut result = Vec::new();
        let mut last_end: Option<Version> = None;

        for range in &self.ranges {
            if let Some(start) = &range.start {
                if last_end.is_none() || &last_end.clone().unwrap() < start {
                    result.push(VersionRange {
                        start: last_end.clone(),
                        end: Some(start.clone()),
                        start_inclusive: last_end.is_none(),
                        end_inclusive: !range.start_inclusive,
                    });
                }
            }
            last_end = range.end.clone();
        }

        if last_end.is_some() {
            result.push(VersionRange {
                start: last_end,
                end: None,
                start_inclusive: false,
                end_inclusive: true,
            });
        }

        VersionSet { ranges: result }
    }

    pub fn contains(&self, version: &Version) -> bool {
        self.ranges.iter().any(|r| r.contains(version))
    }

    pub fn is_empty(&self) -> bool {
        self.ranges.is_empty()
    }

    fn normalize(mut ranges: Vec<VersionRange>) -> VersionSet {
        // Sort and merge overlapping ranges
        ranges.sort_by(|a, b| {
            match (&a.start, &b.start) {
                (None, None) => std::cmp::Ordering::Equal,
                (None, Some(_)) => std::cmp::Ordering::Less,
                (Some(_), None) => std::cmp::Ordering::Greater,
                (Some(a), Some(b)) => a.cmp(b),
            }
        });

        let mut merged = Vec::new();
        for range in ranges {
            if let Some(last) = merged.last_mut() {
                if last.overlaps_or_adjacent(&range) {
                    last.merge(&range);
                    continue;
                }
            }
            merged.push(range);
        }

        VersionSet { ranges: merged }
    }
}

impl VersionRange {
    pub fn contains(&self, version: &Version) -> bool {
        let start_ok = match &self.start {
            None => true,
            Some(s) => if self.start_inclusive { version >= s } else { version > s },
        };
        let end_ok = match &self.end {
            None => true,
            Some(e) => if self.end_inclusive { version <= e } else { version < e },
        };
        start_ok && end_ok
    }

    pub fn intersect(&self, other: &VersionRange) -> Option<VersionRange> {
        let (start, start_inclusive) = match (&self.start, &other.start) {
            (None, None) => (None, true),
            (Some(s), None) => (Some(s.clone()), self.start_inclusive),
            (None, Some(s)) => (Some(s.clone()), other.start_inclusive),
            (Some(s1), Some(s2)) => {
                if s1 > s2 {
                    (Some(s1.clone()), self.start_inclusive)
                } else if s2 > s1 {
                    (Some(s2.clone()), other.start_inclusive)
                } else {
                    (Some(s1.clone()), self.start_inclusive && other.start_inclusive)
                }
            }
        };

        let (end, end_inclusive) = match (&self.end, &other.end) {
            (None, None) => (None, true),
            (Some(e), None) => (Some(e.clone()), self.end_inclusive),
            (None, Some(e)) => (Some(e.clone()), other.end_inclusive),
            (Some(e1), Some(e2)) => {
                if e1 < e2 {
                    (Some(e1.clone()), self.end_inclusive)
                } else if e2 < e1 {
                    (Some(e2.clone()), other.end_inclusive)
                } else {
                    (Some(e1.clone()), self.end_inclusive && other.end_inclusive)
                }
            }
        };

        // Check if range is valid
        if let (Some(s), Some(e)) = (&start, &end) {
            if s > e || (s == e && !(start_inclusive && end_inclusive)) {
                return None;
            }
        }

        Some(VersionRange { start, end, start_inclusive, end_inclusive })
    }

    pub fn overlaps_or_adjacent(&self, other: &VersionRange) -> bool {
        // Check if ranges overlap or are adjacent
        self.intersect(other).is_some()
    }

    pub fn merge(&mut self, other: &VersionRange) {
        self.start = match (&self.start, &other.start) {
            (None, _) | (_, None) => None,
            (Some(s1), Some(s2)) => Some(if s1 < s2 { s1.clone() } else { s2.clone() }),
        };
        self.end = match (&self.end, &other.end) {
            (None, _) | (_, None) => None,
            (Some(e1), Some(e2)) => Some(if e1 > e2 { e1.clone() } else { e2.clone() }),
        };
    }
}

/// PubGrub incompatibility
#[derive(Clone, Debug)]
pub struct Incompatibility {
    terms: HashMap<String, Term>,
    cause: IncompatibilityCause,
}

#[derive(Clone, Debug)]
pub struct Term {
    package: String,
    positive: bool,
    version_set: VersionSet,
}

#[derive(Clone, Debug)]
pub enum IncompatibilityCause {
    Root,
    Dependency(String, Version),
    NoVersions(String),
    Conflict(Box<Incompatibility>, Box<Incompatibility>),
}

/// PubGrub partial solution
pub struct PartialSolution {
    assignments: Vec<Assignment>,
    decisions: HashMap<String, Version>,
    positive: HashMap<String, VersionSet>,
    negative: HashMap<String, VersionSet>,
}

#[derive(Clone)]
pub struct Assignment {
    package: String,
    version_set: VersionSet,
    is_decision: bool,
    decision_level: usize,
    cause: Option<Incompatibility>,
}

impl PartialSolution {
    pub fn new() -> Self {
        PartialSolution {
            assignments: Vec::new(),
            decisions: HashMap::new(),
            positive: HashMap::new(),
            negative: HashMap::new(),
        }
    }

    pub fn decide(&mut self, package: &str, version: Version) {
        let level = self.decision_level() + 1;
        self.decisions.insert(package.to_string(), version.clone());
        self.assignments.push(Assignment {
            package: package.to_string(),
            version_set: VersionSet::exact(version),
            is_decision: true,
            decision_level: level,
            cause: None,
        });
        self.positive.insert(package.to_string(), VersionSet::any());
    }

    pub fn derive(&mut self, package: &str, version_set: VersionSet, positive: bool, cause: Incompatibility) {
        let level = self.decision_level();
        self.assignments.push(Assignment {
            package: package.to_string(),
            version_set: version_set.clone(),
            is_decision: false,
            decision_level: level,
            cause: Some(cause),
        });

        if positive {
            let existing = self.positive.get(package).cloned().unwrap_or(VersionSet::any());
            self.positive.insert(package.to_string(), existing.intersection(&version_set));
        } else {
            let existing = self.negative.get(package).cloned().unwrap_or(VersionSet::none());
            self.negative.insert(package.to_string(), existing.union(&version_set));
        }
    }

    pub fn decision_level(&self) -> usize {
        self.decisions.len()
    }

    pub fn backtrack(&mut self, level: usize) {
        while let Some(assignment) = self.assignments.last() {
            if assignment.decision_level <= level {
                break;
            }
            let assignment = self.assignments.pop().unwrap();
            if assignment.is_decision {
                self.decisions.remove(&assignment.package);
            }
        }
        // Rebuild positive/negative maps
        self.positive.clear();
        self.negative.clear();
        for assignment in &self.assignments {
            if assignment.is_decision {
                self.positive.insert(assignment.package.clone(), assignment.version_set.clone());
            }
        }
    }

    pub fn satisfies(&self, incomp: &Incompatibility) -> bool {
        incomp.terms.iter().all(|(pkg, term)| {
            if term.positive {
                self.positive.get(pkg)
                    .map(|vs| !vs.intersection(&term.version_set).is_empty())
                    .unwrap_or(false)
            } else {
                self.negative.get(pkg)
                    .map(|vs| !vs.intersection(&term.version_set).is_empty())
                    .unwrap_or(true)
            }
        })
    }
}

/// Advanced PubGrub resolver
pub struct PubGrubResolver {
    registry: Registry,
    incompatibilities: Vec<Incompatibility>,
    solution: PartialSolution,
}

impl PubGrubResolver {
    pub fn new(registry: Registry) -> Self {
        PubGrubResolver {
            registry,
            incompatibilities: Vec::new(),
            solution: PartialSolution::new(),
        }
    }

    /// Resolve dependencies using PubGrub algorithm
    pub fn resolve(&mut self, root_package: &str, root_deps: &HashMap<String, VersionReq>) -> Result<Resolution, ResolveError> {
        println!("Resolving with PubGrub SAT-solver...");

        // Add root incompatibility
        self.add_root_incompatibility(root_package);

        // Add root dependencies
        for (name, req) in root_deps {
            self.add_dependency(root_package, name, req)?;
        }

        // Main solving loop
        loop {
            // Check for conflicts
            if let Some(incomp) = self.find_conflict() {
                let (new_incomp, package) = self.resolve_conflict(&incomp)?;
                self.incompatibilities.push(new_incomp);

                // Continue with the conflicting package
                if let Some(pkg) = package {
                    continue;
                }
            }

            // Find next undecided package
            if let Some((package, version)) = self.choose_next() {
                println!("  Selected {} v{}", package, version);
                self.solution.decide(&package, version.clone());

                // Add dependencies for chosen version
                let versions = self.registry.get_versions(&package)?;
                if let Some(pkg_ver) = versions.iter().find(|v| v.version == version) {
                    for (dep_name, dep_req) in &pkg_ver.dependencies {
                        self.add_dependency(&package, dep_name, dep_req)?;
                    }
                }
            } else {
                // All packages decided
                break;
            }
        }

        // Build resolution from solution
        let mut packages = Vec::new();
        for (name, version) in &self.solution.decisions {
            if name != root_package {
                packages.push(ResolvedPackage {
                    name: name.clone(),
                    version: version.clone(),
                    source: PackageSource::Registry(self.registry.url.clone()),
                    dependencies: Vec::new(),
                    features: HashSet::new(),
                });
            }
        }

        Ok(Resolution {
            packages,
            features: HashMap::new(),
        })
    }

    fn add_root_incompatibility(&mut self, root_package: &str) {
        let mut terms = HashMap::new();
        terms.insert(root_package.to_string(), Term {
            package: root_package.to_string(),
            positive: false,
            version_set: VersionSet::any(),
        });
        self.incompatibilities.push(Incompatibility {
            terms,
            cause: IncompatibilityCause::Root,
        });
    }

    fn add_dependency(&mut self, from: &str, to: &str, req: &VersionReq) -> Result<(), ResolveError> {
        let version_set = self.version_req_to_set(req);

        let mut terms = HashMap::new();
        terms.insert(from.to_string(), Term {
            package: from.to_string(),
            positive: true,
            version_set: VersionSet::any(),
        });
        terms.insert(to.to_string(), Term {
            package: to.to_string(),
            positive: false,
            version_set: version_set.complement(),
        });

        self.incompatibilities.push(Incompatibility {
            terms,
            cause: IncompatibilityCause::Dependency(from.to_string(), Version::new(0, 0, 0)),
        });

        Ok(())
    }

    fn version_req_to_set(&self, req: &VersionReq) -> VersionSet {
        // Convert VersionReq to VersionSet
        // This is a simplified implementation
        VersionSet::any()
    }

    fn find_conflict(&self) -> Option<Incompatibility> {
        for incomp in &self.incompatibilities {
            if self.solution.satisfies(incomp) {
                return Some(incomp.clone());
            }
        }
        None
    }

    fn resolve_conflict(&mut self, incomp: &Incompatibility) -> Result<(Incompatibility, Option<String>), ResolveError> {
        // Conflict resolution using PubGrub algorithm
        let mut current = incomp.clone();

        loop {
            // Find satisfier with highest decision level
            let mut satisfier: Option<&Assignment> = None;
            let mut satisfier_package: Option<String> = None;

            for (pkg, _term) in &current.terms {
                for assignment in self.solution.assignments.iter().rev() {
                    if &assignment.package == pkg {
                        if satisfier.is_none() || assignment.decision_level > satisfier.unwrap().decision_level {
                            satisfier = Some(assignment);
                            satisfier_package = Some(pkg.clone());
                        }
                        break;
                    }
                }
            }

            let satisfier = satisfier.ok_or(ResolveError::CyclicDependency(Vec::new()))?;

            if satisfier.is_decision {
                // Backtrack to before this decision
                let level = satisfier.decision_level - 1;
                self.solution.backtrack(level);
                return Ok((current, satisfier_package));
            }

            // Combine with cause
            if let Some(cause) = &satisfier.cause {
                let new_terms = self.combine_terms(&current, cause);
                current = Incompatibility {
                    terms: new_terms,
                    cause: IncompatibilityCause::Conflict(
                        Box::new(current.clone()),
                        Box::new(cause.clone()),
                    ),
                };
            } else {
                return Err(ResolveError::CyclicDependency(Vec::new()));
            }
        }
    }

    fn combine_terms(&self, a: &Incompatibility, b: &Incompatibility) -> HashMap<String, Term> {
        let mut combined = a.terms.clone();
        for (pkg, term) in &b.terms {
            combined.insert(pkg.clone(), term.clone());
        }
        combined
    }

    fn choose_next(&self) -> Option<(String, Version)> {
        // Find next undecided package that has positive assignments
        for (pkg, version_set) in &self.solution.positive {
            if !self.solution.decisions.contains_key(pkg) {
                // Get available versions
                if let Ok(versions) = self.registry.get_versions(pkg) {
                    // Choose best version that matches constraints
                    let matching: Vec<_> = versions.iter()
                        .filter(|v| !v.yanked && version_set.contains(&v.version))
                        .collect();

                    if let Some(best) = matching.iter().map(|v| &v.version).max() {
                        return Some((pkg.clone(), best.clone()));
                    }
                }
            }
        }
        None
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Workspace for managing multiple packages (monorepo support)
#[derive(Clone, Debug)]
pub struct Workspace {
    pub root: String,
    pub members: Vec<WorkspaceMember>,
    pub default_members: Vec<String>,
    pub exclude: Vec<String>,
    pub resolver: String,
    pub metadata: HashMap<String, String>,
}

#[derive(Clone, Debug)]
pub struct WorkspaceMember {
    pub path: String,
    pub manifest: Manifest,
    pub dependencies_to_other_members: Vec<String>,
}

#[derive(Clone, Debug)]
pub struct WorkspaceConfig {
    pub members: Vec<String>,
    pub default_members: Option<Vec<String>>,
    pub exclude: Vec<String>,
    pub resolver: Option<String>,
    pub dependencies: HashMap<String, Dependency>,
}

impl Workspace {
    /// Load workspace from root directory
    pub fn load(root: &str) -> Result<Self, WorkspaceError> {
        let manifest_path = format!("{}/quark.toml", root);
        let content = read_to_string(&manifest_path)?;

        // Parse workspace section
        let config = Self::parse_workspace_config(&content)?;

        let mut members = Vec::new();

        // Expand glob patterns and load member manifests
        for pattern in &config.members {
            let paths = Self::expand_glob(root, pattern);
            for path in paths {
                if config.exclude.contains(&path) {
                    continue;
                }

                let member_manifest_path = format!("{}/{}/quark.toml", root, path);
                if exists(&member_manifest_path) {
                    let manifest = Manifest::load(&member_manifest_path)?;
                    members.push(WorkspaceMember {
                        path: path.clone(),
                        manifest,
                        dependencies_to_other_members: Vec::new(),
                    });
                }
            }
        }

        // Resolve inter-member dependencies
        let member_names: Vec<String> = members.iter()
            .map(|m| m.manifest.package.name.clone())
            .collect();

        for member in &mut members {
            for (dep_name, _) in &member.manifest.dependencies {
                if member_names.contains(dep_name) {
                    member.dependencies_to_other_members.push(dep_name.clone());
                }
            }
        }

        Ok(Workspace {
            root: root.to_string(),
            members,
            default_members: config.default_members.unwrap_or_default(),
            exclude: config.exclude,
            resolver: config.resolver.unwrap_or("2".to_string()),
            metadata: HashMap::new(),
        })
    }

    /// Get topological build order for workspace members
    pub fn build_order(&self) -> Result<Vec<&WorkspaceMember>, WorkspaceError> {
        let mut order = Vec::new();
        let mut visited = HashSet::new();
        let mut in_stack = HashSet::new();

        for member in &self.members {
            self.visit_member(member, &mut order, &mut visited, &mut in_stack)?;
        }

        Ok(order)
    }

    fn visit_member<'a>(
        &'a self,
        member: &'a WorkspaceMember,
        order: &mut Vec<&'a WorkspaceMember>,
        visited: &mut HashSet<String>,
        in_stack: &mut HashSet<String>,
    ) -> Result<(), WorkspaceError> {
        let name = &member.manifest.package.name;

        if in_stack.contains(name) {
            return Err(WorkspaceError::CyclicDependency(name.clone()));
        }

        if visited.contains(name) {
            return Ok(());
        }

        in_stack.insert(name.clone());

        // Visit dependencies first
        for dep_name in &member.dependencies_to_other_members {
            if let Some(dep_member) = self.members.iter().find(|m| &m.manifest.package.name == dep_name) {
                self.visit_member(dep_member, order, visited, in_stack)?;
            }
        }

        in_stack.remove(name);
        visited.insert(name.clone());
        order.push(member);

        Ok(())
    }

    /// Run command for all workspace members
    pub fn for_each<F>(&self, f: F) -> Result<(), WorkspaceError>
    where F: Fn(&WorkspaceMember) -> Result<(), PackageError>
    {
        for member in self.build_order()? {
            println!("Processing {}...", member.manifest.package.name);
            f(member).map_err(|e| WorkspaceError::MemberError(member.path.clone(), e))?;
        }
        Ok(())
    }

    /// Get all dependencies across workspace
    pub fn all_dependencies(&self) -> HashMap<String, Dependency> {
        let mut deps = HashMap::new();
        for member in &self.members {
            for (name, dep) in &member.manifest.dependencies {
                // Only include external dependencies
                if !self.members.iter().any(|m| &m.manifest.package.name == name) {
                    deps.insert(name.clone(), dep.clone());
                }
            }
        }
        deps
    }

    fn parse_workspace_config(content: &str) -> Result<WorkspaceConfig, WorkspaceError> {
        // Parse [workspace] section from TOML
        let mut config = WorkspaceConfig {
            members: Vec::new(),
            default_members: None,
            exclude: Vec::new(),
            resolver: None,
            dependencies: HashMap::new(),
        };

        let mut in_workspace = false;
        for line in content.lines() {
            let line = line.trim();
            if line == "[workspace]" {
                in_workspace = true;
                continue;
            }
            if line.starts_with('[') && in_workspace {
                in_workspace = false;
            }
            if in_workspace {
                if line.starts_with("members = ") {
                    // Parse array
                    let array_str = line.strip_prefix("members = ").unwrap();
                    config.members = parse_string_array(array_str);
                }
                if line.starts_with("resolver = ") {
                    config.resolver = Some(parse_string_value(line));
                }
            }
        }

        Ok(config)
    }

    fn expand_glob(root: &str, pattern: &str) -> Vec<String> {
        // Expand glob pattern to matching paths
        // Simplified implementation
        vec![pattern.replace("/*", "").to_string()]
    }
}

fn parse_string_array(s: &str) -> Vec<String> {
    s.trim_matches(|c| c == '[' || c == ']')
        .split(',')
        .map(|s| s.trim().trim_matches('"').to_string())
        .filter(|s| !s.is_empty())
        .collect()
}

#[derive(Debug)]
pub enum WorkspaceError {
    IoError(String),
    ManifestError(ManifestError),
    CyclicDependency(String),
    MemberError(String, PackageError),
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECURITY AUDITING
// ═══════════════════════════════════════════════════════════════════════════════

/// Security auditing for packages
pub struct SecurityAuditor {
    advisory_db: AdvisoryDatabase,
    config: AuditConfig,
}

#[derive(Clone)]
pub struct AuditConfig {
    pub database_url: String,
    pub ignore_advisories: Vec<String>,
    pub severity_threshold: Severity,
    pub check_yanked: bool,
}

impl Default for AuditConfig {
    fn default() -> Self {
        AuditConfig {
            database_url: "https://advisories.quanta-universe.dev".to_string(),
            ignore_advisories: Vec::new(),
            severity_threshold: Severity::Low,
            check_yanked: true,
        }
    }
}

pub struct AdvisoryDatabase {
    advisories: HashMap<String, Vec<Advisory>>,
    last_updated: u64,
}

#[derive(Clone, Debug)]
pub struct Advisory {
    pub id: String,
    pub package: String,
    pub title: String,
    pub description: String,
    pub severity: Severity,
    pub affected_versions: VersionSet,
    pub patched_versions: Option<VersionSet>,
    pub cve: Option<String>,
    pub url: Option<String>,
    pub published_date: String,
}

#[derive(Clone, Debug, PartialEq, PartialOrd)]
pub enum Severity {
    None,
    Low,
    Medium,
    High,
    Critical,
}

#[derive(Clone, Debug)]
pub struct AuditReport {
    pub vulnerabilities: Vec<VulnerabilityFinding>,
    pub warnings: Vec<AuditWarning>,
    pub statistics: AuditStatistics,
}

#[derive(Clone, Debug)]
pub struct VulnerabilityFinding {
    pub advisory: Advisory,
    pub package: String,
    pub version: Version,
    pub dependency_chain: Vec<String>,
}

#[derive(Clone, Debug)]
pub struct AuditWarning {
    pub kind: WarningKind,
    pub message: String,
    pub package: Option<String>,
}

#[derive(Clone, Debug)]
pub enum WarningKind {
    YankedPackage,
    UnmaintainedPackage,
    DeprecatedPackage,
    UnsafeDependency,
    LicenseIssue,
}

#[derive(Clone, Debug)]
pub struct AuditStatistics {
    pub packages_scanned: usize,
    pub vulnerabilities_found: usize,
    pub critical_count: usize,
    pub high_count: usize,
    pub medium_count: usize,
    pub low_count: usize,
}

impl SecurityAuditor {
    pub fn new(config: AuditConfig) -> Self {
        SecurityAuditor {
            advisory_db: AdvisoryDatabase {
                advisories: HashMap::new(),
                last_updated: 0,
            },
            config,
        }
    }

    /// Update advisory database
    pub fn update_database(&mut self) -> Result<(), AuditError> {
        println!("Updating security advisory database...");

        let client = HttpClient::new();
        let response = client.get(&format!("{}/advisories.json", self.config.database_url))?;

        self.advisory_db = self.parse_advisories(&response.body)?;
        self.advisory_db.last_updated = current_timestamp();

        println!("  Database updated: {} advisories loaded",
            self.advisory_db.advisories.values().map(|v| v.len()).sum::<usize>());

        Ok(())
    }

    /// Audit resolved packages for vulnerabilities
    pub fn audit(&self, resolution: &Resolution) -> Result<AuditReport, AuditError> {
        println!("Auditing {} packages for security vulnerabilities...", resolution.packages.len());

        let mut vulnerabilities = Vec::new();
        let mut warnings = Vec::new();

        for pkg in &resolution.packages {
            // Check for advisories
            if let Some(advisories) = self.advisory_db.advisories.get(&pkg.name) {
                for advisory in advisories {
                    if advisory.affected_versions.contains(&pkg.version) {
                        if self.config.ignore_advisories.contains(&advisory.id) {
                            continue;
                        }
                        if advisory.severity >= self.config.severity_threshold {
                            vulnerabilities.push(VulnerabilityFinding {
                                advisory: advisory.clone(),
                                package: pkg.name.clone(),
                                version: pkg.version.clone(),
                                dependency_chain: self.build_dependency_chain(&pkg.name, resolution),
                            });
                        }
                    }
                }
            }

            // Check for yanked packages
            if self.config.check_yanked {
                // Would check registry for yanked status
            }
        }

        let statistics = AuditStatistics {
            packages_scanned: resolution.packages.len(),
            vulnerabilities_found: vulnerabilities.len(),
            critical_count: vulnerabilities.iter().filter(|v| v.advisory.severity == Severity::Critical).count(),
            high_count: vulnerabilities.iter().filter(|v| v.advisory.severity == Severity::High).count(),
            medium_count: vulnerabilities.iter().filter(|v| v.advisory.severity == Severity::Medium).count(),
            low_count: vulnerabilities.iter().filter(|v| v.advisory.severity == Severity::Low).count(),
        };

        Ok(AuditReport {
            vulnerabilities,
            warnings,
            statistics,
        })
    }

    /// Print audit report
    pub fn print_report(&self, report: &AuditReport) {
        println!();
        println!("╔════════════════════════════════════════════════════════════════╗");
        println!("║  Security Audit Report                                         ║");
        println!("╚════════════════════════════════════════════════════════════════╝");
        println!();
        println!("Packages scanned: {}", report.statistics.packages_scanned);
        println!("Vulnerabilities found: {}", report.statistics.vulnerabilities_found);
        println!();

        if report.vulnerabilities.is_empty() {
            println!("  ✓ No known vulnerabilities found");
        } else {
            println!("  Breakdown by severity:");
            println!("    Critical: {}", report.statistics.critical_count);
            println!("    High: {}", report.statistics.high_count);
            println!("    Medium: {}", report.statistics.medium_count);
            println!("    Low: {}", report.statistics.low_count);
            println!();

            for vuln in &report.vulnerabilities {
                let severity_icon = match vuln.advisory.severity {
                    Severity::Critical => "🔴",
                    Severity::High => "🟠",
                    Severity::Medium => "🟡",
                    Severity::Low => "🟢",
                    Severity::None => "⚪",
                };

                println!("{} {} - {} v{}", severity_icon, vuln.advisory.id, vuln.package, vuln.version);
                println!("    {}", vuln.advisory.title);
                if let Some(cve) = &vuln.advisory.cve {
                    println!("    CVE: {}", cve);
                }
                if !vuln.dependency_chain.is_empty() {
                    println!("    Dependency chain: {}", vuln.dependency_chain.join(" -> "));
                }
                if let Some(ref patched) = vuln.advisory.patched_versions {
                    println!("    Patched in: newer versions available");
                }
                println!();
            }
        }

        for warning in &report.warnings {
            println!("  ⚠ Warning: {}", warning.message);
        }
    }

    fn parse_advisories(&self, _body: &[u8]) -> Result<AdvisoryDatabase, AuditError> {
        // Parse JSON advisory database
        Ok(AdvisoryDatabase {
            advisories: HashMap::new(),
            last_updated: current_timestamp(),
        })
    }

    fn build_dependency_chain(&self, package: &str, resolution: &Resolution) -> Vec<String> {
        // Build reverse dependency chain
        let mut chain = Vec::new();
        // Implementation would walk the dependency graph backwards
        chain
    }
}

fn current_timestamp() -> u64 {
    0 // Would use actual time
}

#[derive(Debug)]
pub enum AuditError {
    NetworkError(String),
    ParseError(String),
    DatabaseError(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// LICENSE COMPLIANCE
// ═══════════════════════════════════════════════════════════════════════════════

/// License compliance checker
pub struct LicenseChecker {
    config: LicenseConfig,
}

#[derive(Clone)]
pub struct LicenseConfig {
    pub allowed_licenses: Vec<String>,
    pub denied_licenses: Vec<String>,
    pub copyleft_allowed: bool,
    pub allow_unknown: bool,
}

impl Default for LicenseConfig {
    fn default() -> Self {
        LicenseConfig {
            allowed_licenses: vec![
                "MIT".to_string(),
                "Apache-2.0".to_string(),
                "BSD-2-Clause".to_string(),
                "BSD-3-Clause".to_string(),
                "ISC".to_string(),
                "Zlib".to_string(),
                "Unlicense".to_string(),
            ],
            denied_licenses: Vec::new(),
            copyleft_allowed: true,
            allow_unknown: false,
        }
    }
}

#[derive(Clone, Debug)]
pub struct LicenseReport {
    pub packages: Vec<PackageLicense>,
    pub issues: Vec<LicenseIssue>,
    pub summary: LicenseSummary,
}

#[derive(Clone, Debug)]
pub struct PackageLicense {
    pub package: String,
    pub version: Version,
    pub license: Option<String>,
    pub license_file: Option<String>,
}

#[derive(Clone, Debug)]
pub struct LicenseIssue {
    pub package: String,
    pub issue: LicenseIssueKind,
    pub license: Option<String>,
}

#[derive(Clone, Debug)]
pub enum LicenseIssueKind {
    UnknownLicense,
    DeniedLicense,
    CopyleftLicense,
    IncompatibleLicenses,
}

#[derive(Clone, Debug)]
pub struct LicenseSummary {
    pub total_packages: usize,
    pub license_counts: HashMap<String, usize>,
    pub unknown_count: usize,
    pub issue_count: usize,
}

impl LicenseChecker {
    pub fn new(config: LicenseConfig) -> Self {
        LicenseChecker { config }
    }

    /// Check licenses for all resolved packages
    pub fn check(&self, resolution: &Resolution, registry: &Registry) -> Result<LicenseReport, PackageError> {
        println!("Checking licenses for {} packages...", resolution.packages.len());

        let mut packages = Vec::new();
        let mut issues = Vec::new();
        let mut license_counts = HashMap::new();
        let mut unknown_count = 0;

        for pkg in &resolution.packages {
            let info = registry.get_package(&pkg.name)?;
            let license = info.license.clone();

            packages.push(PackageLicense {
                package: pkg.name.clone(),
                version: pkg.version.clone(),
                license: license.clone(),
                license_file: None,
            });

            if let Some(ref lic) = license {
                *license_counts.entry(lic.clone()).or_insert(0) += 1;

                // Check against denied list
                if self.config.denied_licenses.contains(lic) {
                    issues.push(LicenseIssue {
                        package: pkg.name.clone(),
                        issue: LicenseIssueKind::DeniedLicense,
                        license: license.clone(),
                    });
                }

                // Check copyleft
                if !self.config.copyleft_allowed && self.is_copyleft(lic) {
                    issues.push(LicenseIssue {
                        package: pkg.name.clone(),
                        issue: LicenseIssueKind::CopyleftLicense,
                        license: license.clone(),
                    });
                }
            } else {
                unknown_count += 1;
                if !self.config.allow_unknown {
                    issues.push(LicenseIssue {
                        package: pkg.name.clone(),
                        issue: LicenseIssueKind::UnknownLicense,
                        license: None,
                    });
                }
            }
        }

        Ok(LicenseReport {
            packages,
            issues: issues.clone(),
            summary: LicenseSummary {
                total_packages: resolution.packages.len(),
                license_counts,
                unknown_count,
                issue_count: issues.len(),
            },
        })
    }

    fn is_copyleft(&self, license: &str) -> bool {
        matches!(license, "GPL-2.0" | "GPL-3.0" | "LGPL-2.1" | "LGPL-3.0" | "AGPL-3.0" | "MPL-2.0")
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE LINKING (LOCAL DEVELOPMENT)
// ═══════════════════════════════════════════════════════════════════════════════

/// Package linking for local development
pub struct PackageLinker {
    links: HashMap<String, String>,
    global_links_dir: String,
}

impl PackageLinker {
    pub fn new(global_links_dir: &str) -> Self {
        PackageLinker {
            links: HashMap::new(),
            global_links_dir: global_links_dir.to_string(),
        }
    }

    /// Create a global link for a package
    pub fn link(&mut self, manifest_path: &str) -> Result<(), PackageError> {
        let manifest = Manifest::load(manifest_path)?;
        let package_name = &manifest.package.name;
        let package_dir = manifest_path.trim_end_matches("/quark.toml");

        // Create symlink in global links directory
        let link_path = format!("{}/{}", self.global_links_dir, package_name);
        create_dir_all(&self.global_links_dir)?;

        // Create symlink (platform-specific)
        self.create_symlink(package_dir, &link_path)?;

        self.links.insert(package_name.clone(), package_dir.to_string());

        println!("Linked {} -> {}", package_name, package_dir);
        Ok(())
    }

    /// Use a linked package in current project
    pub fn link_to(&self, package_name: &str, target_dir: &str) -> Result<(), PackageError> {
        let link_source = format!("{}/{}", self.global_links_dir, package_name);

        if !exists(&link_source) {
            return Err(PackageError::PackageNotFound(package_name.to_string()));
        }

        let link_target = format!("{}/quark_modules/{}", target_dir, package_name);
        create_dir_all(&format!("{}/quark_modules", target_dir))?;

        self.create_symlink(&link_source, &link_target)?;

        println!("Linked {} in project", package_name);
        Ok(())
    }

    /// Remove a global link
    pub fn unlink(&mut self, package_name: &str) -> Result<(), PackageError> {
        let link_path = format!("{}/{}", self.global_links_dir, package_name);

        if exists(&link_path) {
            remove_dir_all(&link_path)?;
            self.links.remove(package_name);
            println!("Unlinked {}", package_name);
        }

        Ok(())
    }

    /// List all global links
    pub fn list(&self) -> Vec<(String, String)> {
        self.links.iter()
            .map(|(k, v)| (k.clone(), v.clone()))
            .collect()
    }

    fn create_symlink(&self, source: &str, target: &str) -> Result<(), PackageError> {
        // Platform-specific symlink creation
        #[cfg(unix)]
        {
            std::os::unix::fs::symlink(source, target)
                .map_err(|e| PackageError::IoError(e.to_string()))?;
        }
        #[cfg(windows)]
        {
            std::os::windows::fs::symlink_dir(source, target)
                .map_err(|e| PackageError::IoError(e.to_string()))?;
        }
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPENDENCY TREE VISUALIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Dependency tree visualizer
pub struct DependencyTree {
    resolution: Resolution,
    duplicates: HashMap<String, Vec<Version>>,
}

impl DependencyTree {
    pub fn new(resolution: Resolution) -> Self {
        let mut duplicates = HashMap::new();

        // Find packages with multiple versions
        let mut versions: HashMap<String, Vec<Version>> = HashMap::new();
        for pkg in &resolution.packages {
            versions.entry(pkg.name.clone())
                .or_default()
                .push(pkg.version.clone());
        }

        for (name, vers) in versions {
            if vers.len() > 1 {
                duplicates.insert(name, vers);
            }
        }

        DependencyTree { resolution, duplicates }
    }

    /// Print ASCII tree
    pub fn print(&self, root: &str) {
        println!("{}", root);
        self.print_deps(root, "", true);
    }

    fn print_deps(&self, package: &str, prefix: &str, is_last: bool) {
        if let Some(pkg) = self.resolution.packages.iter().find(|p| p.name == package) {
            for (i, dep) in pkg.dependencies.iter().enumerate() {
                let is_last_dep = i == pkg.dependencies.len() - 1;
                let connector = if is_last_dep { "└── " } else { "├── " };
                let new_prefix = if is_last_dep { "    " } else { "│   " };

                if let Some(dep_pkg) = self.resolution.packages.iter().find(|p| &p.name == dep) {
                    let dup_marker = if self.duplicates.contains_key(&dep_pkg.name) {
                        " (*)"
                    } else {
                        ""
                    };
                    println!("{}{}{} v{}{}", prefix, connector, dep_pkg.name, dep_pkg.version, dup_marker);
                    self.print_deps(dep, &format!("{}{}", prefix, new_prefix), is_last_dep);
                }
            }
        }
    }

    /// Print inverted tree (show what depends on a package)
    pub fn print_inverted(&self, package: &str) {
        println!("{}", package);
        println!("Depended on by:");

        for pkg in &self.resolution.packages {
            if pkg.dependencies.contains(&package.to_string()) {
                println!("  └── {} v{}", pkg.name, pkg.version);
            }
        }
    }

    /// Get statistics
    pub fn statistics(&self) -> TreeStatistics {
        let total = self.resolution.packages.len();
        let duplicates = self.duplicates.len();
        let max_depth = self.calculate_max_depth();

        TreeStatistics {
            total_packages: total,
            duplicate_packages: duplicates,
            max_depth,
        }
    }

    fn calculate_max_depth(&self) -> usize {
        // BFS to find max depth
        0 // Simplified
    }
}

#[derive(Clone, Debug)]
pub struct TreeStatistics {
    pub total_packages: usize,
    pub duplicate_packages: usize,
    pub max_depth: usize,
}

