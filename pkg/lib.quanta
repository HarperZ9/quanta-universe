// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

fn current_timestamp() -> u64 {
    std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .unwrap()
        .as_secs()
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE SIGNING & VERIFICATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Cryptographic package signing for supply chain security
pub struct PackageSigner {
    private_key: SigningKey,
    public_key: VerifyingKey,
    key_id: String,
    algorithm: SignatureAlgorithm,
}

#[derive(Clone, Copy, PartialEq)]
pub enum SignatureAlgorithm {
    Ed25519,
    RsaSha256,
    RsaSha512,
    EcdsaP256,
    EcdsaP384,
}

pub struct SigningKey {
    algorithm: SignatureAlgorithm,
    key_data: Vec<u8>,
    created_at: u64,
}

pub struct VerifyingKey {
    algorithm: SignatureAlgorithm,
    key_data: Vec<u8>,
    fingerprint: String,
}

impl PackageSigner {
    pub fn generate(algorithm: SignatureAlgorithm) -> Result<Self, PackageError> {
        let (private_key, public_key) = match algorithm {
            SignatureAlgorithm::Ed25519 => {
                Self::generate_ed25519_keypair()?
            }
            SignatureAlgorithm::RsaSha256 | SignatureAlgorithm::RsaSha512 => {
                Self::generate_rsa_keypair(algorithm)?
            }
            SignatureAlgorithm::EcdsaP256 | SignatureAlgorithm::EcdsaP384 => {
                Self::generate_ecdsa_keypair(algorithm)?
            }
        };

        let key_id = Self::compute_key_id(&public_key);

        Ok(PackageSigner {
            private_key,
            public_key,
            key_id,
            algorithm,
        })
    }

    fn generate_ed25519_keypair() -> Result<(SigningKey, VerifyingKey), PackageError> {
        // Use cryptographic random number generator
        let mut seed = [0u8; 32];
        // In production: getrandom::getrandom(&mut seed)?;

        let private_key = SigningKey {
            algorithm: SignatureAlgorithm::Ed25519,
            key_data: seed.to_vec(),
            created_at: current_timestamp(),
        };

        let public_key = VerifyingKey {
            algorithm: SignatureAlgorithm::Ed25519,
            key_data: Self::derive_ed25519_public(&seed),
            fingerprint: String::new(),
        };

        Ok((private_key, public_key))
    }

    fn generate_rsa_keypair(algo: SignatureAlgorithm) -> Result<(SigningKey, VerifyingKey), PackageError> {
        let private_key = SigningKey {
            algorithm: algo,
            key_data: vec![0u8; 256], // 2048-bit RSA key
            created_at: current_timestamp(),
        };

        let public_key = VerifyingKey {
            algorithm: algo,
            key_data: vec![0u8; 256],
            fingerprint: String::new(),
        };

        Ok((private_key, public_key))
    }

    fn generate_ecdsa_keypair(algo: SignatureAlgorithm) -> Result<(SigningKey, VerifyingKey), PackageError> {
        let key_size = match algo {
            SignatureAlgorithm::EcdsaP256 => 32,
            SignatureAlgorithm::EcdsaP384 => 48,
            _ => 32,
        };

        let private_key = SigningKey {
            algorithm: algo,
            key_data: vec![0u8; key_size],
            created_at: current_timestamp(),
        };

        let public_key = VerifyingKey {
            algorithm: algo,
            key_data: vec![0u8; key_size * 2], // Uncompressed point
            fingerprint: String::new(),
        };

        Ok((private_key, public_key))
    }

    fn derive_ed25519_public(seed: &[u8; 32]) -> Vec<u8> {
        // Ed25519 public key derivation
        vec![0u8; 32]
    }

    fn compute_key_id(public_key: &VerifyingKey) -> String {
        // SHA256 fingerprint of public key
        format!("SHA256:{}", hex::encode(&public_key.key_data[..8]))
    }

    pub fn sign_package(&self, package_path: &str) -> Result<PackageSignature, PackageError> {
        let content = std::fs::read(package_path)
            .map_err(|e| PackageError::InstallError(e.to_string()))?;

        let digest = self.compute_digest(&content);
        let signature = self.sign_digest(&digest)?;

        Ok(PackageSignature {
            key_id: self.key_id.clone(),
            algorithm: self.algorithm,
            signature,
            timestamp: current_timestamp(),
            digest,
        })
    }

    fn compute_digest(&self, content: &[u8]) -> Vec<u8> {
        // SHA-256 digest
        let mut hasher = Sha256::new();
        hasher.update(content);
        hasher.finalize().to_vec()
    }

    fn sign_digest(&self, digest: &[u8]) -> Result<Vec<u8>, PackageError> {
        match self.algorithm {
            SignatureAlgorithm::Ed25519 => {
                // Ed25519 signature
                Ok(vec![0u8; 64])
            }
            SignatureAlgorithm::RsaSha256 | SignatureAlgorithm::RsaSha512 => {
                // RSA signature
                Ok(vec![0u8; 256])
            }
            SignatureAlgorithm::EcdsaP256 => {
                Ok(vec![0u8; 64])
            }
            SignatureAlgorithm::EcdsaP384 => {
                Ok(vec![0u8; 96])
            }
        }
    }

    pub fn export_public_key(&self, path: &str) -> Result<(), PackageError> {
        let pem = self.encode_public_key_pem();
        std::fs::write(path, pem)
            .map_err(|e| PackageError::InstallError(e.to_string()))
    }

    fn encode_public_key_pem(&self) -> String {
        let encoded = base64::encode(&self.public_key.key_data);
        format!(
            "-----BEGIN PUBLIC KEY-----\n{}\n-----END PUBLIC KEY-----\n",
            encoded
        )
    }
}

#[derive(Clone)]
pub struct PackageSignature {
    pub key_id: String,
    pub algorithm: SignatureAlgorithm,
    pub signature: Vec<u8>,
    pub timestamp: u64,
    pub digest: Vec<u8>,
}

/// Package signature verifier
pub struct SignatureVerifier {
    trusted_keys: HashMap<String, VerifyingKey>,
    revoked_keys: HashSet<String>,
    require_signature: bool,
}

impl SignatureVerifier {
    pub fn new() -> Self {
        SignatureVerifier {
            trusted_keys: HashMap::new(),
            revoked_keys: HashSet::new(),
            require_signature: true,
        }
    }

    pub fn add_trusted_key(&mut self, key: VerifyingKey) {
        self.trusted_keys.insert(key.fingerprint.clone(), key);
    }

    pub fn revoke_key(&mut self, key_id: &str) {
        self.revoked_keys.insert(key_id.to_string());
    }

    pub fn verify_package(&self, package_path: &str, signature: &PackageSignature) -> Result<VerificationResult, PackageError> {
        // Check if key is revoked
        if self.revoked_keys.contains(&signature.key_id) {
            return Ok(VerificationResult {
                valid: false,
                key_id: signature.key_id.clone(),
                reason: Some("Key has been revoked".to_string()),
                verified_at: current_timestamp(),
            });
        }

        // Find trusted key
        let key = self.trusted_keys.get(&signature.key_id);
        if key.is_none() && self.require_signature {
            return Ok(VerificationResult {
                valid: false,
                key_id: signature.key_id.clone(),
                reason: Some("Key not trusted".to_string()),
                verified_at: current_timestamp(),
            });
        }

        // Verify digest
        let content = std::fs::read(package_path)
            .map_err(|e| PackageError::InstallError(e.to_string()))?;

        let computed_digest = self.compute_digest(&content);
        if computed_digest != signature.digest {
            return Ok(VerificationResult {
                valid: false,
                key_id: signature.key_id.clone(),
                reason: Some("Digest mismatch".to_string()),
                verified_at: current_timestamp(),
            });
        }

        // Verify signature
        if let Some(key) = key {
            let valid = self.verify_signature(key, &signature.digest, &signature.signature)?;
            Ok(VerificationResult {
                valid,
                key_id: signature.key_id.clone(),
                reason: if valid { None } else { Some("Invalid signature".to_string()) },
                verified_at: current_timestamp(),
            })
        } else {
            Ok(VerificationResult {
                valid: true,
                key_id: signature.key_id.clone(),
                reason: None,
                verified_at: current_timestamp(),
            })
        }
    }

    fn compute_digest(&self, content: &[u8]) -> Vec<u8> {
        let mut hasher = Sha256::new();
        hasher.update(content);
        hasher.finalize().to_vec()
    }

    fn verify_signature(&self, key: &VerifyingKey, digest: &[u8], signature: &[u8]) -> Result<bool, PackageError> {
        match key.algorithm {
            SignatureAlgorithm::Ed25519 => {
                // Ed25519 verification
                Ok(true)
            }
            SignatureAlgorithm::RsaSha256 | SignatureAlgorithm::RsaSha512 => {
                // RSA verification
                Ok(true)
            }
            SignatureAlgorithm::EcdsaP256 | SignatureAlgorithm::EcdsaP384 => {
                // ECDSA verification
                Ok(true)
            }
        }
    }
}

#[derive(Clone)]
pub struct VerificationResult {
    pub valid: bool,
    pub key_id: String,
    pub reason: Option<String>,
    pub verified_at: u64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE ANALYTICS & TELEMETRY
// ═══════════════════════════════════════════════════════════════════════════════

/// Package usage analytics collector
pub struct PackageAnalytics {
    events: Vec<AnalyticsEvent>,
    session_id: String,
    enabled: bool,
    endpoint: Option<String>,
}

#[derive(Clone)]
pub struct AnalyticsEvent {
    pub event_type: AnalyticsEventType,
    pub package_name: String,
    pub package_version: String,
    pub timestamp: u64,
    pub metadata: HashMap<String, String>,
}

#[derive(Clone, Copy, PartialEq)]
pub enum AnalyticsEventType {
    Install,
    Update,
    Remove,
    Build,
    Test,
    Publish,
    Download,
    CacheHit,
    CacheMiss,
    ResolutionStart,
    ResolutionComplete,
    Error,
}

impl PackageAnalytics {
    pub fn new() -> Self {
        PackageAnalytics {
            events: Vec::new(),
            session_id: generate_session_id(),
            enabled: true,
            endpoint: None,
        }
    }

    pub fn with_endpoint(mut self, endpoint: &str) -> Self {
        self.endpoint = Some(endpoint.to_string());
        self
    }

    pub fn disable(&mut self) {
        self.enabled = false;
    }

    pub fn record_event(&mut self, event_type: AnalyticsEventType, package: &str, version: &str) {
        if !self.enabled {
            return;
        }

        self.events.push(AnalyticsEvent {
            event_type,
            package_name: package.to_string(),
            package_version: version.to_string(),
            timestamp: current_timestamp(),
            metadata: HashMap::new(),
        });
    }

    pub fn record_event_with_metadata(
        &mut self,
        event_type: AnalyticsEventType,
        package: &str,
        version: &str,
        metadata: HashMap<String, String>,
    ) {
        if !self.enabled {
            return;
        }

        self.events.push(AnalyticsEvent {
            event_type,
            package_name: package.to_string(),
            package_version: version.to_string(),
            timestamp: current_timestamp(),
            metadata,
        });
    }

    pub fn flush(&mut self) -> Result<(), PackageError> {
        if self.events.is_empty() || !self.enabled {
            return Ok(());
        }

        if let Some(endpoint) = &self.endpoint {
            self.send_events(endpoint)?;
        }

        self.events.clear();
        Ok(())
    }

    fn send_events(&self, endpoint: &str) -> Result<(), PackageError> {
        // Batch send events to analytics endpoint
        let payload = self.serialize_events();
        // HTTP POST to endpoint
        Ok(())
    }

    fn serialize_events(&self) -> String {
        // JSON serialization
        "[]".to_string()
    }

    pub fn get_statistics(&self) -> AnalyticsStatistics {
        let mut stats = AnalyticsStatistics::default();

        for event in &self.events {
            match event.event_type {
                AnalyticsEventType::Install => stats.installs += 1,
                AnalyticsEventType::Update => stats.updates += 1,
                AnalyticsEventType::Remove => stats.removes += 1,
                AnalyticsEventType::CacheHit => stats.cache_hits += 1,
                AnalyticsEventType::CacheMiss => stats.cache_misses += 1,
                AnalyticsEventType::Error => stats.errors += 1,
                _ => {}
            }
        }

        if stats.cache_hits + stats.cache_misses > 0 {
            stats.cache_hit_rate = stats.cache_hits as f64 / (stats.cache_hits + stats.cache_misses) as f64;
        }

        stats
    }
}

#[derive(Clone, Default)]
pub struct AnalyticsStatistics {
    pub installs: u64,
    pub updates: u64,
    pub removes: u64,
    pub cache_hits: u64,
    pub cache_misses: u64,
    pub cache_hit_rate: f64,
    pub errors: u64,
}

fn generate_session_id() -> String {
    format!("session-{}", current_timestamp())
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE MIGRATION TOOLS
// ═══════════════════════════════════════════════════════════════════════════════

/// Package migration between registries or formats
pub struct PackageMigrator {
    source_registry: RegistryConfig,
    target_registry: RegistryConfig,
    dry_run: bool,
    preserve_versions: bool,
}

#[derive(Clone)]
pub struct RegistryConfig {
    pub url: String,
    pub auth_token: Option<String>,
    pub registry_type: RegistryType,
}

#[derive(Clone, Copy, PartialEq)]
pub enum RegistryType {
    Quark,
    Npm,
    Cargo,
    PyPI,
    Maven,
    NuGet,
}

impl PackageMigrator {
    pub fn new(source: RegistryConfig, target: RegistryConfig) -> Self {
        PackageMigrator {
            source_registry: source,
            target_registry: target,
            dry_run: false,
            preserve_versions: true,
        }
    }

    pub fn dry_run(mut self, enabled: bool) -> Self {
        self.dry_run = enabled;
        self
    }

    pub fn migrate_package(&self, package_name: &str) -> Result<MigrationResult, PackageError> {
        println!("Migrating package: {}", package_name);

        // Fetch from source registry
        let package_data = self.fetch_from_source(package_name)?;

        // Transform if needed
        let transformed = self.transform_package(&package_data)?;

        // Publish to target
        if !self.dry_run {
            self.publish_to_target(&transformed)?;
        }

        Ok(MigrationResult {
            package_name: package_name.to_string(),
            versions_migrated: package_data.versions.len(),
            success: true,
            dry_run: self.dry_run,
        })
    }

    fn fetch_from_source(&self, package_name: &str) -> Result<PackageData, PackageError> {
        match self.source_registry.registry_type {
            RegistryType::Quark => self.fetch_quark_package(package_name),
            RegistryType::Npm => self.fetch_npm_package(package_name),
            RegistryType::Cargo => self.fetch_cargo_package(package_name),
            RegistryType::PyPI => self.fetch_pypi_package(package_name),
            _ => Err(PackageError::NetworkError("Unsupported registry".to_string())),
        }
    }

    fn fetch_quark_package(&self, name: &str) -> Result<PackageData, PackageError> {
        Ok(PackageData {
            name: name.to_string(),
            versions: vec!["1.0.0".to_string()],
            metadata: HashMap::new(),
        })
    }

    fn fetch_npm_package(&self, name: &str) -> Result<PackageData, PackageError> {
        Ok(PackageData {
            name: name.to_string(),
            versions: vec!["1.0.0".to_string()],
            metadata: HashMap::new(),
        })
    }

    fn fetch_cargo_package(&self, name: &str) -> Result<PackageData, PackageError> {
        Ok(PackageData {
            name: name.to_string(),
            versions: vec!["1.0.0".to_string()],
            metadata: HashMap::new(),
        })
    }

    fn fetch_pypi_package(&self, name: &str) -> Result<PackageData, PackageError> {
        Ok(PackageData {
            name: name.to_string(),
            versions: vec!["1.0.0".to_string()],
            metadata: HashMap::new(),
        })
    }

    fn transform_package(&self, data: &PackageData) -> Result<PackageData, PackageError> {
        // Transform package format between registries
        Ok(data.clone())
    }

    fn publish_to_target(&self, data: &PackageData) -> Result<(), PackageError> {
        println!("Publishing {} to target registry", data.name);
        Ok(())
    }
}

#[derive(Clone)]
pub struct PackageData {
    pub name: String,
    pub versions: Vec<String>,
    pub metadata: HashMap<String, String>,
}

#[derive(Clone)]
pub struct MigrationResult {
    pub package_name: String,
    pub versions_migrated: usize,
    pub success: bool,
    pub dry_run: bool,
}

/// Bulk package migration
pub struct BulkMigrator {
    migrator: PackageMigrator,
    packages: Vec<String>,
    concurrency: usize,
    results: Vec<MigrationResult>,
}

impl BulkMigrator {
    pub fn new(migrator: PackageMigrator) -> Self {
        BulkMigrator {
            migrator,
            packages: Vec::new(),
            concurrency: 4,
            results: Vec::new(),
        }
    }

    pub fn add_package(&mut self, name: &str) {
        self.packages.push(name.to_string());
    }

    pub fn add_packages(&mut self, names: &[&str]) {
        for name in names {
            self.packages.push(name.to_string());
        }
    }

    pub fn concurrency(mut self, n: usize) -> Self {
        self.concurrency = n;
        self
    }

    pub fn execute(&mut self) -> Result<BulkMigrationResult, PackageError> {
        let total = self.packages.len();
        let mut successful = 0;
        let mut failed = 0;

        for package in &self.packages {
            match self.migrator.migrate_package(package) {
                Ok(result) => {
                    if result.success {
                        successful += 1;
                    } else {
                        failed += 1;
                    }
                    self.results.push(result);
                }
                Err(_) => {
                    failed += 1;
                }
            }
        }

        Ok(BulkMigrationResult {
            total,
            successful,
            failed,
            results: self.results.clone(),
        })
    }
}

#[derive(Clone)]
pub struct BulkMigrationResult {
    pub total: usize,
    pub successful: usize,
    pub failed: usize,
    pub results: Vec<MigrationResult>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENDED UNIT TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod extended_tests {
    use super::*;

    #[test]
    fn test_package_signer_generation() {
        let signer = PackageSigner::generate(SignatureAlgorithm::Ed25519).unwrap();
        assert!(!signer.key_id.is_empty());
    }

    #[test]
    fn test_signature_verifier() {
        let mut verifier = SignatureVerifier::new();
        assert!(verifier.trusted_keys.is_empty());

        let key = VerifyingKey {
            algorithm: SignatureAlgorithm::Ed25519,
            key_data: vec![0u8; 32],
            fingerprint: "test-key".to_string(),
        };

        verifier.add_trusted_key(key);
        assert_eq!(verifier.trusted_keys.len(), 1);
    }

    #[test]
    fn test_key_revocation() {
        let mut verifier = SignatureVerifier::new();
        verifier.revoke_key("old-key");
        assert!(verifier.revoked_keys.contains("old-key"));
    }

    #[test]
    fn test_analytics_event_recording() {
        let mut analytics = PackageAnalytics::new();
        analytics.record_event(AnalyticsEventType::Install, "test-pkg", "1.0.0");
        assert_eq!(analytics.events.len(), 1);
    }

    #[test]
    fn test_analytics_disabled() {
        let mut analytics = PackageAnalytics::new();
        analytics.disable();
        analytics.record_event(AnalyticsEventType::Install, "test-pkg", "1.0.0");
        assert!(analytics.events.is_empty());
    }

    #[test]
    fn test_analytics_statistics() {
        let mut analytics = PackageAnalytics::new();
        analytics.record_event(AnalyticsEventType::Install, "pkg1", "1.0.0");
        analytics.record_event(AnalyticsEventType::Install, "pkg2", "1.0.0");
        analytics.record_event(AnalyticsEventType::CacheHit, "pkg1", "1.0.0");

        let stats = analytics.get_statistics();
        assert_eq!(stats.installs, 2);
        assert_eq!(stats.cache_hits, 1);
    }

    #[test]
    fn test_registry_config() {
        let config = RegistryConfig {
            url: "https://registry.quark.dev".to_string(),
            auth_token: Some("token123".to_string()),
            registry_type: RegistryType::Quark,
        };
        assert_eq!(config.registry_type, RegistryType::Quark);
    }

    #[test]
    fn test_package_migrator_dry_run() {
        let source = RegistryConfig {
            url: "https://source.registry".to_string(),
            auth_token: None,
            registry_type: RegistryType::Npm,
        };

        let target = RegistryConfig {
            url: "https://target.registry".to_string(),
            auth_token: None,
            registry_type: RegistryType::Quark,
        };

        let migrator = PackageMigrator::new(source, target).dry_run(true);
        assert!(migrator.dry_run);
    }

    #[test]
    fn test_bulk_migrator() {
        let source = RegistryConfig {
            url: "https://source.registry".to_string(),
            auth_token: None,
            registry_type: RegistryType::Npm,
        };

        let target = RegistryConfig {
            url: "https://target.registry".to_string(),
            auth_token: None,
            registry_type: RegistryType::Quark,
        };

        let migrator = PackageMigrator::new(source, target);
        let mut bulk = BulkMigrator::new(migrator).concurrency(2);
        bulk.add_packages(&["pkg1", "pkg2", "pkg3"]);
        assert_eq!(bulk.packages.len(), 3);
    }

    #[test]
    fn test_signature_algorithms() {
        assert_ne!(SignatureAlgorithm::Ed25519, SignatureAlgorithm::RsaSha256);
        assert_ne!(SignatureAlgorithm::EcdsaP256, SignatureAlgorithm::EcdsaP384);
    }

    #[test]
    fn test_compression_types() {
        let gz = CompressionType::Gzip;
        let zstd = CompressionType::Zstd;
        assert_ne!(gz as u8, zstd as u8);
    }

    #[test]
    fn test_export_result() {
        let result = ExportResult {
            packages: 10,
            total_size: 1024 * 1024,
            output_path: "/tmp/export".to_string(),
        };
        assert_eq!(result.packages, 10);
    }

    #[test]
    fn test_import_result() {
        let result = ImportResult { packages: 5 };
        assert_eq!(result.packages, 5);
    }
}
