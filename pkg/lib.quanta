// ═══════════════════════════════════════════════════════════════════════════════
// SCRIPT RUNNER
// ═══════════════════════════════════════════════════════════════════════════════

/// Script runner for package scripts
pub struct ScriptRunner {
    scripts: HashMap<String, Script>,
    env: HashMap<String, String>,
}

#[derive(Clone)]
pub struct Script {
    pub name: String,
    pub command: String,
    pub description: Option<String>,
    pub pre_script: Option<String>,
    pub post_script: Option<String>,
}

impl ScriptRunner {
    pub fn new() -> Self {
        ScriptRunner {
            scripts: HashMap::new(),
            env: HashMap::new(),
        }
    }

    /// Load scripts from manifest
    pub fn load_from_manifest(&mut self, manifest: &Manifest) -> Result<(), PackageError> {
        if let Some(scripts_meta) = manifest.metadata.get("scripts") {
            // Parse scripts from metadata
            // Format: "name:command;name2:command2"
            for entry in scripts_meta.split(';') {
                let parts: Vec<&str> = entry.split(':').collect();
                if parts.len() >= 2 {
                    self.scripts.insert(parts[0].to_string(), Script {
                        name: parts[0].to_string(),
                        command: parts[1].to_string(),
                        description: None,
                        pre_script: None,
                        post_script: None,
                    });
                }
            }
        }
        Ok(())
    }

    /// Register a script
    pub fn register(&mut self, script: Script) {
        self.scripts.insert(script.name.clone(), script);
    }

    /// Set environment variable
    pub fn set_env(&mut self, key: &str, value: &str) {
        self.env.insert(key.to_string(), value.to_string());
    }

    /// Run a script
    pub fn run(&self, name: &str, args: &[&str]) -> Result<i32, ScriptError> {
        let script = self.scripts.get(name)
            .ok_or_else(|| ScriptError::NotFound(name.to_string()))?;

        println!("Running script: {}", name);

        // Run pre-script
        if let Some(ref pre) = script.pre_script {
            if let Some(pre_script) = self.scripts.get(pre) {
                self.execute(&pre_script.command, &[])?;
            }
        }

        // Run main script
        let exit_code = self.execute(&script.command, args)?;

        // Run post-script
        if let Some(ref post) = script.post_script {
            if let Some(post_script) = self.scripts.get(post) {
                self.execute(&post_script.command, &[])?;
            }
        }

        Ok(exit_code)
    }

    /// List all available scripts
    pub fn list(&self) -> Vec<&Script> {
        self.scripts.values().collect()
    }

    fn execute(&self, command: &str, args: &[&str]) -> Result<i32, ScriptError> {
        // Build command with environment
        let mut full_command = command.to_string();
        for arg in args {
            full_command.push(' ');
            full_command.push_str(arg);
        }

        // Execute command
        // In real implementation, would use std::process::Command
        println!("  $ {}", full_command);

        Ok(0)
    }
}

#[derive(Debug)]
pub enum ScriptError {
    NotFound(String),
    ExecutionFailed(String, i32),
    IoError(String),
}

