// HEALTH MONITORING
// ═══════════════════════════════════════════════════════════════════════════════

/// System health monitor
pub struct HealthMonitor {
    checks: Vec<Box<dyn HealthCheckFn>>,
    interval: u64,
    running: bool,
    status: HealthStatus,
}

pub trait HealthCheckFn: Send + Sync {
    fn name(&self) -> &str;
    fn check(&self) -> HealthCheckResult;
}

#[derive(Clone)]
pub struct HealthCheckResult {
    name: String,
    status: HealthStatus,
    message: Option<String>,
    duration_ms: u64,
}

#[derive(Clone, Copy, Debug)]
pub enum HealthStatus {
    Healthy,
    Degraded,
    Unhealthy,
    Unknown,
}

impl HealthMonitor {
    pub fn new() -> Self {
        HealthMonitor {
            checks: Vec::new(),
            interval: 30000,
            running: false,
            status: HealthStatus::Unknown,
        }
    }

    pub fn add_check<C: HealthCheckFn + 'static>(&mut self, check: C) {
        self.checks.push(Box::new(check));
    }

    pub fn run_checks(&mut self) -> Vec<HealthCheckResult> {
        let mut results = Vec::new();
        let mut overall_healthy = true;

        for check in &self.checks {
            let start = Instant::now();
            let mut result = check.check();
            result.duration_ms = start.elapsed().as_millis() as u64;

            if !matches!(result.status, HealthStatus::Healthy) {
                overall_healthy = false;
            }

            results.push(result);
        }

        self.status = if overall_healthy {
            HealthStatus::Healthy
        } else {
            HealthStatus::Degraded
        };

        results
    }

    pub fn start(&mut self) {
        self.running = true;

        while self.running {
            self.run_checks();
            std::thread::sleep(std::time::Duration::from_millis(self.interval));
        }
    }

    pub fn stop(&mut self) {
        self.running = false;
    }

    pub fn status(&self) -> HealthStatus {
        self.status
    }
}

