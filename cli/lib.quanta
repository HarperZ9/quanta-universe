// SECRET MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Secure secret manager
pub struct SecretManager {
    backend: Box<dyn SecretBackend>,
    cache: HashMap<String, CachedSecret>,
    cache_ttl: u64,
}

pub trait SecretBackend: Send + Sync {
    fn get(&self, key: &str) -> Result<String, String>;
    fn set(&mut self, key: &str, value: &str) -> Result<(), String>;
    fn delete(&mut self, key: &str) -> Result<(), String>;
    fn list(&self) -> Result<Vec<String>, String>;
    fn rotate(&mut self, key: &str) -> Result<String, String>;
}

#[derive(Clone)]
struct CachedSecret {
    value: String,
    cached_at: u64,
}

impl SecretManager {
    pub fn new<B: SecretBackend + 'static>(backend: B) -> Self {
        SecretManager {
            backend: Box::new(backend),
            cache: HashMap::new(),
            cache_ttl: 300000, // 5 minutes
        }
    }

    pub fn get(&mut self, key: &str) -> Result<String, String> {
        let now = current_time_ms();

        // Check cache
        if let Some(cached) = self.cache.get(key) {
            if now - cached.cached_at < self.cache_ttl {
                return Ok(cached.value.clone());
            }
        }

        // Fetch from backend
        let value = self.backend.get(key)?;

        // Update cache
        self.cache.insert(key.to_string(), CachedSecret {
            value: value.clone(),
            cached_at: now,
        });

        Ok(value)
    }

    pub fn set(&mut self, key: &str, value: &str) -> Result<(), String> {
        self.backend.set(key, value)?;
        self.cache.remove(key);
        Ok(())
    }

    pub fn delete(&mut self, key: &str) -> Result<(), String> {
        self.backend.delete(key)?;
        self.cache.remove(key);
        Ok(())
    }

    pub fn list(&self) -> Result<Vec<String>, String> {
        self.backend.list()
    }

    pub fn rotate(&mut self, key: &str) -> Result<String, String> {
        let new_value = self.backend.rotate(key)?;
        self.cache.remove(key);
        Ok(new_value)
    }

    pub fn clear_cache(&mut self) {
        self.cache.clear();
    }
}

/// File-based secret backend (encrypted)
pub struct FileSecretBackend {
    path: String,
    encryption_key: [u8; 32],
}

impl FileSecretBackend {
    pub fn new(path: &str, key: [u8; 32]) -> Self {
        FileSecretBackend {
            path: path.to_string(),
            encryption_key: key,
        }
    }

    fn encrypt(&self, data: &str) -> Vec<u8> {
        // In real implementation, use proper encryption
        data.as_bytes().to_vec()
    }

    fn decrypt(&self, data: &[u8]) -> String {
        // In real implementation, use proper decryption
        String::from_utf8_lossy(data).to_string()
    }
}

impl SecretBackend for FileSecretBackend {
    fn get(&self, key: &str) -> Result<String, String> {
        let path = format!("{}/{}", self.path, key);
        let data = std::fs::read(&path)
            .map_err(|e| format!("Secret not found: {}", e))?;
        Ok(self.decrypt(&data))
    }

    fn set(&mut self, key: &str, value: &str) -> Result<(), String> {
        std::fs::create_dir_all(&self.path).ok();
        let path = format!("{}/{}", self.path, key);
        let encrypted = self.encrypt(value);
        std::fs::write(&path, encrypted)
            .map_err(|e| e.to_string())
    }

    fn delete(&mut self, key: &str) -> Result<(), String> {
        let path = format!("{}/{}", self.path, key);
        std::fs::remove_file(&path)
            .map_err(|e| e.to_string())
    }

    fn list(&self) -> Result<Vec<String>, String> {
        let mut secrets = Vec::new();
        if let Ok(entries) = std::fs::read_dir(&self.path) {
            for entry in entries.flatten() {
                if let Some(name) = entry.file_name().to_str() {
                    secrets.push(name.to_string());
                }
            }
        }
        Ok(secrets)
    }

    fn rotate(&mut self, key: &str) -> Result<String, String> {
        let new_value = generate_secret(32);
        self.set(key, &new_value)?;
        Ok(new_value)
    }
}

