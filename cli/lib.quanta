// NOTIFICATION SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Notification manager for alerts and updates
pub struct NotificationManager {
    channels: Vec<Box<dyn NotificationChannel>>,
    rules: Vec<NotificationRule>,
}

pub trait NotificationChannel: Send + Sync {
    fn name(&self) -> &str;
    fn send(&self, notification: &Notification) -> Result<(), String>;
}

#[derive(Clone)]
pub struct Notification {
    id: String,
    title: String,
    message: String,
    severity: Severity,
    timestamp: u64,
    metadata: HashMap<String, String>,
}

#[derive(Clone, Copy, Debug)]
pub enum Severity {
    Info,
    Warning,
    Error,
    Critical,
}

#[derive(Clone)]
pub struct NotificationRule {
    name: String,
    condition: String,
    channels: Vec<String>,
    severity_filter: Option<Severity>,
    throttle_seconds: Option<u64>,
}

impl NotificationManager {
    pub fn new() -> Self {
        NotificationManager {
            channels: Vec::new(),
            rules: Vec::new(),
        }
    }

    pub fn add_channel<C: NotificationChannel + 'static>(&mut self, channel: C) {
        self.channels.push(Box::new(channel));
    }

    pub fn add_rule(&mut self, rule: NotificationRule) {
        self.rules.push(rule);
    }

    pub fn notify(&self, notification: &Notification) {
        for rule in &self.rules {
            if self.matches_rule(&notification, &rule) {
                for channel_name in &rule.channels {
                    if let Some(channel) = self.channels.iter()
                        .find(|c| c.name() == channel_name) {
                        channel.send(notification).ok();
                    }
                }
            }
        }
    }

    fn matches_rule(&self, notification: &Notification, rule: &NotificationRule) -> bool {
        if let Some(severity) = rule.severity_filter {
            if notification.severity as u8 >= severity as u8 {
                return true;
            }
            return false;
        }
        true
    }
}

