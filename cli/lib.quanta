/// Environment manager for multi-environment deployments
pub struct EnvironmentManager {
    environments: HashMap<String, Environment>,
    active: Option<String>,
    config_dir: String,
}

#[derive(Clone)]
pub struct Environment {
    name: String,
    description: String,
    variables: HashMap<String, String>,
    secrets: Vec<String>, // Secret names (actual values stored securely)
    targets: Vec<DeploymentTarget>,
    config_overrides: HashMap<String, String>,
    inherit_from: Option<String>,
}

#[derive(Clone)]
pub struct DeploymentTarget {
    name: String,
    host: String,
    port: u16,
    protocol: Protocol,
    credentials: Option<Credentials>,
    health_check: Option<HealthCheck>,
}

#[derive(Clone)]
pub enum Protocol {
    SSH,
    Docker,
    Kubernetes,
    AWS,
    Azure,
    GCP,
    HTTP,
    Custom(String),
}

#[derive(Clone)]
pub struct Credentials {
    kind: CredentialKind,
    secret_name: String,
}

#[derive(Clone)]
pub enum CredentialKind {
    Password,
    SSHKey,
    Token,
    Certificate,
    ServiceAccount,
}

#[derive(Clone)]
pub struct HealthCheck {
    endpoint: String,
    interval: u64,
    timeout: u64,
    healthy_threshold: u32,
    unhealthy_threshold: u32,
}

impl EnvironmentManager {
    pub fn new() -> Self {
        EnvironmentManager {
            environments: HashMap::new(),
            active: None,
            config_dir: ".quanta/environments".to_string(),
        }
    }

    pub fn load(&mut self) -> Result<(), String> {
        // Load environments from config directory
        let path = std::path::Path::new(&self.config_dir);
        if !path.exists() {
            return Ok(());
        }

        if let Ok(entries) = std::fs::read_dir(path) {
            for entry in entries.flatten() {
                if let Some(ext) = entry.path().extension() {
                    if ext == "toml" || ext == "yaml" {
                        self.load_environment(&entry.path())?;
                    }
                }
            }
        }

        Ok(())
    }

    fn load_environment(&mut self, path: &std::path::Path) -> Result<(), String> {
        let content = std::fs::read_to_string(path)
            .map_err(|e| format!("Failed to read {}: {}", path.display(), e))?;

        // Parse environment config
        let name = path.file_stem()
            .and_then(|s| s.to_str())
            .unwrap_or("unknown")
            .to_string();

        let env = Environment {
            name: name.clone(),
            description: String::new(),
            variables: HashMap::new(),
            secrets: Vec::new(),
            targets: Vec::new(),
            config_overrides: HashMap::new(),
            inherit_from: None,
        };

        self.environments.insert(name, env);
        Ok(())
    }

    pub fn activate(&mut self, name: &str) -> Result<(), String> {
        if !self.environments.contains_key(name) {
            return Err(format!("Environment '{}' not found", name));
        }

        self.active = Some(name.to_string());
        self.apply_environment(name)
    }

    fn apply_environment(&self, name: &str) -> Result<(), String> {
        let env = self.get_environment(name)?;

        // Apply variables
        for (key, value) in &env.variables {
            std::env::set_var(key, value);
        }

        // Apply config overrides
        // In real implementation, modify runtime config

        Ok(())
    }

    pub fn get_environment(&self, name: &str) -> Result<Environment, String> {
        let env = self.environments.get(name)
            .ok_or_else(|| format!("Environment '{}' not found", name))?;

        // Handle inheritance
        if let Some(ref parent_name) = env.inherit_from {
            let parent = self.get_environment(parent_name)?;
            return Ok(self.merge_environments(&parent, env));
        }

        Ok(env.clone())
    }

    fn merge_environments(&self, parent: &Environment, child: &Environment) -> Environment {
        let mut merged = parent.clone();
        merged.name = child.name.clone();
        merged.description = child.description.clone();

        // Merge variables (child overrides parent)
        for (k, v) in &child.variables {
            merged.variables.insert(k.clone(), v.clone());
        }

        // Merge config overrides
        for (k, v) in &child.config_overrides {
            merged.config_overrides.insert(k.clone(), v.clone());
        }

        // Child targets replace parent targets
        if !child.targets.is_empty() {
            merged.targets = child.targets.clone();
        }

        merged
    }

    pub fn list(&self) -> Vec<&str> {
        self.environments.keys().map(|s| s.as_str()).collect()
    }

    pub fn current(&self) -> Option<&str> {
        self.active.as_deref()
    }

    pub fn create(&mut self, name: &str, description: &str) -> Result<(), String> {
        if self.environments.contains_key(name) {
            return Err(format!("Environment '{}' already exists", name));
        }

        let env = Environment {
            name: name.to_string(),
            description: description.to_string(),
            variables: HashMap::new(),
            secrets: Vec::new(),
            targets: Vec::new(),
            config_overrides: HashMap::new(),
            inherit_from: None,
        };

        self.environments.insert(name.to_string(), env);
        self.save_environment(name)
    }

    fn save_environment(&self, name: &str) -> Result<(), String> {
        let env = self.environments.get(name)
            .ok_or_else(|| format!("Environment '{}' not found", name))?;

        std::fs::create_dir_all(&self.config_dir)
            .map_err(|e| e.to_string())?;

        let path = format!("{}/{}.toml", self.config_dir, name);
        // Serialize and save environment
        Ok(())
    }
}

