/// Cloud provider abstraction
pub trait CloudProvider: Send + Sync {
    fn name(&self) -> &str;
    fn regions(&self) -> Vec<String>;
    fn deploy(&self, config: &DeployConfig) -> Result<DeployResult, String>;
    fn status(&self, deployment_id: &str) -> Result<DeployStatus, String>;
    fn logs(&self, deployment_id: &str) -> Result<String, String>;
    fn destroy(&self, deployment_id: &str) -> Result<(), String>;
}

#[derive(Clone)]
pub struct DeployConfig {
    name: String,
    region: String,
    instance_type: String,
    replicas: u32,
    environment: HashMap<String, String>,
    secrets: Vec<String>,
}

#[derive(Clone)]
pub struct DeployResult {
    deployment_id: String,
    url: Option<String>,
    status: DeployStatus,
}

#[derive(Clone, Copy)]
pub enum DeployStatus {
    Pending,
    Deploying,
    Running,
    Failed,
    Stopped,
}

/// AWS provider
pub struct AwsProvider {
    region: String,
    access_key: String,
    secret_key: String,
}

impl AwsProvider {
    pub fn new(region: &str, access_key: &str, secret_key: &str) -> Self {
        AwsProvider {
            region: region.to_string(),
            access_key: access_key.to_string(),
            secret_key: secret_key.to_string(),
        }
    }

    pub fn from_env() -> Result<Self, String> {
        Ok(AwsProvider {
            region: std::env::var("AWS_REGION").unwrap_or_else(|_| "us-east-1".to_string()),
            access_key: std::env::var("AWS_ACCESS_KEY_ID")
                .map_err(|_| "AWS_ACCESS_KEY_ID not set")?,
            secret_key: std::env::var("AWS_SECRET_ACCESS_KEY")
                .map_err(|_| "AWS_SECRET_ACCESS_KEY not set")?,
        })
    }
}

impl CloudProvider for AwsProvider {
    fn name(&self) -> &str { "AWS" }

    fn regions(&self) -> Vec<String> {
        vec![
            "us-east-1".to_string(), "us-east-2".to_string(),
            "us-west-1".to_string(), "us-west-2".to_string(),
            "eu-west-1".to_string(), "eu-central-1".to_string(),
            "ap-northeast-1".to_string(), "ap-southeast-1".to_string(),
        ]
    }

    fn deploy(&self, config: &DeployConfig) -> Result<DeployResult, String> {
        println!("Deploying to AWS {}...", self.region);
        Ok(DeployResult {
            deployment_id: generate_uuid(),
            url: Some(format!("https://{}.execute-api.{}.amazonaws.com",
                config.name, self.region)),
            status: DeployStatus::Running,
        })
    }

    fn status(&self, deployment_id: &str) -> Result<DeployStatus, String> {
        Ok(DeployStatus::Running)
    }

    fn logs(&self, deployment_id: &str) -> Result<String, String> {
        Ok(String::new())
    }

    fn destroy(&self, deployment_id: &str) -> Result<(), String> {
        println!("Destroying AWS deployment {}...", deployment_id);
        Ok(())
    }
}

