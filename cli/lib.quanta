#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_cli_creation() {
        let cli = CLI::new();
        assert!(!cli.verbose);
        assert!(!cli.quiet);
    }

    #[test]
    fn test_flag_parsing() {
        let mut cli = CLI {
            args: vec!["quanta".to_string(), "build".to_string(), "-v".to_string()],
            verbose: false,
            quiet: false,
        };
        cli.parse_flags();
        assert!(cli.verbose);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED ARGUMENT PARSING
// ═══════════════════════════════════════════════════════════════════════════════

/// Command-line argument parser with support for subcommands, options, and flags
#[derive(Clone)]
pub struct ArgParser {
    program_name: String,
    description: String,
    version: String,
    commands: Vec<Command>,
    global_flags: Vec<Flag>,
    global_options: Vec<CliOption>,
}

#[derive(Clone)]
pub struct Command {
    name: String,
    description: String,
    aliases: Vec<String>,
    flags: Vec<Flag>,
    options: Vec<CliOption>,
    args: Vec<Argument>,
    subcommands: Vec<Command>,
    handler: Option<fn(&ParsedArgs) -> Result<i32, String>>,
}

#[derive(Clone)]
pub struct Flag {
    short: Option<char>,
    long: String,
    description: String,
    env_var: Option<String>,
}

#[derive(Clone)]
pub struct CliOption {
    short: Option<char>,
    long: String,
    description: String,
    value_name: String,
    default: Option<String>,
    env_var: Option<String>,
    required: bool,
    multiple: bool,
    choices: Option<Vec<String>>,
}

#[derive(Clone)]
pub struct Argument {
    name: String,
    description: String,
    required: bool,
    multiple: bool,
}

#[derive(Clone)]
pub struct ParsedArgs {
    command: Vec<String>,
    flags: HashMap<String, bool>,
    options: HashMap<String, Vec<String>>,
    args: Vec<String>,
}

impl ArgParser {
    pub fn new(name: &str) -> Self {
        ArgParser {
            program_name: name.to_string(),
            description: String::new(),
            version: "1.0.0".to_string(),
            commands: Vec::new(),
            global_flags: Vec::new(),
            global_options: Vec::new(),
        }
    }

    pub fn description(mut self, desc: &str) -> Self {
        self.description = desc.to_string();
        self
    }

    pub fn version(mut self, ver: &str) -> Self {
        self.version = ver.to_string();
        self
    }

    pub fn command(mut self, cmd: Command) -> Self {
        self.commands.push(cmd);
        self
    }

    pub fn flag(mut self, flag: Flag) -> Self {
        self.global_flags.push(flag);
        self
    }

    pub fn option(mut self, opt: CliOption) -> Self {
        self.global_options.push(opt);
        self
    }

    /// Parse command line arguments
    pub fn parse(&self, args: &[String]) -> Result<ParsedArgs, String> {
        let mut parsed = ParsedArgs {
            command: Vec::new(),
            flags: HashMap::new(),
            options: HashMap::new(),
            args: Vec::new(),
        };

        // Initialize from environment variables
        for flag in &self.global_flags {
            if let Some(ref env) = flag.env_var {
                if std::env::var(env).is_ok() {
                    parsed.flags.insert(flag.long.clone(), true);
                }
            }
        }

        for opt in &self.global_options {
            if let Some(ref env) = opt.env_var {
                if let Ok(val) = std::env::var(env) {
                    parsed.options.insert(opt.long.clone(), vec![val]);
                }
            }
        }

        let mut i = 1; // Skip program name
        while i < args.len() {
            let arg = &args[i];

            if arg.starts_with("--") {
                // Long flag/option
                let name = &arg[2..];
                if let Some(eq_pos) = name.find('=') {
                    let key = &name[..eq_pos];
                    let value = &name[eq_pos + 1..];
                    parsed.options.entry(key.to_string())
                        .or_insert_with(Vec::new)
                        .push(value.to_string());
                } else if self.is_flag(name) {
                    parsed.flags.insert(name.to_string(), true);
                } else if i + 1 < args.len() {
                    i += 1;
                    parsed.options.entry(name.to_string())
                        .or_insert_with(Vec::new)
                        .push(args[i].clone());
                }
            } else if arg.starts_with("-") && arg.len() > 1 {
                // Short flags/options
                let chars: Vec<char> = arg[1..].chars().collect();
                for (j, c) in chars.iter().enumerate() {
                    if let Some(flag) = self.find_short_flag(*c) {
                        parsed.flags.insert(flag.long.clone(), true);
                    } else if let Some(opt) = self.find_short_option(*c) {
                        if j == chars.len() - 1 && i + 1 < args.len() {
                            i += 1;
                            parsed.options.entry(opt.long.clone())
                                .or_insert_with(Vec::new)
                                .push(args[i].clone());
                        }
                    }
                }
            } else {
                // Positional argument or command
                if parsed.command.is_empty() && self.is_command(arg) {
                    parsed.command.push(arg.clone());
                } else {
                    parsed.args.push(arg.clone());
                }
            }

            i += 1;
        }

        // Apply defaults
        for opt in &self.global_options {
            if !parsed.options.contains_key(&opt.long) {
                if let Some(ref default) = opt.default {
                    parsed.options.insert(opt.long.clone(), vec![default.clone()]);
                }
            }
        }

        // Validate required options
        for opt in &self.global_options {
            if opt.required && !parsed.options.contains_key(&opt.long) {
                return Err(format!("Missing required option: --{}", opt.long));
            }
        }

        Ok(parsed)
    }

    fn is_flag(&self, name: &str) -> bool {
        self.global_flags.iter().any(|f| f.long == name)
    }

    fn is_command(&self, name: &str) -> bool {
        self.commands.iter().any(|c| c.name == name || c.aliases.contains(&name.to_string()))
    }

    fn find_short_flag(&self, c: char) -> Option<&Flag> {
        self.global_flags.iter().find(|f| f.short == Some(c))
    }

    fn find_short_option(&self, c: char) -> Option<&CliOption> {
        self.global_options.iter().find(|o| o.short == Some(c))
    }

    /// Generate shell completion script
    pub fn generate_completions(&self, shell: Shell) -> String {
        match shell {
            Shell::Bash => self.gen_bash_completions(),
            Shell::Zsh => self.gen_zsh_completions(),
            Shell::Fish => self.gen_fish_completions(),
            Shell::PowerShell => self.gen_powershell_completions(),
        }
    }

    fn gen_bash_completions(&self) -> String {
        let mut script = format!(
            r#"_{}() {{
    local cur prev words cword
    _init_completion || return

    local commands="{}"
    local flags="{}"

    case "$prev" in
"#,
            self.program_name,
            self.commands.iter().map(|c| c.name.as_str()).collect::<Vec<_>>().join(" "),
            self.global_flags.iter().map(|f| format!("--{}", f.long)).collect::<Vec<_>>().join(" ")
        );

        // Add option completions
        for opt in &self.global_options {
            if let Some(ref choices) = opt.choices {
                script.push_str(&format!(
                    "        --{})\n            COMPREPLY=($(compgen -W \"{}\" -- \"$cur\"))\n            return ;;\n",
                    opt.long,
                    choices.join(" ")
                ));
            }
        }

        script.push_str(r#"    esac

    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "$flags" -- "$cur"))
    else
        COMPREPLY=($(compgen -W "$commands" -- "$cur"))
    fi
}

"#);
        script.push_str(&format!("complete -F _{} {}\n", self.program_name, self.program_name));
        script
    }

    fn gen_zsh_completions(&self) -> String {
        let mut script = format!(
            r#"#compdef {}

_{}() {{
    local -a commands flags

    commands=(
"#,
            self.program_name, self.program_name
        );

        for cmd in &self.commands {
            script.push_str(&format!("        '{}:{}'\n", cmd.name, cmd.description));
        }

        script.push_str("    )\n\n    flags=(\n");

        for flag in &self.global_flags {
            if let Some(short) = flag.short {
                script.push_str(&format!(
                    "        '(-{} --{})'{{{},--{}}}\"[{}]\"\n",
                    short, flag.long, short, flag.long, flag.description
                ));
            } else {
                script.push_str(&format!(
                    "        '--{}[{}]'\n", flag.long, flag.description
                ));
            }
        }

        script.push_str(r#"    )

    _arguments -s $flags ':command:->command' '*::arg:->args'

    case "$state" in
        command)
            _describe 'command' commands
            ;;
    esac
}

"#);
        script.push_str(&format!("compdef _{} {}\n", self.program_name, self.program_name));
        script
    }

    fn gen_fish_completions(&self) -> String {
        let mut script = format!(
            "# Fish completions for {}\n\n",
            self.program_name
        );

        // Commands
        for cmd in &self.commands {
            script.push_str(&format!(
                "complete -c {} -n \"__fish_use_subcommand\" -a {} -d \"{}\"\n",
                self.program_name, cmd.name, cmd.description
            ));
        }

        // Global flags
        for flag in &self.global_flags {
            if let Some(short) = flag.short {
                script.push_str(&format!(
                    "complete -c {} -s {} -l {} -d \"{}\"\n",
                    self.program_name, short, flag.long, flag.description
                ));
            } else {
                script.push_str(&format!(
                    "complete -c {} -l {} -d \"{}\"\n",
                    self.program_name, flag.long, flag.description
                ));
            }
        }

        script
    }

    fn gen_powershell_completions(&self) -> String {
        let mut script = format!(
            r#"# PowerShell completions for {}

Register-ArgumentCompleter -Native -CommandName {} -ScriptBlock {{
    param($wordToComplete, $commandAst, $cursorPosition)

    $commands = @(
"#,
            self.program_name, self.program_name
        );

        for cmd in &self.commands {
            script.push_str(&format!(
                "        [PSCustomObject]@{{ CompletionText='{}'; ToolTip='{}' }}\n",
                cmd.name, cmd.description
            ));
        }

        script.push_str(r#"    )

    $commands | Where-Object { $_.CompletionText -like "$wordToComplete*" }
}
"#);
        script
    }
}

impl Command {
    pub fn new(name: &str) -> Self {
        Command {
            name: name.to_string(),
            description: String::new(),
            aliases: Vec::new(),
            flags: Vec::new(),
            options: Vec::new(),
            args: Vec::new(),
            subcommands: Vec::new(),
            handler: None,
        }
    }

    pub fn description(mut self, desc: &str) -> Self {
        self.description = desc.to_string();
        self
    }

    pub fn alias(mut self, alias: &str) -> Self {
        self.aliases.push(alias.to_string());
        self
    }

    pub fn flag(mut self, flag: Flag) -> Self {
        self.flags.push(flag);
        self
    }

    pub fn option(mut self, opt: CliOption) -> Self {
        self.options.push(opt);
        self
    }

    pub fn arg(mut self, arg: Argument) -> Self {
        self.args.push(arg);
        self
    }

    pub fn subcommand(mut self, cmd: Command) -> Self {
        self.subcommands.push(cmd);
        self
    }

    pub fn handler(mut self, f: fn(&ParsedArgs) -> Result<i32, String>) -> Self {
        self.handler = Some(f);
        self
    }
}

impl Flag {
    pub fn new(long: &str) -> Self {
        Flag {
            short: None,
            long: long.to_string(),
            description: String::new(),
            env_var: None,
        }
    }

    pub fn short(mut self, c: char) -> Self {
        self.short = Some(c);
        self
    }

    pub fn description(mut self, desc: &str) -> Self {
        self.description = desc.to_string();
        self
    }

    pub fn env(mut self, var: &str) -> Self {
        self.env_var = Some(var.to_string());
        self
    }
}

impl CliOption {
    pub fn new(long: &str) -> Self {
        CliOption {
            short: None,
            long: long.to_string(),
            description: String::new(),
            value_name: "VALUE".to_string(),
            default: None,
            env_var: None,
            required: false,
            multiple: false,
            choices: None,
        }
    }

    pub fn short(mut self, c: char) -> Self {
        self.short = Some(c);
        self
    }

    pub fn description(mut self, desc: &str) -> Self {
        self.description = desc.to_string();
        self
    }

    pub fn value_name(mut self, name: &str) -> Self {
        self.value_name = name.to_string();
        self
    }

    pub fn default(mut self, val: &str) -> Self {
        self.default = Some(val.to_string());
        self
    }

    pub fn env(mut self, var: &str) -> Self {
        self.env_var = Some(var.to_string());
        self
    }

    pub fn required(mut self) -> Self {
        self.required = true;
        self
    }

    pub fn multiple(mut self) -> Self {
        self.multiple = true;
        self
    }

    pub fn choices(mut self, vals: Vec<&str>) -> Self {
        self.choices = Some(vals.iter().map(|s| s.to_string()).collect());
        self
    }
}

impl ParsedArgs {
    pub fn has_flag(&self, name: &str) -> bool {
        *self.flags.get(name).unwrap_or(&false)
    }

    pub fn get_option(&self, name: &str) -> Option<&str> {
        self.options.get(name).and_then(|v| v.first()).map(|s| s.as_str())
    }

    pub fn get_options(&self, name: &str) -> Vec<&str> {
        self.options.get(name)
            .map(|v| v.iter().map(|s| s.as_str()).collect())
            .unwrap_or_default()
    }

    pub fn get_arg(&self, index: usize) -> Option<&str> {
        self.args.get(index).map(|s| s.as_str())
    }

    pub fn command_is(&self, name: &str) -> bool {
        self.command.first().map(|s| s.as_str()) == Some(name)
    }
}

#[derive(Clone, Copy)]
pub enum Shell {
    Bash,
    Zsh,
    Fish,
    PowerShell,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TERMINAL OUTPUT STYLING
// ═══════════════════════════════════════════════════════════════════════════════

/// Terminal color and style support
pub struct TermStyle {
    colors_enabled: bool,
}

impl TermStyle {
    pub fn new() -> Self {
        TermStyle {
            colors_enabled: Self::supports_color(),
        }
    }

    fn supports_color() -> bool {
        // Check TERM and NO_COLOR environment variables
        if std::env::var("NO_COLOR").is_ok() {
            return false;
        }
        if let Ok(term) = std::env::var("TERM") {
            return term != "dumb";
        }
        true
    }

    pub fn bold(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[1m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn dim(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[2m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn italic(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[3m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn underline(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[4m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn red(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[31m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn green(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[32m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn yellow(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[33m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn blue(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[34m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn magenta(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[35m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn cyan(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[36m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn white(&self, text: &str) -> String {
        if self.colors_enabled {
            format!("\x1b[37m{}\x1b[0m", text)
        } else {
            text.to_string()
        }
    }

    pub fn rgb(&self, text: &str, r: u8, g: u8, b: u8) -> String {
        if self.colors_enabled {
            format!("\x1b[38;2;{};{};{}m{}\x1b[0m", r, g, b, text)
        } else {
            text.to_string()
        }
    }

    pub fn bg_rgb(&self, text: &str, r: u8, g: u8, b: u8) -> String {
        if self.colors_enabled {
            format!("\x1b[48;2;{};{};{}m{}\x1b[0m", r, g, b, text)
        } else {
            text.to_string()
        }
    }

    pub fn success(&self, text: &str) -> String {
        self.green(&format!("✓ {}", text))
    }

    pub fn error(&self, text: &str) -> String {
        self.red(&format!("✗ {}", text))
    }

    pub fn warning(&self, text: &str) -> String {
        self.yellow(&format!("⚠ {}", text))
    }

    pub fn info(&self, text: &str) -> String {
        self.blue(&format!("ℹ {}", text))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROGRESS INDICATORS
// ═══════════════════════════════════════════════════════════════════════════════

/// Animated spinner for indeterminate progress
pub struct Spinner {
    frames: Vec<&'static str>,
    current: usize,
    message: String,
    style: TermStyle,
    running: bool,
}

impl Spinner {
    pub fn new() -> Self {
        Spinner {
            frames: vec!["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"],
            current: 0,
            message: String::new(),
            style: TermStyle::new(),
            running: false,
        }
    }

    pub fn dots() -> Self {
        Spinner {
            frames: vec!["⣾", "⣽", "⣻", "⢿", "⡿", "⣟", "⣯", "⣷"],
            current: 0,
            message: String::new(),
            style: TermStyle::new(),
            running: false,
        }
    }

    pub fn line() -> Self {
        Spinner {
            frames: vec!["—", "\\", "|", "/"],
            current: 0,
            message: String::new(),
            style: TermStyle::new(),
            running: false,
        }
    }

    pub fn arrow() -> Self {
        Spinner {
            frames: vec!["▹▹▹▹▹", "▸▹▹▹▹", "▹▸▹▹▹", "▹▹▸▹▹", "▹▹▹▸▹", "▹▹▹▹▸"],
            current: 0,
            message: String::new(),
            style: TermStyle::new(),
            running: false,
        }
    }

    pub fn start(&mut self, message: &str) {
        self.message = message.to_string();
        self.running = true;
        self.current = 0;
    }

    pub fn tick(&mut self) {
        if !self.running { return; }

        print!("\r{} {} ",
            self.style.cyan(self.frames[self.current]),
            self.message
        );
        std::io::stdout().flush().ok();

        self.current = (self.current + 1) % self.frames.len();
    }

    pub fn succeed(&mut self, message: &str) {
        self.running = false;
        println!("\r{}", self.style.success(message));
    }

    pub fn fail(&mut self, message: &str) {
        self.running = false;
        println!("\r{}", self.style.error(message));
    }

    pub fn warn(&mut self, message: &str) {
        self.running = false;
        println!("\r{}", self.style.warning(message));
    }

    pub fn stop(&mut self) {
        self.running = false;
        print!("\r\x1b[K"); // Clear line
    }
}

/// Progress bar for determinate progress
pub struct ProgressBar {
    total: u64,
    current: u64,
    width: usize,
    message: String,
    style: TermStyle,
    start_time: Instant,
    show_eta: bool,
    show_speed: bool,
}

impl ProgressBar {
    pub fn new(total: u64) -> Self {
        ProgressBar {
            total,
            current: 0,
            width: 40,
            message: String::new(),
            style: TermStyle::new(),
            start_time: Instant::now(),
            show_eta: true,
            show_speed: false,
        }
    }

    pub fn width(mut self, w: usize) -> Self {
        self.width = w;
        self
    }

    pub fn message(mut self, msg: &str) -> Self {
        self.message = msg.to_string();
        self
    }

    pub fn with_eta(mut self) -> Self {
        self.show_eta = true;
        self
    }

    pub fn with_speed(mut self) -> Self {
        self.show_speed = true;
        self
    }

    pub fn set(&mut self, value: u64) {
        self.current = value.min(self.total);
        self.draw();
    }

    pub fn inc(&mut self, delta: u64) {
        self.current = (self.current + delta).min(self.total);
        self.draw();
    }

    fn draw(&self) {
        let percent = if self.total > 0 {
            self.current as f64 / self.total as f64
        } else {
            0.0
        };

        let filled = (self.width as f64 * percent) as usize;
        let empty = self.width - filled;

        let bar = format!(
            "{}{}",
            "█".repeat(filled),
            "░".repeat(empty)
        );

        let percent_str = format!("{:>3.0}%", percent * 100.0);

        let mut extra = String::new();

        if self.show_eta && self.current > 0 {
            let elapsed = self.start_time.elapsed().as_secs_f64();
            let rate = self.current as f64 / elapsed;
            let remaining = (self.total - self.current) as f64 / rate;
            extra.push_str(&format!(" ETA: {}", format_duration_secs(remaining)));
        }

        if self.show_speed && self.current > 0 {
            let elapsed = self.start_time.elapsed().as_secs_f64();
            let rate = self.current as f64 / elapsed;
            extra.push_str(&format!(" ({:.1}/s)", rate));
        }

        print!("\r{} {} [{}/{}]{}  ",
            self.message,
            self.style.cyan(&bar),
            percent_str,
            self.total,
            extra
        );
        std::io::stdout().flush().ok();
    }

    pub fn finish(&self) {
        println!();
    }

    pub fn finish_with_message(&self, msg: &str) {
        println!("\r{}", self.style.success(msg));
    }
}

fn format_duration_secs(secs: f64) -> String {
    if secs < 60.0 {
        format!("{:.0}s", secs)
    } else if secs < 3600.0 {
        format!("{}m {}s", (secs / 60.0) as u32, (secs % 60.0) as u32)
    } else {
        format!("{}h {}m", (secs / 3600.0) as u32, ((secs % 3600.0) / 60.0) as u32)
    }
}

/// Multi-progress display for parallel tasks
pub struct MultiProgress {
    bars: Vec<ProgressBar>,
    lines: usize,
}

impl MultiProgress {
    pub fn new() -> Self {
        MultiProgress {
            bars: Vec::new(),
            lines: 0,
        }
    }

    pub fn add(&mut self, bar: ProgressBar) -> usize {
        let idx = self.bars.len();
        self.bars.push(bar);
        self.lines += 1;
        idx
    }

    pub fn update(&mut self, index: usize, value: u64) {
        if index < self.bars.len() {
            self.bars[index].set(value);
        }
    }

    pub fn finish(&self) {
        for _ in 0..self.lines {
            println!();
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE WATCHING
// ═══════════════════════════════════════════════════════════════════════════════

/// File watcher for watch mode
pub struct FileWatcher {
    paths: Vec<String>,
    patterns: Vec<String>,
    ignore_patterns: Vec<String>,
    debounce_ms: u64,
    last_change: HashMap<String, u64>,
}

#[derive(Clone)]
pub struct FileChange {
    pub path: String,
    pub kind: ChangeKind,
    pub timestamp: u64,
}

#[derive(Clone, Copy, Debug)]
pub enum ChangeKind {
    Created,
    Modified,
    Deleted,
    Renamed,
}

impl FileWatcher {
    pub fn new() -> Self {
        FileWatcher {
            paths: Vec::new(),
            patterns: vec!["**/*.quanta".to_string()],
            ignore_patterns: vec![
                "**/target/**".to_string(),
                "**/node_modules/**".to_string(),
                "**/.git/**".to_string(),
            ],
            debounce_ms: 100,
            last_change: HashMap::new(),
        }
    }

    pub fn watch(mut self, path: &str) -> Self {
        self.paths.push(path.to_string());
        self
    }

    pub fn pattern(mut self, pattern: &str) -> Self {
        self.patterns.push(pattern.to_string());
        self
    }

    pub fn ignore(mut self, pattern: &str) -> Self {
        self.ignore_patterns.push(pattern.to_string());
        self
    }

    pub fn debounce(mut self, ms: u64) -> Self {
        self.debounce_ms = ms;
        self
    }

    /// Start watching for file changes (blocking)
    pub fn run<F>(&mut self, mut callback: F)
    where
        F: FnMut(&[FileChange]),
    {
        let style = TermStyle::new();
        println!("{}", style.info("Watching for file changes..."));

        loop {
            let changes = self.poll_changes();
            if !changes.is_empty() {
                callback(&changes);
            }
            std::thread::sleep(std::time::Duration::from_millis(100));
        }
    }

    fn poll_changes(&mut self) -> Vec<FileChange> {
        let mut changes = Vec::new();
        let now = Self::current_time_ms();

        for path in &self.paths {
            self.scan_directory(path, &mut changes, now);
        }

        // Apply debouncing
        changes.retain(|c| {
            if let Some(&last) = self.last_change.get(&c.path) {
                if now - last < self.debounce_ms {
                    return false;
                }
            }
            self.last_change.insert(c.path.clone(), now);
            true
        });

        changes
    }

    fn scan_directory(&self, path: &str, changes: &mut Vec<FileChange>, now: u64) {
        // In real implementation, use OS-specific file watching APIs
        // This is a simplified polling approach
    }

    fn matches_pattern(&self, path: &str) -> bool {
        // Check ignore patterns first
        for pattern in &self.ignore_patterns {
            if Self::glob_match(pattern, path) {
                return false;
            }
        }

        // Check include patterns
        for pattern in &self.patterns {
            if Self::glob_match(pattern, path) {
                return true;
            }
        }

        false
    }

    fn glob_match(pattern: &str, path: &str) -> bool {
        // Simplified glob matching
        if pattern.contains("**") {
            let parts: Vec<&str> = pattern.split("**").collect();
            if parts.len() == 2 {
                return path.starts_with(parts[0]) && path.ends_with(parts[1]);
            }
        }
        path.ends_with(pattern.trim_start_matches('*'))
    }

    fn current_time_ms() -> u64 {
        std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_millis() as u64
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Multi-project workspace
#[derive(Clone)]
pub struct Workspace {
    root: String,
    members: Vec<WorkspaceMember>,
    config: WorkspaceConfig,
}

#[derive(Clone)]
pub struct WorkspaceMember {
    name: String,
    path: String,
    dependencies: Vec<String>,
}

#[derive(Clone)]
pub struct WorkspaceConfig {
    parallel_builds: bool,
    shared_cache: bool,
    default_members: Vec<String>,
}

impl Workspace {
    pub fn discover(start_path: &str) -> Option<Self> {
        // Look for quanta-workspace.toml going up the directory tree
        let mut current = std::path::PathBuf::from(start_path);

        loop {
            let workspace_file = current.join("quanta-workspace.toml");
            if workspace_file.exists() {
                return Self::load(&workspace_file.to_string_lossy());
            }

            if !current.pop() {
                return None;
            }
        }
    }

    pub fn load(path: &str) -> Option<Self> {
        // Parse workspace config
        Some(Workspace {
            root: std::path::Path::new(path)
                .parent()
                .map(|p| p.to_string_lossy().to_string())
                .unwrap_or_default(),
            members: Vec::new(),
            config: WorkspaceConfig {
                parallel_builds: true,
                shared_cache: true,
                default_members: Vec::new(),
            },
        })
    }

    pub fn members(&self) -> &[WorkspaceMember] {
        &self.members
    }

    pub fn root(&self) -> &str {
        &self.root
    }

    /// Get build order respecting dependencies
    pub fn build_order(&self) -> Vec<&str> {
        // Topological sort based on dependencies
        let mut order = Vec::new();
        let mut visited = std::collections::HashSet::new();

        fn visit<'a>(
            member: &'a WorkspaceMember,
            members: &'a [WorkspaceMember],
            visited: &mut std::collections::HashSet<String>,
            order: &mut Vec<&'a str>,
        ) {
            if visited.contains(&member.name) {
                return;
            }
            visited.insert(member.name.clone());

            for dep in &member.dependencies {
                if let Some(m) = members.iter().find(|m| &m.name == dep) {
                    visit(m, members, visited, order);
                }
            }

            order.push(&member.name);
        }

        for member in &self.members {
            visit(member, &self.members, &mut visited, &mut order);
        }

        order
    }

    /// Run command for all members
    pub fn run_for_all<F>(&self, f: F) -> Vec<Result<i32, String>>
    where
        F: Fn(&WorkspaceMember) -> Result<i32, String>,
    {
        if self.config.parallel_builds {
            // Parallel execution
            self.members.iter().map(|m| f(m)).collect()
        } else {
            // Sequential based on build order
            let order = self.build_order();
            order.iter()
                .filter_map(|name| self.members.iter().find(|m| &m.name == name))
                .map(|m| f(m))
                .collect()
        }
    }
}

