// PLUGIN SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// CLI plugin interface
pub trait Plugin {
    fn name(&self) -> &str;
    fn description(&self) -> &str;
    fn version(&self) -> &str;

    fn commands(&self) -> Vec<Command>;
    fn hooks(&self) -> Vec<Hook>;

    fn on_load(&mut self) {}
    fn on_unload(&mut self) {}
}

#[derive(Clone)]
pub struct Hook {
    pub event: HookEvent,
    pub handler: fn(&HookContext) -> Result<(), String>,
}

#[derive(Clone, Copy, Debug)]
pub enum HookEvent {
    PreBuild,
    PostBuild,
    PreTest,
    PostTest,
    PreRun,
    PostRun,
    FileChange,
}

pub struct HookContext {
    pub event: HookEvent,
    pub args: HashMap<String, String>,
}

/// Plugin manager
pub struct PluginManager {
    plugins: Vec<Box<dyn Plugin>>,
    plugin_dir: String,
}

impl PluginManager {
    pub fn new() -> Self {
        PluginManager {
            plugins: Vec::new(),
            plugin_dir: "~/.quanta/plugins".to_string(),
        }
    }

    pub fn discover_plugins(&mut self) {
        // Look for plugins in plugin directory
        // Each plugin is a .quanta file or directory with a plugin.quanta entry point
    }

    pub fn load(&mut self, name: &str) -> Result<(), String> {
        // Load and initialize plugin
        Ok(())
    }

    pub fn unload(&mut self, name: &str) -> Result<(), String> {
        // Unload plugin
        Ok(())
    }

    pub fn run_hooks(&self, event: HookEvent, ctx: &HookContext) {
        for plugin in &self.plugins {
            for hook in plugin.hooks() {
                if std::mem::discriminant(&hook.event) == std::mem::discriminant(&event) {
                    (hook.handler)(ctx).ok();
                }
            }
        }
    }

    pub fn list(&self) -> Vec<&str> {
        self.plugins.iter().map(|p| p.name()).collect()
    }
}

