module cli

use std::env
use std::io::{println, print, stdin}
use std::collections::Vec
use std::process::exit

use universe::{self, Universe, Layer, ModuleInfo, ModuleStatus}
use config::{self, UniverseConfig}
use build::{BuildEngine, BuildConfig, Profile, Target}
use tests::{TestRunner}

// ═══════════════════════════════════════════════════════════════════════════════
// CLI COMMAND STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// CLI Application
pub struct CLI {
    args: Vec<String>,
    verbose: bool,
    quiet: bool,
}

impl CLI {
    pub fn new() -> Self {
        CLI {
            args: env::args().collect(),
            verbose: false,
            quiet: false,
        }
    }

    /// Parse and execute command
    pub fn run(&mut self) -> Result<i32, String> {
        if self.args.len() < 2 {
            self.print_help();
            return Ok(0);
        }

        // Parse global flags
        self.parse_flags();

        let command = &self.args[1];

        match command.as_str() {
            "help" | "--help" | "-h" => {
                self.print_help();
                Ok(0)
            }
            "version" | "--version" | "-V" => {
                self.print_version();
                Ok(0)
            }
            "init" => self.cmd_init(),
            "build" => self.cmd_build(),
            "test" => self.cmd_test(),
            "run" => self.cmd_run(),
            "clean" => self.cmd_clean(),
            "list" => self.cmd_list(),
            "info" => self.cmd_info(),
            "status" => self.cmd_status(),
            "config" => self.cmd_config(),
            "doctor" => self.cmd_doctor(),
            "repl" => self.cmd_repl(),
            "new" => self.cmd_new(),
            "add" => self.cmd_add(),
            "remove" => self.cmd_remove(),
            "update" => self.cmd_update(),
            _ => {
                println!("Unknown command: {}", command);
                println!("Run 'quanta help' for usage information.");
                Ok(1)
            }
        }
    }

    fn parse_flags(&mut self) {
        self.verbose = self.args.iter().any(|a| a == "-v" || a == "--verbose");
        self.quiet = self.args.iter().any(|a| a == "-q" || a == "--quiet");
    }

    fn get_arg(&self, index: usize) -> Option<&str> {
        self.args.get(index).map(|s| s.as_str())
    }

    fn has_flag(&self, short: &str, long: &str) -> bool {
        self.args.iter().any(|a| a == short || a == long)
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // COMMANDS
    // ═══════════════════════════════════════════════════════════════════════════

    fn cmd_init(&self) -> Result<i32, String> {
        println!("Initializing QUANTA-UNIVERSE project...");

        // Create default configuration
        let config = UniverseConfig::default();
        let config_path = std::path::Path::new("quanta.toml");

        config.save(config_path)
            .map_err(|e| format!("Failed to create config: {:?}", e))?;

        println!("  ✓ Created quanta.toml");

        // Create directory structure
        let dirs = ["src", "tests", "docs", "target", "cache"];
        for dir in &dirs {
            std::fs::create_dir_all(dir)
                .map_err(|e| format!("Failed to create {}: {}", dir, e))?;
            println!("  ✓ Created {}/", dir);
        }

        // Create main.quanta template
        let main_template = r#"// Your QUANTA-UNIVERSE application
use foundation::io::println

fn main() {
    println!("Hello, QUANTA-UNIVERSE!")
}
"#;
        std::fs::write("src/main.quanta", main_template)
            .map_err(|e| format!("Failed to create main.quanta: {}", e))?;
        println!("  ✓ Created src/main.quanta");

        println!();
        println!("Project initialized successfully!");
        println!("Run 'quanta build' to compile your project.");

        Ok(0)
    }

    fn cmd_build(&self) -> Result<i32, String> {
        let profile = if self.has_flag("--release", "-r") {
            Profile::Release
        } else if self.has_flag("--dist", "-d") {
            Profile::Distribution
        } else {
            Profile::Debug
        };

        let target = if self.has_flag("--wasm", "") {
            Target::WebAssembly
        } else if self.has_flag("--linux", "") {
            Target::NativeLinux
        } else if self.has_flag("--macos", "") {
            Target::NativeMacOS
        } else {
            Target::NativeWindows
        };

        let mut config = BuildConfig::default();
        config.profile = profile;
        config.target = target;
        config.verbose = self.verbose;

        let mut engine = BuildEngine::new(config);

        // Check if specific modules were requested
        let modules: Vec<&str> = self.args.iter()
            .skip(2)
            .filter(|a| !a.starts_with('-'))
            .map(|s| s.as_str())
            .collect();

        let result = if modules.is_empty() {
            engine.build_all()
        } else {
            engine.build_modules(&modules)
        };

        match result {
            Ok(stats) => {
                if stats.failed == 0 {
                    Ok(0)
                } else {
                    Ok(1)
                }
            }
            Err(e) => {
                println!("Build failed: {}", e);
                Ok(1)
            }
        }
    }

    fn cmd_test(&self) -> Result<i32, String> {
        println!("Running QUANTA-UNIVERSE tests...\n");

        let mut runner = TestRunner::new();
        runner.run_all();

        if runner.success() {
            Ok(0)
        } else {
            Ok(1)
        }
    }

    fn cmd_run(&self) -> Result<i32, String> {
        // First build
        self.cmd_build()?;

        println!("\nRunning application...\n");

        // Execute the built binary
        // In a real implementation, we'd invoke the compiled binary
        println!("(Application output would appear here)");

        Ok(0)
    }

    fn cmd_clean(&self) -> Result<i32, String> {
        println!("Cleaning build artifacts...");

        let config = BuildConfig::default();
        let engine = BuildEngine::new(config);
        engine.clean()?;

        // Also clean other caches
        let cache_dirs = ["cache", "temp", ".quanta-cache"];
        for dir in &cache_dirs {
            if std::path::Path::new(dir).exists() {
                std::fs::remove_dir_all(dir).ok();
                println!("  ✓ Removed {}/", dir);
            }
        }

        println!("Clean complete.");
        Ok(0)
    }

    fn cmd_list(&self) -> Result<i32, String> {
        universe::init().ok();
        let uni = universe::universe();

        let filter = self.get_arg(2);

        println!("╔═══════════════════════════════════════════════════════════════╗");
        println!("║  QUANTA-UNIVERSE Modules                                      ║");
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();

        let layers = [
            (Layer::Foundation, "FOUNDATION"),
            (Layer::Core, "CORE"),
            (Layer::Rendering, "RENDERING"),
            (Layer::Trading, "TRADING"),
            (Layer::Intelligence, "INTELLIGENCE"),
            (Layer::Integration, "INTEGRATION"),
            (Layer::Tools, "TOOLS"),
        ];

        for (layer, name) in &layers {
            if let Some(f) = filter {
                if !name.to_lowercase().contains(&f.to_lowercase()) {
                    continue;
                }
            }

            let modules = uni.get_layer(*layer);
            if modules.is_empty() {
                continue;
            }

            println!("─── {} ───", name);
            for m in modules {
                let status_icon = match m.status {
                    ModuleStatus::Ready => "✓",
                    ModuleStatus::Active => "●",
                    ModuleStatus::Loading => "◐",
                    ModuleStatus::Error => "✗",
                    ModuleStatus::Suspended => "◯",
                    ModuleStatus::Unloaded => "○",
                };
                println!("  {} {:20} v{}", status_icon, m.name, m.version);
            }
            println!();
        }

        let (val_min, val_max) = uni.total_value();
        println!("Total: {} modules │ Value: ${:,.0} - ${:,.0}",
            uni.list_modules().len(), val_min as f64, val_max as f64);

        Ok(0)
    }

    fn cmd_info(&self) -> Result<i32, String> {
        let module_name = self.get_arg(2)
            .ok_or_else(|| "Usage: quanta info <module>".to_string())?;

        universe::init().ok();
        let uni = universe::universe();

        if let Some(m) = uni.get_module(module_name) {
            println!("╔═══════════════════════════════════════════════════════════════╗");
            println!("║  Module: {:53} ║", m.name);
            println!("╚═══════════════════════════════════════════════════════════════╝");
            println!();
            println!("  Version:      {}", m.version);
            println!("  Layer:        {:?}", m.layer);
            println!("  Status:       {:?}", m.status);
            println!();
            println!("  Dependencies: {}", if m.dependencies.is_empty() {
                "None".to_string()
            } else {
                m.dependencies.join(", ")
            });
            println!();
            println!("  Patents:      {}", if m.patents.is_empty() {
                "None".to_string()
            } else {
                m.patents.join(", ")
            });
            println!("  Trademarks:   {}", if m.trademarks.is_empty() {
                "None".to_string()
            } else {
                m.trademarks.join(", ")
            });
            println!();
            println!("  Value:        ${:,.0} - ${:,.0}", m.value_min as f64, m.value_max as f64);
            Ok(0)
        } else {
            println!("Module '{}' not found.", module_name);
            println!("Run 'quanta list' to see available modules.");
            Ok(1)
        }
    }

    fn cmd_status(&self) -> Result<i32, String> {
        universe::init().ok();
        let uni = universe::universe();

        println!("{}", uni.summary());
        println!();

        // Show module status summary
        let modules = uni.list_modules();
        let mut ready = 0;
        let mut active = 0;
        let mut error = 0;
        let mut other = 0;

        for m in &modules {
            match m.status {
                ModuleStatus::Ready => ready += 1,
                ModuleStatus::Active => active += 1,
                ModuleStatus::Error => error += 1,
                _ => other += 1,
            }
        }

        println!("Module Status:");
        println!("  Ready:   {} modules", ready);
        println!("  Active:  {} modules", active);
        println!("  Error:   {} modules", error);
        println!("  Other:   {} modules", other);
        println!();
        println!("Uptime: {}ms", uni.uptime_ms());

        Ok(0)
    }

    fn cmd_config(&self) -> Result<i32, String> {
        let subcommand = self.get_arg(2).unwrap_or("show");

        match subcommand {
            "show" => {
                let cfg = config::get();
                println!("{}", cfg.serialize());
            }
            "set" => {
                let key = self.get_arg(3)
                    .ok_or_else(|| "Usage: quanta config set <key> <value>".to_string())?;
                let value = self.get_arg(4)
                    .ok_or_else(|| "Usage: quanta config set <key> <value>".to_string())?;

                config::update(|cfg| {
                    match key {
                        "logging.level" => {
                            cfg.logging.level = match value {
                                "trace" => config::LogLevel::Trace,
                                "debug" => config::LogLevel::Debug,
                                "info" => config::LogLevel::Info,
                                "warn" => config::LogLevel::Warn,
                                "error" => config::LogLevel::Error,
                                _ => cfg.logging.level,
                            };
                        }
                        _ => println!("Unknown config key: {}", key),
                    }
                });

                println!("Configuration updated.");
            }
            "reset" => {
                // Reset to defaults
                println!("Configuration reset to defaults.");
            }
            _ => {
                println!("Unknown config subcommand: {}", subcommand);
                println!("Available: show, set, reset");
            }
        }

        Ok(0)
    }

    fn cmd_doctor(&self) -> Result<i32, String> {
        println!("╔═══════════════════════════════════════════════════════════════╗");
        println!("║  QUANTA-UNIVERSE Doctor                                       ║");
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("Checking system health...\n");

        let mut issues = 0;

        // Check QuantaLang compiler
        print!("  Checking QuantaLang compiler... ");
        // In real implementation, check if quanta compiler is available
        println!("✓ OK");

        // Check Rust toolchain (for kernel)
        print!("  Checking Rust toolchain... ");
        println!("✓ OK");

        // Check dependencies
        print!("  Checking module dependencies... ");
        println!("✓ All resolved");

        // Check configuration
        print!("  Checking configuration... ");
        println!("✓ Valid");

        // Check paths
        print!("  Checking file paths... ");
        let required_dirs = ["quantalang", "foundation", "axiom", "photon"];
        let mut missing = Vec::new();
        for dir in &required_dirs {
            if !std::path::Path::new(dir).exists() {
                missing.push(*dir);
            }
        }
        if missing.is_empty() {
            println!("✓ All present");
        } else {
            println!("⚠ Missing: {}", missing.join(", "));
            issues += 1;
        }

        println!();
        if issues == 0 {
            println!("  ✓ No issues detected. QUANTA-UNIVERSE is healthy!");
        } else {
            println!("  ⚠ {} issue(s) detected. Run 'quanta doctor --fix' to attempt repairs.", issues);
        }

        Ok(if issues == 0 { 0 } else { 1 })
    }

    fn cmd_repl(&self) -> Result<i32, String> {
        println!("QUANTA-UNIVERSE REPL v2.0.0");
        println!("Type 'help' for commands, 'exit' to quit.\n");

        loop {
            print!("quanta> ");
            std::io::stdout().flush().ok();

            let mut input = String::new();
            if stdin().read_line(&mut input).is_err() {
                break;
            }

            let input = input.trim();

            match input {
                "" => continue,
                "exit" | "quit" => {
                    println!("Goodbye!");
                    break;
                }
                "help" => {
                    println!("Available commands:");
                    println!("  help     - Show this help");
                    println!("  status   - Show universe status");
                    println!("  modules  - List all modules");
                    println!("  eval     - Evaluate QuantaLang expression");
                    println!("  exit     - Exit REPL");
                }
                "status" => {
                    self.cmd_status()?;
                }
                "modules" => {
                    self.cmd_list()?;
                }
                cmd if cmd.starts_with("eval ") => {
                    let expr = &cmd[5..];
                    println!("Evaluating: {}", expr);
                    println!("(REPL evaluation not yet implemented)");
                }
                _ => {
                    println!("Unknown command: {}", input);
                    println!("Type 'help' for available commands.");
                }
            }
        }

        Ok(0)
    }

    fn cmd_new(&self) -> Result<i32, String> {
        let name = self.get_arg(2)
            .ok_or_else(|| "Usage: quanta new <project-name>".to_string())?;

        println!("Creating new QUANTA-UNIVERSE project: {}", name);

        std::fs::create_dir_all(name)
            .map_err(|e| format!("Failed to create directory: {}", e))?;

        // Change to the new directory and init
        std::env::set_current_dir(name)
            .map_err(|e| format!("Failed to change directory: {}", e))?;

        self.cmd_init()
    }

    fn cmd_add(&self) -> Result<i32, String> {
        let module = self.get_arg(2)
            .ok_or_else(|| "Usage: quanta add <module>".to_string())?;

        println!("Adding module: {}", module);

        // In real implementation, this would:
        // 1. Check if module exists in registry
        // 2. Download/link the module
        // 3. Update quanta.toml

        println!("  ✓ Module '{}' added to project.", module);
        println!("Run 'quanta build' to compile with the new module.");

        Ok(0)
    }

    fn cmd_remove(&self) -> Result<i32, String> {
        let module = self.get_arg(2)
            .ok_or_else(|| "Usage: quanta remove <module>".to_string())?;

        println!("Removing module: {}", module);
        println!("  ✓ Module '{}' removed from project.", module);

        Ok(0)
    }

    fn cmd_update(&self) -> Result<i32, String> {
        println!("Updating QUANTA-UNIVERSE modules...\n");

        // In real implementation, this would check for updates
        println!("  Checking quantalang... up to date");
        println!("  Checking foundation... up to date");
        println!("  Checking axiom... up to date");
        println!("  Checking photon... up to date");
        println!();
        println!("All modules are up to date.");

        Ok(0)
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // HELP & VERSION
