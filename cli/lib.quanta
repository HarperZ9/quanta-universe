// AUDIT LOGGING & COMPLIANCE
// ═══════════════════════════════════════════════════════════════════════════════

/// Audit logger for compliance and security
pub struct AuditLogger {
    backend: Box<dyn AuditBackend>,
    context: AuditContext,
    enabled: bool,
}

pub trait AuditBackend: Send + Sync {
    fn log(&self, event: &AuditEvent) -> Result<(), String>;
    fn query(&self, filter: &AuditFilter) -> Result<Vec<AuditEvent>, String>;
}

#[derive(Clone)]
pub struct AuditEvent {
    id: String,
    timestamp: u64,
    event_type: AuditEventType,
    action: String,
    resource: String,
    user: String,
    ip_address: Option<String>,
    user_agent: Option<String>,
    result: AuditResult,
    details: HashMap<String, String>,
}

#[derive(Clone, Copy, Debug)]
pub enum AuditEventType {
    Authentication,
    Authorization,
    DataAccess,
    Configuration,
    Deployment,
    Build,
    System,
}

#[derive(Clone, Copy, Debug)]
pub enum AuditResult {
    Success,
    Failure,
    Denied,
}

#[derive(Clone)]
pub struct AuditContext {
    user: Option<String>,
    session_id: Option<String>,
    ip_address: Option<String>,
    user_agent: Option<String>,
}

#[derive(Clone, Default)]
pub struct AuditFilter {
    start_time: Option<u64>,
    end_time: Option<u64>,
    event_types: Vec<AuditEventType>,
    user: Option<String>,
    action: Option<String>,
    resource: Option<String>,
    result: Option<AuditResult>,
    limit: Option<usize>,
}

impl AuditLogger {
    pub fn new<B: AuditBackend + 'static>(backend: B) -> Self {
        AuditLogger {
            backend: Box::new(backend),
            context: AuditContext {
                user: None,
                session_id: None,
                ip_address: None,
                user_agent: None,
            },
            enabled: true,
        }
    }

    pub fn with_context(mut self, ctx: AuditContext) -> Self {
        self.context = ctx;
        self
    }

    pub fn log(&self, event_type: AuditEventType, action: &str, resource: &str, result: AuditResult) {
        if !self.enabled {
            return;
        }

        let event = AuditEvent {
            id: generate_uuid(),
            timestamp: current_time_ms(),
            event_type,
            action: action.to_string(),
            resource: resource.to_string(),
            user: self.context.user.clone().unwrap_or_else(|| "anonymous".to_string()),
            ip_address: self.context.ip_address.clone(),
            user_agent: self.context.user_agent.clone(),
            result,
            details: HashMap::new(),
        };

        self.backend.log(&event).ok();
    }

    pub fn log_with_details(
        &self,
        event_type: AuditEventType,
        action: &str,
        resource: &str,
        result: AuditResult,
        details: HashMap<String, String>,
    ) {
        if !self.enabled {
            return;
        }

        let event = AuditEvent {
            id: generate_uuid(),
            timestamp: current_time_ms(),
            event_type,
            action: action.to_string(),
            resource: resource.to_string(),
            user: self.context.user.clone().unwrap_or_else(|| "anonymous".to_string()),
            ip_address: self.context.ip_address.clone(),
            user_agent: self.context.user_agent.clone(),
            result,
            details,
        };

        self.backend.log(&event).ok();
    }

    pub fn query(&self, filter: &AuditFilter) -> Result<Vec<AuditEvent>, String> {
        self.backend.query(filter)
    }
}

/// File-based audit backend
pub struct FileAuditBackend {
    path: String,
    max_size: u64,
    rotate: bool,
}

impl FileAuditBackend {
    pub fn new(path: &str) -> Self {
        FileAuditBackend {
            path: path.to_string(),
            max_size: 100 * 1024 * 1024, // 100MB
            rotate: true,
        }
    }
}

impl AuditBackend for FileAuditBackend {
    fn log(&self, event: &AuditEvent) -> Result<(), String> {
        let line = format!("{} {} {} {} {} {:?}\n",
            event.timestamp,
            event.user,
            event.action,
            event.resource,
            match event.result {
                AuditResult::Success => "SUCCESS",
                AuditResult::Failure => "FAILURE",
                AuditResult::Denied => "DENIED",
            },
            event.event_type,
        );

        std::fs::OpenOptions::new()
            .create(true)
            .append(true)
            .open(&self.path)
            .and_then(|mut f| {
                use std::io::Write;
                f.write_all(line.as_bytes())
            })
            .map_err(|e| e.to_string())
    }

    fn query(&self, filter: &AuditFilter) -> Result<Vec<AuditEvent>, String> {
        // In real implementation, parse and filter log file
        Ok(Vec::new())
    }
}

