// CONFIGURATION FILE SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// CLI configuration loaded from file or environment
#[derive(Clone)]
pub struct CliConfig {
    pub default_profile: String,
    pub default_target: String,
    pub colors: bool,
    pub parallel_jobs: usize,
    pub cache_dir: String,
    pub registry_url: String,
    pub auth_token: Option<String>,
}

impl CliConfig {
    pub fn load() -> Self {
        let mut config = CliConfig::default();

        // Load from file
        let config_paths = [
            "quanta.toml",
            ".quanta/config.toml",
            "~/.config/quanta/config.toml",
        ];

        for path in &config_paths {
            if let Ok(content) = std::fs::read_to_string(path) {
                config.merge_from_toml(&content);
            }
        }

        // Override from environment
        if let Ok(profile) = std::env::var("QUANTA_PROFILE") {
            config.default_profile = profile;
        }
        if let Ok(target) = std::env::var("QUANTA_TARGET") {
            config.default_target = target;
        }
        if std::env::var("NO_COLOR").is_ok() {
            config.colors = false;
        }
        if let Ok(jobs) = std::env::var("QUANTA_JOBS") {
            if let Ok(n) = jobs.parse() {
                config.parallel_jobs = n;
            }
        }
        if let Ok(token) = std::env::var("QUANTA_TOKEN") {
            config.auth_token = Some(token);
        }

        config
    }

    fn merge_from_toml(&mut self, _content: &str) {
        // Parse TOML and update config
    }
}

impl Default for CliConfig {
    fn default() -> Self {
        CliConfig {
            default_profile: "debug".to_string(),
            default_target: "native".to_string(),
            colors: true,
            parallel_jobs: num_cpus(),
            cache_dir: "~/.cache/quanta".to_string(),
            registry_url: "https://registry.quanta-universe.dev".to_string(),
            auth_token: None,
        }
    }
}

fn num_cpus() -> usize {
    // In real implementation, detect CPU count
    4
}

