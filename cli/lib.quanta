/// CLI telemetry collector
pub struct TelemetryCollector {
    enabled: bool,
    endpoint: Option<String>,
    events: Vec<TelemetryEvent>,
    session_id: String,
    user_id: Option<String>,
}

#[derive(Clone)]
pub struct TelemetryEvent {
    name: String,
    properties: HashMap<String, String>,
    metrics: HashMap<String, f64>,
    timestamp: u64,
}

impl TelemetryCollector {
    pub fn new() -> Self {
        TelemetryCollector {
            enabled: Self::is_enabled(),
            endpoint: None,
            events: Vec::new(),
            session_id: generate_uuid(),
            user_id: None,
        }
    }

    fn is_enabled() -> bool {
        // Respect DO_NOT_TRACK and similar env vars
        if std::env::var("DO_NOT_TRACK").is_ok() {
            return false;
        }
        if std::env::var("QUANTA_TELEMETRY_OPTOUT").is_ok() {
            return false;
        }
        true
    }

    pub fn disable(&mut self) {
        self.enabled = false;
    }

    pub fn track(&mut self, name: &str) {
        if !self.enabled { return; }

        self.events.push(TelemetryEvent {
            name: name.to_string(),
            properties: HashMap::new(),
            metrics: HashMap::new(),
            timestamp: current_time_ms(),
        });
    }

    pub fn track_with_props(&mut self, name: &str, props: HashMap<String, String>) {
        if !self.enabled { return; }

        self.events.push(TelemetryEvent {
            name: name.to_string(),
            properties: props,
            metrics: HashMap::new(),
            timestamp: current_time_ms(),
        });
    }

    pub fn track_metric(&mut self, name: &str, value: f64) {
        if !self.enabled { return; }

        let mut metrics = HashMap::new();
        metrics.insert("value".to_string(), value);

        self.events.push(TelemetryEvent {
            name: name.to_string(),
            properties: HashMap::new(),
            metrics,
            timestamp: current_time_ms(),
        });
    }

    pub fn flush(&mut self) -> Result<(), String> {
        if !self.enabled || self.events.is_empty() {
            return Ok(());
        }

        if let Some(ref endpoint) = self.endpoint {
            // In real implementation, send events to endpoint
        }

        self.events.clear();
        Ok(())
    }
}

