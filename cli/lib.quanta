// JOB QUEUE & SCHEDULING
// ═══════════════════════════════════════════════════════════════════════════════

/// Distributed job queue
pub struct JobQueue {
    jobs: HashMap<String, Job>,
    pending: VecDeque<String>,
    running: HashMap<String, String>, // job_id -> worker_id
    completed: HashMap<String, JobResult>,
    max_concurrent: usize,
}

#[derive(Clone)]
pub struct Job {
    id: String,
    name: String,
    command: String,
    args: Vec<String>,
    env: HashMap<String, String>,
    working_dir: Option<String>,
    timeout: Option<u64>,
    retries: u32,
    priority: i32,
    depends_on: Vec<String>,
    schedule: Option<Schedule>,
    metadata: HashMap<String, String>,
}

#[derive(Clone, Copy, Debug)]
pub enum JobStatus {
    Pending,
    Queued,
    Running,
    Completed,
    Failed,
    Cancelled,
    Retrying,
}

#[derive(Clone)]
pub struct JobResult {
    job_id: String,
    status: JobStatus,
    exit_code: Option<i32>,
    stdout: String,
    stderr: String,
    started_at: u64,
    finished_at: u64,
    attempts: u32,
}

#[derive(Clone)]
pub enum Schedule {
    Once(u64),           // Unix timestamp
    Cron(String),        // Cron expression
    Interval(u64),       // Milliseconds
    Daily(u8, u8),       // Hour, minute
    Weekly(u8, u8, u8),  // Day of week, hour, minute
}

impl JobQueue {
    pub fn new() -> Self {
        JobQueue {
            jobs: HashMap::new(),
            pending: VecDeque::new(),
            running: HashMap::new(),
            completed: HashMap::new(),
            max_concurrent: 4,
        }
    }

    pub fn with_max_concurrent(mut self, n: usize) -> Self {
        self.max_concurrent = n;
        self
    }

    pub fn submit(&mut self, job: Job) -> String {
        let id = job.id.clone();
        self.jobs.insert(id.clone(), job);
        self.pending.push_back(id.clone());
        id
    }

    pub fn cancel(&mut self, job_id: &str) -> Result<(), String> {
        if let Some(pos) = self.pending.iter().position(|id| id == job_id) {
            self.pending.remove(pos);
            return Ok(());
        }

        if self.running.contains_key(job_id) {
            // Signal cancellation to worker
            self.running.remove(job_id);
            return Ok(());
        }

        Err("Job not found or already completed".to_string())
    }

    pub fn get_status(&self, job_id: &str) -> Option<JobStatus> {
        if self.pending.iter().any(|id| id == job_id) {
            return Some(JobStatus::Pending);
        }
        if self.running.contains_key(job_id) {
            return Some(JobStatus::Running);
        }
        if let Some(result) = self.completed.get(job_id) {
            return Some(result.status);
        }
        None
    }

    pub fn process(&mut self) {
        while self.running.len() < self.max_concurrent {
            if let Some(job_id) = self.next_runnable_job() {
                self.start_job(&job_id);
            } else {
                break;
            }
        }
    }

    fn next_runnable_job(&self) -> Option<String> {
        for job_id in &self.pending {
            let job = self.jobs.get(job_id)?;

            // Check dependencies
            let deps_satisfied = job.depends_on.iter()
                .all(|dep| self.completed.contains_key(dep));

            if deps_satisfied {
                return Some(job_id.clone());
            }
        }
        None
    }

    fn start_job(&mut self, job_id: &str) {
        if let Some(pos) = self.pending.iter().position(|id| id == job_id) {
            self.pending.remove(pos);
            self.running.insert(job_id.to_string(), "worker_0".to_string());
        }
    }
}

impl Job {
    pub fn new(name: &str, command: &str) -> Self {
        Job {
            id: generate_uuid(),
            name: name.to_string(),
            command: command.to_string(),
            args: Vec::new(),
            env: HashMap::new(),
            working_dir: None,
            timeout: None,
            retries: 0,
            priority: 0,
            depends_on: Vec::new(),
            schedule: None,
            metadata: HashMap::new(),
        }
    }

    pub fn arg(mut self, arg: &str) -> Self {
        self.args.push(arg.to_string());
        self
    }

    pub fn args(mut self, args: &[&str]) -> Self {
        self.args.extend(args.iter().map(|s| s.to_string()));
        self
    }

    pub fn env(mut self, key: &str, value: &str) -> Self {
        self.env.insert(key.to_string(), value.to_string());
        self
    }

    pub fn working_dir(mut self, dir: &str) -> Self {
        self.working_dir = Some(dir.to_string());
        self
    }

    pub fn timeout(mut self, ms: u64) -> Self {
        self.timeout = Some(ms);
        self
    }

    pub fn retries(mut self, n: u32) -> Self {
        self.retries = n;
        self
    }

    pub fn priority(mut self, p: i32) -> Self {
        self.priority = p;
        self
    }

    pub fn depends_on(mut self, job_id: &str) -> Self {
        self.depends_on.push(job_id.to_string());
        self
    }

    pub fn schedule(mut self, s: Schedule) -> Self {
        self.schedule = Some(s);
        self
    }
}

/// Task scheduler with cron support
pub struct TaskScheduler {
    tasks: Vec<ScheduledTask>,
    running: bool,
}

#[derive(Clone)]
pub struct ScheduledTask {
    id: String,
    name: String,
    schedule: Schedule,
    command: String,
    last_run: Option<u64>,
    next_run: Option<u64>,
    enabled: bool,
}

impl TaskScheduler {
    pub fn new() -> Self {
        TaskScheduler {
            tasks: Vec::new(),
            running: false,
        }
    }

    pub fn add_task(&mut self, task: ScheduledTask) {
        self.tasks.push(task);
    }

    pub fn remove_task(&mut self, id: &str) {
        self.tasks.retain(|t| t.id != id);
    }

    pub fn start(&mut self) {
        self.running = true;

        while self.running {
            let now = current_time_ms();

            for task in &mut self.tasks {
                if !task.enabled {
                    continue;
                }

                if let Some(next) = task.next_run {
                    if now >= next {
                        self.run_task(task);
                        task.last_run = Some(now);
                        task.next_run = self.calculate_next_run(&task.schedule, now);
                    }
                }
            }

            std::thread::sleep(std::time::Duration::from_secs(1));
        }
    }

    pub fn stop(&mut self) {
        self.running = false;
    }

    fn run_task(&self, task: &ScheduledTask) {
        println!("Running scheduled task: {}", task.name);
        // Execute task command
    }

    fn calculate_next_run(&self, schedule: &Schedule, now: u64) -> Option<u64> {
        match schedule {
            Schedule::Once(_) => None, // Only runs once
            Schedule::Interval(ms) => Some(now + ms),
            Schedule::Cron(expr) => self.parse_cron_next(expr, now),
            Schedule::Daily(hour, minute) => {
                // Calculate next daily run
                Some(now + 86400000) // Simplified
            }
            Schedule::Weekly(day, hour, minute) => {
                // Calculate next weekly run
                Some(now + 604800000) // Simplified
            }
        }
    }

    fn parse_cron_next(&self, _expr: &str, _now: u64) -> Option<u64> {
        // Parse cron expression and calculate next run
        None
    }
}

