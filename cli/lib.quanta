    fn print_help(&self) {
        println!(r#"
QUANTA-UNIVERSE CLI v2.0.0
The Complete Physics-Inspired Software Universe

USAGE:
    quanta <COMMAND> [OPTIONS] [ARGS]

COMMANDS:
    init        Initialize a new QUANTA-UNIVERSE project
    new         Create a new project in a new directory
    build       Build the project or specific modules
    run         Build and run the project
    test        Run the test suite
    clean       Remove build artifacts

    list        List all available modules
    info        Show detailed module information
    status      Show universe status
    add         Add a module to the project
    remove      Remove a module from the project
    update      Update modules to latest versions

    config      View or modify configuration
    doctor      Check system health and dependencies
    repl        Start interactive REPL

    help        Show this help message
    version     Show version information

OPTIONS:
    -v, --verbose    Enable verbose output
    -q, --quiet      Suppress output
    -r, --release    Build in release mode
    -d, --dist       Build for distribution

BUILD TARGETS:
    --wasm       Build for WebAssembly
    --linux      Build for Linux
    --macos      Build for macOS
    (default)    Build for Windows

EXAMPLES:
    quanta new my-project         Create a new project
    quanta build --release        Build in release mode
    quanta build photon oracle    Build specific modules
    quanta test                   Run all tests
    quanta info quantum-finance   Show module details
    quanta repl                   Start interactive mode

For more information, visit: https://quanta-universe.dev
"#);
    }

    fn print_version(&self) {
        println!("QUANTA-UNIVERSE CLI v2.0.0");
        println!("QuantaLang Compiler v1.0.0");
        println!();
        println!("Copyright © 2024-2025 Zain Dana Harper. All Rights Reserved.");
        println!("22 Modules │ MIT License");
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN ENTRY POINT
// ═══════════════════════════════════════════════════════════════════════════════

pub fn main() -> i32 {
    let mut cli = CLI::new();

    match cli.run() {
        Ok(code) => code,
        Err(e) => {
            eprintln!("Error: {}", e);
            1
        }
    }
}

