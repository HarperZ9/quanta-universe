            Self { distortion_k1: 0.0, distortion_k2: 0.0, distortion_k3: 0.0, chromatic_aberration: 0.0, vignette_intensity: 0.3,
                vignette_roundness: 1.0, vignette_smoothness: 0.5, lens_flare_intensity: 0.0, lens_flare_threshold: 0.9, lens_dirt_intensity: 0.0, anamorphic_squeeze: 1.0, anamorphic_bloom: false }
        }
    }

    #[derive(Debug, Clone)]
    pub struct ColorGradingSettings {
        pub lift: [f32; 3],
        pub gamma: [f32; 3],
        pub gain: [f32; 3],
        pub offset: [f32; 3],
        pub saturation: f32,
        pub contrast: f32,
        pub temperature: f32,
        pub tint: f32,
        pub shadows: [f32; 3],
        pub midtones: [f32; 3],
        pub highlights: [f32; 3],
        pub shadow_balance: f32,
        pub highlight_balance: f32,
        pub hue_shift: f32,
        pub vibrance: f32,
    }

    impl Default for ColorGradingSettings {
        fn default() -> Self {
            Self { lift: [0.0; 3], gamma: [1.0; 3], gain: [1.0; 3], offset: [0.0; 3], saturation: 1.0, contrast: 1.0,
                temperature: 0.0, tint: 0.0, shadows: [1.0; 3], midtones: [1.0; 3], highlights: [1.0; 3],
                shadow_balance: 0.0, highlight_balance: 0.0, hue_shift: 0.0, vibrance: 0.0 }
        }
    }

    impl ColorGradingSettings {
        pub fn apply_lift_gamma_gain(&self, color: [f32; 3]) -> [f32; 3] {
            let mut result = color;
            for i in 0..3 {
                result[i] = result[i] + self.lift[i];
                result[i] = result[i].powf(1.0 / self.gamma[i]);
                result[i] = result[i] * self.gain[i];
                result[i] = result[i] + self.offset[i];
            }
            result
        }

        pub fn apply_temperature_tint(&self, color: [f32; 3]) -> [f32; 3] {
            let temp_shift = self.temperature * 0.1;
            let tint_shift = self.tint * 0.1;
            [color[0] + temp_shift, color[1] + tint_shift, color[2] - temp_shift]
        }

        pub fn apply_saturation(&self, color: [f32; 3]) -> [f32; 3] {
            let luma = 0.299 * color[0] + 0.587 * color[1] + 0.114 * color[2];
            [luma + (color[0] - luma) * self.saturation, luma + (color[1] - luma) * self.saturation, luma + (color[2] - luma) * self.saturation]
        }

        pub fn apply_contrast(&self, color: [f32; 3]) -> [f32; 3] {
            [(color[0] - 0.5) * self.contrast + 0.5, (color[1] - 0.5) * self.contrast + 0.5, (color[2] - 0.5) * self.contrast + 0.5]
        }

        pub fn apply_vibrance(&self, color: [f32; 3]) -> [f32; 3] {
            let luma = 0.299 * color[0] + 0.587 * color[1] + 0.114 * color[2];
            let max_c = color[0].max(color[1]).max(color[2]);
            let min_c = color[0].min(color[1]).min(color[2]);
            let sat = if max_c > 0.0 { (max_c - min_c) / max_c } else { 0.0 };
            let vibrance_factor = 1.0 + self.vibrance * (1.0 - sat);
            [luma + (color[0] - luma) * vibrance_factor, luma + (color[1] - luma) * vibrance_factor, luma + (color[2] - luma) * vibrance_factor]
        }
    }

    #[derive(Debug, Clone)]
    pub struct TonemapSettings {
        pub operator: TonemapOperator,
        pub exposure: f32,
        pub white_point: f32,
        pub shoulder_strength: f32,
        pub linear_strength: f32,
        pub linear_angle: f32,
        pub toe_strength: f32,
        pub toe_numerator: f32,
        pub toe_denominator: f32,
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum TonemapOperator { Linear, Reinhard, ReinhardExtended, HableFilmic, ACES, ACESFitted, AgX, Khronos, Neutral, Custom }

    impl Default for TonemapSettings {
        fn default() -> Self { Self { operator: TonemapOperator::ACES, exposure: 1.0, white_point: 11.2, shoulder_strength: 0.22, linear_strength: 0.3, linear_angle: 0.1, toe_strength: 0.2, toe_numerator: 0.01, toe_denominator: 0.3 } }
    }

    impl TonemapSettings {
        pub fn apply(&self, hdr: [f32; 3]) -> [f32; 3] {
            let exposed = [hdr[0] * self.exposure, hdr[1] * self.exposure, hdr[2] * self.exposure];
            match self.operator {
                TonemapOperator::Linear => exposed.map(|c| c.min(1.0)),
                TonemapOperator::Reinhard => exposed.map(|c| c / (1.0 + c)),
                TonemapOperator::ReinhardExtended => exposed.map(|c| (c * (1.0 + c / (self.white_point * self.white_point))) / (1.0 + c)),
                TonemapOperator::ACES => self.aces(exposed),
                TonemapOperator::ACESFitted => self.aces_fitted(exposed),
                TonemapOperator::HableFilmic => self.hable_filmic(exposed),
                TonemapOperator::AgX => self.agx(exposed),
                _ => exposed.map(|c| c.min(1.0)),
            }
        }

        fn aces(&self, c: [f32; 3]) -> [f32; 3] {
            let m1 = [[0.59719, 0.35458, 0.04823], [0.07600, 0.90834, 0.01566], [0.02840, 0.13383, 0.83777]];
            let m2 = [[1.60475, -0.53108, -0.07367], [-0.10208, 1.10813, -0.00605], [-0.00327, -0.07276, 1.07602]];
            let v = [m1[0][0]*c[0]+m1[0][1]*c[1]+m1[0][2]*c[2], m1[1][0]*c[0]+m1[1][1]*c[1]+m1[1][2]*c[2], m1[2][0]*c[0]+m1[2][1]*c[1]+m1[2][2]*c[2]];
            let rtt = |x: f32| (x * (x + 0.0245786) - 0.000090537) / (x * (0.983729 * x + 0.4329510) + 0.238081);
            let t = [rtt(v[0]), rtt(v[1]), rtt(v[2])];
            [m2[0][0]*t[0]+m2[0][1]*t[1]+m2[0][2]*t[2], m2[1][0]*t[0]+m2[1][1]*t[1]+m2[1][2]*t[2], m2[2][0]*t[0]+m2[2][1]*t[1]+m2[2][2]*t[2]]
        }

        fn aces_fitted(&self, c: [f32; 3]) -> [f32; 3] {
            let a = 2.51; let b = 0.03; let cc = 2.43; let d = 0.59; let e = 0.14;
            c.map(|x| ((x * (a * x + b)) / (x * (cc * x + d) + e)).clamp(0.0, 1.0))
        }

        fn hable_filmic(&self, c: [f32; 3]) -> [f32; 3] {
            let hable = |x: f32| {
                let a = self.shoulder_strength; let b = self.linear_strength; let cc = self.linear_angle;
                let d = self.toe_strength; let e = self.toe_numerator; let f = self.toe_denominator;
                ((x * (a * x + cc * b) + d * e) / (x * (a * x + b) + d * f)) - e / f
            };
            let white = hable(self.white_point);
            c.map(|x| hable(x) / white)
        }

        fn agx(&self, c: [f32; 3]) -> [f32; 3] {
            let agx_mat = [[0.842479, 0.0784336, 0.0792227], [0.0423303, 0.878468, 0.0791916], [0.0423, 0.0784, 0.8793]];
            let log2_min = -10.0; let log2_max = 6.5;
            let t = c.map(|x| ((x.max(1e-10).log2() - log2_min) / (log2_max - log2_min)).clamp(0.0, 1.0));
            let tt = t.map(|x| x * x * x * (x * (x * 6.0 - 15.0) + 10.0));
            [agx_mat[0][0]*tt[0]+agx_mat[0][1]*tt[1]+agx_mat[0][2]*tt[2],
             agx_mat[1][0]*tt[0]+agx_mat[1][1]*tt[1]+agx_mat[1][2]*tt[2],
             agx_mat[2][0]*tt[0]+agx_mat[2][1]*tt[1]+agx_mat[2][2]*tt[2]]
        }
    }

    #[derive(Debug, Clone)]
    pub struct MotionBlurSettings {
        pub intensity: f32,
        pub samples: u32,
        pub shutter_angle: f32,
        pub tile_size: u32,
        pub max_velocity: f32,
        pub depth_scale: f32,
        pub velocity_scale: f32,
    }

    impl Default for MotionBlurSettings {
        fn default() -> Self { Self { intensity: 1.0, samples: 16, shutter_angle: 180.0, tile_size: 16, max_velocity: 32.0, depth_scale: 1.0, velocity_scale: 1.0 } }
    }

    pub struct CinematicProcessor {
        pub film_emulation: FilmEmulation,
        pub aspect_ratio: AspectRatio,
        pub film_grain: FilmGrainSettings,
        pub lens: LensSettings,
        pub color_grading: ColorGradingSettings,
        pub tonemap: TonemapSettings,
        pub motion_blur: MotionBlurSettings,
        pub letterbox_opacity: f32,
        pub scanlines_enabled: bool,
        pub scanlines_intensity: f32,
    }

    impl CinematicProcessor {
        pub fn new() -> Self {
            Self { film_emulation: FilmEmulation::None, aspect_ratio: AspectRatio::R16x9, film_grain: FilmGrainSettings::default(),
                lens: LensSettings::default(), color_grading: ColorGradingSettings::default(), tonemap: TonemapSettings::default(),
                motion_blur: MotionBlurSettings::default(), letterbox_opacity: 1.0, scanlines_enabled: false, scanlines_intensity: 0.1 }
        }

        pub fn preset_cinematic_film() -> Self {
            let mut p = Self::new();
            p.film_emulation = FilmEmulation::Kodak5219;
            p.aspect_ratio = AspectRatio::R2_39x1;
            p.film_grain.intensity = 0.08;
            p.lens.vignette_intensity = 0.4;
            p.color_grading.contrast = 1.1;
            p.color_grading.saturation = 0.95;
            p.tonemap.operator = TonemapOperator::ACESFitted;
            p
        }

        pub fn preset_vintage_film() -> Self {
            let mut p = Self::new();
            p.film_emulation = FilmEmulation::Kodak2383;
            p.film_grain.intensity = 0.15;
            p.film_grain.color_amount = 0.5;
            p.lens.vignette_intensity = 0.6;
            p.lens.chromatic_aberration = 0.02;
            p.color_grading.saturation = 0.8;
            p.color_grading.shadows = [1.1, 0.9, 0.8];
            p.scanlines_enabled = true;
            p.scanlines_intensity = 0.05;
            p
        }

        pub fn preset_modern_digital() -> Self {
            let mut p = Self::new();
            p.tonemap.operator = TonemapOperator::AgX;
            p.color_grading.contrast = 1.05;
            p.color_grading.vibrance = 0.1;
            p.lens.vignette_intensity = 0.15;
            p.film_grain.intensity = 0.02;
            p
        }

        pub fn process(&self, color: [f32; 3]) -> [f32; 3] {
            let mut c = self.tonemap.apply(color);
            c = self.color_grading.apply_lift_gamma_gain(c);
            c = self.color_grading.apply_temperature_tint(c);
            c = self.color_grading.apply_contrast(c);
            c = self.color_grading.apply_saturation(c);
            c = self.color_grading.apply_vibrance(c);
            c.map(|x| x.clamp(0.0, 1.0))
        }
    }

    pub fn generate_cinematic_shader() -> String {
        r#"
// Cinematic Effects System
cbuffer CinematicBuffer {
    float3 lift, gamma, gain, offset;
    float saturation, contrast, exposure;
    float vignetteIntensity, vignetteRoundness, vignetteSmoothness;
    float grainIntensity, grainSize;
    float letterboxTop, letterboxBottom;
    int tonemapOperator;
};

float3 ApplyLiftGammaGain(float3 color) {
    color = color + lift;
    color = pow(abs(color), 1.0 / gamma) * sign(color);
    color = color * gain + offset;
    return color;
}

float3 ApplyTonemap(float3 hdr) {
    hdr *= exposure;
    if (tonemapOperator == 0) return saturate(hdr);
    if (tonemapOperator == 1) return hdr / (1.0 + hdr);
    if (tonemapOperator == 2) { // ACES Fitted
        float a = 2.51, b = 0.03, c = 2.43, d = 0.59, e = 0.14;
        return saturate((hdr * (a * hdr + b)) / (hdr * (c * hdr + d) + e));
    }
    return saturate(hdr);
}

float3 ApplySaturation(float3 color, float sat) {
    float luma = dot(color, float3(0.299, 0.587, 0.114));
    return lerp(luma.xxx, color, sat);
}

float ApplyVignette(float2 uv) {
    float2 d = abs(uv - 0.5) * 2.0;
    d = pow(d, vignetteRoundness.xx);
    float vignette = pow(saturate(1.0 - dot(d, d)), vignetteSmoothness);
    return lerp(1.0, vignette, vignetteIntensity);
}

float3 ApplyFilmGrain(float3 color, float2 uv, float time) {
    float noise = frac(sin(dot(uv + time, float2(12.9898, 78.233))) * 43758.5453);
    noise = (noise - 0.5) * grainIntensity;
    float luma = dot(color, float3(0.299, 0.587, 0.114));
    float grainMask = 1.0 - saturate(luma * 2.0);
    return color + noise * grainMask;
}

float4 CinematicPass(float2 texcoord, float time) {
    if (texcoord.y < letterboxTop || texcoord.y > 1.0 - letterboxBottom)
        return float4(0, 0, 0, 1);
    float3 color = tex2D(ColorSampler, texcoord).rgb;
    color = ApplyTonemap(color);
    color = ApplyLiftGammaGain(color);
    color = ApplySaturation(color, saturation);
    color *= ApplyVignette(texcoord);
    color = ApplyFilmGrain(color, texcoord, time);
    return float4(saturate(color), 1.0);
}"#.to_string()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUBSURFACE SCATTERING - SKIN & TRANSLUCENT MATERIALS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod subsurface_scattering {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum SSSModel { Gaussian, Burley, RandomWalk, DipoleDiffusion, Screen }

    #[derive(Debug, Clone)]
    pub struct SubsurfaceSSSProfile {
        pub name: String,
        pub scatter_color: [f32; 3],
        pub scatter_radius: f32,
        pub subsurface_color: [f32; 3],
        pub falloff: [f32; 3],
        pub sharpness: f32,
        pub model: SSSModel,
    }

    impl Default for SubsurfaceSSSProfile {
        fn default() -> Self {
            Self { name: "Skin".to_string(), scatter_color: [1.0, 0.4, 0.25], scatter_radius: 1.0, subsurface_color: [0.8, 0.2, 0.1], falloff: [1.0, 0.37, 0.12], sharpness: 1.0, model: SSSModel::Burley }
        }
    }

    impl SubsurfaceSSSProfile {
        pub fn skin() -> Self { Self::default() }
        pub fn marble() -> Self { Self { name: "Marble".to_string(), scatter_color: [1.0, 0.95, 0.9], scatter_radius: 0.5, subsurface_color: [0.9, 0.8, 0.7], falloff: [1.0, 0.9, 0.8], sharpness: 2.0, model: SSSModel::Gaussian } }
        pub fn wax() -> Self { Self { name: "Wax".to_string(), scatter_color: [1.0, 0.9, 0.7], scatter_radius: 2.0, subsurface_color: [0.8, 0.5, 0.2], falloff: [1.0, 0.6, 0.3], sharpness: 0.5, model: SSSModel::Burley } }
        pub fn jade() -> Self { Self { name: "Jade".to_string(), scatter_color: [0.3, 0.8, 0.4], scatter_radius: 0.8, subsurface_color: [0.1, 0.5, 0.2], falloff: [0.3, 1.0, 0.4], sharpness: 1.5, model: SSSModel::DipoleDiffusion } }
        pub fn milk() -> Self { Self { name: "Milk".to_string(), scatter_color: [1.0, 1.0, 0.98], scatter_radius: 3.0, subsurface_color: [0.95, 0.95, 0.9], falloff: [1.0, 0.95, 0.9], sharpness: 0.3, model: SSSModel::RandomWalk } }
        pub fn foliage() -> Self { Self { name: "Foliage".to_string(), scatter_color: [0.4, 0.8, 0.2], scatter_radius: 0.3, subsurface_color: [0.2, 0.6, 0.1], falloff: [0.5, 1.0, 0.3], sharpness: 2.5, model: SSSModel::Screen } }

        pub fn gaussian_kernel(&self, distance: f32) -> [f32; 3] {
            self.falloff.map(|f| (-distance * distance / (2.0 * f * f * self.scatter_radius * self.scatter_radius)).exp() / (f * self.scatter_radius * (2.0 * std::f32::consts::PI).sqrt()))
        }

        pub fn burley_profile(&self, r: f32) -> [f32; 3] {
            let s = self.sharpness;
            self.falloff.map(|d| {
                let scaled = r / (d * self.scatter_radius);
                let exp1 = (-scaled).exp();
                let exp2 = (-scaled / 3.0).exp();
                s * (exp1 + exp2) / (8.0 * std::f32::consts::PI * d * self.scatter_radius)
            })
        }
    }

    pub struct SSSRenderer {
        pub profiles: Vec<SubsurfaceSSSProfile>,
        pub sample_count: u32,
        pub blur_radius: f32,
        pub separation_scale: f32,
        pub follow_surface: bool,
        pub transmittance_bias: f32,
        pub normal_influence: f32,
    }

    impl SSSRenderer {
        pub fn new() -> Self {
            Self { profiles: vec![SubsurfaceSSSProfile::skin()], sample_count: 25, blur_radius: 0.0125, separation_scale: 1.0, follow_surface: true, transmittance_bias: 0.0, normal_influence: 0.5 }
        }

        pub fn separable_kernel(samples: u32) -> Vec<(f32, f32)> {
            let mut kernel = Vec::with_capacity(samples as usize);
            let range = 3.0;
            for i in 0..samples {
                let x = (i as f32 / (samples - 1) as f32) * 2.0 - 1.0;
                let offset = x * range;
                let weight = (-offset * offset / 2.0).exp() / (2.0 * std::f32::consts::PI).sqrt();
                kernel.push((offset, weight));
            }
            kernel
        }

        pub fn transmittance(&self, thickness: f32, profile: &SubsurfaceSSSProfile) -> [f32; 3] {
            profile.subsurface_color.map(|c| (-(1.0 - c) * thickness / profile.scatter_radius).exp())
        }
    }

    pub fn generate_sss_shader() -> String {
        r#"
// Subsurface Scattering System
#define SSS_SAMPLES 25
cbuffer SSSBuffer {
    float3 scatterColor; float3 falloff; float scatterRadius; float sharpness;
};

float3 BurleySSS(float r, float3 d) {
    float3 scaled = r / (d * scatterRadius);
    float3 exp1 = exp(-scaled);
    float3 exp2 = exp(-scaled / 3.0);
    return sharpness * (exp1 + exp2) / (8.0 * 3.14159 * d * scatterRadius);
}

float3 SSSBlur(float2 texcoord, float2 direction, float sssStrength) {
    float3 colorAccum = float3(0, 0, 0);
    float3 weightSum = float3(0, 0, 0);
    float range = scatterRadius * sssStrength;

    for (int i = 0; i < SSS_SAMPLES; i++) {
        float offset = (float(i) / float(SSS_SAMPLES - 1) - 0.5) * 2.0 * range;
        float2 sampleUV = texcoord + direction * offset * BUFFER_PIXEL_SIZE;
        float3 sampleColor = tex2D(ColorSampler, sampleUV).rgb;
        float3 weight = BurleySSS(abs(offset), falloff);
        colorAccum += sampleColor * weight;
        weightSum += weight;
    }
    return colorAccum / weightSum;
}

float3 Transmittance(float thickness, float3 subsurfaceColor) {
    return exp(-(1.0 - subsurfaceColor) * thickness / scatterRadius);
}"#.to_string()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_game_detection() {
        let mut hooks = GameHooks::new();
        let game = hooks.detect_game();
        // Game detection depends on current exe
        assert!(matches!(game, DetectedGame::Unknown | _));
    }

    #[test]
    fn test_shader_hash() {
        let bytecode = vec![0x44, 0x58, 0x42, 0x43];
        let hash = ShaderInjector::hash_shader(&bytecode);
        assert_ne!(hash, 0);
    }

    #[test]
    fn test_config_ini_parse() {
        let reload = ConfigHotReload::new(1000);
        let ini = "[Section]\nKey=Value\n";
        let sections = reload.parse_ini(ini);
        assert!(sections.contains_key("Section"));
        assert_eq!(sections.get("Section").unwrap().get("Key"), Some(&"Value".to_string()));
    }

    #[test]
    fn test_memory_patcher() {
        let mut patcher = MemoryPatcher::new();
        patcher.add_patch("test", 0x1000, vec![0x90], vec![0xCC], "Test patch");
        assert!(patcher.apply_patch("test"));
        assert!(patcher.revert_patch("test"));
    }

    #[test]
    fn test_enb_reshade_bridge() {
        let mut bridge = ENBReShadebridge::new();
        bridge.register_shared_texture("color", TextureFormat::RGBA8, 1920, 1080);
        assert!(!bridge.shared_textures.is_empty());
    }
}
