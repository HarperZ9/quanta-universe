// ============================================================================
// ENB VERSION DETECTION AND COMPATIBILITY
// ============================================================================

/// Supported ENB binary versions
pub enum ENBVersion {
    V0_262,     // Legacy version
    V0_278,     // Skyrim LE classic
    V0_308,     // Fallout 4 initial
    V0_315,     // Skyrim SE initial
    V0_347,     // Major update
    V0_356,     // SSE improvements
    V0_393,     // Particle lights
    V0_403,     // Ray tracing preview
    V0_419,     // SSE major update
    V0_440,     // Complex particle lights
    V0_454,     // Water improvements
    V0_463,     // AO improvements
    V0_475,     // SSR improvements
    V0_484,     // Current stable
    V0_490,     // Latest preview
    Unknown,
}

/// Target game enumeration
pub enum TargetGame {
    SkyrimLE,           // Original Skyrim
    SkyrimSE,           // Special Edition
    SkyrimAE,           // Anniversary Edition
    SkyrimVR,           // VR Edition
    Fallout3,           // Fallout 3
    FalloutNV,          // New Vegas
    Fallout4,           // Fallout 4
    Fallout4VR,         // Fallout 4 VR
    Fallout76,          // Fallout 76
    GTA5,               // Grand Theft Auto V
    Witcher3,           // Witcher 3
    Cyberpunk2077,      // Cyberpunk 2077
    DragonsDogma2,      // Dragon's Dogma 2
    EldenRing,          // Elden Ring
    Unknown,
}

/// ENB feature capability flags
pub flags ENBFeatures {
    BasicEffects        = 0x0001,
    SSAO                = 0x0002,
    SSR                 = 0x0004,
    DOF                 = 0x0008,
    Bloom               = 0x0010,
    ColorCorrection     = 0x0020,
    Tonemapping         = 0x0040,
    Skylighting         = 0x0080,
    ParticleLights      = 0x0100,
    ComplexParticles    = 0x0200,
    RayTracing          = 0x0400,
    SubsurfaceScatter   = 0x0800,
    Volumetrics         = 0x1000,
    WaterEffects        = 0x2000,
    TerrainBlending     = 0x4000,
    WeatherSupport      = 0x8000,
}

/// D3D11 hook points for ENB integration
pub enum HookPoint {
    // Device hooks
    CreateDevice,
    CreateDeviceAndSwapChain,
    DeviceRelease,

    // Swap chain hooks
    SwapChainPresent,
    SwapChainResizeBuffers,
    SwapChainResizeTarget,

    // Context hooks
    ContextDraw,
    ContextDrawIndexed,
    ContextDrawInstanced,
    ContextDrawIndexedInstanced,
    ContextDispatch,
    ContextClearRTV,
    ContextClearDSV,
    ContextOMSetRenderTargets,
    ContextPSSetShaderResources,
    ContextVSSetConstantBuffers,
    ContextPSSetConstantBuffers,

    // ENB specific hooks
    ENBPrePass,
    ENBPostPass,
    ENBPreUI,
    ENBPostUI,
    ENBPreWater,
    ENBPostWater,
    ENBPreSky,
    ENBPostSky,
    ENBPreSSAO,
    ENBPostSSAO,
    ENBPreSSR,
    ENBPostSSR,
    ENBPreDOF,
    ENBPostDOF,
    ENBPreBloom,
    ENBPostBloom,
    ENBPreToneMap,
    ENBPostToneMap,
}

