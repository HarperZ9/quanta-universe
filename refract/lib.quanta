// SUBSURFACE SCATTERING PROFILES
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ProfileSSSProfile { pub name: String, pub scatter_color: Vec3, pub scatter_distance: f32, pub falloff: Vec3, pub translucency: f32 }

pub struct ProfileSSSProfileLibrary {
    pub profiles: HashMap<String, ProfileSSSProfile>,
}

impl ProfileSSSProfileLibrary {
    pub fn new() -> Self {
        let mut lib = Self { profiles: HashMap::new() };
        lib.add(ProfileSSSProfile { name: "Skin".into(), scatter_color: Vec3::new(1.0, 0.4, 0.25), scatter_distance: 2.7, falloff: Vec3::new(1.0, 0.37, 0.3), translucency: 0.5 });
        lib.add(ProfileSSSProfile { name: "Marble".into(), scatter_color: Vec3::new(0.83, 0.79, 0.75), scatter_distance: 8.51, falloff: Vec3::new(1.0, 0.93, 0.88), translucency: 0.2 });
        lib.add(ProfileSSSProfile { name: "Milk".into(), scatter_color: Vec3::new(0.98, 0.98, 0.95), scatter_distance: 2.0, falloff: Vec3::new(1.0, 0.95, 0.85), translucency: 0.8 });
        lib.add(ProfileSSSProfile { name: "Jade".into(), scatter_color: Vec3::new(0.4, 0.8, 0.5), scatter_distance: 4.0, falloff: Vec3::new(0.8, 1.0, 0.85), translucency: 0.3 });
        lib.add(ProfileSSSProfile { name: "Wax".into(), scatter_color: Vec3::new(1.0, 0.9, 0.7), scatter_distance: 3.0, falloff: Vec3::new(1.0, 0.85, 0.6), translucency: 0.6 });
        lib.add(ProfileSSSProfile { name: "Leaf".into(), scatter_color: Vec3::new(0.3, 0.7, 0.2), scatter_distance: 1.5, falloff: Vec3::new(0.5, 1.0, 0.4), translucency: 0.7 });
        lib
    }

    pub fn add(&mut self, profile: ProfileSSSProfile) { self.profiles.insert(profile.name.clone(), profile); }
    pub fn get(&self, name: &str) -> Option<&ProfileSSSProfile> { self.profiles.get(name) }

    pub fn gaussian_kernel(&self, profile: &ProfileSSSProfile, radius: f32, samples: usize) -> Vec<(f32, Vec3)> {
        let mut kernel = Vec::with_capacity(samples);
        let step = radius / samples as f32;
        for i in 0..samples {
            let r = i as f32 * step;
            let weight = Vec3::new(
                (-r * r / (2.0 * profile.scatter_distance * profile.falloff.x)).exp(),
                (-r * r / (2.0 * profile.scatter_distance * profile.falloff.y)).exp(),
                (-r * r / (2.0 * profile.scatter_distance * profile.falloff.z)).exp(),
            );
            kernel.push((r, weight * profile.scatter_color));
        }
        kernel
    }
}

