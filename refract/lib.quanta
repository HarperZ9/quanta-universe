// AMBIENT OCCLUSION SYSTEMS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SSAOConfig { pub radius: f32, pub bias: f32, pub intensity: f32, pub samples: u32, pub blur_size: u32, pub range_check: f32 }
pub struct HBAOConfig { pub radius: f32, pub angle_bias: f32, pub intensity: f32, pub directions: u32, pub steps: u32, pub blur_sharpness: f32 }
pub struct GTAOConfig { pub slice_count: u32, pub steps_per_slice: u32, pub radius: f32, pub falloff_start: f32, pub falloff_end: f32, pub intensity: f32 }

impl SSAOConfig { pub fn new() -> Self { Self { radius: 0.5, bias: 0.025, intensity: 1.0, samples: 64, blur_size: 4, range_check: 0.1 } } }
impl HBAOConfig { pub fn new() -> Self { Self { radius: 1.0, angle_bias: 0.1, intensity: 1.5, directions: 8, steps: 4, blur_sharpness: 16.0 } } }
impl GTAOConfig { pub fn new() -> Self { Self { slice_count: 3, steps_per_slice: 3, radius: 2.0, falloff_start: 0.2, falloff_end: 2.0, intensity: 1.0 } } }

pub struct AmbientOcclusion {
    pub method: AOMethod,
    pub ssao: SSAOConfig,
    pub hbao: HBAOConfig,
    pub gtao: GTAOConfig,
    pub temporal: bool,
    pub bent_normals: bool,
}

pub enum AOMethod { SSAO, HBAO, GTAO, RTAO }

impl AmbientOcclusion {
    pub fn new(method: AOMethod) -> Self { Self { method, ssao: SSAOConfig::new(), hbao: HBAOConfig::new(), gtao: GTAOConfig::new(), temporal: true, bent_normals: false } }

    pub fn generate_ssao_kernel(samples: u32) -> Vec<Vec3> {
        let mut kernel = Vec::with_capacity(samples as usize);
        for i in 0..samples {
            let scale = i as f32 / samples as f32;
            let scale = 0.1 + scale * scale * 0.9;
            let phi = 2.4 * i as f32;
            let cos_theta = 1.0 - (i as f32 + 0.5) / samples as f32;
            let sin_theta = (1.0 - cos_theta * cos_theta).sqrt();
            kernel.push(Vec3::new(sin_theta * phi.cos(), sin_theta * phi.sin(), cos_theta) * scale);
        }
        kernel
    }

    pub fn compute_ssao(&self, pos: Vec3, normal: Vec3, depth: f32, sample_depth: impl Fn(Vec3) -> f32, kernel: &[Vec3]) -> f32 {
        let mut occlusion = 0.0;
        for sample in kernel {
            let sample_pos = pos + sample.hemispherical_orient(normal) * self.ssao.radius;
            let sample_d = sample_depth(sample_pos);
            let range_check = ((depth - sample_d).abs() < self.ssao.range_check) as i32 as f32;
            occlusion += ((sample_d >= sample_pos.z + self.ssao.bias) as i32 as f32) * range_check;
        }
        1.0 - (occlusion / kernel.len() as f32) * self.ssao.intensity
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GLOBAL ILLUMINATION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct VoxelGI {
    pub grid_size: [u32; 3],
    pub voxel_size: f32,
    pub bounds_min: Vec3,
    pub bounds_max: Vec3,
    pub radiance: Vec<Vec4>,
    pub opacity: Vec<f32>,
    pub cone_trace_steps: u32,
    pub cone_angle: f32,
    pub diffuse_cones: u32,
    pub specular_cones: u32,
    pub ao_cones: u32,
}

impl VoxelGI {
    pub fn new(grid_size: [u32; 3], bounds_min: Vec3, bounds_max: Vec3) -> Self {
        let total = (grid_size[0] * grid_size[1] * grid_size[2]) as usize;
        let extent = bounds_max - bounds_min;
        let voxel_size = extent.x / grid_size[0] as f32;
        Self { grid_size, voxel_size, bounds_min, bounds_max, radiance: vec![Vec4::zero(); total], opacity: vec![0.0; total], cone_trace_steps: 64, cone_angle: 0.5, diffuse_cones: 6, specular_cones: 1, ao_cones: 4 }
    }

    fn world_to_voxel(&self, pos: Vec3) -> Option<[u32; 3]> {
        let local = (pos - self.bounds_min) / self.voxel_size;
        if local.x < 0.0 || local.y < 0.0 || local.z < 0.0 { return None; }
        let x = local.x as u32; let y = local.y as u32; let z = local.z as u32;
        if x >= self.grid_size[0] || y >= self.grid_size[1] || z >= self.grid_size[2] { return None; }
        Some([x, y, z])
    }

    fn voxel_index(&self, coords: [u32; 3]) -> usize { (coords[2] * self.grid_size[1] * self.grid_size[0] + coords[1] * self.grid_size[0] + coords[0]) as usize }

    pub fn inject_radiance(&mut self, pos: Vec3, radiance: Vec4, opacity: f32) {
        if let Some(coords) = self.world_to_voxel(pos) {
            let idx = self.voxel_index(coords);
            self.radiance[idx] = self.radiance[idx] + radiance;
            self.opacity[idx] = (self.opacity[idx] + opacity).min(1.0);
        }
    }

    pub fn cone_trace(&self, origin: Vec3, direction: Vec3, cone_angle: f32, max_dist: f32) -> Vec4 {
        let mut color = Vec4::zero();
        let mut occlusion = 0.0;
        let mut dist = self.voxel_size;
        while dist < max_dist && occlusion < 0.99 {
            let diameter = 2.0 * cone_angle * dist;
            let mip_level = (diameter / self.voxel_size).log2().max(0.0);
            let sample_pos = origin + direction * dist;
            if let Some(coords) = self.world_to_voxel(sample_pos) {
                let idx = self.voxel_index(coords);
                let sample_radiance = self.radiance[idx];
                let sample_opacity = self.opacity[idx];
                let weight = 1.0 - occlusion;
                color = color + sample_radiance * weight * sample_opacity;
                occlusion += sample_opacity * weight;
            }
            dist += diameter * 0.5;
        }
        color
    }

    pub fn diffuse_indirect(&self, pos: Vec3, normal: Vec3) -> Vec3 {
        let mut result = Vec3::zero();
        let cone_dirs = self.generate_cone_directions(normal, self.diffuse_cones);
        for dir in &cone_dirs {
            let traced = self.cone_trace(pos + normal * self.voxel_size, *dir, self.cone_angle, 100.0);
            result = result + Vec3::new(traced.x, traced.y, traced.z);
        }
        result / self.diffuse_cones as f32
    }

    fn generate_cone_directions(&self, normal: Vec3, count: u32) -> Vec<Vec3> {
        let mut dirs = Vec::with_capacity(count as usize);
        let tangent = if normal.y.abs() < 0.999 { normal.cross(Vec3::unit_y()).normalized() } else { normal.cross(Vec3::unit_x()).normalized() };
        let bitangent = normal.cross(tangent);
        for i in 0..count {
            let angle = 2.0 * PI * i as f32 / count as f32;
            let cone_dir = (normal * 0.7 + tangent * angle.cos() * 0.5 + bitangent * angle.sin() * 0.5).normalized();
            dirs.push(cone_dir);
        }
        dirs
    }
}

pub struct ScreenSpaceGI { pub radius: f32, pub intensity: f32, pub samples: u32, pub thickness: f32, pub falloff: f32, pub temporal: bool }
impl ScreenSpaceGI {
    pub fn new() -> Self { Self { radius: 3.0, intensity: 1.0, samples: 16, thickness: 0.5, falloff: 2.0, temporal: true } }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCREEN SPACE REFLECTIONS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SSRConfig {
    pub max_ray_distance: f32,
    pub resolution_scale: f32,
    pub stride: f32,
    pub stride_cutoff: f32,
    pub max_steps: u32,
    pub binary_search_steps: u32,
    pub thickness: f32,
    pub jitter: f32,
    pub temporal: bool,
    pub roughness_cutoff: f32,
    pub edge_fade: f32,
}

impl SSRConfig { pub fn new() -> Self { Self { max_ray_distance: 100.0, resolution_scale: 0.5, stride: 2.0, stride_cutoff: 0.1, max_steps: 64, binary_search_steps: 8, thickness: 0.5, jitter: 0.0, temporal: true, roughness_cutoff: 0.9, edge_fade: 0.1 } } }

pub struct SSRTracer { pub config: SSRConfig }

impl SSRTracer {
    pub fn new(config: SSRConfig) -> Self { Self { config } }

    pub fn trace_ray(&self, origin: Vec3, direction: Vec3, depth_buffer: impl Fn(Vec2) -> f32, project: impl Fn(Vec3) -> Vec2) -> Option<(Vec2, f32)> {
        let mut ray_pos = origin;
        let mut stride = self.config.stride;
        for step in 0..self.config.max_steps {
            ray_pos = ray_pos + direction * stride;
            let screen_pos = project(ray_pos);
            if screen_pos.x < 0.0 || screen_pos.x > 1.0 || screen_pos.y < 0.0 || screen_pos.y > 1.0 { return None; }
            let sampled_depth = depth_buffer(screen_pos);
            if ray_pos.z > sampled_depth {
                let hit_uv = self.binary_search(origin, direction, step as f32 * stride, depth_buffer, &project);
                let confidence = self.compute_confidence(hit_uv, origin.distance(ray_pos));
                return Some((hit_uv, confidence));
            }
            stride = (stride * 1.5).min(self.config.stride_cutoff);
        }
        None
    }

    fn binary_search(&self, origin: Vec3, dir: Vec3, initial_dist: f32, depth: impl Fn(Vec2) -> f32, project: impl Fn(Vec3) -> Vec2) -> Vec2 {
        let mut min_dist = initial_dist - self.config.stride;
        let mut max_dist = initial_dist;
        for _ in 0..self.config.binary_search_steps {
            let mid = (min_dist + max_dist) * 0.5;
            let pos = origin + dir * mid;
            let uv = project(pos);
            if pos.z > depth(uv) { max_dist = mid; } else { min_dist = mid; }
        }
        project(origin + dir * (min_dist + max_dist) * 0.5)
    }

    fn compute_confidence(&self, uv: Vec2, distance: f32) -> f32 {
        let edge_fade_x = (uv.x.min(1.0 - uv.x) / self.config.edge_fade).min(1.0);
        let edge_fade_y = (uv.y.min(1.0 - uv.y) / self.config.edge_fade).min(1.0);
        let distance_fade = 1.0 - (distance / self.config.max_ray_distance).min(1.0);
        edge_fade_x * edge_fade_y * distance_fade
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEMPORAL ANTI-ALIASING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct TAAConfig {
    pub jitter_scale: f32,
    pub feedback: f32,
    pub motion_scale: f32,
    pub sharpness: f32,
    pub variance_clip: bool,
    pub variance_gamma: f32,
    pub ycocg: bool,
    pub bicubic_history: bool,
    pub anti_flicker: f32,
    pub anti_ghosting: f32,
}

impl TAAConfig { pub fn new() -> Self { Self { jitter_scale: 1.0, feedback: 0.95, motion_scale: 1.0, sharpness: 0.0, variance_clip: true, variance_gamma: 1.0, ycocg: true, bicubic_history: true, anti_flicker: 0.5, anti_ghosting: 0.5 } } }

pub struct TemporalAA {
    pub config: TAAConfig,
    pub jitter_sequence: Vec<Vec2>,
    pub frame_index: u32,
}

impl TemporalAA {
    pub fn new(config: TAAConfig) -> Self { Self { config, jitter_sequence: Self::halton_sequence(16), frame_index: 0 } }

    pub fn halton_sequence(count: u32) -> Vec<Vec2> {
        fn halton(index: u32, base: u32) -> f32 {
            let mut result = 0.0;
            let mut f = 1.0;
            let mut i = index;
            while i > 0 { f /= base as f32; result += f * (i % base) as f32; i /= base; }
            result
        }
        (0..count).map(|i| Vec2::new(halton(i + 1, 2) - 0.5, halton(i + 1, 3) - 0.5)).collect()
    }

    pub fn get_jitter(&self) -> Vec2 { self.jitter_sequence[(self.frame_index as usize) % self.jitter_sequence.len()] * self.config.jitter_scale }

    pub fn advance_frame(&mut self) { self.frame_index += 1; }

    pub fn rgb_to_ycocg(rgb: Vec3) -> Vec3 { Vec3::new(rgb.dot(Vec3::new(0.25, 0.5, 0.25)), rgb.dot(Vec3::new(0.5, 0.0, -0.5)), rgb.dot(Vec3::new(-0.25, 0.5, -0.25))) }
    pub fn ycocg_to_rgb(ycocg: Vec3) -> Vec3 { Vec3::new(ycocg.x + ycocg.y - ycocg.z, ycocg.x + ycocg.z, ycocg.x - ycocg.y - ycocg.z) }

    pub fn variance_clip(&self, history: Vec3, current: Vec3, neighbors: &[Vec3]) -> Vec3 {
        let (mut m1, mut m2) = (Vec3::zero(), Vec3::zero());
        for n in neighbors { m1 = m1 + *n; m2 = m2 + *n * *n; }
        m1 = m1 / neighbors.len() as f32;
        m2 = m2 / neighbors.len() as f32;
        let variance = (m2 - m1 * m1).max_elem(0.0).sqrt() * self.config.variance_gamma;
        let aabb_min = m1 - variance;
        let aabb_max = m1 + variance;
        history.clamp_components(aabb_min, aabb_max)
    }

    pub fn blend(&self, current: Vec3, history: Vec3, motion: Vec2) -> Vec3 {
        let motion_weight = motion.length() * self.config.motion_scale;
        let feedback = self.config.feedback * (1.0 - motion_weight.min(0.5));
        current * (1.0 - feedback) + history * feedback
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEFERRED SHADING PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct GBuffer { pub albedo: Vec<Vec4>, pub normal: Vec<Vec4>, pub material: Vec<Vec4>, pub depth: Vec<f32>, pub velocity: Vec<Vec2>, pub width: u32, pub height: u32 }

impl GBuffer {
    pub fn new(width: u32, height: u32) -> Self {
        let size = (width * height) as usize;
        Self { albedo: vec![Vec4::zero(); size], normal: vec![Vec4::zero(); size], material: vec![Vec4::zero(); size], depth: vec![1.0; size], velocity: vec![Vec2::zero(); size], width, height }
    }

    pub fn clear(&mut self) {
        for i in 0..self.albedo.len() { self.albedo[i] = Vec4::zero(); self.normal[i] = Vec4::zero(); self.material[i] = Vec4::zero(); self.depth[i] = 1.0; self.velocity[i] = Vec2::zero(); }
    }

    fn index(&self, x: u32, y: u32) -> usize { (y * self.width + x) as usize }

    pub fn write(&mut self, x: u32, y: u32, albedo: Vec4, normal: Vec4, material: Vec4, depth: f32, velocity: Vec2) {
        let idx = self.index(x, y);
        self.albedo[idx] = albedo; self.normal[idx] = normal; self.material[idx] = material; self.depth[idx] = depth; self.velocity[idx] = velocity;
    }

    pub fn read(&self, x: u32, y: u32) -> (Vec4, Vec4, Vec4, f32, Vec2) {
        let idx = self.index(x, y);
        (self.albedo[idx], self.normal[idx], self.material[idx], self.depth[idx], self.velocity[idx])
    }

    pub fn unpack_normal(packed: Vec4) -> Vec3 { Vec3::new(packed.x * 2.0 - 1.0, packed.y * 2.0 - 1.0, packed.z * 2.0 - 1.0).normalized() }
    pub fn pack_normal(n: Vec3) -> Vec4 { Vec4::new(n.x * 0.5 + 0.5, n.y * 0.5 + 0.5, n.z * 0.5 + 0.5, 1.0) }
    pub fn unpack_material(packed: Vec4) -> (f32, f32, f32, f32) { (packed.x, packed.y, packed.z, packed.w) }
}

pub struct DeferredRenderer {
    pub gbuffer: GBuffer,
    pub light_buffer: Vec<Vec4>,
    pub ao: AmbientOcclusion,
    pub ssr: SSRTracer,
    pub taa: TemporalAA,
    pub gi: Option<VoxelGI>,
}

impl DeferredRenderer {
    pub fn new(width: u32, height: u32) -> Self {
        Self {
            gbuffer: GBuffer::new(width, height),
            light_buffer: vec![Vec4::zero(); (width * height) as usize],
            ao: AmbientOcclusion::new(AOMethod::GTAO),
            ssr: SSRTracer::new(SSRConfig::new()),
            taa: TemporalAA::new(TAAConfig::new()),
            gi: None,
        }
    }

    pub fn enable_gi(&mut self, grid_size: [u32; 3], bounds_min: Vec3, bounds_max: Vec3) { self.gi = Some(VoxelGI::new(grid_size, bounds_min, bounds_max)); }

    pub fn geometry_pass(&mut self, objects: &[RenderObject]) { for obj in objects { /* Rasterize to GBuffer */ } }

    pub fn lighting_pass(&mut self, lights: &[Light], camera_pos: Vec3) {
        for y in 0..self.gbuffer.height { for x in 0..self.gbuffer.width {
            let (albedo, normal_packed, material, depth, _velocity) = self.gbuffer.read(x, y);
            if depth >= 1.0 { continue; }
            let normal = GBuffer::unpack_normal(normal_packed);
            let (metallic, roughness, ao, _) = GBuffer::unpack_material(material);
            let world_pos = self.reconstruct_position(x, y, depth);
            let view_dir = (camera_pos - world_pos).normalized();
            let mut result = Vec3::zero();
            for light in lights { result = result + self.evaluate_light(light, world_pos, normal, view_dir, Vec3::new(albedo.x, albedo.y, albedo.z), metallic, roughness); }
            result = result * ao;
            self.light_buffer[(y * self.gbuffer.width + x) as usize] = Vec4::new(result.x, result.y, result.z, 1.0);
        }}
    }

    fn reconstruct_position(&self, _x: u32, _y: u32, _depth: f32) -> Vec3 { Vec3::zero() }

    fn evaluate_light(&self, light: &Light, pos: Vec3, normal: Vec3, view: Vec3, albedo: Vec3, metallic: f32, roughness: f32) -> Vec3 {
        let light_dir = match light.light_type { LightType::Directional => -light.direction, LightType::Point | LightType::Spot => (light.position - pos).normalized() };
        let mat = PBRMaterial { name: String::new(), albedo, metallic, roughness, normal_strength: 1.0, ao_strength: 1.0, emission: Vec3::zero(), emission_strength: 0.0, ior: 1.5, transmission: 0.0, transmission_roughness: 0.0, clearcoat: 0.0, clearcoat_roughness: 0.03, anisotropy: 0.0, anisotropy_rotation: 0.0, sheen: 0.0, sheen_tint: 0.5, subsurface: 0.0, subsurface_color: Vec3::zero(), subsurface_radius: Vec3::one() };
        mat.evaluate_brdf(normal, view, light_dir) * light.color * light.intensity
    }
}

pub struct RenderObject { pub transform: Mat4, pub mesh_id: u32, pub material_id: u32 }
pub struct Light { pub light_type: LightType, pub position: Vec3, pub direction: Vec3, pub color: Vec3, pub intensity: f32, pub radius: f32, pub inner_angle: f32, pub outer_angle: f32 }
pub enum LightType { Directional, Point, Spot }

// ═══════════════════════════════════════════════════════════════════════════════
// ENB PRESET SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub struct DeferredENBPreset {
    pub name: String,
    pub author: String,
    pub version: String,
    pub game: String,
    pub sections: HashMap<String, HashMap<String, ENBValue>>,
    pub weather_configs: HashMap<String, WeatherConfig>,
    pub interior_config: Option<InteriorConfig>,
    pub time_of_day: Vec<TimeOfDayConfig>,
}

pub enum ENBValue { Bool(bool), Int(i32), Float(f32), Color([f32; 3]), String(String) }
pub struct WeatherConfig { pub weather_id: u32, pub settings: HashMap<String, ENBValue> }
pub struct InteriorConfig { pub brightness: f32, pub contrast: f32, pub saturation: f32, pub color_filter: [f32; 3] }
pub struct TimeOfDayConfig { pub hour: f32, pub settings: HashMap<String, ENBValue> }

impl DeferredENBPreset {
    pub fn new(name: &str) -> Self { Self { name: name.to_string(), author: String::new(), version: "1.0".to_string(), game: String::new(), sections: HashMap::new(), weather_configs: HashMap::new(), interior_config: None, time_of_day: Vec::new() } }

    pub fn set(&mut self, section: &str, key: &str, value: ENBValue) { self.sections.entry(section.to_string()).or_insert_with(HashMap::new).insert(key.to_string(), value); }

    pub fn get(&self, section: &str, key: &str) -> Option<&ENBValue> { self.sections.get(section).and_then(|s| s.get(key)) }

    pub fn get_float(&self, section: &str, key: &str, default: f32) -> f32 { match self.get(section, key) { Some(ENBValue::Float(v)) => *v, Some(ENBValue::Int(v)) => *v as f32, _ => default } }

    pub fn get_bool(&self, section: &str, key: &str, default: bool) -> bool { match self.get(section, key) { Some(ENBValue::Bool(v)) => *v, Some(ENBValue::Int(v)) => *v != 0, _ => default } }

    pub fn add_weather_config(&mut self, weather_id: u32, settings: HashMap<String, ENBValue>) { self.weather_configs.insert(format!("{:08X}", weather_id), WeatherConfig { weather_id, settings }); }

    pub fn add_time_config(&mut self, hour: f32, settings: HashMap<String, ENBValue>) { self.time_of_day.push(TimeOfDayConfig { hour, settings }); self.time_of_day.sort_by(|a, b| a.hour.partial_cmp(&b.hour).unwrap()); }

    pub fn interpolate_time(&self, hour: f32, key: &str) -> Option<f32> {
        if self.time_of_day.len() < 2 { return None; }
        let mut prev_idx = 0;
        for (i, tod) in self.time_of_day.iter().enumerate() { if tod.hour <= hour { prev_idx = i; } }
        let next_idx = (prev_idx + 1) % self.time_of_day.len();
        let prev = &self.time_of_day[prev_idx];
        let next = &self.time_of_day[next_idx];
        let (prev_val, next_val) = match (prev.settings.get(key), next.settings.get(key)) { (Some(ENBValue::Float(a)), Some(ENBValue::Float(b))) => (*a, *b), _ => return None };
        let mut t = if next.hour > prev.hour { (hour - prev.hour) / (next.hour - prev.hour) } else { let range = 24.0 - prev.hour + next.hour; if hour >= prev.hour { (hour - prev.hour) / range } else { (24.0 - prev.hour + hour) / range } };
        t = t.clamp(0.0, 1.0);
        Some(prev_val + (next_val - prev_val) * t)
    }

    pub fn to_ini(&self) -> String {
        let mut s = format!("; {} by {}\n; Version {}\n\n", self.name, self.author, self.version);
        for (section, values) in &self.sections {
            s.push_str(&format!("[{}]\n", section));
            for (key, value) in values {
                let val_str = match value { ENBValue::Bool(b) => if *b { "true" } else { "false" }.to_string(), ENBValue::Int(i) => i.to_string(), ENBValue::Float(f) => format!("{:.6}", f), ENBValue::Color(c) => format!("{},{},{}", (c[0] * 255.0) as u8, (c[1] * 255.0) as u8, (c[2] * 255.0) as u8), ENBValue::String(s) => s.clone() };
                s.push_str(&format!("{}={}\n", key, val_str));
            }
            s.push('\n');
        }
        s
    }

    pub fn from_ini(content: &str) -> Self {
        let mut preset = Self::new("Imported");
        let mut current_section = String::new();
        for line in content.lines() {
            let line = line.trim();
            if line.is_empty() || line.starts_with(';') || line.starts_with('#') { continue; }
            if line.starts_with('[') && line.ends_with(']') { current_section = line[1..line.len()-1].to_string(); continue; }
            if let Some((key, value)) = line.split_once('=') {
                let key = key.trim();
                let value = value.trim();
                let enb_value = if value == "true" { ENBValue::Bool(true) }
                    else if value == "false" { ENBValue::Bool(false) }
                    else if let Ok(i) = value.parse::<i32>() { ENBValue::Int(i) }
                    else if let Ok(f) = value.parse::<f32>() { ENBValue::Float(f) }
                    else { ENBValue::String(value.to_string()) };
                preset.set(&current_section, key, enb_value);
            }
        }
        preset
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED LIGHTING SYSTEM - PHYSICALLY-BASED ENB LIGHTING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod advanced_lighting {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum AdvancedLightType { Directional, Point, Spot, Area, IES, Emissive }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum ShadowQuality { Off, Low, Medium, High, Ultra, RayTraced }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum ShadowType { Hard, PCF, PCSS, VSM, ESM, MSM, RayTraced }

    #[derive(Debug, Clone)]
    pub struct LightSource {
        pub light_type: AdvancedLightType,
        pub position: [f32; 3],
        pub direction: [f32; 3],
        pub color: [f32; 3],
        pub intensity: f32,
        pub temperature: f32,
        pub radius: f32,
        pub inner_angle: f32,
        pub outer_angle: f32,
        pub area_size: [f32; 2],
        pub ies_profile: Option<IESProfile>,
        pub cast_shadows: bool,
        pub shadow_bias: f32,
        pub volumetric: bool,
        pub volumetric_intensity: f32,
    }

    impl Default for LightSource {
        fn default() -> Self {
            Self { light_type: AdvancedLightType::Point, position: [0.0; 3], direction: [0.0, -1.0, 0.0], color: [1.0; 3], intensity: 1.0, temperature: 6500.0,
                radius: 10.0, inner_angle: 30.0, outer_angle: 45.0, area_size: [1.0, 1.0], ies_profile: None, cast_shadows: true, shadow_bias: 0.001, volumetric: false, volumetric_intensity: 0.1 }
        }
    }

    impl LightSource {
        pub fn directional(direction: [f32; 3], color: [f32; 3], intensity: f32) -> Self { Self { light_type: AdvancedLightType::Directional, direction, color, intensity, ..Default::default() } }
        pub fn point(position: [f32; 3], color: [f32; 3], intensity: f32, radius: f32) -> Self { Self { light_type: AdvancedLightType::Point, position, color, intensity, radius, ..Default::default() } }
        pub fn spot(position: [f32; 3], direction: [f32; 3], color: [f32; 3], intensity: f32, inner: f32, outer: f32) -> Self { Self { light_type: AdvancedLightType::Spot, position, direction, color, intensity, inner_angle: inner, outer_angle: outer, ..Default::default() } }
        pub fn area(position: [f32; 3], direction: [f32; 3], size: [f32; 2], color: [f32; 3], intensity: f32) -> Self { Self { light_type: AdvancedLightType::Area, position, direction, area_size: size, color, intensity, ..Default::default() } }

        pub fn temperature_to_rgb(kelvin: f32) -> [f32; 3] {
            let temp = (kelvin / 100.0).clamp(10.0, 400.0);
            let r = if temp <= 66.0 { 1.0 } else { (329.698727446 * (temp - 60.0).powf(-0.1332047592) / 255.0).clamp(0.0, 1.0) };
            let g = if temp <= 66.0 { (99.4708025861 * temp.ln() - 161.1195681661) / 255.0 } else { (288.1221695283 * (temp - 60.0).powf(-0.0755148492)) / 255.0 }.clamp(0.0, 1.0);
            let b = if temp >= 66.0 { 1.0 } else if temp <= 19.0 { 0.0 } else { ((138.5177312231 * (temp - 10.0).ln()) - 305.0447927307) / 255.0 }.clamp(0.0, 1.0);
            [r, g, b]
        }

        pub fn get_temperature_color(&self) -> [f32; 3] { Self::temperature_to_rgb(self.temperature) }

        pub fn attenuation(&self, distance: f32) -> f32 {
            match self.light_type {
                AdvancedLightType::Directional => 1.0,
                AdvancedLightType::Point | AdvancedLightType::Spot | AdvancedLightType::Area => {
                    let d = distance / self.radius;
                    let atten = 1.0 / (1.0 + d * d);
                    let falloff = (1.0 - (d * d * d * d).min(1.0)).max(0.0);
                    atten * falloff * falloff
                }
                _ => 1.0,
            }
        }

        pub fn spot_factor(&self, light_dir: [f32; 3], to_light: [f32; 3]) -> f32 {
            if self.light_type != AdvancedLightType::Spot { return 1.0; }
            let dot = -(light_dir[0] * to_light[0] + light_dir[1] * to_light[1] + light_dir[2] * to_light[2]);
            let inner_cos = self.inner_angle.to_radians().cos();
            let outer_cos = self.outer_angle.to_radians().cos();
            ((dot - outer_cos) / (inner_cos - outer_cos)).clamp(0.0, 1.0)
        }
    }

    #[derive(Debug, Clone)]
    pub struct IESProfile {
        pub name: String,
        pub vertical_angles: Vec<f32>,
        pub horizontal_angles: Vec<f32>,
        pub candela_values: Vec<Vec<f32>>,
        pub lumens: f32,
    }

    impl IESProfile {
        pub fn sample(&self, vertical: f32, horizontal: f32) -> f32 {
            if self.vertical_angles.is_empty() || self.horizontal_angles.is_empty() { return 1.0; }
            let v_idx = self.find_index(&self.vertical_angles, vertical);
            let h_idx = self.find_index(&self.horizontal_angles, horizontal);
            self.candela_values.get(h_idx).and_then(|row| row.get(v_idx)).copied().unwrap_or(1.0) / self.lumens.max(1.0)
        }

        fn find_index(&self, angles: &[f32], value: f32) -> usize {
            for (i, &angle) in angles.iter().enumerate() { if value <= angle { return i; } }
            angles.len().saturating_sub(1)
        }
    }

    #[derive(Debug, Clone)]
    pub struct ShadowCascade {
        pub split_distances: Vec<f32>,
        pub matrices: Vec<[[f32; 4]; 4]>,
        pub resolution: u32,
        pub blend_range: f32,
    }

    impl ShadowCascade {
        pub fn new(cascade_count: usize, near: f32, far: f32, lambda: f32) -> Self {
            let mut splits = Vec::with_capacity(cascade_count + 1);
            splits.push(near);
            for i in 1..=cascade_count {
                let uniform = near + (far - near) * (i as f32 / cascade_count as f32);
                let log = near * (far / near).powf(i as f32 / cascade_count as f32);
                splits.push(lambda * log + (1.0 - lambda) * uniform);
            }
            Self { split_distances: splits, matrices: vec![[[0.0; 4]; 4]; cascade_count], resolution: 2048, blend_range: 0.1 }
        }

        pub fn get_cascade_index(&self, view_z: f32) -> usize {
            for (i, window) in self.split_distances.windows(2).enumerate() {
                if view_z >= window[0] && view_z < window[1] { return i; }
            }
            self.split_distances.len().saturating_sub(2)
        }

        pub fn get_blend_factor(&self, view_z: f32, cascade_idx: usize) -> f32 {
            if cascade_idx >= self.split_distances.len() - 1 { return 0.0; }
            let end = self.split_distances[cascade_idx + 1];
            let blend_start = end * (1.0 - self.blend_range);
            if view_z > blend_start { (view_z - blend_start) / (end - blend_start) } else { 0.0 }
        }
    }

    pub struct ShadowRenderer {
        pub quality: ShadowQuality,
        pub shadow_type: ShadowType,
        pub cascades: ShadowCascade,
        pub pcf_samples: u32,
        pub pcss_blocker_samples: u32,
        pub pcss_light_size: f32,
        pub vsm_min_variance: f32,
        pub vsm_light_bleed_reduction: f32,
        pub esm_exponent: f32,
        pub contact_shadows: bool,
        pub contact_shadow_length: f32,
        pub contact_shadow_thickness: f32,
    }

    impl ShadowRenderer {
        pub fn new(quality: ShadowQuality) -> Self {
            let (pcf, pcss_blocker, resolution) = match quality {
                ShadowQuality::Off => (0, 0, 0),
                ShadowQuality::Low => (4, 4, 512),
                ShadowQuality::Medium => (8, 8, 1024),
                ShadowQuality::High => (16, 16, 2048),
                ShadowQuality::Ultra => (32, 32, 4096),
                ShadowQuality::RayTraced => (1, 1, 4096),
            };
            Self {
                quality, shadow_type: ShadowType::PCSS, cascades: ShadowCascade::new(4, 0.1, 500.0, 0.5),
                pcf_samples: pcf, pcss_blocker_samples: pcss_blocker, pcss_light_size: 0.02,
                vsm_min_variance: 0.00001, vsm_light_bleed_reduction: 0.2, esm_exponent: 80.0,
                contact_shadows: true, contact_shadow_length: 0.1, contact_shadow_thickness: 0.02,
            }
        }

        pub fn pcf_sample_offset(sample: u32, total: u32) -> [f32; 2] {
            let golden_angle = 2.39996323;
            let r = ((sample as f32 + 0.5) / total as f32).sqrt();
            let theta = sample as f32 * golden_angle;
            [r * theta.cos(), r * theta.sin()]
        }

        pub fn estimate_penumbra_size(&self, blocker_depth: f32, receiver_depth: f32) -> f32 {
            self.pcss_light_size * (receiver_depth - blocker_depth) / blocker_depth
        }

        pub fn vsm_chebyshev(&self, moments: [f32; 2], depth: f32) -> f32 {
            let p = if depth <= moments[0] { 1.0 } else {
                let variance = (moments[1] - moments[0] * moments[0]).max(self.vsm_min_variance);
                let d = depth - moments[0];
                variance / (variance + d * d)
            };
            ((p - self.vsm_light_bleed_reduction) / (1.0 - self.vsm_light_bleed_reduction)).clamp(0.0, 1.0)
        }

        pub fn esm_shadow(&self, occluder_depth: f32, receiver_depth: f32) -> f32 {
            (self.esm_exponent * (occluder_depth - receiver_depth)).exp().min(1.0)
        }
    }

    pub struct GlobalIllumination {
        pub enabled: bool,
        pub gi_intensity: f32,
        pub ao_intensity: f32,
        pub ao_radius: f32,
        pub ao_samples: u32,
        pub ao_power: f32,
        pub indirect_diffuse_intensity: f32,
        pub indirect_specular_intensity: f32,
        pub reflection_intensity: f32,
        pub ssr_enabled: bool,
        pub ssr_max_distance: f32,
        pub ssr_thickness: f32,
        pub ssr_stride: f32,
        pub probe_grid_size: [u32; 3],
        pub probe_spacing: f32,
    }

    impl Default for GlobalIllumination {
        fn default() -> Self {
            Self { enabled: true, gi_intensity: 1.0, ao_intensity: 1.0, ao_radius: 0.5, ao_samples: 16, ao_power: 2.0,
                indirect_diffuse_intensity: 1.0, indirect_specular_intensity: 1.0, reflection_intensity: 1.0,
                ssr_enabled: true, ssr_max_distance: 100.0, ssr_thickness: 0.1, ssr_stride: 0.1,
                probe_grid_size: [8, 4, 8], probe_spacing: 4.0 }
        }
    }

    impl GlobalIllumination {
        pub fn calculate_ao(&self, samples: &[[f32; 3]], normal: [f32; 3]) -> f32 {
            let mut occlusion = 0.0;
            for sample in samples {
                let dot = sample[0] * normal[0] + sample[1] * normal[1] + sample[2] * normal[2];
                occlusion += dot.max(0.0);
            }
            (1.0 - occlusion / samples.len() as f32).powf(self.ao_power) * self.ao_intensity
        }

        pub fn hemisphere_sample(i: u32, n: u32) -> [f32; 3] {
            let phi = 2.0 * std::f32::consts::PI * (i as f32 / n as f32);
            let cos_theta = 1.0 - (i as f32 + 0.5) / n as f32;
            let sin_theta = (1.0 - cos_theta * cos_theta).sqrt();
            [sin_theta * phi.cos(), sin_theta * phi.sin(), cos_theta]
        }
    }

    pub fn generate_lighting_shader() -> String {
        r#"
// Advanced Lighting System
#define MAX_LIGHTS 128
#define CASCADE_COUNT 4

struct ShaderLight { float3 position; float3 direction; float3 color; float intensity; float radius; float innerAngle; float outerAngle; int type; bool castShadows; };
cbuffer LightBuffer { ShaderLight lights[MAX_LIGHTS]; int lightCount; };

float DistanceAttenuation(float distance, float radius) {
    float d = distance / radius;
    float atten = 1.0 / (1.0 + d * d);
    float falloff = saturate(1.0 - d * d * d * d);
    return atten * falloff * falloff;
}

float SpotAttenuation(float3 lightDir, float3 toLight, float innerAngle, float outerAngle) {
    float cosOuter = cos(radians(outerAngle));
    float cosInner = cos(radians(innerAngle));
    float cosAngle = dot(-lightDir, toLight);
    return saturate((cosAngle - cosOuter) / (cosInner - cosOuter));
}

float3 CalculateLighting(float3 worldPos, float3 normal, float3 albedo, float roughness, float metallic, float3 viewDir) {
    float3 result = float3(0, 0, 0);
    for (int i = 0; i < lightCount; i++) {
        Light light = lights[i];
        float3 L = light.type == 0 ? -light.direction : normalize(light.position - worldPos);
        float distance = light.type == 0 ? 1.0 : length(light.position - worldPos);
        float atten = light.type == 0 ? 1.0 : DistanceAttenuation(distance, light.radius);
        if (light.type == 2) atten *= SpotAttenuation(light.direction, L, light.innerAngle, light.outerAngle);
        float NdotL = saturate(dot(normal, L));
        float3 H = normalize(L + viewDir);
        float NdotH = saturate(dot(normal, H));
        float3 F0 = lerp(float3(0.04, 0.04, 0.04), albedo, metallic);
        float3 F = F0 + (1.0 - F0) * pow(1.0 - saturate(dot(H, viewDir)), 5.0);
        float D = (roughness * roughness) / (3.14159 * pow(NdotH * NdotH * (roughness * roughness - 1.0) + 1.0, 2.0));
        float k = (roughness + 1.0) * (roughness + 1.0) / 8.0;
        float NdotV = saturate(dot(normal, viewDir));
        float G = (NdotL / (NdotL * (1.0 - k) + k)) * (NdotV / (NdotV * (1.0 - k) + k));
        float3 specular = (D * F * G) / (4.0 * NdotL * NdotV + 0.001);
        float3 kD = (1.0 - F) * (1.0 - metallic);
        result += (kD * albedo / 3.14159 + specular) * light.color * light.intensity * atten * NdotL;
    }
    return result;
}"#.to_string()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEATHER INTEGRATION - DYNAMIC ATMOSPHERIC EFFECTS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod weather_integration {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum IntegrationWeatherType { Clear, Cloudy, Overcast, Foggy, Rainy, Stormy, Snowy, Blizzard, Dusty, Sandstorm }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum CloudType { None, Cirrus, Cumulus, Stratus, Cumulonimbus, Stratocumulus, Altocumulus }

    #[derive(Debug, Clone)]
    pub struct IntegrationWeatherState {
        pub weather_type: IntegrationWeatherType,
        pub cloud_type: CloudType,
        pub cloud_coverage: f32,
        pub cloud_density: f32,
        pub precipitation_intensity: f32,
        pub wind_speed: f32,
        pub wind_direction: [f32; 2],
        pub fog_density: f32,
        pub fog_start: f32,
        pub fog_end: f32,
        pub fog_height: f32,
        pub fog_height_falloff: f32,
        pub lightning_intensity: f32,
        pub lightning_frequency: f32,
        pub sun_intensity: f32,
        pub ambient_intensity: f32,
        pub temperature: f32,
        pub humidity: f32,
        pub wetness: f32,
        pub snow_coverage: f32,
        pub puddle_amount: f32,
    }

    impl Default for IntegrationWeatherState {
        fn default() -> Self {
            Self { weather_type: IntegrationWeatherType::Clear, cloud_type: CloudType::Cumulus, cloud_coverage: 0.3, cloud_density: 0.5, precipitation_intensity: 0.0,
                wind_speed: 1.0, wind_direction: [1.0, 0.0], fog_density: 0.0, fog_start: 100.0, fog_end: 1000.0, fog_height: 50.0, fog_height_falloff: 0.1,
                lightning_intensity: 0.0, lightning_frequency: 0.0, sun_intensity: 1.0, ambient_intensity: 0.3, temperature: 20.0, humidity: 0.5, wetness: 0.0, snow_coverage: 0.0, puddle_amount: 0.0 }
        }
    }

    impl IntegrationWeatherState {
        pub fn clear() -> Self { Self::default() }
        pub fn cloudy() -> Self { Self { weather_type: IntegrationWeatherType::Cloudy, cloud_coverage: 0.6, sun_intensity: 0.8, ..Default::default() } }
        pub fn overcast() -> Self { Self { weather_type: IntegrationWeatherType::Overcast, cloud_type: CloudType::Stratus, cloud_coverage: 1.0, sun_intensity: 0.4, ambient_intensity: 0.5, ..Default::default() } }
        pub fn foggy() -> Self { Self { weather_type: IntegrationWeatherType::Foggy, fog_density: 0.5, fog_start: 10.0, fog_end: 200.0, sun_intensity: 0.3, ..Default::default() } }
        pub fn rainy() -> Self { Self { weather_type: IntegrationWeatherType::Rainy, cloud_type: CloudType::Cumulonimbus, cloud_coverage: 0.9, precipitation_intensity: 0.7, sun_intensity: 0.2, wetness: 0.8, puddle_amount: 0.5, humidity: 0.9, ..Default::default() } }
        pub fn stormy() -> Self { Self { weather_type: IntegrationWeatherType::Stormy, cloud_type: CloudType::Cumulonimbus, cloud_coverage: 1.0, precipitation_intensity: 1.0, wind_speed: 5.0, lightning_intensity: 1.0, lightning_frequency: 0.3, sun_intensity: 0.1, wetness: 1.0, puddle_amount: 0.8, ..Default::default() } }
        pub fn snowy() -> Self { Self { weather_type: IntegrationWeatherType::Snowy, cloud_coverage: 0.8, precipitation_intensity: 0.5, temperature: -5.0, snow_coverage: 0.6, sun_intensity: 0.6, ..Default::default() } }
        pub fn blizzard() -> Self { Self { weather_type: IntegrationWeatherType::Blizzard, cloud_coverage: 1.0, precipitation_intensity: 1.0, wind_speed: 8.0, fog_density: 0.7, temperature: -15.0, snow_coverage: 1.0, sun_intensity: 0.1, ..Default::default() } }

        pub fn lerp(&self, other: &IntegrationWeatherState, t: f32) -> IntegrationWeatherState {
            IntegrationWeatherState {
                weather_type: if t < 0.5 { self.weather_type } else { other.weather_type },
                cloud_type: if t < 0.5 { self.cloud_type } else { other.cloud_type },
                cloud_coverage: self.cloud_coverage + (other.cloud_coverage - self.cloud_coverage) * t,
                cloud_density: self.cloud_density + (other.cloud_density - self.cloud_density) * t,
                precipitation_intensity: self.precipitation_intensity + (other.precipitation_intensity - self.precipitation_intensity) * t,
                wind_speed: self.wind_speed + (other.wind_speed - self.wind_speed) * t,
                wind_direction: [self.wind_direction[0] + (other.wind_direction[0] - self.wind_direction[0]) * t, self.wind_direction[1] + (other.wind_direction[1] - self.wind_direction[1]) * t],
                fog_density: self.fog_density + (other.fog_density - self.fog_density) * t,
                fog_start: self.fog_start + (other.fog_start - self.fog_start) * t,
                fog_end: self.fog_end + (other.fog_end - self.fog_end) * t,
                fog_height: self.fog_height + (other.fog_height - self.fog_height) * t,
                fog_height_falloff: self.fog_height_falloff + (other.fog_height_falloff - self.fog_height_falloff) * t,
                lightning_intensity: self.lightning_intensity + (other.lightning_intensity - self.lightning_intensity) * t,
                lightning_frequency: self.lightning_frequency + (other.lightning_frequency - self.lightning_frequency) * t,
                sun_intensity: self.sun_intensity + (other.sun_intensity - self.sun_intensity) * t,
                ambient_intensity: self.ambient_intensity + (other.ambient_intensity - self.ambient_intensity) * t,
                temperature: self.temperature + (other.temperature - self.temperature) * t,
                humidity: self.humidity + (other.humidity - self.humidity) * t,
                wetness: self.wetness + (other.wetness - self.wetness) * t,
                snow_coverage: self.snow_coverage + (other.snow_coverage - self.snow_coverage) * t,
                puddle_amount: self.puddle_amount + (other.puddle_amount - self.puddle_amount) * t,
            }
        }
    }

    pub struct IntegrationWeatherSystem {
        pub current_state: IntegrationWeatherState,
        pub target_state: IntegrationWeatherState,
        pub transition_progress: f32,
        pub transition_duration: f32,
        pub time_of_day: f32,
        pub day_length: f32,
        pub random_seed: u32,
    }

    impl IntegrationWeatherSystem {
        pub fn new() -> Self { Self { current_state: IntegrationWeatherState::default(), target_state: IntegrationWeatherState::default(), transition_progress: 1.0, transition_duration: 30.0, time_of_day: 12.0, day_length: 24.0, random_seed: 42 } }

        pub fn set_weather(&mut self, weather: IntegrationWeatherState, duration: f32) {
            self.target_state = weather;
            self.transition_duration = duration;
            self.transition_progress = 0.0;
        }

        pub fn update(&mut self, dt: f32) {
            self.time_of_day = (self.time_of_day + dt / 60.0) % self.day_length;
            if self.transition_progress < 1.0 {
                self.transition_progress = (self.transition_progress + dt / self.transition_duration).min(1.0);
                self.current_state = self.current_state.lerp(&self.target_state, self.transition_progress);
            }
        }

        pub fn get_sun_position(&self) -> [f32; 3] {
            let sun_angle = (self.time_of_day / self.day_length) * 2.0 * std::f32::consts::PI - std::f32::consts::PI / 2.0;
            let height = sun_angle.sin();
            let horizontal = sun_angle.cos();
            [horizontal, height.max(-0.2), 0.3]
        }

        pub fn get_sun_color(&self) -> [f32; 3] {
            let height = self.get_sun_position()[1];
            let sunset_factor = ((0.3 - height.abs()) / 0.3).clamp(0.0, 1.0);
            let day_color = [1.0, 0.98, 0.95];
            let sunset_color = [1.0, 0.5, 0.2];
            [day_color[0] * (1.0 - sunset_factor) + sunset_color[0] * sunset_factor,
             day_color[1] * (1.0 - sunset_factor) + sunset_color[1] * sunset_factor,
             day_color[2] * (1.0 - sunset_factor) + sunset_color[2] * sunset_factor]
        }

        pub fn is_daytime(&self) -> bool { self.time_of_day > 6.0 && self.time_of_day < 18.0 }
    }

    #[derive(Debug, Clone)]
    pub struct CloudRenderer {
        pub density_scale: f32,
        pub absorption: f32,
        pub scattering: f32,
        pub phase_g: f32,
        pub detail_scale: f32,
        pub erosion_amount: f32,
        pub anvil_bias: f32,
        pub light_step_count: u32,
        pub shadow_step_count: u32,
        pub noise_octaves: u32,
    }

    impl Default for CloudRenderer {
        fn default() -> Self {
            Self { density_scale: 0.1, absorption: 0.04, scattering: 0.06, phase_g: 0.8, detail_scale: 4.0, erosion_amount: 0.3, anvil_bias: 0.5, light_step_count: 6, shadow_step_count: 4, noise_octaves: 4 }
        }
    }

    impl CloudRenderer {
        pub fn henyey_greenstein(&self, cos_theta: f32) -> f32 {
            let g = self.phase_g;
            let denom = 1.0 + g * g - 2.0 * g * cos_theta;
            (1.0 - g * g) / (4.0 * std::f32::consts::PI * denom.powf(1.5))
        }

        pub fn beer_lambert(&self, density: f32, distance: f32) -> f32 {
            (-self.absorption * density * distance).exp()
        }

        pub fn powder_effect(&self, density: f32, cos_theta: f32) -> f32 {
            let powder = 1.0 - (-density * 2.0).exp();
            let beers = (-density).exp();
            beers * (1.0 - powder * (1.0 - cos_theta) * 0.5)
        }
    }

    #[derive(Debug, Clone)]
    pub struct PrecipitationRenderer {
        pub particle_count: u32,
        pub particle_size: f32,
        pub particle_speed: f32,
        pub particle_stretch: f32,
        pub splash_intensity: f32,
        pub ripple_frequency: f32,
        pub snow_accumulation_rate: f32,
        pub snow_melt_rate: f32,
        pub wetness_spread_rate: f32,
        pub wetness_dry_rate: f32,
        pub drip_intensity: f32,
    }

    impl Default for PrecipitationRenderer {
        fn default() -> Self {
            Self { particle_count: 10000, particle_size: 0.01, particle_speed: 10.0, particle_stretch: 5.0, splash_intensity: 0.5, ripple_frequency: 2.0,
                snow_accumulation_rate: 0.01, snow_melt_rate: 0.005, wetness_spread_rate: 0.1, wetness_dry_rate: 0.02, drip_intensity: 0.3 }
        }
    }

    pub fn generate_weather_shader() -> String {
        r#"
// Weather Integration System
cbuffer WeatherBuffer {
    float cloudCoverage; float cloudDensity; float precipitationIntensity;
    float2 windDirection; float windSpeed; float fogDensity; float fogStart; float fogEnd;
    float wetness; float snowCoverage; float puddleAmount; float time;
};

float3 ApplyFog(float3 color, float3 fogColor, float distance, float height) {
    float fogFactor = saturate((distance - fogStart) / (fogEnd - fogStart));
    float heightFog = exp(-height * 0.01) * fogDensity;
    fogFactor = saturate(fogFactor + heightFog);
    return lerp(color, fogColor, fogFactor);
}

float3 ApplyWetness(float3 albedo, float3 normal, float wetAmount) {
    float3 wetAlbedo = albedo * 0.6;
    float wetRoughness = 0.1;
    float wetSpecular = 0.5;
    return lerp(albedo, wetAlbedo, wetAmount);
}

float3 ApplySnow(float3 albedo, float3 normal, float snowAmount, float3 upVector) {
    float snowFacing = saturate(dot(normal, upVector));
    float actualSnow = snowAmount * snowFacing;
    float3 snowColor = float3(0.95, 0.95, 1.0);
    return lerp(albedo, snowColor, actualSnow);
}

float GetPuddleMask(float2 uv, float puddleAmount) {
    float noise = frac(sin(dot(uv, float2(12.9898, 78.233))) * 43758.5453);
    return step(noise, puddleAmount) * step(0.1, puddleAmount);
}

float3 RainRipples(float2 uv, float time, float intensity) {
    float2 center1 = float2(0.3, 0.4);
    float2 center2 = float2(0.7, 0.6);
    float ripple1 = sin(length(uv - center1) * 50.0 - time * 5.0) * exp(-length(uv - center1) * 3.0);
    float ripple2 = sin(length(uv - center2) * 50.0 - time * 5.0 + 1.5) * exp(-length(uv - center2) * 3.0);
    return float3(ripple1 + ripple2, ripple1 + ripple2, 0) * intensity * 0.1;
}"#.to_string()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CINEMATIC EFFECTS - FILM-QUALITY POST-PROCESSING
// ═══════════════════════════════════════════════════════════════════════════════

pub mod cinematic_effects {
    use super::*;

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum FilmEmulation { None, Kodak5219, Kodak5207, Kodak2383, FujiEterna, Arri, RedLogFilm, SonyVenice, BlackmagicFilm }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum AspectRatio { R16x9, R21x9, R2_35x1, R2_39x1, R1_85x1, R4x3, R1x1, RAnamorphic, Custom(f32, f32) }

    impl AspectRatio {
        pub fn value(&self) -> f32 {
            match self {
                Self::R16x9 => 16.0 / 9.0,
                Self::R21x9 => 21.0 / 9.0,
                Self::R2_35x1 => 2.35,
                Self::R2_39x1 => 2.39,
                Self::R1_85x1 => 1.85,
                Self::R4x3 => 4.0 / 3.0,
                Self::R1x1 => 1.0,
                Self::RAnamorphic => 2.39,
                Self::Custom(w, h) => w / h,
            }
        }

        pub fn letterbox_height(&self, screen_aspect: f32) -> f32 {
            let target = self.value();
            if screen_aspect > target { (1.0 - target / screen_aspect) / 2.0 } else { 0.0 }
        }
    }

    #[derive(Debug, Clone)]
    pub struct FilmGrainSettings {
        pub intensity: f32,
        pub size: f32,
        pub roughness: f32,
