// PHYSICALLY BASED MATERIALS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct PBRMaterial {
    pub name: String,
    pub albedo: Vec3,
    pub metallic: f32,
    pub roughness: f32,
    pub normal_strength: f32,
    pub ao_strength: f32,
    pub emission: Vec3,
    pub emission_strength: f32,
    pub ior: f32,
    pub transmission: f32,
    pub transmission_roughness: f32,
    pub clearcoat: f32,
    pub clearcoat_roughness: f32,
    pub anisotropy: f32,
    pub anisotropy_rotation: f32,
    pub sheen: f32,
    pub sheen_tint: f32,
    pub subsurface: f32,
    pub subsurface_color: Vec3,
    pub subsurface_radius: Vec3,
}

impl PBRMaterial {
    pub fn new(name: &str) -> Self {
        Self {
            name: name.to_string(), albedo: Vec3::new(0.8, 0.8, 0.8), metallic: 0.0, roughness: 0.5,
            normal_strength: 1.0, ao_strength: 1.0, emission: Vec3::zero(), emission_strength: 0.0,
            ior: 1.5, transmission: 0.0, transmission_roughness: 0.0, clearcoat: 0.0, clearcoat_roughness: 0.03,
            anisotropy: 0.0, anisotropy_rotation: 0.0, sheen: 0.0, sheen_tint: 0.5,
            subsurface: 0.0, subsurface_color: Vec3::new(1.0, 0.2, 0.1), subsurface_radius: Vec3::new(1.0, 0.2, 0.1),
        }
    }

    pub fn metal(name: &str, albedo: Vec3, roughness: f32) -> Self { let mut m = Self::new(name); m.albedo = albedo; m.metallic = 1.0; m.roughness = roughness; m }
    pub fn dielectric(name: &str, albedo: Vec3, roughness: f32) -> Self { let mut m = Self::new(name); m.albedo = albedo; m.metallic = 0.0; m.roughness = roughness; m }
    pub fn glass(name: &str, ior: f32) -> Self { let mut m = Self::new(name); m.transmission = 1.0; m.ior = ior; m.roughness = 0.0; m }
    pub fn emissive(name: &str, color: Vec3, strength: f32) -> Self { let mut m = Self::new(name); m.emission = color; m.emission_strength = strength; m }

    pub fn fresnel_schlick(&self, cos_theta: f32) -> Vec3 {
        let f0 = if self.metallic > 0.0 { self.albedo } else { Vec3::splat(((self.ior - 1.0) / (self.ior + 1.0)).powi(2)) };
        f0 + (Vec3::one() - f0) * (1.0 - cos_theta).powi(5)
    }

    pub fn ggx_distribution(&self, n_dot_h: f32) -> f32 {
        let a = self.roughness * self.roughness;
        let a2 = a * a;
        let denom = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
        a2 / (PI * denom * denom)
    }

    pub fn smith_ggx_geometry(&self, n_dot_v: f32, n_dot_l: f32) -> f32 {
        let r = self.roughness + 1.0;
        let k = (r * r) / 8.0;
        let g1_v = n_dot_v / (n_dot_v * (1.0 - k) + k);
        let g1_l = n_dot_l / (n_dot_l * (1.0 - k) + k);
        g1_v * g1_l
    }

    pub fn evaluate_brdf(&self, n: Vec3, v: Vec3, l: Vec3) -> Vec3 {
        let h = (v + l).normalized();
        let n_dot_v = n.dot(v).max(0.001);
        let n_dot_l = n.dot(l).max(0.001);
        let n_dot_h = n.dot(h).max(0.0);
        let v_dot_h = v.dot(h).max(0.0);
        let d = self.ggx_distribution(n_dot_h);
        let g = self.smith_ggx_geometry(n_dot_v, n_dot_l);
        let f = self.fresnel_schlick(v_dot_h);
        let spec = (d * g * f) / (4.0 * n_dot_v * n_dot_l);
        let k_d = (Vec3::one() - f) * (1.0 - self.metallic);
        let diffuse = self.albedo / PI;
        (k_d * diffuse + spec) * n_dot_l
    }
}

pub struct MaterialLibrary { pub materials: HashMap<String, PBRMaterial> }
impl MaterialLibrary {
    pub fn new() -> Self {
        let mut lib = Self { materials: HashMap::new() };
        lib.add(PBRMaterial::metal("Gold", Vec3::new(1.0, 0.766, 0.336), 0.3));
        lib.add(PBRMaterial::metal("Silver", Vec3::new(0.972, 0.960, 0.915), 0.2));
        lib.add(PBRMaterial::metal("Copper", Vec3::new(0.955, 0.637, 0.538), 0.35));
        lib.add(PBRMaterial::metal("Iron", Vec3::new(0.560, 0.570, 0.580), 0.4));
        lib.add(PBRMaterial::metal("Aluminum", Vec3::new(0.913, 0.921, 0.925), 0.25));
        lib.add(PBRMaterial::dielectric("Plastic", Vec3::new(0.04, 0.04, 0.04), 0.4));
        lib.add(PBRMaterial::dielectric("Rubber", Vec3::new(0.02, 0.02, 0.02), 0.8));
        lib.add(PBRMaterial::glass("Glass", 1.5));
        lib.add(PBRMaterial::glass("Diamond", 2.42));
        lib.add(PBRMaterial::glass("Water", 1.33));
        lib
    }
    pub fn add(&mut self, mat: PBRMaterial) { self.materials.insert(mat.name.clone(), mat); }
    pub fn get(&self, name: &str) -> Option<&PBRMaterial> { self.materials.get(name) }
}

