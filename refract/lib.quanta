/// Time of day information
pub struct TimeOfDay {
    game_hour: f32,      // 0-24
    game_day: u32,
    game_month: u32,
    game_year: u32,

    // Derived values
    sun_altitude: f32,   // Degrees
    sun_azimuth: f32,    // Degrees
    moon_phase: f32,     // 0-1
    is_night: bool,
    is_twilight: bool,

    // Time periods
    dawn_start: f32,
    dawn_end: f32,
    dusk_start: f32,
    dusk_end: f32,
}

impl TimeOfDay {
    pub fn get_sun_position(&self) -> Vec3 {
        shader {
            let altitude_rad = radians(self.sun_altitude);
            let azimuth_rad = radians(self.sun_azimuth);

            Vec3::new(
                cos(altitude_rad) * sin(azimuth_rad),
                sin(altitude_rad),
                cos(altitude_rad) * cos(azimuth_rad)
            )
        }
    }

    pub fn get_time_blend(&self) -> TimeBlend {
        shader {
            let hour = self.game_hour;

            if hour < self.dawn_start {
                TimeBlend::Night(1.0)
            } else if hour < self.dawn_end {
                let t = (hour - self.dawn_start) / (self.dawn_end - self.dawn_start);
                TimeBlend::Dawn(t)
            } else if hour < self.dusk_start {
                TimeBlend::Day(1.0)
            } else if hour < self.dusk_end {
                let t = (hour - self.dusk_start) / (self.dusk_end - self.dusk_start);
                TimeBlend::Dusk(t)
            } else {
                TimeBlend::Night(1.0)
            }
        }
    }
}

/// Time period blend
pub enum TimeBlend {
    Night(f32),
    Dawn(f32),
    Day(f32),
    Dusk(f32),
}

