// ═══════════════════════════════════════════════════════════════════════════════
// ENB/RESHADE BRIDGE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ENBReShadebridge {
    enb_active: bool,
    reshade_active: bool,
    shared_textures: HashMap<String, SharedTexture>,
    sync_mode: BridgeSyncMode,
    priority: RenderPriority,
}

#[derive(Debug, Clone)]
pub struct SharedTexture {
    pub name: String,
    pub enb_handle: u64,
    pub reshade_handle: u64,
    pub format: TextureFormat,
    pub width: u32,
    pub height: u32,
    pub shared: bool,
}

#[derive(Debug, Clone, Copy)]
pub enum BridgeSyncMode { Sequential, Interleaved, Parallel }

#[derive(Debug, Clone, Copy)]
pub enum RenderPriority { ENBFirst, ReShadeFirst, Custom(u8) }

#[derive(Debug, Clone, Copy)]
pub enum TextureFormat { RGBA8, RGBA16F, RGBA32F, R11G11B10F, Depth32F }

impl ENBReShadebridge {
    pub fn new() -> Self {
        ENBReShadebridge {
            enb_active: false, reshade_active: false, shared_textures: HashMap::new(),
            sync_mode: BridgeSyncMode::Sequential, priority: RenderPriority::ENBFirst,
        }
    }

    pub fn detect_installations(&mut self) -> (bool, bool) {
        self.enb_active = self.check_enb_dll();
        self.reshade_active = self.check_reshade_dll();
        (self.enb_active, self.reshade_active)
    }

    fn check_enb_dll(&self) -> bool {
        std::path::Path::new("d3d11.dll").exists() || std::path::Path::new("d3dcompiler_46e.dll").exists()
    }

    fn check_reshade_dll(&self) -> bool {
        std::path::Path::new("ReShade.ini").exists() || std::path::Path::new("reshade-shaders").exists()
    }

    pub fn register_shared_texture(&mut self, name: &str, format: TextureFormat, w: u32, h: u32) {
        self.shared_textures.insert(name.to_string(), SharedTexture {
            name: name.to_string(), enb_handle: 0, reshade_handle: 0, format, width: w, height: h, shared: true,
        });
    }

    pub fn sync_texture(&mut self, name: &str) {
        if let Some(tex) = self.shared_textures.get_mut(name) {
            // Copy between ENB and ReShade texture handles
            tex.shared = true;
        }
    }

    pub fn execute_render_pass(&self) {
        match self.priority {
            RenderPriority::ENBFirst => { /* ENB -> ReShade */ }
            RenderPriority::ReShadeFirst => { /* ReShade -> ENB */ }
            RenderPriority::Custom(_) => { /* Custom order */ }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GAME-SPECIFIC HOOKS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct GameHooks {
    game: DetectedGame,
    hooks: Vec<InstalledHook>,
    vtable_patches: Vec<VTablePatch>,
    original_functions: HashMap<String, usize>,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum DetectedGame {
    SkyrimSE, SkyrimLE, SkyrimVR,
    Fallout4, Fallout4VR, Fallout76,
    Starfield, Oblivion, NewVegas, Fallout3,
    TheWitcher3, Cyberpunk2077, EldenRing,
    Unknown,
}

#[derive(Debug, Clone)]
pub struct InstalledHook {
    pub name: String,
    pub address: usize,
    pub original_bytes: Vec<u8>,
    pub hook_function: usize,
    pub enabled: bool,
}

#[derive(Debug, Clone)]
pub struct VTablePatch {
    pub class_name: String,
    pub vtable_address: usize,
    pub method_index: usize,
    pub original_method: usize,
    pub new_method: usize,
}

impl GameHooks {
    pub fn new() -> Self {
        GameHooks { game: DetectedGame::Unknown, hooks: Vec::new(), vtable_patches: Vec::new(), original_functions: HashMap::new() }
    }

    pub fn detect_game(&mut self) -> DetectedGame {
        let exe_name = std::env::current_exe().ok().and_then(|p| p.file_name().map(|n| n.to_string_lossy().to_lowercase().to_string())).unwrap_or_default();

        self.game = match exe_name.as_str() {
            "skyrimse.exe" | "skyrimspecialedition.exe" => DetectedGame::SkyrimSE,
            "tesv.exe" | "skyrim.exe" => DetectedGame::SkyrimLE,
            "skyrimvr.exe" => DetectedGame::SkyrimVR,
            "fallout4.exe" => DetectedGame::Fallout4,
            "fallout4vr.exe" => DetectedGame::Fallout4VR,
            "starfield.exe" => DetectedGame::Starfield,
            "oblivion.exe" => DetectedGame::Oblivion,
            "falloutnv.exe" => DetectedGame::NewVegas,
            "fallout3.exe" => DetectedGame::Fallout3,
            "witcher3.exe" => DetectedGame::TheWitcher3,
            "cyberpunk2077.exe" => DetectedGame::Cyberpunk2077,
            "eldenring.exe" => DetectedGame::EldenRing,
            _ => DetectedGame::Unknown,
        };
        self.game
    }

    pub fn install_hook(&mut self, name: &str, address: usize, hook_fn: usize) -> bool {
        let original_bytes = self.read_memory(address, 14);
        self.hooks.push(InstalledHook { name: name.to_string(), address, original_bytes, hook_function: hook_fn, enabled: true });
        self.original_functions.insert(name.to_string(), address);
        true
    }

    pub fn remove_hook(&mut self, name: &str) {
        if let Some(idx) = self.hooks.iter().position(|h| h.name == name) {
            let hook = &self.hooks[idx];
            self.write_memory(hook.address, &hook.original_bytes);
            self.hooks.remove(idx);
        }
    }

    pub fn patch_vtable(&mut self, class: &str, vtable: usize, index: usize, new_method: usize) {
        let original = self.read_ptr(vtable + index * 8);
        self.vtable_patches.push(VTablePatch { class_name: class.to_string(), vtable_address: vtable, method_index: index, original_method: original, new_method });
        self.write_ptr(vtable + index * 8, new_method);
    }

    fn read_memory(&self, _addr: usize, size: usize) -> Vec<u8> { vec![0u8; size] }
    fn write_memory(&self, _addr: usize, _data: &[u8]) {}
    fn read_ptr(&self, _addr: usize) -> usize { 0 }
    fn write_ptr(&self, _addr: usize, _value: usize) {}
}

// ═══════════════════════════════════════════════════════════════════════════════
// SHADER INJECTION PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ShaderInjector {
    injected_shaders: HashMap<u64, InjectedShader>,
    replacement_map: HashMap<u64, u64>,
    bytecode_patches: Vec<BytecodePatch>,
    compile_cache: HashMap<u64, Vec<u8>>,
}

#[derive(Debug, Clone)]
pub struct InjectedShader {
    pub original_hash: u64,
    pub replacement_hash: u64,
    pub shader_type: ShaderStage,
    pub original_bytecode: Vec<u8>,
    pub modified_bytecode: Vec<u8>,
    pub source_file: Option<String>,
}

#[derive(Debug, Clone, Copy)]
pub enum ShaderStage { Vertex, Hull, Domain, Geometry, Pixel, Compute }

#[derive(Debug, Clone)]
pub struct BytecodePatch {
    pub shader_hash: u64,
    pub offset: usize,
    pub original: Vec<u8>,
    pub replacement: Vec<u8>,
    pub description: String,
}

impl ShaderInjector {
    pub fn new() -> Self {
        ShaderInjector { injected_shaders: HashMap::new(), replacement_map: HashMap::new(), bytecode_patches: Vec::new(), compile_cache: HashMap::new() }
    }

    pub fn intercept_shader(&mut self, hash: u64, bytecode: &[u8], stage: ShaderStage) -> Option<Vec<u8>> {
        if let Some(replacement_hash) = self.replacement_map.get(&hash) {
            return self.compile_cache.get(replacement_hash).cloned();
        }

        if let Some(patches) = self.get_patches_for_shader(hash) {
            let mut modified = bytecode.to_vec();
            for patch in patches {
                if patch.offset + patch.original.len() <= modified.len() {
                    if &modified[patch.offset..patch.offset + patch.original.len()] == patch.original.as_slice() {
                        modified[patch.offset..patch.offset + patch.replacement.len()].copy_from_slice(&patch.replacement);
                    }
                }
            }
            return Some(modified);
        }

        None
    }

    pub fn register_replacement(&mut self, original_hash: u64, replacement: InjectedShader) {
        self.replacement_map.insert(original_hash, replacement.replacement_hash);
        self.compile_cache.insert(replacement.replacement_hash, replacement.modified_bytecode.clone());
        self.injected_shaders.insert(original_hash, replacement);
    }

    pub fn add_bytecode_patch(&mut self, patch: BytecodePatch) {
        self.bytecode_patches.push(patch);
    }

    fn get_patches_for_shader(&self, hash: u64) -> Option<Vec<&BytecodePatch>> {
        let patches: Vec<_> = self.bytecode_patches.iter().filter(|p| p.shader_hash == hash).collect();
        if patches.is_empty() { None } else { Some(patches) }
    }

    pub fn hash_shader(bytecode: &[u8]) -> u64 {
        bytecode.iter().fold(0u64, |acc, &b| acc.wrapping_mul(31).wrapping_add(b as u64))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION HOT-RELOAD
// ═══════════════════════════════════════════════════════════════════════════════

pub struct ConfigHotReload {
    watched_files: HashMap<String, WatchedConfig>,
    last_check: u64,
    check_interval_ms: u64,
    callbacks: HashMap<String, Vec<Box<dyn Fn(&ConfigChange)>>>,
}

#[derive(Debug, Clone)]
pub struct WatchedConfig {
    pub path: String,
    pub last_modified: u64,
    pub checksum: u32,
    pub sections: HashMap<String, HashMap<String, String>>,
}

#[derive(Debug, Clone)]
pub struct ConfigChange {
    pub file: String,
    pub section: String,
    pub key: String,
    pub old_value: Option<String>,
    pub new_value: String,
}

impl ConfigHotReload {
    pub fn new(interval_ms: u64) -> Self {
        ConfigHotReload { watched_files: HashMap::new(), last_check: 0, check_interval_ms: interval_ms, callbacks: HashMap::new() }
    }

    pub fn watch(&mut self, path: &str) {
        if let Ok(content) = std::fs::read_to_string(path) {
            let sections = self.parse_ini(&content);
            self.watched_files.insert(path.to_string(), WatchedConfig {
                path: path.to_string(), last_modified: 0, checksum: self.compute_checksum(&content), sections,
            });
        }
    }

    pub fn check_updates(&mut self) -> Vec<ConfigChange> {
        let mut changes = Vec::new();
        let paths: Vec<_> = self.watched_files.keys().cloned().collect();

        for path in paths {
            if let Ok(content) = std::fs::read_to_string(&path) {
                let new_checksum = self.compute_checksum(&content);
                if let Some(watched) = self.watched_files.get_mut(&path) {
                    if new_checksum != watched.checksum {
                        let new_sections = self.parse_ini(&content);
                        for (section, values) in &new_sections {
                            for (key, new_val) in values {
                                let old_val = watched.sections.get(section).and_then(|s| s.get(key)).cloned();
                                if old_val.as_ref() != Some(new_val) {
                                    changes.push(ConfigChange {
                                        file: path.clone(), section: section.clone(), key: key.clone(),
                                        old_value: old_val, new_value: new_val.clone(),
                                    });
                                }
                            }
                        }
                        watched.sections = new_sections;
                        watched.checksum = new_checksum;
                    }
                }
            }
        }

        for change in &changes {
            if let Some(cbs) = self.callbacks.get(&change.file) {
                for cb in cbs { cb(change); }
            }
        }

        changes
    }

    fn parse_ini(&self, content: &str) -> HashMap<String, HashMap<String, String>> {
        let mut sections = HashMap::new();
        let mut current_section = String::new();

        for line in content.lines() {
            let line = line.trim();
            if line.starts_with('[') && line.ends_with(']') {
                current_section = line[1..line.len()-1].to_string();
                sections.insert(current_section.clone(), HashMap::new());
            } else if let Some((key, value)) = line.split_once('=') {
                if let Some(section) = sections.get_mut(&current_section) {
                    section.insert(key.trim().to_string(), value.trim().to_string());
                }
            }
        }
        sections
    }

    fn compute_checksum(&self, data: &str) -> u32 {
        data.bytes().fold(0u32, |acc, b| acc.wrapping_add(b as u32))
    }

    pub fn get_value(&self, path: &str, section: &str, key: &str) -> Option<String> {
        self.watched_files.get(path)?.sections.get(section)?.get(key).cloned()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEMORY PATCH SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub struct MemoryPatcher {
    patches: Vec<MemoryPatch>,
    pattern_cache: HashMap<String, Vec<usize>>,
    enabled: bool,
}

#[derive(Debug, Clone)]
pub struct MemoryPatch {
    pub name: String,
    pub address: usize,
    pub original: Vec<u8>,
    pub patched: Vec<u8>,
    pub applied: bool,
    pub description: String,
}

impl MemoryPatcher {
    pub fn new() -> Self { MemoryPatcher { patches: Vec::new(), pattern_cache: HashMap::new(), enabled: true } }

    pub fn find_pattern(&mut self, pattern: &str, mask: &str) -> Vec<usize> {
        if let Some(cached) = self.pattern_cache.get(pattern) { return cached.clone(); }

        let results = self.scan_memory(pattern, mask);
        self.pattern_cache.insert(pattern.to_string(), results.clone());
        results
    }

    fn scan_memory(&self, _pattern: &str, _mask: &str) -> Vec<usize> { Vec::new() }

    pub fn add_patch(&mut self, name: &str, address: usize, original: Vec<u8>, patched: Vec<u8>, desc: &str) {
        self.patches.push(MemoryPatch { name: name.to_string(), address, original, patched, applied: false, description: desc.to_string() });
    }

    pub fn apply_patch(&mut self, name: &str) -> bool {
        if let Some(patch) = self.patches.iter_mut().find(|p| p.name == name && !p.applied) {
            patch.applied = true;
            return true;
        }
        false
    }

    pub fn revert_patch(&mut self, name: &str) -> bool {
        if let Some(patch) = self.patches.iter_mut().find(|p| p.name == name && p.applied) {
            patch.applied = false;
            return true;
        }
        false
    }

    pub fn apply_all(&mut self) { for patch in &mut self.patches { patch.applied = true; } }
    pub fn revert_all(&mut self) { for patch in &mut self.patches { patch.applied = false; } }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENB PRESET MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod presets {
    use super::*;

    pub struct PresetsENBPreset {
        pub name: String,
        pub author: String,
        pub version: String,
        pub target_game: TargetGame,
        pub enb_version: ENBVersion,
        pub files: Vec<PresetFile>,
        pub screenshots: Vec<String>,
        pub description: String,
        pub performance_impact: PerformanceImpact,
    }

    pub struct PresetFile {
        pub path: String,
        pub content: Vec<u8>,
        pub is_shader: bool,
        pub is_texture: bool,
    }

    pub enum PerformanceImpact { Minimal, Light, Medium, Heavy, Extreme }

    pub struct PresetsPresetManager {
        installed_presets: HashMap<String, PresetsENBPreset>,
        active_preset: Option<String>,
        backup_path: String,
        game_path: String,
    }

    impl PresetsPresetManager {
        pub fn new(game_path: &str, backup_path: &str) -> Self {
            Self {
                installed_presets: HashMap::new(),
                active_preset: None,
                backup_path: backup_path.to_string(),
                game_path: game_path.to_string(),
            }
        }

        pub fn import_preset(&mut self, archive_path: &str) -> Result<String, String> {
            // Extract and parse preset
            let preset = PresetsENBPreset {
                name: "Imported".to_string(), author: "Unknown".to_string(),
                version: "1.0.0".to_string(), target_game: TargetGame::Unknown,
                enb_version: ENBVersion::Unknown, files: Vec::new(),
                screenshots: Vec::new(), description: String::new(),
                performance_impact: PerformanceImpact::Medium,
            };
            let id = preset.name.clone();
            self.installed_presets.insert(id.clone(), preset);
            Ok(id)
        }

        pub fn export_preset(&self, preset_id: &str, dest: &str) -> Result<String, String> {
            let preset = self.installed_presets.get(preset_id).ok_or("Preset not found")?;
            let archive = format!("{}/{}.zip", dest, preset.name);
            // Create archive with all preset files
            Ok(archive)
        }

        pub fn activate_preset(&mut self, preset_id: &str) -> Result<(), String> {
            if self.active_preset.is_some() { self.deactivate_current()?; }
            let preset = self.installed_presets.get(preset_id).ok_or("Preset not found")?;
            for file in &preset.files {
                let dest = format!("{}/{}", self.game_path, file.path);
                // Copy file to game directory
            }
            self.active_preset = Some(preset_id.to_string());
            Ok(())
        }

        pub fn deactivate_current(&mut self) -> Result<(), String> {
            if let Some(preset_id) = &self.active_preset {
                let preset = self.installed_presets.get(preset_id).ok_or("Preset not found")?;
                for file in &preset.files {
                    let path = format!("{}/{}", self.game_path, file.path);
                    // Remove file from game directory
                }
            }
            self.active_preset = None;
            Ok(())
        }

        pub fn backup_original(&self) -> Result<(), String> {
            // Backup original game shaders
            Ok(())
        }

        pub fn restore_original(&self) -> Result<(), String> {
            // Restore from backup
            Ok(())
        }

        pub fn list_presets(&self) -> Vec<(&String, &PresetsENBPreset)> {
            self.installed_presets.iter().collect()
        }
    }

    pub struct PresetComparison {
        pub preset_a: String,
        pub preset_b: String,
        pub differences: Vec<FileDifference>,
    }

    pub struct FileDifference {
        pub path: String,
        pub diff_type: DiffType,
        pub details: String,
    }

    pub enum DiffType { OnlyInA, OnlyInB, Different, Identical }

    impl PresetComparison {
        pub fn compare(manager: &PresetsPresetManager, a: &str, b: &str) -> Result<Self, String> {
            let preset_a = manager.installed_presets.get(a).ok_or("Preset A not found")?;
            let preset_b = manager.installed_presets.get(b).ok_or("Preset B not found")?;

            let mut differences = Vec::new();
            let files_a: HashMap<_, _> = preset_a.files.iter().map(|f| (&f.path, f)).collect();
            let files_b: HashMap<_, _> = preset_b.files.iter().map(|f| (&f.path, f)).collect();

            for (path, file_a) in &files_a {
                match files_b.get(path) {
                    Some(file_b) if file_a.content == file_b.content => {
                        differences.push(FileDifference {
                            path: path.to_string(), diff_type: DiffType::Identical,
                            details: String::new(),
                        });
                    },
                    Some(_) => {
                        differences.push(FileDifference {
                            path: path.to_string(), diff_type: DiffType::Different,
                            details: "Content differs".to_string(),
                        });
                    },
                    None => {
                        differences.push(FileDifference {
                            path: path.to_string(), diff_type: DiffType::OnlyInA,
                            details: String::new(),
                        });
                    },
                }
            }

            for path in files_b.keys() {
                if !files_a.contains_key(path) {
                    differences.push(FileDifference {
                        path: path.to_string(), diff_type: DiffType::OnlyInB,
                        details: String::new(),
                    });
                }
            }

            Ok(Self {
                preset_a: a.to_string(),
                preset_b: b.to_string(),
                differences,
            })
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEATHER INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod weather {
    use super::*;

    pub struct WeatherSystem {
        current_weather: WeatherModWeatherType,
        transition_progress: f32,
        target_weather: Option<WeatherModWeatherType>,
        weather_params: HashMap<WeatherModWeatherType, WeatherParams>,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
    pub enum WeatherModWeatherType {
        Clear, Cloudy, Overcast, Foggy, Rainy, Stormy, Snowy, Blizzard, Ash, Dust,
    }

    #[derive(Debug, Clone)]
    pub struct WeatherParams {
        pub ambient_intensity: f32,
        pub sun_intensity: f32,
        pub fog_density: f32,
        pub fog_color: (f32, f32, f32),
        pub sky_color: (f32, f32, f32),
        pub cloud_coverage: f32,
        pub precipitation_intensity: f32,
        pub wind_speed: f32,
        pub lightning_frequency: f32,
    }

    impl Default for WeatherParams {
        fn default() -> Self {
            Self {
                ambient_intensity: 1.0, sun_intensity: 1.0, fog_density: 0.0,
                fog_color: (0.5, 0.5, 0.5), sky_color: (0.5, 0.7, 1.0),
                cloud_coverage: 0.3, precipitation_intensity: 0.0,
                wind_speed: 0.0, lightning_frequency: 0.0,
            }
        }
    }

    impl WeatherSystem {
        pub fn new() -> Self {
            let mut params = HashMap::new();
            params.insert(WeatherModWeatherType::Clear, WeatherParams::default());
            params.insert(WeatherModWeatherType::Cloudy, WeatherParams {
                cloud_coverage: 0.6, sun_intensity: 0.8, ..Default::default()
            });
            params.insert(WeatherModWeatherType::Rainy, WeatherParams {
                cloud_coverage: 1.0, sun_intensity: 0.3, fog_density: 0.2,
                precipitation_intensity: 0.7, ..Default::default()
            });
            params.insert(WeatherModWeatherType::Stormy, WeatherParams {
                cloud_coverage: 1.0, sun_intensity: 0.1, fog_density: 0.3,
                precipitation_intensity: 1.0, lightning_frequency: 0.3, wind_speed: 0.8,
                ..Default::default()
            });
            params.insert(WeatherModWeatherType::Snowy, WeatherParams {
                cloud_coverage: 0.8, sun_intensity: 0.5, fog_density: 0.1,
                precipitation_intensity: 0.5, fog_color: (0.9, 0.9, 1.0),
                ..Default::default()
            });

            Self {
                current_weather: WeatherModWeatherType::Clear,
                transition_progress: 0.0,
                target_weather: None,
                weather_params: params,
            }
        }

        pub fn set_weather(&mut self, weather: WeatherModWeatherType) {
            if weather != self.current_weather {
                self.target_weather = Some(weather);
                self.transition_progress = 0.0;
            }
        }

        pub fn update(&mut self, delta_time: f32) {
            if let Some(target) = self.target_weather {
                self.transition_progress += delta_time * 0.2;  // 5 second transition
                if self.transition_progress >= 1.0 {
                    self.current_weather = target;
                    self.target_weather = None;
                    self.transition_progress = 0.0;
                }
            }
        }

        pub fn get_current_params(&self) -> WeatherParams {
            let current = self.weather_params.get(&self.current_weather)
                .cloned().unwrap_or_default();

            if let Some(target) = self.target_weather {
                let target_params = self.weather_params.get(&target)
                    .cloned().unwrap_or_default();
                self.lerp_params(&current, &target_params, self.transition_progress)
            } else {
                current
            }
        }

        fn lerp_params(&self, a: &WeatherParams, b: &WeatherParams, t: f32) -> WeatherParams {
            WeatherParams {
                ambient_intensity: a.ambient_intensity * (1.0 - t) + b.ambient_intensity * t,
                sun_intensity: a.sun_intensity * (1.0 - t) + b.sun_intensity * t,
                fog_density: a.fog_density * (1.0 - t) + b.fog_density * t,
                fog_color: (
                    a.fog_color.0 * (1.0 - t) + b.fog_color.0 * t,
                    a.fog_color.1 * (1.0 - t) + b.fog_color.1 * t,
                    a.fog_color.2 * (1.0 - t) + b.fog_color.2 * t,
                ),
                sky_color: (
                    a.sky_color.0 * (1.0 - t) + b.sky_color.0 * t,
                    a.sky_color.1 * (1.0 - t) + b.sky_color.1 * t,
                    a.sky_color.2 * (1.0 - t) + b.sky_color.2 * t,
                ),
                cloud_coverage: a.cloud_coverage * (1.0 - t) + b.cloud_coverage * t,
                precipitation_intensity: a.precipitation_intensity * (1.0 - t) + b.precipitation_intensity * t,
                wind_speed: a.wind_speed * (1.0 - t) + b.wind_speed * t,
                lightning_frequency: a.lightning_frequency * (1.0 - t) + b.lightning_frequency * t,
            }
        }

        pub fn get_enb_params(&self) -> HashMap<String, f32> {
            let params = self.get_current_params();
            let mut enb = HashMap::new();
            enb.insert("fAmbientMultiplier".to_string(), params.ambient_intensity);
            enb.insert("fDirectLightMultiplier".to_string(), params.sun_intensity);
            enb.insert("fFogDensity".to_string(), params.fog_density);
            enb.insert("fCloudCoverage".to_string(), params.cloud_coverage);
            enb
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTERIOR/EXTERIOR DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod location {
    use super::*;

    pub struct LocationSystem {
        is_interior: bool,
        current_cell: Option<CellInfo>,
        transition_blend: f32,
        interior_params: LocationParams,
        exterior_params: LocationParams,
    }

    pub struct CellInfo {
        pub name: String,
        pub form_id: u32,
        pub is_interior: bool,
        pub lighting_template: Option<String>,
        pub ambient_color: (u8, u8, u8),
        pub directional_color: (u8, u8, u8),
        pub fog_near: f32,
        pub fog_far: f32,
    }

    #[derive(Clone)]
    pub struct LocationParams {
        pub ambient_mult: f32,
        pub direct_mult: f32,
        pub ao_intensity: f32,
        pub bloom_intensity: f32,
        pub adaptation_min: f32,
        pub adaptation_max: f32,
        pub tonemap_curve: f32,
    }

    impl Default for LocationParams {
        fn default() -> Self {
            Self {
                ambient_mult: 1.0, direct_mult: 1.0, ao_intensity: 1.0,
                bloom_intensity: 1.0, adaptation_min: 0.1, adaptation_max: 2.0,
                tonemap_curve: 1.0,
            }
        }
    }

    impl LocationSystem {
        pub fn new() -> Self {
            Self {
                is_interior: false,
                current_cell: None,
                transition_blend: 0.0,
                interior_params: LocationParams {
                    ambient_mult: 0.8, ao_intensity: 1.5, adaptation_min: 0.05,
                    adaptation_max: 1.0, ..Default::default()
                },
                exterior_params: LocationParams::default(),
            }
        }

        pub fn update_cell(&mut self, cell: CellInfo) {
            let was_interior = self.is_interior;
            self.is_interior = cell.is_interior;
            self.current_cell = Some(cell);

            if was_interior != self.is_interior {
                self.transition_blend = 0.0;
            }
        }

        pub fn update(&mut self, delta_time: f32) {
            if self.transition_blend < 1.0 {
                self.transition_blend = (self.transition_blend + delta_time * 0.5).min(1.0);
            }
        }

        pub fn get_params(&self) -> LocationParams {
            if self.transition_blend >= 1.0 {
                if self.is_interior { self.interior_params.clone() }
                else { self.exterior_params.clone() }
            } else {
                let (from, to) = if self.is_interior {
                    (&self.exterior_params, &self.interior_params)
                } else {
                    (&self.interior_params, &self.exterior_params)
                };
                self.lerp_params(from, to, self.transition_blend)
            }
        }

        fn lerp_params(&self, a: &LocationParams, b: &LocationParams, t: f32) -> LocationParams {
            LocationParams {
                ambient_mult: a.ambient_mult * (1.0 - t) + b.ambient_mult * t,
                direct_mult: a.direct_mult * (1.0 - t) + b.direct_mult * t,
                ao_intensity: a.ao_intensity * (1.0 - t) + b.ao_intensity * t,
                bloom_intensity: a.bloom_intensity * (1.0 - t) + b.bloom_intensity * t,
                adaptation_min: a.adaptation_min * (1.0 - t) + b.adaptation_min * t,
                adaptation_max: a.adaptation_max * (1.0 - t) + b.adaptation_max * t,
                tonemap_curve: a.tonemap_curve * (1.0 - t) + b.tonemap_curve * t,
            }
        }

        pub fn is_interior(&self) -> bool { self.is_interior }
        pub fn transition_complete(&self) -> bool { self.transition_blend >= 1.0 }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLOR PALETTE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub mod palette {
    use super::*;

    pub struct PaletteSystem {
        palettes: HashMap<String, ColorPalette>,
        active_palette: Option<String>,
        time_of_day_palettes: HashMap<TimeOfDay, String>,
    }

    #[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
    pub enum TimeOfDay { Dawn, Morning, Noon, Afternoon, Dusk, Night, Midnight }

    pub struct ColorPalette {
        pub name: String,
        pub shadows: (f32, f32, f32),
        pub midtones: (f32, f32, f32),
        pub highlights: (f32, f32, f32),
        pub contrast: f32,
        pub saturation: f32,
        pub temperature: f32,  // -1 = cool, +1 = warm
        pub tint: f32,         // -1 = green, +1 = magenta
    }

    impl Default for ColorPalette {
        fn default() -> Self {
            Self {
                name: "Default".to_string(),
                shadows: (0.0, 0.0, 0.0),
                midtones: (0.0, 0.0, 0.0),
                highlights: (0.0, 0.0, 0.0),
                contrast: 1.0,
                saturation: 1.0,
                temperature: 0.0,
                tint: 0.0,
            }
        }
    }

    impl PaletteSystem {
        pub fn new() -> Self {
            let mut palettes = HashMap::new();
            palettes.insert("neutral".to_string(), ColorPalette::default());
            palettes.insert("warm".to_string(), ColorPalette {
                name: "Warm".to_string(),
                temperature: 0.3, saturation: 1.1,
                shadows: (0.02, 0.0, -0.02),
                highlights: (0.05, 0.02, -0.03),
                ..Default::default()
            });
            palettes.insert("cool".to_string(), ColorPalette {
                name: "Cool".to_string(),
                temperature: -0.2, saturation: 0.95,
                shadows: (-0.02, 0.0, 0.03),
                highlights: (-0.02, 0.0, 0.05),
                ..Default::default()
            });
            palettes.insert("cinematic".to_string(), ColorPalette {
                name: "Cinematic".to_string(),
                contrast: 1.15, saturation: 0.9,
                shadows: (0.0, -0.02, 0.03),
                highlights: (0.03, 0.01, -0.02),
                ..Default::default()
            });

            Self {
                palettes,
                active_palette: Some("neutral".to_string()),
                time_of_day_palettes: HashMap::new(),
            }
        }

        pub fn add_palette(&mut self, id: &str, palette: ColorPalette) {
            self.palettes.insert(id.to_string(), palette);
        }

        pub fn set_active(&mut self, id: &str) -> bool {
            if self.palettes.contains_key(id) {
                self.active_palette = Some(id.to_string());
                true
            } else { false }
        }

        pub fn assign_time_of_day(&mut self, tod: TimeOfDay, palette_id: &str) {
            if self.palettes.contains_key(palette_id) {
                self.time_of_day_palettes.insert(tod, palette_id.to_string());
            }
        }

        pub fn get_palette_for_time(&self, tod: TimeOfDay) -> &ColorPalette {
            self.time_of_day_palettes.get(&tod)
                .and_then(|id| self.palettes.get(id))
                .or_else(|| self.active_palette.as_ref().and_then(|id| self.palettes.get(id)))
                .unwrap_or_else(|| self.palettes.get("neutral").unwrap())
        }

        pub fn blend_palettes(&self, a: &ColorPalette, b: &ColorPalette, t: f32) -> ColorPalette {
            ColorPalette {
                name: format!("Blend({:.0}%)", t * 100.0),
                shadows: (
                    a.shadows.0 * (1.0 - t) + b.shadows.0 * t,
                    a.shadows.1 * (1.0 - t) + b.shadows.1 * t,
                    a.shadows.2 * (1.0 - t) + b.shadows.2 * t,
                ),
                midtones: (
                    a.midtones.0 * (1.0 - t) + b.midtones.0 * t,
                    a.midtones.1 * (1.0 - t) + b.midtones.1 * t,
                    a.midtones.2 * (1.0 - t) + b.midtones.2 * t,
                ),
                highlights: (
                    a.highlights.0 * (1.0 - t) + b.highlights.0 * t,
                    a.highlights.1 * (1.0 - t) + b.highlights.1 * t,
                    a.highlights.2 * (1.0 - t) + b.highlights.2 * t,
                ),
                contrast: a.contrast * (1.0 - t) + b.contrast * t,
                saturation: a.saturation * (1.0 - t) + b.saturation * t,
                temperature: a.temperature * (1.0 - t) + b.temperature * t,
                tint: a.tint * (1.0 - t) + b.tint * t,
            }
        }

        pub fn apply_to_color(&self, palette: &ColorPalette, r: f32, g: f32, b: f32) -> (f32, f32, f32) {
            let luma = r * 0.299 + g * 0.587 + b * 0.114;

            // Apply lift/gamma/gain
            let shadow_weight = 1.0 - luma;
            let highlight_weight = luma;

            let mut out_r = r + palette.shadows.0 * shadow_weight + palette.highlights.0 * highlight_weight;
            let mut out_g = g + palette.shadows.1 * shadow_weight + palette.highlights.1 * highlight_weight;
            let mut out_b = b + palette.shadows.2 * shadow_weight + palette.highlights.2 * highlight_weight;

            // Apply contrast
            out_r = (out_r - 0.5) * palette.contrast + 0.5;
            out_g = (out_g - 0.5) * palette.contrast + 0.5;
            out_b = (out_b - 0.5) * palette.contrast + 0.5;

            // Apply saturation
            let new_luma = out_r * 0.299 + out_g * 0.587 + out_b * 0.114;
            out_r = new_luma + (out_r - new_luma) * palette.saturation;
            out_g = new_luma + (out_g - new_luma) * palette.saturation;
            out_b = new_luma + (out_b - new_luma) * palette.saturation;

            // Apply temperature/tint
            out_r += palette.temperature * 0.1;
            out_b -= palette.temperature * 0.1;
            out_g += palette.tint * 0.05;

            (out_r.max(0.0).min(1.0), out_g.max(0.0).min(1.0), out_b.max(0.0).min(1.0))
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SHADER REPLACEMENT
// ═══════════════════════════════════════════════════════════════════════════════

pub mod shader_swap {
    use super::*;

    pub struct ShaderSwapSystem {
        replacements: HashMap<String, ShaderReplacement>,
        active_swaps: HashSet<String>,
        shader_cache: HashMap<String, Vec<u8>>,
    }

    pub struct ShaderReplacement {
        pub original_name: String,
        pub replacement_code: String,
        pub compile_target: ShaderModel,
        pub entry_point: String,
        pub defines: HashMap<String, String>,
    }

    pub enum ShaderModel { SM30, SM40, SM41, SM50, SM51 }

    impl ShaderSwapSystem {
        pub fn new() -> Self {
            Self {
                replacements: HashMap::new(),
                active_swaps: HashSet::new(),
                shader_cache: HashMap::new(),
            }
        }

        pub fn register_replacement(&mut self, id: &str, replacement: ShaderReplacement) {
            self.replacements.insert(id.to_string(), replacement);
        }

        pub fn activate_swap(&mut self, id: &str) -> bool {
            if self.replacements.contains_key(id) {
                self.active_swaps.insert(id.to_string());
                true
            } else { false }
        }

        pub fn deactivate_swap(&mut self, id: &str) {
            self.active_swaps.remove(id);
        }

        pub fn get_replacement(&self, original_name: &str) -> Option<&ShaderReplacement> {
            for id in &self.active_swaps {
                if let Some(replacement) = self.replacements.get(id) {
                    if replacement.original_name == original_name {
                        return Some(replacement);
                    }
                }
            }
            None
        }

        pub fn compile_shader(&mut self, id: &str) -> Result<Vec<u8>, String> {
            let replacement = self.replacements.get(id).ok_or("Replacement not found")?;
            // Compile HLSL to bytecode
            let bytecode = vec![0u8; 100];  // Placeholder
            self.shader_cache.insert(id.to_string(), bytecode.clone());
            Ok(bytecode)
        }

        pub fn get_cached(&self, id: &str) -> Option<&[u8]> {
            self.shader_cache.get(id).map(|v| v.as_slice())
        }

        pub fn clear_cache(&mut self) {
            self.shader_cache.clear();
        }
    }

    /// Common shader snippets for ENB effects
    pub struct ShaderLibrary {
        snippets: HashMap<String, String>,
    }

    impl ShaderLibrary {
        pub fn new() -> Self {
            let mut snippets = HashMap::new();
            snippets.insert("tonemap_aces".to_string(), r#"
float3 ACESFilm(float3 x) {
    float a = 2.51f; float b = 0.03f;
    float c = 2.43f; float d = 0.59f; float e = 0.14f;
    return saturate((x*(a*x+b))/(x*(c*x+d)+e));
}
"#.to_string());

            snippets.insert("linear_to_srgb".to_string(), r#"
float3 LinearToSRGB(float3 color) {
    return pow(max(color, 0.0), 1.0/2.2);
}
"#.to_string());

            snippets.insert("srgb_to_linear".to_string(), r#"
float3 SRGBToLinear(float3 color) {
    return pow(max(color, 0.0), 2.2);
}
"#.to_string());

            snippets.insert("luminance".to_string(), r#"
float GetLuminance(float3 color) {
    return dot(color, float3(0.299, 0.587, 0.114));
}
"#.to_string());

            Self { snippets }
        }

        pub fn get_snippet(&self, name: &str) -> Option<&str> {
            self.snippets.get(name).map(|s| s.as_str())
        }

        pub fn add_snippet(&mut self, name: &str, code: &str) {
            self.snippets.insert(name.to_string(), code.to_string());
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TIME OF DAY SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub mod time_of_day {
    use super::*;

    pub struct TimeOfDaySystem {
        current_hour: f32,  // 0.0 - 24.0
        day_length_scale: f32,
        sun_position: (f32, f32),  // (azimuth, elevation)
        tod_settings: HashMap<u32, TODSettings>,
    }

    pub struct TODSettings {
        pub hour: u32,
        pub sun_color: (f32, f32, f32),
        pub ambient_color: (f32, f32, f32),
        pub sky_top_color: (f32, f32, f32),
        pub sky_horizon_color: (f32, f32, f32),
        pub fog_color: (f32, f32, f32),
        pub sun_intensity: f32,
        pub ambient_intensity: f32,
    }

    impl TimeOfDaySystem {
        pub fn new() -> Self {
            let mut tod_settings = HashMap::new();
            // Dawn (5-7)
            tod_settings.insert(6, TODSettings {
                hour: 6,
                sun_color: (1.0, 0.6, 0.3),
                ambient_color: (0.4, 0.4, 0.6),
                sky_top_color: (0.2, 0.3, 0.5),
                sky_horizon_color: (1.0, 0.6, 0.4),
                fog_color: (0.8, 0.6, 0.5),
                sun_intensity: 0.5,
                ambient_intensity: 0.4,
            });
            // Noon (11-13)
            tod_settings.insert(12, TODSettings {
                hour: 12,
                sun_color: (1.0, 0.98, 0.95),
                ambient_color: (0.6, 0.7, 0.9),
                sky_top_color: (0.2, 0.4, 0.8),
                sky_horizon_color: (0.5, 0.7, 1.0),
                fog_color: (0.7, 0.8, 0.9),
                sun_intensity: 1.0,
                ambient_intensity: 0.8,
            });
            // Dusk (17-19)
            tod_settings.insert(18, TODSettings {
                hour: 18,
                sun_color: (1.0, 0.5, 0.2),
                ambient_color: (0.5, 0.4, 0.5),
                sky_top_color: (0.3, 0.2, 0.4),
                sky_horizon_color: (1.0, 0.4, 0.2),
                fog_color: (0.7, 0.5, 0.4),
                sun_intensity: 0.4,
                ambient_intensity: 0.3,
            });
            // Night (22-4)
            tod_settings.insert(0, TODSettings {
                hour: 0,
                sun_color: (0.2, 0.2, 0.4),
                ambient_color: (0.1, 0.1, 0.2),
                sky_top_color: (0.02, 0.02, 0.05),
                sky_horizon_color: (0.05, 0.05, 0.1),
                fog_color: (0.1, 0.1, 0.15),
                sun_intensity: 0.1,
                ambient_intensity: 0.15,
            });

            Self {
                current_hour: 12.0,
                day_length_scale: 1.0,
                sun_position: (0.0, 45.0),
                tod_settings,
            }
        }

        pub fn set_time(&mut self, hour: f32) {
            self.current_hour = hour.rem_euclid(24.0);
            self.update_sun_position();
        }

        pub fn advance_time(&mut self, delta_hours: f32) {
            self.current_hour = (self.current_hour + delta_hours * self.day_length_scale).rem_euclid(24.0);
            self.update_sun_position();
        }

        fn update_sun_position(&mut self) {
            let angle = (self.current_hour - 6.0) / 12.0 * std::f32::consts::PI;
            self.sun_position.0 = 180.0;  // South
            self.sun_position.1 = (angle.sin() * 90.0).max(-18.0);  // -18 is astronomical twilight
        }

        pub fn get_interpolated_settings(&self) -> TODSettings {
            let hours: Vec<u32> = self.tod_settings.keys().cloned().collect();
            let hour = self.current_hour as u32;

            let mut prev_hour = 0u32;
            let mut next_hour = 24u32;
            for &h in &hours {
                if h <= hour && h >= prev_hour { prev_hour = h; }
                if h > hour && h < next_hour { next_hour = h; }
            }
            if next_hour == 24 { next_hour = *hours.iter().min().unwrap_or(&0); }

            let prev = self.tod_settings.get(&prev_hour).cloned().unwrap_or_default();
            let next = self.tod_settings.get(&(next_hour % 24)).cloned().unwrap_or_default();

            let range = if next_hour > prev_hour { next_hour - prev_hour } else { 24 - prev_hour + next_hour };
            let progress = if self.current_hour as u32 >= prev_hour {
                (self.current_hour - prev_hour as f32) / range as f32
            } else {
                (self.current_hour + 24.0 - prev_hour as f32) / range as f32
            };

            self.lerp_settings(&prev, &next, progress.min(1.0))
        }

        fn lerp_settings(&self, a: &TODSettings, b: &TODSettings, t: f32) -> TODSettings {
            TODSettings {
                hour: a.hour,
                sun_color: self.lerp3(a.sun_color, b.sun_color, t),
                ambient_color: self.lerp3(a.ambient_color, b.ambient_color, t),
                sky_top_color: self.lerp3(a.sky_top_color, b.sky_top_color, t),
                sky_horizon_color: self.lerp3(a.sky_horizon_color, b.sky_horizon_color, t),
                fog_color: self.lerp3(a.fog_color, b.fog_color, t),
                sun_intensity: a.sun_intensity * (1.0 - t) + b.sun_intensity * t,
                ambient_intensity: a.ambient_intensity * (1.0 - t) + b.ambient_intensity * t,
            }
        }

        fn lerp3(&self, a: (f32, f32, f32), b: (f32, f32, f32), t: f32) -> (f32, f32, f32) {
            (a.0 * (1.0 - t) + b.0 * t, a.1 * (1.0 - t) + b.1 * t, a.2 * (1.0 - t) + b.2 * t)
        }

        pub fn sun_position(&self) -> (f32, f32) { self.sun_position }
        pub fn is_night(&self) -> bool { self.current_hour < 6.0 || self.current_hour > 20.0 }
    }

    impl Default for TODSettings {
        fn default() -> Self {
            Self {
                hour: 12, sun_color: (1.0, 1.0, 1.0), ambient_color: (0.5, 0.5, 0.5),
                sky_top_color: (0.3, 0.5, 0.8), sky_horizon_color: (0.6, 0.7, 0.9),
                fog_color: (0.5, 0.5, 0.5), sun_intensity: 1.0, ambient_intensity: 0.5,
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ATMOSPHERE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

pub struct AtmosphereParams {
    pub rayleigh_coeff: Vec3,
    pub mie_coeff: f32,
    pub mie_g: f32,
    pub sun_angular_radius: f32,
    pub atmosphere_height: f32,
    pub planet_radius: f32,
    pub ozone_density: f32,
    pub multiple_scattering: bool,
}

impl AtmosphereParams {
    pub fn earth() -> Self {
        Self {
            rayleigh_coeff: Vec3::new(5.8e-6, 13.5e-6, 33.1e-6),
            mie_coeff: 21e-6, mie_g: 0.76, sun_angular_radius: 0.00935,
            atmosphere_height: 100000.0, planet_radius: 6371000.0,
            ozone_density: 0.001, multiple_scattering: true,
        }
    }

    pub fn mars() -> Self {
        Self {
            rayleigh_coeff: Vec3::new(19.9e-6, 13.6e-6, 5.7e-6),
            mie_coeff: 4e-6, mie_g: 0.65, sun_angular_radius: 0.00615,
            atmosphere_height: 11000.0, planet_radius: 3389500.0,
            ozone_density: 0.0, multiple_scattering: false,
        }
    }
}

pub struct AtmosphericScattering {
    pub params: AtmosphereParams,
    pub lut_size: (u32, u32, u32),
    pub transmittance_lut: Vec<f32>,
    pub scattering_lut: Vec<f32>,
}

impl AtmosphericScattering {
    pub fn new(params: AtmosphereParams) -> Self {
        Self { params, lut_size: (256, 64, 32), transmittance_lut: Vec::new(), scattering_lut: Vec::new() }
    }

    pub fn compute_transmittance(&self, start: Vec3, dir: Vec3, dist: f32) -> Vec3 {
        let samples = 32;
        let step = dist / samples as f32;
        let mut optical_depth = Vec3::splat(0.0);
        for i in 0..samples {
            let pos = start + dir * (i as f32 + 0.5) * step;
            let height = pos.length() - self.params.planet_radius;
            let density_r = (-height / 8500.0).exp();
            let density_m = (-height / 1200.0).exp();
            optical_depth = optical_depth + Vec3::new(
                self.params.rayleigh_coeff.x * density_r,
                self.params.rayleigh_coeff.y * density_r,
                self.params.rayleigh_coeff.z * density_r,
            ) * step + Vec3::splat(self.params.mie_coeff * density_m * step);
        }
        Vec3::new((-optical_depth.x).exp(), (-optical_depth.y).exp(), (-optical_depth.z).exp())
    }

    pub fn rayleigh_phase(cos_theta: f32) -> f32 { 3.0 / (16.0 * std::f32::consts::PI) * (1.0 + cos_theta * cos_theta) }

    pub fn mie_phase(&self, cos_theta: f32) -> f32 {
        let g = self.params.mie_g; let g2 = g * g;
        3.0 / (8.0 * std::f32::consts::PI) * ((1.0 - g2) * (1.0 + cos_theta * cos_theta)) / ((2.0 + g2) * (1.0 + g2 - 2.0 * g * cos_theta).powf(1.5))
    }

    pub fn sky_color(&self, view_dir: Vec3, sun_dir: Vec3) -> Vec3 {
        let cos_theta = view_dir.dot(sun_dir);
        let rayleigh = Self::rayleigh_phase(cos_theta);
        let mie = self.mie_phase(cos_theta);
        let base = Vec3::new(0.3, 0.5, 0.9);
        base * rayleigh + Vec3::splat(mie * 0.1)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VOLUMETRIC CLOUDS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct CloudLayer { pub altitude: f32, pub thickness: f32, pub coverage: f32, pub density: f32, pub detail_scale: f32 }

pub struct VolumetricClouds {
    pub layers: Vec<CloudLayer>,
    pub wind_direction: Vec2,
    pub wind_speed: f32,
    pub time: f32,
    pub light_absorption: f32,
    pub ambient_light: f32,
    pub silver_lining: f32,
    pub powder_effect: f32,
}

impl VolumetricClouds {
    pub fn new() -> Self {
        Self {
            layers: vec![CloudLayer { altitude: 2000.0, thickness: 1000.0, coverage: 0.5, density: 0.1, detail_scale: 0.3 }],
            wind_direction: Vec2::new(1.0, 0.0), wind_speed: 10.0, time: 0.0,
            light_absorption: 0.9, ambient_light: 0.3, silver_lining: 0.5, powder_effect: 0.5,
        }
    }

    pub fn sample_density(&self, pos: Vec3, layer: &CloudLayer) -> f32 {
        let height_fraction = (pos.y - layer.altitude) / layer.thickness;
        if height_fraction < 0.0 || height_fraction > 1.0 { return 0.0; }
        let height_falloff = 1.0 - (height_fraction * 2.0 - 1.0).abs();
        let wind_offset = Vec2::new(pos.x, pos.z) + self.wind_direction * self.wind_speed * self.time;
        let base_noise = self.fbm3d(pos.x * 0.001 + wind_offset.x * 0.001, pos.y * 0.002, pos.z * 0.001 + wind_offset.y * 0.001);
        let detail_noise = self.fbm3d(pos.x * 0.01, pos.y * 0.02, pos.z * 0.01) * layer.detail_scale;
        let coverage_falloff = (layer.coverage - 0.5).max(0.0) * 2.0;
        ((base_noise + coverage_falloff - detail_noise) * height_falloff * layer.density).max(0.0)
    }

    fn fbm3d(&self, x: f32, y: f32, z: f32) -> f32 {
        let mut val = 0.0; let mut amp = 0.5; let mut freq = 1.0;
        for _ in 0..4 { val += self.noise3d(x * freq, y * freq, z * freq) * amp; amp *= 0.5; freq *= 2.0; }
        val
    }

    fn noise3d(&self, x: f32, y: f32, z: f32) -> f32 {
        let xi = x.floor() as i32; let yi = y.floor() as i32; let zi = z.floor() as i32;
        let xf = x - xi as f32; let yf = y - yi as f32; let zf = z - zi as f32;
        let u = xf * xf * (3.0 - 2.0 * xf); let v = yf * yf * (3.0 - 2.0 * yf); let w = zf * zf * (3.0 - 2.0 * zf);
        let hash = |a: i32, b: i32, c: i32| { let n = (a * 73856093) ^ (b * 19349663) ^ (c * 83492791); ((n & 0x7fffffff) as f32) / 0x7fffffff as f32 };
        let c000 = hash(xi, yi, zi); let c100 = hash(xi+1, yi, zi); let c010 = hash(xi, yi+1, zi); let c110 = hash(xi+1, yi+1, zi);
        let c001 = hash(xi, yi, zi+1); let c101 = hash(xi+1, yi, zi+1); let c011 = hash(xi, yi+1, zi+1); let c111 = hash(xi+1, yi+1, zi+1);
        let x00 = c000 * (1.0-u) + c100 * u; let x10 = c010 * (1.0-u) + c110 * u;
        let x01 = c001 * (1.0-u) + c101 * u; let x11 = c011 * (1.0-u) + c111 * u;
        let y0 = x00 * (1.0-v) + x10 * v; let y1 = x01 * (1.0-v) + x11 * v;
        y0 * (1.0-w) + y1 * w
    }

    pub fn raymarch(&self, origin: Vec3, dir: Vec3, sun_dir: Vec3, max_dist: f32) -> (Vec3, f32) {
        let steps = 64; let step_size = max_dist / steps as f32;
        let mut transmittance = 1.0; let mut light = Vec3::splat(0.0);
        for i in 0..steps {
            let pos = origin + dir * (i as f32 + 0.5) * step_size;
            for layer in &self.layers {
                let density = self.sample_density(pos, layer);
                if density > 0.001 {
                    let light_samples = 6; let mut light_trans = 1.0;
                    for j in 0..light_samples { let light_pos = pos + sun_dir * (j as f32 + 0.5) * 100.0; light_trans *= (-self.sample_density(light_pos, layer) * self.light_absorption).exp(); }
                    let powder = 1.0 - (-density * 2.0).exp();
                    let scatter = light_trans * (1.0 - (-density).exp()) * (self.ambient_light + (1.0 - self.ambient_light) * light_trans);
                    light = light + Vec3::splat(scatter * (1.0 + powder * self.powder_effect)) * transmittance;
                    transmittance *= (-density * step_size * 0.01).exp();
                    if transmittance < 0.01 { break; }
                }
            }
        }
        (light, transmittance)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WATER RENDERING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct WaterParams {
    pub wave_scale: f32,
    pub wave_speed: f32,
    pub wave_choppiness: f32,
    pub foam_threshold: f32,
    pub foam_intensity: f32,
    pub caustics_scale: f32,
    pub caustics_speed: f32,
    pub absorption_color: Vec3,
    pub scattering_color: Vec3,
    pub max_visibility: f32,
    pub fresnel_power: f32,
    pub reflection_intensity: f32,
    pub refraction_intensity: f32,
}

impl WaterParams {
    pub fn ocean() -> Self {
        Self { wave_scale: 1.0, wave_speed: 1.0, wave_choppiness: 1.5, foam_threshold: 0.8, foam_intensity: 1.0,
               caustics_scale: 0.5, caustics_speed: 0.3, absorption_color: Vec3::new(0.45, 0.1, 0.02),
               scattering_color: Vec3::new(0.02, 0.12, 0.15), max_visibility: 50.0, fresnel_power: 5.0,
               reflection_intensity: 1.0, refraction_intensity: 1.0 }
    }

    pub fn lake() -> Self {
        Self { wave_scale: 0.3, wave_speed: 0.5, wave_choppiness: 0.5, foam_threshold: 0.9, foam_intensity: 0.3,
               caustics_scale: 1.0, caustics_speed: 0.2, absorption_color: Vec3::new(0.25, 0.08, 0.01),
               scattering_color: Vec3::new(0.01, 0.08, 0.1), max_visibility: 20.0, fresnel_power: 4.0,
               reflection_intensity: 0.9, refraction_intensity: 1.0 }
    }
}

pub struct GerstnerWave { pub direction: Vec2, pub steepness: f32, pub wavelength: f32, pub speed: f32 }

pub struct RenderWaterSystem {
    pub params: WaterParams,
    pub waves: Vec<GerstnerWave>,
    pub time: f32,
}

impl RenderWaterSystem {
    pub fn new(params: WaterParams) -> Self {
        let waves = vec![
            GerstnerWave { direction: Vec2::new(1.0, 0.0).normalize(), steepness: 0.5, wavelength: 60.0, speed: 1.0 },
            GerstnerWave { direction: Vec2::new(1.0, 0.6).normalize(), steepness: 0.25, wavelength: 31.0, speed: 1.3 },
            GerstnerWave { direction: Vec2::new(1.0, 1.3).normalize(), steepness: 0.15, wavelength: 18.0, speed: 0.8 },
            GerstnerWave { direction: Vec2::new(-0.5, 1.0).normalize(), steepness: 0.1, wavelength: 8.0, speed: 1.1 },
        ];
        Self { params, waves, time: 0.0 }
    }

    pub fn gerstner_wave(&self, pos: Vec2, wave: &GerstnerWave) -> (Vec3, Vec3) {
        let k = 2.0 * std::f32::consts::PI / wave.wavelength;
        let c = (9.81 / k).sqrt() * wave.speed * self.params.wave_speed;
        let d = wave.direction;
        let f = k * (d.dot(pos) - c * self.time);
        let a = wave.steepness / k * self.params.wave_scale;
        let disp = Vec3::new(d.x * a * f.cos(), a * f.sin(), d.y * a * f.cos());
        let tangent_x = Vec3::new(1.0 - d.x * d.x * wave.steepness * f.sin(), d.x * wave.steepness * f.cos(), -d.x * d.y * wave.steepness * f.sin());
        let tangent_z = Vec3::new(-d.x * d.y * wave.steepness * f.sin(), d.y * wave.steepness * f.cos(), 1.0 - d.y * d.y * wave.steepness * f.sin());
        let normal = tangent_z.cross(tangent_x).normalize();
        (disp, normal)
    }

    pub fn sample(&self, pos: Vec2) -> (Vec3, Vec3) {
        let mut total_disp = Vec3::splat(0.0); let mut total_normal = Vec3::new(0.0, 1.0, 0.0);
        for wave in &self.waves { let (d, n) = self.gerstner_wave(pos, wave); total_disp = total_disp + d; total_normal = total_normal + n; }
        (total_disp, total_normal.normalize())
    }

    pub fn fresnel(&self, view_dir: Vec3, normal: Vec3) -> f32 {
        let n_dot_v = view_dir.dot(normal).max(0.0);
        0.02 + 0.98 * (1.0 - n_dot_v).powf(self.params.fresnel_power)
    }

    pub fn underwater_fog(&self, dist: f32, base_color: Vec3) -> Vec3 {
        let extinction = Vec3::new((-dist * self.params.absorption_color.x).exp(), (-dist * self.params.absorption_color.y).exp(), (-dist * self.params.absorption_color.z).exp());
        let inscatter = self.params.scattering_color * (1.0 - (-dist * 0.1).exp());
        base_color * extinction + inscatter
    }

    pub fn update(&mut self, dt: f32) { self.time += dt; }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LENS EFFECTS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct LensFlareGhost { pub offset: f32, pub scale: f32, pub color: Vec3, pub opacity: f32 }

pub struct LensFlareSystem {
    pub ghosts: Vec<LensFlareGhost>,
    pub halo_radius: f32,
    pub halo_width: f32,
    pub halo_color: Vec3,
    pub starburst_rotation: f32,
    pub starburst_scale: f32,
    pub chromatic_aberration: f32,
    pub dirt_intensity: f32,
    pub threshold: f32,
}

impl LensFlareSystem {
    pub fn cinematic() -> Self {
        Self {
            ghosts: vec![
                LensFlareGhost { offset: -0.5, scale: 0.3, color: Vec3::new(1.0, 0.8, 0.5), opacity: 0.2 },
                LensFlareGhost { offset: 0.3, scale: 0.5, color: Vec3::new(0.5, 0.8, 1.0), opacity: 0.15 },
                LensFlareGhost { offset: 0.7, scale: 0.2, color: Vec3::new(1.0, 1.0, 0.8), opacity: 0.1 },
                LensFlareGhost { offset: -0.8, scale: 0.6, color: Vec3::new(0.8, 0.5, 1.0), opacity: 0.08 },
            ],
            halo_radius: 0.5, halo_width: 0.1, halo_color: Vec3::new(1.0, 0.9, 0.7),
            starburst_rotation: 0.0, starburst_scale: 1.0, chromatic_aberration: 0.02, dirt_intensity: 0.3, threshold: 0.9,
        }
    }

    pub fn compute_ghost(&self, light_pos: Vec2, ghost: &LensFlareGhost) -> (Vec2, f32, Vec3) {
        let center = Vec2::new(0.5, 0.5);
        let delta = light_pos - center;
        let ghost_pos = center - delta * ghost.offset;
        let dist_from_center = delta.length();
        let fade = 1.0 - (dist_from_center * 2.0).min(1.0);
        (ghost_pos, ghost.scale * fade, ghost.color * ghost.opacity * fade)
    }

    pub fn compute_halo(&self, light_pos: Vec2, uv: Vec2) -> f32 {
        let center = Vec2::new(0.5, 0.5);
        let delta = light_pos - center;
        let halo_center = center - delta * 0.5;
        let dist = (uv - halo_center).length();
        let ring = 1.0 - ((dist - self.halo_radius).abs() / self.halo_width).min(1.0);
        ring * ring
    }

    pub fn starburst(&self, angle: f32) -> f32 {
        let rotated = angle + self.starburst_rotation;
        let streaks = 6.0;
        let burst = (rotated * streaks).cos().abs().powf(8.0);
        burst * self.starburst_scale
    }
}

pub struct AnamorphicFlare {
    pub streak_length: f32,
    pub streak_threshold: f32,
    pub streak_color: Vec3,
    pub vertical_squeeze: f32,
    pub blur_iterations: u32,
}

impl AnamorphicFlare {
    pub fn new() -> Self { Self { streak_length: 0.5, streak_threshold: 0.8, streak_color: Vec3::new(0.8, 0.9, 1.0), vertical_squeeze: 0.3, blur_iterations: 4 } }

    pub fn compute(&self, bright_pixels: &[(Vec2, f32)]) -> Vec<(Vec2, f32, f32)> {
        let mut streaks = Vec::new();
        for &(pos, brightness) in bright_pixels {
            if brightness > self.streak_threshold {
                let intensity = (brightness - self.streak_threshold) / (1.0 - self.streak_threshold);
                streaks.push((pos, self.streak_length * intensity, intensity));
            }
        }
        streaks
    }
}

