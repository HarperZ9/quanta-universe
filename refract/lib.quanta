/// ENB texture types
pub enum ENBTextureType {
    // Game textures (read-only)
    GameColor,
    GameDepth,
    GameNormal,
    GameAlbedo,
    GameMaterial,

    // ENB textures
    ENBColor,
    ENBOriginal,
    ENBPalette,
    ENBLensMask,
    ENBBloom,
    ENBAdaptation,

    // Effect textures
    SSAOTexture,
    SSRTexture,
    DOFTexture,
    MotionBlurTexture,

    // External textures
    LUT,
    Noise,
    BlueNoise,
    Custom(String),
}

/// Texture sampler wrapper
pub struct ENBTexture {
    texture: *mut ID3D11Texture2D,
    srv: *mut ID3D11ShaderResourceView,
    rtv: Option<*mut ID3D11RenderTargetView>,
    uav: Option<*mut ID3D11UnorderedAccessView>,

    width: u32,
    height: u32,
    format: DXGI_FORMAT,
    mip_levels: u32,

    texture_type: ENBTextureType,
}

impl ENBTexture {
    pub fn create(device: *mut ID3D11Device, width: u32, height: u32,
                  format: DXGI_FORMAT, flags: TextureFlags) -> Result<Self, ENBError> {
        shader {
            let desc = D3D11_TEXTURE2D_DESC {
                Width: width,
                Height: height,
                MipLevels: if flags.contains(TextureFlags::Mipmaps) { 0 } else { 1 },
                ArraySize: 1,
                Format: format,
                SampleDesc: DXGI_SAMPLE_DESC { Count: 1, Quality: 0 },
                Usage: D3D11_USAGE_DEFAULT,
                BindFlags: calculate_bind_flags(flags),
                CPUAccessFlags: 0,
                MiscFlags: if flags.contains(TextureFlags::Mipmaps) {
                    D3D11_RESOURCE_MISC_GENERATE_MIPS
                } else { 0 },
            };

            let mut texture: *mut ID3D11Texture2D = std::ptr::null_mut();
            let hr = (*device).CreateTexture2D(&desc, std::ptr::null(), &mut texture);

            if FAILED(hr) {
                return Err(ENBError::TextureCreationFailed);
            }

            // Create views...
            Ok(ENBTexture { ... })
        }
    }

    pub fn load(device: *mut ID3D11Device, path: &str) -> Result<Self, ENBError> {
        // Load texture from file
        shader {
            let extension = path.rsplit('.').next().unwrap_or("");

            match extension.to_lowercase().as_str() {
                "dds" => Self::load_dds(device, path),
                "png" => Self::load_png(device, path),
                "tga" => Self::load_tga(device, path),
                "hdr" => Self::load_hdr(device, path),
                "exr" => Self::load_exr(device, path),
                _ => Err(ENBError::UnsupportedFormat),
            }
        }
    }
}

pub flags TextureFlags {
    None        = 0,
    RenderTarget = 1,
    UAV         = 2,
    Mipmaps     = 4,
    Cubemap     = 8,
}

// ============================================================================
// ENB HELPER FUNCTIONS
// ============================================================================

/// Helper shader functions for ENB integration
pub mod enb_helpers {
    /// Full-screen triangle vertex shader
    @vertex_shader
    pub fn fullscreen_triangle_vs(vertex_id: u32) -> VertexOutput {
        var output: VertexOutput;

        // Generate full-screen triangle from vertex ID
        let uv = vec2<f32>(
            f32((vertex_id << 1) & 2),
            f32(vertex_id & 2)
        );

        output.position = vec4<f32>(uv * 2.0 - 1.0, 0.0, 1.0);
        output.position.y = -output.position.y;
        output.texcoord = uv;

        return output;
    }

    /// Linear to sRGB conversion
    @inline
    pub fn linear_to_srgb(color: Vec3) -> Vec3 {
        let cutoff = color < vec3<f32>(0.0031308);
        let higher = 1.055 * pow(color, vec3<f32>(1.0/2.4)) - 0.055;
        let lower = color * 12.92;
        return select(higher, lower, cutoff);
    }

    /// sRGB to linear conversion
    @inline
    pub fn srgb_to_linear(color: Vec3) -> Vec3 {
        let cutoff = color < vec3<f32>(0.04045);
        let higher = pow((color + 0.055) / 1.055, vec3<f32>(2.4));
        let lower = color / 12.92;
        return select(higher, lower, cutoff);
    }

    /// Get luminance (Rec. 709)
    @inline
    pub fn luminance(color: Vec3) -> f32 {
        return dot(color, vec3<f32>(0.2126, 0.7152, 0.0722));
    }

    /// Reconstruct world position from depth
    @inline
    pub fn reconstruct_position(uv: Vec2, depth: f32, inv_vp: Mat4) -> Vec3 {
        let ndc = vec4<f32>(uv * 2.0 - 1.0, depth, 1.0);
        let world = inv_vp * ndc;
        return world.xyz / world.w;
    }

    /// Reconstruct view-space position from depth
    @inline
    pub fn reconstruct_view_position(uv: Vec2, depth: f32, inv_proj: Mat4) -> Vec3 {
        let ndc = vec4<f32>(uv * 2.0 - 1.0, depth, 1.0);
        let view = inv_proj * ndc;
        return view.xyz / view.w;
    }

    /// Decode normal from GBuffer
    @inline
    pub fn decode_normal(encoded: Vec2) -> Vec3 {
        let n = encoded * 2.0 - 1.0;
        let z = sqrt(1.0 - saturate(dot(n, n)));
        return vec3<f32>(n.x, n.y, z);
    }

    /// Encode normal for GBuffer
    @inline
    pub fn encode_normal(normal: Vec3) -> Vec2 {
        return normal.xy * 0.5 + 0.5;
    }

    /// Linear depth from hardware depth
    @inline
    pub fn linearize_depth(depth: f32, near: f32, far: f32) -> f32 {
        return near * far / (far - depth * (far - near));
    }

    /// Hardware depth from linear depth
    @inline
    pub fn unlinearize_depth(linear: f32, near: f32, far: f32) -> f32 {
        return (far * (1.0 - near / linear)) / (far - near);
    }

    /// Get dithered offset for temporal effects
    @inline
    pub fn get_temporal_offset(pixel: Vec2, frame: u32) -> Vec2 {
        let halton = HALTON_SEQUENCE[frame % 16];
        return halton - 0.5;
    }
}

/// Halton sequence for temporal jitter (2,3 base)
const HALTON_SEQUENCE: [Vec2; 16] = [
    Vec2::new(0.5, 0.333333),
    Vec2::new(0.25, 0.666667),
    Vec2::new(0.75, 0.111111),
    Vec2::new(0.125, 0.444444),
    Vec2::new(0.625, 0.777778),
    Vec2::new(0.375, 0.222222),
    Vec2::new(0.875, 0.555556),
    Vec2::new(0.0625, 0.888889),
    Vec2::new(0.5625, 0.037037),
    Vec2::new(0.3125, 0.370370),
    Vec2::new(0.8125, 0.703704),
    Vec2::new(0.1875, 0.148148),
    Vec2::new(0.6875, 0.481481),
    Vec2::new(0.4375, 0.814815),
    Vec2::new(0.9375, 0.259259),
    Vec2::new(0.03125, 0.592593),
];

// ============================================================================
// ERROR HANDLING
// ============================================================================

/// ENB integration errors
pub enum ENBError {
    DeviceNotFound,
    ContextNotFound,
    SwapChainNotFound,

    VersionNotSupported(ENBVersion),
    GameNotSupported(TargetGame),
    FeatureNotSupported(String),

    ShaderCompilationFailed(String),
    TextureCreationFailed,
    BufferCreationFailed,

    PresetLoadFailed(String),
    PresetSaveFailed(String),
    PresetParseError(String),

    HookFailed(HookPoint),
    RenderFailed(RenderStage),

    IoError(std::io::Error),
    Other(String),
}

impl From<std::io::Error> for ENBError {
    fn from(err: std::io::Error) -> Self {
        ENBError::IoError(err)
    }
}

// ============================================================================
// EFFECT FRAMEWORK
// ============================================================================

/// Base effect structure for custom ENB effects
pub struct Effect {
    name: String,
    enabled: bool,
    priority: i32,
    render_stage: RenderStage,

    // Shader resources
    vertex_shader: Option<*mut ID3D11VertexShader>,
    pixel_shader: Option<*mut ID3D11PixelShader>,
    compute_shader: Option<*mut ID3D11ComputeShader>,

    // Parameters
    parameters: HashMap<String, ParameterValue>,
    constant_buffer: *mut ID3D11Buffer,

    // Textures
    input_textures: Vec<ENBTexture>,
    output_textures: Vec<ENBTexture>,

    // State
    blend_state: *mut ID3D11BlendState,
    depth_state: *mut ID3D11DepthStencilState,
    raster_state: *mut ID3D11RasterizerState,
}

impl Effect {
    pub fn new(name: &str) -> Self {
        Self {
            name: name.to_string(),
            enabled: true,
            priority: 0,
            render_stage: RenderStage::Final,
            vertex_shader: None,
            pixel_shader: None,
            compute_shader: None,
            parameters: HashMap::new(),
            constant_buffer: std::ptr::null_mut(),
            input_textures: Vec::new(),
            output_textures: Vec::new(),
            blend_state: std::ptr::null_mut(),
            depth_state: std::ptr::null_mut(),
            raster_state: std::ptr::null_mut(),
        }
    }

    pub fn load_shader(&mut self, device: *mut ID3D11Device, path: &str,
                       shader_type: ShaderType) -> Result<(), ENBError> {
        shader {
            let source = fs::read_to_string(path)?;
            let compiled = compile_shader(&source, shader_type)?;

            match shader_type {
                ShaderType::Vertex => {
                    let mut vs: *mut ID3D11VertexShader = std::ptr::null_mut();
                    (*device).CreateVertexShader(
                        compiled.as_ptr(),
                        compiled.len(),
                        std::ptr::null_mut(),
                        &mut vs
                    );
                    self.vertex_shader = Some(vs);
                },
                ShaderType::Pixel => {
                    let mut ps: *mut ID3D11PixelShader = std::ptr::null_mut();
                    (*device).CreatePixelShader(
                        compiled.as_ptr(),
                        compiled.len(),
                        std::ptr::null_mut(),
                        &mut ps
                    );
                    self.pixel_shader = Some(ps);
                },
                ShaderType::Compute => {
                    let mut cs: *mut ID3D11ComputeShader = std::ptr::null_mut();
                    (*device).CreateComputeShader(
                        compiled.as_ptr(),
                        compiled.len(),
                        std::ptr::null_mut(),
                        &mut cs
                    );
                    self.compute_shader = Some(cs);
                },
            }

            Ok(())
        }
    }

    pub fn apply(&self, ctx: &RenderContext) {
        shader {
            if !self.enabled {
                return;
            }

            // Set shaders
            if let Some(vs) = self.vertex_shader {
                (*ctx.context).VSSetShader(vs, std::ptr::null(), 0);
            }
            if let Some(ps) = self.pixel_shader {
                (*ctx.context).PSSetShader(ps, std::ptr::null(), 0);
            }

            // Set constant buffer
            (*ctx.context).PSSetConstantBuffers(1, 1, &self.constant_buffer);

            // Set input textures
            for (i, tex) in self.input_textures.iter().enumerate() {
                (*ctx.context).PSSetShaderResources(i as u32, 1, &tex.srv);
            }

            // Set render states
            (*ctx.context).OMSetBlendState(self.blend_state, &[1.0; 4], 0xffffffff);
            (*ctx.context).OMSetDepthStencilState(self.depth_state, 0);
            (*ctx.context).RSSetState(self.raster_state);

            // Draw
            ctx.draw_fullscreen();
        }
    }

    pub fn set_parameter(&mut self, name: &str, value: ParameterValue) {
        self.parameters.insert(name.to_string(), value);
    }
}

#[derive(Debug, Clone, Copy)]
pub enum ShaderType {
    Vertex,
    Pixel,
    Compute,
}

/// Effect chain for multi-pass effects
pub struct EffectChain {
    effects: Vec<Effect>,
    intermediate_targets: Vec<ENBTexture>,
    name: String,
}

impl EffectChain {
    pub fn new(name: &str) -> Self {
        Self {
            effects: Vec::new(),
            intermediate_targets: Vec::new(),
            name: name.to_string(),
        }
    }

    pub fn add_effect(&mut self, effect: Effect) {
        self.effects.push(effect);
        self.effects.sort_by_key(|e| e.priority);
    }

    pub fn remove_effect(&mut self, name: &str) {
        self.effects.retain(|e| e.name != name);
    }

    pub fn execute(&self, ctx: &RenderContext) {
        for effect in &self.effects {
            if effect.enabled {
                effect.apply(ctx);
            }
        }
    }
}

// ============================================================================
// PRESET MANAGEMENT SYSTEM
// ============================================================================

/// Advanced preset manager with categories and thumbnails
pub struct PresetManager {
    presets: HashMap<String, ENBPreset>,
    categories: Vec<PresetCategory>,
    current_preset: Option<String>,
    favorite_presets: Vec<String>,

    // Transition
    transition_preset: Option<String>,
    transition_progress: f32,
    transition_duration: f32,

    // Paths
    preset_directory: String,
    cache_directory: String,
}

pub struct PresetCategory {
    name: String,
    presets: Vec<String>,
    icon: Option<ENBTexture>,
}

impl PresetManager {
    pub fn new(preset_dir: &str) -> Self {
        Self {
            presets: HashMap::new(),
            categories: vec![
                PresetCategory { name: "Realistic".into(), presets: Vec::new(), icon: None },
                PresetCategory { name: "Fantasy".into(), presets: Vec::new(), icon: None },
                PresetCategory { name: "Cinematic".into(), presets: Vec::new(), icon: None },
                PresetCategory { name: "Performance".into(), presets: Vec::new(), icon: None },
                PresetCategory { name: "Custom".into(), presets: Vec::new(), icon: None },
            ],
            current_preset: None,
            favorite_presets: Vec::new(),
            transition_preset: None,
            transition_progress: 1.0,
            transition_duration: 1.0,
            preset_directory: preset_dir.to_string(),
            cache_directory: format!("{}/cache", preset_dir),
        }
    }

    pub fn scan_presets(&mut self) -> Result<u32, ENBError> {
        shader {
            let mut count = 0u32;

            let entries = fs::read_dir(&self.preset_directory)?;

            for entry in entries {
                let entry = entry?;
                let path = entry.path();

                if path.is_dir() {
                    let ini_path = path.join("enbseries.ini");
                    if ini_path.exists() {
                        if let Ok(preset) = ENBPreset::load(ini_path.to_str().unwrap()) {
                            let name = path.file_name()
                                .unwrap()
                                .to_str()
                                .unwrap()
                                .to_string();

                            self.presets.insert(name.clone(), preset);
                            count += 1;

                            // Auto-categorize based on name/author
                            self.auto_categorize(&name);
                        }
                    }
                }
            }

            Ok(count)
        }
    }

    fn auto_categorize(&mut self, preset_name: &str) {
        let name_lower = preset_name.to_lowercase();

        let category_idx = if name_lower.contains("realistic") || name_lower.contains("photorealistic") {
            0
        } else if name_lower.contains("fantasy") || name_lower.contains("vibrant") {
            1
        } else if name_lower.contains("cinematic") || name_lower.contains("film") {
            2
        } else if name_lower.contains("performance") || name_lower.contains("lite") {
            3
        } else {
            4
        };

        self.categories[category_idx].presets.push(preset_name.to_string());
    }

    pub fn apply_preset(&mut self, name: &str, smooth: bool) -> Result<(), ENBError> {
        if !self.presets.contains_key(name) {
            return Err(ENBError::PresetLoadFailed(name.to_string()));
        }

        if smooth && self.current_preset.is_some() {
            self.transition_preset = Some(name.to_string());
            self.transition_progress = 0.0;
        } else {
            self.current_preset = Some(name.to_string());
            self.transition_progress = 1.0;
        }

        Ok(())
    }

    pub fn update_transition(&mut self, delta_time: f32) -> Option<ENBPreset> {
        if self.transition_preset.is_none() || self.transition_progress >= 1.0 {
            return self.current_preset.as_ref()
                .and_then(|name| self.presets.get(name))
                .cloned();
        }

        self.transition_progress += delta_time / self.transition_duration;
        self.transition_progress = self.transition_progress.min(1.0);

        if self.transition_progress >= 1.0 {
            self.current_preset = self.transition_preset.take();
            return self.current_preset.as_ref()
                .and_then(|name| self.presets.get(name))
                .cloned();
        }

        // Interpolate between presets
        let current = self.current_preset.as_ref()
            .and_then(|name| self.presets.get(name));
        let target = self.transition_preset.as_ref()
            .and_then(|name| self.presets.get(name));

        match (current, target) {
            (Some(current), Some(target)) => {
                Some(current.interpolate(target, self.transition_progress))
            },
            (None, Some(target)) => Some(target.clone()),
            (Some(current), None) => Some(current.clone()),
            (None, None) => None,
        }
    }

    pub fn create_screenshot_preset(&self, device: *mut ID3D11Device,
                                     swap_chain: *mut IDXGISwapChain) -> Result<ENBTexture, ENBError> {
        shader {
            // Capture current frame as preset thumbnail
            let mut back_buffer: *mut ID3D11Texture2D = std::ptr::null_mut();
            (*swap_chain).GetBuffer(0, &IID_ID3D11Texture2D, &mut back_buffer as *mut _ as *mut *mut _);

            // Create staging texture for readback
            let desc = D3D11_TEXTURE2D_DESC {
                Width: 256,
                Height: 144,
                MipLevels: 1,
                ArraySize: 1,
                Format: DXGI_FORMAT_R8G8B8A8_UNORM,
                SampleDesc: DXGI_SAMPLE_DESC { Count: 1, Quality: 0 },
                Usage: D3D11_USAGE_STAGING,
                BindFlags: 0,
                CPUAccessFlags: D3D11_CPU_ACCESS_READ,
                MiscFlags: 0,
            };

            let mut thumbnail: *mut ID3D11Texture2D = std::ptr::null_mut();
            (*device).CreateTexture2D(&desc, std::ptr::null(), &mut thumbnail);

            // Copy and resize
            // ... implementation details

            ENBTexture::from_texture(device, thumbnail)
        }
    }
}

