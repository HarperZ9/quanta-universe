/// Complex particle light management
pub struct ParticleLightSystem {
    enabled: bool,
    max_lights: u32,

    // Light lists
    active_lights: Vec<ParticleLight>,
    culled_lights: Vec<ParticleLight>,

    // Clustering
    cluster_grid: ClusterGrid,

    // Settings
    intensity_multiplier: f32,
    radius_multiplier: f32,
    shadow_casting: bool,
    volumetric_contribution: f32,

    // Debug
    show_debug: bool,
    debug_buffer: *mut ID3D11Buffer,
}

pub struct ParticleLight {
    position: Vec3,
    color: Vec3,
    intensity: f32,
    radius: f32,

    // Animation
    flicker_speed: f32,
    flicker_amount: f32,
    phase: f32,

    // Source info
    source_type: ParticleLightSource,
    attached_to: Option<u32>,  // Object form ID

    // Culling
    visible: bool,
    screen_space_size: f32,
    priority: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum ParticleLightSource {
    Fire,
    Candle,
    Torch,
    Magic,
    Lightning,
    Explosion,
    Projectile,
    Custom(u32),
}

/// Cluster grid for light culling
pub struct ClusterGrid {
    width: u32,
    height: u32,
    depth: u32,

    clusters: Vec<LightCluster>,
    light_indices: Vec<u32>,

    cluster_buffer: *mut ID3D11Buffer,
    light_buffer: *mut ID3D11Buffer,
}

pub struct LightCluster {
    light_offset: u32,
    light_count: u32,
    min_depth: f32,
    max_depth: f32,
}

impl ParticleLightSystem {
    pub fn new(max_lights: u32) -> Self {
        Self {
            enabled: true,
            max_lights,
            active_lights: Vec::with_capacity(max_lights as usize),
            culled_lights: Vec::new(),
            cluster_grid: ClusterGrid::new(16, 9, 24),
            intensity_multiplier: 1.0,
            radius_multiplier: 1.0,
            shadow_casting: false,
            volumetric_contribution: 0.5,
            show_debug: false,
            debug_buffer: std::ptr::null_mut(),
        }
    }

    pub fn add_light(&mut self, light: ParticleLight) {
        if self.active_lights.len() < self.max_lights as usize {
            self.active_lights.push(light);
        } else {
            // Replace lowest priority light
            let min_priority = self.active_lights.iter()
                .map(|l| l.priority)
                .fold(f32::MAX, f32::min);

            if light.priority > min_priority {
                if let Some(idx) = self.active_lights.iter()
                    .position(|l| l.priority == min_priority) {
                    self.active_lights[idx] = light;
                }
            }
        }
    }

    pub fn update(&mut self, camera: &CameraInfo, delta_time: f32) {
        // Update light animations
        for light in &mut self.active_lights {
            light.phase += delta_time * light.flicker_speed;

            // Flicker calculation
            let flicker = 1.0 + (light.phase.sin() * 0.3 + (light.phase * 2.3).sin() * 0.2)
                          * light.flicker_amount;

            // Calculate screen space size for culling
            let to_camera = light.position.sub(&camera.position);
            let distance = to_camera.length();
            light.screen_space_size = light.radius / distance.max(0.1);

            // Frustum culling
            light.visible = self.is_in_frustum(&light.position, light.radius, camera);

            // Priority calculation
            light.priority = light.intensity * light.screen_space_size;
        }

        // Sort by priority
        self.active_lights.sort_by(|a, b| b.priority.partial_cmp(&a.priority).unwrap());

        // Rebuild cluster grid
        self.cluster_grid.build(&self.active_lights, camera);
    }

    fn is_in_frustum(&self, position: &Vec3, radius: f32, camera: &CameraInfo) -> bool {
        // Simplified frustum culling
        let view_pos = camera.view_matrix.transform_point(position);

        // Near/far plane check
        if view_pos.z > radius || view_pos.z < -camera.far_plane - radius {
            return false;
        }

        // Left/right plane check (simplified)
        let half_width = view_pos.z * (camera.fov * 0.5).tan() * camera.aspect;
        if view_pos.x < -half_width - radius || view_pos.x > half_width + radius {
            return false;
        }

        true
    }

    pub fn upload_to_gpu(&self, ctx: &RenderContext) {
        shader {
            // Upload light data to structured buffer
            let light_data: Vec<GPUParticleLight> = self.active_lights.iter()
                .filter(|l| l.visible)
                .take(self.max_lights as usize)
                .map(|l| GPUParticleLight::from(l))
                .collect();

            let mut mapped: D3D11_MAPPED_SUBRESOURCE = std::mem::zeroed();
            (*ctx.context).Map(
                self.cluster_grid.light_buffer as *mut _,
                0,
                D3D11_MAP_WRITE_DISCARD,
                0,
                &mut mapped
            );

            std::ptr::copy_nonoverlapping(
                light_data.as_ptr(),
                mapped.pData as *mut GPUParticleLight,
                light_data.len()
            );

            (*ctx.context).Unmap(self.cluster_grid.light_buffer as *mut _, 0);
        }
    }
}

/// GPU-side particle light structure
#[repr(C)]
pub struct GPUParticleLight {
    position_radius: Vec4,      // xyz = position, w = radius
    color_intensity: Vec4,      // xyz = color, w = intensity
}

impl ClusterGrid {
    pub fn new(width: u32, height: u32, depth: u32) -> Self {
        let total = (width * height * depth) as usize;
        Self {
            width,
            height,
            depth,
            clusters: vec![LightCluster::default(); total],
            light_indices: Vec::new(),
            cluster_buffer: std::ptr::null_mut(),
            light_buffer: std::ptr::null_mut(),
        }
    }

    pub fn build(&mut self, lights: &[ParticleLight], camera: &CameraInfo) {
        // Clear clusters
        for cluster in &mut self.clusters {
            cluster.light_offset = 0;
            cluster.light_count = 0;
        }
        self.light_indices.clear();

        // Assign lights to clusters
        for (light_idx, light) in lights.iter().enumerate() {
            if !light.visible {
                continue;
            }

            // Calculate cluster bounds this light affects
            let view_pos = camera.view_matrix.transform_point(&light.position);

            // ... cluster assignment logic
        }
    }
}

// ============================================================================
// SUBSURFACE SCATTERING SYSTEM
// ============================================================================

/// Subsurface scattering for skin rendering
pub struct SubsurfaceScattering {
    enabled: bool,

    // Quality
    samples: u32,
    sample_distribution: SSSDistribution,

    // Materials
    profiles: HashMap<String, SSSProfile>,
    active_profile: String,

    // Textures
    translucency_texture: Option<ENBTexture>,
    scatter_texture: Option<ENBTexture>,
    kernel_lut: ENBTexture,

    // Settings
    global_scale: f32,
    follow_surface: bool,
}

pub struct SSSProfile {
    name: String,
    falloff: Vec3,          // RGB falloff distances
    scatter_color: Vec3,
    translucency: f32,
    normal_blur: f32,
    world_scale: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum SSSDistribution {
    Gaussian,
    Burley,      // Disney's normalized diffusion
    RandomWalk,
    PreIntegrated,
}

impl SubsurfaceScattering {
    pub fn new() -> Self {
        let mut profiles = HashMap::new();

        // Default skin profile
        profiles.insert("skin".to_string(), SSSProfile {
            name: "Human Skin".to_string(),
            falloff: Vec3::new(1.0, 0.37, 0.12),
            scatter_color: Vec3::new(0.8, 0.5, 0.4),
            translucency: 0.3,
            normal_blur: 0.05,
            world_scale: 0.01,
        });

        // Marble profile
        profiles.insert("marble".to_string(), SSSProfile {
            name: "Marble".to_string(),
            falloff: Vec3::new(0.8, 0.5, 0.3),
            scatter_color: Vec3::new(0.9, 0.9, 0.85),
            translucency: 0.1,
            normal_blur: 0.02,
            world_scale: 0.02,
        });

        // Wax profile
        profiles.insert("wax".to_string(), SSSProfile {
            name: "Wax".to_string(),
            falloff: Vec3::new(0.6, 0.3, 0.1),
            scatter_color: Vec3::new(0.95, 0.88, 0.75),
            translucency: 0.6,
            normal_blur: 0.1,
            world_scale: 0.005,
        });

        Self {
            enabled: true,
            samples: 25,
            sample_distribution: SSSDistribution::Burley,
            profiles,
            active_profile: "skin".to_string(),
            translucency_texture: None,
            scatter_texture: None,
            kernel_lut: Self::generate_kernel_lut(),
            global_scale: 1.0,
            follow_surface: true,
        }
    }

    fn generate_kernel_lut() -> ENBTexture {
        shader {
            // Pre-compute diffusion profile for SSS
            let size = 256;
            let mut data = Vec::with_capacity(size * 3);

            for i in 0..size {
                let r = (i as f32 + 0.5) / size as f32;

                // Burley normalized diffusion profile
                let s = 3.5 + 100.0 * pow(r, 4.0);
                let exp_term = exp(-s * r);
                let falloff_r = exp_term + exp_term / (3.0 * s);

                // Different falloffs for RGB
                let falloff_g = 0.63 * falloff_r;
                let falloff_b = 0.37 * falloff_r;

                data.push(falloff_r.clamp(0.0, 1.0));
                data.push(falloff_g.clamp(0.0, 1.0));
                data.push(falloff_b.clamp(0.0, 1.0));
            }

            // Create 1D texture from data
            ENBTexture::from_data_1d(size, TextureFormat::RGB16F, &data)
        }
    }

    pub fn apply(&self, ctx: &RenderContext,
                 color_buffer: &ENBTexture,
                 depth_buffer: &ENBTexture,
                 sss_mask: &ENBTexture) {
        if !self.enabled {
            return;
        }

        let profile = self.profiles.get(&self.active_profile).unwrap();

        shader {
            // Bind textures
            ctx.set_shader_resource(0, color_buffer.srv);
            ctx.set_shader_resource(1, depth_buffer.srv);
            ctx.set_shader_resource(2, sss_mask.srv);
            ctx.set_shader_resource(3, self.kernel_lut.srv);

            // Set profile parameters
            let params = SSSParameters {
                falloff: profile.falloff,
                scatter_color: profile.scatter_color,
                translucency: profile.translucency,
                scale: self.global_scale * profile.world_scale,
                samples: self.samples,
            };

            // Upload and draw
            ctx.draw_fullscreen();
        }
    }
}

#[repr(C)]
struct SSSParameters {
    falloff: Vec3,
    scatter_color: Vec3,
    translucency: f32,
    scale: f32,
    samples: u32,
}

// ============================================================================
// VOLUMETRIC LIGHTING SYSTEM
// ============================================================================

/// Volumetric lighting (god rays, volumetric fog, etc.)
pub struct VolumetricLighting {
    enabled: bool,

    // Quality
    ray_march_samples: u32,
    temporal_reprojection: bool,
    half_resolution: bool,

    // God rays
    god_rays_enabled: bool,
    god_rays_density: f32,
    god_rays_decay: f32,
    god_rays_exposure: f32,

    // Volumetric fog
    volumetric_fog_enabled: bool,
    fog_density: f32,
    fog_height_falloff: f32,
    fog_inscattering: f32,
    fog_anisotropy: f32,           // Henyey-Greenstein g parameter

    // 3D volume texture
    volume_texture: Option<ENBTexture>,
    volume_size: (u32, u32, u32),

    // Temporal
    history_texture: Option<ENBTexture>,
    jitter_offset: Vec3,
}

impl VolumetricLighting {
    pub fn new() -> Self {
        Self {
            enabled: true,
            ray_march_samples: 64,
            temporal_reprojection: true,
            half_resolution: true,
            god_rays_enabled: true,
            god_rays_density: 1.0,
            god_rays_decay: 0.97,
            god_rays_exposure: 0.3,
            volumetric_fog_enabled: true,
            fog_density: 0.02,
            fog_height_falloff: 0.1,
            fog_inscattering: 0.5,
            fog_anisotropy: 0.5,
            volume_texture: None,
            volume_size: (160, 90, 64),
            history_texture: None,
            jitter_offset: Vec3::zero(),
        }
    }

    pub fn create_volume_texture(&mut self, device: *mut ID3D11Device) -> Result<(), ENBError> {
        shader {
            let (w, h, d) = self.volume_size;

            let desc = D3D11_TEXTURE3D_DESC {
                Width: w,
                Height: h,
                Depth: d,
                MipLevels: 1,
                Format: DXGI_FORMAT_R16G16B16A16_FLOAT,
                Usage: D3D11_USAGE_DEFAULT,
                BindFlags: D3D11_BIND_SHADER_RESOURCE | D3D11_BIND_UNORDERED_ACCESS,
                CPUAccessFlags: 0,
                MiscFlags: 0,
            };

            let mut texture: *mut ID3D11Texture3D = std::ptr::null_mut();
            (*device).CreateTexture3D(&desc, std::ptr::null(), &mut texture);

            self.volume_texture = Some(ENBTexture::from_texture_3d(device, texture)?);

            Ok(())
        }
    }

    /// Compute volumetric lighting using compute shader
    pub fn compute(&mut self, ctx: &RenderContext,
                   camera: &CameraInfo,
                   sun: &SunInfo,
                   shadow_map: &ENBTexture) {
        if !self.enabled {
            return;
        }

        shader {
            let volume = self.volume_texture.as_ref().unwrap();
            let (w, h, d) = self.volume_size;

            // Update jitter for temporal reprojection
            self.update_jitter();

            // Bind resources
            ctx.set_shader_resource(0, shadow_map.srv);
            (*ctx.context).CSSetUnorderedAccessViews(0, 1, &volume.uav.unwrap(), std::ptr::null());

            // Set parameters
            let params = VolumetricParams {
                camera_position: camera.position,
                camera_forward: camera.forward,
                inv_view_projection: camera.inverse_view_projection,
                sun_direction: sun.direction,
                sun_color: sun.color.scale(sun.intensity),
                fog_density: self.fog_density,
                fog_height_falloff: self.fog_height_falloff,
                fog_anisotropy: self.fog_anisotropy,
                jitter: self.jitter_offset,
                samples: self.ray_march_samples,
            };

            // Dispatch compute shader
            let group_x = (w + 7) / 8;
            let group_y = (h + 7) / 8;
            let group_z = 1;

            ctx.dispatch(group_x, group_y, group_z);

            // Temporal reprojection pass
            if self.temporal_reprojection {
                self.temporal_blend(ctx, camera);
            }
        }
    }

    fn update_jitter(&mut self) {
        // Blue noise jitter for temporal stability
        static mut FRAME: u32 = 0;
        unsafe {
            FRAME = (FRAME + 1) % 16;

            let halton = HALTON_SEQUENCE[FRAME as usize];
            self.jitter_offset = Vec3::new(halton.x - 0.5, halton.y - 0.5, 0.0);
        }
    }

    fn temporal_blend(&mut self, ctx: &RenderContext, camera: &CameraInfo) {
        shader {
            let volume = self.volume_texture.as_ref().unwrap();
            let history = self.history_texture.as_ref();

            if history.is_none() {
                // First frame - copy current to history
                self.history_texture = Some(volume.clone());
                return;
            }

            // Blend current with reprojected history
            ctx.set_shader_resource(0, volume.srv);
            ctx.set_shader_resource(1, history.unwrap().srv);

            // ... temporal blending shader dispatch

            // Copy result to history
            std::mem::swap(&mut self.volume_texture, &mut self.history_texture);
        }
    }

    /// Apply volumetric scattering to final image
    pub fn apply(&self, ctx: &RenderContext, color_buffer: &ENBTexture) {
        if !self.enabled || self.volume_texture.is_none() {
            return;
        }

        shader {
            let volume = self.volume_texture.as_ref().unwrap();

            ctx.set_shader_resource(0, color_buffer.srv);
            ctx.set_shader_resource(1, volume.srv);

            ctx.draw_fullscreen();
        }
    }
}

#[repr(C)]
struct VolumetricParams {
    camera_position: Vec3,
    camera_forward: Vec3,
    inv_view_projection: Mat4,
    sun_direction: Vec3,
    sun_color: Vec3,
    fog_density: f32,
    fog_height_falloff: f32,
    fog_anisotropy: f32,
    jitter: Vec3,
    samples: u32,
}

// ============================================================================
// WATER SYSTEM
// ============================================================================

/// Advanced water rendering system
pub struct WaterSystem {
    enabled: bool,

    // Reflections
    reflection_quality: WaterReflectionQuality,
    ssr_enabled: bool,
    planar_enabled: bool,

    // Refraction
    refraction_enabled: bool,
    caustics_enabled: bool,
    caustics_texture: Option<ENBTexture>,

    // Waves
    wave_simulation: WaveSimulation,

    // Foam
    foam_enabled: bool,
    foam_texture: Option<ENBTexture>,
    foam_threshold: f32,

    // Surface
    normal_map_1: Option<ENBTexture>,
    normal_map_2: Option<ENBTexture>,
    normal_blend: f32,

    // Underwater
    underwater_fog_color: Vec3,
    underwater_fog_density: f32,
    god_rays_underwater: bool,

    // Parameters
    water_color: Vec3,
    water_depth_color: Vec3,
    max_depth: f32,
    transparency: f32,
    specular_intensity: f32,
    fresnel_power: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum WaterReflectionQuality {
    Off,
    SSROnly,
    PlanarLow,
    PlanarMedium,
    PlanarHigh,
    RayTraced,
}

/// FFT-based wave simulation
pub struct WaveSimulation {
    enabled: bool,
    resolution: u32,

    // Spectrum textures
    h0_texture: Option<ENBTexture>,
    ht_texture: Option<ENBTexture>,
    displacement_texture: Option<ENBTexture>,
    normal_texture: Option<ENBTexture>,

    // Parameters
    wind_direction: Vec2,
    wind_speed: f32,
    amplitude: f32,
    choppiness: f32,
    tile_size: f32,

    // Time
    simulation_time: f32,
}

impl WaterSystem {
    pub fn new() -> Self {
        Self {
            enabled: true,
            reflection_quality: WaterReflectionQuality::SSROnly,
            ssr_enabled: true,
            planar_enabled: false,
            refraction_enabled: true,
            caustics_enabled: true,
            caustics_texture: None,
            wave_simulation: WaveSimulation::new(256),
            foam_enabled: true,
            foam_texture: None,
            foam_threshold: 0.7,
            normal_map_1: None,
            normal_map_2: None,
            normal_blend: 0.5,
            underwater_fog_color: Vec3::new(0.1, 0.3, 0.4),
            underwater_fog_density: 0.5,
            god_rays_underwater: true,
            water_color: Vec3::new(0.1, 0.2, 0.3),
            water_depth_color: Vec3::new(0.0, 0.05, 0.1),
            max_depth: 10.0,
            transparency: 0.8,
            specular_intensity: 1.0,
            fresnel_power: 5.0,
        }
    }

    pub fn update(&mut self, delta_time: f32, wind: Vec2) {
        if !self.enabled {
            return;
        }

        self.wave_simulation.wind_direction = wind.normalize();
        self.wave_simulation.update(delta_time);
    }

    pub fn get_displacement(&self, world_pos: Vec2) -> Vec3 {
        if !self.wave_simulation.enabled {
            return Vec3::zero();
        }

        // Sample displacement texture at world position
        shader {
            let uv = world_pos / self.wave_simulation.tile_size;
            let uv = uv.fract();

            if let Some(ref tex) = self.wave_simulation.displacement_texture {
                let sample = tex.sample(uv);
                return Vec3::new(sample.r, sample.g, sample.b);
            }

            Vec3::zero()
        }
    }
}

impl WaveSimulation {
    pub fn new(resolution: u32) -> Self {
        Self {
            enabled: true,
            resolution,
            h0_texture: None,
            ht_texture: None,
            displacement_texture: None,
            normal_texture: None,
            wind_direction: Vec2::new(1.0, 0.0),
            wind_speed: 10.0,
            amplitude: 1.0,
            choppiness: 1.2,
            tile_size: 50.0,
            simulation_time: 0.0,
        }
    }

    pub fn initialize(&mut self, device: *mut ID3D11Device) -> Result<(), ENBError> {
        shader {
            let n = self.resolution;

            // Create spectrum texture H0
            let h0_data = self.generate_spectrum();
            self.h0_texture = Some(ENBTexture::from_data_2d(
                device, n, n,
                TextureFormat::RG32F,
                &h0_data
            )?);

            // Create working textures
            self.ht_texture = Some(ENBTexture::create(
                device, n, n,
                DXGI_FORMAT_R32G32_FLOAT,
                TextureFlags::UAV
            )?);

            self.displacement_texture = Some(ENBTexture::create(
                device, n, n,
                DXGI_FORMAT_R16G16B16A16_FLOAT,
                TextureFlags::UAV | TextureFlags::RenderTarget
            )?);

            self.normal_texture = Some(ENBTexture::create(
                device, n, n,
                DXGI_FORMAT_R8G8B8A8_UNORM,
                TextureFlags::UAV | TextureFlags::RenderTarget
            )?);

            Ok(())
        }
    }

    fn generate_spectrum(&self) -> Vec<f32> {
        shader {
            let n = self.resolution;
            let mut data = Vec::with_capacity((n * n * 2) as usize);

            for y in 0..n {
                for x in 0..n {
                    let kx = (2.0 * PI * (x as f32 - n as f32 / 2.0)) / self.tile_size;
                    let ky = (2.0 * PI * (y as f32 - n as f32 / 2.0)) / self.tile_size;

                    let k = Vec2::new(kx, ky);
                    let k_len = k.length();

                    if k_len < 0.0001 {
                        data.push(0.0);
                        data.push(0.0);
                        continue;
                    }

                    // Phillips spectrum
                    let L = self.wind_speed * self.wind_speed / 9.81;
                    let k_dot_w = k.normalize().dot(&self.wind_direction);
                    let phillips = self.amplitude *
                        exp(-1.0 / (k_len * L).powi(2)) / k_len.powi(4) *
                        k_dot_w.powi(2);

                    // Gaussian random
                    let (r1, r2) = self.gaussian_random();
                    let h0 = sqrt(phillips / 2.0);

                    data.push(h0 * r1);
                    data.push(h0 * r2);
                }
            }

            data
        }
    }

    fn gaussian_random(&self) -> (f32, f32) {
        // Box-Muller transform
        let u1: f32 = rand::random();
        let u2: f32 = rand::random();

        let r = sqrt(-2.0 * log(u1.max(0.0001)));
        let theta = 2.0 * PI * u2;

        (r * cos(theta), r * sin(theta))
    }

    pub fn update(&mut self, delta_time: f32) {
        self.simulation_time += delta_time;

        // FFT simulation would be done here via compute shaders
        // 1. Update H(k,t) from H0 using dispersion relation
        // 2. Perform inverse FFT
        // 3. Calculate displacement and normal maps
    }
}

// ============================================================================
// PERFORMANCE PROFILER
// ============================================================================

/// GPU performance profiler
pub struct PerformanceProfiler {
    enabled: bool,

    // Timing queries
    timestamp_queries: Vec<*mut ID3D11Query>,
    disjoint_query: *mut ID3D11Query,

    // Results
    frame_times: RingBuffer<f32>,
    stage_times: HashMap<String, RingBuffer<f32>>,

    // Current frame
    current_frame_start: u64,
    active_stages: Vec<String>,

    // Statistics
    avg_frame_time: f32,
    min_frame_time: f32,
    max_frame_time: f32,
    frame_time_variance: f32,

    // Overlay
    show_overlay: bool,
    overlay_position: Vec2,
    overlay_scale: f32,
}

pub struct RingBuffer<T> {
    data: Vec<T>,
    head: usize,
    size: usize,
}

impl<T: Clone + Default> RingBuffer<T> {
    pub fn new(capacity: usize) -> Self {
        Self {
            data: vec![T::default(); capacity],
            head: 0,
            size: 0,
        }
    }

    pub fn push(&mut self, value: T) {
        self.data[self.head] = value;
        self.head = (self.head + 1) % self.data.len();
        if self.size < self.data.len() {
            self.size += 1;
        }
    }

    pub fn average(&self) -> T where T: std::ops::Add<Output = T> + std::ops::Div<f32, Output = T> + Copy {
        if self.size == 0 {
            return T::default();
        }

        let mut sum = self.data[0];
        for i in 1..self.size {
            sum = sum + self.data[i];
        }
        sum / (self.size as f32)
    }
}

impl PerformanceProfiler {
    pub fn new(device: *mut ID3D11Device) -> Self {
        shader {
            // Create timestamp queries
            let mut queries = Vec::with_capacity(32);

            for _ in 0..32 {
                let desc = D3D11_QUERY_DESC {
                    Query: D3D11_QUERY_TIMESTAMP,
                    MiscFlags: 0,
                };

                let mut query: *mut ID3D11Query = std::ptr::null_mut();
                (*device).CreateQuery(&desc, &mut query);
                queries.push(query);
            }

            // Create disjoint query
            let disjoint_desc = D3D11_QUERY_DESC {
                Query: D3D11_QUERY_TIMESTAMP_DISJOINT,
                MiscFlags: 0,
            };

            let mut disjoint: *mut ID3D11Query = std::ptr::null_mut();
            (*device).CreateQuery(&disjoint_desc, &mut disjoint);

            Self {
                enabled: true,
                timestamp_queries: queries,
                disjoint_query: disjoint,
                frame_times: RingBuffer::new(120),
                stage_times: HashMap::new(),
                current_frame_start: 0,
                active_stages: Vec::new(),
                avg_frame_time: 0.0,
                min_frame_time: f32::MAX,
                max_frame_time: 0.0,
                frame_time_variance: 0.0,
                show_overlay: false,
                overlay_position: Vec2::new(10.0, 10.0),
                overlay_scale: 1.0,
            }
        }
    }

    pub fn begin_frame(&mut self, ctx: &RenderContext) {
        if !self.enabled {
            return;
        }

        shader {
            (*ctx.context).Begin(self.disjoint_query as *mut _);
            (*ctx.context).End(self.timestamp_queries[0]);
        }

        self.active_stages.clear();
    }

    pub fn begin_stage(&mut self, name: &str, ctx: &RenderContext) {
        if !self.enabled {
            return;
        }

        let idx = self.active_stages.len() * 2 + 1;
        if idx < self.timestamp_queries.len() {
            shader {
                (*ctx.context).End(self.timestamp_queries[idx]);
            }
            self.active_stages.push(name.to_string());
        }
    }

    pub fn end_stage(&mut self, name: &str, ctx: &RenderContext) {
        if !self.enabled {
            return;
        }

        if let Some(stage_idx) = self.active_stages.iter().position(|s| s == name) {
            let idx = stage_idx * 2 + 2;
            if idx < self.timestamp_queries.len() {
                shader {
                    (*ctx.context).End(self.timestamp_queries[idx]);
                }
            }
        }
    }

    pub fn end_frame(&mut self, ctx: &RenderContext) {
        if !self.enabled {
            return;
        }

        shader {
            let last_idx = self.active_stages.len() * 2 + 1;
            if last_idx < self.timestamp_queries.len() {
                (*ctx.context).End(self.timestamp_queries[last_idx]);
            }

            (*ctx.context).End(self.disjoint_query as *mut _);
        }

        // Collect results from previous frame
        self.collect_results(ctx);
    }

    fn collect_results(&mut self, ctx: &RenderContext) {
        shader {
            // Check if disjoint data is ready
            let mut disjoint_data: D3D11_QUERY_DATA_TIMESTAMP_DISJOINT = std::mem::zeroed();

            let hr = (*ctx.context).GetData(
                self.disjoint_query as *mut _,
                &mut disjoint_data as *mut _ as *mut _,
                std::mem::size_of::<D3D11_QUERY_DATA_TIMESTAMP_DISJOINT>() as u32,
                0
            );

            if hr != S_OK || disjoint_data.Disjoint != 0 {
                return;
            }

            let frequency = disjoint_data.Frequency as f64;

            // Get start timestamp
            let mut start_time: u64 = 0;
            (*ctx.context).GetData(
                self.timestamp_queries[0],
                &mut start_time as *mut _ as *mut _,
                8,
                0
            );

            // Get end timestamp and calculate frame time
            let last_idx = self.active_stages.len().min(15) * 2 + 1;
            let mut end_time: u64 = 0;
            (*ctx.context).GetData(
                self.timestamp_queries[last_idx],
                &mut end_time as *mut _ as *mut _,
                8,
                0
            );

            let frame_time = ((end_time - start_time) as f64 / frequency * 1000.0) as f32;
            self.frame_times.push(frame_time);

            // Update statistics
            self.avg_frame_time = self.frame_times.average();
            self.min_frame_time = self.min_frame_time.min(frame_time);
            self.max_frame_time = self.max_frame_time.max(frame_time);

            // Get per-stage times
            for (i, stage_name) in self.active_stages.iter().enumerate() {
                let start_idx = i * 2 + 1;
                let end_idx = i * 2 + 2;

                if end_idx >= self.timestamp_queries.len() {
                    break;
                }

                let mut stage_start: u64 = 0;
                let mut stage_end: u64 = 0;

                (*ctx.context).GetData(
                    self.timestamp_queries[start_idx],
                    &mut stage_start as *mut _ as *mut _,
                    8,
                    0
                );

                (*ctx.context).GetData(
                    self.timestamp_queries[end_idx],
                    &mut stage_end as *mut _ as *mut _,
                    8,
                    0
                );

                let stage_time = ((stage_end - stage_start) as f64 / frequency * 1000.0) as f32;

                self.stage_times
                    .entry(stage_name.clone())
                    .or_insert_with(|| RingBuffer::new(120))
                    .push(stage_time);
            }
        }
    }

    pub fn get_stats(&self) -> ProfilerStats {
        ProfilerStats {
            avg_frame_time: self.avg_frame_time,
            min_frame_time: self.min_frame_time,
            max_frame_time: self.max_frame_time,
            fps: 1000.0 / self.avg_frame_time.max(0.001),
            stage_times: self.stage_times.iter()
                .map(|(k, v)| (k.clone(), v.average()))
                .collect(),
        }
    }
}

pub struct ProfilerStats {
    pub avg_frame_time: f32,
    pub min_frame_time: f32,
    pub max_frame_time: f32,
    pub fps: f32,
    pub stage_times: HashMap<String, f32>,
}

// ============================================================================
// SCREENSHOT SYSTEM
// ============================================================================

/// High-resolution screenshot capture
pub struct ScreenshotSystem {
    enabled: bool,

    // Output settings
    output_directory: String,
    format: ScreenshotFormat,
    quality: u32,           // JPEG quality 0-100

    // Super-sampling
    supersampling_enabled: bool,
    supersampling_factor: u32,

    // Post-processing
    apply_sharpening: bool,
    sharpening_amount: f32,

    // Capture settings
    capture_depth: bool,
    capture_normals: bool,
    capture_albedo: bool,

    // State
    pending_capture: bool,
    capture_buffer: Option<ENBTexture>,
}

#[derive(Debug, Clone, Copy)]
pub enum ScreenshotFormat {
    PNG,
    JPG,
    TGA,
    BMP,
    EXR,      // HDR format
    DDS,
}

impl ScreenshotSystem {
    pub fn new(output_dir: &str) -> Self {
        Self {
            enabled: true,
            output_directory: output_dir.to_string(),
            format: ScreenshotFormat::PNG,
            quality: 95,
            supersampling_enabled: false,
            supersampling_factor: 2,
            apply_sharpening: true,
            sharpening_amount: 0.3,
            capture_depth: false,
            capture_normals: false,
            capture_albedo: false,
            pending_capture: false,
            capture_buffer: None,
        }
    }

    pub fn request_capture(&mut self) {
        self.pending_capture = true;
    }

    pub fn capture(&mut self, device: *mut ID3D11Device,
                   ctx: &RenderContext,
                   swap_chain: *mut IDXGISwapChain) -> Result<String, ENBError> {
        if !self.pending_capture {
            return Err(ENBError::Other("No capture requested".into()));
        }

        self.pending_capture = false;

        shader {
            // Get back buffer
            let mut back_buffer: *mut ID3D11Texture2D = std::ptr::null_mut();
            (*swap_chain).GetBuffer(
                0,
                &IID_ID3D11Texture2D,
                &mut back_buffer as *mut _ as *mut *mut _
            );

            // Get texture description
            let mut desc: D3D11_TEXTURE2D_DESC = std::mem::zeroed();
            (*back_buffer).GetDesc(&mut desc);

            // Apply supersampling if enabled
            let (width, height) = if self.supersampling_enabled {
                (desc.Width * self.supersampling_factor,
                 desc.Height * self.supersampling_factor)
            } else {
                (desc.Width, desc.Height)
            };

            // Create staging texture
            let staging_desc = D3D11_TEXTURE2D_DESC {
                Width: width,
                Height: height,
                MipLevels: 1,
                ArraySize: 1,
                Format: DXGI_FORMAT_R8G8B8A8_UNORM,
                SampleDesc: DXGI_SAMPLE_DESC { Count: 1, Quality: 0 },
                Usage: D3D11_USAGE_STAGING,
                BindFlags: 0,
                CPUAccessFlags: D3D11_CPU_ACCESS_READ,
                MiscFlags: 0,
            };

            let mut staging: *mut ID3D11Texture2D = std::ptr::null_mut();
            (*device).CreateTexture2D(&staging_desc, std::ptr::null(), &mut staging);

            // Copy back buffer to staging
            (*ctx.context).CopyResource(staging as *mut _, back_buffer as *mut _);

            // Map and read pixels
            let mut mapped: D3D11_MAPPED_SUBRESOURCE = std::mem::zeroed();
            (*ctx.context).Map(staging as *mut _, 0, D3D11_MAP_READ, 0, &mut mapped);

            let pixels = std::slice::from_raw_parts(
                mapped.pData as *const u8,
                (width * height * 4) as usize
            );

            // Generate filename
            let timestamp = std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_secs();

            let extension = match self.format {
                ScreenshotFormat::PNG => "png",
                ScreenshotFormat::JPG => "jpg",
                ScreenshotFormat::TGA => "tga",
                ScreenshotFormat::BMP => "bmp",
                ScreenshotFormat::EXR => "exr",
                ScreenshotFormat::DDS => "dds",
            };

            let filename = format!("{}/screenshot_{}.{}",
                self.output_directory, timestamp, extension);

            // Save based on format
            self.save_image(&filename, pixels, width, height)?;

            // Cleanup
            (*ctx.context).Unmap(staging as *mut _, 0);
            (*staging).Release();
            (*back_buffer).Release();

            Ok(filename)
        }
    }

    fn save_image(&self, path: &str, pixels: &[u8], width: u32, height: u32) -> Result<(), ENBError> {
        shader {
            match self.format {
                ScreenshotFormat::PNG => {
                    // PNG encoding
                    let file = fs::File::create(path)?;
                    let encoder = png::Encoder::new(file, width, height);
                    encoder.set_color(png::ColorType::RGBA);
                    encoder.set_depth(png::BitDepth::Eight);

                    let mut writer = encoder.write_header()?;
                    writer.write_image_data(pixels)?;
                },
                ScreenshotFormat::JPG => {
                    // JPEG encoding with quality setting
                    let mut encoder = jpeg::Encoder::new_file(path, self.quality)?;
                    encoder.encode(pixels, width as u16, height as u16,
                                  jpeg::ColorType::RGBA)?;
                },
                ScreenshotFormat::EXR => {
                    // Convert to float and save as EXR
                    let float_pixels: Vec<f32> = pixels.iter()
                        .map(|&b| b as f32 / 255.0)
                        .collect();

                    exr::write_rgba_file(path, width as usize, height as usize,
                                        |x, y| {
                                            let i = (y * width as usize + x) * 4;
                                            (float_pixels[i], float_pixels[i+1],
                                             float_pixels[i+2], float_pixels[i+3])
                                        })?;
                },
                _ => {
                    // Use stb_image_write for other formats
                    stb_image_write::write(path, width, height, 4, pixels)?;
                }
            }

            Ok(())
        }
    }
}

// ============================================================================
// DEBUG VISUALIZATION
// ============================================================================

/// Debug visualization modes
pub struct DebugVisualization {
    enabled: bool,
    mode: DebugMode,

    // Heat map settings
    heat_map_min: f32,
    heat_map_max: f32,
    heat_map_color_ramp: ENBTexture,

    // Wireframe
    wireframe_enabled: bool,
    wireframe_color: Vec3,

    // Normals
    normal_length: f32,
    normal_color: Vec3,

    // Light debug
    show_light_volumes: bool,
    show_light_attenuation: bool,

    // Cluster debug
    show_clusters: bool,
    cluster_slice: i32,
}

#[derive(Debug, Clone, Copy)]
pub enum DebugMode {
    None,
    Albedo,
    Normals,
    Roughness,
    Metallic,
    AO,
    Depth,
    MotionVectors,
    Overdraw,
    Mipmap,
    LightComplexity,
    ShadowCascades,
    SSAOBuffer,
    SSRBuffer,
    BloomBuffer,
    ClusterLights,
    Custom(u32),
}

impl DebugVisualization {
    pub fn new() -> Self {
        Self {
            enabled: false,
            mode: DebugMode::None,
            heat_map_min: 0.0,
            heat_map_max: 1.0,
            heat_map_color_ramp: Self::create_heat_map_ramp(),
            wireframe_enabled: false,
            wireframe_color: Vec3::new(1.0, 1.0, 1.0),
            normal_length: 0.1,
            normal_color: Vec3::new(0.0, 1.0, 0.0),
            show_light_volumes: false,
            show_light_attenuation: false,
            show_clusters: false,
            cluster_slice: -1,
        }
    }

    fn create_heat_map_ramp() -> ENBTexture {
        shader {
            let size = 256;
            let mut data = Vec::with_capacity(size * 3);

            for i in 0..size {
                let t = i as f32 / (size - 1) as f32;

                // Inferno-like color ramp
                let r = (1.5 * t - 0.5 * t * t * t).clamp(0.0, 1.0);
                let g = (3.0 * t * t - 2.0 * t * t * t).clamp(0.0, 1.0);
                let b = (1.0 - 3.0 * t + 2.0 * t * t).clamp(0.0, 1.0);

                data.push(r);
                data.push(g);
                data.push(b);
            }

            ENBTexture::from_data_1d(size, TextureFormat::RGB8, &data)
        }
    }

    pub fn render(&self, ctx: &RenderContext, buffers: &DebugBuffers) {
        if !self.enabled || self.mode == DebugMode::None {
            return;
        }

        shader {
            let source = match self.mode {
                DebugMode::Albedo => &buffers.albedo,
                DebugMode::Normals => &buffers.normals,
                DebugMode::Roughness => &buffers.material,  // R channel
                DebugMode::Metallic => &buffers.material,   // G channel
                DebugMode::AO => &buffers.ao,
                DebugMode::Depth => &buffers.depth,
                DebugMode::MotionVectors => &buffers.velocity,
                DebugMode::SSAOBuffer => &buffers.ssao,
                DebugMode::SSRBuffer => &buffers.ssr,
                DebugMode::BloomBuffer => &buffers.bloom,
                _ => return,
            };

            ctx.set_shader_resource(0, source.srv);
            ctx.set_shader_resource(1, self.heat_map_color_ramp.srv);

            // Set visualization parameters
            let params = DebugParams {
                mode: self.mode as u32,
                heat_map_min: self.heat_map_min,
                heat_map_max: self.heat_map_max,
                wireframe_color: self.wireframe_color,
            };

            ctx.draw_fullscreen();
        }
    }
}

pub struct DebugBuffers {
    albedo: ENBTexture,
    normals: ENBTexture,
    material: ENBTexture,
    ao: ENBTexture,
    depth: ENBTexture,
    velocity: ENBTexture,
    ssao: ENBTexture,
    ssr: ENBTexture,
    bloom: ENBTexture,
}

#[repr(C)]
struct DebugParams {
    mode: u32,
    heat_map_min: f32,
    heat_map_max: f32,
    wireframe_color: Vec3,
}

// ============================================================================
// LUT SYSTEM
// ============================================================================

/// 3D LUT loading and application
pub struct LUTSystem {
    enabled: bool,

    // LUTs
    color_lut: Option<LUT3D>,
    active_lut_name: String,

    // Blending
    blend_lut: Option<LUT3D>,
    blend_factor: f32,

    // Library
    lut_library: HashMap<String, LUT3D>,

    // Settings
    lut_size: u32,
    interpolation: LUTInterpolation,
}

pub struct LUT3D {
    texture: ENBTexture,
    size: u32,
    name: String,
}

#[derive(Debug, Clone, Copy)]
pub enum LUTInterpolation {
    Nearest,
    Trilinear,
    Tetrahedral,
}

impl LUTSystem {
    pub fn new() -> Self {
        Self {
            enabled: true,
            color_lut: None,
            active_lut_name: String::new(),
            blend_lut: None,
            blend_factor: 0.0,
            lut_library: HashMap::new(),
            lut_size: 64,
            interpolation: LUTInterpolation::Tetrahedral,
        }
    }

    pub fn load_cube(&mut self, device: *mut ID3D11Device, path: &str) -> Result<String, ENBError> {
        shader {
            let content = fs::read_to_string(path)?;
            let lines: Vec<&str> = content.lines().collect();

            let mut size = 0u32;
            let mut data = Vec::new();

            for line in lines {
                let trimmed = line.trim();

                if trimmed.starts_with("LUT_3D_SIZE") {
                    let parts: Vec<&str> = trimmed.split_whitespace().collect();
                    size = parts[1].parse().unwrap_or(0);
                } else if !trimmed.is_empty() && !trimmed.starts_with("#") && !trimmed.starts_with("TITLE") && !trimmed.starts_with("DOMAIN") {
                    let values: Vec<f32> = trimmed
                        .split_whitespace()
                        .filter_map(|s| s.parse().ok())
                        .collect();

                    if values.len() >= 3 {
                        data.push(values[0]);
                        data.push(values[1]);
                        data.push(values[2]);
                        data.push(1.0);
                    }
                }
            }

            if size == 0 || data.is_empty() {
                return Err(ENBError::PresetParseError("Invalid CUBE file".into()));
            }

            // Create 3D texture
            let desc = D3D11_TEXTURE3D_DESC {
                Width: size,
                Height: size,
                Depth: size,
                MipLevels: 1,
                Format: DXGI_FORMAT_R32G32B32A32_FLOAT,
                Usage: D3D11_USAGE_IMMUTABLE,
                BindFlags: D3D11_BIND_SHADER_RESOURCE,
                CPUAccessFlags: 0,
                MiscFlags: 0,
            };

            let subresource = D3D11_SUBRESOURCE_DATA {
                pSysMem: data.as_ptr() as *const _,
                SysMemPitch: size * 16,
                SysMemSlicePitch: size * size * 16,
            };

            let mut texture: *mut ID3D11Texture3D = std::ptr::null_mut();
            (*device).CreateTexture3D(&desc, &subresource, &mut texture);

            let name = std::path::Path::new(path)
                .file_stem()
                .unwrap()
                .to_str()
                .unwrap()
                .to_string();

            let lut = LUT3D {
                texture: ENBTexture::from_texture_3d(device, texture)?,
                size,
                name: name.clone(),
            };

            self.lut_library.insert(name.clone(), lut);

            Ok(name)
        }
    }

    pub fn apply(&mut self, name: &str) -> Result<(), ENBError> {
        if let Some(lut) = self.lut_library.get(name) {
            self.color_lut = Some(lut.clone());
            self.active_lut_name = name.to_string();
            Ok(())
        } else {
            Err(ENBError::PresetLoadFailed(name.to_string()))
        }
    }

    pub fn blend_to(&mut self, name: &str, duration: f32) {
        if let Some(lut) = self.lut_library.get(name) {
            self.blend_lut = Some(lut.clone());
            self.blend_factor = 0.0;
        }
    }

    pub fn update(&mut self, delta_time: f32) {
        if self.blend_lut.is_some() && self.blend_factor < 1.0 {
            self.blend_factor += delta_time;

            if self.blend_factor >= 1.0 {
                self.color_lut = self.blend_lut.take();
                self.blend_factor = 0.0;
            }
        }
    }

    pub fn get_texture(&self) -> Option<&ENBTexture> {
        self.color_lut.as_ref().map(|lut| &lut.texture)
    }
}

