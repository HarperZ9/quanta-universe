// ============================================================================
// ENB CONFIGURATION SYSTEM
// ============================================================================

/// Main ENB configuration structure
pub struct ENBConfig {
    // Version info
    enb_version: ENBVersion,
    target_game: TargetGame,
    features: ENBFeatures,

    // Quality settings
    quality_level: QualityLevel,
    performance_mode: bool,

    // Resolution
    render_width: u32,
    render_height: u32,
    internal_scale: f32,

    // Feature toggles
    enable_ssao: bool,
    enable_ssr: bool,
    enable_dof: bool,
    enable_bloom: bool,
    enable_volumetrics: bool,
    enable_subsurface: bool,
    enable_particle_lights: bool,
    enable_complex_particles: bool,

    // Weather integration
    weather_support: bool,
    weather_lerp_speed: f32,
    interior_detection: bool,

    // Debug
    debug_mode: bool,
    profile_gpu: bool,
}

impl ENBConfig {
    pub fn new(game: TargetGame) -> Self {
        Self {
            enb_version: ENBVersion::Unknown,
            target_game: game,
            features: ENBFeatures::BasicEffects,
            quality_level: QualityLevel::High,
            performance_mode: false,
            render_width: 1920,
            render_height: 1080,
            internal_scale: 1.0,
            enable_ssao: true,
            enable_ssr: true,
            enable_dof: true,
            enable_bloom: true,
            enable_volumetrics: true,
            enable_subsurface: true,
            enable_particle_lights: true,
            enable_complex_particles: false,
            weather_support: true,
            weather_lerp_speed: 1.0,
            interior_detection: true,
            debug_mode: false,
            profile_gpu: false,
        }
    }

    pub fn detect_version() -> ENBVersion {
        // Version detection logic
        shader {
            // Check ENB binary signature
            let signature = read_memory(ENB_BASE_ADDR, 16);

            match signature {
                SIG_V0_490 => ENBVersion::V0_490,
                SIG_V0_484 => ENBVersion::V0_484,
                SIG_V0_475 => ENBVersion::V0_475,
                SIG_V0_463 => ENBVersion::V0_463,
                SIG_V0_454 => ENBVersion::V0_454,
                SIG_V0_440 => ENBVersion::V0_440,
                SIG_V0_419 => ENBVersion::V0_419,
                SIG_V0_403 => ENBVersion::V0_403,
                SIG_V0_393 => ENBVersion::V0_393,
                SIG_V0_356 => ENBVersion::V0_356,
                SIG_V0_347 => ENBVersion::V0_347,
                SIG_V0_315 => ENBVersion::V0_315,
                SIG_V0_308 => ENBVersion::V0_308,
                SIG_V0_278 => ENBVersion::V0_278,
                SIG_V0_262 => ENBVersion::V0_262,
                _ => ENBVersion::Unknown,
            }
        }
    }

    pub fn get_features_for_version(version: ENBVersion) -> ENBFeatures {
        match version {
            ENBVersion::V0_262 | ENBVersion::V0_278 => {
                ENBFeatures::BasicEffects |
                ENBFeatures::SSAO |
                ENBFeatures::Bloom |
                ENBFeatures::ColorCorrection
            },
            ENBVersion::V0_308 | ENBVersion::V0_315 => {
                ENBFeatures::BasicEffects |
                ENBFeatures::SSAO |
                ENBFeatures::SSR |
                ENBFeatures::DOF |
                ENBFeatures::Bloom |
                ENBFeatures::ColorCorrection |
                ENBFeatures::Tonemapping
            },
            ENBVersion::V0_347..=ENBVersion::V0_392 => {
                ENBFeatures::BasicEffects |
                ENBFeatures::SSAO |
                ENBFeatures::SSR |
                ENBFeatures::DOF |
                ENBFeatures::Bloom |
                ENBFeatures::ColorCorrection |
                ENBFeatures::Tonemapping |
                ENBFeatures::Skylighting |
                ENBFeatures::WaterEffects
            },
            ENBVersion::V0_393..=ENBVersion::V0_439 => {
                ENBFeatures::BasicEffects |
                ENBFeatures::SSAO |
                ENBFeatures::SSR |
                ENBFeatures::DOF |
                ENBFeatures::Bloom |
                ENBFeatures::ColorCorrection |
                ENBFeatures::Tonemapping |
                ENBFeatures::Skylighting |
                ENBFeatures::ParticleLights |
                ENBFeatures::WaterEffects |
                ENBFeatures::WeatherSupport
            },
            ENBVersion::V0_440..=ENBVersion::V0_490 => {
                ENBFeatures::all()
            },
            ENBVersion::Unknown => ENBFeatures::BasicEffects,
        }
    }
}

/// Quality level presets
pub enum QualityLevel {
    Low,
    Medium,
    High,
    Ultra,
    Extreme,
    Custom,
}

