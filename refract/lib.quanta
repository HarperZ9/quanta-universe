/// ENB shader constants (mirroring enbseries SDK)
@constant_buffer(b0)
pub struct ENBShaderConstants {
    // Matrices
    world_matrix: Mat4,
    view_matrix: Mat4,
    projection_matrix: Mat4,
    world_view_matrix: Mat4,
    world_view_projection: Mat4,
    inverse_view_matrix: Mat4,
    inverse_projection: Mat4,
    inverse_view_projection: Mat4,

    // Previous frame
    prev_view_projection: Mat4,

    // Camera
    camera_position: Vec4,          // xyz = pos, w = near
    camera_direction: Vec4,         // xyz = forward, w = far

    // Screen
    screen_size: Vec4,              // xy = size, zw = 1/size

    // Time
    timer: Vec4,                    // x = time, y = sin(time), z = cos(time), w = delta

    // Weather
    weather_transition: f32,
    weather_current: u32,
    weather_target: u32,
    is_interior: f32,

    // Time of day
    game_time: f32,
    sun_direction: Vec4,            // xyz = direction, w = altitude
    sun_color: Vec4,                // xyz = color, w = intensity
    moon_direction: Vec4,
    moon_phase: f32,

    // ENB specific
    adaptation: f32,
    enb_day_night_factor: f32,
    enb_interior_factor: f32,
}

/// ENB effect shader base
pub trait ENBEffectShader {
    fn get_name(&self) -> &str;
    fn get_technique_count(&self) -> u32;
    fn get_pass_count(&self, technique: u32) -> u32;
    fn apply(&self, pass: u32, context: &RenderContext);
}

/// Render context for ENB shaders
pub struct RenderContext {
    device: *mut ID3D11Device,
    context: *mut ID3D11DeviceContext,
    constants: ENBShaderConstants,
    render_targets: RenderTargets,
    current_stage: RenderStage,

    // Samplers
    point_sampler: *mut ID3D11SamplerState,
    linear_sampler: *mut ID3D11SamplerState,
    aniso_sampler: *mut ID3D11SamplerState,
    shadow_sampler: *mut ID3D11SamplerState,
}

impl RenderContext {
    pub fn set_render_target(&self, slot: u32, target: *mut ID3D11RenderTargetView) {
        unsafe {
            (*self.context).OMSetRenderTargets(1, &target, std::ptr::null_mut());
        }
    }

    pub fn set_shader_resource(&self, slot: u32, srv: *mut ID3D11ShaderResourceView) {
        unsafe {
            (*self.context).PSSetShaderResources(slot, 1, &srv);
        }
    }

    pub fn draw_fullscreen(&self) {
        unsafe {
            (*self.context).Draw(3, 0);
        }
    }

    pub fn dispatch(&self, x: u32, y: u32, z: u32) {
        unsafe {
            (*self.context).Dispatch(x, y, z);
        }
    }
}

