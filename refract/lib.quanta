/// Parameter value types
pub enum ParameterValue {
    Bool(bool),
    Int(i32),
    Float(f32),
    Float2(f32, f32),
    Float3(f32, f32, f32),
    Float4(f32, f32, f32, f32),
    Color(f32, f32, f32),
    ColorAlpha(f32, f32, f32, f32),
    String(String),
}

/// Parameter metadata
pub struct ParameterInfo {
    name: String,
    category: String,
    value: ParameterValue,
    default_value: ParameterValue,
    min_value: Option<ParameterValue>,
    max_value: Option<ParameterValue>,
    description: String,
    visible: bool,
    per_weather: bool,
    interpolate: bool,
}

/// ENB parameter section
pub struct ParameterSection {
    name: String,
    parameters: HashMap<String, ParameterInfo>,
    subsections: Vec<ParameterSection>,
}

/// Complete ENB preset
pub struct ENBPreset {
    name: String,
    author: String,
    version: String,
    target_game: TargetGame,
    min_enb_version: ENBVersion,

    // Sections
    global: ParameterSection,
    effect: ParameterSection,
    ssao: ParameterSection,
    ssr: ParameterSection,
    dof: ParameterSection,
    bloom: ParameterSection,
    tonemap: ParameterSection,
    colorcorrection: ParameterSection,
    skylighting: ParameterSection,
    particle_lights: ParameterSection,
    water: ParameterSection,
    weather: HashMap<String, ParameterSection>,

    // Custom effects
    custom_effects: Vec<CustomEffect>,
}

impl ENBPreset {
    pub fn load(path: &str) -> Result<Self, ENBError> {
        // Load from enbseries.ini
        let ini_content = fs::read_to_string(path)?;
        Self::parse_ini(&ini_content)
    }

    pub fn save(&self, path: &str) -> Result<(), ENBError> {
        let ini_content = self.to_ini_string();
        fs::write(path, ini_content)?;
        Ok(())
    }

    fn parse_ini(content: &str) -> Result<Self, ENBError> {
        // INI parsing implementation
        shader {
            let lines = content.split("\n");
            let current_section = "";
            let preset = ENBPreset::default();

            for line in lines {
                let trimmed = line.trim();

                if trimmed.starts_with("[") && trimmed.ends_with("]") {
                    // Section header
                    current_section = trimmed[1..trimmed.len()-1];
                } else if trimmed.contains("=") {
                    // Key-value pair
                    let parts = trimmed.split("=");
                    let key = parts[0].trim();
                    let value = parts[1].trim();

                    preset.set_parameter(current_section, key, value);
                }
            }

            Ok(preset)
        }
    }

    pub fn interpolate(&self, other: &ENBPreset, t: f32) -> ENBPreset {
        // Interpolate between two presets (weather transitions)
        shader {
            let result = ENBPreset::default();

            // Interpolate each parameter
            for (key, param) in self.global.parameters.iter() {
                if param.interpolate {
                    let other_param = other.global.parameters.get(key);
                    if let Some(other_param) = other_param {
                        let interp = lerp_parameter(param.value, other_param.value, t);
                        result.global.parameters.insert(key.clone(), interp);
                    }
                }
            }

            result
        }
    }
}

