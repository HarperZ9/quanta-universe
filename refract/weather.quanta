// QUANTA-UNIVERSE: Refract - Weather System Integration
// Dynamic weather-based effect parameter adjustment
// Version: 1.0.0

module refract::weather;

use super::lib::*;
use super::effects::*;

// ============================================================================
// WEATHER CLASSIFICATION
// ============================================================================

/// Detailed weather classification
pub struct WeatherClassification {
    pub primary_type: WeatherType,
    pub intensity: f32,           // 0-1 weather intensity
    pub cloud_coverage: f32,      // 0-1 cloud cover
    pub precipitation: f32,       // 0-1 precipitation amount
    pub fog_density: f32,         // 0-1 fog amount
    pub wind_strength: f32,       // 0-1 wind intensity
    pub lightning_chance: f32,    // 0-1 lightning probability
    pub is_harsh: bool,           // Extreme weather
}

impl WeatherClassification {
    pub fn from_weather_id(game: TargetGame, weather_id: u32) -> Self {
        match game {
            TargetGame::SkyrimSE | TargetGame::SkyrimAE => {
                Self::classify_skyrim_weather(weather_id)
            },
            TargetGame::Fallout4 => {
                Self::classify_fallout4_weather(weather_id)
            },
            _ => Self::default()
        }
    }

    fn classify_skyrim_weather(weather_id: u32) -> Self {
        // Skyrim weather form IDs
        match weather_id {
            // Clear weathers
            0x10E1F2 | 0x10FE7E | 0x10FE82 => Self {
                primary_type: WeatherType::Clear,
                intensity: 0.0,
                cloud_coverage: 0.1,
                precipitation: 0.0,
                fog_density: 0.0,
                wind_strength: 0.2,
                lightning_chance: 0.0,
                is_harsh: false,
            },
            // Cloudy weathers
            0x10E1F3 | 0x10FE7F | 0x10FE83 => Self {
                primary_type: WeatherType::Cloudy,
                intensity: 0.3,
                cloud_coverage: 0.5,
                precipitation: 0.0,
                fog_density: 0.1,
                wind_strength: 0.3,
                lightning_chance: 0.0,
                is_harsh: false,
            },
            // Overcast
            0x10E1F4 | 0x10FE80 | 0x10FE84 => Self {
                primary_type: WeatherType::Overcast,
                intensity: 0.5,
                cloud_coverage: 0.9,
                precipitation: 0.0,
                fog_density: 0.2,
                wind_strength: 0.4,
                lightning_chance: 0.0,
                is_harsh: false,
            },
            // Fog
            0x10E1F5 | 0x10FE81 | 0x10FE85 => Self {
                primary_type: WeatherType::Fog,
                intensity: 0.7,
                cloud_coverage: 1.0,
                precipitation: 0.0,
                fog_density: 0.8,
                wind_strength: 0.1,
                lightning_chance: 0.0,
                is_harsh: false,
            },
            // Rain
            0x10E1F6 | 0x10FE7D => Self {
                primary_type: WeatherType::Rain,
                intensity: 0.6,
                cloud_coverage: 0.9,
                precipitation: 0.7,
                fog_density: 0.3,
                wind_strength: 0.5,
                lightning_chance: 0.1,
                is_harsh: false,
            },
            // Storm
            0x10E1F7 | 0x10FE86 => Self {
                primary_type: WeatherType::Storm,
                intensity: 1.0,
                cloud_coverage: 1.0,
                precipitation: 1.0,
                fog_density: 0.4,
                wind_strength: 0.9,
                lightning_chance: 0.5,
                is_harsh: true,
            },
            // Snow
            0x10E1F8 | 0x10FE87 => Self {
                primary_type: WeatherType::Snow,
                intensity: 0.6,
                cloud_coverage: 0.8,
                precipitation: 0.6,
                fog_density: 0.2,
                wind_strength: 0.3,
                lightning_chance: 0.0,
                is_harsh: false,
            },
            // Blizzard
            0x10E1F9 => Self {
                primary_type: WeatherType::Blizzard,
                intensity: 1.0,
                cloud_coverage: 1.0,
                precipitation: 1.0,
                fog_density: 0.7,
                wind_strength: 1.0,
                lightning_chance: 0.0,
                is_harsh: true,
            },
            _ => Self::default()
        }
    }

    fn classify_fallout4_weather(weather_id: u32) -> Self {
        // Fallout 4 weather form IDs
        match weather_id {
            // Clear
            0x0001ED8C => Self {
                primary_type: WeatherType::Clear,
                intensity: 0.0,
                cloud_coverage: 0.1,
                precipitation: 0.0,
                fog_density: 0.05,
                wind_strength: 0.2,
                lightning_chance: 0.0,
                is_harsh: false,
            },
            // Radstorm
            0x001C858B => Self {
                primary_type: WeatherType::Custom("Radstorm".to_string()),
                intensity: 1.0,
                cloud_coverage: 1.0,
                precipitation: 0.3,
                fog_density: 0.8,
                wind_strength: 0.8,
                lightning_chance: 0.8,
                is_harsh: true,
            },
            _ => Self::default()
        }
    }
}

impl Default for WeatherClassification {
    fn default() -> Self {
        Self {
            primary_type: WeatherType::Clear,
            intensity: 0.0,
            cloud_coverage: 0.2,
            precipitation: 0.0,
            fog_density: 0.0,
            wind_strength: 0.2,
            lightning_chance: 0.0,
            is_harsh: false,
        }
    }
}

// ============================================================================
// WEATHER PARAMETER PROFILES
// ============================================================================

/// Weather-specific effect parameters
pub struct WeatherEffectProfile {
    pub name: String,
    pub weather_types: Vec<WeatherType>,

    // SSAO adjustments
    pub ssao_intensity_mult: f32,
    pub ssao_radius_mult: f32,

    // SSR adjustments
    pub ssr_intensity_mult: f32,
    pub ssr_roughness_offset: f32,

    // Bloom adjustments
    pub bloom_intensity_mult: f32,
    pub bloom_threshold_mult: f32,

    // DOF adjustments
    pub dof_blur_mult: f32,
    pub dof_focus_shift: f32,

    // Tonemap adjustments
    pub exposure_mult: f32,
    pub contrast_mult: f32,
    pub saturation_mult: f32,

    // Color grading
    pub color_tint: Vec3,
    pub color_tint_intensity: f32,
    pub shadow_tint: Vec3,
    pub highlight_tint: Vec3,

    // Fog
    pub fog_color: Vec3,
    pub fog_density_mult: f32,
    pub fog_start_mult: f32,
    pub fog_end_mult: f32,

    // Volumetric adjustments
    pub volumetric_intensity_mult: f32,
    pub volumetric_scatter_mult: f32,
    pub god_ray_intensity_mult: f32,

    // Ambient adjustments
    pub ambient_intensity_mult: f32,
    pub ambient_tint: Vec3,

    // Sun/Sky
    pub sun_intensity_mult: f32,
    pub sun_color_mult: Vec3,
    pub sky_intensity_mult: f32,
}

impl WeatherEffectProfile {
    /// Create a profile for clear weather
    pub fn clear() -> Self {
        Self {
            name: "Clear".to_string(),
            weather_types: vec![WeatherType::Clear],

            ssao_intensity_mult: 1.0,
            ssao_radius_mult: 1.0,

            ssr_intensity_mult: 1.0,
            ssr_roughness_offset: 0.0,

            bloom_intensity_mult: 1.0,
            bloom_threshold_mult: 1.0,

            dof_blur_mult: 1.0,
            dof_focus_shift: 0.0,

            exposure_mult: 1.0,
            contrast_mult: 1.0,
            saturation_mult: 1.0,

            color_tint: Vec3::new(1.0, 1.0, 1.0),
            color_tint_intensity: 0.0,
            shadow_tint: Vec3::new(0.9, 0.9, 1.0),
            highlight_tint: Vec3::new(1.0, 0.98, 0.95),

            fog_color: Vec3::new(0.7, 0.8, 1.0),
            fog_density_mult: 1.0,
            fog_start_mult: 1.0,
            fog_end_mult: 1.0,

            volumetric_intensity_mult: 1.0,
            volumetric_scatter_mult: 1.0,
            god_ray_intensity_mult: 1.0,

            ambient_intensity_mult: 1.0,
            ambient_tint: Vec3::new(1.0, 1.0, 1.0),

            sun_intensity_mult: 1.0,
            sun_color_mult: Vec3::new(1.0, 1.0, 1.0),
            sky_intensity_mult: 1.0,
