            dof_blur_mult: 1.0,
            dof_focus_shift: 0.0,

            exposure_mult: 1.1,
            contrast_mult: 0.95,
            saturation_mult: 0.9,

            color_tint: Vec3::new(0.95, 0.95, 1.0),
            color_tint_intensity: 0.1,
            shadow_tint: Vec3::new(0.85, 0.88, 0.95),
            highlight_tint: Vec3::new(0.98, 0.98, 1.0),

            fog_color: Vec3::new(0.75, 0.78, 0.85),
