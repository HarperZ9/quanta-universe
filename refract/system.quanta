    pub active_particle_lights: u32,
    pub visible_particle_lights: u32,

    pub current_weather: String,
    pub weather_transition_progress: f32,

    pub memory_usage_mb: f32,
    pub texture_memory_mb: f32,
}

impl DebugInfo {
    pub fn new() -> Self {
        Self {
            fps: 60.0,
            frame_time: 0.016667,
            gpu_time: 0.0,
            cpu_time: 0.0,

            ssao_time: 0.0,
            ssr_time: 0.0,
            bloom_time: 0.0,
            dof_time: 0.0,
            tonemap_time: 0.0,

            active_particle_lights: 0,
            visible_particle_lights: 0,

            current_weather: "Unknown".to_string(),
            weather_transition_progress: 0.0,

            memory_usage_mb: 0.0,
            texture_memory_mb: 0.0,
        }
    }
}

// ============================================================================
// ERROR TYPES
// ============================================================================

#[derive(Debug)]
pub enum SystemError {
    InitializationFailed(String),
    HookInstallFailed(String),
    ResourceCreationFailed(String),
    ShaderCompilationFailed(String),
    InvalidState(String),
}

impl std::fmt::Display for SystemError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            SystemError::InitializationFailed(msg) => write!(f, "Initialization failed: {}", msg),
            SystemError::HookInstallFailed(msg) => write!(f, "Hook install failed: {}", msg),
            SystemError::ResourceCreationFailed(msg) => write!(f, "Resource creation failed: {}", msg),
            SystemError::ShaderCompilationFailed(msg) => write!(f, "Shader compilation failed: {}", msg),
            SystemError::InvalidState(msg) => write!(f, "Invalid state: {}", msg),
        }
    }
}

