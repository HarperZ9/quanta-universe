pub struct Device;

// ============================================================================
// GLOBAL SYSTEM INSTANCE
// ============================================================================

static mut ENB_SYSTEM: Option<ENBSystem> = None;

/// Get global ENB system instance
pub fn get_system() -> Option<&'static mut ENBSystem> {
    unsafe { ENB_SYSTEM.as_mut() }
}

/// Initialize global ENB system
pub fn initialize_system(quality: SystemQuality) -> &'static mut ENBSystem {
    unsafe {
        ENB_SYSTEM = Some(ENBSystem::new(quality));
        ENB_SYSTEM.as_mut().unwrap()
    }
}

/// Shutdown global ENB system
pub fn shutdown_system() {
    unsafe {
        if let Some(ref mut system) = ENB_SYSTEM {
            system.shutdown();
        }
        ENB_SYSTEM = None;
    }
}

// ============================================================================
// C-COMPATIBLE API
// ============================================================================

/// C-compatible API for integration with game engines
pub mod ffi {
    use super::*;

    #[no_mangle]
    pub extern "C" fn enb_initialize(quality: i32) -> bool {
        let q = match quality {
            0 => SystemQuality::Performance,
            1 => SystemQuality::Balanced,
            2 => SystemQuality::Quality,
            3 => SystemQuality::Ultra,
            _ => SystemQuality::Custom,
        };

        initialize_system(q);
        true
    }

    #[no_mangle]
    pub extern "C" fn enb_shutdown() {
        shutdown_system();
    }

    #[no_mangle]
    pub extern "C" fn enb_update(delta_time: f32) {
        if let Some(system) = get_system() {
            system.update(delta_time);
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_render() {
        if let Some(system) = get_system() {
            let device = Device;
            system.render(&device);
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_set_effect_enabled(effect: *const i8, enabled: bool) {
        if let Some(system) = get_system() {
            let effect_str = unsafe {
                std::ffi::CStr::from_ptr(effect).to_str().unwrap_or("")
            };
            system.set_effect_enabled(effect_str, enabled);
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_set_effect_param(effect: *const i8, param: *const i8, value: f32) {
        if let Some(system) = get_system() {
            let effect_str = unsafe {
                std::ffi::CStr::from_ptr(effect).to_str().unwrap_or("")
            };
            let param_str = unsafe {
                std::ffi::CStr::from_ptr(param).to_str().unwrap_or("")
            };
            system.set_effect_param(effect_str, param_str, value);
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_update_camera(
        view: *const f32,
        projection: *const f32,
        pos_x: f32, pos_y: f32, pos_z: f32,
        dir_x: f32, dir_y: f32, dir_z: f32
    ) {
        if let Some(system) = get_system() {
            // Would convert raw pointers to Mat4
            let view_mat = Mat4::IDENTITY;  // Placeholder
            let proj_mat = Mat4::IDENTITY;  // Placeholder
            system.update_camera(
                view_mat,
                proj_mat,
                Vec3::new(pos_x, pos_y, pos_z),
                Vec3::new(dir_x, dir_y, dir_z)
            );
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_update_environment(time_of_day: f32, weather_id: u32, is_interior: bool) {
        if let Some(system) = get_system() {
            system.update_environment(time_of_day, weather_id, is_interior);
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_get_fps() -> f32 {
        if let Some(system) = get_system() {
            system.debug_info.fps
        } else {
            0.0
        }
    }

    #[no_mangle]
    pub extern "C" fn enb_resize(width: u32, height: u32) {
        if let Some(system) = get_system() {
            let device = Device;
            system.on_resize(&device, width, height);
        }
    }
}

