const PI: f32 = std::f32::consts::PI;

const D3D11_USAGE_DYNAMIC: u32 = 2;
const D3D11_BIND_SHADER_RESOURCE: u32 = 8;
const D3D11_CPU_ACCESS_WRITE: u32 = 0x10000;
const D3D11_RESOURCE_MISC_BUFFER_STRUCTURED: u32 = 64;
const D3D11_SRV_DIMENSION_BUFFER: u32 = 1;
const DXGI_FORMAT_UNKNOWN: u32 = 0;
const DXGI_FORMAT_R16_FLOAT: u32 = 54;

#[repr(C)]
struct D3D11_BUFFER_DESC {
    ByteWidth: u32,
    Usage: u32,
    BindFlags: u32,
    CPUAccessFlags: u32,
    MiscFlags: u32,
    StructureByteStride: u32,
}

#[repr(C)]
struct D3D11_BUFFER_SRV {
    FirstElement: u32,
    NumElements: u32,
}

#[repr(C)]
struct D3D11_SHADER_RESOURCE_VIEW_DESC {
    Format: u32,
    ViewDimension: u32,
    Buffer: D3D11_BUFFER_SRV,
}

struct ID3D11Buffer;
struct ID3D11ComputeShader;

use std::collections::HashSet;

