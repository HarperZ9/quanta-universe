// CODEC SUPPORT - Encoding/Decoding Parameters
// ═══════════════════════════════════════════════════════════════════════════════

/// Video codec types
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum VideoCodec {
    H264,
    H265,   // HEVC
    VP9,
    AV1,
    ProRes,
    DNxHD,
    FFV1,   // Lossless
}

/// Encoding preset
#[derive(Debug, Clone, Copy)]
pub enum EncodingPreset {
    UltraFast,
    SuperFast,
    VeryFast,
    Faster,
    Fast,
    Medium,
    Slow,
    Slower,
    VerySlow,
    Placebo,
}

/// Rate control mode
#[derive(Debug, Clone, Copy)]
pub enum RateControl {
    CRF(u8),        // Constant Rate Factor (0-51)
    CBR(u32),       // Constant Bit Rate (kbps)
    VBR { target: u32, max: u32 },  // Variable Bit Rate
    CQP(u8),        // Constant Quantization Parameter
    ABR(u32),       // Average Bit Rate
}

/// Video encoding configuration
#[derive(Debug, Clone)]
pub struct VideoEncoderConfig {
    pub codec: VideoCodec,
    pub width: u32,
    pub height: u32,
    pub frame_rate: f64,
    pub preset: EncodingPreset,
    pub rate_control: RateControl,
    pub pixel_format: PixelFormat,
    pub color_space: ColorSpace,
    pub bit_depth: u8,
    pub gop_size: u32,
    pub b_frames: u8,
    pub profile: Option<String>,
    pub level: Option<String>,
    pub tune: Option<String>,
}

#[derive(Debug, Clone, Copy)]
pub enum PixelFormat {
    YUV420P,
    YUV422P,
    YUV444P,
    RGB24,
    RGBA32,
    YUV420P10LE,  // 10-bit
    YUV422P10LE,
}

#[derive(Debug, Clone, Copy)]
pub enum ColorSpace {
    BT709,
    BT2020,
    DCIP3,
    SRGB,
}

impl VideoEncoderConfig {
    pub fn h264_web(width: u32, height: u32, fps: f64) -> Self {
        Self {
            codec: VideoCodec::H264,
            width,
            height,
            frame_rate: fps,
            preset: EncodingPreset::Medium,
            rate_control: RateControl::CRF(23),
            pixel_format: PixelFormat::YUV420P,
            color_space: ColorSpace::BT709,
            bit_depth: 8,
            gop_size: 250,
            b_frames: 3,
            profile: Some("high".to_string()),
            level: Some("4.1".to_string()),
            tune: None,
        }
    }

    pub fn h265_hdr(width: u32, height: u32, fps: f64) -> Self {
        Self {
            codec: VideoCodec::H265,
            width,
            height,
            frame_rate: fps,
            preset: EncodingPreset::Slow,
            rate_control: RateControl::CRF(20),
            pixel_format: PixelFormat::YUV420P10LE,
            color_space: ColorSpace::BT2020,
            bit_depth: 10,
            gop_size: 120,
            b_frames: 4,
            profile: Some("main10".to_string()),
            level: Some("5.1".to_string()),
            tune: None,
        }
    }

    pub fn prores_proxy(width: u32, height: u32, fps: f64) -> Self {
        Self {
            codec: VideoCodec::ProRes,
            width,
            height,
            frame_rate: fps,
            preset: EncodingPreset::Medium,
            rate_control: RateControl::VBR { target: 45000, max: 60000 },
            pixel_format: PixelFormat::YUV422P10LE,
            color_space: ColorSpace::BT709,
            bit_depth: 10,
            gop_size: 1,
            b_frames: 0,
            profile: Some("proxy".to_string()),
            level: None,
            tune: None,
        }
    }

    pub fn av1_streaming(width: u32, height: u32, fps: f64) -> Self {
        Self {
            codec: VideoCodec::AV1,
            width,
            height,
            frame_rate: fps,
            preset: EncodingPreset::Medium,
            rate_control: RateControl::CRF(30),
            pixel_format: PixelFormat::YUV420P,
            color_space: ColorSpace::BT709,
            bit_depth: 8,
            gop_size: 240,
            b_frames: 2,
            profile: Some("main".to_string()),
            level: None,
            tune: None,
        }
    }

    pub fn to_ffmpeg_args(&self) -> Vec<String> {
        let mut args = Vec::new();

        let codec_str = match self.codec {
            VideoCodec::H264 => "libx264",
            VideoCodec::H265 => "libx265",
            VideoCodec::VP9 => "libvpx-vp9",
            VideoCodec::AV1 => "libaom-av1",
            VideoCodec::ProRes => "prores_ks",
            VideoCodec::DNxHD => "dnxhd",
            VideoCodec::FFV1 => "ffv1",
        };
        args.extend(["-c:v".to_string(), codec_str.to_string()]);

        let preset_str = match self.preset {
            EncodingPreset::UltraFast => "ultrafast",
            EncodingPreset::SuperFast => "superfast",
            EncodingPreset::VeryFast => "veryfast",
            EncodingPreset::Faster => "faster",
            EncodingPreset::Fast => "fast",
            EncodingPreset::Medium => "medium",
            EncodingPreset::Slow => "slow",
            EncodingPreset::Slower => "slower",
            EncodingPreset::VerySlow => "veryslow",
            EncodingPreset::Placebo => "placebo",
        };
        args.extend(["-preset".to_string(), preset_str.to_string()]);

        match self.rate_control {
            RateControl::CRF(crf) => {
                args.extend(["-crf".to_string(), crf.to_string()]);
            }
            RateControl::CBR(bitrate) => {
                args.extend(["-b:v".to_string(), format!("{}k", bitrate)]);
                args.extend(["-maxrate".to_string(), format!("{}k", bitrate)]);
                args.extend(["-bufsize".to_string(), format!("{}k", bitrate * 2)]);
            }
            RateControl::VBR { target, max } => {
                args.extend(["-b:v".to_string(), format!("{}k", target)]);
                args.extend(["-maxrate".to_string(), format!("{}k", max)]);
            }
            RateControl::CQP(qp) => {
                args.extend(["-qp".to_string(), qp.to_string()]);
            }
            RateControl::ABR(bitrate) => {
                args.extend(["-b:v".to_string(), format!("{}k", bitrate)]);
            }
        }

        args.extend(["-g".to_string(), self.gop_size.to_string()]);
        args.extend(["-bf".to_string(), self.b_frames.to_string()]);

        if let Some(ref profile) = self.profile {
            args.extend(["-profile:v".to_string(), profile.clone()]);
        }

        args
    }
}

/// Audio codec types
#[derive(Debug, Clone, Copy)]
pub enum AudioCodec {
    AAC,
    MP3,
    Opus,
    FLAC,
    ALAC,
    PCM,
    Vorbis,
    AC3,
    EAC3,
}

/// Audio encoder configuration
#[derive(Debug, Clone)]
pub struct AudioEncoderConfig {
    pub codec: AudioCodec,
    pub sample_rate: u32,
    pub channels: u8,
    pub bitrate: Option<u32>,
    pub quality: Option<f32>,
    pub bit_depth: u8,
}

impl AudioEncoderConfig {
