/// Audio filter types
#[derive(Clone, Copy, PartialEq)]
pub enum FilterType {
    LowPass,
    HighPass,
    BandPass,
    Notch,
    LowShelf,
    HighShelf,
    Peak,
}

/// Biquad filter for audio processing
#[derive(Clone)]
pub struct BiquadFilter {
    filter_type: FilterType,
    frequency: f64,
    q: f64,
    gain: f64,
    // Coefficients
    b0: f64, b1: f64, b2: f64,
    a1: f64, a2: f64,
    // State
    x1: f64, x2: f64,
    y1: f64, y2: f64,
}

impl BiquadFilter {
    pub fn new(filter_type: FilterType, sample_rate: u32, frequency: f64, q: f64, gain: f64) -> Self {
        let mut filter = BiquadFilter {
            filter_type,
            frequency,
            q,
            gain,
            b0: 1.0, b1: 0.0, b2: 0.0,
            a1: 0.0, a2: 0.0,
            x1: 0.0, x2: 0.0,
            y1: 0.0, y2: 0.0,
        };
        filter.calculate_coefficients(sample_rate as f64);
        filter
    }

    fn calculate_coefficients(&mut self, sample_rate: f64) {
        let omega = 2.0 * std::f64::consts::PI * self.frequency / sample_rate;
        let sin_omega = omega.sin();
        let cos_omega = omega.cos();
        let alpha = sin_omega / (2.0 * self.q);
        let a = 10.0_f64.powf(self.gain / 40.0);

        let (b0, b1, b2, a0, a1, a2) = match self.filter_type {
            FilterType::LowPass => {
                let b0 = (1.0 - cos_omega) / 2.0;
                let b1 = 1.0 - cos_omega;
                let b2 = (1.0 - cos_omega) / 2.0;
                let a0 = 1.0 + alpha;
                let a1 = -2.0 * cos_omega;
                let a2 = 1.0 - alpha;
                (b0, b1, b2, a0, a1, a2)
            }
            FilterType::HighPass => {
                let b0 = (1.0 + cos_omega) / 2.0;
                let b1 = -(1.0 + cos_omega);
                let b2 = (1.0 + cos_omega) / 2.0;
                let a0 = 1.0 + alpha;
                let a1 = -2.0 * cos_omega;
                let a2 = 1.0 - alpha;
                (b0, b1, b2, a0, a1, a2)
            }
            FilterType::BandPass => {
                let b0 = sin_omega / 2.0;
                let b1 = 0.0;
                let b2 = -sin_omega / 2.0;
                let a0 = 1.0 + alpha;
                let a1 = -2.0 * cos_omega;
                let a2 = 1.0 - alpha;
                (b0, b1, b2, a0, a1, a2)
            }
            FilterType::Notch => {
                let b0 = 1.0;
                let b1 = -2.0 * cos_omega;
                let b2 = 1.0;
                let a0 = 1.0 + alpha;
                let a1 = -2.0 * cos_omega;
                let a2 = 1.0 - alpha;
                (b0, b1, b2, a0, a1, a2)
            }
            FilterType::LowShelf => {
                let b0 = a * ((a + 1.0) - (a - 1.0) * cos_omega + 2.0 * a.sqrt() * alpha);
                let b1 = 2.0 * a * ((a - 1.0) - (a + 1.0) * cos_omega);
                let b2 = a * ((a + 1.0) - (a - 1.0) * cos_omega - 2.0 * a.sqrt() * alpha);
                let a0 = (a + 1.0) + (a - 1.0) * cos_omega + 2.0 * a.sqrt() * alpha;
                let a1 = -2.0 * ((a - 1.0) + (a + 1.0) * cos_omega);
                let a2 = (a + 1.0) + (a - 1.0) * cos_omega - 2.0 * a.sqrt() * alpha;
                (b0, b1, b2, a0, a1, a2)
            }
            FilterType::HighShelf => {
                let b0 = a * ((a + 1.0) + (a - 1.0) * cos_omega + 2.0 * a.sqrt() * alpha);
                let b1 = -2.0 * a * ((a - 1.0) + (a + 1.0) * cos_omega);
                let b2 = a * ((a + 1.0) + (a - 1.0) * cos_omega - 2.0 * a.sqrt() * alpha);
                let a0 = (a + 1.0) - (a - 1.0) * cos_omega + 2.0 * a.sqrt() * alpha;
                let a1 = 2.0 * ((a - 1.0) - (a + 1.0) * cos_omega);
                let a2 = (a + 1.0) - (a - 1.0) * cos_omega - 2.0 * a.sqrt() * alpha;
                (b0, b1, b2, a0, a1, a2)
            }
            FilterType::Peak => {
                let b0 = 1.0 + alpha * a;
                let b1 = -2.0 * cos_omega;
                let b2 = 1.0 - alpha * a;
                let a0 = 1.0 + alpha / a;
                let a1 = -2.0 * cos_omega;
                let a2 = 1.0 - alpha / a;
                (b0, b1, b2, a0, a1, a2)
            }
        };

        self.b0 = b0 / a0;
        self.b1 = b1 / a0;
        self.b2 = b2 / a0;
        self.a1 = a1 / a0;
        self.a2 = a2 / a0;
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let output = self.b0 * input + self.b1 * self.x1 + self.b2 * self.x2
                   - self.a1 * self.y1 - self.a2 * self.y2;

        self.x2 = self.x1;
        self.x1 = input;
        self.y2 = self.y1;
        self.y1 = output;

        output
    }

    pub fn reset(&mut self) {
        self.x1 = 0.0;
        self.x2 = 0.0;
        self.y1 = 0.0;
        self.y2 = 0.0;
    }
}

/// Parametric EQ with multiple bands
pub struct ParametricEQ {
    bands: Vec<BiquadFilter>,
    sample_rate: u32,
}

impl ParametricEQ {
    pub fn new(sample_rate: u32) -> Self {
        ParametricEQ {
            bands: Vec::new(),
            sample_rate,
        }
    }

    pub fn add_band(&mut self, filter_type: FilterType, frequency: f64, q: f64, gain: f64) {
        self.bands.push(BiquadFilter::new(filter_type, self.sample_rate, frequency, q, gain));
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let mut output = input;
        for band in &mut self.bands {
            output = band.process(output);
        }
        output
    }

    pub fn process_buffer(&mut self, buffer: &mut AudioBuffer) {
        for sample in &mut buffer.samples {
            sample.left = self.process(sample.left as f64) as f32;
            sample.right = self.process(sample.right as f64) as f32;
        }
    }
}

/// Compressor/Limiter
#[derive(Clone)]
pub struct Compressor {
    threshold: f64,    // dB
    ratio: f64,        // compression ratio
    attack: f64,       // seconds
    release: f64,      // seconds
    makeup_gain: f64,  // dB
    knee: f64,         // dB
    sample_rate: u32,
    envelope: f64,
}

impl Compressor {
    pub fn new(sample_rate: u32) -> Self {
        Compressor {
            threshold: -20.0,
            ratio: 4.0,
            attack: 0.01,
            release: 0.1,
            makeup_gain: 0.0,
            knee: 6.0,
            sample_rate,
            envelope: 0.0,
        }
    }

    pub fn set_threshold(&mut self, db: f64) { self.threshold = db; }
    pub fn set_ratio(&mut self, ratio: f64) { self.ratio = ratio.max(1.0); }
    pub fn set_attack(&mut self, seconds: f64) { self.attack = seconds.max(0.0001); }
    pub fn set_release(&mut self, seconds: f64) { self.release = seconds.max(0.001); }
    pub fn set_makeup_gain(&mut self, db: f64) { self.makeup_gain = db; }

    pub fn process(&mut self, input: f64) -> f64 {
        // Convert to dB
        let input_db = 20.0 * (input.abs() + 1e-10).log10();

        // Envelope follower
        let attack_coeff = (-2.2 / (self.attack * self.sample_rate as f64)).exp();
        let release_coeff = (-2.2 / (self.release * self.sample_rate as f64)).exp();

        if input_db > self.envelope {
            self.envelope = attack_coeff * self.envelope + (1.0 - attack_coeff) * input_db;
        } else {
            self.envelope = release_coeff * self.envelope + (1.0 - release_coeff) * input_db;
        }

        // Calculate gain reduction with soft knee
        let over_threshold = self.envelope - self.threshold;
        let gain_reduction = if over_threshold <= -self.knee / 2.0 {
            0.0
        } else if over_threshold > self.knee / 2.0 {
            over_threshold * (1.0 - 1.0 / self.ratio)
        } else {
            // Soft knee region
            let x = over_threshold + self.knee / 2.0;
            x * x / (2.0 * self.knee) * (1.0 - 1.0 / self.ratio)
        };

        // Apply gain reduction and makeup
        let gain_db = -gain_reduction + self.makeup_gain;
        let gain_linear = 10.0_f64.powf(gain_db / 20.0);

        input * gain_linear
    }

    pub fn process_buffer(&mut self, buffer: &mut AudioBuffer) {
        for sample in &mut buffer.samples {
            let mono = (sample.left + sample.right) as f64 / 2.0;
            let gain = self.process(mono) / mono.max(1e-10);
            sample.left *= gain as f32;
            sample.right *= gain as f32;
        }
    }
}

/// Reverb effect using Schroeder/Moorer algorithm
pub struct Reverb {
    comb_delays: Vec<DelayLine>,
    allpass_delays: Vec<DelayLine>,
    wet_mix: f64,
    decay: f64,
    pre_delay: DelayLine,
}

struct DelayLine {
    buffer: Vec<f64>,
    write_pos: usize,
    delay_samples: usize,
    feedback: f64,
}

impl DelayLine {
    fn new(max_delay_samples: usize) -> Self {
        DelayLine {
            buffer: vec![0.0; max_delay_samples],
            write_pos: 0,
            delay_samples: max_delay_samples,
            feedback: 0.5,
        }
    }

    fn set_delay(&mut self, samples: usize) {
        self.delay_samples = samples.min(self.buffer.len());
    }

    fn process_comb(&mut self, input: f64) -> f64 {
        let read_pos = (self.write_pos + self.buffer.len() - self.delay_samples) % self.buffer.len();
        let output = self.buffer[read_pos];
        self.buffer[self.write_pos] = input + output * self.feedback;
        self.write_pos = (self.write_pos + 1) % self.buffer.len();
        output
    }

    fn process_allpass(&mut self, input: f64) -> f64 {
        let read_pos = (self.write_pos + self.buffer.len() - self.delay_samples) % self.buffer.len();
        let buffered = self.buffer[read_pos];
        let output = -input + buffered;
        self.buffer[self.write_pos] = input + buffered * self.feedback;
        self.write_pos = (self.write_pos + 1) % self.buffer.len();
        output
    }
}

impl Reverb {
    pub fn new(sample_rate: u32) -> Self {
        // Schroeder reverb with 4 comb filters and 2 allpass filters
        let comb_delays = vec![
            { let mut d = DelayLine::new(sample_rate as usize); d.set_delay((0.0297 * sample_rate as f64) as usize); d.feedback = 0.805; d },
            { let mut d = DelayLine::new(sample_rate as usize); d.set_delay((0.0371 * sample_rate as f64) as usize); d.feedback = 0.827; d },
            { let mut d = DelayLine::new(sample_rate as usize); d.set_delay((0.0411 * sample_rate as f64) as usize); d.feedback = 0.783; d },
            { let mut d = DelayLine::new(sample_rate as usize); d.set_delay((0.0437 * sample_rate as f64) as usize); d.feedback = 0.764; d },
        ];

        let allpass_delays = vec![
            { let mut d = DelayLine::new(sample_rate as usize / 10); d.set_delay((0.09683 * sample_rate as f64 / 10.0) as usize); d.feedback = 0.7; d },
            { let mut d = DelayLine::new(sample_rate as usize / 30); d.set_delay((0.03292 * sample_rate as f64 / 10.0) as usize); d.feedback = 0.7; d },
        ];

        Reverb {
            comb_delays,
            allpass_delays,
            wet_mix: 0.3,
            decay: 0.5,
            pre_delay: DelayLine::new((0.05 * sample_rate as f64) as usize),
        }
    }

    pub fn set_wet_mix(&mut self, mix: f64) { self.wet_mix = mix.clamp(0.0, 1.0); }
    pub fn set_decay(&mut self, decay: f64) {
        self.decay = decay.clamp(0.0, 1.0);
        for comb in &mut self.comb_delays {
            comb.feedback = 0.7 + 0.2 * self.decay;
        }
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let pre_delayed = self.pre_delay.process_comb(input);

        // Sum comb filter outputs
        let mut comb_sum = 0.0;
        for comb in &mut self.comb_delays {
            comb_sum += comb.process_comb(pre_delayed);
        }
        comb_sum /= self.comb_delays.len() as f64;

        // Chain allpass filters
        let mut output = comb_sum;
        for allpass in &mut self.allpass_delays {
            output = allpass.process_allpass(output);
        }

        // Mix wet and dry
        input * (1.0 - self.wet_mix) + output * self.wet_mix
    }

    pub fn process_buffer(&mut self, buffer: &mut AudioBuffer) {
        for sample in &mut buffer.samples {
            let mono = (sample.left + sample.right) as f64 / 2.0;
            let wet = self.process(mono) as f32;
            sample.left = sample.left * (1.0 - self.wet_mix as f32) + wet * self.wet_mix as f32;
            sample.right = sample.right * (1.0 - self.wet_mix as f32) + wet * self.wet_mix as f32;
        }
    }
}

/// Audio normalizer
pub struct Normalizer {
    target_lufs: f64,
    peak_limit: f64,
}

impl Normalizer {
    pub fn new() -> Self {
        Normalizer {
            target_lufs: -14.0,  // Streaming standard
            peak_limit: -1.0,    // True peak limit
        }
    }

    /// Analyze loudness (simplified LUFS)
    pub fn analyze_loudness(&self, buffer: &AudioBuffer) -> f64 {
        let mut sum_squares = 0.0;
        for sample in &buffer.samples {
            let mono = (sample.left + sample.right) / 2.0;
            sum_squares += (mono * mono) as f64;
        }
        let rms = (sum_squares / buffer.samples.len() as f64).sqrt();
        20.0 * (rms + 1e-10).log10()
    }

    /// Normalize audio to target loudness
    pub fn normalize(&self, buffer: &mut AudioBuffer) {
        let current_lufs = self.analyze_loudness(buffer);
        let gain_db = self.target_lufs - current_lufs;
        let gain_linear = 10.0_f64.powf(gain_db / 20.0) as f32;

        // Find peak after gain
        let mut peak = 0.0f32;
        for sample in &buffer.samples {
            peak = peak.max(sample.left.abs() * gain_linear);
            peak = peak.max(sample.right.abs() * gain_linear);
        }

        // Limit if needed
        let peak_limit_linear = 10.0_f64.powf(self.peak_limit / 20.0) as f32;
        let final_gain = if peak > peak_limit_linear {
            gain_linear * (peak_limit_linear / peak)
        } else {
            gain_linear
        };

        // Apply gain
        for sample in &mut buffer.samples {
            sample.left *= final_gain;
            sample.right *= final_gain;
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// IMAGE PROCESSING
// ═══════════════════════════════════════════════════════════════════════════════

/// Image for processing
#[derive(Clone)]
pub struct Image {
    pub width: u32,
    pub height: u32,
    pub pixels: Vec<RGB>,
}

impl Image {
    pub fn new(width: u32, height: u32) -> Self {
        Image {
            width,
            height,
            pixels: vec![RGB::new(0.0, 0.0, 0.0); (width * height) as usize],
        }
    }

    pub fn from_frame(frame: &VideoFrame) -> Self {
        Image {
            width: frame.width,
            height: frame.height,
            pixels: frame.pixels.clone(),
        }
    }

    pub fn get_pixel(&self, x: u32, y: u32) -> RGB {
        if x < self.width && y < self.height {
            self.pixels[(y * self.width + x) as usize].clone()
        } else {
            RGB::new(0.0, 0.0, 0.0)
        }
    }

    pub fn set_pixel(&mut self, x: u32, y: u32, color: RGB) {
        if x < self.width && y < self.height {
            self.pixels[(y * self.width + x) as usize] = color;
        }
    }

    /// Resize image using bilinear interpolation
    pub fn resize(&self, new_width: u32, new_height: u32) -> Image {
        let mut result = Image::new(new_width, new_height);
        let x_ratio = self.width as f64 / new_width as f64;
        let y_ratio = self.height as f64 / new_height as f64;

        for y in 0..new_height {
            for x in 0..new_width {
                let src_x = x as f64 * x_ratio;
                let src_y = y as f64 * y_ratio;

                let x0 = src_x.floor() as u32;
                let y0 = src_y.floor() as u32;
                let x1 = (x0 + 1).min(self.width - 1);
                let y1 = (y0 + 1).min(self.height - 1);

                let x_lerp = src_x - x0 as f64;
                let y_lerp = src_y - y0 as f64;

                let c00 = self.get_pixel(x0, y0);
                let c10 = self.get_pixel(x1, y0);
                let c01 = self.get_pixel(x0, y1);
                let c11 = self.get_pixel(x1, y1);

                let color = RGB::new(
                    Self::bilerp(c00.r, c10.r, c01.r, c11.r, x_lerp as f32, y_lerp as f32),
                    Self::bilerp(c00.g, c10.g, c01.g, c11.g, x_lerp as f32, y_lerp as f32),
                    Self::bilerp(c00.b, c10.b, c01.b, c11.b, x_lerp as f32, y_lerp as f32),
                );

                result.set_pixel(x, y, color);
            }
        }

        result
    }

    fn bilerp(c00: f32, c10: f32, c01: f32, c11: f32, x: f32, y: f32) -> f32 {
        let top = c00 * (1.0 - x) + c10 * x;
        let bottom = c01 * (1.0 - x) + c11 * x;
        top * (1.0 - y) + bottom * y
    }

    /// Crop image
    pub fn crop(&self, x: u32, y: u32, width: u32, height: u32) -> Image {
        let mut result = Image::new(width, height);

        for dy in 0..height {
            for dx in 0..width {
                let src_x = x + dx;
                let src_y = y + dy;
                if src_x < self.width && src_y < self.height {
                    result.set_pixel(dx, dy, self.get_pixel(src_x, src_y));
                }
            }
        }

        result
    }

    /// Rotate image by 90, 180, or 270 degrees
    pub fn rotate(&self, degrees: i32) -> Image {
        match degrees % 360 {
            90 | -270 => {
                let mut result = Image::new(self.height, self.width);
                for y in 0..self.height {
                    for x in 0..self.width {
                        result.set_pixel(self.height - 1 - y, x, self.get_pixel(x, y));
                    }
                }
                result
            }
            180 | -180 => {
                let mut result = Image::new(self.width, self.height);
                for y in 0..self.height {
                    for x in 0..self.width {
                        result.set_pixel(self.width - 1 - x, self.height - 1 - y, self.get_pixel(x, y));
                    }
                }
                result
            }
            270 | -90 => {
                let mut result = Image::new(self.height, self.width);
                for y in 0..self.height {
                    for x in 0..self.width {
                        result.set_pixel(y, self.width - 1 - x, self.get_pixel(x, y));
                    }
                }
                result
            }
            _ => self.clone()
        }
    }

    /// Flip image horizontally or vertically
    pub fn flip(&self, horizontal: bool) -> Image {
        let mut result = Image::new(self.width, self.height);

        for y in 0..self.height {
            for x in 0..self.width {
                let (src_x, src_y) = if horizontal {
                    (self.width - 1 - x, y)
                } else {
                    (x, self.height - 1 - y)
                };
                result.set_pixel(x, y, self.get_pixel(src_x, src_y));
            }
        }

        result
    }

    /// Apply Gaussian blur
    pub fn blur(&self, radius: u32) -> Image {
        let kernel_size = radius * 2 + 1;
        let sigma = radius as f64 / 3.0;

        // Generate Gaussian kernel
        let mut kernel = Vec::new();
        let mut sum = 0.0;

        for i in 0..kernel_size {
            let x = i as f64 - radius as f64;
            let value = (-x * x / (2.0 * sigma * sigma)).exp();
            kernel.push(value);
            sum += value;
        }

        // Normalize kernel
        for k in &mut kernel {
            *k /= sum;
        }

        // Horizontal pass
        let mut temp = Image::new(self.width, self.height);
        for y in 0..self.height {
            for x in 0..self.width {
                let mut r = 0.0;
                let mut g = 0.0;
                let mut b = 0.0;

                for i in 0..kernel_size {
                    let sx = (x as i32 + i as i32 - radius as i32).max(0).min(self.width as i32 - 1) as u32;
                    let pixel = self.get_pixel(sx, y);
                    r += pixel.r as f64 * kernel[i as usize];
                    g += pixel.g as f64 * kernel[i as usize];
                    b += pixel.b as f64 * kernel[i as usize];
                }

                temp.set_pixel(x, y, RGB::new(r as f32, g as f32, b as f32));
            }
        }

        // Vertical pass
        let mut result = Image::new(self.width, self.height);
        for y in 0..self.height {
            for x in 0..self.width {
                let mut r = 0.0;
                let mut g = 0.0;
                let mut b = 0.0;

                for i in 0..kernel_size {
                    let sy = (y as i32 + i as i32 - radius as i32).max(0).min(self.height as i32 - 1) as u32;
                    let pixel = temp.get_pixel(x, sy);
                    r += pixel.r as f64 * kernel[i as usize];
                    g += pixel.g as f64 * kernel[i as usize];
                    b += pixel.b as f64 * kernel[i as usize];
                }

                result.set_pixel(x, y, RGB::new(r as f32, g as f32, b as f32));
            }
        }

        result
    }

    /// Apply sharpening
    pub fn sharpen(&self, amount: f32) -> Image {
        let mut result = Image::new(self.width, self.height);

        // Unsharp mask: original + amount * (original - blurred)
        let blurred = self.blur(1);

        for y in 0..self.height {
            for x in 0..self.width {
                let orig = self.get_pixel(x, y);
                let blur = blurred.get_pixel(x, y);

                result.set_pixel(x, y, RGB::new(
                    (orig.r + amount * (orig.r - blur.r)).clamp(0.0, 1.0),
                    (orig.g + amount * (orig.g - blur.g)).clamp(0.0, 1.0),
                    (orig.b + amount * (orig.b - blur.b)).clamp(0.0, 1.0),
                ));
            }
        }

        result
    }

    /// Adjust brightness and contrast
    pub fn adjust_brightness_contrast(&self, brightness: f32, contrast: f32) -> Image {
        let mut result = Image::new(self.width, self.height);

        for y in 0..self.height {
            for x in 0..self.width {
                let pixel = self.get_pixel(x, y);

                result.set_pixel(x, y, RGB::new(
                    ((pixel.r - 0.5) * contrast + 0.5 + brightness).clamp(0.0, 1.0),
                    ((pixel.g - 0.5) * contrast + 0.5 + brightness).clamp(0.0, 1.0),
                    ((pixel.b - 0.5) * contrast + 0.5 + brightness).clamp(0.0, 1.0),
                ));
            }
        }

        result
    }

    /// Adjust hue, saturation, lightness
    pub fn adjust_hsl(&self, hue_shift: f32, saturation: f32, lightness: f32) -> Image {
        let mut result = Image::new(self.width, self.height);

        for y in 0..self.height {
            for x in 0..self.width {
                let pixel = self.get_pixel(x, y);

                // Convert to HSL
                let (h, s, l) = Self::rgb_to_hsl(pixel.r, pixel.g, pixel.b);

                // Apply adjustments
                let new_h = (h + hue_shift) % 360.0;
                let new_s = (s * saturation).clamp(0.0, 1.0);
                let new_l = (l + lightness).clamp(0.0, 1.0);

                // Convert back to RGB
                let (r, g, b) = Self::hsl_to_rgb(new_h, new_s, new_l);
                result.set_pixel(x, y, RGB::new(r, g, b));
            }
        }

        result
    }

    fn rgb_to_hsl(r: f32, g: f32, b: f32) -> (f32, f32, f32) {
        let max = r.max(g).max(b);
        let min = r.min(g).min(b);
        let l = (max + min) / 2.0;

        if max == min {
            return (0.0, 0.0, l);
        }

        let d = max - min;
        let s = if l > 0.5 { d / (2.0 - max - min) } else { d / (max + min) };

        let h = if max == r {
            60.0 * (((g - b) / d) % 6.0)
        } else if max == g {
            60.0 * ((b - r) / d + 2.0)
        } else {
            60.0 * ((r - g) / d + 4.0)
        };

        (if h < 0.0 { h + 360.0 } else { h }, s, l)
    }

    fn hsl_to_rgb(h: f32, s: f32, l: f32) -> (f32, f32, f32) {
        if s == 0.0 {
            return (l, l, l);
        }

        let q = if l < 0.5 { l * (1.0 + s) } else { l + s - l * s };
        let p = 2.0 * l - q;

        let hue_to_rgb = |t: f32| -> f32 {
            let t = if t < 0.0 { t + 1.0 } else if t > 1.0 { t - 1.0 } else { t };

            if t < 1.0 / 6.0 {
                p + (q - p) * 6.0 * t
            } else if t < 1.0 / 2.0 {
                q
            } else if t < 2.0 / 3.0 {
                p + (q - p) * (2.0 / 3.0 - t) * 6.0
            } else {
                p
            }
        };

        let h = h / 360.0;
        (
            hue_to_rgb(h + 1.0 / 3.0),
            hue_to_rgb(h),
            hue_to_rgb(h - 1.0 / 3.0),
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI UPSCALING
// ═══════════════════════════════════════════════════════════════════════════════

/// AI upscaling algorithm
#[derive(Clone, Copy, PartialEq)]
pub enum UpscaleAlgorithm {
    Bilinear,
    Bicubic,
    Lanczos,
    ESRGAN,      // AI-based
    RealESRGAN,  // Real-world AI
}

/// AI upscaler
pub struct AIUpscaler {
    algorithm: UpscaleAlgorithm,
    denoise_strength: f32,
}

impl AIUpscaler {
    pub fn new(algorithm: UpscaleAlgorithm) -> Self {
        AIUpscaler {
            algorithm,
            denoise_strength: 0.5,
        }
    }

    pub fn set_denoise_strength(&mut self, strength: f32) {
        self.denoise_strength = strength.clamp(0.0, 1.0);
    }

    /// Upscale image by given factor
    pub fn upscale(&self, image: &Image, scale: u32) -> Image {
        let new_width = image.width * scale;
        let new_height = image.height * scale;

        match self.algorithm {
            UpscaleAlgorithm::Bilinear => image.resize(new_width, new_height),
            UpscaleAlgorithm::Bicubic => self.bicubic_upscale(image, new_width, new_height),
            UpscaleAlgorithm::Lanczos => self.lanczos_upscale(image, new_width, new_height, 3),
            UpscaleAlgorithm::ESRGAN | UpscaleAlgorithm::RealESRGAN => {
                // AI upscaling - use Lanczos as base, then enhance edges
                let base = self.lanczos_upscale(image, new_width, new_height, 3);
                self.enhance_edges(&base)
            }
        }
    }

    fn bicubic_upscale(&self, image: &Image, new_width: u32, new_height: u32) -> Image {
        let mut result = Image::new(new_width, new_height);
        let x_ratio = image.width as f64 / new_width as f64;
        let y_ratio = image.height as f64 / new_height as f64;

        for y in 0..new_height {
            for x in 0..new_width {
                let src_x = x as f64 * x_ratio;
                let src_y = y as f64 * y_ratio;

                let x0 = src_x.floor() as i32;
                let y0 = src_y.floor() as i32;
                let dx = src_x - x0 as f64;
                let dy = src_y - y0 as f64;

                let mut r = 0.0;
                let mut g = 0.0;
                let mut b = 0.0;

                for j in -1..=2 {
                    for i in -1..=2 {
                        let px = (x0 + i).max(0).min(image.width as i32 - 1) as u32;
                        let py = (y0 + j).max(0).min(image.height as i32 - 1) as u32;
                        let pixel = image.get_pixel(px, py);

                        let weight = Self::cubic_weight(i as f64 - dx) * Self::cubic_weight(j as f64 - dy);
                        r += pixel.r as f64 * weight;
                        g += pixel.g as f64 * weight;
                        b += pixel.b as f64 * weight;
                    }
                }

                result.set_pixel(x, y, RGB::new(
                    r.clamp(0.0, 1.0) as f32,
                    g.clamp(0.0, 1.0) as f32,
                    b.clamp(0.0, 1.0) as f32,
                ));
            }
        }

        result
    }

    fn cubic_weight(x: f64) -> f64 {
        let x = x.abs();
        if x < 1.0 {
            (1.5 * x - 2.5) * x * x + 1.0
        } else if x < 2.0 {
            ((-0.5 * x + 2.5) * x - 4.0) * x + 2.0
        } else {
            0.0
        }
    }

    fn lanczos_upscale(&self, image: &Image, new_width: u32, new_height: u32, a: i32) -> Image {
        let mut result = Image::new(new_width, new_height);
        let x_ratio = image.width as f64 / new_width as f64;
        let y_ratio = image.height as f64 / new_height as f64;

        for y in 0..new_height {
            for x in 0..new_width {
                let src_x = x as f64 * x_ratio;
                let src_y = y as f64 * y_ratio;

                let x0 = src_x.floor() as i32;
                let y0 = src_y.floor() as i32;

                let mut r = 0.0;
                let mut g = 0.0;
                let mut b = 0.0;
                let mut weight_sum = 0.0;

                for j in -a+1..=a {
                    for i in -a+1..=a {
                        let px = (x0 + i).max(0).min(image.width as i32 - 1) as u32;
                        let py = (y0 + j).max(0).min(image.height as i32 - 1) as u32;
                        let pixel = image.get_pixel(px, py);

                        let dx = src_x - (x0 + i) as f64;
                        let dy = src_y - (y0 + j) as f64;
                        let weight = Self::lanczos_kernel(dx, a) * Self::lanczos_kernel(dy, a);

                        r += pixel.r as f64 * weight;
                        g += pixel.g as f64 * weight;
                        b += pixel.b as f64 * weight;
                        weight_sum += weight;
                    }
                }

                if weight_sum > 0.0 {
                    r /= weight_sum;
                    g /= weight_sum;
                    b /= weight_sum;
                }

                result.set_pixel(x, y, RGB::new(
                    r.clamp(0.0, 1.0) as f32,
                    g.clamp(0.0, 1.0) as f32,
                    b.clamp(0.0, 1.0) as f32,
                ));
            }
        }

        result
    }

    fn lanczos_kernel(x: f64, a: i32) -> f64 {
        if x == 0.0 {
            1.0
        } else if x.abs() < a as f64 {
            let pi_x = std::f64::consts::PI * x;
            (a as f64 * pi_x.sin() * (pi_x / a as f64).sin()) / (pi_x * pi_x)
        } else {
            0.0
        }
    }

    fn enhance_edges(&self, image: &Image) -> Image {
        // Simple edge enhancement for AI upscaling simulation
        let sharpened = image.sharpen(0.5 * (1.0 - self.denoise_strength));

        // Add subtle detail enhancement
        let mut result = Image::new(image.width, image.height);

        for y in 1..image.height - 1 {
            for x in 1..image.width - 1 {
                let sharp = sharpened.get_pixel(x, y);
                let orig = image.get_pixel(x, y);

                // Detect edges using Sobel-like operator
                let left = image.get_pixel(x - 1, y);
                let right = image.get_pixel(x + 1, y);
                let up = image.get_pixel(x, y - 1);
                let down = image.get_pixel(x, y + 1);

                let edge_h = ((right.r - left.r).abs() + (right.g - left.g).abs() + (right.b - left.b).abs()) / 3.0;
                let edge_v = ((down.r - up.r).abs() + (down.g - up.g).abs() + (down.b - up.b).abs()) / 3.0;
                let edge_strength = (edge_h * edge_h + edge_v * edge_v).sqrt();

                // Blend based on edge strength
                let blend = (edge_strength * 2.0).min(1.0);
                result.set_pixel(x, y, RGB::new(
                    orig.r * (1.0 - blend) + sharp.r * blend,
                    orig.g * (1.0 - blend) + sharp.g * blend,
                    orig.b * (1.0 - blend) + sharp.b * blend,
                ));
            }
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO ENCODING
// ═══════════════════════════════════════════════════════════════════════════════

/// Video codec
#[derive(Clone, Copy, PartialEq)]
pub enum VideoCodec {
    H264,
    H265,
    VP9,
    AV1,
    ProRes,
}

/// Video encoding preset
#[derive(Clone, Copy, PartialEq)]
pub enum EncodingPreset {
    UltraFast,
    SuperFast,
    VeryFast,
    Faster,
    Fast,
    Medium,
    Slow,
    Slower,
    VerySlow,
    Placebo,
}

/// Video encoder configuration
#[derive(Clone)]
pub struct EncoderConfig {
    pub codec: VideoCodec,
    pub preset: EncodingPreset,
    pub bitrate: u32,      // kbps
    pub crf: u32,          // constant rate factor (0-51)
    pub width: u32,
    pub height: u32,
    pub frame_rate: f64,
    pub keyframe_interval: u32,
    pub b_frames: u32,
    pub profile: String,
    pub level: String,
}

impl Default for EncoderConfig {
    fn default() -> Self {
        EncoderConfig {
            codec: VideoCodec::H264,
            preset: EncodingPreset::Medium,
            bitrate: 5000,
            crf: 23,
            width: 1920,
            height: 1080,
            frame_rate: 30.0,
            keyframe_interval: 60,
            b_frames: 3,
            profile: "high".to_string(),
            level: "4.1".to_string(),
        }
    }
}

/// Video encoder
pub struct VideoEncoder {
    config: EncoderConfig,
    frame_count: u64,
    encoded_data: Vec<u8>,
}

impl VideoEncoder {
    pub fn new(config: EncoderConfig) -> Self {
        VideoEncoder {
            config,
            frame_count: 0,
            encoded_data: Vec::new(),
        }
    }

    /// Encode a single frame
    pub fn encode_frame(&mut self, frame: &VideoFrame) -> Result<Vec<u8>, String> {
        // Simplified encoding - in reality, this would use actual codec
        let is_keyframe = self.frame_count % self.config.keyframe_interval as u64 == 0;

        // Create encoded frame header
        let mut data = Vec::new();

        // NAL unit header (simplified)
        if is_keyframe {
            data.push(0x65); // IDR slice
        } else {
            data.push(0x61); // Non-IDR slice
        }

        // Frame number
        data.extend_from_slice(&(self.frame_count as u32).to_le_bytes());

        // Timestamp
        data.extend_from_slice(&(frame.timestamp.to_bits()).to_le_bytes());

        // Compressed pixel data (simplified - just store dimensions)
        data.extend_from_slice(&frame.width.to_le_bytes());
        data.extend_from_slice(&frame.height.to_le_bytes());

        // Add to total encoded data
        self.encoded_data.extend(&data);

        self.frame_count += 1;

        Ok(data)
    }

    /// Finish encoding and get final data
    pub fn finish(&mut self) -> Vec<u8> {
        // Add container headers, etc.
        let mut output = Vec::new();

        // Simple container header
        output.extend_from_slice(b"QMEDIA01");
        output.extend_from_slice(&(self.frame_count as u32).to_le_bytes());
        output.extend_from_slice(&self.config.width.to_le_bytes());
        output.extend_from_slice(&self.config.height.to_le_bytes());
        output.extend_from_slice(&self.config.frame_rate.to_bits().to_le_bytes());

        // Append encoded data
        output.extend(&self.encoded_data);

        output
    }

    /// Get encoding statistics
    pub fn stats(&self) -> EncodingStats {
        EncodingStats {
            frames_encoded: self.frame_count,
            total_bytes: self.encoded_data.len(),
            average_bitrate: if self.frame_count > 0 {
                (self.encoded_data.len() as f64 * 8.0 * self.config.frame_rate) / self.frame_count as f64 / 1000.0
            } else {
                0.0
            },
        }
    }
}

#[derive(Debug, Clone)]
pub struct EncodingStats {
    pub frames_encoded: u64,
    pub total_bytes: usize,
    pub average_bitrate: f64,  // kbps
}

/// Audio encoder configuration
#[derive(Clone)]
pub struct AudioEncoderConfig {
    pub codec: AudioCodec,
    pub bitrate: u32,
    pub sample_rate: u32,
    pub channels: u32,
}

#[derive(Clone, Copy, PartialEq)]
pub enum AudioCodec {
    AAC,
    MP3,
    OPUS,
    FLAC,
    WAV,
}

impl Default for AudioEncoderConfig {
    fn default() -> Self {
        AudioEncoderConfig {
            codec: AudioCodec::AAC,
            bitrate: 320,
            sample_rate: 48000,
            channels: 2,
        }
    }
}

/// Audio encoder
pub struct AudioEncoder {
    config: AudioEncoderConfig,
    samples_encoded: u64,
}

impl AudioEncoder {
    pub fn new(config: AudioEncoderConfig) -> Self {
        AudioEncoder {
            config,
            samples_encoded: 0,
        }
    }

    /// Encode audio buffer
    pub fn encode(&mut self, buffer: &AudioBuffer) -> Vec<u8> {
        // Simplified encoding
        let mut data = Vec::new();

        // Header
        data.push(match self.config.codec {
            AudioCodec::AAC => 0x01,
            AudioCodec::MP3 => 0x02,
            AudioCodec::OPUS => 0x03,
            AudioCodec::FLAC => 0x04,
            AudioCodec::WAV => 0x05,
        });

        data.extend_from_slice(&(buffer.samples.len() as u32).to_le_bytes());
        data.extend_from_slice(&self.config.sample_rate.to_le_bytes());
        data.extend_from_slice(&self.config.channels.to_le_bytes());

        self.samples_encoded += buffer.samples.len() as u64;

        data
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN QUANTA MEDIA SUITE
// ═══════════════════════════════════════════════════════════════════════════════

/// Complete Wavelength Suite
pub struct QuantaMediaSuite {
    pub cut: QuantaCut,
    pub grade: QuantaGrade,
    pub upscaler: AIUpscaler,
    pub audio_eq: ParametricEQ,
    pub compressor: Compressor,
    pub reverb: Reverb,
    pub normalizer: Normalizer,
}

impl QuantaMediaSuite {
    pub fn new(frame_rate: f64, resolution: (u32, u32), sample_rate: u32) -> Self {
        QuantaMediaSuite {
            cut: QuantaCut::new(frame_rate, resolution),
            grade: QuantaGrade::new(),
            upscaler: AIUpscaler::new(UpscaleAlgorithm::RealESRGAN),
            audio_eq: ParametricEQ::new(sample_rate),
            compressor: Compressor::new(sample_rate),
            reverb: Reverb::new(sample_rate),
            normalizer: Normalizer::new(),
        }
    }

    /// Process video frame through the entire pipeline
    pub fn process_frame(&mut self, frame: &mut VideoFrame, style: Option<&ColorGradeStyle>) {
        // Apply color grading
        if let Some(s) = style {
            self.grade.grade(frame, s);
        } else {
            self.grade.auto_grade(frame);
        }
    }

    /// Process audio buffer through effects chain
    pub fn process_audio(&mut self, buffer: &mut AudioBuffer) {
        self.audio_eq.process_buffer(buffer);
        self.compressor.process_buffer(buffer);
        self.reverb.process_buffer(buffer);
        self.normalizer.normalize(buffer);
    }

    /// Upscale video frame
    pub fn upscale_frame(&self, frame: &VideoFrame, scale: u32) -> VideoFrame {
        let image = Image::from_frame(frame);
        let upscaled = self.upscaler.upscale(&image, scale);

        VideoFrame {
            width: upscaled.width,
            height: upscaled.height,
            pixels: upscaled.pixels,
            timestamp: frame.timestamp,
            frame_number: frame.frame_number,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIO SPECTRUM ANALYSIS - FFT-based analysis
// ═══════════════════════════════════════════════════════════════════════════════

/// FFT implementation for spectrum analysis
pub struct FFT {
    size: usize,
    twiddle_real: Vec<f64>,
    twiddle_imag: Vec<f64>,
}

impl FFT {
    pub fn new(size: usize) -> Self {
        let mut twiddle_real = Vec::with_capacity(size / 2);
        let mut twiddle_imag = Vec::with_capacity(size / 2);

        for k in 0..size / 2 {
            let angle = -2.0 * std::f64::consts::PI * k as f64 / size as f64;
            twiddle_real.push(angle.cos());
            twiddle_imag.push(angle.sin());
        }

        FFT { size, twiddle_real, twiddle_imag }
    }

    /// Perform forward FFT (in-place Cooley-Tukey)
    pub fn forward(&self, real: &mut [f64], imag: &mut [f64]) {
        let n = self.size;

        // Bit reversal permutation
        let mut j = 0;
        for i in 0..n - 1 {
            if i < j {
                real.swap(i, j);
                imag.swap(i, j);
            }
            let mut k = n >> 1;
            while k <= j {
                j -= k;
                k >>= 1;
            }
            j += k;
        }

        // Cooley-Tukey iterative FFT
        let mut len = 2;
        while len <= n {
            let half = len >> 1;
            let step = n / len;

            for i in (0..n).step_by(len) {
                for j in 0..half {
                    let idx = j * step;
                    let t_real = self.twiddle_real[idx];
                    let t_imag = self.twiddle_imag[idx];

                    let a = i + j;
                    let b = a + half;

                    let temp_real = real[b] * t_real - imag[b] * t_imag;
                    let temp_imag = real[b] * t_imag + imag[b] * t_real;

                    real[b] = real[a] - temp_real;
                    imag[b] = imag[a] - temp_imag;
                    real[a] += temp_real;
                    imag[a] += temp_imag;
                }
            }
            len <<= 1;
        }
    }

    /// Perform inverse FFT
    pub fn inverse(&self, real: &mut [f64], imag: &mut [f64]) {
        // Conjugate
        for i in imag.iter_mut() {
            *i = -*i;
        }

        // Forward FFT
        self.forward(real, imag);

        // Conjugate and scale
        let scale = 1.0 / self.size as f64;
        for i in 0..self.size {
            real[i] *= scale;
            imag[i] = -imag[i] * scale;
        }
    }

    /// Get magnitude spectrum
    pub fn magnitude(&self, real: &[f64], imag: &[f64]) -> Vec<f64> {
        real.iter()
            .zip(imag)
            .map(|(&r, &i)| (r * r + i * i).sqrt())
            .collect()
    }

    /// Get phase spectrum
    pub fn phase(&self, real: &[f64], imag: &[f64]) -> Vec<f64> {
        real.iter()
            .zip(imag)
            .map(|(&r, &i)| i.atan2(r))
            .collect()
    }

    /// Convert to decibels
    pub fn to_db(&self, magnitude: &[f64]) -> Vec<f64> {
        magnitude.iter()
            .map(|&m| 20.0 * (m + 1e-10).log10())
            .collect()
    }
}

/// Spectrum analyzer for audio visualization
pub struct SpectrumAnalyzer {
    fft: FFT,
    window: Vec<f64>,
    window_type: WindowType,
    fft_size: usize,
    overlap: f64,
    sample_rate: u32,
    smoothing: f64,
    last_spectrum: Vec<f64>,
}

#[derive(Clone, Copy, PartialEq)]
pub enum WindowType {
    Rectangular,
    Hann,
    Hamming,
    Blackman,
    BlackmanHarris,
    FlatTop,
    Kaiser(f64),
}

impl SpectrumAnalyzer {
    pub fn new(fft_size: usize, sample_rate: u32, window_type: WindowType) -> Self {
        let fft = FFT::new(fft_size);
        let window = Self::generate_window(fft_size, window_type);

        SpectrumAnalyzer {
            fft,
            window,
            window_type,
            fft_size,
            overlap: 0.5,
            sample_rate,
            smoothing: 0.8,
            last_spectrum: vec![0.0; fft_size / 2],
        }
    }

    fn generate_window(size: usize, window_type: WindowType) -> Vec<f64> {
        let n = size as f64;
        (0..size)
            .map(|i| {
                let x = i as f64 / n;
                match window_type {
                    WindowType::Rectangular => 1.0,
                    WindowType::Hann => 0.5 * (1.0 - (2.0 * std::f64::consts::PI * x).cos()),
                    WindowType::Hamming => 0.54 - 0.46 * (2.0 * std::f64::consts::PI * x).cos(),
                    WindowType::Blackman => {
                        0.42 - 0.5 * (2.0 * std::f64::consts::PI * x).cos()
                            + 0.08 * (4.0 * std::f64::consts::PI * x).cos()
                    }
                    WindowType::BlackmanHarris => {
                        0.35875 - 0.48829 * (2.0 * std::f64::consts::PI * x).cos()
                            + 0.14128 * (4.0 * std::f64::consts::PI * x).cos()
                            - 0.01168 * (6.0 * std::f64::consts::PI * x).cos()
                    }
                    WindowType::FlatTop => {
                        0.21557895 - 0.41663158 * (2.0 * std::f64::consts::PI * x).cos()
                            + 0.277263158 * (4.0 * std::f64::consts::PI * x).cos()
                            - 0.083578947 * (6.0 * std::f64::consts::PI * x).cos()
                            + 0.006947368 * (8.0 * std::f64::consts::PI * x).cos()
                    }
                    WindowType::Kaiser(beta) => {
                        let m = (size - 1) as f64 / 2.0;
                        let k = i as f64 - m;
                        let arg = 1.0 - (k / m).powi(2);
                        Self::bessel_i0(beta * arg.sqrt().max(0.0)) / Self::bessel_i0(beta)
                    }
                }
            })
            .collect()
    }

    fn bessel_i0(x: f64) -> f64 {
        let mut sum = 1.0;
        let mut term = 1.0;
        for k in 1..50 {
            term *= (x / (2.0 * k as f64)).powi(2);
            sum += term;
            if term < 1e-12 { break; }
        }
        sum
    }

    /// Analyze spectrum of audio buffer
    pub fn analyze(&mut self, samples: &[f64]) -> Vec<f64> {
        if samples.len() < self.fft_size {
            return self.last_spectrum.clone();
        }

        let mut real: Vec<f64> = samples[..self.fft_size]
            .iter()
            .zip(&self.window)
            .map(|(&s, &w)| s * w)
            .collect();
        let mut imag = vec![0.0; self.fft_size];

        self.fft.forward(&mut real, &mut imag);

        let magnitude = self.fft.magnitude(&real, &imag);
        let half = self.fft_size / 2;

        // Apply smoothing
        for i in 0..half {
            self.last_spectrum[i] = self.smoothing * self.last_spectrum[i]
                + (1.0 - self.smoothing) * magnitude[i];
        }

        self.last_spectrum.clone()
    }

    /// Get frequency for bin index
    pub fn bin_to_frequency(&self, bin: usize) -> f64 {
        bin as f64 * self.sample_rate as f64 / self.fft_size as f64
    }

    /// Get bin index for frequency
    pub fn frequency_to_bin(&self, freq: f64) -> usize {
        (freq * self.fft_size as f64 / self.sample_rate as f64) as usize
    }

    /// Get bark scale spectrum (perceptual)
    pub fn to_bark(&self, spectrum: &[f64], num_bands: usize) -> Vec<f64> {
        let mut bands = vec![0.0; num_bands];
        let nyquist = self.sample_rate as f64 / 2.0;

        for i in 0..spectrum.len() {
            let freq = self.bin_to_frequency(i);
            if freq >= nyquist { break; }

            // Bark scale formula
            let bark = 13.0 * (freq / 1000.0 * 0.76).atan()
                + 3.5 * ((freq / 7500.0).powi(2)).atan();
            let band = ((bark / 24.0) * num_bands as f64) as usize;

            if band < num_bands {
                bands[band] += spectrum[i];
            }
        }

        bands
    }

    /// Get mel scale spectrum
    pub fn to_mel(&self, spectrum: &[f64], num_bands: usize) -> Vec<f64> {
        let mut bands = vec![0.0; num_bands];
        let nyquist = self.sample_rate as f64 / 2.0;
        let max_mel = 2595.0 * (1.0 + nyquist / 700.0).log10();

        for i in 0..spectrum.len() {
            let freq = self.bin_to_frequency(i);
            if freq >= nyquist { break; }

            let mel = 2595.0 * (1.0 + freq / 700.0).log10();
            let band = ((mel / max_mel) * num_bands as f64) as usize;

            if band < num_bands {
                bands[band] += spectrum[i];
            }
        }

        bands
    }
}

/// Short-Time Fourier Transform
pub struct STFT {
    fft: FFT,
    window: Vec<f64>,
    hop_size: usize,
    fft_size: usize,
}

impl STFT {
    pub fn new(fft_size: usize, hop_size: usize, window_type: WindowType) -> Self {
        let fft = FFT::new(fft_size);
        let window = SpectrumAnalyzer::generate_window(fft_size, window_type);

        STFT { fft, window, hop_size, fft_size }
    }

    /// Compute spectrogram
    pub fn spectrogram(&self, samples: &[f64]) -> Vec<Vec<f64>> {
        let mut result = Vec::new();
        let mut pos = 0;

        while pos + self.fft_size <= samples.len() {
            let mut real: Vec<f64> = samples[pos..pos + self.fft_size]
                .iter()
                .zip(&self.window)
                .map(|(&s, &w)| s * w)
                .collect();
            let mut imag = vec![0.0; self.fft_size];

            self.fft.forward(&mut real, &mut imag);

            let magnitude = self.fft.magnitude(&real, &imag);
            result.push(magnitude[..self.fft_size / 2].to_vec());

            pos += self.hop_size;
        }

        result
    }

    /// Reconstruct audio from spectrogram (Griffin-Lim)
    pub fn griffin_lim(&self, magnitude: &[Vec<f64>], iterations: usize) -> Vec<f64> {
        let num_frames = magnitude.len();
        let output_len = (num_frames - 1) * self.hop_size + self.fft_size;
        let mut result = vec![0.0; output_len];
        let mut phase: Vec<Vec<f64>> = magnitude.iter()
            .map(|m| vec![0.0; m.len()])
            .collect();

        for _ in 0..iterations {
            // Reconstruct with current phase
            let mut new_result = vec![0.0; output_len];
            let mut weight = vec![0.0; output_len];

            for (f, mag) in magnitude.iter().enumerate() {
                let mut real: Vec<f64> = mag.iter()
                    .zip(&phase[f])
                    .map(|(&m, &p)| m * p.cos())
                    .collect();
                let mut imag: Vec<f64> = mag.iter()
                    .zip(&phase[f])
                    .map(|(&m, &p)| m * p.sin())
                    .collect();

                // Mirror for full spectrum
                for i in 1..self.fft_size / 2 {
                    real.push(real[self.fft_size / 2 - i]);
                    imag.push(-imag[self.fft_size / 2 - i]);
                }

                self.fft.inverse(&mut real, &mut imag);

                let pos = f * self.hop_size;
                for i in 0..self.fft_size {
                    if pos + i < output_len {
                        new_result[pos + i] += real[i] * self.window[i];
                        weight[pos + i] += self.window[i] * self.window[i];
                    }
                }
            }

            // Normalize
            for i in 0..output_len {
                if weight[i] > 1e-10 {
                    result[i] = new_result[i] / weight[i];
                }
            }

            // Update phase from STFT of reconstructed signal
            let new_spec = self.spectrogram(&result);
            for (f, frame) in new_spec.iter().enumerate() {
                if f < phase.len() {
                    for i in 0..frame.len().min(phase[f].len()) {
                        // Keep original magnitude, use new phase
                        phase[f][i] = result[f * self.hop_size + i].atan2(0.0);
                    }
                }
            }
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIO SYNTHESIS - Oscillators, envelopes, and LFOs
// ═══════════════════════════════════════════════════════════════════════════════

/// Oscillator waveform types
#[derive(Clone, Copy, PartialEq)]
pub enum Waveform {
    Sine,
    Square,
    Sawtooth,
    Triangle,
    Pulse(f64),  // duty cycle
    Noise,
    SuperSaw(usize, f64),  // num_oscillators, detune
}

/// Basic oscillator
pub struct Oscillator {
    waveform: Waveform,
    frequency: f64,
    phase: f64,
    sample_rate: u32,
    phase_increment: f64,
    // For noise
    noise_state: u64,
    // For supersaw
    saw_phases: Vec<f64>,
}

impl Oscillator {
    pub fn new(waveform: Waveform, frequency: f64, sample_rate: u32) -> Self {
        let phase_increment = frequency / sample_rate as f64;
        let saw_phases = if let Waveform::SuperSaw(n, _) = waveform {
            vec![0.0; n]
        } else {
            Vec::new()
        };

        Oscillator {
            waveform,
            frequency,
            phase: 0.0,
            sample_rate,
            phase_increment,
            noise_state: 12345,
            saw_phases,
        }
    }

    pub fn set_frequency(&mut self, freq: f64) {
        self.frequency = freq;
        self.phase_increment = freq / self.sample_rate as f64;
    }

    pub fn next_sample(&mut self) -> f64 {
        let sample = match self.waveform {
            Waveform::Sine => (2.0 * std::f64::consts::PI * self.phase).sin(),
            Waveform::Square => if self.phase < 0.5 { 1.0 } else { -1.0 },
            Waveform::Sawtooth => 2.0 * self.phase - 1.0,
            Waveform::Triangle => {
                if self.phase < 0.25 {
                    4.0 * self.phase
                } else if self.phase < 0.75 {
                    2.0 - 4.0 * self.phase
                } else {
                    4.0 * self.phase - 4.0
                }
            }
            Waveform::Pulse(duty) => if self.phase < duty { 1.0 } else { -1.0 },
            Waveform::Noise => {
                self.noise_state = self.noise_state.wrapping_mul(1103515245).wrapping_add(12345);
                (self.noise_state as f64 / u64::MAX as f64) * 2.0 - 1.0
            }
            Waveform::SuperSaw(n, detune) => {
                let mut sum = 0.0;
                for i in 0..n {
                    let offset = (i as f64 / (n - 1) as f64 - 0.5) * detune;
                    let phase = (self.saw_phases[i] + self.phase_increment * (1.0 + offset)) % 1.0;
                    sum += 2.0 * phase - 1.0;
                    self.saw_phases[i] = phase;
                }
                sum / n as f64
            }
        };

        self.phase = (self.phase + self.phase_increment) % 1.0;
        sample
    }

    pub fn reset(&mut self) {
        self.phase = 0.0;
        for p in &mut self.saw_phases {
            *p = 0.0;
        }
    }
}

/// ADSR envelope
pub struct ADSREnvelope {
    attack: f64,   // seconds
    decay: f64,    // seconds
    sustain: f64,  // level 0-1
    release: f64,  // seconds
    sample_rate: u32,
    state: EnvelopeState,
    level: f64,
    note_on: bool,
    release_level: f64,
}

#[derive(Clone, Copy, PartialEq)]
enum EnvelopeState {
    Idle,
    Attack,
    Decay,
    Sustain,
    Release,
}

impl ADSREnvelope {
    pub fn new(attack: f64, decay: f64, sustain: f64, release: f64, sample_rate: u32) -> Self {
        ADSREnvelope {
            attack,
            decay,
            sustain: sustain.clamp(0.0, 1.0),
            release,
            sample_rate,
            state: EnvelopeState::Idle,
            level: 0.0,
            note_on: false,
            release_level: 0.0,
        }
    }

    pub fn note_on(&mut self) {
        self.note_on = true;
        self.state = EnvelopeState::Attack;
    }

    pub fn note_off(&mut self) {
        self.note_on = false;
        self.release_level = self.level;
        self.state = EnvelopeState::Release;
    }

    pub fn next_sample(&mut self) -> f64 {
        let attack_rate = 1.0 / (self.attack * self.sample_rate as f64).max(1.0);
        let decay_rate = 1.0 / (self.decay * self.sample_rate as f64).max(1.0);
        let release_rate = 1.0 / (self.release * self.sample_rate as f64).max(1.0);

        match self.state {
            EnvelopeState::Idle => {
                self.level = 0.0;
            }
            EnvelopeState::Attack => {
                self.level += attack_rate;
                if self.level >= 1.0 {
                    self.level = 1.0;
                    self.state = EnvelopeState::Decay;
                }
            }
            EnvelopeState::Decay => {
                self.level -= decay_rate;
                if self.level <= self.sustain {
                    self.level = self.sustain;
                    self.state = EnvelopeState::Sustain;
                }
            }
            EnvelopeState::Sustain => {
                self.level = self.sustain;
            }
            EnvelopeState::Release => {
                self.level = self.release_level * (1.0 - release_rate);
                self.release_level = self.level;
                if self.level < 0.001 {
                    self.level = 0.0;
                    self.state = EnvelopeState::Idle;
                }
            }
        }

        self.level
    }

    pub fn is_active(&self) -> bool {
        self.state != EnvelopeState::Idle
    }
}

/// Low Frequency Oscillator
pub struct LFO {
    oscillator: Oscillator,
    depth: f64,
    center: f64,
}

impl LFO {
    pub fn new(waveform: Waveform, frequency: f64, depth: f64, center: f64, sample_rate: u32) -> Self {
        LFO {
            oscillator: Oscillator::new(waveform, frequency, sample_rate),
            depth,
            center,
        }
    }

    pub fn set_frequency(&mut self, freq: f64) {
        self.oscillator.set_frequency(freq);
    }

    pub fn set_depth(&mut self, depth: f64) {
        self.depth = depth;
    }

    pub fn next_sample(&mut self) -> f64 {
        self.center + self.oscillator.next_sample() * self.depth
    }
}

/// Simple synthesizer voice
pub struct SynthVoice {
    oscillator: Oscillator,
    envelope: ADSREnvelope,
    filter: BiquadFilter,
    velocity: f64,
    note: u8,
}

impl SynthVoice {
    pub fn new(sample_rate: u32) -> Self {
        SynthVoice {
            oscillator: Oscillator::new(Waveform::Sawtooth, 440.0, sample_rate),
            envelope: ADSREnvelope::new(0.01, 0.1, 0.7, 0.3, sample_rate),
            filter: BiquadFilter::new(FilterType::LowPass, sample_rate, 2000.0, 0.707, 0.0),
            velocity: 1.0,
            note: 0,
        }
    }

    pub fn note_on(&mut self, note: u8, velocity: u8) {
        self.note = note;
        self.velocity = velocity as f64 / 127.0;
        let freq = 440.0 * 2.0_f64.powf((note as f64 - 69.0) / 12.0);
        self.oscillator.set_frequency(freq);
        self.envelope.note_on();
    }

    pub fn note_off(&mut self) {
        self.envelope.note_off();
    }

    pub fn process(&mut self) -> f64 {
        if !self.envelope.is_active() {
            return 0.0;
        }

        let osc = self.oscillator.next_sample();
        let env = self.envelope.next_sample();
        let filtered = self.filter.process(osc);

        filtered * env * self.velocity
    }

    pub fn is_active(&self) -> bool {
        self.envelope.is_active()
    }
}

/// Polyphonic synthesizer
pub struct PolySynth {
    voices: Vec<SynthVoice>,
    max_voices: usize,
    sample_rate: u32,
    master_volume: f64,
}

impl PolySynth {
    pub fn new(max_voices: usize, sample_rate: u32) -> Self {
        let voices = (0..max_voices)
            .map(|_| SynthVoice::new(sample_rate))
            .collect();

        PolySynth {
            voices,
            max_voices,
            sample_rate,
            master_volume: 0.5,
        }
    }

    pub fn note_on(&mut self, note: u8, velocity: u8) {
        // Find free voice or steal oldest
        let voice = self.voices.iter_mut()
            .find(|v| !v.is_active())
            .or_else(|| self.voices.first_mut());

        if let Some(v) = voice {
            v.note_on(note, velocity);
        }
    }

    pub fn note_off(&mut self, note: u8) {
        for voice in &mut self.voices {
            if voice.note == note {
                voice.note_off();
            }
        }
    }

    pub fn process(&mut self) -> f64 {
        let mut sum = 0.0;
        for voice in &mut self.voices {
            sum += voice.process();
        }
        sum * self.master_volume / self.max_voices as f64
    }

    pub fn render(&mut self, samples: usize) -> Vec<f64> {
        (0..samples).map(|_| self.process()).collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO STABILIZATION - Motion compensation
// ═══════════════════════════════════════════════════════════════════════════════

/// Motion vector
#[derive(Clone, Copy, Debug)]
pub struct MotionVector {
    pub dx: f64,
    pub dy: f64,
    pub confidence: f64,
}

impl MotionVector {
    pub fn zero() -> Self {
        MotionVector { dx: 0.0, dy: 0.0, confidence: 0.0 }
    }

    pub fn magnitude(&self) -> f64 {
        (self.dx * self.dx + self.dy * self.dy).sqrt()
    }
}

/// Block matching for motion estimation
pub struct MotionEstimator {
    block_size: u32,
    search_range: u32,
    threshold: f64,
}

impl MotionEstimator {
    pub fn new(block_size: u32, search_range: u32) -> Self {
        MotionEstimator {
            block_size,
            search_range,
            threshold: 0.1,
        }
    }

    /// Estimate global motion between frames
    pub fn estimate_global(&self, prev: &VideoFrame, curr: &VideoFrame) -> MotionVector {
        let mut vectors = Vec::new();

        // Sample motion at grid points
        let step = self.block_size * 2;
        let mut y = step;
        while y + self.block_size < prev.height - step {
            let mut x = step;
            while x + self.block_size < prev.width - step {
                let mv = self.estimate_block(prev, curr, x, y);
                if mv.confidence > self.threshold {
                    vectors.push(mv);
                }
                x += step;
            }
            y += step;
        }

        // Compute robust average (median-based)
        if vectors.is_empty() {
            return MotionVector::zero();
        }

        let mut dx_vals: Vec<f64> = vectors.iter().map(|v| v.dx).collect();
        let mut dy_vals: Vec<f64> = vectors.iter().map(|v| v.dy).collect();

        dx_vals.sort_by(|a, b| a.partial_cmp(b).unwrap());
        dy_vals.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let mid = vectors.len() / 2;
        MotionVector {
            dx: dx_vals[mid],
            dy: dy_vals[mid],
            confidence: 1.0,
        }
    }

    /// Estimate motion for a single block
    pub fn estimate_block(&self, prev: &VideoFrame, curr: &VideoFrame, bx: u32, by: u32) -> MotionVector {
        let mut best_dx = 0i32;
        let mut best_dy = 0i32;
        let mut best_sad = f64::MAX;

        let sr = self.search_range as i32;

        for dy in -sr..=sr {
            for dx in -sr..=sr {
                let sad = self.block_sad(prev, curr, bx, by, dx, dy);
                if sad < best_sad {
                    best_sad = sad;
                    best_dx = dx;
                    best_dy = dy;
                }
            }
        }

        // Compute confidence based on SAD
        let zero_sad = self.block_sad(prev, curr, bx, by, 0, 0);
        let confidence = if best_sad < zero_sad {
            1.0 - best_sad / zero_sad.max(1.0)
        } else {
            0.0
        };

        MotionVector {
            dx: best_dx as f64,
            dy: best_dy as f64,
            confidence,
        }
    }

    fn block_sad(&self, prev: &VideoFrame, curr: &VideoFrame, bx: u32, by: u32, dx: i32, dy: i32) -> f64 {
        let mut sad = 0.0;
        let bs = self.block_size;

        for y in 0..bs {
            for x in 0..bs {
                let px = bx + x;
                let py = by + y;

                let cx = (px as i32 + dx).max(0).min(curr.width as i32 - 1) as u32;
                let cy = (py as i32 + dy).max(0).min(curr.height as i32 - 1) as u32;

                let p = prev.get_pixel(px, py);
                let c = curr.get_pixel(cx, cy);

                sad += (p.r - c.r).abs() as f64;
                sad += (p.g - c.g).abs() as f64;
                sad += (p.b - c.b).abs() as f64;
            }
        }

        sad / (bs * bs * 3) as f64
    }

    /// Generate dense motion field
    pub fn dense_motion_field(&self, prev: &VideoFrame, curr: &VideoFrame) -> Vec<Vec<MotionVector>> {
        let blocks_x = (prev.width / self.block_size) as usize;
        let blocks_y = (prev.height / self.block_size) as usize;

        let mut field = vec![vec![MotionVector::zero(); blocks_x]; blocks_y];

        for by in 0..blocks_y {
            for bx in 0..blocks_x {
                let px = (bx as u32 * self.block_size).min(prev.width - self.block_size - 1);
                let py = (by as u32 * self.block_size).min(prev.height - self.block_size - 1);
                field[by][bx] = self.estimate_block(prev, curr, px, py);
            }
        }

        field
    }
}

/// Video stabilizer
pub struct VideoStabilizer {
    motion_estimator: MotionEstimator,
    smoothing: f64,
    crop_ratio: f64,
    accumulated_dx: f64,
    accumulated_dy: f64,
    smoothed_dx: f64,
    smoothed_dy: f64,
}

impl VideoStabilizer {
    pub fn new(smoothing: f64, crop_ratio: f64) -> Self {
        VideoStabilizer {
            motion_estimator: MotionEstimator::new(16, 32),
            smoothing: smoothing.clamp(0.5, 0.99),
            crop_ratio: crop_ratio.clamp(0.7, 0.95),
            accumulated_dx: 0.0,
            accumulated_dy: 0.0,
            smoothed_dx: 0.0,
            smoothed_dy: 0.0,
        }
    }

    /// Stabilize a frame relative to previous
    pub fn stabilize(&mut self, prev: &VideoFrame, curr: &VideoFrame) -> VideoFrame {
        // Estimate motion
        let motion = self.motion_estimator.estimate_global(prev, curr);

        // Accumulate motion
        self.accumulated_dx += motion.dx;
        self.accumulated_dy += motion.dy;

        // Smooth accumulated motion
        self.smoothed_dx = self.smoothing * self.smoothed_dx + (1.0 - self.smoothing) * self.accumulated_dx;
        self.smoothed_dy = self.smoothing * self.smoothed_dy + (1.0 - self.smoothing) * self.accumulated_dy;

        // Correction is difference between accumulated and smoothed
        let correct_dx = self.smoothed_dx - self.accumulated_dx;
        let correct_dy = self.smoothed_dy - self.accumulated_dy;

        // Apply correction with crop
        self.apply_transform(curr, correct_dx, correct_dy)
    }

    fn apply_transform(&self, frame: &VideoFrame, dx: f64, dy: f64) -> VideoFrame {
        let crop_w = (frame.width as f64 * self.crop_ratio) as u32;
        let crop_h = (frame.height as f64 * self.crop_ratio) as u32;
        let offset_x = (frame.width - crop_w) / 2;
        let offset_y = (frame.height - crop_h) / 2;

        let mut result = VideoFrame::new(crop_w, crop_h);
        result.timestamp = frame.timestamp;
        result.frame_number = frame.frame_number;

        for y in 0..crop_h {
            for x in 0..crop_w {
                let src_x = ((x + offset_x) as f64 - dx).round() as i32;
                let src_y = ((y + offset_y) as f64 - dy).round() as i32;

                if src_x >= 0 && src_x < frame.width as i32 &&
                   src_y >= 0 && src_y < frame.height as i32 {
                    result.set_pixel(x, y, frame.get_pixel(src_x as u32, src_y as u32));
                }
            }
        }

        result
    }

    pub fn reset(&mut self) {
        self.accumulated_dx = 0.0;
        self.accumulated_dy = 0.0;
        self.smoothed_dx = 0.0;
        self.smoothed_dy = 0.0;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOISE REDUCTION - Audio and video denoising
// ═══════════════════════════════════════════════════════════════════════════════

/// Spectral noise reduction for audio
pub struct SpectralNoiseReduction {
    fft: FFT,
    fft_size: usize,
    hop_size: usize,
    window: Vec<f64>,
    noise_profile: Vec<f64>,
    reduction_amount: f64,
    sample_rate: u32,
    input_buffer: Vec<f64>,
    output_buffer: Vec<f64>,
}

impl SpectralNoiseReduction {
    pub fn new(fft_size: usize, sample_rate: u32) -> Self {
        let fft = FFT::new(fft_size);
        let window = SpectrumAnalyzer::generate_window(fft_size, WindowType::Hann);
        let hop_size = fft_size / 4;

        SpectralNoiseReduction {
            fft,
            fft_size,
            hop_size,
            window,
            noise_profile: vec![0.0; fft_size / 2],
            reduction_amount: 1.0,
            sample_rate,
            input_buffer: Vec::new(),
            output_buffer: vec![0.0; fft_size],
        }
    }

    /// Learn noise profile from noise-only segment
    pub fn learn_noise_profile(&mut self, noise_samples: &[f64]) {
        if noise_samples.len() < self.fft_size {
            return;
        }

        let mut profile = vec![0.0; self.fft_size / 2];
        let mut count = 0;

        let mut pos = 0;
        while pos + self.fft_size <= noise_samples.len() {
            let mut real: Vec<f64> = noise_samples[pos..pos + self.fft_size]
                .iter()
                .zip(&self.window)
                .map(|(&s, &w)| s * w)
                .collect();
            let mut imag = vec![0.0; self.fft_size];

            self.fft.forward(&mut real, &mut imag);

            for i in 0..self.fft_size / 2 {
                profile[i] += (real[i] * real[i] + imag[i] * imag[i]).sqrt();
            }

            count += 1;
            pos += self.hop_size;
        }

        if count > 0 {
            for p in &mut profile {
                *p /= count as f64;
            }
        }

        self.noise_profile = profile;
    }

    /// Process audio with noise reduction
    pub fn process(&mut self, input: &[f64]) -> Vec<f64> {
        self.input_buffer.extend_from_slice(input);

        let mut output = Vec::new();

        while self.input_buffer.len() >= self.fft_size {
            // FFT
            let mut real: Vec<f64> = self.input_buffer[..self.fft_size]
                .iter()
                .zip(&self.window)
                .map(|(&s, &w)| s * w)
                .collect();
            let mut imag = vec![0.0; self.fft_size];

            self.fft.forward(&mut real, &mut imag);

            // Spectral subtraction
            for i in 0..self.fft_size / 2 {
                let mag = (real[i] * real[i] + imag[i] * imag[i]).sqrt();
                let phase = imag[i].atan2(real[i]);

                let noise = self.noise_profile[i] * self.reduction_amount;
                let new_mag = (mag - noise).max(mag * 0.01);  // Keep some residual

                real[i] = new_mag * phase.cos();
                imag[i] = new_mag * phase.sin();

                // Mirror
                if i > 0 && i < self.fft_size / 2 {
                    real[self.fft_size - i] = real[i];
                    imag[self.fft_size - i] = -imag[i];
                }
            }

            // IFFT
            self.fft.inverse(&mut real, &mut imag);

            // Overlap-add
            for i in 0..self.fft_size {
                self.output_buffer[i] += real[i] * self.window[i];
            }

            // Output hop_size samples
            output.extend_from_slice(&self.output_buffer[..self.hop_size]);

            // Shift buffers
            self.output_buffer.copy_within(self.hop_size.., 0);
            for i in (self.fft_size - self.hop_size)..self.fft_size {
                self.output_buffer[i] = 0.0;
            }

            self.input_buffer.drain(..self.hop_size);
        }

        output
    }

    pub fn set_reduction_amount(&mut self, amount: f64) {
        self.reduction_amount = amount.clamp(0.0, 2.0);
    }
}

/// Video denoising using temporal filtering
pub struct VideoDenoiser {
    strength: f64,
    temporal_radius: usize,
    frame_buffer: VecDeque<VideoFrame>,
}

impl VideoDenoiser {
    pub fn new(strength: f64, temporal_radius: usize) -> Self {
        VideoDenoiser {
            strength: strength.clamp(0.0, 1.0),
            temporal_radius,
            frame_buffer: VecDeque::with_capacity(temporal_radius * 2 + 1),
        }
    }

    /// Denoise frame using temporal averaging
    pub fn denoise(&mut self, frame: VideoFrame) -> Option<VideoFrame> {
        self.frame_buffer.push_back(frame);

        if self.frame_buffer.len() < self.temporal_radius * 2 + 1 {
            return None;  // Need more frames
        }

        let center_idx = self.temporal_radius;
        let center = &self.frame_buffer[center_idx];
        let mut result = VideoFrame::new(center.width, center.height);
        result.timestamp = center.timestamp;
        result.frame_number = center.frame_number;

        for y in 0..center.height {
            for x in 0..center.width {
                let center_pixel = center.get_pixel(x, y);
                let mut r_sum = 0.0;
                let mut g_sum = 0.0;
                let mut b_sum = 0.0;
                let mut weight_sum = 0.0;

                for (i, frame) in self.frame_buffer.iter().enumerate() {
                    let pixel = frame.get_pixel(x, y);

                    // Weight based on similarity to center
                    let diff = (center_pixel.r - pixel.r).abs()
                             + (center_pixel.g - pixel.g).abs()
                             + (center_pixel.b - pixel.b).abs();
                    let similarity = (-diff as f64 * 10.0 * self.strength).exp();

                    // Weight also based on temporal distance
                    let temporal = 1.0 - (i as f64 - center_idx as f64).abs() / (self.temporal_radius as f64 + 1.0);

                    let weight = similarity * temporal;

                    r_sum += pixel.r as f64 * weight;
                    g_sum += pixel.g as f64 * weight;
                    b_sum += pixel.b as f64 * weight;
                    weight_sum += weight;
                }

                if weight_sum > 0.0 {
                    result.set_pixel(x, y, RGB::new(
                        (r_sum / weight_sum) as f32,
                        (g_sum / weight_sum) as f32,
                        (b_sum / weight_sum) as f32,
                    ));
                } else {
                    result.set_pixel(x, y, center_pixel);
                }
            }
        }

        // Remove oldest frame
        self.frame_buffer.pop_front();

        Some(result)
    }

    /// Spatial denoising using bilateral filter
    pub fn bilateral_denoise(frame: &VideoFrame, spatial_sigma: f64, range_sigma: f64, radius: u32) -> VideoFrame {
        let mut result = VideoFrame::new(frame.width, frame.height);
        result.timestamp = frame.timestamp;
        result.frame_number = frame.frame_number;

        let spatial_coeff = -0.5 / (spatial_sigma * spatial_sigma);
        let range_coeff = -0.5 / (range_sigma * range_sigma);

        for y in 0..frame.height {
            for x in 0..frame.width {
                let center = frame.get_pixel(x, y);
                let mut r_sum = 0.0;
                let mut g_sum = 0.0;
                let mut b_sum = 0.0;
                let mut weight_sum = 0.0;

                for dy in -(radius as i32)..=(radius as i32) {
                    for dx in -(radius as i32)..=(radius as i32) {
                        let nx = (x as i32 + dx).max(0).min(frame.width as i32 - 1) as u32;
                        let ny = (y as i32 + dy).max(0).min(frame.height as i32 - 1) as u32;
                        let neighbor = frame.get_pixel(nx, ny);

                        let spatial_dist = (dx * dx + dy * dy) as f64;
                        let range_dist = ((center.r - neighbor.r).powi(2)
                                        + (center.g - neighbor.g).powi(2)
                                        + (center.b - neighbor.b).powi(2)) as f64;

                        let weight = (spatial_coeff * spatial_dist + range_coeff * range_dist).exp();

                        r_sum += neighbor.r as f64 * weight;
                        g_sum += neighbor.g as f64 * weight;
                        b_sum += neighbor.b as f64 * weight;
                        weight_sum += weight;
                    }
                }

                result.set_pixel(x, y, RGB::new(
                    (r_sum / weight_sum) as f32,
                    (g_sum / weight_sum) as f32,
                    (b_sum / weight_sum) as f32,
                ));
            }
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO TRANSITIONS - Transition effects between clips
// ═══════════════════════════════════════════════════════════════════════════════

/// Transition renderer
pub struct TransitionRenderer {
    duration: f64,
    frame_rate: f64,
}

impl TransitionRenderer {
    pub fn new(duration: f64, frame_rate: f64) -> Self {
        TransitionRenderer { duration, frame_rate }
    }

    /// Render transition frame
    pub fn render(&self, from: &VideoFrame, to: &VideoFrame, progress: f64, transition: TransitionType) -> VideoFrame {
        let t = progress.clamp(0.0, 1.0);
        let mut result = VideoFrame::new(from.width, from.height);
        result.timestamp = from.timestamp + progress * self.duration;
        result.frame_number = from.frame_number;

        match transition {
            TransitionType::Cut => {
                if t < 0.5 {
                    result.pixels = from.pixels.clone();
                } else {
                    result.pixels = to.pixels.clone();
                }
            }
            TransitionType::Dissolve => {
                self.dissolve(from, to, t, &mut result);
            }
            TransitionType::Wipe => {
                self.wipe(from, to, t, &mut result);
            }
            TransitionType::Slide => {
                self.slide(from, to, t, &mut result);
            }
            TransitionType::Zoom => {
                self.zoom(from, to, t, &mut result);
            }
            TransitionType::AIContentAware => {
                // AI transition - use dissolve with edge-aware blending
                self.content_aware_dissolve(from, to, t, &mut result);
            }
        }

        result
    }

    fn dissolve(&self, from: &VideoFrame, to: &VideoFrame, t: f64, result: &mut VideoFrame) {
        for y in 0..result.height {
            for x in 0..result.width {
                let a = from.get_pixel(x, y);
                let b = to.get_pixel(x, y);
                result.set_pixel(x, y, RGB::new(
                    a.r * (1.0 - t as f32) + b.r * t as f32,
                    a.g * (1.0 - t as f32) + b.g * t as f32,
                    a.b * (1.0 - t as f32) + b.b * t as f32,
                ));
            }
        }
    }

    fn wipe(&self, from: &VideoFrame, to: &VideoFrame, t: f64, result: &mut VideoFrame) {
        let wipe_x = (result.width as f64 * t) as u32;

        for y in 0..result.height {
            for x in 0..result.width {
                if x < wipe_x {
                    result.set_pixel(x, y, to.get_pixel(x, y));
                } else {
                    result.set_pixel(x, y, from.get_pixel(x, y));
                }
            }
        }
    }

    fn slide(&self, from: &VideoFrame, to: &VideoFrame, t: f64, result: &mut VideoFrame) {
        let offset = (result.width as f64 * t) as i32;

        for y in 0..result.height {
            for x in 0..result.width {
                let from_x = x as i32 + offset;
                let to_x = x as i32 + offset - result.width as i32;

                if from_x < result.width as i32 && from_x >= 0 {
                    result.set_pixel(x, y, from.get_pixel(from_x as u32, y));
                } else if to_x >= 0 && to_x < result.width as i32 {
                    result.set_pixel(x, y, to.get_pixel(to_x as u32, y));
                }
            }
        }
    }

    fn zoom(&self, from: &VideoFrame, to: &VideoFrame, t: f64, result: &mut VideoFrame) {
        let t = t as f32;
        let scale = 1.0 + t * 0.5;  // Zoom out from
        let cx = result.width as f32 / 2.0;
        let cy = result.height as f32 / 2.0;

        for y in 0..result.height {
            for x in 0..result.width {
                // Sample from zoomed-out 'from' frame
                let fx = cx + (x as f32 - cx) / scale;
                let fy = cy + (y as f32 - cy) / scale;

                let from_pixel = if fx >= 0.0 && fx < result.width as f32 && fy >= 0.0 && fy < result.height as f32 {
                    from.get_pixel(fx as u32, fy as u32)
                } else {
                    RGB::new(0.0, 0.0, 0.0)
                };

                let to_pixel = to.get_pixel(x, y);

                // Blend
                result.set_pixel(x, y, RGB::new(
                    from_pixel.r * (1.0 - t) + to_pixel.r * t,
                    from_pixel.g * (1.0 - t) + to_pixel.g * t,
                    from_pixel.b * (1.0 - t) + to_pixel.b * t,
                ));
            }
        }
    }

    fn content_aware_dissolve(&self, from: &VideoFrame, to: &VideoFrame, t: f64, result: &mut VideoFrame) {
        // Compute edge maps for both frames
        let from_edges = self.compute_edges(from);
        let to_edges = self.compute_edges(to);

        let t = t as f32;

        for y in 0..result.height {
            for x in 0..result.width {
                let a = from.get_pixel(x, y);
                let b = to.get_pixel(x, y);

                let idx = (y * result.width + x) as usize;
                let edge_a = from_edges.get(idx).copied().unwrap_or(0.0);
                let edge_b = to_edges.get(idx).copied().unwrap_or(0.0);

                // Adjust blend based on edges
                let edge_factor = (edge_a + edge_b) / 2.0;
                let adjusted_t = t + (t - 0.5) * edge_factor * 0.5;
                let blend = adjusted_t.clamp(0.0, 1.0);

                result.set_pixel(x, y, RGB::new(
                    a.r * (1.0 - blend) + b.r * blend,
                    a.g * (1.0 - blend) + b.g * blend,
                    a.b * (1.0 - blend) + b.b * blend,
                ));
            }
        }
    }

    fn compute_edges(&self, frame: &VideoFrame) -> Vec<f32> {
        let mut edges = vec![0.0f32; (frame.width * frame.height) as usize];

        for y in 1..frame.height - 1 {
            for x in 1..frame.width - 1 {
                let c = frame.get_pixel(x, y);
                let l = frame.get_pixel(x - 1, y);
                let r = frame.get_pixel(x + 1, y);
                let u = frame.get_pixel(x, y - 1);
                let d = frame.get_pixel(x, y + 1);

                let gx = ((r.r - l.r).abs() + (r.g - l.g).abs() + (r.b - l.b).abs()) / 3.0;
                let gy = ((d.r - u.r).abs() + (d.g - u.g).abs() + (d.b - u.b).abs()) / 3.0;

                edges[(y * frame.width + x) as usize] = (gx * gx + gy * gy).sqrt();
            }
        }

        edges
    }

    /// Render circle reveal transition
    pub fn circle_reveal(&self, from: &VideoFrame, to: &VideoFrame, t: f64, center: (f64, f64)) -> VideoFrame {
        let mut result = VideoFrame::new(from.width, from.height);
        let max_radius = ((from.width.pow(2) + from.height.pow(2)) as f64).sqrt();
        let radius = t * max_radius;

        let cx = center.0 * from.width as f64;
        let cy = center.1 * from.height as f64;

        for y in 0..result.height {
            for x in 0..result.width {
                let dist = ((x as f64 - cx).powi(2) + (y as f64 - cy).powi(2)).sqrt();

                if dist < radius {
                    result.set_pixel(x, y, to.get_pixel(x, y));
                } else {
                    result.set_pixel(x, y, from.get_pixel(x, y));
                }
            }
        }

        result
    }

    /// Render page curl transition
    pub fn page_curl(&self, from: &VideoFrame, to: &VideoFrame, t: f64) -> VideoFrame {
        let mut result = VideoFrame::new(from.width, from.height);
        let curl_x = (1.0 - t) * from.width as f64;
        let curl_radius = from.width as f64 * 0.1;

        for y in 0..result.height {
            for x in 0..result.width {
                let dist = x as f64 - curl_x;

                if dist < 0.0 {
                    // Show 'to' page
                    result.set_pixel(x, y, to.get_pixel(x, y));
                } else if dist < curl_radius {
                    // Curl region - show darkened from page
                    let from_px = from.get_pixel(x, y);
                    let shadow = 1.0 - (dist / curl_radius) as f32 * 0.5;
                    result.set_pixel(x, y, RGB::new(
                        from_px.r * shadow,
                        from_px.g * shadow,
                        from_px.b * shadow,
                    ));
                } else {
                    // Flat from page
                    result.set_pixel(x, y, from.get_pixel(x, y));
                }
            }
        }

        result
    }
}

/// Audio crossfade
pub struct AudioCrossfade {
    fade_type: FadeType,
}

#[derive(Clone, Copy, PartialEq)]
pub enum FadeType {
    Linear,
    Logarithmic,
    Exponential,
    SCurve,
    EqualPower,
}

impl AudioCrossfade {
    pub fn new(fade_type: FadeType) -> Self {
        AudioCrossfade { fade_type }
    }

    /// Crossfade between two audio buffers
    pub fn crossfade(&self, from: &AudioBuffer, to: &AudioBuffer, duration_samples: usize) -> AudioBuffer {
        let total_len = from.samples.len().max(to.samples.len());
        let mut result = AudioBuffer::new(from.sample_rate, from.channels);

        for i in 0..total_len {
            let from_sample = from.samples.get(i).cloned().unwrap_or(AudioSample { left: 0.0, right: 0.0 });
            let to_sample = to.samples.get(i).cloned().unwrap_or(AudioSample { left: 0.0, right: 0.0 });

            let crossfade_pos = if i < from.samples.len().saturating_sub(duration_samples) {
                0.0  // Full 'from'
            } else if i < from.samples.len() {
                (i - (from.samples.len() - duration_samples)) as f64 / duration_samples as f64
            } else {
                1.0  // Full 'to'
            };

            let (gain_a, gain_b) = self.compute_gains(crossfade_pos);

            result.samples.push(AudioSample {
                left: from_sample.left * gain_a as f32 + to_sample.left * gain_b as f32,
                right: from_sample.right * gain_a as f32 + to_sample.right * gain_b as f32,
            });
        }

        result
    }

    fn compute_gains(&self, t: f64) -> (f64, f64) {
        match self.fade_type {
            FadeType::Linear => (1.0 - t, t),
            FadeType::Logarithmic => {
                let gain_a = if t < 1.0 { (1.0 - t).ln().max(-10.0) / -10.0 } else { 0.0 };
                let gain_b = if t > 0.0 { t.ln().max(-10.0) / -10.0 + 1.0 } else { 0.0 };
                (gain_a.clamp(0.0, 1.0), gain_b.clamp(0.0, 1.0))
            }
            FadeType::Exponential => {
                let gain_a = (1.0 - t).powi(2);
                let gain_b = t.powi(2);
                (gain_a, gain_b)
            }
            FadeType::SCurve => {
                let s = t * t * (3.0 - 2.0 * t);
                (1.0 - s, s)
            }
            FadeType::EqualPower => {
                let angle = t * std::f64::consts::PI / 2.0;
                (angle.cos(), angle.sin())
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIO EFFECTS - Additional effects
// ═══════════════════════════════════════════════════════════════════════════════

/// Delay effect
pub struct Delay {
    buffer: Vec<f64>,
    write_pos: usize,
    delay_samples: usize,
    feedback: f64,
    wet_mix: f64,
    sample_rate: u32,
}

impl Delay {
    pub fn new(max_delay_ms: f64, sample_rate: u32) -> Self {
        let max_samples = (max_delay_ms * sample_rate as f64 / 1000.0) as usize;
        Delay {
            buffer: vec![0.0; max_samples],
            write_pos: 0,
            delay_samples: max_samples / 2,
            feedback: 0.5,
            wet_mix: 0.5,
            sample_rate,
        }
    }

    pub fn set_delay_ms(&mut self, ms: f64) {
        self.delay_samples = ((ms * self.sample_rate as f64 / 1000.0) as usize).min(self.buffer.len());
    }

    pub fn set_feedback(&mut self, feedback: f64) {
        self.feedback = feedback.clamp(0.0, 0.99);
    }

    pub fn set_wet_mix(&mut self, mix: f64) {
        self.wet_mix = mix.clamp(0.0, 1.0);
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let read_pos = (self.write_pos + self.buffer.len() - self.delay_samples) % self.buffer.len();
        let delayed = self.buffer[read_pos];

        self.buffer[self.write_pos] = input + delayed * self.feedback;
        self.write_pos = (self.write_pos + 1) % self.buffer.len();

        input * (1.0 - self.wet_mix) + delayed * self.wet_mix
    }
}

/// Chorus effect
pub struct Chorus {
    delays: Vec<DelayLine>,
    lfos: Vec<LFO>,
    wet_mix: f64,
    depth: f64,
}

impl Chorus {
    pub fn new(num_voices: usize, sample_rate: u32) -> Self {
        let base_delay = (0.02 * sample_rate as f64) as usize;

        let delays: Vec<DelayLine> = (0..num_voices)
            .map(|_| DelayLine::new(base_delay * 2))
            .collect();

        let lfos: Vec<LFO> = (0..num_voices)
            .map(|i| {
                let freq = 0.5 + i as f64 * 0.1;
                LFO::new(Waveform::Sine, freq, 0.002, 0.01, sample_rate)
            })
            .collect();

        Chorus {
            delays,
            lfos,
            wet_mix: 0.5,
            depth: 0.5,
        }
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let mut output = 0.0;

        for (delay, lfo) in self.delays.iter_mut().zip(self.lfos.iter_mut()) {
            let mod_delay = (lfo.next_sample() * self.depth * delay.buffer.len() as f64) as usize;
            delay.set_delay(mod_delay.max(1).min(delay.buffer.len() - 1));
            output += delay.process_comb(input);
        }

        input * (1.0 - self.wet_mix) + output / self.delays.len() as f64 * self.wet_mix
    }
}

/// Flanger effect
pub struct Flanger {
    delay: DelayLine,
    lfo: LFO,
    depth: f64,
    feedback: f64,
    wet_mix: f64,
}

impl Flanger {
    pub fn new(sample_rate: u32) -> Self {
        let max_delay = (0.01 * sample_rate as f64) as usize;
        let mut delay = DelayLine::new(max_delay);
        delay.feedback = 0.0;

        Flanger {
            delay,
            lfo: LFO::new(Waveform::Sine, 0.25, 0.5, 0.5, sample_rate),
            depth: 0.8,
            feedback: 0.7,
            wet_mix: 0.5,
        }
    }

    pub fn set_rate(&mut self, hz: f64) {
        self.lfo.set_frequency(hz);
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let mod_val = self.lfo.next_sample();
        let delay_samples = ((mod_val * self.depth) * self.delay.buffer.len() as f64) as usize;
        self.delay.set_delay(delay_samples.max(1).min(self.delay.buffer.len() - 1));
        self.delay.feedback = self.feedback;

        let delayed = self.delay.process_comb(input);
        input * (1.0 - self.wet_mix) + delayed * self.wet_mix
    }
}

/// Phaser effect
pub struct Phaser {
    allpass_filters: Vec<AllpassFilter>,
    lfo: LFO,
    depth: f64,
    feedback: f64,
    wet_mix: f64,
    last_output: f64,
}

struct AllpassFilter {
    delay: f64,
    last_input: f64,
    last_output: f64,
}

impl AllpassFilter {
    fn new() -> Self {
        AllpassFilter {
            delay: 0.5,
            last_input: 0.0,
            last_output: 0.0,
        }
    }

    fn process(&mut self, input: f64, coefficient: f64) -> f64 {
        let output = -input * coefficient + self.last_input + self.last_output * coefficient;
        self.last_input = input;
        self.last_output = output;
        output
    }
}

impl Phaser {
    pub fn new(num_stages: usize, sample_rate: u32) -> Self {
        Phaser {
            allpass_filters: (0..num_stages).map(|_| AllpassFilter::new()).collect(),
            lfo: LFO::new(Waveform::Sine, 0.5, 0.5, 0.5, sample_rate),
            depth: 0.8,
            feedback: 0.7,
            wet_mix: 0.5,
            last_output: 0.0,
        }
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let mod_val = self.lfo.next_sample();
        let coefficient = 0.1 + mod_val * self.depth * 0.8;

        let mut signal = input + self.last_output * self.feedback;

        for filter in &mut self.allpass_filters {
            signal = filter.process(signal, coefficient);
        }

        self.last_output = signal;
        input * (1.0 - self.wet_mix) + signal * self.wet_mix
    }
}

/// Distortion effect
pub struct Distortion {
    drive: f64,
    tone: f64,
    mix: f64,
    dist_type: DistortionType,
    tone_filter: BiquadFilter,
}

#[derive(Clone, Copy, PartialEq)]
pub enum DistortionType {
    SoftClip,
    HardClip,
    Tube,
    Fuzz,
    Bitcrush(u32),
}

impl Distortion {
    pub fn new(dist_type: DistortionType, sample_rate: u32) -> Self {
        Distortion {
            drive: 1.0,
            tone: 0.5,
            mix: 1.0,
            dist_type,
            tone_filter: BiquadFilter::new(FilterType::LowPass, sample_rate, 5000.0, 0.707, 0.0),
        }
    }

    pub fn set_drive(&mut self, drive: f64) {
        self.drive = drive.clamp(0.1, 100.0);
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let driven = input * self.drive;

        let distorted = match self.dist_type {
            DistortionType::SoftClip => {
                // Soft clipping using tanh
                driven.tanh()
            }
            DistortionType::HardClip => {
                // Hard clipping
                driven.clamp(-1.0, 1.0)
            }
            DistortionType::Tube => {
                // Tube-like asymmetric distortion
                if driven >= 0.0 {
                    1.0 - (-driven).exp()
                } else {
                    -1.0 + driven.exp()
                }
            }
            DistortionType::Fuzz => {
                // Fuzz with more harmonics
                let sign = driven.signum();
                sign * (1.0 - (-driven.abs() * 3.0).exp())
            }
            DistortionType::Bitcrush(bits) => {
                // Bit crushing
                let levels = (1 << bits) as f64;
                (driven * levels).round() / levels
            }
        };

        // Apply tone control
        let filtered = self.tone_filter.process(distorted);
        let toned = distorted * (1.0 - self.tone) + filtered * self.tone;

        // Mix
        input * (1.0 - self.mix) + toned * self.mix
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI UPSCALING - Neural Super-Resolution
// ═══════════════════════════════════════════════════════════════════════════════

/// Upscaling model types
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum UpscaleModel {
    ESRGAN,           // Enhanced Super-Resolution GAN
    RealESRGAN,       // Real-world Enhanced SRGAN
    BSRGAN,           // Blind Super-Resolution GAN
    SwinIR,           // Swin Transformer for Image Restoration
    HAT,              // Hybrid Attention Transformer
    Anime4K,          // Anime-optimized upscaler
    Waifu2x,          // Anime/artwork upscaler
    Lanczos,          // Traditional high-quality resampling
}

/// Upscaling configuration
#[derive(Debug, Clone)]
pub struct UpscaleConfig {
    pub model: UpscaleModel,
    pub scale_factor: u32,
    pub tile_size: u32,
    pub tile_overlap: u32,
    pub denoise_strength: f64,
    pub sharpen_amount: f64,
    pub gpu_id: i32,
    pub half_precision: bool,
}

impl UpscaleConfig {
    pub fn new(model: UpscaleModel, scale: u32) -> Self {
        Self {
            model,
            scale_factor: scale.clamp(1, 8),
            tile_size: 512,
            tile_overlap: 32,
            denoise_strength: 0.0,
            sharpen_amount: 0.0,
            gpu_id: 0,
            half_precision: true,
        }
    }

    pub fn with_denoise(mut self, strength: f64) -> Self {
        self.denoise_strength = strength.clamp(0.0, 1.0);
        self
    }

    pub fn with_sharpen(mut self, amount: f64) -> Self {
        self.sharpen_amount = amount.clamp(0.0, 2.0);
        self
    }
}

/// Neural network layer for upscaling
#[derive(Debug, Clone)]
struct ConvBlock {
    weights: Vec<Vec<Vec<f64>>>,
    biases: Vec<f64>,
    in_channels: usize,
    out_channels: usize,
    kernel_size: usize,
    activation: Activation,
}

#[derive(Debug, Clone, Copy)]
enum Activation {
    ReLU,
    LeakyReLU(f64),
    PReLU,
    SiLU,
    GELU,
}

impl ConvBlock {
    fn new(in_ch: usize, out_ch: usize, kernel: usize, act: Activation) -> Self {
        let weights = vec![vec![vec![0.0; kernel * kernel]; in_ch]; out_ch];
        let biases = vec![0.0; out_ch];
        Self {
            weights,
            biases,
            in_channels: in_ch,
            out_channels: out_ch,
            kernel_size: kernel,
            activation: act,
        }
    }

    fn forward(&self, input: &[Vec<Vec<f64>>]) -> Vec<Vec<Vec<f64>>> {
        let h = input[0].len();
        let w = input[0][0].len();
        let pad = self.kernel_size / 2;
        let mut output = vec![vec![vec![0.0; w]; h]; self.out_channels];

        for oc in 0..self.out_channels {
            for y in 0..h {
                for x in 0..w {
                    let mut sum = self.biases[oc];
                    for ic in 0..self.in_channels {
                        for ky in 0..self.kernel_size {
                            for kx in 0..self.kernel_size {
                                let iy = (y + ky).saturating_sub(pad).min(h - 1);
                                let ix = (x + kx).saturating_sub(pad).min(w - 1);
                                let wi = ky * self.kernel_size + kx;
                                sum += input[ic][iy][ix] * self.weights[oc][ic][wi];
                            }
                        }
                    }
                    output[oc][y][x] = self.activate(sum);
                }
            }
        }
        output
    }

    fn activate(&self, x: f64) -> f64 {
        match self.activation {
            Activation::ReLU => x.max(0.0),
            Activation::LeakyReLU(alpha) => if x > 0.0 { x } else { alpha * x },
            Activation::PReLU => if x > 0.0 { x } else { 0.25 * x },
            Activation::SiLU => x / (1.0 + (-x).exp()),
            Activation::GELU => 0.5 * x * (1.0 + (0.7978845608 * (x + 0.044715 * x.powi(3))).tanh()),
        }
    }
}

/// Residual Dense Block for ESRGAN
#[derive(Debug, Clone)]
struct ResidualDenseBlock {
    conv_layers: Vec<ConvBlock>,
    growth_channels: usize,
}

impl ResidualDenseBlock {
    fn new(channels: usize, growth: usize) -> Self {
        let mut layers = Vec::new();
        for i in 0..5 {
            let in_ch = channels + i * growth;
            let out_ch = if i < 4 { growth } else { channels };
            layers.push(ConvBlock::new(in_ch, out_ch, 3, Activation::LeakyReLU(0.2)));
        }
        Self { conv_layers: layers, growth_channels: growth }
    }

    fn forward(&self, input: &[Vec<Vec<f64>>]) -> Vec<Vec<Vec<f64>>> {
        let mut features = vec![input.to_vec()];
        for (i, conv) in self.conv_layers.iter().enumerate() {
            let concat: Vec<Vec<Vec<f64>>> = features.iter().flat_map(|f| f.clone()).collect();
            let out = conv.forward(&concat);
            if i < 4 {
                features.push(out);
            } else {
                return Self::add_tensors(input, &out, 0.2);
            }
        }
        input.to_vec()
    }

    fn add_tensors(a: &[Vec<Vec<f64>>], b: &[Vec<Vec<f64>>], scale: f64) -> Vec<Vec<Vec<f64>>> {
        a.iter().zip(b.iter()).map(|(ac, bc)| {
            ac.iter().zip(bc.iter()).map(|(ar, br)| {
                ar.iter().zip(br.iter()).map(|(av, bv)| av + bv * scale).collect()
            }).collect()
        }).collect()
    }
}

/// Pixel shuffle upsampling
#[derive(Debug)]
struct PixelShuffle {
    scale: usize,
}

impl PixelShuffle {
    fn new(scale: usize) -> Self {
        Self { scale }
    }

    fn forward(&self, input: &[Vec<Vec<f64>>]) -> Vec<Vec<Vec<f64>>> {
        let c = input.len();
        let h = input[0].len();
        let w = input[0][0].len();
        let out_c = c / (self.scale * self.scale);
        let out_h = h * self.scale;
        let out_w = w * self.scale;

        let mut output = vec![vec![vec![0.0; out_w]; out_h]; out_c];
        for oc in 0..out_c {
            for y in 0..out_h {
                for x in 0..out_w {
                    let sy = y % self.scale;
                    let sx = x % self.scale;
                    let ic = oc * self.scale * self.scale + sy * self.scale + sx;
                    let iy = y / self.scale;
                    let ix = x / self.scale;
                    output[oc][y][x] = input[ic][iy][ix];
                }
            }
        }
        output
    }
}

/// AI Upscaler with neural network inference
pub struct AIUpscaler {
    config: UpscaleConfig,
    feature_extractor: Vec<ConvBlock>,
    residual_blocks: Vec<ResidualDenseBlock>,
    upsampler: Vec<(ConvBlock, PixelShuffle)>,
    reconstruction: ConvBlock,
}

impl AIUpscaler {
    pub fn new(config: UpscaleConfig) -> Self {
        let base_channels = 64;
        let feature_extractor = vec![
            ConvBlock::new(3, base_channels, 3, Activation::LeakyReLU(0.2)),
        ];

        let mut residual_blocks = Vec::new();
        for _ in 0..23 {
            residual_blocks.push(ResidualDenseBlock::new(base_channels, 32));
        }

        let num_upsample = (config.scale_factor as f64).log2().ceil() as usize;
        let mut upsampler = Vec::new();
        for _ in 0..num_upsample {
            upsampler.push((
                ConvBlock::new(base_channels, base_channels * 4, 3, Activation::LeakyReLU(0.2)),
                PixelShuffle::new(2),
            ));
        }

        let reconstruction = ConvBlock::new(base_channels, 3, 3, Activation::SiLU);

        Self { config, feature_extractor, residual_blocks, upsampler, reconstruction }
    }

    pub fn upscale(&self, frame: &VideoFrame) -> VideoFrame {
        let tiles = self.split_tiles(frame);
        let mut upscaled_tiles = Vec::new();

        for tile in tiles {
            let processed = self.process_tile(&tile);
            upscaled_tiles.push(processed);
        }

        self.merge_tiles(&upscaled_tiles, frame.width * self.config.scale_factor as usize,
                         frame.height * self.config.scale_factor as usize)
    }

    fn split_tiles(&self, frame: &VideoFrame) -> Vec<VideoFrame> {
        let tile_size = self.config.tile_size as usize;
        let overlap = self.config.tile_overlap as usize;
        let step = tile_size - overlap;
        let mut tiles = Vec::new();

        let mut y = 0;
        while y < frame.height {
            let mut x = 0;
            while x < frame.width {
                let tw = (tile_size).min(frame.width - x);
                let th = (tile_size).min(frame.height - y);
                let mut tile = VideoFrame::new(tw, th);
                for ty in 0..th {
                    for tx in 0..tw {
                        tile.set_pixel(tx, ty, frame.get_pixel(x + tx, y + ty));
                    }
                }
                tiles.push(tile);
                x += step;
            }
            y += step;
        }
        tiles
    }

    fn process_tile(&self, tile: &VideoFrame) -> VideoFrame {
        let input = self.frame_to_tensor(tile);
        let mut features = self.feature_extractor[0].forward(&input);
        let trunk = features.clone();

        for block in &self.residual_blocks {
            features = block.forward(&features);
        }

        features = ResidualDenseBlock::add_tensors(&features, &trunk, 1.0);

        for (conv, shuffle) in &self.upsampler {
            features = conv.forward(&features);
            features = shuffle.forward(&features);
        }

        features = self.reconstruction.forward(&features);
        self.tensor_to_frame(&features)
    }

    fn merge_tiles(&self, tiles: &[VideoFrame], width: usize, height: usize) -> VideoFrame {
        let mut output = VideoFrame::new(width, height);
        let scale = self.config.scale_factor as usize;
        let tile_size = self.config.tile_size as usize * scale;
        let overlap = self.config.tile_overlap as usize * scale;
        let step = tile_size - overlap;

        let mut idx = 0;
        let mut y = 0;
        while y < height && idx < tiles.len() {
            let mut x = 0;
            while x < width && idx < tiles.len() {
                let tile = &tiles[idx];
                for ty in 0..tile.height {
                    for tx in 0..tile.width {
                        if x + tx < width && y + ty < height {
                            output.set_pixel(x + tx, y + ty, tile.get_pixel(tx, ty));
                        }
                    }
                }
                idx += 1;
                x += step;
            }
            y += step;
        }
        output
    }

    fn frame_to_tensor(&self, frame: &VideoFrame) -> Vec<Vec<Vec<f64>>> {
        let mut tensor = vec![
            vec![vec![0.0; frame.width]; frame.height],
            vec![vec![0.0; frame.width]; frame.height],
            vec![vec![0.0; frame.width]; frame.height],
        ];
        for y in 0..frame.height {
            for x in 0..frame.width {
                let pixel = frame.get_pixel(x, y);
                tensor[0][y][x] = pixel.r;
                tensor[1][y][x] = pixel.g;
                tensor[2][y][x] = pixel.b;
            }
        }
        tensor
    }

    fn tensor_to_frame(&self, tensor: &[Vec<Vec<f64>>]) -> VideoFrame {
        let height = tensor[0].len();
        let width = tensor[0][0].len();
        let mut frame = VideoFrame::new(width, height);
        for y in 0..height {
            for x in 0..width {
                frame.set_pixel(x, y, RGB::new(
                    tensor[0][y][x].clamp(0.0, 1.0),
                    tensor[1][y][x].clamp(0.0, 1.0),
                    tensor[2][y][x].clamp(0.0, 1.0),
                ));
            }
        }
        frame
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOISE REDUCTION - Temporal and Spatial Denoising
// ═══════════════════════════════════════════════════════════════════════════════

/// Denoising algorithm types
#[derive(Debug, Clone, Copy)]
pub enum DenoiseAlgorithm {
    BilateralFilter,
    NonLocalMeans,
    BM3D,               // Block-Matching 3D
    VBM4D,              // Video Block-Matching 4D (temporal)
    DnCNN,              // Deep denoiser
    FFDNet,             // Fast and Flexible Denoising
}

/// Spatial denoiser using bilateral filtering
pub struct SpatialDenoiser {
    sigma_spatial: f64,
    sigma_color: f64,
    kernel_size: usize,
}

impl SpatialDenoiser {
    pub fn new(spatial: f64, color: f64) -> Self {
        let kernel_size = (spatial * 3.0).ceil() as usize | 1;
        Self {
            sigma_spatial: spatial,
            sigma_color: color,
            kernel_size,
        }
    }

    pub fn process(&self, frame: &VideoFrame) -> VideoFrame {
        let mut output = VideoFrame::new(frame.width, frame.height);
        let half = self.kernel_size / 2;

        for y in 0..frame.height {
            for x in 0..frame.width {
                let center = frame.get_pixel(x, y);
                let mut sum_r = 0.0;
                let mut sum_g = 0.0;
                let mut sum_b = 0.0;
                let mut weight_sum = 0.0;

                for ky in 0..self.kernel_size {
                    for kx in 0..self.kernel_size {
                        let ny = (y + ky).saturating_sub(half).min(frame.height - 1);
                        let nx = (x + kx).saturating_sub(half).min(frame.width - 1);
                        let neighbor = frame.get_pixel(nx, ny);

                        let dx = kx as f64 - half as f64;
                        let dy = ky as f64 - half as f64;
                        let spatial_dist = dx * dx + dy * dy;
                        let spatial_weight = (-spatial_dist / (2.0 * self.sigma_spatial * self.sigma_spatial)).exp();

                        let color_diff = (center.r - neighbor.r).powi(2) +
                                        (center.g - neighbor.g).powi(2) +
                                        (center.b - neighbor.b).powi(2);
                        let color_weight = (-color_diff / (2.0 * self.sigma_color * self.sigma_color)).exp();

                        let weight = spatial_weight * color_weight;
                        sum_r += neighbor.r * weight;
                        sum_g += neighbor.g * weight;
                        sum_b += neighbor.b * weight;
                        weight_sum += weight;
                    }
                }

                if weight_sum > 0.0 {
                    output.set_pixel(x, y, RGB::new(
                        sum_r / weight_sum,
                        sum_g / weight_sum,
                        sum_b / weight_sum,
                    ));
                } else {
                    output.set_pixel(x, y, center);
                }
            }
        }
        output
    }
}

/// Non-Local Means denoiser
pub struct NonLocalMeansDenoiser {
    search_window: usize,
    patch_size: usize,
    h: f64,
}

impl NonLocalMeansDenoiser {
    pub fn new(search_window: usize, patch_size: usize, h: f64) -> Self {
        Self { search_window, patch_size, h }
    }

    pub fn process(&self, frame: &VideoFrame) -> VideoFrame {
        let mut output = VideoFrame::new(frame.width, frame.height);
        let half_search = self.search_window / 2;
        let half_patch = self.patch_size / 2;
        let h2 = self.h * self.h;

        for y in 0..frame.height {
            for x in 0..frame.width {
                let mut sum_r = 0.0;
                let mut sum_g = 0.0;
                let mut sum_b = 0.0;
                let mut weight_sum = 0.0;

                let y_start = y.saturating_sub(half_search);
                let y_end = (y + half_search).min(frame.height - 1);
                let x_start = x.saturating_sub(half_search);
                let x_end = (x + half_search).min(frame.width - 1);

                for sy in y_start..=y_end {
                    for sx in x_start..=x_end {
                        let dist = self.patch_distance(frame, x, y, sx, sy, half_patch);
                        let weight = (-dist / h2).exp();
                        let pixel = frame.get_pixel(sx, sy);
                        sum_r += pixel.r * weight;
                        sum_g += pixel.g * weight;
                        sum_b += pixel.b * weight;
                        weight_sum += weight;
                    }
                }

                if weight_sum > 0.0 {
                    output.set_pixel(x, y, RGB::new(
                        sum_r / weight_sum,
                        sum_g / weight_sum,
                        sum_b / weight_sum,
                    ));
                }
            }
        }
        output
    }

    fn patch_distance(&self, frame: &VideoFrame, x1: usize, y1: usize, x2: usize, y2: usize, half: usize) -> f64 {
        let mut dist = 0.0;
        let mut count = 0;

        for dy in 0..self.patch_size {
            for dx in 0..self.patch_size {
                let py1 = (y1 + dy).saturating_sub(half).min(frame.height - 1);
                let px1 = (x1 + dx).saturating_sub(half).min(frame.width - 1);
                let py2 = (y2 + dy).saturating_sub(half).min(frame.height - 1);
                let px2 = (x2 + dx).saturating_sub(half).min(frame.width - 1);

                let p1 = frame.get_pixel(px1, py1);
                let p2 = frame.get_pixel(px2, py2);
                dist += (p1.r - p2.r).powi(2) + (p1.g - p2.g).powi(2) + (p1.b - p2.b).powi(2);
                count += 1;
            }
        }
        dist / count as f64
    }
}

/// Temporal denoiser with motion compensation
pub struct TemporalDenoiser {
    frame_buffer: VecDeque<VideoFrame>,
    buffer_size: usize,
    blend_strength: f64,
    motion_threshold: f64,
}

impl TemporalDenoiser {
    pub fn new(buffer_size: usize, strength: f64) -> Self {
        Self {
            frame_buffer: VecDeque::with_capacity(buffer_size),
            buffer_size,
            blend_strength: strength.clamp(0.0, 1.0),
            motion_threshold: 0.1,
        }
    }

    pub fn process(&mut self, frame: &VideoFrame) -> VideoFrame {
        self.frame_buffer.push_back(frame.clone());
        if self.frame_buffer.len() > self.buffer_size {
            self.frame_buffer.pop_front();
        }

        if self.frame_buffer.len() < 2 {
            return frame.clone();
        }

        let mut output = VideoFrame::new(frame.width, frame.height);
        let count = self.frame_buffer.len();

        for y in 0..frame.height {
            for x in 0..frame.width {
                let current = frame.get_pixel(x, y);
                let mut sum_r = 0.0;
                let mut sum_g = 0.0;
                let mut sum_b = 0.0;
                let mut weight_sum = 0.0;

                for (i, buf_frame) in self.frame_buffer.iter().enumerate() {
                    let pixel = buf_frame.get_pixel(x, y);
                    let color_diff = (current.r - pixel.r).abs() +
                                    (current.g - pixel.g).abs() +
                                    (current.b - pixel.b).abs();

                    if color_diff < self.motion_threshold {
                        let temporal_weight = 1.0 / (1.0 + (count - 1 - i) as f64 * 0.5);
                        sum_r += pixel.r * temporal_weight;
                        sum_g += pixel.g * temporal_weight;
                        sum_b += pixel.b * temporal_weight;
                        weight_sum += temporal_weight;
                    }
                }

                if weight_sum > 0.0 {
                    let denoised = RGB::new(
                        sum_r / weight_sum,
                        sum_g / weight_sum,
                        sum_b / weight_sum,
                    );
                    output.set_pixel(x, y, RGB::new(
                        current.r * (1.0 - self.blend_strength) + denoised.r * self.blend_strength,
                        current.g * (1.0 - self.blend_strength) + denoised.g * self.blend_strength,
                        current.b * (1.0 - self.blend_strength) + denoised.b * self.blend_strength,
                    ));
                } else {
                    output.set_pixel(x, y, current);
                }
            }
        }
        output
    }

    pub fn reset(&mut self) {
        self.frame_buffer.clear();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FRAME INTERPOLATION - Optical Flow Based
// ═══════════════════════════════════════════════════════════════════════════════

/// Optical flow vector
#[derive(Debug, Clone, Copy, Default)]
pub struct FlowVector {
    pub u: f64,  // Horizontal displacement
    pub v: f64,  // Vertical displacement
}

/// Optical flow computation methods
#[derive(Debug, Clone, Copy)]
pub enum FlowMethod {
    LucasKanade,
    HornSchunck,
    Farneback,
    RAFT,       // Recurrent All-Pairs Field Transforms
}

/// Optical flow estimator using Lucas-Kanade
pub struct OpticalFlowEstimator {
    window_size: usize,
    pyramid_levels: usize,
    iterations: usize,
}

impl OpticalFlowEstimator {
    pub fn new(window_size: usize, levels: usize) -> Self {
        Self {
            window_size,
            pyramid_levels: levels,
            iterations: 10,
        }
    }

    pub fn compute(&self, prev: &VideoFrame, curr: &VideoFrame) -> Vec<Vec<FlowVector>> {
        let mut flow = vec![vec![FlowVector::default(); prev.width]; prev.height];
        let half = self.window_size / 2;

        let prev_gray = self.to_grayscale(prev);
        let curr_gray = self.to_grayscale(curr);
        let (ix, iy, it) = self.compute_gradients(&prev_gray, &curr_gray);

        for y in half..(prev.height - half) {
            for x in half..(prev.width - half) {
                let (u, v) = self.lucas_kanade_point(&ix, &iy, &it, x, y, half);
                flow[y][x] = FlowVector { u, v };
            }
        }
        flow
    }

    fn to_grayscale(&self, frame: &VideoFrame) -> Vec<Vec<f64>> {
        let mut gray = vec![vec![0.0; frame.width]; frame.height];
        for y in 0..frame.height {
            for x in 0..frame.width {
                let p = frame.get_pixel(x, y);
                gray[y][x] = 0.299 * p.r + 0.587 * p.g + 0.114 * p.b;
            }
        }
        gray
    }

    fn compute_gradients(&self, prev: &[Vec<f64>], curr: &[Vec<f64>]) -> (Vec<Vec<f64>>, Vec<Vec<f64>>, Vec<Vec<f64>>) {
        let h = prev.len();
        let w = prev[0].len();
        let mut ix = vec![vec![0.0; w]; h];
        let mut iy = vec![vec![0.0; w]; h];
        let mut it = vec![vec![0.0; w]; h];

        for y in 1..(h - 1) {
            for x in 1..(w - 1) {
                ix[y][x] = (prev[y][x + 1] - prev[y][x - 1] + curr[y][x + 1] - curr[y][x - 1]) / 4.0;
                iy[y][x] = (prev[y + 1][x] - prev[y - 1][x] + curr[y + 1][x] - curr[y - 1][x]) / 4.0;
                it[y][x] = curr[y][x] - prev[y][x];
            }
        }
        (ix, iy, it)
    }

    fn lucas_kanade_point(&self, ix: &[Vec<f64>], iy: &[Vec<f64>], it: &[Vec<f64>],
                          x: usize, y: usize, half: usize) -> (f64, f64) {
        let mut sum_ix2 = 0.0;
        let mut sum_iy2 = 0.0;
        let mut sum_ixiy = 0.0;
        let mut sum_ixit = 0.0;
        let mut sum_iyit = 0.0;

        for dy in 0..self.window_size {
            for dx in 0..self.window_size {
                let py = y + dy - half;
                let px = x + dx - half;
                sum_ix2 += ix[py][px] * ix[py][px];
                sum_iy2 += iy[py][px] * iy[py][px];
                sum_ixiy += ix[py][px] * iy[py][px];
                sum_ixit += ix[py][px] * it[py][px];
                sum_iyit += iy[py][px] * it[py][px];
            }
        }

        let det = sum_ix2 * sum_iy2 - sum_ixiy * sum_ixiy;
        if det.abs() < 1e-10 {
            return (0.0, 0.0);
        }

        let u = -(sum_iy2 * sum_ixit - sum_ixiy * sum_iyit) / det;
        let v = -(sum_ix2 * sum_iyit - sum_ixiy * sum_ixit) / det;
        (u, v)
    }
}

/// Frame interpolator for motion smoothing
pub struct FrameInterpolator {
    flow_estimator: OpticalFlowEstimator,
    blend_mode: BlendMode,
}

#[derive(Debug, Clone, Copy)]
pub enum BlendMode {
    Linear,
    Cosine,
    SmoothStep,
    Overlap,
}

impl FrameInterpolator {
    pub fn new() -> Self {
        Self {
            flow_estimator: OpticalFlowEstimator::new(15, 3),
            blend_mode: BlendMode::SmoothStep,
        }
    }

    pub fn interpolate(&self, frame1: &VideoFrame, frame2: &VideoFrame, t: f64) -> VideoFrame {
        let t = t.clamp(0.0, 1.0);
        let flow = self.flow_estimator.compute(frame1, frame2);
        let mut output = VideoFrame::new(frame1.width, frame1.height);

        let blend_factor = match self.blend_mode {
            BlendMode::Linear => t,
            BlendMode::Cosine => 0.5 * (1.0 - (t * std::f64::consts::PI).cos()),
            BlendMode::SmoothStep => t * t * (3.0 - 2.0 * t),
            BlendMode::Overlap => t,
        };

        for y in 0..frame1.height {
            for x in 0..frame1.width {
                let fv = &flow[y][x];
                let x1 = (x as f64 + fv.u * t).round() as i64;
                let y1 = (y as f64 + fv.v * t).round() as i64;
                let x2 = (x as f64 - fv.u * (1.0 - t)).round() as i64;
                let y2 = (y as f64 - fv.v * (1.0 - t)).round() as i64;

                let p1 = self.sample_bilinear(frame1, x1, y1);
                let p2 = self.sample_bilinear(frame2, x2, y2);

                output.set_pixel(x, y, RGB::new(
                    p1.r * (1.0 - blend_factor) + p2.r * blend_factor,
                    p1.g * (1.0 - blend_factor) + p2.g * blend_factor,
                    p1.b * (1.0 - blend_factor) + p2.b * blend_factor,
                ));
            }
        }
        output
    }

    fn sample_bilinear(&self, frame: &VideoFrame, x: i64, y: i64) -> RGB {
        let x = x.clamp(0, frame.width as i64 - 1) as usize;
        let y = y.clamp(0, frame.height as i64 - 1) as usize;
        frame.get_pixel(x, y)
    }

    pub fn interpolate_sequence(&self, frames: &[VideoFrame], factor: usize) -> Vec<VideoFrame> {
        let mut output = Vec::new();
        for i in 0..(frames.len() - 1) {
            output.push(frames[i].clone());
            for j in 1..factor {
                let t = j as f64 / factor as f64;
                output.push(self.interpolate(&frames[i], &frames[i + 1], t));
            }
        }
        if let Some(last) = frames.last() {
            output.push(last.clone());
        }
        output
    }
}

