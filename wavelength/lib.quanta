/// Video frame
#[derive(Clone)]
pub struct VideoFrame {
    pub width: u32,
    pub height: u32,
    pub pixels: Vec<RGB>,
    pub timestamp: f64,
    pub frame_number: u64,
}

impl VideoFrame {
    pub fn new(width: u32, height: u32) -> Self {
        VideoFrame {
            width,
            height,
            pixels: vec![RGB::black(); (width * height) as usize],
            timestamp: 0.0,
            frame_number: 0,
        }
    }
    
    pub fn get_pixel(&self, x: u32, y: u32) -> RGB {
        self.pixels[(y * self.width + x) as usize].clone()
    }
    
    pub fn set_pixel(&mut self, x: u32, y: u32, color: RGB) {
        self.pixels[(y * self.width + x) as usize] = color;
    }
}

/// Audio sample
#[derive(Clone)]
pub struct AudioSample {
    pub left: f32,
    pub right: f32,
}

/// Audio buffer
#[derive(Clone)]
pub struct AudioBuffer {
    pub samples: Vec<AudioSample>,
    pub sample_rate: u32,
    pub channels: u32,
}

impl AudioBuffer {
    pub fn new(sample_rate: u32, channels: u32) -> Self {
        AudioBuffer {
            samples: Vec::new(),
            sample_rate,
            channels,
        }
    }
    
    pub fn duration(&self) -> f64 {
        self.samples.len() as f64 / self.sample_rate as f64
    }
}

/// Media clip
#[derive(Clone)]
pub struct MediaClip {
    pub id: u64,
    pub name: String,
    pub clip_type: ClipType,
    pub start_time: f64,
    pub duration: f64,
    pub in_point: f64,
    pub out_point: f64,
    pub track: u32,
    pub effects: Vec<Effect>,
    pub transitions: Vec<Transition>,
}

#[derive(Clone, Copy, PartialEq)]
pub enum ClipType {
    Video,
    Audio,
    Image,
    Title,
}

/// Effect on a clip
#[derive(Clone)]
pub struct Effect {
    pub effect_type: EffectType,
    pub parameters: HashMap<String, f64>,
    pub enabled: bool,
}

#[derive(Clone, Copy, PartialEq)]
pub enum EffectType {
    ColorCorrection,
    Blur,
    Sharpen,
    Denoise,
    SpeedChange,
    Stabilization,
    AIEnhance,
}

/// Transition between clips
#[derive(Clone)]
pub struct Transition {
    pub transition_type: TransitionType,
    pub duration: f64,
    pub parameters: HashMap<String, f64>,
}

#[derive(Clone, Copy, PartialEq)]
pub enum TransitionType {
    Cut,
    Dissolve,
    Wipe,
    Slide,
    Zoom,
    AIContentAware,
}

