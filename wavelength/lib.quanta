/// HDR metadata
#[derive(Debug, Clone)]
pub struct HDRMetadata {
    pub transfer_function: TransferFunction,
    pub color_primaries: ColorPrimaries,
    pub max_content_light_level: u16,
    pub max_frame_average_light_level: u16,
    pub mastering_display_primaries: [[f32; 2]; 3],
    pub mastering_white_point: [f32; 2],
    pub mastering_luminance_min: f32,
    pub mastering_luminance_max: f32,
}

#[derive(Debug, Clone, Copy)]
pub enum TransferFunction {
    SDR,
    PQ,
    HLG,
    Linear,
}

#[derive(Debug, Clone, Copy)]
pub enum ColorPrimaries {
    BT709,
    BT2020,
    DCI_P3,
    AdobeRGB,
    ACES,
}

impl HDRMetadata {
    pub fn hdr10() -> Self {
        Self {
            transfer_function: TransferFunction::PQ,
            color_primaries: ColorPrimaries::BT2020,
            max_content_light_level: 1000,
            max_frame_average_light_level: 400,
            mastering_display_primaries: [
                [0.68, 0.32], [0.265, 0.69], [0.15, 0.06],
            ],
            mastering_white_point: [0.3127, 0.329],
            mastering_luminance_min: 0.0001,
            mastering_luminance_max: 1000.0,
        }
    }

    pub fn dolby_vision() -> Self {
        Self {
            transfer_function: TransferFunction::PQ,
            color_primaries: ColorPrimaries::BT2020,
            max_content_light_level: 4000,
            max_frame_average_light_level: 1000,
            mastering_display_primaries: [
                [0.68, 0.32], [0.265, 0.69], [0.15, 0.06],
            ],
            mastering_white_point: [0.3127, 0.329],
            mastering_luminance_min: 0.0001,
            mastering_luminance_max: 4000.0,
        }
    }
}

/// PQ (Perceptual Quantizer) EOTF
pub struct PQTransfer;

impl PQTransfer {
    const M1: f32 = 0.1593017578125;
    const M2: f32 = 78.84375;
    const C1: f32 = 0.8359375;
    const C2: f32 = 18.8515625;
    const C3: f32 = 18.6875;

    pub fn eotf(v: f32) -> f32 {
        if v <= 0.0 { return 0.0; }

        let vp = v.powf(1.0 / Self::M2);
        let num = (vp - Self::C1).max(0.0);
        let den = Self::C2 - Self::C3 * vp;

        if den <= 0.0 { return 0.0; }

        (num / den).powf(1.0 / Self::M1) * 10000.0
    }

    pub fn oetf(l: f32) -> f32 {
        if l <= 0.0 { return 0.0; }

        let y = (l / 10000.0).clamp(0.0, 1.0);
        let yp = y.powf(Self::M1);
        let num = Self::C1 + Self::C2 * yp;
        let den = 1.0 + Self::C3 * yp;

        (num / den).powf(Self::M2)
    }
}

/// HLG (Hybrid Log-Gamma) EOTF
pub struct HLGTransfer;

impl HLGTransfer {
    const A: f32 = 0.17883277;
    const B: f32 = 0.28466892;
    const C: f32 = 0.55991073;

    pub fn eotf(v: f32) -> f32 {
        if v <= 0.5 {
            v * v / 3.0
        } else {
            ((v - Self::C) / Self::A + Self::B).exp() / 12.0
        }
    }

    pub fn oetf(l: f32) -> f32 {
        if l <= 1.0 / 12.0 {
            (3.0 * l).sqrt()
        } else {
            Self::A * (12.0 * l - Self::B).ln() + Self::C
        }
    }
}

/// Tone mapper for HDR to SDR conversion
pub struct HDRToneMapper {
    pub target_luminance: f32,
    pub shoulder_strength: f32,
    pub linear_strength: f32,
    pub linear_angle: f32,
    pub toe_strength: f32,
}

impl HDRToneMapper {
    pub fn new(target_luminance: f32) -> Self {
        Self {
            target_luminance,
            shoulder_strength: 0.22,
            linear_strength: 0.30,
            linear_angle: 0.10,
            toe_strength: 0.20,
        }
    }

    pub fn reinhard(&self, l: f32) -> f32 {
        l / (1.0 + l) * (1.0 + l / (self.target_luminance * self.target_luminance))
    }

    pub fn aces_filmic(&self, l: f32) -> f32 {
        let a = 2.51;
        let b = 0.03;
        let c = 2.43;
        let d = 0.59;
        let e = 0.14;

        ((l * (a * l + b)) / (l * (c * l + d) + e)).clamp(0.0, 1.0)
    }

    pub fn hable_filmic(&self, l: f32) -> f32 {
        let a = self.shoulder_strength;
        let b = self.linear_strength;
        let c = self.linear_angle;
        let d = self.toe_strength;
        let e = 0.02;
        let f = 0.30;

        ((l * (a * l + c * b) + d * e) / (l * (a * l + b) + d * f)) - e / f
    }

    pub fn map_frame(&self, frame: &VideoFrame, source_max_lum: f32) -> VideoFrame {
        let mut result = VideoFrame::new(frame.width, frame.height);
        let scale = self.target_luminance / source_max_lum;

        for y in 0..frame.height {
            for x in 0..frame.width {
                let pixel = frame.get_pixel(x, y);
                let luminance = 0.2126 * pixel.r + 0.7152 * pixel.g + 0.0722 * pixel.b;
                let mapped_lum = self.aces_filmic(luminance * scale);
                let ratio = if luminance > 0.0 { mapped_lum / luminance } else { 0.0 };

                result.set_pixel(x, y, RGB::new(
                    (pixel.r * ratio).clamp(0.0, 1.0),
                    (pixel.g * ratio).clamp(0.0, 1.0),
                    (pixel.b * ratio).clamp(0.0, 1.0),
                ));
            }
        }

        result
    }
}

/// HDR analyzer
pub struct HDRAnalyzer {
    pub histogram_bins: usize,
}

impl HDRAnalyzer {
    pub fn new() -> Self {
        Self { histogram_bins: 256 }
    }

    pub fn analyze_frame(&self, frame: &VideoFrame) -> HDRFrameStats {
        let mut min_lum = f32::MAX;
        let mut max_lum = 0.0_f32;
        let mut sum_lum = 0.0;
        let mut histogram = vec![0u32; self.histogram_bins];

        for y in 0..frame.height {
            for x in 0..frame.width {
                let pixel = frame.get_pixel(x, y);
                let lum = 0.2126 * pixel.r + 0.7152 * pixel.g + 0.0722 * pixel.b;

                min_lum = min_lum.min(lum);
                max_lum = max_lum.max(lum);
                sum_lum += lum;

                let bin = ((lum.log10() + 4.0) / 8.0 * self.histogram_bins as f32) as usize;
                let bin = bin.min(self.histogram_bins - 1);
                histogram[bin] += 1;
            }
        }

        let pixel_count = (frame.width * frame.height) as f32;

        HDRFrameStats {
            min_luminance: min_lum,
            max_luminance: max_lum,
            average_luminance: sum_lum / pixel_count,
            histogram,
        }
    }

    pub fn detect_clipping(&self, frame: &VideoFrame, threshold: f32) -> f32 {
        let mut clipped = 0u32;

        for y in 0..frame.height {
            for x in 0..frame.width {
                let pixel = frame.get_pixel(x, y);
                if pixel.r >= threshold || pixel.g >= threshold || pixel.b >= threshold {
                    clipped += 1;
                }
            }
        }

        clipped as f32 / (frame.width * frame.height) as f32
    }
}

/// HDR frame statistics
#[derive(Debug, Clone)]
pub struct HDRFrameStats {
    pub min_luminance: f32,
    pub max_luminance: f32,
    pub average_luminance: f32,
    pub histogram: Vec<u32>,
}

