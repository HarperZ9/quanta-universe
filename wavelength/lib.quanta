        }
    }

    pub fn srt_low_latency(url: &str) -> Self {
        Self {
            protocol: StreamProtocol::SRT,
            url: url.to_string(),
            stream_key: None,
            video_bitrate: 8000,
            audio_bitrate: 256,
            keyframe_interval: 1,
            low_latency: true,
        }
    }
}

/// Adaptive bitrate ladder
#[derive(Debug, Clone)]
pub struct ABRLadder {
    pub rungs: Vec<ABRRung>,
}

#[derive(Debug, Clone)]
pub struct ABRRung {
    pub width: u32,
    pub height: u32,
    pub bitrate: u32,
    pub frame_rate: f32,
    pub profile: String,
}

impl ABRLadder {
    pub fn standard() -> Self {
        Self {
            rungs: vec![
                ABRRung { width: 1920, height: 1080, bitrate: 8000, frame_rate: 60.0, profile: "high".into() },
                ABRRung { width: 1920, height: 1080, bitrate: 4500, frame_rate: 30.0, profile: "high".into() },
                ABRRung { width: 1280, height: 720, bitrate: 3000, frame_rate: 30.0, profile: "main".into() },
                ABRRung { width: 854, height: 480, bitrate: 1500, frame_rate: 30.0, profile: "main".into() },
                ABRRung { width: 640, height: 360, bitrate: 800, frame_rate: 30.0, profile: "baseline".into() },
            ],
        }
    }

    pub fn for_bandwidth(&self, bandwidth: u32) -> Option<&ABRRung> {
        self.rungs.iter().find(|r| r.bitrate <= bandwidth)
    }
}

/// HLS playlist generator
pub struct HLSPlaylistGenerator {
    pub segment_duration: f32,
    pub playlist_size: usize,
}

impl HLSPlaylistGenerator {
    pub fn new(segment_duration: f32) -> Self {
        Self { segment_duration, playlist_size: 5 }
    }

    pub fn generate_master(&self, ladder: &ABRLadder, base_url: &str) -> String {
        let mut playlist = String::from("#EXTM3U\n#EXT-X-VERSION:3\n\n");

        for rung in &ladder.rungs {
            playlist.push_str(&format!(
                "#EXT-X-STREAM-INF:BANDWIDTH={},RESOLUTION={}x{}\n{}/{}.m3u8\n\n",
                rung.bitrate * 1000,
                rung.width,
                rung.height,
                base_url,
                rung.bitrate
            ));
        }

        playlist
    }

    pub fn generate_media(&self, segments: &[(u32, f32)], media_sequence: u32) -> String {
        let mut playlist = String::from("#EXTM3U\n#EXT-X-VERSION:3\n");
        playlist.push_str(&format!("#EXT-X-TARGETDURATION:{}\n", self.segment_duration.ceil() as u32));
        playlist.push_str(&format!("#EXT-X-MEDIA-SEQUENCE:{}\n\n", media_sequence));

        for (seq, duration) in segments {
            playlist.push_str(&format!("#EXTINF:{:.3},\nsegment_{}.ts\n", duration, seq));
        }

        playlist
    }
}

/// Stream health monitor
#[derive(Debug)]
pub struct StreamHealthMonitor {
    pub bitrate_history: Vec<(u64, u32)>,
    pub dropped_frames: u32,
    pub total_frames: u32,
    pub buffer_health: f32,
    pub network_rtt: u32,
}

impl StreamHealthMonitor {
    pub fn new() -> Self {
        Self {
            bitrate_history: Vec::new(),
            dropped_frames: 0,
            total_frames: 0,
            buffer_health: 1.0,
            network_rtt: 0,
        }
    }

    pub fn record_frame(&mut self, dropped: bool) {
        self.total_frames += 1;
        if dropped { self.dropped_frames += 1; }
    }

    pub fn drop_rate(&self) -> f32 {
        if self.total_frames == 0 { 0.0 }
        else { self.dropped_frames as f32 / self.total_frames as f32 }
    }

    pub fn health_score(&self) -> f32 {
        let drop_penalty = 1.0 - self.drop_rate().min(1.0);
        let buffer_score = self.buffer_health;
        let rtt_score = 1.0 - (self.network_rtt as f32 / 1000.0).min(1.0);

        (drop_penalty * 0.4 + buffer_score * 0.4 + rtt_score * 0.2).clamp(0.0, 1.0)
    }
}

