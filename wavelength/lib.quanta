}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO STABILIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Motion vector for stabilization
#[derive(Debug, Clone, Copy)]
pub struct MotionVector {
    pub dx: f32,
    pub dy: f32,
    pub rotation: f32,
    pub scale: f32,
    pub confidence: f32,
}

impl MotionVector {
    pub fn identity() -> Self {
        Self { dx: 0.0, dy: 0.0, rotation: 0.0, scale: 1.0, confidence: 1.0 }
    }

    pub fn magnitude(&self) -> f32 {
        (self.dx * self.dx + self.dy * self.dy).sqrt()
    }

    pub fn interpolate(&self, other: &Self, t: f32) -> Self {
        Self {
            dx: self.dx + (other.dx - self.dx) * t,
            dy: self.dy + (other.dy - self.dy) * t,
            rotation: self.rotation + (other.rotation - self.rotation) * t,
            scale: self.scale + (other.scale - self.scale) * t,
            confidence: self.confidence.min(other.confidence),
        }
    }
}

/// Feature point for tracking
#[derive(Debug, Clone)]
pub struct FeaturePoint {
    pub x: f32,
    pub y: f32,
    pub response: f32,
    pub octave: i32,
    pub descriptor: Vec<f32>,
}

/// Harris corner detector
pub struct HarrisDetector {
    pub block_size: u32,
    pub ksize: u32,
    pub k: f32,
    pub threshold: f32,
}

impl HarrisDetector {
    pub fn new() -> Self {
        Self { block_size: 3, ksize: 3, k: 0.04, threshold: 0.01 }
    }

    pub fn detect(&self, frame: &VideoFrame) -> Vec<FeaturePoint> {
        let mut features = Vec::new();
        let gray = self.to_grayscale(frame);

        let (ix, iy) = self.compute_gradients(&gray, frame.width, frame.height);
        let (ixx, iyy, ixy) = self.compute_structure_tensor(&ix, &iy, frame.width, frame.height);

        for y in self.block_size..(frame.height - self.block_size) {
            for x in self.block_size..(frame.width - self.block_size) {
                let idx = (y * frame.width + x) as usize;
                let a = ixx[idx];
                let b = iyy[idx];
                let c = ixy[idx];

                let det = a * b - c * c;
                let trace = a + b;
                let response = det - self.k * trace * trace;

                if response > self.threshold {
                    features.push(FeaturePoint {
                        x: x as f32,
                        y: y as f32,
                        response,
                        octave: 0,
                        descriptor: Vec::new(),
                    });
                }
            }
        }

        self.non_max_suppression(&mut features, 8.0);
        features
    }

    fn to_grayscale(&self, frame: &VideoFrame) -> Vec<f32> {
        frame.data.iter().map(|p| 0.299 * p.r + 0.587 * p.g + 0.114 * p.b).collect()
    }

    fn compute_gradients(&self, gray: &[f32], w: u32, h: u32) -> (Vec<f32>, Vec<f32>) {
        let mut ix = vec![0.0; gray.len()];
        let mut iy = vec![0.0; gray.len()];

        for y in 1..(h - 1) {
            for x in 1..(w - 1) {
                let idx = (y * w + x) as usize;
                ix[idx] = gray[idx + 1] - gray[idx - 1];
                iy[idx] = gray[idx + w as usize] - gray[idx - w as usize];
            }
        }
        (ix, iy)
    }

    fn compute_structure_tensor(&self, ix: &[f32], iy: &[f32], w: u32, h: u32) -> (Vec<f32>, Vec<f32>, Vec<f32>) {
        let mut ixx = vec![0.0; ix.len()];
        let mut iyy = vec![0.0; ix.len()];
        let mut ixy = vec![0.0; ix.len()];

        let r = self.block_size as i32;
        for y in r..(h as i32 - r) {
            for x in r..(w as i32 - r) {
                let mut sum_xx = 0.0;
                let mut sum_yy = 0.0;
                let mut sum_xy = 0.0;

                for dy in -r..=r {
                    for dx in -r..=r {
                        let idx = ((y + dy) * w as i32 + (x + dx)) as usize;
                        sum_xx += ix[idx] * ix[idx];
                        sum_yy += iy[idx] * iy[idx];
                        sum_xy += ix[idx] * iy[idx];
                    }
                }

                let idx = (y * w as i32 + x) as usize;
                ixx[idx] = sum_xx;
                iyy[idx] = sum_yy;
                ixy[idx] = sum_xy;
            }
        }
        (ixx, iyy, ixy)
    }

    fn non_max_suppression(&self, features: &mut Vec<FeaturePoint>, radius: f32) {
        features.sort_by(|a, b| b.response.partial_cmp(&a.response).unwrap());
        let mut keep = vec![true; features.len()];

        for i in 0..features.len() {
            if !keep[i] { continue; }
            for j in (i + 1)..features.len() {
                if !keep[j] { continue; }
                let dx = features[i].x - features[j].x;
                let dy = features[i].y - features[j].y;
                if dx * dx + dy * dy < radius * radius {
                    keep[j] = false;
                }
            }
        }

        let mut idx = 0;
        features.retain(|_| { let k = keep[idx]; idx += 1; k });
    }
}

/// Lucas-Kanade optical flow tracker
pub struct LKTracker {
    pub window_size: u32,
    pub max_iterations: u32,
    pub epsilon: f32,
    pub min_eigenvalue: f32,
}

impl LKTracker {
    pub fn new() -> Self {
        Self { window_size: 21, max_iterations: 30, epsilon: 0.01, min_eigenvalue: 1e-4 }
    }

    pub fn track(&self, prev: &VideoFrame, next: &VideoFrame, points: &[FeaturePoint]) -> Vec<(FeaturePoint, bool)> {
        let prev_gray = self.to_grayscale(prev);
        let next_gray = self.to_grayscale(next);

        points.iter().map(|pt| {
            match self.track_point(&prev_gray, &next_gray, pt, prev.width, prev.height) {
                Some(new_pt) => (new_pt, true),
                None => (pt.clone(), false),
            }
        }).collect()
    }

    fn to_grayscale(&self, frame: &VideoFrame) -> Vec<f32> {
        frame.data.iter().map(|p| 0.299 * p.r + 0.587 * p.g + 0.114 * p.b).collect()
    }

    fn track_point(&self, prev: &[f32], next: &[f32], pt: &FeaturePoint, w: u32, h: u32) -> Option<FeaturePoint> {
        let r = (self.window_size / 2) as i32;
        let mut x = pt.x;
        let mut y = pt.y;

        for _ in 0..self.max_iterations {
            let (gxx, gyy, gxy) = self.compute_gradient_matrix(prev, x, y, r, w);
            let det = gxx * gyy - gxy * gxy;

            if det.abs() < self.min_eigenvalue { return None; }

            let (bx, by) = self.compute_mismatch(prev, next, x, y, r, w);
            let dx = (gyy * bx - gxy * by) / det;
            let dy = (gxx * by - gxy * bx) / det;

            x += dx;
            y += dy;

            if dx.abs() < self.epsilon && dy.abs() < self.epsilon { break; }
            if x < 0.0 || x >= w as f32 || y < 0.0 || y >= h as f32 { return None; }
        }

        Some(FeaturePoint { x, y, response: pt.response, octave: pt.octave, descriptor: Vec::new() })
    }

    fn compute_gradient_matrix(&self, img: &[f32], x: f32, y: f32, r: i32, w: u32) -> (f32, f32, f32) {
        let mut gxx = 0.0;
        let mut gyy = 0.0;
        let mut gxy = 0.0;

        let xi = x as i32;
        let yi = y as i32;

        for dy in -r..=r {
            for dx in -r..=r {
                let px = (xi + dx).clamp(1, w as i32 - 2) as usize;
                let py = (yi + dy).clamp(1, w as i32 - 2) as usize;
                let idx = py * w as usize + px;

                let ix = img[idx + 1] - img[idx - 1];
                let iy = img[idx + w as usize] - img[idx - w as usize];

                gxx += ix * ix;
                gyy += iy * iy;
                gxy += ix * iy;
            }
        }
        (gxx, gyy, gxy)
    }

    fn compute_mismatch(&self, prev: &[f32], next: &[f32], x: f32, y: f32, r: i32, w: u32) -> (f32, f32) {
        let mut bx = 0.0;
        let mut by = 0.0;

        let xi = x as i32;
        let yi = y as i32;

        for dy in -r..=r {
            for dx in -r..=r {
                let px = (xi + dx).clamp(1, w as i32 - 2) as usize;
                let py = (yi + dy).clamp(1, w as i32 - 2) as usize;
                let idx = py * w as usize + px;

                let ix = prev[idx + 1] - prev[idx - 1];
                let iy = prev[idx + w as usize] - prev[idx - w as usize];
                let it = next[idx] - prev[idx];

                bx -= ix * it;
                by -= iy * it;
            }
        }
        (bx, by)
    }
}

/// Video stabilizer with trajectory smoothing
pub struct VideoStabilizer {
    pub smoothing_radius: u32,
    pub crop_ratio: f32,
    pub border_mode: BorderMode,
    pub detector: HarrisDetector,
    pub tracker: LKTracker,
}

#[derive(Debug, Clone, Copy)]
pub enum BorderMode {
    Replicate,
    Reflect,
    Black,
    Blur,
}

impl VideoStabilizer {
    pub fn new() -> Self {
        Self {
            smoothing_radius: 30,
            crop_ratio: 0.1,
            border_mode: BorderMode::Replicate,
            detector: HarrisDetector::new(),
            tracker: LKTracker::new(),
        }
    }

    pub fn analyze(&self, frames: &[VideoFrame]) -> Vec<MotionVector> {
        if frames.len() < 2 { return Vec::new(); }

        let mut motions = Vec::with_capacity(frames.len() - 1);

        for i in 0..(frames.len() - 1) {
            let features = self.detector.detect(&frames[i]);
            let tracked = self.tracker.track(&frames[i], &frames[i + 1], &features);
            let motion = self.estimate_motion(&features, &tracked);
            motions.push(motion);
        }

        motions
    }

    fn estimate_motion(&self, prev: &[FeaturePoint], tracked: &[(FeaturePoint, bool)]) -> MotionVector {
        let valid: Vec<_> = prev.iter().zip(tracked.iter())
            .filter(|(_, (_, ok))| *ok)
            .collect();

        if valid.len() < 4 { return MotionVector::identity(); }

        let mut dx_sum = 0.0;
        let mut dy_sum = 0.0;

        for (old, (new, _)) in &valid {
            dx_sum += new.x - old.x;
            dy_sum += new.y - old.y;
        }

        let n = valid.len() as f32;
        MotionVector {
            dx: dx_sum / n,
            dy: dy_sum / n,
            rotation: 0.0,
            scale: 1.0,
            confidence: n / prev.len() as f32,
        }
    }

    pub fn smooth_trajectory(&self, motions: &[MotionVector]) -> Vec<MotionVector> {
        let n = motions.len();
        if n == 0 { return Vec::new(); }

        let mut trajectory = vec![MotionVector::identity(); n + 1];
        for i in 0..n {
            trajectory[i + 1].dx = trajectory[i].dx + motions[i].dx;
            trajectory[i + 1].dy = trajectory[i].dy + motions[i].dy;
        }

        let mut smoothed = vec![MotionVector::identity(); n + 1];
        let r = self.smoothing_radius as usize;

        for i in 0..=n {
            let start = i.saturating_sub(r);
            let end = (i + r).min(n);
            let mut sum_x = 0.0;
            let mut sum_y = 0.0;

            for j in start..=end {
                sum_x += trajectory[j].dx;
                sum_y += trajectory[j].dy;
            }

            let count = (end - start + 1) as f32;
            smoothed[i].dx = sum_x / count;
            smoothed[i].dy = sum_y / count;
        }

        let mut corrections = vec![MotionVector::identity(); n];
        for i in 0..n {
            corrections[i].dx = smoothed[i + 1].dx - trajectory[i + 1].dx;
            corrections[i].dy = smoothed[i + 1].dy - trajectory[i + 1].dy;
        }

        corrections
    }

    pub fn stabilize(&self, frames: &[VideoFrame], corrections: &[MotionVector]) -> Vec<VideoFrame> {
        frames.iter().zip(corrections.iter())
            .map(|(frame, correction)| self.apply_correction(frame, correction))
            .collect()
    }

    fn apply_correction(&self, frame: &VideoFrame, correction: &MotionVector) -> VideoFrame {
        let mut result = VideoFrame::new(frame.width, frame.height);

        for y in 0..frame.height {
            for x in 0..frame.width {
                let sx = x as f32 - correction.dx;
                let sy = y as f32 - correction.dy;

                let pixel = if sx >= 0.0 && sx < frame.width as f32 - 1.0 &&
                              sy >= 0.0 && sy < frame.height as f32 - 1.0 {
                    self.bilinear_sample(frame, sx, sy)
                } else {
                    self.handle_border(frame, sx, sy)
                };

                result.set_pixel(x, y, pixel);
            }
        }

        result
    }

    fn bilinear_sample(&self, frame: &VideoFrame, x: f32, y: f32) -> RGB {
        let x0 = x.floor() as u32;
        let y0 = y.floor() as u32;
        let fx = x.fract();
        let fy = y.fract();

        let p00 = frame.get_pixel(x0, y0);
        let p10 = frame.get_pixel(x0 + 1, y0);
        let p01 = frame.get_pixel(x0, y0 + 1);
        let p11 = frame.get_pixel(x0 + 1, y0 + 1);

        RGB {
            r: p00.r * (1.0 - fx) * (1.0 - fy) + p10.r * fx * (1.0 - fy) +
               p01.r * (1.0 - fx) * fy + p11.r * fx * fy,
            g: p00.g * (1.0 - fx) * (1.0 - fy) + p10.g * fx * (1.0 - fy) +
               p01.g * (1.0 - fx) * fy + p11.g * fx * fy,
            b: p00.b * (1.0 - fx) * (1.0 - fy) + p10.b * fx * (1.0 - fy) +
               p01.b * (1.0 - fx) * fy + p11.b * fx * fy,
        }
    }

    fn handle_border(&self, frame: &VideoFrame, x: f32, y: f32) -> RGB {
        match self.border_mode {
            BorderMode::Black => RGB::new(0.0, 0.0, 0.0),
            BorderMode::Replicate => {
                let cx = x.clamp(0.0, frame.width as f32 - 1.0) as u32;
                let cy = y.clamp(0.0, frame.height as f32 - 1.0) as u32;
                frame.get_pixel(cx, cy)
            }
            BorderMode::Reflect => {
                let cx = self.reflect_coord(x, frame.width as f32);
                let cy = self.reflect_coord(y, frame.height as f32);
                frame.get_pixel(cx as u32, cy as u32)
            }
            BorderMode::Blur => RGB::new(0.5, 0.5, 0.5),
        }
    }

    fn reflect_coord(&self, v: f32, max: f32) -> f32 {
        let mut v = v;
        if v < 0.0 { v = -v; }
        if v >= max { v = 2.0 * max - v - 1.0; }
        v.clamp(0.0, max - 1.0)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPATIAL AUDIO (3D AUDIO)
// ═══════════════════════════════════════════════════════════════════════════════

/// 3D position in space
#[derive(Debug, Clone, Copy)]
pub struct Position3D {
    pub x: f32,
    pub y: f32,
    pub z: f32,
}

impl Position3D {
    pub fn new(x: f32, y: f32, z: f32) -> Self {
        Self { x, y, z }
    }

    pub fn origin() -> Self { Self::new(0.0, 0.0, 0.0) }

    pub fn distance(&self, other: &Self) -> f32 {
        let dx = self.x - other.x;
        let dy = self.y - other.y;
        let dz = self.z - other.z;
        (dx * dx + dy * dy + dz * dz).sqrt()
    }

    pub fn azimuth(&self) -> f32 {
        self.x.atan2(self.z)
    }

    pub fn elevation(&self) -> f32 {
        let horizontal = (self.x * self.x + self.z * self.z).sqrt();
        self.y.atan2(horizontal)
    }
}

/// HRTF (Head-Related Transfer Function) for binaural audio
#[derive(Debug, Clone)]
pub struct HRTF {
    pub azimuth_resolution: u32,
    pub elevation_resolution: u32,
    pub ir_length: usize,
    pub left_irs: Vec<Vec<f32>>,
    pub right_irs: Vec<Vec<f32>>,
}

impl HRTF {
    pub fn mit_kemar() -> Self {
        Self {
            azimuth_resolution: 72,
            elevation_resolution: 14,
            ir_length: 128,
            left_irs: vec![vec![0.0; 128]; 72 * 14],
            right_irs: vec![vec![0.0; 128]; 72 * 14],
        }
    }

    pub fn get_ir(&self, azimuth: f32, elevation: f32) -> (&[f32], &[f32]) {
        let az_idx = ((azimuth.to_degrees() + 180.0) / 360.0 * self.azimuth_resolution as f32) as usize
            % self.azimuth_resolution as usize;
        let el_idx = (((elevation.to_degrees() + 90.0) / 180.0 * self.elevation_resolution as f32) as usize)
            .min(self.elevation_resolution as usize - 1);

        let idx = el_idx * self.azimuth_resolution as usize + az_idx;
        (&self.left_irs[idx], &self.right_irs[idx])
    }
}

/// Binaural audio renderer
pub struct BinauralRenderer {
    pub hrtf: HRTF,
    pub listener_pos: Position3D,
    pub listener_forward: Position3D,
    pub listener_up: Position3D,
    pub left_buffer: Vec<f32>,
    pub right_buffer: Vec<f32>,
}

impl BinauralRenderer {
    pub fn new(hrtf: HRTF) -> Self {
        Self {
            hrtf,
            listener_pos: Position3D::origin(),
            listener_forward: Position3D::new(0.0, 0.0, 1.0),
            listener_up: Position3D::new(0.0, 1.0, 0.0),
            left_buffer: Vec::new(),
            right_buffer: Vec::new(),
        }
    }

    pub fn render_source(&mut self, audio: &[f32], source_pos: &Position3D) -> (Vec<f32>, Vec<f32>) {
        let relative = Position3D::new(
            source_pos.x - self.listener_pos.x,
            source_pos.y - self.listener_pos.y,
            source_pos.z - self.listener_pos.z,
        );

        let distance = relative.distance(&Position3D::origin());
        let azimuth = relative.azimuth();
        let elevation = relative.elevation();

        let gain = 1.0 / (1.0 + distance * 0.1);

        let (left_ir, right_ir) = self.hrtf.get_ir(azimuth, elevation);

        let mut left = vec![0.0; audio.len() + left_ir.len() - 1];
        let mut right = vec![0.0; audio.len() + right_ir.len() - 1];

        for (i, &sample) in audio.iter().enumerate() {
            for (j, &h) in left_ir.iter().enumerate() {
                left[i + j] += sample * h * gain;
            }
            for (j, &h) in right_ir.iter().enumerate() {
                right[i + j] += sample * h * gain;
            }
        }

        (left, right)
    }
}

/// Ambisonics encoder/decoder
#[derive(Debug, Clone)]
pub struct AmbisonicsEncoder {
    pub order: u32,
    pub num_channels: usize,
}

impl AmbisonicsEncoder {
    pub fn first_order() -> Self {
        Self { order: 1, num_channels: 4 }
    }

    pub fn second_order() -> Self {
        Self { order: 2, num_channels: 9 }
    }

    pub fn third_order() -> Self {
        Self { order: 3, num_channels: 16 }
    }

    pub fn encode(&self, mono: &[f32], position: &Position3D) -> Vec<Vec<f32>> {
        let az = position.azimuth();
        let el = position.elevation();

        let mut channels = vec![vec![0.0; mono.len()]; self.num_channels];

        channels[0] = mono.to_vec();

        if self.order >= 1 {
            let y1_1 = az.sin() * el.cos();
            let y1_0 = el.sin();
            let y1_neg1 = az.cos() * el.cos();

            for (i, &s) in mono.iter().enumerate() {
                channels[1][i] = s * y1_1;
                channels[2][i] = s * y1_0;
                channels[3][i] = s * y1_neg1;
            }
        }

        if self.order >= 2 && self.num_channels >= 9 {
            let cos_el = el.cos();
            let sin_el = el.sin();
            let cos_2az = (2.0 * az).cos();
            let sin_2az = (2.0 * az).sin();

            for (i, &s) in mono.iter().enumerate() {
                channels[4][i] = s * sin_2az * cos_el * cos_el;
                channels[5][i] = s * az.sin() * sin_el * cos_el;
                channels[6][i] = s * (3.0 * sin_el * sin_el - 1.0) * 0.5;
                channels[7][i] = s * az.cos() * sin_el * cos_el;
                channels[8][i] = s * cos_2az * cos_el * cos_el;
            }
        }

        channels
    }

    pub fn decode_binaural(&self, ambisonic: &[Vec<f32>], hrtf: &HRTF) -> (Vec<f32>, Vec<f32>) {
        if ambisonic.is_empty() || ambisonic[0].is_empty() {
            return (Vec::new(), Vec::new());
        }

        let len = ambisonic[0].len();
        let mut left = vec![0.0; len];
        let mut right = vec![0.0; len];

        let virtual_speakers = [
            (0.0_f32, 0.0_f32), (30.0, 0.0), (-30.0, 0.0), (90.0, 0.0), (-90.0, 0.0),
            (135.0, 0.0), (-135.0, 0.0), (180.0, 0.0),
        ];

        for (az_deg, el_deg) in &virtual_speakers {
            let az = az_deg.to_radians();
            let el = el_deg.to_radians();

            let mut speaker_signal = vec![0.0; len];

            speaker_signal.iter_mut().zip(ambisonic[0].iter()).for_each(|(s, &a)| *s += a * 0.707);

            if self.order >= 1 && ambisonic.len() >= 4 {
                let y1 = [az.sin() * el.cos(), el.sin(), az.cos() * el.cos()];
                for (i, s) in speaker_signal.iter_mut().enumerate() {
                    *s += ambisonic[1][i] * y1[0] + ambisonic[2][i] * y1[1] + ambisonic[3][i] * y1[2];
                }
            }

            let (l_ir, r_ir) = hrtf.get_ir(az, el);
            for (i, &s) in speaker_signal.iter().enumerate() {
                left[i] += s * l_ir.get(0).unwrap_or(&0.5);
                right[i] += s * r_ir.get(0).unwrap_or(&0.5);
            }
        }

        let norm = 1.0 / virtual_speakers.len() as f32;
        left.iter_mut().for_each(|s| *s *= norm);
        right.iter_mut().for_each(|s| *s *= norm);

        (left, right)
    }
}

/// Reverb for spatial audio
pub struct SpatialReverb {
    pub room_size: f32,
    pub damping: f32,
    pub wet_level: f32,
    pub dry_level: f32,
    pub early_reflections: Vec<(f32, f32)>,
    pub comb_filters: Vec<CombFilter>,
    pub allpass_filters: Vec<AllpassFilter>,
}

struct CombFilter {
    buffer: Vec<f32>,
    index: usize,
    feedback: f32,
    damp: f32,
    damp_prev: f32,
}

struct AllpassFilter {
    buffer: Vec<f32>,
    index: usize,
    feedback: f32,
}

impl SpatialReverb {
    pub fn new(room_size: f32, damping: f32) -> Self {
        let comb_delays = [1557, 1617, 1491, 1422, 1277, 1356, 1188, 1116];
        let allpass_delays = [225, 556, 441, 341];

        Self {
            room_size,
            damping,
            wet_level: 0.3,
            dry_level: 0.7,
            early_reflections: vec![
                (0.01, 0.7), (0.02, 0.5), (0.03, 0.4), (0.04, 0.3),
            ],
            comb_filters: comb_delays.iter().map(|&d| CombFilter {
                buffer: vec![0.0; d],
                index: 0,
                feedback: room_size * 0.84,
                damp: damping,
                damp_prev: 0.0,
            }).collect(),
            allpass_filters: allpass_delays.iter().map(|&d| AllpassFilter {
                buffer: vec![0.0; d],
                index: 0,
                feedback: 0.5,
            }).collect(),
        }
    }

    pub fn process(&mut self, input: &[f32]) -> Vec<f32> {
        let mut output = vec![0.0; input.len()];

        for (i, &sample) in input.iter().enumerate() {
            let mut sum = 0.0;

            for comb in &mut self.comb_filters {
                let delayed = comb.buffer[comb.index];
                comb.damp_prev = delayed * (1.0 - comb.damp) + comb.damp_prev * comb.damp;
                comb.buffer[comb.index] = sample + comb.damp_prev * comb.feedback;
                comb.index = (comb.index + 1) % comb.buffer.len();
                sum += delayed;
            }

            sum /= self.comb_filters.len() as f32;

            for allpass in &mut self.allpass_filters {
                let delayed = allpass.buffer[allpass.index];
                let new_sample = sum + delayed * allpass.feedback;
                allpass.buffer[allpass.index] = sum - delayed * allpass.feedback;
                allpass.index = (allpass.index + 1) % allpass.buffer.len();
                sum = new_sample;
            }

            output[i] = sample * self.dry_level + sum * self.wet_level;
        }

        output
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUBTITLE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Subtitle cue
#[derive(Debug, Clone)]
pub struct SubtitleCue {
    pub id: u32,
    pub start_time: f64,
    pub end_time: f64,
    pub text: String,
    pub style: Option<SubtitleStyle>,
    pub position: Option<SubtitlePosition>,
}

/// Subtitle style
#[derive(Debug, Clone)]
pub struct SubtitleStyle {
    pub font_family: String,
    pub font_size: f32,
    pub color: u32,
    pub background_color: Option<u32>,
    pub bold: bool,
    pub italic: bool,
    pub underline: bool,
    pub outline_color: Option<u32>,
    pub outline_width: f32,
    pub shadow_color: Option<u32>,
    pub shadow_offset: (f32, f32),
}

impl SubtitleStyle {
    pub fn default_style() -> Self {
        Self {
            font_family: "Arial".to_string(),
            font_size: 24.0,
            color: 0xFFFFFFFF,
            background_color: Some(0x80000000),
            bold: false,
            italic: false,
            underline: false,
            outline_color: Some(0xFF000000),
            outline_width: 1.0,
            shadow_color: None,
            shadow_offset: (2.0, 2.0),
        }
    }
}

/// Subtitle position
#[derive(Debug, Clone, Copy)]
pub struct SubtitlePosition {
    pub x: f32,
    pub y: f32,
    pub alignment: SubtitleAlignment,
}

#[derive(Debug, Clone, Copy)]
pub enum SubtitleAlignment {
    TopLeft, TopCenter, TopRight,
    MiddleLeft, MiddleCenter, MiddleRight,
    BottomLeft, BottomCenter, BottomRight,
}

/// SRT parser
pub struct SRTParser;

impl SRTParser {
    pub fn parse(content: &str) -> Vec<SubtitleCue> {
        let mut cues = Vec::new();
        let blocks: Vec<&str> = content.split("\n\n").collect();

        for block in blocks {
            let lines: Vec<&str> = block.lines().collect();
            if lines.len() < 3 { continue; }

            let id = lines[0].trim().parse::<u32>().unwrap_or(0);

            let times: Vec<&str> = lines[1].split(" --> ").collect();
            if times.len() != 2 { continue; }

            let start_time = Self::parse_timestamp(times[0]);
            let end_time = Self::parse_timestamp(times[1]);

            let text = lines[2..].join("\n");

            cues.push(SubtitleCue {
                id,
                start_time,
                end_time,
                text,
                style: None,
                position: None,
            });
        }

        cues
    }

    fn parse_timestamp(ts: &str) -> f64 {
        let parts: Vec<&str> = ts.trim().replace(',', ".").split(':').collect();
        if parts.len() != 3 { return 0.0; }

        let hours: f64 = parts[0].parse().unwrap_or(0.0);
        let minutes: f64 = parts[1].parse().unwrap_or(0.0);
        let seconds: f64 = parts[2].parse().unwrap_or(0.0);

        hours * 3600.0 + minutes * 60.0 + seconds
    }

    pub fn write(cues: &[SubtitleCue]) -> String {
        let mut output = String::new();

        for cue in cues {
            output.push_str(&format!("{}\n", cue.id));
            output.push_str(&format!("{} --> {}\n",
                Self::format_timestamp(cue.start_time),
                Self::format_timestamp(cue.end_time)
            ));
            output.push_str(&cue.text);
            output.push_str("\n\n");
        }

        output
    }

    fn format_timestamp(seconds: f64) -> String {
        let hours = (seconds / 3600.0) as u32;
        let minutes = ((seconds % 3600.0) / 60.0) as u32;
        let secs = seconds % 60.0;
        format!("{:02}:{:02}:{:06.3}", hours, minutes, secs).replace('.', ",")
    }
}

/// WebVTT parser
pub struct WebVTTParser;

impl WebVTTParser {
    pub fn parse(content: &str) -> Vec<SubtitleCue> {
        let mut cues = Vec::new();
        let lines: Vec<&str> = content.lines().collect();

        if lines.is_empty() || !lines[0].starts_with("WEBVTT") {
            return cues;
        }

        let mut i = 1;
        let mut cue_id = 1u32;

        while i < lines.len() {
            while i < lines.len() && lines[i].trim().is_empty() {
                i += 1;
            }
            if i >= lines.len() { break; }

            let time_line = if lines[i].contains("-->") {
                lines[i]
            } else {
                i += 1;
                if i >= lines.len() { break; }
                lines[i]
            };
            i += 1;

            let times: Vec<&str> = time_line.split("-->").collect();
            if times.len() != 2 { continue; }

            let start_time = Self::parse_timestamp(times[0].trim());
            let end_time = Self::parse_timestamp(times[1].trim().split_whitespace().next().unwrap_or(""));

            let mut text = String::new();
            while i < lines.len() && !lines[i].trim().is_empty() {
                if !text.is_empty() { text.push('\n'); }
                text.push_str(lines[i]);
                i += 1;
            }

            cues.push(SubtitleCue {
                id: cue_id,
                start_time,
                end_time,
                text,
                style: None,
                position: None,
            });
            cue_id += 1;
        }

        cues
    }

    fn parse_timestamp(ts: &str) -> f64 {
        let parts: Vec<&str> = ts.split(':').collect();
        match parts.len() {
            2 => {
                let minutes: f64 = parts[0].parse().unwrap_or(0.0);
                let seconds: f64 = parts[1].parse().unwrap_or(0.0);
                minutes * 60.0 + seconds
            }
            3 => {
                let hours: f64 = parts[0].parse().unwrap_or(0.0);
                let minutes: f64 = parts[1].parse().unwrap_or(0.0);
                let seconds: f64 = parts[2].parse().unwrap_or(0.0);
                hours * 3600.0 + minutes * 60.0 + seconds
            }
            _ => 0.0,
        }
    }

    pub fn write(cues: &[SubtitleCue]) -> String {
        let mut output = String::from("WEBVTT\n\n");

        for cue in cues {
            output.push_str(&format!("{} --> {}\n",
                Self::format_timestamp(cue.start_time),
                Self::format_timestamp(cue.end_time)
            ));
            output.push_str(&cue.text);
            output.push_str("\n\n");
        }

        output
    }

    fn format_timestamp(seconds: f64) -> String {
        let hours = (seconds / 3600.0) as u32;
        let minutes = ((seconds % 3600.0) / 60.0) as u32;
        let secs = seconds % 60.0;
        if hours > 0 {
            format!("{:02}:{:02}:{:06.3}", hours, minutes, secs)
        } else {
            format!("{:02}:{:06.3}", minutes, secs)
        }
    }
}

/// ASS/SSA subtitle parser
pub struct ASSParser;

impl ASSParser {
    pub fn parse(content: &str) -> Vec<SubtitleCue> {
        let mut cues = Vec::new();
        let mut in_events = false;
        let mut cue_id = 1u32;

        for line in content.lines() {
            if line.starts_with("[Events]") {
                in_events = true;
                continue;
            }

            if line.starts_with("[") {
                in_events = false;
                continue;
            }

            if in_events && line.starts_with("Dialogue:") {
                if let Some(cue) = Self::parse_dialogue(line, cue_id) {
                    cues.push(cue);
                    cue_id += 1;
                }
            }
        }

        cues
    }

    fn parse_dialogue(line: &str, id: u32) -> Option<SubtitleCue> {
        let parts: Vec<&str> = line[9..].splitn(10, ',').collect();
        if parts.len() < 10 { return None; }

        let start_time = Self::parse_timestamp(parts[1]);
        let end_time = Self::parse_timestamp(parts[2]);
        let text = parts[9].replace("\\N", "\n").replace("\\n", "\n");

        Some(SubtitleCue {
            id,
            start_time,
            end_time,
            text,
            style: None,
            position: None,
        })
    }

    fn parse_timestamp(ts: &str) -> f64 {
        let parts: Vec<&str> = ts.trim().split(':').collect();
        if parts.len() != 3 { return 0.0; }

        let hours: f64 = parts[0].parse().unwrap_or(0.0);
        let minutes: f64 = parts[1].parse().unwrap_or(0.0);
        let seconds: f64 = parts[2].parse().unwrap_or(0.0);

        hours * 3600.0 + minutes * 60.0 + seconds
    }
}

/// Subtitle renderer
pub struct SubtitleRenderer {
    pub default_style: SubtitleStyle,
    pub margin: (f32, f32, f32, f32),
}

impl SubtitleRenderer {
    pub fn new() -> Self {
        Self {
            default_style: SubtitleStyle::default_style(),
            margin: (20.0, 20.0, 20.0, 60.0),
        }
    }

    pub fn get_active_cues<'a>(&self, cues: &'a [SubtitleCue], time: f64) -> Vec<&'a SubtitleCue> {
        cues.iter()
            .filter(|c| time >= c.start_time && time < c.end_time)
            .collect()
    }
}

