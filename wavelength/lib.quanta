/// Stream protocol
#[derive(Debug, Clone, Copy)]
pub enum StreamProtocol {
    RTMP,
    RTMPS,
    SRT,
    WebRTC,
    HLS,
    DASH,
}

/// Stream configuration
#[derive(Debug, Clone)]
pub struct StreamConfig {
