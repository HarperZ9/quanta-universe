// AI AUDIO ENHANCEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Voice enhancement for clarity
pub struct VoiceEnhancer {
    sample_rate: u32,
    highpass_freq: f64,
    lowpass_freq: f64,
    de_esser_threshold: f64,
    compressor: DynamicsProcessor,
}

impl VoiceEnhancer {
    pub fn new(sample_rate: u32) -> Self {
        Self {
            sample_rate,
            highpass_freq: 80.0,
            lowpass_freq: 12000.0,
            de_esser_threshold: 0.3,
            compressor: DynamicsProcessor::new(sample_rate as f64),
        }
    }

    pub fn process(&mut self, samples: &[f64]) -> Vec<f64> {
        let mut output = self.apply_highpass(samples);
        output = self.apply_lowpass(&output);
        output = self.de_ess(&output);
        self.compressor.process(&output)
    }

    fn apply_highpass(&self, samples: &[f64]) -> Vec<f64> {
        let rc = 1.0 / (2.0 * std::f64::consts::PI * self.highpass_freq);
        let dt = 1.0 / self.sample_rate as f64;
        let alpha = rc / (rc + dt);

        let mut output = vec![0.0; samples.len()];
        let mut prev_in = 0.0;
        let mut prev_out = 0.0;

        for (i, &sample) in samples.iter().enumerate() {
            output[i] = alpha * (prev_out + sample - prev_in);
            prev_in = sample;
            prev_out = output[i];
        }
        output
    }

    fn apply_lowpass(&self, samples: &[f64]) -> Vec<f64> {
        let rc = 1.0 / (2.0 * std::f64::consts::PI * self.lowpass_freq);
        let dt = 1.0 / self.sample_rate as f64;
        let alpha = dt / (rc + dt);

        let mut output = vec![0.0; samples.len()];
        let mut prev = 0.0;

        for (i, &sample) in samples.iter().enumerate() {
            output[i] = prev + alpha * (sample - prev);
            prev = output[i];
        }
        output
    }

    fn de_ess(&self, samples: &[f64]) -> Vec<f64> {
        let sibilant_low = 4000.0;
        let sibilant_high = 9000.0;
        let mut output = samples.to_vec();

        let window_size = (self.sample_rate as f64 * 0.01) as usize;
        for chunk in output.chunks_mut(window_size) {
            let energy: f64 = chunk.iter().map(|x| x * x).sum::<f64>() / chunk.len() as f64;
            if energy > self.de_esser_threshold * self.de_esser_threshold {
                for sample in chunk.iter_mut() {
                    *sample *= 0.7;
                }
            }
        }
        output
    }
}

/// Spectral noise gate
pub struct SpectralNoiseGate {
    fft_size: usize,
    hop_size: usize,
    threshold_db: f64,
    noise_profile: Vec<f64>,
    reduction_db: f64,
}

impl SpectralNoiseGate {
    pub fn new(fft_size: usize) -> Self {
        Self {
            fft_size,
            hop_size: fft_size / 4,
            threshold_db: -40.0,
            noise_profile: vec![0.0; fft_size / 2 + 1],
            reduction_db: -20.0,
        }
    }

    pub fn learn_noise(&mut self, noise_samples: &[f64]) {
        let num_bins = self.fft_size / 2 + 1;
        let mut accumulator = vec![0.0; num_bins];
        let mut count = 0;

        for chunk in noise_samples.chunks(self.fft_size) {
            if chunk.len() == self.fft_size {
                let spectrum = self.compute_magnitude_spectrum(chunk);
                for (i, mag) in spectrum.iter().enumerate() {
                    accumulator[i] += mag;
                }
                count += 1;
            }
        }

        if count > 0 {
            for (i, val) in self.noise_profile.iter_mut().enumerate() {
                *val = accumulator[i] / count as f64;
            }
        }
    }

    pub fn process(&self, samples: &[f64]) -> Vec<f64> {
        let mut output = Vec::with_capacity(samples.len());
        let reduction = 10.0_f64.powf(self.reduction_db / 20.0);

        for chunk in samples.chunks(self.hop_size) {
            let processed: Vec<f64> = chunk.iter().map(|&s| {
                let level = s.abs();
                let level_db = if level > 0.0 { 20.0 * level.log10() } else { -100.0 };
                if level_db < self.threshold_db {
                    s * reduction
                } else {
                    s
                }
            }).collect();
            output.extend(processed);
        }
        output
    }

    fn compute_magnitude_spectrum(&self, samples: &[f64]) -> Vec<f64> {
        let num_bins = self.fft_size / 2 + 1;
        let mut magnitudes = vec![0.0; num_bins];

        for k in 0..num_bins {
            let mut real = 0.0;
            let mut imag = 0.0;
            for (n, &sample) in samples.iter().enumerate() {
                let angle = -2.0 * std::f64::consts::PI * k as f64 * n as f64 / self.fft_size as f64;
                real += sample * angle.cos();
                imag += sample * angle.sin();
            }
            magnitudes[k] = (real * real + imag * imag).sqrt();
        }
        magnitudes
    }
}

