// AUDIO SIGNAL PROCESSING
// ═══════════════════════════════════════════════════════════════════════════════

/// Complex number for DSP operations
#[derive(Clone, Copy, Debug)]
pub struct Complex {
    pub re: f64,
    pub im: f64,
}

impl Complex {
    pub fn new(re: f64, im: f64) -> Self { Self { re, im } }
    pub fn from_polar(r: f64, theta: f64) -> Self { Self { re: r * theta.cos(), im: r * theta.sin() } }
    pub fn magnitude(&self) -> f64 { (self.re * self.re + self.im * self.im).sqrt() }
    pub fn phase(&self) -> f64 { self.im.atan2(self.re) }
    pub fn conjugate(&self) -> Self { Self { re: self.re, im: -self.im } }
    pub fn add(&self, other: &Self) -> Self { Self { re: self.re + other.re, im: self.im + other.im } }
    pub fn sub(&self, other: &Self) -> Self { Self { re: self.re - other.re, im: self.im - other.im } }
    pub fn mul(&self, other: &Self) -> Self {
        Self { re: self.re * other.re - self.im * other.im, im: self.re * other.im + self.im * other.re }
    }
}

/// Fast Fourier Transform
pub struct FFT {
    size: usize,
    twiddles: Vec<Complex>,
    inverse_twiddles: Vec<Complex>,
}

impl FFT {
    pub fn new(size: usize) -> Self {
        assert!(size.is_power_of_two(), "FFT size must be power of 2");
        let mut twiddles = Vec::with_capacity(size / 2);
        let mut inverse_twiddles = Vec::with_capacity(size / 2);

        for k in 0..size / 2 {
            let angle = -2.0 * std::f64::consts::PI * k as f64 / size as f64;
            twiddles.push(Complex::from_polar(1.0, angle));
            inverse_twiddles.push(Complex::from_polar(1.0, -angle));
        }

        Self { size, twiddles, inverse_twiddles }
    }

    pub fn forward(&self, signal: &[f64]) -> Vec<Complex> {
        let mut buffer: Vec<_> = signal.iter().map(|&x| Complex::new(x, 0.0)).collect();
        buffer.resize(self.size, Complex::new(0.0, 0.0));
        self.fft_recursive(&mut buffer, &self.twiddles);
        buffer
    }

    pub fn inverse(&self, spectrum: &[Complex]) -> Vec<f64> {
        let mut buffer = spectrum.to_vec();
        buffer.resize(self.size, Complex::new(0.0, 0.0));
        self.fft_recursive(&mut buffer, &self.inverse_twiddles);
        let scale = 1.0 / self.size as f64;
        buffer.iter().map(|c| c.re * scale).collect()
    }

    fn fft_recursive(&self, data: &mut [Complex], twiddles: &[Complex]) {
        let n = data.len();
        if n <= 1 { return; }

        let half = n / 2;
        let mut even: Vec<_> = (0..half).map(|i| data[2 * i]).collect();
        let mut odd: Vec<_> = (0..half).map(|i| data[2 * i + 1]).collect();

        let step = self.size / n;
        let sub_twiddles: Vec<_> = (0..half).map(|i| twiddles[i * step]).collect();

        self.fft_recursive(&mut even, &sub_twiddles);
        self.fft_recursive(&mut odd, &sub_twiddles);

        for k in 0..half {
            let t = twiddles[k * step].mul(&odd[k]);
            data[k] = even[k].add(&t);
            data[k + half] = even[k].sub(&t);
        }
    }

    pub fn power_spectrum(&self, signal: &[f64]) -> Vec<f64> {
        self.forward(signal).iter().map(|c| c.magnitude().powi(2)).collect()
    }

    pub fn magnitude_spectrum(&self, signal: &[f64]) -> Vec<f64> {
        self.forward(signal).iter().map(|c| c.magnitude()).collect()
    }
}

/// Audio filter types
pub enum FilterType { LowPass, HighPass, BandPass, BandStop, AllPass }

/// Biquad filter implementation
pub struct BiquadFilter {
    filter_type: FilterType,
    sample_rate: f32,
    frequency: f32,
    q: f32,
    gain_db: f32,
    b0: f64, b1: f64, b2: f64,
    a1: f64, a2: f64,
    x1: f64, x2: f64,
    y1: f64, y2: f64,
}

impl BiquadFilter {
    pub fn new(filter_type: FilterType, sample_rate: f32, frequency: f32, q: f32, gain_db: f32) -> Self {
        let mut filter = Self {
            filter_type, sample_rate, frequency, q, gain_db,
            b0: 1.0, b1: 0.0, b2: 0.0, a1: 0.0, a2: 0.0,
            x1: 0.0, x2: 0.0, y1: 0.0, y2: 0.0,
        };
        filter.calculate_coefficients();
        filter
    }

    fn calculate_coefficients(&mut self) {
        let w0 = 2.0 * std::f64::consts::PI * self.frequency as f64 / self.sample_rate as f64;
        let cos_w0 = w0.cos();
        let sin_w0 = w0.sin();
        let alpha = sin_w0 / (2.0 * self.q as f64);

        match self.filter_type {
            FilterType::LowPass => {
                let b1_norm = 1.0 - cos_w0;
                self.b0 = b1_norm / 2.0;
                self.b1 = b1_norm;
                self.b2 = b1_norm / 2.0;
                self.a1 = -2.0 * cos_w0;
                self.a2 = 1.0 - alpha;
            },
            FilterType::HighPass => {
                let b1_norm = 1.0 + cos_w0;
                self.b0 = b1_norm / 2.0;
                self.b1 = -b1_norm;
                self.b2 = b1_norm / 2.0;
                self.a1 = -2.0 * cos_w0;
                self.a2 = 1.0 - alpha;
            },
            FilterType::BandPass => {
                self.b0 = alpha;
                self.b1 = 0.0;
                self.b2 = -alpha;
                self.a1 = -2.0 * cos_w0;
                self.a2 = 1.0 - alpha;
            },
            FilterType::BandStop => {
                self.b0 = 1.0;
                self.b1 = -2.0 * cos_w0;
                self.b2 = 1.0;
                self.a1 = -2.0 * cos_w0;
                self.a2 = 1.0 - alpha;
            },
            FilterType::AllPass => {
                self.b0 = 1.0 - alpha;
                self.b1 = -2.0 * cos_w0;
                self.b2 = 1.0 + alpha;
                self.a1 = -2.0 * cos_w0;
                self.a2 = 1.0 - alpha;
            },
        }

        let a0 = 1.0 + alpha;
        self.b0 /= a0; self.b1 /= a0; self.b2 /= a0;
        self.a1 /= a0; self.a2 /= a0;
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let output = self.b0 * input + self.b1 * self.x1 + self.b2 * self.x2
                   - self.a1 * self.y1 - self.a2 * self.y2;
        self.x2 = self.x1; self.x1 = input;
        self.y2 = self.y1; self.y1 = output;
        output
    }

    pub fn process_block(&mut self, buffer: &mut [f64]) {
        for sample in buffer.iter_mut() { *sample = self.process(*sample); }
    }

    pub fn reset(&mut self) { self.x1 = 0.0; self.x2 = 0.0; self.y1 = 0.0; self.y2 = 0.0; }
}

/// Audio convolution engine for impulse responses
pub struct ConvolutionEngine {
    impulse_response: Vec<f64>,
    fft: FFT,
    ir_spectrum: Vec<Complex>,
    overlap_buffer: Vec<f64>,
    block_size: usize,
}

impl ConvolutionEngine {
    pub fn new(impulse_response: Vec<f64>, block_size: usize) -> Self {
        let fft_size = (block_size + impulse_response.len() - 1).next_power_of_two();
        let fft = FFT::new(fft_size);
        let ir_spectrum = fft.forward(&impulse_response);

        Self {
            impulse_response,
            fft,
            ir_spectrum,
            overlap_buffer: vec![0.0; fft_size],
            block_size,
        }
    }

    pub fn process(&mut self, input: &[f64]) -> Vec<f64> {
        let input_spectrum = self.fft.forward(input);
        let mut output_spectrum: Vec<_> = input_spectrum.iter()
            .zip(self.ir_spectrum.iter())
            .map(|(a, b)| a.mul(b))
            .collect();

        let output = self.fft.inverse(&output_spectrum);
        let mut result = vec![0.0; self.block_size];

        for i in 0..self.block_size {
            result[i] = output[i] + self.overlap_buffer[i];
        }

        for i in 0..self.overlap_buffer.len() - self.block_size {
            self.overlap_buffer[i] = output.get(i + self.block_size).copied().unwrap_or(0.0);
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIO EFFECTS PROCESSING
// ═══════════════════════════════════════════════════════════════════════════════

/// Delay line for audio effects
pub struct DelayLine {
    buffer: Vec<f64>,
    write_pos: usize,
    delay_samples: usize,
}

impl DelayLine {
    pub fn new(max_delay_samples: usize) -> Self {
        Self { buffer: vec![0.0; max_delay_samples], write_pos: 0, delay_samples: max_delay_samples / 2 }
    }

    pub fn set_delay(&mut self, samples: usize) { self.delay_samples = samples.min(self.buffer.len() - 1); }

    pub fn process(&mut self, input: f64) -> f64 {
        self.buffer[self.write_pos] = input;
        let read_pos = (self.write_pos + self.buffer.len() - self.delay_samples) % self.buffer.len();
        let output = self.buffer[read_pos];
        self.write_pos = (self.write_pos + 1) % self.buffer.len();
        output
    }
}

/// Reverb effect using Schroeder algorithm
pub struct SchroederReverb {
    comb_filters: Vec<(DelayLine, f64)>,
    allpass_filters: Vec<(DelayLine, f64)>,
    wet_mix: f64,
    dry_mix: f64,
}

impl SchroederReverb {
    pub fn new(sample_rate: f32, room_size: f32, damping: f32) -> Self {
        let base_delays = [1557, 1617, 1491, 1422, 1277, 1356, 1188, 1116];
        let allpass_delays = [225, 556, 441, 341];

        let scale = sample_rate / 44100.0;
        let feedback = 0.84 * room_size;

        let comb_filters: Vec<_> = base_delays.iter()
            .map(|&d| {
                let samples = (d as f32 * scale) as usize;
                (DelayLine::new(samples + 1), feedback as f64 * (1.0 - damping as f64 * 0.4))
            })
            .collect();

        let allpass_filters: Vec<_> = allpass_delays.iter()
            .map(|&d| {
                let samples = (d as f32 * scale) as usize;
                (DelayLine::new(samples + 1), 0.5)
            })
            .collect();

        Self { comb_filters, allpass_filters, wet_mix: 0.3, dry_mix: 0.7 }
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let mut comb_sum = 0.0;
        for (delay, feedback) in &mut self.comb_filters {
            let delayed = delay.process(input + comb_sum * *feedback);
            comb_sum += delayed;
        }
        comb_sum /= self.comb_filters.len() as f64;

        let mut output = comb_sum;
        for (delay, coeff) in &mut self.allpass_filters {
            let delayed = delay.process(output);
            output = -output * *coeff + delayed * (1.0 + *coeff);
        }

        input * self.dry_mix + output * self.wet_mix
    }
}

/// Dynamic range compressor
pub struct Compressor {
    threshold_db: f64,
    ratio: f64,
    attack_ms: f64,
    release_ms: f64,
    makeup_gain_db: f64,
    sample_rate: f64,
    envelope: f64,
}

impl Compressor {
    pub fn new(sample_rate: f64, threshold_db: f64, ratio: f64, attack_ms: f64, release_ms: f64) -> Self {
        Self { threshold_db, ratio, attack_ms, release_ms, makeup_gain_db: 0.0, sample_rate, envelope: 0.0 }
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let input_db = 20.0 * input.abs().max(1e-10).log10();
        let attack_coeff = (-1.0 / (self.attack_ms * 0.001 * self.sample_rate)).exp();
        let release_coeff = (-1.0 / (self.release_ms * 0.001 * self.sample_rate)).exp();

        let coeff = if input_db > self.envelope { attack_coeff } else { release_coeff };
        self.envelope = coeff * self.envelope + (1.0 - coeff) * input_db;

        let gain_reduction = if self.envelope > self.threshold_db {
            (self.envelope - self.threshold_db) * (1.0 - 1.0 / self.ratio)
        } else { 0.0 };

        let gain = 10.0_f64.powf((-gain_reduction + self.makeup_gain_db) / 20.0);
        input * gain
    }
}

/// Parametric equalizer with multiple bands
pub struct ParametricEQ {
    bands: Vec<BiquadFilter>,
}

impl ParametricEQ {
    pub fn new(sample_rate: f32) -> Self { Self { bands: Vec::new() } }

    pub fn add_band(&mut self, filter_type: FilterType, frequency: f32, q: f32, gain_db: f32, sample_rate: f32) {
        self.bands.push(BiquadFilter::new(filter_type, sample_rate, frequency, q, gain_db));
    }

    pub fn process(&mut self, input: f64) -> f64 {
        let mut output = input;
        for band in &mut self.bands { output = band.process(output); }
        output
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO PROCESSING PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Pixel format enumeration
pub enum PixelFormat { RGB24, RGBA32, YUV420P, YUV422P, YUV444P, NV12, BGR24, GRAY8 }

/// Video frame buffer
pub struct VideoFrame {
    width: u32,
    height: u32,
    format: PixelFormat,
    data: Vec<u8>,
    stride: Vec<usize>,
    pts: i64,
    dts: i64,
    duration: i64,
}

impl VideoFrame {
    pub fn new(width: u32, height: u32, format: PixelFormat) -> Self {
        let (data, stride) = match &format {
            PixelFormat::RGB24 | PixelFormat::BGR24 => {
                (vec![0u8; width as usize * height as usize * 3], vec![width as usize * 3])
            },
            PixelFormat::RGBA32 => {
                (vec![0u8; width as usize * height as usize * 4], vec![width as usize * 4])
            },
            PixelFormat::YUV420P => {
                let y_size = width as usize * height as usize;
                let uv_size = y_size / 4;
                (vec![0u8; y_size + uv_size * 2], vec![width as usize, width as usize / 2, width as usize / 2])
            },
            PixelFormat::YUV422P => {
                let y_size = width as usize * height as usize;
                let uv_size = y_size / 2;
                (vec![0u8; y_size + uv_size * 2], vec![width as usize, width as usize / 2, width as usize / 2])
            },
            PixelFormat::YUV444P => {
                let plane_size = width as usize * height as usize;
                (vec![0u8; plane_size * 3], vec![width as usize; 3])
            },
            PixelFormat::NV12 => {
                let y_size = width as usize * height as usize;
                (vec![0u8; y_size * 3 / 2], vec![width as usize, width as usize])
            },
            PixelFormat::GRAY8 => {
                (vec![0u8; width as usize * height as usize], vec![width as usize])
            },
        };
        Self { width, height, format, data, stride, pts: 0, dts: 0, duration: 0 }
    }

    pub fn get_pixel(&self, x: u32, y: u32) -> (u8, u8, u8) {
        match self.format {
            PixelFormat::RGB24 => {
                let idx = (y as usize * self.stride[0] + x as usize * 3);
                (self.data[idx], self.data[idx + 1], self.data[idx + 2])
            },
            PixelFormat::YUV420P => {
                let y_idx = y as usize * self.stride[0] + x as usize;
                let uv_x = x as usize / 2;
                let uv_y = y as usize / 2;
                let y_plane_size = self.width as usize * self.height as usize;
                let u_idx = y_plane_size + uv_y * self.stride[1] + uv_x;
                let v_idx = y_plane_size + y_plane_size / 4 + uv_y * self.stride[2] + uv_x;
                (self.data[y_idx], self.data[u_idx], self.data[v_idx])
            },
            _ => (0, 0, 0),
        }
    }
}

/// Color space conversion
pub struct ColorConverter;

impl ColorConverter {
    pub fn yuv_to_rgb(y: u8, u: u8, v: u8) -> (u8, u8, u8) {
        let y = y as f32;
        let u = u as f32 - 128.0;
        let v = v as f32 - 128.0;
        let r = (y + 1.402 * v).clamp(0.0, 255.0) as u8;
        let g = (y - 0.344 * u - 0.714 * v).clamp(0.0, 255.0) as u8;
        let b = (y + 1.772 * u).clamp(0.0, 255.0) as u8;
        (r, g, b)
    }

    pub fn rgb_to_yuv(r: u8, g: u8, b: u8) -> (u8, u8, u8) {
        let r = r as f32; let g = g as f32; let b = b as f32;
        let y = (0.299 * r + 0.587 * g + 0.114 * b).clamp(0.0, 255.0) as u8;
        let u = (-0.169 * r - 0.331 * g + 0.500 * b + 128.0).clamp(0.0, 255.0) as u8;
        let v = (0.500 * r - 0.419 * g - 0.081 * b + 128.0).clamp(0.0, 255.0) as u8;
        (y, u, v)
    }

    pub fn convert(frame: &VideoFrame, target_format: PixelFormat) -> VideoFrame {
        let mut output = VideoFrame::new(frame.width, frame.height, target_format);
        // Conversion logic based on source and target formats
        output
    }
}

/// Video scaler with multiple algorithms
pub struct VideoScaler {
    algorithm: ScaleAlgorithm,
}

pub enum ScaleAlgorithm { NearestNeighbor, Bilinear, Bicubic, Lanczos }

impl VideoScaler {
    pub fn new(algorithm: ScaleAlgorithm) -> Self { Self { algorithm } }

    pub fn scale(&self, input: &VideoFrame, width: u32, height: u32) -> VideoFrame {
        let mut output = VideoFrame::new(width, height, PixelFormat::RGB24);
        let x_ratio = input.width as f64 / width as f64;
        let y_ratio = input.height as f64 / height as f64;

        match self.algorithm {
            ScaleAlgorithm::NearestNeighbor => {
                for y in 0..height {
                    for x in 0..width {
                        let src_x = (x as f64 * x_ratio) as u32;
                        let src_y = (y as f64 * y_ratio) as u32;
                        let pixel = input.get_pixel(src_x, src_y);
                        let idx = (y as usize * output.stride[0] + x as usize * 3);
                        output.data[idx] = pixel.0;
                        output.data[idx + 1] = pixel.1;
                        output.data[idx + 2] = pixel.2;
                    }
                }
            },
            ScaleAlgorithm::Bilinear => {
                for y in 0..height {
                    for x in 0..width {
                        let src_x = x as f64 * x_ratio;
                        let src_y = y as f64 * y_ratio;
                        let pixel = self.bilinear_sample(input, src_x, src_y);
                        let idx = (y as usize * output.stride[0] + x as usize * 3);
                        output.data[idx] = pixel.0;
                        output.data[idx + 1] = pixel.1;
                        output.data[idx + 2] = pixel.2;
                    }
                }
            },
            _ => {},
        }
        output
    }

    fn bilinear_sample(&self, frame: &VideoFrame, x: f64, y: f64) -> (u8, u8, u8) {
        let x0 = x.floor() as u32;
        let y0 = y.floor() as u32;
        let x1 = (x0 + 1).min(frame.width - 1);
        let y1 = (y0 + 1).min(frame.height - 1);
        let xf = x - x0 as f64;
        let yf = y - y0 as f64;

        let p00 = frame.get_pixel(x0, y0);
        let p10 = frame.get_pixel(x1, y0);
        let p01 = frame.get_pixel(x0, y1);
        let p11 = frame.get_pixel(x1, y1);

        let lerp = |a: u8, b: u8, t: f64| (a as f64 * (1.0 - t) + b as f64 * t) as u8;
        let top = (lerp(p00.0, p10.0, xf), lerp(p00.1, p10.1, xf), lerp(p00.2, p10.2, xf));
        let bot = (lerp(p01.0, p11.0, xf), lerp(p01.1, p11.1, xf), lerp(p01.2, p11.2, xf));
        (lerp(top.0, bot.0, yf), lerp(top.1, bot.1, yf), lerp(top.2, bot.2, yf))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUBTITLE PROCESSING
// ═══════════════════════════════════════════════════════════════════════════════

/// Subtitle cue
pub struct SubtitleCue {
    id: u32,
    start_time: i64,
    end_time: i64,
    text: String,
    style: SubtitleStyle,
    position: Option<(f32, f32)>,
}

pub struct SubtitleStyle {
    font_family: String,
    font_size: f32,
    color: (u8, u8, u8, u8),
    background_color: Option<(u8, u8, u8, u8)>,
    bold: bool,
    italic: bool,
    underline: bool,
    outline_width: f32,
    outline_color: (u8, u8, u8),
}

impl SubtitleStyle {
    pub fn default_style() -> Self {
        Self {
            font_family: "Arial".to_string(),
            font_size: 24.0,
            color: (255, 255, 255, 255),
            background_color: Some((0, 0, 0, 128)),
            bold: false, italic: false, underline: false,
            outline_width: 1.0,
            outline_color: (0, 0, 0),
        }
    }
}

/// SRT subtitle parser
pub struct SRTParser;

impl SRTParser {
    pub fn parse(content: &str) -> Vec<SubtitleCue> {
        let mut cues = Vec::new();
        let blocks: Vec<_> = content.split("\n\n").filter(|b| !b.trim().is_empty()).collect();

        for block in blocks {
            let lines: Vec<_> = block.lines().collect();
            if lines.len() >= 3 {
                if let Ok(id) = lines[0].trim().parse::<u32>() {
                    if let Some((start, end)) = Self::parse_timing(lines[1]) {
                        let text = lines[2..].join("\n");
                        cues.push(SubtitleCue {
                            id, start_time: start, end_time: end, text,
                            style: SubtitleStyle::default_style(),
                            position: None,
                        });
                    }
                }
            }
        }
        cues
    }

    fn parse_timing(line: &str) -> Option<(i64, i64)> {
        let parts: Vec<_> = line.split(" --> ").collect();
        if parts.len() == 2 {
            let start = Self::parse_timestamp(parts[0].trim())?;
            let end = Self::parse_timestamp(parts[1].trim())?;
            Some((start, end))
        } else { None }
    }

    fn parse_timestamp(ts: &str) -> Option<i64> {
        let ts = ts.replace(',', ".");
        let parts: Vec<_> = ts.split(':').collect();
        if parts.len() == 3 {
            let hours: i64 = parts[0].parse().ok()?;
            let minutes: i64 = parts[1].parse().ok()?;
            let secs_parts: Vec<_> = parts[2].split('.').collect();
            let seconds: i64 = secs_parts[0].parse().ok()?;
            let millis: i64 = secs_parts.get(1).and_then(|m| m.parse().ok()).unwrap_or(0);
            Some(hours * 3600000 + minutes * 60000 + seconds * 1000 + millis)
        } else { None }
    }
}

/// WebVTT subtitle parser
pub struct VTTParser;

impl VTTParser {
    pub fn parse(content: &str) -> Vec<SubtitleCue> {
        let mut cues = Vec::new();
        let mut id = 0u32;

        for block in content.split("\n\n").skip(1) {
            let lines: Vec<_> = block.lines().collect();
            if lines.len() >= 2 {
                for (i, line) in lines.iter().enumerate() {
                    if line.contains("-->") {
                        if let Some((start, end)) = Self::parse_timing(line) {
                            let text = lines[i + 1..].join("\n");
                            id += 1;
                            cues.push(SubtitleCue {
                                id, start_time: start, end_time: end, text,
                                style: SubtitleStyle::default_style(),
                                position: None,
                            });
                        }
                        break;
                    }
                }
            }
        }
        cues
    }

    fn parse_timing(line: &str) -> Option<(i64, i64)> {
        let parts: Vec<_> = line.split(" --> ").collect();
        if parts.len() >= 2 {
            let start = SRTParser::parse_timestamp(parts[0].trim())?;
            let end_part = parts[1].split_whitespace().next()?;
            let end = SRTParser::parse_timestamp(end_part)?;
            Some((start, end))
        } else { None }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEDIA CONTAINER FORMATS
// ═══════════════════════════════════════════════════════════════════════════════

/// Media container type
pub enum ContainerFormat { MP4, MKV, WebM, AVI, MOV, FLV, TS }

/// Media track information
pub struct MediaTrack {
    track_id: u32,
    track_type: TrackType,
    codec: String,
    bitrate: u32,
    duration: i64,
    language: Option<String>,
    metadata: HashMap<String, String>,
}

pub enum TrackType { Video, Audio, Subtitle, Data }

/// Media container demuxer
pub struct ContainerDemuxer {
    format: ContainerFormat,
    tracks: Vec<MediaTrack>,
    duration: i64,
    bitrate: u32,
    metadata: HashMap<String, String>,
}

impl ContainerDemuxer {
    pub fn open(path: &str) -> Result<Self, String> {
        let format = Self::detect_format(path)?;
        Ok(Self {
            format,
            tracks: Vec::new(),
            duration: 0,
            bitrate: 0,
            metadata: HashMap::new(),
        })
    }

    fn detect_format(path: &str) -> Result<ContainerFormat, String> {
        let ext = path.rsplit('.').next().unwrap_or("").to_lowercase();
        match ext.as_str() {
            "mp4" | "m4v" | "m4a" => Ok(ContainerFormat::MP4),
            "mkv" | "mka" => Ok(ContainerFormat::MKV),
            "webm" => Ok(ContainerFormat::WebM),
            "avi" => Ok(ContainerFormat::AVI),
            "mov" => Ok(ContainerFormat::MOV),
            "flv" => Ok(ContainerFormat::FLV),
            "ts" | "mts" | "m2ts" => Ok(ContainerFormat::TS),
            _ => Err(format!("Unknown format: {}", ext)),
        }
    }

    pub fn get_video_track(&self) -> Option<&MediaTrack> {
        self.tracks.iter().find(|t| matches!(t.track_type, TrackType::Video))
    }

    pub fn get_audio_tracks(&self) -> Vec<&MediaTrack> {
        self.tracks.iter().filter(|t| matches!(t.track_type, TrackType::Audio)).collect()
    }
}

/// Media container muxer
pub struct ContainerMuxer {
    format: ContainerFormat,
    tracks: Vec<MediaTrack>,
    output_path: String,
}

impl ContainerMuxer {
    pub fn new(format: ContainerFormat, output_path: &str) -> Self {
        Self { format, tracks: Vec::new(), output_path: output_path.to_string() }
    }

    pub fn add_track(&mut self, track: MediaTrack) { self.tracks.push(track); }

    pub fn write_header(&mut self) -> Result<(), String> {
        match self.format {
            ContainerFormat::MP4 => self.write_mp4_header(),
            ContainerFormat::MKV => self.write_mkv_header(),
            _ => Ok(()),
        }
    }

    fn write_mp4_header(&mut self) -> Result<(), String> {
        // MP4 ftyp and moov atom structure
        Ok(())
    }

    fn write_mkv_header(&mut self) -> Result<(), String> {
        // Matroska EBML header
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIO VISUALIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Audio visualizer
pub struct AudioVisualizer {
    fft: FFT,
    window: Vec<f64>,
    smoothing: f64,
    previous_magnitudes: Vec<f64>,
}

impl AudioVisualizer {
    pub fn new(fft_size: usize, smoothing: f64) -> Self {
        let window: Vec<_> = (0..fft_size)
            .map(|i| 0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / fft_size as f64).cos()))
            .collect();

        Self { fft: FFT::new(fft_size), window, smoothing, previous_magnitudes: vec![0.0; fft_size / 2] }
    }

    pub fn get_spectrum(&mut self, samples: &[f64]) -> Vec<f64> {
        let windowed: Vec<_> = samples.iter().zip(self.window.iter())
            .map(|(s, w)| s * w)
            .collect();

        let spectrum = self.fft.magnitude_spectrum(&windowed);
        let half_len = spectrum.len() / 2;

        let mut result = Vec::with_capacity(half_len);
        for i in 0..half_len {
            let smoothed = self.smoothing * self.previous_magnitudes[i] + (1.0 - self.smoothing) * spectrum[i];
            self.previous_magnitudes[i] = smoothed;
            result.push(smoothed);
        }
        result
    }

    pub fn get_frequency_bands(&mut self, samples: &[f64], num_bands: usize) -> Vec<f64> {
        let spectrum = self.get_spectrum(samples);
        let band_size = spectrum.len() / num_bands;

        (0..num_bands).map(|i| {
            let start = i * band_size;
            let end = (start + band_size).min(spectrum.len());
            spectrum[start..end].iter().sum::<f64>() / band_size as f64
        }).collect()
    }

    pub fn get_waveform(&self, samples: &[f64], num_points: usize) -> Vec<f64> {
        let chunk_size = samples.len() / num_points;
        (0..num_points).map(|i| {
            let start = i * chunk_size;
            let end = (start + chunk_size).min(samples.len());
            samples[start..end].iter().map(|x| x.abs()).sum::<f64>() / chunk_size as f64
        }).collect()
    }
}

/// VU meter
pub struct VUMeter {
    peak: f64,
    rms: f64,
    peak_hold: f64,
    peak_decay: f64,
    rms_decay: f64,
}

impl VUMeter {
    pub fn new() -> Self {
        Self { peak: 0.0, rms: 0.0, peak_hold: 0.0, peak_decay: 0.995, rms_decay: 0.97 }
    }

    pub fn process(&mut self, samples: &[f64]) {
        let current_peak = samples.iter().map(|s| s.abs()).fold(0.0f64, |a, b| a.max(b));
        let current_rms = (samples.iter().map(|s| s * s).sum::<f64>() / samples.len() as f64).sqrt();

        self.peak = if current_peak > self.peak { current_peak } else { self.peak * self.peak_decay };
        self.rms = self.rms * self.rms_decay + current_rms * (1.0 - self.rms_decay);
        self.peak_hold = if current_peak > self.peak_hold { current_peak } else { (self.peak_hold - 0.001).max(0.0) };
    }

    pub fn get_db(&self) -> (f64, f64) {
        let peak_db = 20.0 * self.peak.max(1e-10).log10();
        let rms_db = 20.0 * self.rms.max(1e-10).log10();
        (peak_db, rms_db)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEDIA PIPELINE MODULE - Production Media Processing Pipelines
// ═══════════════════════════════════════════════════════════════════════════════

pub mod pipeline {
    use std::collections::HashMap;
    use std::sync::{Arc, Mutex};

    /// Pipeline stage trait
    pub trait PipelineStage: Send + Sync {
        fn name(&self) -> &str;
        fn process(&self, input: MediaBuffer) -> Result<MediaBuffer, PipelineError>;
        fn configure(&mut self, config: &HashMap<String, String>);
    }

    /// Media buffer for pipeline data
    #[derive(Clone)]
    pub struct MediaBuffer {
        pub data: Vec<u8>,
        pub format: MediaFormat,
        pub timestamp: f64,
        pub duration: f64,
        pub metadata: HashMap<String, String>,
    }

    impl MediaBuffer {
        pub fn new(format: MediaFormat) -> Self {
            Self {
                data: Vec::new(),
                format,
                timestamp: 0.0,
                duration: 0.0,
                metadata: HashMap::new(),
            }
        }

        pub fn audio(samples: Vec<f32>, sample_rate: u32, channels: u32) -> Self {
            let bytes: Vec<u8> = samples.iter()
                .flat_map(|s| s.to_le_bytes())
                .collect();
            Self {
                data: bytes,
                format: MediaFormat::Audio { sample_rate, channels, bit_depth: 32 },
                timestamp: 0.0,
                duration: samples.len() as f64 / channels as f64 / sample_rate as f64,
                metadata: HashMap::new(),
            }
        }

        pub fn video(pixels: Vec<u8>, width: u32, height: u32) -> Self {
            Self {
                data: pixels,
                format: MediaFormat::Video { width, height, pixel_format: PixelFormat::RGBA },
                timestamp: 0.0,
                duration: 1.0 / 30.0,
                metadata: HashMap::new(),
            }
        }
    }

    /// Media format specification
    #[derive(Clone, Debug)]
    pub enum MediaFormat {
        Audio { sample_rate: u32, channels: u32, bit_depth: u32 },
        Video { width: u32, height: u32, pixel_format: PixelFormat },
        Subtitle { encoding: String },
        Data,
    }

    /// Pixel format
    #[derive(Clone, Copy, Debug, PartialEq, Eq)]
    pub enum PixelFormat {
        RGB,
        RGBA,
        YUV420,
        YUV422,
        YUV444,
        NV12,
        BGR,
        BGRA,
    }

    /// Pipeline error
    #[derive(Debug)]
    pub struct PipelineError {
        pub stage: String,
        pub message: String,
    }

    /// Media processing pipeline
    pub struct MediaPipeline {
        stages: Vec<Box<dyn PipelineStage>>,
        name: String,
        config: HashMap<String, String>,
    }

    impl MediaPipeline {
        pub fn new(name: &str) -> Self {
            Self { stages: Vec::new(), name: name.into(), config: HashMap::new() }
        }

        pub fn add_stage<S: PipelineStage + 'static>(&mut self, stage: S) {
            self.stages.push(Box::new(stage));
        }

        pub fn process(&self, input: MediaBuffer) -> Result<MediaBuffer, PipelineError> {
            let mut buffer = input;
            for stage in &self.stages {
                buffer = stage.process(buffer)?;
            }
            Ok(buffer)
        }

        pub fn process_batch(&self, inputs: Vec<MediaBuffer>) -> Vec<Result<MediaBuffer, PipelineError>> {
            inputs.into_iter().map(|buf| self.process(buf)).collect()
        }
    }

    /// Audio resampler stage
    pub struct Resampler {
        pub target_rate: u32,
        pub quality: ResampleQuality,
    }

    #[derive(Clone, Copy)]
    pub enum ResampleQuality {
        Fastest,
        Low,
        Medium,
        High,
        Best,
    }

    impl Resampler {
        pub fn new(target_rate: u32, quality: ResampleQuality) -> Self {
            Self { target_rate, quality }
        }
    }

    impl PipelineStage for Resampler {
        fn name(&self) -> &str { "Resampler" }

        fn process(&self, input: MediaBuffer) -> Result<MediaBuffer, PipelineError> {
            if let MediaFormat::Audio { sample_rate, channels, bit_depth } = input.format {
                if sample_rate == self.target_rate {
                    return Ok(input);
                }
                let ratio = self.target_rate as f64 / sample_rate as f64;
                let input_samples: Vec<f32> = input.data.chunks(4)
                    .map(|c| f32::from_le_bytes([c[0], c[1], c[2], c[3]]))
                    .collect();
                let output_len = (input_samples.len() as f64 * ratio) as usize;
                let mut output_samples = Vec::with_capacity(output_len);

                // Linear interpolation resampling
                for i in 0..output_len {
                    let src_pos = i as f64 / ratio;
                    let idx = src_pos.floor() as usize;
                    let frac = src_pos.fract() as f32;
                    let s0 = input_samples.get(idx).copied().unwrap_or(0.0);
                    let s1 = input_samples.get(idx + 1).copied().unwrap_or(s0);
                    output_samples.push(s0 + (s1 - s0) * frac);
                }

                Ok(MediaBuffer::audio(output_samples, self.target_rate, channels))
            } else {
                Err(PipelineError { stage: self.name().into(), message: "Not audio".into() })
            }
        }

        fn configure(&mut self, config: &HashMap<String, String>) {
            if let Some(rate) = config.get("target_rate") {
                self.target_rate = rate.parse().unwrap_or(self.target_rate);
            }
        }
    }

    /// Video scaler stage
    pub struct VideoScaler {
        pub target_width: u32,
        pub target_height: u32,
        pub algorithm: ScaleAlgorithm,
    }

    #[derive(Clone, Copy)]
    pub enum ScaleAlgorithm {
        NearestNeighbor,
        Bilinear,
        Bicubic,
        Lanczos,
    }

    impl VideoScaler {
        pub fn new(width: u32, height: u32, algo: ScaleAlgorithm) -> Self {
            Self { target_width: width, target_height: height, algorithm: algo }
        }
    }

    impl PipelineStage for VideoScaler {
        fn name(&self) -> &str { "VideoScaler" }

        fn process(&self, input: MediaBuffer) -> Result<MediaBuffer, PipelineError> {
            if let MediaFormat::Video { width, height, pixel_format } = input.format {
                if width == self.target_width && height == self.target_height {
                    return Ok(input);
                }
                let channels = match pixel_format {
                    PixelFormat::RGB | PixelFormat::BGR => 3,
                    PixelFormat::RGBA | PixelFormat::BGRA => 4,
                    _ => return Err(PipelineError { stage: self.name().into(), message: "Unsupported format".into() }),
                };
                let mut output = vec![0u8; (self.target_width * self.target_height * channels) as usize];
                let x_ratio = width as f64 / self.target_width as f64;
                let y_ratio = height as f64 / self.target_height as f64;

                for y in 0..self.target_height {
                    for x in 0..self.target_width {
                        let src_x = (x as f64 * x_ratio) as u32;
                        let src_y = (y as f64 * y_ratio) as u32;
                        let src_idx = ((src_y * width + src_x) * channels) as usize;
                        let dst_idx = ((y * self.target_width + x) * channels) as usize;
                        for c in 0..channels as usize {
                            output[dst_idx + c] = input.data.get(src_idx + c).copied().unwrap_or(0);
                        }
                    }
                }

                Ok(MediaBuffer {
                    data: output,
                    format: MediaFormat::Video {
                        width: self.target_width,
                        height: self.target_height,
                        pixel_format,
                    },
                    ..input
                })
            } else {
                Err(PipelineError { stage: self.name().into(), message: "Not video".into() })
            }
        }

        fn configure(&mut self, config: &HashMap<String, String>) {
            if let Some(w) = config.get("width") { self.target_width = w.parse().unwrap_or(self.target_width); }
            if let Some(h) = config.get("height") { self.target_height = h.parse().unwrap_or(self.target_height); }
        }
    }

    /// Audio mixer stage
    pub struct AudioMixer {
        pub tracks: Vec<MixerTrack>,
        pub master_gain: f32,
    }

    pub struct MixerTrack {
        pub name: String,
        pub gain: f32,
        pub pan: f32,
        pub muted: bool,
        pub solo: bool,
    }

    impl AudioMixer {
        pub fn new() -> Self {
            Self { tracks: Vec::new(), master_gain: 1.0 }
        }

        pub fn add_track(&mut self, name: &str, gain: f32) {
            self.tracks.push(MixerTrack {
                name: name.into(),
                gain,
                pan: 0.0,
                muted: false,
                solo: false,
            });
        }

        pub fn mix(&self, buffers: &[MediaBuffer]) -> MediaBuffer {
            if buffers.is_empty() { return MediaBuffer::new(MediaFormat::Data); }
            let first = &buffers[0];
            if let MediaFormat::Audio { sample_rate, channels, bit_depth } = first.format {
                let max_len = buffers.iter().map(|b| b.data.len()).max().unwrap_or(0);
                let mut mixed = vec![0.0f32; max_len / 4];
                let has_solo = self.tracks.iter().any(|t| t.solo);

                for (i, (buf, track)) in buffers.iter().zip(&self.tracks).enumerate() {
                    if track.muted { continue; }
                    if has_solo && !track.solo { continue; }
                    let samples: Vec<f32> = buf.data.chunks(4)
                        .map(|c| f32::from_le_bytes([c[0], c[1], c[2], c[3]]))
                        .collect();
                    for (j, s) in samples.iter().enumerate() {
                        if j < mixed.len() {
                            mixed[j] += s * track.gain;
                        }
                    }
                }

                // Apply master gain
                for s in &mut mixed { *s *= self.master_gain; }
                MediaBuffer::audio(mixed, sample_rate, channels)
            } else {
                buffers[0].clone()
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LOUDNESS MODULE - Broadcast Loudness Standards
// ═══════════════════════════════════════════════════════════════════════════════

pub mod loudness {
    /// Loudness measurement types
    #[derive(Debug, Clone, Copy)]
    pub enum LoudnessType {
        Momentary,    // 400ms window
        ShortTerm,    // 3s window
        Integrated,   // Full program
    }

    /// EBU R128 loudness meter
    pub struct LoudnessMeter {
        sample_rate: u32,
        channels: u32,
        momentary_buffer: Vec<f64>,
        short_term_buffer: Vec<f64>,
        integrated_sum: f64,
        integrated_count: usize,
        k_filter: KWeightingFilter,
    }

    impl LoudnessMeter {
        pub fn new(sample_rate: u32, channels: u32) -> Self {
            Self {
                sample_rate,
                channels,
                momentary_buffer: Vec::with_capacity(sample_rate as usize * 400 / 1000),
                short_term_buffer: Vec::with_capacity(sample_rate as usize * 3),
                integrated_sum: 0.0,
                integrated_count: 0,
                k_filter: KWeightingFilter::new(sample_rate as f64),
            }
        }

        pub fn process(&mut self, samples: &[f64]) {
            let filtered: Vec<f64> = samples.iter().map(|s| self.k_filter.process(*s)).collect();
            let power: f64 = filtered.iter().map(|s| s * s).sum::<f64>() / filtered.len() as f64;
            self.momentary_buffer.push(power);
            self.short_term_buffer.push(power);

            let momentary_size = self.sample_rate as usize * 400 / 1000 / 1024;
            if self.momentary_buffer.len() > momentary_size {
                self.momentary_buffer.remove(0);
            }
            let short_term_size = self.sample_rate as usize * 3 / 1024;
            if self.short_term_buffer.len() > short_term_size {
                self.short_term_buffer.remove(0);
            }
            self.integrated_sum += power;
            self.integrated_count += 1;
        }

        pub fn momentary_loudness(&self) -> f64 {
            if self.momentary_buffer.is_empty() { return -70.0; }
            let mean = self.momentary_buffer.iter().sum::<f64>() / self.momentary_buffer.len() as f64;
            -0.691 + 10.0 * mean.max(1e-10).log10()
        }

        pub fn short_term_loudness(&self) -> f64 {
            if self.short_term_buffer.is_empty() { return -70.0; }
            let mean = self.short_term_buffer.iter().sum::<f64>() / self.short_term_buffer.len() as f64;
            -0.691 + 10.0 * mean.max(1e-10).log10()
        }

        pub fn integrated_loudness(&self) -> f64 {
            if self.integrated_count == 0 { return -70.0; }
            let mean = self.integrated_sum / self.integrated_count as f64;
            -0.691 + 10.0 * mean.max(1e-10).log10()
        }

        pub fn reset(&mut self) {
            self.momentary_buffer.clear();
            self.short_term_buffer.clear();
            self.integrated_sum = 0.0;
            self.integrated_count = 0;
        }
    }

    /// K-weighting filter for loudness measurement
    struct KWeightingFilter {
        // Pre-filter (high-shelf boost at 1500 Hz)
        pre_b: [f64; 3],
        pre_a: [f64; 3],
        pre_z: [f64; 2],
        // RLB filter (high-pass at 38 Hz)
        rlb_b: [f64; 3],
        rlb_a: [f64; 3],
        rlb_z: [f64; 2],
    }

    impl KWeightingFilter {
        pub fn new(sample_rate: f64) -> Self {
            // Pre-filter coefficients (high-shelf +4dB at 1500Hz)
            let f0 = 1681.974450955533;
            let g = 3.999843853973347;
            let q = 0.7071752369554196;
            let k = (std::f64::consts::PI * f0 / sample_rate).tan();
            let vh = (10.0f64).powf(g / 20.0);
            let vb = vh.powf(0.4996667741545416);
            let a0 = 1.0 + k / q + k * k;
            let pre_b = [
                (vh + vb * k / q + k * k) / a0,
                2.0 * (k * k - vh) / a0,
                (vh - vb * k / q + k * k) / a0,
            ];
            let pre_a = [1.0, 2.0 * (k * k - 1.0) / a0, (1.0 - k / q + k * k) / a0];

            // RLB filter coefficients (high-pass at 38Hz)
            let fc = 38.13547087602444;
            let k = (std::f64::consts::PI * fc / sample_rate).tan();
            let a0 = 1.0 + k * k + k * std::f64::consts::SQRT_2;
            let rlb_b = [1.0, -2.0, 1.0];
            let rlb_a = [
                1.0,
                2.0 * (k * k - 1.0) / a0,
                (1.0 + k * k - k * std::f64::consts::SQRT_2) / a0,
            ];

            Self {
                pre_b,
                pre_a,
                pre_z: [0.0, 0.0],
                rlb_b,
                rlb_a,
                rlb_z: [0.0, 0.0],
            }
        }

        pub fn process(&mut self, x: f64) -> f64 {
            // Pre-filter
            let y1 = self.pre_b[0] * x + self.pre_z[0];
            self.pre_z[0] = self.pre_b[1] * x - self.pre_a[1] * y1 + self.pre_z[1];
            self.pre_z[1] = self.pre_b[2] * x - self.pre_a[2] * y1;

            // RLB filter
            let y2 = self.rlb_b[0] * y1 + self.rlb_z[0];
            self.rlb_z[0] = self.rlb_b[1] * y1 - self.rlb_a[1] * y2 + self.rlb_z[1];
            self.rlb_z[1] = self.rlb_b[2] * y1 - self.rlb_a[2] * y2;

            y2
        }
    }

    /// True Peak meter (oversampled)
    pub struct TruePeakMeter {
        upsample_factor: usize,
        filter_coeffs: Vec<f64>,
        buffer: Vec<f64>,
        max_true_peak: f64,
    }

    impl TruePeakMeter {
        pub fn new() -> Self {
            // 4x oversampling with sinc filter
            let upsample_factor = 4;
            let filter_len = 49;
            let mut filter_coeffs = Vec::with_capacity(filter_len);
            for i in 0..filter_len {
                let n = i as f64 - (filter_len - 1) as f64 / 2.0;
                let sinc = if n.abs() < 1e-10 { 1.0 } else { (std::f64::consts::PI * n / upsample_factor as f64).sin() / (std::f64::consts::PI * n / upsample_factor as f64) };
                // Blackman window
                let window = 0.42 - 0.5 * (2.0 * std::f64::consts::PI * i as f64 / (filter_len - 1) as f64).cos()
                           + 0.08 * (4.0 * std::f64::consts::PI * i as f64 / (filter_len - 1) as f64).cos();
                filter_coeffs.push(sinc * window);
            }

            Self {
                upsample_factor,
                filter_coeffs,
                buffer: vec![0.0; filter_len],
                max_true_peak: 0.0,
            }
        }

        pub fn process(&mut self, sample: f64) -> f64 {
            self.buffer.remove(0);
            self.buffer.push(sample);

            let mut max_interp = sample.abs();
            for phase in 1..self.upsample_factor {
                let mut interp = 0.0;
                for (i, &coeff) in self.filter_coeffs.iter().enumerate() {
                    let buf_idx = i / self.upsample_factor;
                    if buf_idx < self.buffer.len() && i % self.upsample_factor == phase {
                        interp += self.buffer[buf_idx] * coeff;
                    }
                }
                max_interp = max_interp.max(interp.abs());
            }

            self.max_true_peak = self.max_true_peak.max(max_interp);
            max_interp
        }

        pub fn true_peak_dbtp(&self) -> f64 {
            20.0 * self.max_true_peak.max(1e-10).log10()
        }

        pub fn reset(&mut self) {
            self.buffer.fill(0.0);
            self.max_true_peak = 0.0;
        }
    }

    /// Loudness normalizer
    pub struct LoudnessNormalizer {
        target_lufs: f64,
        max_true_peak_dbtp: f64,
    }

    impl LoudnessNormalizer {
        pub fn new(target_lufs: f64, max_true_peak_dbtp: f64) -> Self {
            Self { target_lufs, max_true_peak_dbtp }
        }

        pub fn calculate_gain(&self, current_lufs: f64, current_true_peak: f64) -> f64 {
            let loudness_gain_db = self.target_lufs - current_lufs;
            let peak_headroom_db = self.max_true_peak_dbtp - current_true_peak;
            let gain_db = loudness_gain_db.min(peak_headroom_db);
            10.0f64.powf(gain_db / 20.0)
        }

        pub fn normalize(&self, samples: &mut [f64], current_lufs: f64, current_true_peak: f64) {
            let gain = self.calculate_gain(current_lufs, current_true_peak);
            for s in samples.iter_mut() {
                *s *= gain;
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// IMAGE PROCESSING MODULE - Advanced Image Operations
// ═══════════════════════════════════════════════════════════════════════════════

pub mod imaging {
    /// Image buffer
    pub struct Image {
        pub width: u32,
        pub height: u32,
        pub channels: u32,
        pub data: Vec<f32>,
    }

    impl Image {
        pub fn new(width: u32, height: u32, channels: u32) -> Self {
            Self {
                width, height, channels,
                data: vec![0.0; (width * height * channels) as usize],
            }
        }

        pub fn from_data(width: u32, height: u32, channels: u32, data: Vec<f32>) -> Self {
            Self { width, height, channels, data }
        }

        pub fn get_pixel(&self, x: u32, y: u32) -> &[f32] {
            let idx = ((y * self.width + x) * self.channels) as usize;
            &self.data[idx..idx + self.channels as usize]
        }

        pub fn set_pixel(&mut self, x: u32, y: u32, pixel: &[f32]) {
            let idx = ((y * self.width + x) * self.channels) as usize;
            for (i, &v) in pixel.iter().enumerate() {
                self.data[idx + i] = v;
            }
        }

        pub fn clone_image(&self) -> Self {
            Self {
                width: self.width,
                height: self.height,
                channels: self.channels,
                data: self.data.clone(),
            }
        }
    }

    /// Gaussian blur
    pub fn gaussian_blur(img: &Image, sigma: f32) -> Image {
        let kernel_size = (sigma * 6.0).ceil() as usize | 1;
        let half = kernel_size / 2;
        let mut kernel = vec![0.0f32; kernel_size];
        let mut sum = 0.0;
        for i in 0..kernel_size {
            let x = i as f32 - half as f32;
            kernel[i] = (-x * x / (2.0 * sigma * sigma)).exp();
            sum += kernel[i];
        }
        for k in &mut kernel { *k /= sum; }

        let mut temp = Image::new(img.width, img.height, img.channels);
        let mut result = Image::new(img.width, img.height, img.channels);

        // Horizontal pass
        for y in 0..img.height {
            for x in 0..img.width {
                let mut pixel = vec![0.0f32; img.channels as usize];
                for (i, &k) in kernel.iter().enumerate() {
                    let sx = (x as i32 + i as i32 - half as i32).clamp(0, img.width as i32 - 1) as u32;
                    let src = img.get_pixel(sx, y);
                    for c in 0..img.channels as usize {
                        pixel[c] += src[c] * k;
                    }
                }
                temp.set_pixel(x, y, &pixel);
            }
        }

        // Vertical pass
        for y in 0..img.height {
            for x in 0..img.width {
                let mut pixel = vec![0.0f32; img.channels as usize];
                for (i, &k) in kernel.iter().enumerate() {
                    let sy = (y as i32 + i as i32 - half as i32).clamp(0, img.height as i32 - 1) as u32;
                    let src = temp.get_pixel(x, sy);
                    for c in 0..img.channels as usize {
                        pixel[c] += src[c] * k;
                    }
                }
                result.set_pixel(x, y, &pixel);
            }
        }
        result
    }

    /// Unsharp mask sharpening
    pub fn unsharp_mask(img: &Image, sigma: f32, amount: f32, threshold: f32) -> Image {
        let blurred = gaussian_blur(img, sigma);
        let mut result = Image::new(img.width, img.height, img.channels);

        for y in 0..img.height {
            for x in 0..img.width {
                let orig = img.get_pixel(x, y);
                let blur = blurred.get_pixel(x, y);
                let mut pixel = vec![0.0f32; img.channels as usize];
                for c in 0..img.channels as usize {
                    let diff = orig[c] - blur[c];
                    if diff.abs() > threshold {
                        pixel[c] = (orig[c] + diff * amount).clamp(0.0, 1.0);
                    } else {
                        pixel[c] = orig[c];
                    }
                }
                result.set_pixel(x, y, &pixel);
            }
        }
        result
    }

    /// Histogram equalization
    pub fn histogram_equalize(img: &Image) -> Image {
        let mut result = Image::new(img.width, img.height, img.channels);
        let num_pixels = (img.width * img.height) as usize;

        for c in 0..img.channels as usize {
            // Build histogram
            let mut histogram = vec![0usize; 256];
            for i in 0..num_pixels {
                let val = (img.data[i * img.channels as usize + c] * 255.0).clamp(0.0, 255.0) as usize;
                histogram[val] += 1;
            }

            // Compute CDF
            let mut cdf = vec![0usize; 256];
            cdf[0] = histogram[0];
            for i in 1..256 { cdf[i] = cdf[i - 1] + histogram[i]; }

            // Normalize CDF
            let cdf_min = cdf.iter().find(|&&v| v > 0).copied().unwrap_or(0);
            let scale = 255.0 / (num_pixels - cdf_min) as f32;

            // Apply equalization
            for i in 0..num_pixels {
                let val = (img.data[i * img.channels as usize + c] * 255.0).clamp(0.0, 255.0) as usize;
                let eq_val = ((cdf[val] - cdf_min) as f32 * scale).clamp(0.0, 255.0) / 255.0;
                result.data[i * img.channels as usize + c] = eq_val;
            }
        }
        result
    }

    /// Morphological operations
    pub fn erode(img: &Image, kernel_size: usize) -> Image {
        let half = kernel_size / 2;
        let mut result = Image::new(img.width, img.height, img.channels);

        for y in 0..img.height {
            for x in 0..img.width {
                let mut min_pixel = vec![1.0f32; img.channels as usize];
                for ky in 0..kernel_size {
                    for kx in 0..kernel_size {
                        let sx = (x as i32 + kx as i32 - half as i32).clamp(0, img.width as i32 - 1) as u32;
                        let sy = (y as i32 + ky as i32 - half as i32).clamp(0, img.height as i32 - 1) as u32;
                        let src = img.get_pixel(sx, sy);
                        for c in 0..img.channels as usize {
                            min_pixel[c] = min_pixel[c].min(src[c]);
                        }
                    }
                }
                result.set_pixel(x, y, &min_pixel);
            }
        }
        result
    }

    pub fn dilate(img: &Image, kernel_size: usize) -> Image {
        let half = kernel_size / 2;
        let mut result = Image::new(img.width, img.height, img.channels);

        for y in 0..img.height {
            for x in 0..img.width {
                let mut max_pixel = vec![0.0f32; img.channels as usize];
                for ky in 0..kernel_size {
                    for kx in 0..kernel_size {
                        let sx = (x as i32 + kx as i32 - half as i32).clamp(0, img.width as i32 - 1) as u32;
                        let sy = (y as i32 + ky as i32 - half as i32).clamp(0, img.height as i32 - 1) as u32;
                        let src = img.get_pixel(sx, sy);
                        for c in 0..img.channels as usize {
                            max_pixel[c] = max_pixel[c].max(src[c]);
                        }
                    }
                }
                result.set_pixel(x, y, &max_pixel);
            }
        }
        result
    }

    /// Edge-preserving filter (bilateral-like)
    pub fn edge_preserve_smooth(img: &Image, sigma_space: f32, sigma_color: f32) -> Image {
        let kernel_size = (sigma_space * 3.0).ceil() as i32;
        let mut result = Image::new(img.width, img.height, img.channels);

        for y in 0..img.height {
            for x in 0..img.width {
                let center = img.get_pixel(x, y);
                let mut sum_weight = 0.0f32;
                let mut sum_pixel = vec![0.0f32; img.channels as usize];

                for dy in -kernel_size..=kernel_size {
                    for dx in -kernel_size..=kernel_size {
                        let nx = (x as i32 + dx).clamp(0, img.width as i32 - 1) as u32;
                        let ny = (y as i32 + dy).clamp(0, img.height as i32 - 1) as u32;
                        let neighbor = img.get_pixel(nx, ny);

                        let spatial_dist = (dx * dx + dy * dy) as f32;
                        let spatial_weight = (-spatial_dist / (2.0 * sigma_space * sigma_space)).exp();

                        let mut color_dist = 0.0f32;
                        for c in 0..img.channels as usize {
                            color_dist += (center[c] - neighbor[c]).powi(2);
                        }
                        let color_weight = (-color_dist / (2.0 * sigma_color * sigma_color)).exp();

                        let weight = spatial_weight * color_weight;
                        sum_weight += weight;
                        for c in 0..img.channels as usize {
                            sum_pixel[c] += neighbor[c] * weight;
                        }
                    }
                }

                for c in 0..img.channels as usize {
                    sum_pixel[c] /= sum_weight;
                }
                result.set_pixel(x, y, &sum_pixel);
            }
        }
        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Advanced Audio DSP - Production Ready
// ═══════════════════════════════════════════════════════════════════════════════

pub mod advanced_audio {
    use super::*;

    // Multiband Dynamics Processing
    pub struct MultibandCompressor { pub bands: Vec<CompressorBand>, pub crossover_freqs: Vec<f32>, pub sample_rate: f32 }
    pub struct CompressorBand { pub low_freq: f32, pub high_freq: f32, pub threshold_db: f32, pub ratio: f32, pub attack_ms: f32, pub release_ms: f32, pub knee_db: f32, pub makeup_gain_db: f32, envelope: f32 }
    impl CompressorBand {
        pub fn new(low: f32, high: f32) -> Self { Self { low_freq: low, high_freq: high, threshold_db: -20.0, ratio: 4.0, attack_ms: 10.0, release_ms: 100.0, knee_db: 6.0, makeup_gain_db: 0.0, envelope: 0.0 } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let input_db = 20.0 * (input.abs() + 1e-10).log10();
            let attack_coef = (-1.0 / (self.attack_ms * 0.001 * sample_rate)).exp();
            let release_coef = (-1.0 / (self.release_ms * 0.001 * sample_rate)).exp();
            self.envelope = if input_db > self.envelope { attack_coef * self.envelope + (1.0 - attack_coef) * input_db } else { release_coef * self.envelope + (1.0 - release_coef) * input_db };
            let over_threshold = self.envelope - self.threshold_db;
            let gain_reduction = if over_threshold <= -self.knee_db { 0.0 } else if over_threshold >= self.knee_db { over_threshold * (1.0 - 1.0 / self.ratio) } else { let x = over_threshold + self.knee_db; (1.0 - 1.0 / self.ratio) * x * x / (4.0 * self.knee_db) };
            let gain = 10.0_f32.powf((-gain_reduction + self.makeup_gain_db) / 20.0);
            input * gain
        }
    }
    impl MultibandCompressor {
        pub fn new(sample_rate: f32, num_bands: usize) -> Self {
            let mut freqs = Vec::new();
            let mut bands = Vec::new();
            let base = 100.0; let mult = 4.0;
            for i in 0..num_bands {
                let low = if i == 0 { 20.0 } else { freqs[i - 1] };
                let high = if i == num_bands - 1 { sample_rate / 2.0 } else { base * mult.powi(i as i32) };
                if i < num_bands - 1 { freqs.push(high); }
                bands.push(CompressorBand::new(low, high));
            }
            Self { bands, crossover_freqs: freqs, sample_rate }
        }
    }

    // Limiter
    pub struct Limiter { pub threshold_db: f32, pub release_ms: f32, pub lookahead_ms: f32, buffer: Vec<f32>, envelope: f32, write_pos: usize }
    impl Limiter {
        pub fn new(lookahead_ms: f32, sample_rate: f32) -> Self {
            let size = (lookahead_ms * 0.001 * sample_rate) as usize + 1;
            Self { threshold_db: -0.3, release_ms: 100.0, lookahead_ms, buffer: vec![0.0; size], envelope: 0.0, write_pos: 0 }
        }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let delayed = self.buffer[self.write_pos];
            self.buffer[self.write_pos] = input;
            self.write_pos = (self.write_pos + 1) % self.buffer.len();
            let peak = input.abs();
            let release_coef = (-1.0 / (self.release_ms * 0.001 * sample_rate)).exp();
            self.envelope = if peak > self.envelope { peak } else { release_coef * self.envelope + (1.0 - release_coef) * peak };
            let threshold_linear = 10.0_f32.powf(self.threshold_db / 20.0);
            let gain = if self.envelope > threshold_linear { threshold_linear / self.envelope } else { 1.0 };
            delayed * gain
        }
    }

    // Gate / Expander
    pub struct Gate { pub threshold_db: f32, pub ratio: f32, pub attack_ms: f32, pub release_ms: f32, pub hold_ms: f32, pub range_db: f32, envelope: f32, hold_counter: u32 }
    impl Gate {
        pub fn new() -> Self { Self { threshold_db: -40.0, ratio: 10.0, attack_ms: 1.0, release_ms: 50.0, hold_ms: 20.0, range_db: -80.0, envelope: 0.0, hold_counter: 0 } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let input_db = 20.0 * (input.abs() + 1e-10).log10();
            let attack_coef = (-1.0 / (self.attack_ms * 0.001 * sample_rate)).exp();
            let release_coef = (-1.0 / (self.release_ms * 0.001 * sample_rate)).exp();
            let hold_samples = (self.hold_ms * 0.001 * sample_rate) as u32;
            if input_db > self.threshold_db { self.envelope = attack_coef * self.envelope + (1.0 - attack_coef) * 1.0; self.hold_counter = hold_samples; }
            else if self.hold_counter > 0 { self.hold_counter -= 1; }
            else { let target = 10.0_f32.powf(self.range_db / 20.0); self.envelope = release_coef * self.envelope + (1.0 - release_coef) * target; }
            input * self.envelope
        }
    }

    // De-esser
    pub struct DeEsser { pub freq_low: f32, pub freq_high: f32, pub threshold_db: f32, pub ratio: f32, envelope: f32, filter_state: [f32; 2] }
    impl DeEsser {
        pub fn new() -> Self { Self { freq_low: 4000.0, freq_high: 9000.0, threshold_db: -20.0, ratio: 4.0, envelope: 0.0, filter_state: [0.0; 2] } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let center = (self.freq_low * self.freq_high).sqrt();
            let q = center / (self.freq_high - self.freq_low);
            let w0 = 2.0 * std::f32::consts::PI * center / sample_rate;
            let alpha = w0.sin() / (2.0 * q);
            let b0 = alpha; let b1 = 0.0; let b2 = -alpha;
            let a0 = 1.0 + alpha; let a1 = -2.0 * w0.cos(); let a2 = 1.0 - alpha;
            let sibilance = (b0 / a0) * input + self.filter_state[0];
            self.filter_state[0] = (b1 / a0) * input - (a1 / a0) * sibilance + self.filter_state[1];
            self.filter_state[1] = (b2 / a0) * input - (a2 / a0) * sibilance;
            let sib_db = 20.0 * (sibilance.abs() + 1e-10).log10();
            let attack_coef = 0.99; let release_coef = 0.9995;
            self.envelope = if sib_db > self.envelope { attack_coef * self.envelope + (1.0 - attack_coef) * sib_db } else { release_coef * self.envelope + (1.0 - release_coef) * sib_db };
            let over = self.envelope - self.threshold_db;
            let reduction = if over > 0.0 { over * (1.0 - 1.0 / self.ratio) } else { 0.0 };
            let gain = 10.0_f32.powf(-reduction / 20.0);
            input - sibilance * (1.0 - gain)
        }
    }

    // Exciter / Harmonic Generator
    pub struct Exciter { pub drive: f32, pub mix: f32, pub high_freq: f32 }
    impl Exciter {
        pub fn new() -> Self { Self { drive: 1.5, mix: 0.3, high_freq: 3000.0 } }
        pub fn process(&self, input: f32) -> f32 {
            let driven = (input * self.drive).tanh();
            let harmonics = driven - input;
            input + harmonics * self.mix
        }
    }

    // Stereo Enhancer
    pub struct StereoEnhancer { pub width: f32, pub bass_mono_freq: f32, pub mid_side_balance: f32 }
    impl StereoEnhancer {
        pub fn new() -> Self { Self { width: 1.5, bass_mono_freq: 120.0, mid_side_balance: 0.0 } }
        pub fn process(&self, left: f32, right: f32) -> (f32, f32) {
            let mid = (left + right) * 0.5;
            let side = (left - right) * 0.5 * self.width;
            let new_left = mid + side;
            let new_right = mid - side;
            (new_left, new_right)
        }
    }

    // Transient Shaper
    pub struct TransientShaper { pub attack: f32, pub sustain: f32, fast_env: f32, slow_env: f32 }
    impl TransientShaper {
        pub fn new() -> Self { Self { attack: 0.0, sustain: 0.0, fast_env: 0.0, slow_env: 0.0 } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let abs_input = input.abs();
            let fast_attack = 0.01; let fast_release = 0.05;
            let slow_attack = 0.1; let slow_release = 0.5;
            let fast_coef_a = (-1.0 / (fast_attack * sample_rate)).exp();
            let fast_coef_r = (-1.0 / (fast_release * sample_rate)).exp();
            let slow_coef_a = (-1.0 / (slow_attack * sample_rate)).exp();
            let slow_coef_r = (-1.0 / (slow_release * sample_rate)).exp();
            self.fast_env = if abs_input > self.fast_env { fast_coef_a * self.fast_env + (1.0 - fast_coef_a) * abs_input } else { fast_coef_r * self.fast_env + (1.0 - fast_coef_r) * abs_input };
            self.slow_env = if abs_input > self.slow_env { slow_coef_a * self.slow_env + (1.0 - slow_coef_a) * abs_input } else { slow_coef_r * self.slow_env + (1.0 - slow_coef_r) * abs_input };
            let transient = (self.fast_env - self.slow_env).max(0.0);
            let attack_gain = 1.0 + self.attack * transient * 10.0;
            let sustain_gain = 1.0 + self.sustain * self.slow_env * 2.0;
            input * attack_gain * sustain_gain
        }
    }

    // Vocoder
    pub struct Vocoder { pub num_bands: usize, pub carrier_bands: Vec<f32>, pub modulator_env: Vec<f32>, pub attack_ms: f32, pub release_ms: f32 }
    impl Vocoder {
        pub fn new(num_bands: usize) -> Self {
            Self { num_bands, carrier_bands: vec![0.0; num_bands], modulator_env: vec![0.0; num_bands], attack_ms: 5.0, release_ms: 50.0 }
        }
        pub fn process(&mut self, carrier: f32, modulator: f32, sample_rate: f32) -> f32 {
            let attack_coef = (-1.0 / (self.attack_ms * 0.001 * sample_rate)).exp();
            let release_coef = (-1.0 / (self.release_ms * 0.001 * sample_rate)).exp();
            let mut output = 0.0;
            for i in 0..self.num_bands {
                let mod_level = modulator.abs();
                self.modulator_env[i] = if mod_level > self.modulator_env[i] { attack_coef * self.modulator_env[i] + (1.0 - attack_coef) * mod_level } else { release_coef * self.modulator_env[i] + (1.0 - release_coef) * mod_level };
                output += carrier * self.modulator_env[i] / self.num_bands as f32;
            }
            output
        }
    }

    // Ring Modulator
    pub struct RingModulator { pub frequency: f32, phase: f32 }
    impl RingModulator {
        pub fn new(freq: f32) -> Self { Self { frequency: freq, phase: 0.0 } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let mod_signal = (self.phase * 2.0 * std::f32::consts::PI).sin();
            self.phase = (self.phase + self.frequency / sample_rate) % 1.0;
            input * mod_signal
        }
    }

    // Bitcrusher
    pub struct Bitcrusher { pub bits: u32, pub sample_rate_reduction: f32, hold_sample: f32, hold_counter: f32 }
    impl Bitcrusher {
        pub fn new(bits: u32, rate_reduction: f32) -> Self { Self { bits, sample_rate_reduction: rate_reduction, hold_sample: 0.0, hold_counter: 0.0 } }
        pub fn process(&mut self, input: f32) -> f32 {
            self.hold_counter += 1.0;
            if self.hold_counter >= self.sample_rate_reduction { self.hold_counter = 0.0; let step = 2.0 / (1 << self.bits) as f32; self.hold_sample = ((input + 1.0) / step).floor() * step - 1.0; }
            self.hold_sample
        }
    }

    // Waveshaper
    pub enum WaveshaperType { Tanh, Soft, Hard, Sine, Foldback }
    pub struct Waveshaper { pub shape_type: WaveshaperType, pub drive: f32, pub mix: f32 }
    impl Waveshaper {
        pub fn new(shape_type: WaveshaperType) -> Self { Self { shape_type, drive: 1.0, mix: 1.0 } }
        pub fn process(&self, input: f32) -> f32 {
            let driven = input * self.drive;
            let shaped = match self.shape_type {
                WaveshaperType::Tanh => driven.tanh(),
                WaveshaperType::Soft => driven / (1.0 + driven.abs()),
                WaveshaperType::Hard => driven.clamp(-1.0, 1.0),
                WaveshaperType::Sine => (driven * std::f32::consts::PI * 0.5).sin(),
                WaveshaperType::Foldback => { let mut v = driven; while v.abs() > 1.0 { v = if v > 0.0 { 2.0 - v } else { -2.0 - v }; } v }
            };
            input * (1.0 - self.mix) + shaped * self.mix
        }
    }

    // Phaser
    pub struct Phaser { pub rate: f32, pub depth: f32, pub feedback: f32, pub stages: usize, lfo_phase: f32, allpass_states: Vec<[f32; 2]>, feedback_sample: f32 }
    impl Phaser {
        pub fn new(stages: usize) -> Self { Self { rate: 0.5, depth: 0.7, feedback: 0.5, stages, lfo_phase: 0.0, allpass_states: vec![[0.0; 2]; stages], feedback_sample: 0.0 } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let lfo = (self.lfo_phase * 2.0 * std::f32::consts::PI).sin() * 0.5 + 0.5;
            self.lfo_phase = (self.lfo_phase + self.rate / sample_rate) % 1.0;
            let min_freq = 200.0; let max_freq = 4000.0;
            let center_freq = min_freq + (max_freq - min_freq) * lfo * self.depth;
            let mut signal = input + self.feedback_sample * self.feedback;
            for i in 0..self.stages {
                let freq = center_freq * (1.0 + i as f32 * 0.1);
                let w0 = 2.0 * std::f32::consts::PI * freq / sample_rate;
                let alpha = (w0 / 2.0).tan();
                let coef = (1.0 - alpha) / (1.0 + alpha);
                let output = coef * (signal - self.allpass_states[i][1]) + self.allpass_states[i][0];
                self.allpass_states[i][0] = signal;
                self.allpass_states[i][1] = output;
                signal = output;
            }
            self.feedback_sample = signal;
            (input + signal) * 0.5
        }
    }

    // Flanger
    pub struct Flanger { pub rate: f32, pub depth: f32, pub feedback: f32, pub delay_ms: f32, buffer: Vec<f32>, write_pos: usize, lfo_phase: f32 }
    impl Flanger {
        pub fn new(sample_rate: f32) -> Self {
            let max_delay = (20.0 * 0.001 * sample_rate) as usize + 1;
            Self { rate: 0.3, depth: 0.5, feedback: 0.5, delay_ms: 5.0, buffer: vec![0.0; max_delay], write_pos: 0, lfo_phase: 0.0 }
        }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let lfo = (self.lfo_phase * 2.0 * std::f32::consts::PI).sin() * 0.5 + 0.5;
            self.lfo_phase = (self.lfo_phase + self.rate / sample_rate) % 1.0;
            let delay_samples = (self.delay_ms + lfo * self.depth * self.delay_ms) * 0.001 * sample_rate;
            let read_pos = self.write_pos as f32 - delay_samples;
            let read_pos = if read_pos < 0.0 { read_pos + self.buffer.len() as f32 } else { read_pos };
            let idx0 = read_pos.floor() as usize % self.buffer.len();
            let idx1 = (idx0 + 1) % self.buffer.len();
            let frac = read_pos.fract();
            let delayed = self.buffer[idx0] * (1.0 - frac) + self.buffer[idx1] * frac;
            self.buffer[self.write_pos] = input + delayed * self.feedback;
            self.write_pos = (self.write_pos + 1) % self.buffer.len();
            (input + delayed) * 0.5
        }
    }

    // Chorus
    pub struct Chorus { pub rate: f32, pub depth: f32, pub voices: usize, pub delay_ms: f32, buffers: Vec<Vec<f32>>, write_pos: usize, lfo_phases: Vec<f32> }
    impl Chorus {
        pub fn new(sample_rate: f32, voices: usize) -> Self {
            let max_delay = (50.0 * 0.001 * sample_rate) as usize + 1;
            let mut lfo_phases = Vec::new();
            for i in 0..voices { lfo_phases.push(i as f32 / voices as f32); }
            Self { rate: 1.0, depth: 0.5, voices, delay_ms: 20.0, buffers: vec![vec![0.0; max_delay]; voices], write_pos: 0, lfo_phases }
        }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let mut output = input;
            for v in 0..self.voices {
                let lfo = (self.lfo_phases[v] * 2.0 * std::f32::consts::PI).sin() * 0.5 + 0.5;
                self.lfo_phases[v] = (self.lfo_phases[v] + self.rate / sample_rate) % 1.0;
                let delay_samples = (self.delay_ms + lfo * self.depth * self.delay_ms) * 0.001 * sample_rate;
                let read_pos = self.write_pos as f32 - delay_samples;
                let read_pos = if read_pos < 0.0 { read_pos + self.buffers[v].len() as f32 } else { read_pos };
                let idx0 = read_pos.floor() as usize % self.buffers[v].len();
                let idx1 = (idx0 + 1) % self.buffers[v].len();
                let frac = read_pos.fract();
                let delayed = self.buffers[v][idx0] * (1.0 - frac) + self.buffers[v][idx1] * frac;
                self.buffers[v][self.write_pos] = input;
                output += delayed;
            }
            let len = self.buffers[0].len();
            self.write_pos = (self.write_pos + 1) % len;
            output / (self.voices + 1) as f32
        }
    }

    // Pitch Shifter (simple granular)
    pub struct PitchShifter { pub semitones: f32, pub grain_size_ms: f32, buffer: Vec<f32>, write_pos: usize, read_pos: f32, grain_phase: f32 }
    impl PitchShifter {
        pub fn new(sample_rate: f32) -> Self {
            let size = (500.0 * 0.001 * sample_rate) as usize;
            Self { semitones: 0.0, grain_size_ms: 50.0, buffer: vec![0.0; size], write_pos: 0, read_pos: 0.0, grain_phase: 0.0 }
        }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            self.buffer[self.write_pos] = input;
            self.write_pos = (self.write_pos + 1) % self.buffer.len();
            let ratio = 2.0_f32.powf(self.semitones / 12.0);
            let grain_samples = self.grain_size_ms * 0.001 * sample_rate;
            self.read_pos = (self.read_pos + ratio) % self.buffer.len() as f32;
            self.grain_phase = (self.grain_phase + 1.0 / grain_samples) % 1.0;
            let window = 0.5 - 0.5 * (self.grain_phase * 2.0 * std::f32::consts::PI).cos();
            let idx0 = self.read_pos.floor() as usize % self.buffer.len();
            let idx1 = (idx0 + 1) % self.buffer.len();
            let frac = self.read_pos.fract();
            (self.buffer[idx0] * (1.0 - frac) + self.buffer[idx1] * frac) * window
        }
    }

    // Convolution Reverb
    pub struct ConvolutionReverb { ir: Vec<f32>, input_buffer: Vec<f32>, write_pos: usize, pub dry_wet: f32 }
    impl ConvolutionReverb {
        pub fn new(ir: Vec<f32>) -> Self {
            let len = ir.len();
            Self { ir, input_buffer: vec![0.0; len], write_pos: 0, dry_wet: 0.5 }
        }
        pub fn process(&mut self, input: f32) -> f32 {
            self.input_buffer[self.write_pos] = input;
            let mut wet = 0.0;
            for (i, &h) in self.ir.iter().enumerate() {
                let idx = (self.write_pos + self.input_buffer.len() - i) % self.input_buffer.len();
                wet += self.input_buffer[idx] * h;
            }
            self.write_pos = (self.write_pos + 1) % self.input_buffer.len();
            input * (1.0 - self.dry_wet) + wet * self.dry_wet
        }
    }

    // Plate Reverb (Dattorro)
    pub struct PlateReverb { pub decay: f32, pub damping: f32, pub pre_delay_ms: f32, pub diffusion: f32, input_lpf: f32, allpass: [[f32; 4]; 4], mod_apf: [[f32; 2]; 2], delay_lines: [Vec<f32>; 4], delay_pos: [usize; 4], pre_delay: Vec<f32>, pre_delay_pos: usize }
    impl PlateReverb {
        pub fn new(sample_rate: f32) -> Self {
            let sizes = [142, 107, 379, 277];
            let pre_size = (100.0 * 0.001 * sample_rate) as usize + 1;
            Self { decay: 0.85, damping: 0.7, pre_delay_ms: 20.0, diffusion: 0.75, input_lpf: 0.0, allpass: [[0.0; 4]; 4], mod_apf: [[0.0; 2]; 2], delay_lines: [vec![0.0; sizes[0]], vec![0.0; sizes[1]], vec![0.0; sizes[2]], vec![0.0; sizes[3]]], delay_pos: [0; 4], pre_delay: vec![0.0; pre_size], pre_delay_pos: 0 }
        }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            let pre_samples = (self.pre_delay_ms * 0.001 * sample_rate) as usize;
            let pre_idx = (self.pre_delay_pos + self.pre_delay.len() - pre_samples.min(self.pre_delay.len() - 1)) % self.pre_delay.len();
            let pre_out = self.pre_delay[pre_idx];
            self.pre_delay[self.pre_delay_pos] = input;
            self.pre_delay_pos = (self.pre_delay_pos + 1) % self.pre_delay.len();
            self.input_lpf = self.input_lpf * self.damping + pre_out * (1.0 - self.damping);
            let mut signal = self.input_lpf;
            for i in 0..4 {
                let delayed = self.delay_lines[i][self.delay_pos[i]];
                let apf_out = delayed * self.diffusion + signal;
                self.delay_lines[i][self.delay_pos[i]] = signal - delayed * self.diffusion;
                self.delay_pos[i] = (self.delay_pos[i] + 1) % self.delay_lines[i].len();
                signal = apf_out * self.decay;
            }
            signal
        }
    }

    // Spectral Processing
    pub struct SpectralProcessor { pub fft_size: usize, buffer: Vec<f32>, output_buffer: Vec<f32>, hop_size: usize, pos: usize }
    impl SpectralProcessor {
        pub fn new(fft_size: usize) -> Self { Self { fft_size, buffer: vec![0.0; fft_size], output_buffer: vec![0.0; fft_size], hop_size: fft_size / 4, pos: 0 } }
        pub fn apply_spectral_filter<F>(&mut self, input: f32, mut filter_fn: F) -> f32 where F: FnMut(&mut [f32], &mut [f32]) {
            self.buffer[self.pos] = input;
            let output = self.output_buffer[self.pos];
            self.pos += 1;
            if self.pos >= self.hop_size {
                self.pos = 0;
                let mut real = self.buffer.clone();
                let mut imag = vec![0.0; self.fft_size];
                filter_fn(&mut real, &mut imag);
                for (i, &r) in real.iter().enumerate() { self.output_buffer[i] = r; }
            }
            output
        }
    }

    // Frequency Shifter
    pub struct FrequencyShifter { pub shift_hz: f32, hilbert_buffer: Vec<f32>, osc_phase: f32, pos: usize }
    impl FrequencyShifter {
        pub fn new() -> Self { Self { shift_hz: 100.0, hilbert_buffer: vec![0.0; 128], osc_phase: 0.0, pos: 0 } }
        pub fn process(&mut self, input: f32, sample_rate: f32) -> f32 {
            self.hilbert_buffer[self.pos] = input;
            let delay_idx = (self.pos + self.hilbert_buffer.len() / 2) % self.hilbert_buffer.len();
            let delayed = self.hilbert_buffer[delay_idx];
            self.pos = (self.pos + 1) % self.hilbert_buffer.len();
            let cos_osc = (self.osc_phase * 2.0 * std::f32::consts::PI).cos();
            let sin_osc = (self.osc_phase * 2.0 * std::f32::consts::PI).sin();
            self.osc_phase = (self.osc_phase + self.shift_hz / sample_rate) % 1.0;
            delayed * cos_osc - input * sin_osc
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGION: Video Effects Pipeline - Production Ready
// ═══════════════════════════════════════════════════════════════════════════════

pub mod video_effects {
    use super::*;

    // Motion Estimation
    pub struct BlockMotionEstimator { pub block_size: usize, pub search_range: usize }
    impl BlockMotionEstimator {
        pub fn new(block_size: usize, search_range: usize) -> Self { Self { block_size, search_range } }
        pub fn estimate(&self, prev: &[f32], curr: &[f32], width: usize, height: usize) -> Vec<(i32, i32)> {
            let mut vectors = Vec::new();
            let blocks_x = width / self.block_size;
            let blocks_y = height / self.block_size;
            for by in 0..blocks_y {
                for bx in 0..blocks_x {
                    let mut best_dx = 0i32; let mut best_dy = 0i32; let mut best_sad = f32::MAX;
                    for dy in -(self.search_range as i32)..=(self.search_range as i32) {
                        for dx in -(self.search_range as i32)..=(self.search_range as i32) {
                            let mut sad = 0.0f32;
                            for y in 0..self.block_size {
                                for x in 0..self.block_size {
                                    let cx = bx * self.block_size + x;
                                    let cy = by * self.block_size + y;
                                    let px = (cx as i32 + dx).clamp(0, width as i32 - 1) as usize;
                                    let py = (cy as i32 + dy).clamp(0, height as i32 - 1) as usize;
                                    sad += (curr[cy * width + cx] - prev[py * width + px]).abs();
                                }
                            }
                            if sad < best_sad { best_sad = sad; best_dx = dx; best_dy = dy; }
                        }
                    }
                    vectors.push((best_dx, best_dy));
                }
            }
            vectors
        }
    }

    // Optical Flow (Dense)
    pub struct DenseOpticalFlow { pub iterations: usize, pub pyramid_levels: usize }
    impl DenseOpticalFlow {
        pub fn new() -> Self { Self { iterations: 10, pyramid_levels: 3 } }
        pub fn compute(&self, prev: &[f32], curr: &[f32], width: usize, height: usize) -> (Vec<f32>, Vec<f32>) {
            let mut u = vec![0.0f32; width * height];
            let mut v = vec![0.0f32; width * height];
            for _ in 0..self.iterations {
                for y in 1..height - 1 {
                    for x in 1..width - 1 {
                        let idx = y * width + x;
                        let ix = (curr[idx + 1] - curr[idx - 1]) * 0.5;
                        let iy = (curr[idx + width] - curr[idx - width]) * 0.5;
                        let it = curr[idx] - prev[idx];
                        let u_avg = (u[idx - 1] + u[idx + 1] + u[idx - width] + u[idx + width]) * 0.25;
                        let v_avg = (v[idx - 1] + v[idx + 1] + v[idx - width] + v[idx + width]) * 0.25;
                        let denom = ix * ix + iy * iy + 0.01;
                        let update = (ix * u_avg + iy * v_avg + it) / denom;
                        u[idx] = u_avg - ix * update;
                        v[idx] = v_avg - iy * update;
                    }
                }
            }
            (u, v)
        }
    }

    // Video Denoiser (Temporal)
    pub struct TemporalDenoiser { pub strength: f32, pub motion_threshold: f32, history: Option<Vec<f32>> }
    impl TemporalDenoiser {
        pub fn new(strength: f32) -> Self { Self { strength, motion_threshold: 0.1, history: None } }
        pub fn process(&mut self, frame: &[f32]) -> Vec<f32> {
            match &self.history {
                None => { self.history = Some(frame.to_vec()); frame.to_vec() }
                Some(prev) => {
                    let mut output = vec![0.0; frame.len()];
                    for i in 0..frame.len() {
                        let diff = (frame[i] - prev[i]).abs();
                        let blend = if diff > self.motion_threshold { 0.0 } else { self.strength };
                        output[i] = frame[i] * (1.0 - blend) + prev[i] * blend;
                    }
                    self.history = Some(output.clone());
                    output
                }
            }
        }
    }

    // Color Correction
    pub struct ColorCorrector { pub brightness: f32, pub contrast: f32, pub saturation: f32, pub hue_shift: f32, pub gamma: f32 }
    impl ColorCorrector {
        pub fn new() -> Self { Self { brightness: 0.0, contrast: 1.0, saturation: 1.0, hue_shift: 0.0, gamma: 1.0 } }
        pub fn process_rgb(&self, r: f32, g: f32, b: f32) -> (f32, f32, f32) {
            let r = (r + self.brightness) * self.contrast;
            let g = (g + self.brightness) * self.contrast;
            let b = (b + self.brightness) * self.contrast;
            let luma = 0.299 * r + 0.587 * g + 0.114 * b;
            let r = luma + (r - luma) * self.saturation;
            let g = luma + (g - luma) * self.saturation;
            let b = luma + (b - luma) * self.saturation;
            let r = r.max(0.0).powf(1.0 / self.gamma);
            let g = g.max(0.0).powf(1.0 / self.gamma);
            let b = b.max(0.0).powf(1.0 / self.gamma);
            (r.clamp(0.0, 1.0), g.clamp(0.0, 1.0), b.clamp(0.0, 1.0))
        }
    }

    // Chroma Key
    pub struct ChromaKey { pub key_color: (f32, f32, f32), pub tolerance: f32, pub edge_softness: f32 }
    impl ChromaKey {
        pub fn green_screen() -> Self { Self { key_color: (0.0, 1.0, 0.0), tolerance: 0.3, edge_softness: 0.1 } }
        pub fn compute_alpha(&self, r: f32, g: f32, b: f32) -> f32 {
            let dr = r - self.key_color.0;
            let dg = g - self.key_color.1;
            let db = b - self.key_color.2;
            let dist = (dr * dr + dg * dg + db * db).sqrt();
            let alpha = ((dist - self.tolerance) / self.edge_softness).clamp(0.0, 1.0);
            alpha
        }
    }

    // Lens Distortion
    pub struct LensDistortion { pub k1: f32, pub k2: f32, pub k3: f32, pub center: (f32, f32) }
    impl LensDistortion {
        pub fn barrel(strength: f32) -> Self { Self { k1: -strength, k2: 0.0, k3: 0.0, center: (0.5, 0.5) } }
        pub fn pincushion(strength: f32) -> Self { Self { k1: strength, k2: 0.0, k3: 0.0, center: (0.5, 0.5) } }
        pub fn undistort(&self, x: f32, y: f32) -> (f32, f32) {
            let dx = x - self.center.0;
            let dy = y - self.center.1;
            let r2 = dx * dx + dy * dy;
            let r4 = r2 * r2;
            let r6 = r4 * r2;
            let factor = 1.0 + self.k1 * r2 + self.k2 * r4 + self.k3 * r6;
            (self.center.0 + dx * factor, self.center.1 + dy * factor)
        }
    }

    // Vignette
    pub struct Vignette { pub strength: f32, pub radius: f32, pub softness: f32, pub center: (f32, f32) }
    impl Vignette {
        pub fn new(strength: f32) -> Self { Self { strength, radius: 0.8, softness: 0.3, center: (0.5, 0.5) } }
        pub fn compute_factor(&self, x: f32, y: f32) -> f32 {
            let dx = x - self.center.0;
            let dy = y - self.center.1;
            let dist = (dx * dx + dy * dy).sqrt();
            let vignette = 1.0 - ((dist - self.radius + self.softness) / self.softness).clamp(0.0, 1.0) * self.strength;
            vignette.clamp(0.0, 1.0)
        }
    }

    // Film Grain
    pub struct FilmGrain { pub intensity: f32, pub size: f32, seed: u32 }
    impl FilmGrain {
        pub fn new(intensity: f32) -> Self { Self { intensity, size: 1.0, seed: 12345 } }
        fn noise(&mut self) -> f32 { self.seed = self.seed.wrapping_mul(1664525).wrapping_add(1013904223); (self.seed as f32 / u32::MAX as f32) * 2.0 - 1.0 }
        pub fn apply(&mut self, value: f32) -> f32 { (value + self.noise() * self.intensity).clamp(0.0, 1.0) }
    }

    // Letterbox
    pub struct Letterbox { pub aspect_ratio: f32, pub bar_color: (f32, f32, f32) }
    impl Letterbox {
        pub fn cinematic() -> Self { Self { aspect_ratio: 2.39, bar_color: (0.0, 0.0, 0.0) } }
        pub fn compute_bars(&self, width: usize, height: usize) -> (usize, usize) {
            let current_aspect = width as f32 / height as f32;
            if current_aspect > self.aspect_ratio { let new_width = (height as f32 * self.aspect_ratio) as usize; ((width - new_width) / 2, 0) }
            else { let new_height = (width as f32 / self.aspect_ratio) as usize; (0, (height - new_height) / 2) }
        }
    }

    // Speed Ramp
    pub struct SpeedRamp { pub keyframes: Vec<(f32, f32)>, pub interpolation: Interpolation }
    pub enum Interpolation { Linear, EaseIn, EaseOut, EaseInOut }
    impl SpeedRamp {
        pub fn new() -> Self { Self { keyframes: vec![(0.0, 1.0), (1.0, 1.0)], interpolation: Interpolation::Linear } }
        pub fn add_keyframe(&mut self, time: f32, speed: f32) {
            self.keyframes.push((time, speed));
            self.keyframes.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap());
        }
        pub fn get_speed(&self, time: f32) -> f32 {
            if self.keyframes.is_empty() { return 1.0; }
            if time <= self.keyframes[0].0 { return self.keyframes[0].1; }
            if time >= self.keyframes.last().unwrap().0 { return self.keyframes.last().unwrap().1; }
            for i in 0..self.keyframes.len() - 1 {
                if time >= self.keyframes[i].0 && time < self.keyframes[i + 1].0 {
                    let t = (time - self.keyframes[i].0) / (self.keyframes[i + 1].0 - self.keyframes[i].0);
                    let t = match self.interpolation {
                        Interpolation::Linear => t,
                        Interpolation::EaseIn => t * t,
                        Interpolation::EaseOut => 1.0 - (1.0 - t) * (1.0 - t),
                        Interpolation::EaseInOut => if t < 0.5 { 2.0 * t * t } else { 1.0 - (-2.0 * t + 2.0).powi(2) / 2.0 },
                    };
                    return self.keyframes[i].1 + (self.keyframes[i + 1].1 - self.keyframes[i].1) * t;
                }
            }
            1.0
        }
    }

    // Mask
    pub struct Mask { pub shape: MaskShape, pub feather: f32, pub invert: bool }
    pub enum MaskShape { Rectangle { x: f32, y: f32, width: f32, height: f32 }, Ellipse { cx: f32, cy: f32, rx: f32, ry: f32 }, Polygon { points: Vec<(f32, f32)> } }
    impl Mask {
        pub fn compute_alpha(&self, x: f32, y: f32) -> f32 {
            let alpha = match &self.shape {
                MaskShape::Rectangle { x: rx, y: ry, width, height } => {
                    let inside = x >= *rx && x <= rx + width && y >= *ry && y <= ry + height;
                    if inside { 1.0 } else { 0.0 }
                }
                MaskShape::Ellipse { cx, cy, rx, ry } => {
                    let dx = (x - cx) / rx;
                    let dy = (y - cy) / ry;
                    let dist = (dx * dx + dy * dy).sqrt();
                    (1.0 - (dist - 1.0 + self.feather) / self.feather).clamp(0.0, 1.0)
                }
                MaskShape::Polygon { points } => {
                    let mut inside = false;
                    let n = points.len();
                    let mut j = n - 1;
                    for i in 0..n {
                        let (xi, yi) = points[i];
                        let (xj, yj) = points[j];
                        if ((yi > y) != (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi) { inside = !inside; }
                        j = i;
                    }
                    if inside { 1.0 } else { 0.0 }
                }
            };
            if self.invert { 1.0 - alpha } else { alpha }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_video_frame() {
        let mut frame = VideoFrame::new(100, 100);
        frame.set_pixel(50, 50, RGB::new(1.0, 0.0, 0.0));
        let pixel = frame.get_pixel(50, 50);
        assert_eq!(pixel.r, 1.0);
    }
    
    #[test]
    fn test_scene_detector() {
        let detector = SceneDetector::new();
        let frames = vec![VideoFrame::new(100, 100); 10];
        let scenes = detector.detect_scenes(&frames);
        // With identical frames, no cuts should be detected
        assert_eq!(scenes.len(), 0);
    }
    
    #[test]
    fn test_color_grade_style() {
        let style = ColorGradeStyle::cinematic();
        assert_eq!(style.name, "Cinematic");
    }
    
    #[test]
    fn test_quanta_media_suite() {
        let suite = QuantaMediaSuite::new(24.0, (1920, 1080));
        assert_eq!(suite.cut.timeline.frame_rate, 24.0);
    }
}
