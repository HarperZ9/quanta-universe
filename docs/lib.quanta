module docs

use foundation::io::{println, print, File, read_to_string, write_string}
use foundation::collections::{Vec, HashMap}
use foundation::fs::{create_dir_all, walk_dir, exists}
use foundation::path::Path

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENTATION MODEL
// ═══════════════════════════════════════════════════════════════════════════════

/// Represents a documented item
#[derive(Clone, Debug)]
pub struct DocItem {
    pub name: String,
    pub kind: ItemKind,
    pub visibility: Visibility,
    pub doc_comment: Option<String>,
    pub signature: String,
    pub source_file: String,
    pub line_number: usize,
    pub children: Vec<DocItem>,
    pub attributes: Vec<Attribute>,
}

#[derive(Clone, Debug, PartialEq)]
pub enum ItemKind {
    Module,
    Struct,
    Enum,
    Trait,
    Impl,
    Function,
    Method,
    Constant,
    Static,
    Type,
    Macro,
    Field,
    Variant,
}

#[derive(Clone, Debug, PartialEq)]
pub enum Visibility {
    Public,
    Private,
    Crate,
    Super,
    Restricted(String),
}

#[derive(Clone, Debug)]
pub struct Attribute {
    pub name: String,
    pub args: Option<String>,
}

/// Documentation for a complete module
#[derive(Clone)]
pub struct ModuleDoc {
    pub name: String,
    pub path: String,
    pub doc_comment: Option<String>,
    pub items: Vec<DocItem>,
    pub re_exports: Vec<String>,
    pub submodules: Vec<String>,
}

/// Documentation for the entire crate
pub struct CrateDoc {
    pub name: String,
    pub version: String,
    pub description: Option<String>,
    pub modules: HashMap<String, ModuleDoc>,
    pub readme: Option<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENTATION PARSER
// ═══════════════════════════════════════════════════════════════════════════════

/// Parses source files to extract documentation
pub struct DocParser {
    current_file: String,
    current_line: usize,
}

impl DocParser {
    pub fn new() -> Self {
        DocParser {
            current_file: String::new(),
            current_line: 0,
        }
    }

    /// Parse a source file
    pub fn parse_file(&mut self, path: &str) -> Result<ModuleDoc, DocError> {
        self.current_file = path.to_string();
        self.current_line = 0;

        let content = read_to_string(path)?;
        let module_name = Path::new(path)
            .file_stem()
            .unwrap_or("unknown")
            .to_string();

        let mut module = ModuleDoc {
            name: module_name,
            path: path.to_string(),
            doc_comment: None,
            items: Vec::new(),
            re_exports: Vec::new(),
            submodules: Vec::new(),
        };

        let mut lines = content.lines().enumerate().peekable();
        let mut current_doc: Vec<String> = Vec::new();
        let mut current_attrs: Vec<Attribute> = Vec::new();

        while let Some((line_num, line)) = lines.next() {
            self.current_line = line_num + 1;
            let line = line.trim();

            // Skip empty lines
            if line.is_empty() {
                if !current_doc.is_empty() && !self.is_doc_line(lines.peek().map(|(_, l)| *l).unwrap_or("")) {
                    current_doc.clear();
                }
                continue;
            }

            // Module-level doc comment
            if line.starts_with("//!") {
                let comment = line.strip_prefix("//!").unwrap_or("").trim();
                if module.doc_comment.is_none() {
                    module.doc_comment = Some(String::new());
                }
                if let Some(ref mut doc) = module.doc_comment {
                    if !doc.is_empty() {
                        doc.push('\n');
                    }
                    doc.push_str(comment);
                }
                continue;
            }

            // Item doc comment
            if line.starts_with("///") {
                let comment = line.strip_prefix("///").unwrap_or("").trim();
                current_doc.push(comment.to_string());
                continue;
            }

            // Attribute
            if line.starts_with("#[") {
                let attr = self.parse_attribute(line);
                current_attrs.push(attr);
                continue;
            }

            // Parse item
            if let Some(item) = self.parse_item(line, &current_doc, &current_attrs) {
                module.items.push(item);
            }

            // Clear accumulated doc/attrs
            current_doc.clear();
            current_attrs.clear();
        }

        Ok(module)
    }

    fn is_doc_line(&self, line: &str) -> bool {
        let line = line.trim();
        line.starts_with("///") || line.starts_with("#[")
    }

    fn parse_attribute(&self, line: &str) -> Attribute {
        let content = line.strip_prefix("#[")
            .and_then(|s| s.strip_suffix(']'))
            .unwrap_or(line);

        if let Some(paren_idx) = content.find('(') {
            let name = content[..paren_idx].to_string();
            let args = content[paren_idx + 1..content.len() - 1].to_string();
            Attribute { name, args: Some(args) }
        } else {
            Attribute { name: content.to_string(), args: None }
        }
    }

    fn parse_item(&mut self, line: &str, doc: &[String], attrs: &[Attribute]) -> Option<DocItem> {
        let visibility = self.parse_visibility(line);
        let line = self.strip_visibility(line);

        // Function
        if line.starts_with("fn ") || line.starts_with("async fn ") {
            return Some(self.parse_function(line, doc, attrs, visibility));
        }

        // Struct
        if line.starts_with("struct ") {
            return Some(self.parse_struct(line, doc, attrs, visibility));
        }

        // Enum
        if line.starts_with("enum ") {
            return Some(self.parse_enum(line, doc, attrs, visibility));
        }

        // Trait
        if line.starts_with("trait ") {
            return Some(self.parse_trait(line, doc, attrs, visibility));
        }

        // Impl
        if line.starts_with("impl ") || line.starts_with("impl<") {
            return Some(self.parse_impl(line, doc, attrs));
        }

        // Type alias
        if line.starts_with("type ") {
            return Some(self.parse_type_alias(line, doc, attrs, visibility));
        }

        // Constant
        if line.starts_with("const ") {
            return Some(self.parse_const(line, doc, attrs, visibility));
        }

        // Static
        if line.starts_with("static ") {
            return Some(self.parse_static(line, doc, attrs, visibility));
        }

        // Macro
        if line.starts_with("macro_rules!") || line.contains("macro ") {
            return Some(self.parse_macro(line, doc, attrs, visibility));
        }

        None
    }

    fn parse_visibility(&self, line: &str) -> Visibility {
        if line.starts_with("pub(crate)") {
            Visibility::Crate
        } else if line.starts_with("pub(super)") {
            Visibility::Super
        } else if line.starts_with("pub(in ") {
            let end = line.find(')').unwrap_or(line.len());
            let path = line[7..end].to_string();
            Visibility::Restricted(path)
        } else if line.starts_with("pub ") {
            Visibility::Public
        } else {
            Visibility::Private
        }
    }

    fn strip_visibility(&self, line: &str) -> &str {
        if line.starts_with("pub(") {
            if let Some(idx) = line.find(')') {
                return line[idx + 1..].trim();
            }
        } else if line.starts_with("pub ") {
            return line[4..].trim();
        }
        line
    }

    fn parse_function(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let is_async = line.starts_with("async ");
        let line = if is_async { &line[6..] } else { line };
        let line = line.strip_prefix("fn ").unwrap_or(line);

        let name_end = line.find('(').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        let sig_end = line.find('{').unwrap_or(line.len());
        let signature = if is_async {
            format!("async fn {}", &line[..sig_end].trim())
        } else {
            format!("fn {}", &line[..sig_end].trim())
        };

        DocItem {
            name,
            kind: ItemKind::Function,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature,
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_struct(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let line = line.strip_prefix("struct ").unwrap_or(line);
        let name_end = line.find(|c| c == '<' || c == '{' || c == '(' || c == ';')
            .unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        let sig_end = line.find('{').unwrap_or(line.len());
        let signature = format!("struct {}", &line[..sig_end].trim());

        DocItem {
            name,
            kind: ItemKind::Struct,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature,
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_enum(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let line = line.strip_prefix("enum ").unwrap_or(line);
        let name_end = line.find(|c| c == '<' || c == '{').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        DocItem {
            name: name.clone(),
            kind: ItemKind::Enum,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature: format!("enum {}", name),
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_trait(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let line = line.strip_prefix("trait ").unwrap_or(line);
        let name_end = line.find(|c| c == '<' || c == '{' || c == ':').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        DocItem {
            name: name.clone(),
            kind: ItemKind::Trait,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature: format!("trait {}", name),
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_impl(&self, line: &str, doc: &[String], attrs: &[Attribute]) -> DocItem {
        let signature = line.trim_end_matches('{').trim().to_string();

        // Extract the type being implemented
        let name = if line.contains(" for ") {
            // impl Trait for Type
            line.split(" for ").last().unwrap_or("").split('{').next().unwrap_or("").trim().to_string()
        } else {
            // impl Type
            line.strip_prefix("impl")
                .and_then(|s| s.split('{').next())
                .map(|s| s.trim().trim_start_matches('<').split('>').last().unwrap_or("").trim())
                .unwrap_or("")
                .to_string()
        };

        DocItem {
            name,
            kind: ItemKind::Impl,
            visibility: Visibility::Public,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature,
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_type_alias(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let line = line.strip_prefix("type ").unwrap_or(line);
        let name_end = line.find(|c| c == '<' || c == '=').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        DocItem {
            name: name.clone(),
            kind: ItemKind::Type,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature: format!("type {}", line.trim_end_matches(';').trim()),
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_const(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let line = line.strip_prefix("const ").unwrap_or(line);
        let name_end = line.find(':').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        DocItem {
            name: name.clone(),
            kind: ItemKind::Constant,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature: format!("const {}", line.trim_end_matches(';').trim()),
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_static(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let line = line.strip_prefix("static ").unwrap_or(line);
        let line = line.strip_prefix("mut ").unwrap_or(line);
        let name_end = line.find(':').unwrap_or(line.len());
        let name = line[..name_end].trim().to_string();

        DocItem {
            name: name.clone(),
            kind: ItemKind::Static,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature: format!("static {}", line.trim_end_matches(';').trim()),
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }

    fn parse_macro(&self, line: &str, doc: &[String], attrs: &[Attribute], vis: Visibility) -> DocItem {
        let name = if line.starts_with("macro_rules!") {
            line.strip_prefix("macro_rules!")
                .and_then(|s| s.split('{').next())
                .map(|s| s.trim())
                .unwrap_or("unknown")
                .to_string()
        } else {
            "macro".to_string()
        };

        DocItem {
            name: name.clone(),
            kind: ItemKind::Macro,
            visibility: vis,
            doc_comment: if doc.is_empty() { None } else { Some(doc.join("\n")) },
            signature: format!("{}!", name),
            source_file: self.current_file.clone(),
            line_number: self.current_line,
            children: Vec::new(),
            attributes: attrs.to_vec(),
        }
    }
}

#[derive(Debug)]
pub enum DocError {
    IoError(String),
    ParseError(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// HTML GENERATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Generates HTML documentation
pub struct HtmlGenerator {
    config: HtmlConfig,
}

#[derive(Clone)]
pub struct HtmlConfig {
    pub output_dir: String,
    pub theme: String,
    pub include_private: bool,
    pub include_source: bool,
    pub logo: Option<String>,
    pub favicon: Option<String>,
}

impl Default for HtmlConfig {
    fn default() -> Self {
        HtmlConfig {
            output_dir: "target/doc".to_string(),
            theme: "quanta".to_string(),
            include_private: false,
            include_source: true,
            logo: None,
            favicon: None,
        }
    }
}

impl HtmlGenerator {
    pub fn new(config: HtmlConfig) -> Self {
        HtmlGenerator { config }
    }

    /// Generate documentation for a crate
    pub fn generate(&self, crate_doc: &CrateDoc) -> Result<(), DocError> {
        println!("Generating documentation for {}...", crate_doc.name);

        // Create output directory
        create_dir_all(&self.config.output_dir)?;

        // Generate index page
        self.generate_index(crate_doc)?;

        // Generate module pages
        for (path, module) in &crate_doc.modules {
            self.generate_module_page(path, module)?;
        }

        // Generate CSS
        self.generate_css()?;

        // Generate JS
        self.generate_js()?;

        // Copy static assets
        self.copy_assets()?;

        println!("  ✓ Documentation generated at {}", self.config.output_dir);
        Ok(())
    }

    fn generate_index(&self, crate_doc: &CrateDoc) -> Result<(), DocError> {
        let mut html = String::new();

        html.push_str(&self.html_header(&crate_doc.name));

        html.push_str("<div class=\"container\">\n");
        html.push_str("<div class=\"sidebar\">\n");
        html.push_str(&self.generate_sidebar(crate_doc));
        html.push_str("</div>\n");

        html.push_str("<main class=\"content\">\n");
        html.push_str(&format!("<h1>Crate {}</h1>\n", crate_doc.name));

        if let Some(ref desc) = crate_doc.description {
            html.push_str(&format!("<p class=\"description\">{}</p>\n", desc));
        }

        html.push_str("<p class=\"version\">Version: ");
        html.push_str(&crate_doc.version);
        html.push_str("</p>\n");

        if let Some(ref readme) = crate_doc.readme {
            html.push_str("<div class=\"readme\">\n");
            html.push_str(&self.markdown_to_html(readme));
            html.push_str("</div>\n");
        }

        html.push_str("<h2>Modules</h2>\n");
        html.push_str("<ul class=\"module-list\">\n");
        for (path, module) in &crate_doc.modules {
            html.push_str(&format!(
                "<li><a href=\"{}.html\">{}</a>",
                path.replace("::", "/"),
                module.name
            ));
            if let Some(ref doc) = module.doc_comment {
                let first_line = doc.lines().next().unwrap_or("");
                html.push_str(&format!(" - {}", first_line));
            }
            html.push_str("</li>\n");
        }
        html.push_str("</ul>\n");

        html.push_str("</main>\n");
        html.push_str("</div>\n");
        html.push_str(&self.html_footer());

        let path = format!("{}/index.html", self.config.output_dir);
        write_string(&path, &html)?;

        Ok(())
    }

    fn generate_module_page(&self, path: &str, module: &ModuleDoc) -> Result<(), DocError> {
        let mut html = String::new();

        html.push_str(&self.html_header(&format!("{} - Module", module.name)));

        html.push_str("<div class=\"container\">\n");
        html.push_str("<main class=\"content\">\n");

        html.push_str(&format!("<h1>Module {}</h1>\n", module.name));

        if let Some(ref doc) = module.doc_comment {
            html.push_str("<div class=\"module-doc\">\n");
            html.push_str(&self.markdown_to_html(doc));
            html.push_str("</div>\n");
        }

        // Group items by kind
        let structs: Vec<_> = module.items.iter().filter(|i| i.kind == ItemKind::Struct).collect();
        let enums: Vec<_> = module.items.iter().filter(|i| i.kind == ItemKind::Enum).collect();
        let traits: Vec<_> = module.items.iter().filter(|i| i.kind == ItemKind::Trait).collect();
        let functions: Vec<_> = module.items.iter().filter(|i| i.kind == ItemKind::Function).collect();
        let types: Vec<_> = module.items.iter().filter(|i| i.kind == ItemKind::Type).collect();
        let constants: Vec<_> = module.items.iter().filter(|i| i.kind == ItemKind::Constant).collect();

        if !structs.is_empty() {
            html.push_str("<h2>Structs</h2>\n");
            for item in structs {
                html.push_str(&self.generate_item_html(item));
            }
        }

        if !enums.is_empty() {
            html.push_str("<h2>Enums</h2>\n");
            for item in enums {
                html.push_str(&self.generate_item_html(item));
            }
        }

        if !traits.is_empty() {
            html.push_str("<h2>Traits</h2>\n");
            for item in traits {
                html.push_str(&self.generate_item_html(item));
            }
        }

        if !functions.is_empty() {
            html.push_str("<h2>Functions</h2>\n");
            for item in functions {
                html.push_str(&self.generate_item_html(item));
            }
        }

        if !types.is_empty() {
            html.push_str("<h2>Type Aliases</h2>\n");
            for item in types {
                html.push_str(&self.generate_item_html(item));
            }
        }

        if !constants.is_empty() {
            html.push_str("<h2>Constants</h2>\n");
            for item in constants {
                html.push_str(&self.generate_item_html(item));
            }
        }

        html.push_str("</main>\n");
        html.push_str("</div>\n");
        html.push_str(&self.html_footer());

        let output_path = format!("{}/{}.html", self.config.output_dir, path.replace("::", "/"));
        let parent = Path::new(&output_path).parent().unwrap();
        create_dir_all(parent.to_str().unwrap())?;
        write_string(&output_path, &html)?;

        Ok(())
    }

    fn generate_item_html(&self, item: &DocItem) -> String {
        let mut html = String::new();

        html.push_str(&format!("<div class=\"item {} {}\">\n",
            format!("{:?}", item.kind).to_lowercase(),
            if item.visibility == Visibility::Public { "public" } else { "private" }
        ));

        html.push_str(&format!("<h3 id=\"{}\"><a href=\"#{}\">{}</a></h3>\n",
            item.name, item.name, item.name));

        html.push_str("<pre class=\"signature\"><code>");
        html.push_str(&html_escape(&item.signature));
        html.push_str("</code></pre>\n");

        if let Some(ref doc) = item.doc_comment {
            html.push_str("<div class=\"docstring\">\n");
            html.push_str(&self.markdown_to_html(doc));
            html.push_str("</div>\n");
        }

        if self.config.include_source {
            html.push_str(&format!(
                "<p class=\"source-link\"><a href=\"{}#L{}\">Source</a></p>\n",
                item.source_file, item.line_number
            ));
        }

        html.push_str("</div>\n");

        html
    }

    fn generate_sidebar(&self, crate_doc: &CrateDoc) -> String {
        let mut html = String::new();

        html.push_str("<nav class=\"sidebar-nav\">\n");
        html.push_str(&format!("<h2>{}</h2>\n", crate_doc.name));

        html.push_str("<ul>\n");
        for (path, module) in &crate_doc.modules {
            html.push_str(&format!(
                "<li><a href=\"{}.html\">{}</a></li>\n",
                path.replace("::", "/"),
                module.name
            ));
        }
        html.push_str("</ul>\n");

        html.push_str("</nav>\n");

        html
    }

    fn html_header(&self, title: &str) -> String {
        format!(r#"<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{} - QUANTA-UNIVERSE Documentation</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
<header class="top-bar">
    <div class="logo">QUANTA-UNIVERSE</div>
    <nav class="top-nav">
        <a href="index.html">Home</a>
        <input type="search" placeholder="Search..." class="search-box">
    </nav>
</header>
"#, title)
    }

    fn html_footer(&self) -> String {
        r#"<footer>
    <p>Generated by Quark Doc - QUANTA-UNIVERSE Documentation Generator</p>
</footer>
<script src="main.js"></script>
</body>
</html>"#.to_string()
    }

    fn generate_css(&self) -> Result<(), DocError> {
        let css = r#":root {
    --bg-color: #1a1b26;
    --sidebar-bg: #16161e;
    --text-color: #a9b1d6;
    --heading-color: #c0caf5;
    --link-color: #7aa2f7;
    --code-bg: #24283b;
    --border-color: #414868;
    --accent: #bb9af7;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg-color);
    color: var(--text-color);
    line-height: 1.6;
}

.top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: var(--sidebar-bg);
    border-bottom: 1px solid var(--border-color);
}

.logo { font-size: 1.5rem; font-weight: bold; color: var(--accent); }

.container { display: flex; min-height: calc(100vh - 60px); }

.sidebar {
    width: 250px;
    background: var(--sidebar-bg);
    padding: 1rem;
    border-right: 1px solid var(--border-color);
}

.content {
    flex: 1;
    padding: 2rem;
    max-width: 900px;
}

h1, h2, h3 { color: var(--heading-color); margin: 1rem 0; }
h1 { font-size: 2rem; border-bottom: 2px solid var(--accent); padding-bottom: 0.5rem; }
h2 { font-size: 1.5rem; margin-top: 2rem; }
h3 { font-size: 1.2rem; }

a { color: var(--link-color); text-decoration: none; }
a:hover { text-decoration: underline; }

.signature {
    background: var(--code-bg);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
}

.item {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
}

.item.public { border-left: 3px solid #9ece6a; }
.item.private { border-left: 3px solid #f7768e; }

.docstring { margin-top: 1rem; }
.source-link { margin-top: 0.5rem; font-size: 0.9rem; }

.search-box {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background: var(--code-bg);
    color: var(--text-color);
}

footer {
    text-align: center;
    padding: 1rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.9rem;
}
"#;

        let path = format!("{}/style.css", self.config.output_dir);
        write_string(&path, css)?;
        Ok(())
    }

    fn generate_js(&self) -> Result<(), DocError> {
        let js = r#"// Documentation search and navigation
document.addEventListener('DOMContentLoaded', function() {
    const searchBox = document.querySelector('.search-box');
    if (searchBox) {
        searchBox.addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase();
            // Implement search
        });
    }
});
"#;

        let path = format!("{}/main.js", self.config.output_dir);
        write_string(&path, js)?;
        Ok(())
    }

    fn copy_assets(&self) -> Result<(), DocError> {
        // Copy logo, favicon, etc.
        Ok(())
    }

    fn markdown_to_html(&self, md: &str) -> String {
        // Simple markdown conversion
        let mut html = String::new();

        for line in md.lines() {
            if line.starts_with("# ") {
                html.push_str(&format!("<h1>{}</h1>\n", &line[2..]));
            } else if line.starts_with("## ") {
                html.push_str(&format!("<h2>{}</h2>\n", &line[3..]));
            } else if line.starts_with("### ") {
                html.push_str(&format!("<h3>{}</h3>\n", &line[4..]));
            } else if line.starts_with("```") {
                html.push_str("<pre><code>");
            } else if line.starts_with("- ") {
                html.push_str(&format!("<li>{}</li>\n", &line[2..]));
            } else if !line.is_empty() {
                html.push_str(&format!("<p>{}</p>\n", line));
            }
        }

        html
    }
}

fn html_escape(s: &str) -> String {
    s.replace('&', "&amp;")
        .replace('<', "&lt;")
        .replace('>', "&gt;")
        .replace('"', "&quot;")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN ENTRY POINT
// ═══════════════════════════════════════════════════════════════════════════════

/// Generate documentation for a project
pub fn generate(project_path: &str, output_dir: &str) -> Result<(), DocError> {
    println!("╔═══════════════════════════════════════════════════════════════╗");
    println!("║  Quark Doc - QUANTA-UNIVERSE Documentation Generator         ║");
    println!("╚═══════════════════════════════════════════════════════════════╝");
    println!();

    let mut parser = DocParser::new();
    let mut modules = HashMap::new();

    // Find all .quanta files
    for entry in walk_dir(project_path)? {
        if entry.ends_with(".quanta") {
            println!("  Parsing {}...", entry);
            match parser.parse_file(&entry) {
                Ok(module) => {
                    modules.insert(module.name.clone(), module);
                }
                Err(e) => {
                    println!("    Warning: {:?}", e);
                }
            }
        }
    }

    let crate_doc = CrateDoc {
        name: Path::new(project_path).file_name().unwrap_or("crate").to_string(),
        version: "2.0.0".to_string(),
        description: Some("QUANTA-UNIVERSE - The Complete Physics-Inspired Software Universe".to_string()),
        modules,
        readme: None,
    };

    let generator = HtmlGenerator::new(HtmlConfig {
        output_dir: output_dir.to_string(),
        ..Default::default()
    });

    generator.generate(&crate_doc)?;

    Ok(())
}

pub fn main() {
    if let Err(e) = generate(".", "target/doc") {
        println!("Error: {:?}", e);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// API DOCUMENTATION GENERATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Generates comprehensive API documentation with cross-references
pub struct ApiDocGenerator {
    config: ApiDocConfig,
    type_index: HashMap<String, TypeInfo>,
    function_index: HashMap<String, FunctionInfo>,
    cross_refs: HashMap<String, Vec<CrossRef>>,
}

#[derive(Clone)]
pub struct ApiDocConfig {
    pub output_dir: String,
    pub format: ApiDocFormat,
    pub include_examples: bool,
    pub include_source_links: bool,
    pub version: String,
    pub base_url: Option<String>,
}

#[derive(Clone, Copy)]
pub enum ApiDocFormat {
    Html,
    Markdown,
    Json,
    OpenApi,
}

#[derive(Clone)]
pub struct TypeInfo {
    pub name: String,
    pub module: String,
    pub kind: TypeKind,
    pub generics: Vec<String>,
    pub fields: Vec<FieldInfo>,
    pub methods: Vec<MethodInfo>,
    pub traits_impl: Vec<String>,
    pub doc: Option<String>,
}

#[derive(Clone)]
pub enum TypeKind {
    Struct,
    Enum,
    Trait,
    TypeAlias,
    Union,
}

#[derive(Clone)]
pub struct FieldInfo {
    pub name: String,
    pub type_name: String,
    pub visibility: Visibility,
    pub doc: Option<String>,
}

#[derive(Clone)]
pub struct MethodInfo {
    pub name: String,
    pub signature: String,
    pub is_static: bool,
    pub is_async: bool,
    pub params: Vec<ParamInfo>,
    pub return_type: Option<String>,
    pub doc: Option<String>,
    pub examples: Vec<String>,
}

#[derive(Clone)]
pub struct ParamInfo {
    pub name: String,
    pub type_name: String,
    pub is_mutable: bool,
    pub is_self: bool,
}

#[derive(Clone)]
pub struct FunctionInfo {
    pub name: String,
    pub module: String,
    pub signature: String,
    pub is_async: bool,
    pub params: Vec<ParamInfo>,
    pub return_type: Option<String>,
    pub doc: Option<String>,
    pub examples: Vec<String>,
}

#[derive(Clone)]
pub struct CrossRef {
    pub from_item: String,
    pub to_item: String,
    pub ref_kind: RefKind,
}

#[derive(Clone)]
pub enum RefKind {
    Uses,
    UsedBy,
    Implements,
    ImplementedBy,
    Returns,
    Parameter,
}

impl ApiDocGenerator {
    pub fn new(config: ApiDocConfig) -> Self {
        ApiDocGenerator {
            config,
            type_index: HashMap::new(),
            function_index: HashMap::new(),
            cross_refs: HashMap::new(),
        }
    }

    /// Index all types and functions from parsed modules
    pub fn index_modules(&mut self, modules: &HashMap<String, ModuleDoc>) {
        for (module_path, module) in modules {
            for item in &module.items {
                match item.kind {
                    ItemKind::Struct | ItemKind::Enum | ItemKind::Trait => {
                        self.index_type(module_path, item);
                    }
                    ItemKind::Function => {
                        self.index_function(module_path, item);
                    }
                    _ => {}
                }
            }
        }

        self.build_cross_references();
    }

    fn index_type(&mut self, module: &str, item: &DocItem) {
        let type_info = TypeInfo {
            name: item.name.clone(),
            module: module.to_string(),
            kind: match item.kind {
                ItemKind::Struct => TypeKind::Struct,
                ItemKind::Enum => TypeKind::Enum,
                ItemKind::Trait => TypeKind::Trait,
                _ => TypeKind::Struct,
            },
            generics: self.extract_generics(&item.signature),
            fields: Vec::new(), // Would be populated from full parse
            methods: Vec::new(),
            traits_impl: Vec::new(),
            doc: item.doc_comment.clone(),
        };

        self.type_index.insert(
            format!("{}::{}", module, item.name),
            type_info,
        );
    }

    fn index_function(&mut self, module: &str, item: &DocItem) {
        let func_info = FunctionInfo {
            name: item.name.clone(),
            module: module.to_string(),
            signature: item.signature.clone(),
            is_async: item.signature.starts_with("async"),
            params: self.extract_params(&item.signature),
            return_type: self.extract_return_type(&item.signature),
            doc: item.doc_comment.clone(),
            examples: self.extract_examples(&item.doc_comment),
        };

        self.function_index.insert(
            format!("{}::{}", module, item.name),
            func_info,
        );
    }

    fn extract_generics(&self, signature: &str) -> Vec<String> {
        let mut generics = Vec::new();
        if let Some(start) = signature.find('<') {
            if let Some(end) = signature.find('>') {
                let generic_str = &signature[start + 1..end];
                for g in generic_str.split(',') {
                    generics.push(g.trim().to_string());
                }
            }
        }
        generics
    }

    fn extract_params(&self, signature: &str) -> Vec<ParamInfo> {
        let mut params = Vec::new();
        if let Some(start) = signature.find('(') {
            if let Some(end) = signature.rfind(')') {
                let params_str = &signature[start + 1..end];
                for param in params_str.split(',') {
                    let param = param.trim();
                    if param.is_empty() {
                        continue;
                    }

                    let is_self = param.contains("self");
                    let is_mutable = param.contains("mut");

                    if is_self {
                        params.push(ParamInfo {
                            name: "self".to_string(),
                            type_name: "Self".to_string(),
                            is_mutable,
                            is_self: true,
                        });
                    } else if let Some(colon_idx) = param.find(':') {
                        let name = param[..colon_idx].trim().trim_start_matches("mut ").to_string();
                        let type_name = param[colon_idx + 1..].trim().to_string();
                        params.push(ParamInfo {
                            name,
                            type_name,
                            is_mutable,
                            is_self: false,
                        });
                    }
                }
            }
        }
        params
    }

    fn extract_return_type(&self, signature: &str) -> Option<String> {
        if let Some(arrow_idx) = signature.find("->") {
            let return_part = signature[arrow_idx + 2..].trim();
            let return_type = return_part.split('{').next().unwrap_or(return_part).trim();
            if !return_type.is_empty() {
                return Some(return_type.to_string());
            }
        }
        None
    }

    fn extract_examples(&self, doc: &Option<String>) -> Vec<String> {
        let mut examples = Vec::new();
        if let Some(ref doc) = doc {
            let mut in_example = false;
            let mut current_example = String::new();

            for line in doc.lines() {
                if line.contains("```") {
                    if in_example {
                        examples.push(current_example.clone());
                        current_example.clear();
                    }
                    in_example = !in_example;
                } else if in_example {
                    current_example.push_str(line);
                    current_example.push('\n');
                }
            }
        }
        examples
    }

    fn build_cross_references(&mut self) {
        // Build cross-references between types and functions
        for (func_path, func) in &self.function_index {
            // Check return type references
            if let Some(ref return_type) = func.return_type {
                for (type_path, type_info) in &self.type_index {
                    if return_type.contains(&type_info.name) {
                        self.add_cross_ref(func_path, type_path, RefKind::Returns);
                    }
                }
            }

            // Check parameter type references
            for param in &func.params {
                for (type_path, type_info) in &self.type_index {
                    if param.type_name.contains(&type_info.name) {
                        self.add_cross_ref(func_path, type_path, RefKind::Parameter);
                    }
                }
            }
        }
    }

    fn add_cross_ref(&mut self, from: &str, to: &str, kind: RefKind) {
        let cross_ref = CrossRef {
            from_item: from.to_string(),
            to_item: to.to_string(),
            ref_kind: kind,
        };

        self.cross_refs
            .entry(from.to_string())
            .or_insert_with(Vec::new)
            .push(cross_ref);
    }

    /// Generate API documentation
    pub fn generate(&self) -> Result<(), DocError> {
        match self.config.format {
            ApiDocFormat::Html => self.generate_html(),
            ApiDocFormat::Markdown => self.generate_markdown(),
            ApiDocFormat::Json => self.generate_json(),
            ApiDocFormat::OpenApi => self.generate_openapi(),
        }
    }

    fn generate_html(&self) -> Result<(), DocError> {
        create_dir_all(&self.config.output_dir)?;

        // Generate index page
        self.generate_api_index_html()?;

        // Generate type pages
        for (path, type_info) in &self.type_index {
            self.generate_type_html(path, type_info)?;
        }

        // Generate function pages
        for (path, func_info) in &self.function_index {
            self.generate_function_html(path, func_info)?;
        }

        // Generate search index
        self.generate_search_index()?;

        Ok(())
    }

    fn generate_api_index_html(&self) -> Result<(), DocError> {
        let mut html = String::new();

        html.push_str(&format!(r#"<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QUANTA-UNIVERSE API Reference v{}</title>
    <link rel="stylesheet" href="api-style.css">
</head>
<body>
<header class="api-header">
    <h1>QUANTA-UNIVERSE API Reference</h1>
    <p>Version {}</p>
    <input type="search" id="api-search" placeholder="Search API...">
</header>
<main class="api-main">
<section class="api-section">
    <h2>Types</h2>
    <table class="api-table">
        <thead>
            <tr><th>Type</th><th>Module</th><th>Kind</th><th>Description</th></tr>
        </thead>
        <tbody>
"#, self.config.version, self.config.version));

        for (path, type_info) in &self.type_index {
            let kind_str = match type_info.kind {
                TypeKind::Struct => "struct",
                TypeKind::Enum => "enum",
                TypeKind::Trait => "trait",
                TypeKind::TypeAlias => "type",
                TypeKind::Union => "union",
            };

            let desc = type_info.doc.as_ref()
                .and_then(|d| d.lines().next())
                .unwrap_or("");

            html.push_str(&format!(
                "<tr><td><a href=\"{}.html\">{}</a></td><td>{}</td><td>{}</td><td>{}</td></tr>\n",
                path.replace("::", "_"),
                type_info.name,
                type_info.module,
                kind_str,
                html_escape(desc)
            ));
        }

        html.push_str("</tbody></table></section>\n");

        html.push_str(r#"<section class="api-section">
    <h2>Functions</h2>
    <table class="api-table">
        <thead>
            <tr><th>Function</th><th>Module</th><th>Signature</th></tr>
        </thead>
        <tbody>
"#);

        for (path, func_info) in &self.function_index {
            html.push_str(&format!(
                "<tr><td><a href=\"{}.html\">{}</a></td><td>{}</td><td><code>{}</code></td></tr>\n",
                path.replace("::", "_"),
                func_info.name,
                func_info.module,
                html_escape(&func_info.signature)
            ));
        }

        html.push_str("</tbody></table></section>\n");
        html.push_str("</main>\n<script src=\"api-search.js\"></script>\n</body></html>");

        write_string(&format!("{}/index.html", self.config.output_dir), &html)?;

        // Generate API CSS
        self.generate_api_css()?;

        Ok(())
    }

    fn generate_type_html(&self, path: &str, type_info: &TypeInfo) -> Result<(), DocError> {
        let mut html = String::new();

        let kind_str = match type_info.kind {
            TypeKind::Struct => "struct",
            TypeKind::Enum => "enum",
            TypeKind::Trait => "trait",
            TypeKind::TypeAlias => "type",
            TypeKind::Union => "union",
        };

        html.push_str(&format!(r#"<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{} - QUANTA-UNIVERSE API</title>
    <link rel="stylesheet" href="api-style.css">
</head>
<body>
<nav class="breadcrumb">
    <a href="index.html">API</a> &gt; <a href="#{}">{}</a> &gt; {}
</nav>
<main class="type-doc">
<h1>{} {}</h1>
<p class="module-path">Module: <code>{}</code></p>
"#, type_info.name, type_info.module, type_info.module, type_info.name, kind_str, type_info.name, type_info.module));

        if let Some(ref doc) = type_info.doc {
            html.push_str("<div class=\"doc-content\">\n");
            html.push_str(&markdown_to_html_simple(doc));
            html.push_str("</div>\n");
        }

        if !type_info.generics.is_empty() {
            html.push_str("<h2>Type Parameters</h2>\n<ul>\n");
            for g in &type_info.generics {
                html.push_str(&format!("<li><code>{}</code></li>\n", g));
            }
            html.push_str("</ul>\n");
        }

        if !type_info.fields.is_empty() {
            html.push_str("<h2>Fields</h2>\n<table class=\"fields-table\">\n");
            html.push_str("<thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>\n<tbody>\n");
            for field in &type_info.fields {
                let vis = match field.visibility {
                    Visibility::Public => "pub ",
                    _ => "",
                };
                html.push_str(&format!(
                    "<tr><td><code>{}{}</code></td><td><code>{}</code></td><td>{}</td></tr>\n",
                    vis,
                    field.name,
                    html_escape(&field.type_name),
                    field.doc.as_ref().unwrap_or(&String::new())
                ));
            }
            html.push_str("</tbody></table>\n");
        }

        if !type_info.methods.is_empty() {
            html.push_str("<h2>Methods</h2>\n");
            for method in &type_info.methods {
                html.push_str(&format!(
                    "<div class=\"method\">\n<h3 id=\"{}\">{}</h3>\n<pre><code>{}</code></pre>\n",
                    method.name,
                    method.name,
                    html_escape(&method.signature)
                ));

                if let Some(ref doc) = method.doc {
                    html.push_str(&format!("<div class=\"method-doc\">{}</div>\n", markdown_to_html_simple(doc)));
                }

                if !method.examples.is_empty() {
                    html.push_str("<h4>Examples</h4>\n");
                    for example in &method.examples {
                        html.push_str(&format!("<pre class=\"example\"><code>{}</code></pre>\n", html_escape(example)));
                    }
                }

                html.push_str("</div>\n");
            }
        }

        // Cross references
        if let Some(refs) = self.cross_refs.get(path) {
            html.push_str("<h2>See Also</h2>\n<ul>\n");
            for cross_ref in refs {
                html.push_str(&format!(
                    "<li><a href=\"{}.html\">{}</a></li>\n",
                    cross_ref.to_item.replace("::", "_"),
                    cross_ref.to_item
                ));
            }
            html.push_str("</ul>\n");
        }

        html.push_str("</main>\n</body></html>");

        let file_path = format!("{}/{}.html", self.config.output_dir, path.replace("::", "_"));
        write_string(&file_path, &html)?;

        Ok(())
    }

    fn generate_function_html(&self, path: &str, func_info: &FunctionInfo) -> Result<(), DocError> {
        let mut html = String::new();

        html.push_str(&format!(r#"<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{} - QUANTA-UNIVERSE API</title>
    <link rel="stylesheet" href="api-style.css">
</head>
<body>
<nav class="breadcrumb">
    <a href="index.html">API</a> &gt; <a href="#{}">{}</a> &gt; {}
</nav>
<main class="function-doc">
<h1>fn {}</h1>
<pre class="signature"><code>{}</code></pre>
<p class="module-path">Module: <code>{}</code></p>
"#, func_info.name, func_info.module, func_info.module, func_info.name, func_info.name, html_escape(&func_info.signature), func_info.module));

        if let Some(ref doc) = func_info.doc {
            html.push_str("<div class=\"doc-content\">\n");
            html.push_str(&markdown_to_html_simple(doc));
            html.push_str("</div>\n");
        }

        if !func_info.params.is_empty() {
            html.push_str("<h2>Parameters</h2>\n<table class=\"params-table\">\n");
            html.push_str("<thead><tr><th>Name</th><th>Type</th></tr></thead>\n<tbody>\n");
            for param in &func_info.params {
                if !param.is_self {
                    html.push_str(&format!(
                        "<tr><td><code>{}</code></td><td><code>{}</code></td></tr>\n",
                        param.name,
                        html_escape(&param.type_name)
                    ));
                }
            }
            html.push_str("</tbody></table>\n");
        }

        if let Some(ref return_type) = func_info.return_type {
            html.push_str(&format!("<h2>Returns</h2>\n<p><code>{}</code></p>\n", html_escape(return_type)));
        }

        if !func_info.examples.is_empty() {
            html.push_str("<h2>Examples</h2>\n");
            for example in &func_info.examples {
                html.push_str(&format!("<pre class=\"example\"><code>{}</code></pre>\n", html_escape(example)));
            }
        }

        html.push_str("</main>\n</body></html>");

        let file_path = format!("{}/{}.html", self.config.output_dir, path.replace("::", "_"));
        write_string(&file_path, &html)?;

        Ok(())
    }

    fn generate_api_css(&self) -> Result<(), DocError> {
        let css = r#":root {
    --bg: #0d1117;
    --surface: #161b22;
    --border: #30363d;
    --text: #c9d1d9;
    --text-muted: #8b949e;
    --accent: #58a6ff;
    --success: #3fb950;
    --warning: #d29922;
}

body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; margin: 0; }
.api-header { background: var(--surface); padding: 2rem; border-bottom: 1px solid var(--border); text-align: center; }
.api-header h1 { margin: 0; color: var(--accent); }
#api-search { margin-top: 1rem; padding: 0.75rem 1rem; width: 300px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); }
.api-main { max-width: 1200px; margin: 0 auto; padding: 2rem; }
.api-section { margin: 2rem 0; }
.api-section h2 { color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
.api-table { width: 100%; border-collapse: collapse; }
.api-table th, .api-table td { text-align: left; padding: 0.75rem; border-bottom: 1px solid var(--border); }
.api-table th { color: var(--text-muted); font-weight: 600; }
.api-table a { color: var(--accent); text-decoration: none; }
.api-table a:hover { text-decoration: underline; }
.breadcrumb { background: var(--surface); padding: 0.75rem 2rem; border-bottom: 1px solid var(--border); }
.breadcrumb a { color: var(--accent); text-decoration: none; }
.type-doc, .function-doc { max-width: 900px; margin: 0 auto; padding: 2rem; }
h1 { color: var(--text); }
.module-path { color: var(--text-muted); }
.signature { background: var(--surface); padding: 1rem; border-radius: 6px; overflow-x: auto; }
.doc-content { margin: 1.5rem 0; }
.method { margin: 1.5rem 0; padding: 1rem; border: 1px solid var(--border); border-radius: 6px; }
.method h3 { margin-top: 0; color: var(--accent); }
.fields-table, .params-table { width: 100%; margin: 1rem 0; }
.example { background: var(--surface); border-left: 3px solid var(--success); padding: 1rem; margin: 1rem 0; }
code { font-family: 'JetBrains Mono', 'Fira Code', monospace; background: var(--surface); padding: 0.2rem 0.4rem; border-radius: 3px; }
pre code { display: block; padding: 0; background: none; }
"#;

        write_string(&format!("{}/api-style.css", self.config.output_dir), css)?;
        Ok(())
    }

    fn generate_search_index(&self) -> Result<(), DocError> {
        let mut index = Vec::new();

        for (path, type_info) in &self.type_index {
            index.push(format!(
                "{{\"type\":\"type\",\"name\":\"{}\",\"path\":\"{}\",\"module\":\"{}\"}}",
                type_info.name,
                path.replace("::", "_"),
                type_info.module
            ));
        }

        for (path, func_info) in &self.function_index {
            index.push(format!(
                "{{\"type\":\"function\",\"name\":\"{}\",\"path\":\"{}\",\"module\":\"{}\"}}",
                func_info.name,
                path.replace("::", "_"),
                func_info.module
            ));
        }

        let js = format!(r#"const searchIndex = [{}];

document.getElementById('api-search').addEventListener('input', function(e) {{
    const query = e.target.value.toLowerCase();
    const results = searchIndex.filter(item =>
        item.name.toLowerCase().includes(query) ||
        item.module.toLowerCase().includes(query)
    );
    // Update UI with results
}});
"#, index.join(",\n"));

        write_string(&format!("{}/api-search.js", self.config.output_dir), &js)?;
        Ok(())
    }

    fn generate_markdown(&self) -> Result<(), DocError> {
        create_dir_all(&self.config.output_dir)?;

        let mut md = String::new();
        md.push_str(&format!("# QUANTA-UNIVERSE API Reference v{}\n\n", self.config.version));
        md.push_str("## Table of Contents\n\n");

        // Types section
        md.push_str("### Types\n\n");
        for (path, type_info) in &self.type_index {
            md.push_str(&format!("- [{}](#{}) - {}\n",
                type_info.name,
                path.replace("::", "-"),
                type_info.doc.as_ref().and_then(|d| d.lines().next()).unwrap_or("")
            ));
        }

        // Functions section
        md.push_str("\n### Functions\n\n");
        for (path, func_info) in &self.function_index {
            md.push_str(&format!("- [{}](#{}) - `{}`\n",
                func_info.name,
                path.replace("::", "-"),
                func_info.signature
            ));
        }

        // Detailed documentation
        md.push_str("\n---\n\n## Type Reference\n\n");
        for (path, type_info) in &self.type_index {
            md.push_str(&format!("### {} {}\n\n",
                match type_info.kind {
                    TypeKind::Struct => "struct",
                    TypeKind::Enum => "enum",
                    TypeKind::Trait => "trait",
                    TypeKind::TypeAlias => "type",
                    TypeKind::Union => "union",
                },
                type_info.name
            ));
            md.push_str(&format!("**Module:** `{}`\n\n", type_info.module));
            if let Some(ref doc) = type_info.doc {
                md.push_str(doc);
                md.push_str("\n\n");
            }
        }

        md.push_str("## Function Reference\n\n");
        for (path, func_info) in &self.function_index {
            md.push_str(&format!("### fn {}\n\n", func_info.name));
            md.push_str(&format!("```quanta\n{}\n```\n\n", func_info.signature));
            md.push_str(&format!("**Module:** `{}`\n\n", func_info.module));
            if let Some(ref doc) = func_info.doc {
                md.push_str(doc);
                md.push_str("\n\n");
            }
        }

        write_string(&format!("{}/API.md", self.config.output_dir), &md)?;
        Ok(())
    }

    fn generate_json(&self) -> Result<(), DocError> {
        create_dir_all(&self.config.output_dir)?;

        let mut json = String::new();
        json.push_str("{\n");
        json.push_str(&format!("  \"version\": \"{}\",\n", self.config.version));
        json.push_str("  \"types\": {\n");

        let type_count = self.type_index.len();
        for (i, (path, type_info)) in self.type_index.iter().enumerate() {
            json.push_str(&format!("    \"{}\": {{\n", path));
            json.push_str(&format!("      \"name\": \"{}\",\n", type_info.name));
            json.push_str(&format!("      \"module\": \"{}\",\n", type_info.module));
            json.push_str(&format!("      \"kind\": \"{:?}\"\n", type_info.kind));
            json.push_str("    }");
            if i < type_count - 1 { json.push(','); }
            json.push('\n');
        }

        json.push_str("  },\n");
        json.push_str("  \"functions\": {\n");

        let func_count = self.function_index.len();
        for (i, (path, func_info)) in self.function_index.iter().enumerate() {
            json.push_str(&format!("    \"{}\": {{\n", path));
            json.push_str(&format!("      \"name\": \"{}\",\n", func_info.name));
            json.push_str(&format!("      \"module\": \"{}\",\n", func_info.module));
            json.push_str(&format!("      \"signature\": \"{}\"\n", func_info.signature.replace("\"", "\\\"")));
            json.push_str("    }");
            if i < func_count - 1 { json.push(','); }
            json.push('\n');
        }

        json.push_str("  }\n");
        json.push_str("}\n");

        write_string(&format!("{}/api.json", self.config.output_dir), &json)?;
        Ok(())
    }

    fn generate_openapi(&self) -> Result<(), DocError> {
        create_dir_all(&self.config.output_dir)?;

        let mut yaml = String::new();
        yaml.push_str(&format!(r#"openapi: 3.0.3
info:
  title: QUANTA-UNIVERSE API
  version: '{}'
  description: The Complete Physics-Inspired Software Universe API
paths:
"#, self.config.version));

        // Generate OpenAPI paths from functions
        for (path, func_info) in &self.function_index {
            let api_path = format!("/{}", path.replace("::", "/"));
            yaml.push_str(&format!("  {}:\n", api_path));
            yaml.push_str("    post:\n");
            yaml.push_str(&format!("      summary: {}\n", func_info.name));
            if let Some(ref doc) = func_info.doc {
                yaml.push_str(&format!("      description: |\n        {}\n", doc.lines().next().unwrap_or("")));
            }
            yaml.push_str("      responses:\n");
            yaml.push_str("        '200':\n");
            yaml.push_str("          description: Success\n");
        }

        write_string(&format!("{}/openapi.yaml", self.config.output_dir), &yaml)?;
        Ok(())
    }
}

fn markdown_to_html_simple(md: &str) -> String {
    let mut html = String::new();
    for line in md.lines() {
        if line.starts_with("# ") {
            html.push_str(&format!("<h1>{}</h1>\n", &line[2..]));
        } else if line.starts_with("## ") {
            html.push_str(&format!("<h2>{}</h2>\n", &line[3..]));
        } else if line.starts_with("### ") {
            html.push_str(&format!("<h3>{}</h3>\n", &line[4..]));
        } else if line.starts_with("- ") {
            html.push_str(&format!("<li>{}</li>\n", &line[2..]));
        } else if !line.is_empty() {
            html.push_str(&format!("<p>{}</p>\n", line));
        }
    }
    html
}

/// Generate comprehensive API documentation for QUANTA-UNIVERSE
pub fn generate_api_docs(project_path: &str, output_dir: &str) -> Result<(), DocError> {
    println!("╔═══════════════════════════════════════════════════════════════╗");
    println!("║  QUANTA-UNIVERSE API Documentation Generator                  ║");
    println!("╚═══════════════════════════════════════════════════════════════╝");
    println!();

    let mut parser = DocParser::new();
    let mut modules = HashMap::new();

    // Find all .quanta files
    for entry in walk_dir(project_path)? {
        if entry.ends_with(".quanta") {
            println!("  Parsing {}...", entry);
            match parser.parse_file(&entry) {
                Ok(module) => {
                    modules.insert(module.name.clone(), module);
                }
                Err(e) => {
                    println!("    Warning: {:?}", e);
                }
            }
        }
    }

    println!("\n  Indexing {} modules...", modules.len());

    let config = ApiDocConfig {
        output_dir: output_dir.to_string(),
        format: ApiDocFormat::Html,
        include_examples: true,
        include_source_links: true,
        version: "2.0.0".to_string(),
        base_url: None,
    };

    let mut generator = ApiDocGenerator::new(config);
    generator.index_modules(&modules);

    println!("  Indexed {} types, {} functions",
        generator.type_index.len(),
        generator.function_index.len());

    println!("\n  Generating HTML documentation...");
    generator.generate()?;

    // Also generate markdown
    let md_config = ApiDocConfig {
        output_dir: output_dir.to_string(),
        format: ApiDocFormat::Markdown,
        include_examples: true,
        include_source_links: true,
        version: "2.0.0".to_string(),
        base_url: None,
    };

    let mut md_generator = ApiDocGenerator::new(md_config);
    md_generator.index_modules(&modules);
    md_generator.generate()?;

    // Generate JSON
    let json_config = ApiDocConfig {
        output_dir: output_dir.to_string(),
        format: ApiDocFormat::Json,
        include_examples: true,
        include_source_links: true,
        version: "2.0.0".to_string(),
        base_url: None,
    };

    let mut json_generator = ApiDocGenerator::new(json_config);
    json_generator.index_modules(&modules);
    json_generator.generate()?;

    println!("\n  ✓ API documentation generated at {}", output_dir);
    println!("    - index.html (HTML reference)");
    println!("    - API.md (Markdown reference)");
    println!("    - api.json (JSON schema)");

    Ok(())
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENHANCED MARKDOWN PARSER - Full CommonMark/GFM Support
// ═══════════════════════════════════════════════════════════════════════════════

/// Full-featured Markdown parser with CommonMark and GitHub Flavored Markdown support
pub struct MarkdownParser {
    config: MarkdownConfig,
    extensions: Vec<MarkdownExtension>,
    custom_renderers: HashMap<String, Box<dyn CustomRenderer>>,
}

#[derive(Clone)]
pub struct MarkdownConfig {
    pub hard_breaks: bool,
    pub smart_punctuation: bool,
    pub header_anchors: bool,
    pub task_lists: bool,
    pub tables: bool,
    pub strikethrough: bool,
    pub autolinks: bool,
    pub footnotes: bool,
    pub definition_lists: bool,
    pub highlight_code: bool,
    pub math_support: bool,
    pub emoji_support: bool,
    pub toc_generation: bool,
    pub safe_mode: bool,
}

impl Default for MarkdownConfig {
    fn default() -> Self {
        MarkdownConfig {
            hard_breaks: false,
            smart_punctuation: true,
            header_anchors: true,
            task_lists: true,
            tables: true,
            strikethrough: true,
            autolinks: true,
            footnotes: true,
            definition_lists: true,
            highlight_code: true,
            math_support: true,
            emoji_support: true,
            toc_generation: true,
            safe_mode: false,
        }
    }
}

#[derive(Clone)]
pub enum MarkdownExtension {
    Mermaid,
    PlantUml,
    KaTeX,
    MathJax,
    Highlight,
    Emoji,
    Abbreviations,
    CustomContainers,
    Admonitions,
    Tabs,
}

pub trait CustomRenderer: Send + Sync {
    fn name(&self) -> &str;
    fn can_render(&self, block: &MarkdownBlock) -> bool;
    fn render(&self, block: &MarkdownBlock) -> String;
}

/// Markdown AST node types
#[derive(Clone, Debug)]
pub enum MarkdownBlock {
    Document(Vec<MarkdownBlock>),
    Heading { level: u8, content: Vec<MarkdownInline>, id: Option<String> },
    Paragraph(Vec<MarkdownInline>),
    BlockQuote(Vec<MarkdownBlock>),
    CodeBlock { language: Option<String>, content: String, info: Option<String> },
    FencedDiv { class: String, content: Vec<MarkdownBlock> },
    List { ordered: bool, start: u32, items: Vec<ListItem> },
    Table { header: Vec<TableCell>, rows: Vec<Vec<TableCell>>, alignments: Vec<Alignment> },
    ThematicBreak,
    HtmlBlock(String),
    Footnote { label: String, content: Vec<MarkdownBlock> },
    DefinitionList(Vec<(Vec<MarkdownInline>, Vec<MarkdownBlock>)>),
    Admonition { kind: AdmonitionKind, title: Option<String>, content: Vec<MarkdownBlock> },
    MathBlock(String),
    Diagram { kind: DiagramKind, source: String },
    Toc { max_level: u8 },
}

#[derive(Clone, Debug)]
pub enum MarkdownInline {
    Text(String),
    SoftBreak,
    HardBreak,
    Emphasis(Vec<MarkdownInline>),
    Strong(Vec<MarkdownInline>),
    Strikethrough(Vec<MarkdownInline>),
    Code(String),
    Link { url: String, title: Option<String>, content: Vec<MarkdownInline> },
    Image { url: String, alt: String, title: Option<String> },
    FootnoteRef(String),
    Emoji(String),
    Math(String),
    Html(String),
    Superscript(Vec<MarkdownInline>),
    Subscript(Vec<MarkdownInline>),
    Highlight(Vec<MarkdownInline>),
    Insert(Vec<MarkdownInline>),
    Abbreviation { abbr: String, full: String },
}

#[derive(Clone, Debug)]
pub struct ListItem {
    pub content: Vec<MarkdownBlock>,
    pub checked: Option<bool>,
}

#[derive(Clone, Debug)]
pub struct TableCell {
    pub content: Vec<MarkdownInline>,
    pub is_header: bool,
}

#[derive(Clone, Copy, Debug)]
pub enum Alignment {
    Left,
    Center,
    Right,
    None,
}

#[derive(Clone, Copy, Debug)]
pub enum AdmonitionKind {
    Note,
    Tip,
    Info,
    Warning,
    Danger,
    Bug,
    Example,
    Quote,
    Abstract,
    Success,
    Question,
    Failure,
}

#[derive(Clone, Copy, Debug)]
pub enum DiagramKind {
    Mermaid,
    PlantUml,
    Dot,
    Ditaa,
    Svgbob,
}

impl MarkdownParser {
    pub fn new(config: MarkdownConfig) -> Self {
        MarkdownParser {
            config,
            extensions: Vec::new(),
            custom_renderers: HashMap::new(),
        }
    }

    pub fn with_extension(mut self, ext: MarkdownExtension) -> Self {
        self.extensions.push(ext);
        self
    }

    pub fn add_renderer(&mut self, name: &str, renderer: Box<dyn CustomRenderer>) {
        self.custom_renderers.insert(name.to_string(), renderer);
    }

    /// Parse markdown text into AST
    pub fn parse(&self, text: &str) -> MarkdownBlock {
        let mut blocks = Vec::new();
        let lines: Vec<&str> = text.lines().collect();
        let mut i = 0;

        while i < lines.len() {
            let line = lines[i];

            // Skip empty lines
            if line.trim().is_empty() {
                i += 1;
                continue;
            }

            // ATX Heading
            if line.starts_with('#') {
                if let Some(heading) = self.parse_atx_heading(line) {
                    blocks.push(heading);
                    i += 1;
                    continue;
                }
            }

            // Fenced code block
            if line.starts_with("```") || line.starts_with("~~~") {
                let fence = if line.starts_with("```") { "```" } else { "~~~" };
                let (block, consumed) = self.parse_fenced_code(&lines[i..], fence);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Block quote
            if line.starts_with('>') {
                let (block, consumed) = self.parse_block_quote(&lines[i..]);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Thematic break
            if self.is_thematic_break(line) {
                blocks.push(MarkdownBlock::ThematicBreak);
                i += 1;
                continue;
            }

            // List
            if self.is_list_item(line) {
                let (block, consumed) = self.parse_list(&lines[i..]);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Table
            if self.config.tables && i + 1 < lines.len() && self.is_table_row(line) && self.is_table_delimiter(lines[i + 1]) {
                let (block, consumed) = self.parse_table(&lines[i..]);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Admonition (GFM-style or custom)
            if line.starts_with(":::") || line.starts_with("!!! ") || line.starts_with("> [!") {
                let (block, consumed) = self.parse_admonition(&lines[i..]);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Definition list
            if self.config.definition_lists && i + 1 < lines.len() && lines[i + 1].starts_with(": ") {
                let (block, consumed) = self.parse_definition_list(&lines[i..]);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Footnote definition
            if self.config.footnotes && line.starts_with("[^") {
                if let Some((block, consumed)) = self.parse_footnote_def(&lines[i..]) {
                    blocks.push(block);
                    i += consumed;
                    continue;
                }
            }

            // Math block
            if self.config.math_support && (line.starts_with("$$") || line.starts_with("\\[")) {
                let (block, consumed) = self.parse_math_block(&lines[i..]);
                blocks.push(block);
                i += consumed;
                continue;
            }

            // Table of contents
            if line.trim() == "[TOC]" || line.trim() == "[[toc]]" {
                blocks.push(MarkdownBlock::Toc { max_level: 3 });
                i += 1;
                continue;
            }

            // Default: paragraph
            let (block, consumed) = self.parse_paragraph(&lines[i..]);
            blocks.push(block);
            i += consumed;
        }

        MarkdownBlock::Document(blocks)
    }

    fn parse_atx_heading(&self, line: &str) -> Option<MarkdownBlock> {
        let trimmed = line.trim();
        let level = trimmed.chars().take_while(|&c| c == '#').count();

        if level == 0 || level > 6 {
            return None;
        }

        let content_start = level;
        let content = trimmed[content_start..].trim();

        // Remove trailing #s
        let content = content.trim_end_matches('#').trim();

        // Extract custom ID {#custom-id}
        let (content, id) = if let Some(id_start) = content.find("{#") {
            if let Some(id_end) = content.rfind('}') {
                let id = content[id_start + 2..id_end].to_string();
                let content = content[..id_start].trim();
                (content, Some(id))
            } else {
                (content, None)
            }
        } else if self.config.header_anchors {
            let id = self.slugify(content);
            (content, Some(id))
        } else {
            (content, None)
        };

        let inlines = self.parse_inlines(content);

        Some(MarkdownBlock::Heading {
            level: level as u8,
            content: inlines,
            id,
        })
    }

    fn parse_fenced_code(&self, lines: &[&str], fence: &str) -> (MarkdownBlock, usize) {
        let first_line = lines[0];
        let info = first_line.strip_prefix(fence).unwrap_or("").trim();
        let (language, info_string) = if let Some(space_idx) = info.find(' ') {
            (Some(info[..space_idx].to_string()), Some(info[space_idx..].trim().to_string()))
        } else if !info.is_empty() {
            (Some(info.to_string()), None)
        } else {
            (None, None)
        };

        let mut content = String::new();
        let mut i = 1;

        while i < lines.len() {
            if lines[i].starts_with(fence) {
                i += 1;
                break;
            }
            if !content.is_empty() {
                content.push('\n');
            }
            content.push_str(lines[i]);
            i += 1;
        }

        // Check for diagram types
        if let Some(ref lang) = language {
            match lang.as_str() {
                "mermaid" => {
                    return (MarkdownBlock::Diagram { kind: DiagramKind::Mermaid, source: content }, i);
                }
                "plantuml" | "puml" => {
                    return (MarkdownBlock::Diagram { kind: DiagramKind::PlantUml, source: content }, i);
                }
                "dot" | "graphviz" => {
                    return (MarkdownBlock::Diagram { kind: DiagramKind::Dot, source: content }, i);
                }
                "ditaa" => {
                    return (MarkdownBlock::Diagram { kind: DiagramKind::Ditaa, source: content }, i);
                }
                "svgbob" => {
                    return (MarkdownBlock::Diagram { kind: DiagramKind::Svgbob, source: content }, i);
                }
                _ => {}
            }
        }

        (MarkdownBlock::CodeBlock { language, content, info: info_string }, i)
    }

    fn parse_block_quote(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let mut content_lines = Vec::new();
        let mut i = 0;

        while i < lines.len() {
            let line = lines[i];
            if line.starts_with('>') {
                let content = line.strip_prefix('>').unwrap_or("").trim_start();
                content_lines.push(content);
                i += 1;
            } else if line.trim().is_empty() && i + 1 < lines.len() && lines[i + 1].starts_with('>') {
                content_lines.push("");
                i += 1;
            } else {
                break;
            }
        }

        let inner_text = content_lines.join("\n");
        let inner_doc = self.parse(&inner_text);

        let blocks = match inner_doc {
            MarkdownBlock::Document(blocks) => blocks,
            other => vec![other],
        };

        (MarkdownBlock::BlockQuote(blocks), i)
    }

    fn parse_list(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let first_line = lines[0];
        let (ordered, start) = self.get_list_info(first_line);
        let mut items = Vec::new();
        let mut i = 0;

        while i < lines.len() {
            let line = lines[i];

            if !self.is_list_item(line) && !line.trim().is_empty() {
                // Check for continuation
                if line.starts_with("  ") || line.starts_with("\t") {
                    // Continuation of previous item
                    if let Some(last_item) = items.last_mut() {
                        // Add to last item's content (would need more complex handling)
                    }
                    i += 1;
                    continue;
                }
                break;
            }

            if line.trim().is_empty() {
                i += 1;
                continue;
            }

            let item = self.parse_list_item(line);
            items.push(item);
            i += 1;
        }

        (MarkdownBlock::List { ordered, start, items }, i)
    }

    fn parse_list_item(&self, line: &str) -> ListItem {
        let trimmed = line.trim();

        // Check for task list
        let (checked, content) = if self.config.task_lists {
            if trimmed.starts_with("- [ ] ") || trimmed.starts_with("* [ ] ") {
                (Some(false), &trimmed[6..])
            } else if trimmed.starts_with("- [x] ") || trimmed.starts_with("- [X] ")
                    || trimmed.starts_with("* [x] ") || trimmed.starts_with("* [X] ") {
                (Some(true), &trimmed[6..])
            } else {
                (None, self.strip_list_marker(trimmed))
            }
        } else {
            (None, self.strip_list_marker(trimmed))
        };

        let para = MarkdownBlock::Paragraph(self.parse_inlines(content));

        ListItem {
            content: vec![para],
            checked,
        }
    }

    fn strip_list_marker(&self, line: &str) -> &str {
        // Unordered: - * +
        if line.starts_with("- ") || line.starts_with("* ") || line.starts_with("+ ") {
            return &line[2..];
        }

        // Ordered: 1. 2. etc.
        let mut chars = line.chars();
        while let Some(c) = chars.next() {
            if c.is_ascii_digit() {
                continue;
            }
            if c == '.' || c == ')' {
                let rest = chars.as_str().trim_start();
                return rest;
            }
            break;
        }

        line
    }

    fn parse_table(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let mut i = 0;

        // Parse header row
        let header_cells = self.parse_table_row(lines[i]);
        i += 1;

        // Parse delimiter row
        let alignments = self.parse_table_alignments(lines[i]);
        i += 1;

        // Parse body rows
        let mut rows = Vec::new();
        while i < lines.len() && self.is_table_row(lines[i]) {
            let row_cells = self.parse_table_row(lines[i]);
            rows.push(row_cells);
            i += 1;
        }

        let header: Vec<TableCell> = header_cells.into_iter().map(|content| {
            TableCell {
                content: self.parse_inlines(&content),
                is_header: true,
            }
        }).collect();

        let body_rows: Vec<Vec<TableCell>> = rows.into_iter().map(|row| {
            row.into_iter().map(|content| {
                TableCell {
                    content: self.parse_inlines(&content),
                    is_header: false,
                }
            }).collect()
        }).collect();

        (MarkdownBlock::Table { header, rows: body_rows, alignments }, i)
    }

    fn parse_table_row(&self, line: &str) -> Vec<String> {
        let line = line.trim();
        let line = line.strip_prefix('|').unwrap_or(line);
        let line = line.strip_suffix('|').unwrap_or(line);

        line.split('|')
            .map(|cell| cell.trim().to_string())
            .collect()
    }

    fn parse_table_alignments(&self, line: &str) -> Vec<Alignment> {
        self.parse_table_row(line)
            .into_iter()
            .map(|cell| {
                let cell = cell.trim();
                let left = cell.starts_with(':');
                let right = cell.ends_with(':');

                match (left, right) {
                    (true, true) => Alignment::Center,
                    (true, false) => Alignment::Left,
                    (false, true) => Alignment::Right,
                    (false, false) => Alignment::None,
                }
            })
            .collect()
    }

    fn parse_admonition(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let first_line = lines[0];

        // ::: type title
        // > [!NOTE] GitHub style
        // !!! type "title"

        let (kind, title, start_i) = if first_line.starts_with(":::") {
            let rest = first_line[3..].trim();
            let parts: Vec<&str> = rest.splitn(2, ' ').collect();
            let kind = self.parse_admonition_kind(parts.get(0).unwrap_or(&"note"));
            let title = parts.get(1).map(|s| s.to_string());
            (kind, title, 1)
        } else if first_line.starts_with("> [!") {
            if let Some(end) = first_line.find(']') {
                let kind_str = &first_line[4..end];
                let kind = self.parse_admonition_kind(kind_str);
                let title = if end + 1 < first_line.len() {
                    Some(first_line[end + 1..].trim().to_string())
                } else { None };
                (kind, title, 1)
            } else {
                (AdmonitionKind::Note, None, 1)
            }
        } else if first_line.starts_with("!!! ") {
            let rest = first_line[4..].trim();
            let parts: Vec<&str> = rest.splitn(2, ' ').collect();
            let kind = self.parse_admonition_kind(parts.get(0).unwrap_or(&"note"));
            let title = parts.get(1).map(|s| s.trim_matches('"').to_string());
            (kind, title, 1)
        } else {
            (AdmonitionKind::Note, None, 1)
        };

        let mut content_lines = Vec::new();
        let mut i = start_i;

        while i < lines.len() {
            let line = lines[i];

            // End marker for ::: style
            if line.trim() == ":::" {
                i += 1;
                break;
            }

            // For > [!...] style, continue while lines start with >
            if lines[0].starts_with("> [!") && !line.starts_with('>') && !line.trim().is_empty() {
                break;
            }

            let content = if line.starts_with('>') {
                line[1..].trim_start()
            } else if line.starts_with("    ") {
                &line[4..]
            } else {
                line
            };

            content_lines.push(content);
            i += 1;
        }

        let inner_text = content_lines.join("\n");
        let inner_doc = self.parse(&inner_text);

        let blocks = match inner_doc {
            MarkdownBlock::Document(blocks) => blocks,
            other => vec![other],
        };

        (MarkdownBlock::Admonition { kind, title, content: blocks }, i)
    }

    fn parse_admonition_kind(&self, s: &str) -> AdmonitionKind {
        match s.to_lowercase().as_str() {
            "note" => AdmonitionKind::Note,
            "tip" | "hint" => AdmonitionKind::Tip,
            "info" | "information" => AdmonitionKind::Info,
            "warning" | "warn" | "caution" => AdmonitionKind::Warning,
            "danger" | "error" | "attention" => AdmonitionKind::Danger,
            "bug" => AdmonitionKind::Bug,
            "example" => AdmonitionKind::Example,
            "quote" | "cite" => AdmonitionKind::Quote,
            "abstract" | "summary" | "tldr" => AdmonitionKind::Abstract,
            "success" | "check" | "done" => AdmonitionKind::Success,
            "question" | "help" | "faq" => AdmonitionKind::Question,
            "failure" | "fail" | "missing" => AdmonitionKind::Failure,
            _ => AdmonitionKind::Note,
        }
    }

    fn parse_definition_list(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let mut definitions = Vec::new();
        let mut i = 0;

        while i < lines.len() {
            let term_line = lines[i];
            if term_line.trim().is_empty() {
                i += 1;
                continue;
            }

            if !term_line.starts_with(": ") {
                let term_inlines = self.parse_inlines(term_line.trim());
                let mut defs = Vec::new();
                i += 1;

                while i < lines.len() && lines[i].starts_with(": ") {
                    let def_content = lines[i][2..].trim();
                    let def_block = MarkdownBlock::Paragraph(self.parse_inlines(def_content));
                    defs.push(def_block);
                    i += 1;
                }

                if !defs.is_empty() {
                    definitions.push((term_inlines, defs));
                }
            } else {
                break;
            }
        }

        (MarkdownBlock::DefinitionList(definitions), i)
    }

    fn parse_footnote_def(&self, lines: &[&str]) -> Option<(MarkdownBlock, usize)> {
        let first_line = lines[0];

        if let Some(bracket_end) = first_line.find("]:") {
            let label = first_line[2..bracket_end].to_string();
            let first_content = first_line[bracket_end + 2..].trim();

            let mut content_lines = vec![first_content];
            let mut i = 1;

            while i < lines.len() {
                let line = lines[i];
                if line.starts_with("    ") || line.starts_with("\t") {
                    content_lines.push(line.trim_start());
                    i += 1;
                } else if line.trim().is_empty() {
                    content_lines.push("");
                    i += 1;
                } else {
                    break;
                }
            }

            let inner_text = content_lines.join("\n");
            let inner_doc = self.parse(&inner_text);

            let blocks = match inner_doc {
                MarkdownBlock::Document(blocks) => blocks,
                other => vec![other],
            };

            return Some((MarkdownBlock::Footnote { label, content: blocks }, i));
        }

        None
    }

    fn parse_math_block(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let first_line = lines[0];
        let delimiter = if first_line.starts_with("$$") { "$$" } else { "\\]" };

        let mut content = String::new();
        let mut i = 0;

        if first_line.len() > 2 {
            content.push_str(&first_line[2..]);
            i = 1;
        } else {
            i = 1;
        }

        while i < lines.len() {
            if lines[i].contains(delimiter) {
                let line = lines[i];
                if let Some(end_idx) = line.find(delimiter) {
                    content.push_str(&line[..end_idx]);
                }
                i += 1;
                break;
            }
            if !content.is_empty() {
                content.push('\n');
            }
            content.push_str(lines[i]);
            i += 1;
        }

        (MarkdownBlock::MathBlock(content.trim().to_string()), i)
    }

    fn parse_paragraph(&self, lines: &[&str]) -> (MarkdownBlock, usize) {
        let mut content_lines = Vec::new();
        let mut i = 0;

        while i < lines.len() {
            let line = lines[i];

            if line.trim().is_empty() {
                break;
            }

            // Check for block-level elements that should break the paragraph
            if line.starts_with('#') || line.starts_with('>') || line.starts_with("```")
               || line.starts_with("~~~") || self.is_thematic_break(line)
               || self.is_list_item(line) || line.starts_with(":::") {
                break;
            }

            content_lines.push(line);
            i += 1;
        }

        let text = content_lines.join(if self.config.hard_breaks { "\n" } else { " " });
        let inlines = self.parse_inlines(&text);

        (MarkdownBlock::Paragraph(inlines), i.max(1))
    }

    fn parse_inlines(&self, text: &str) -> Vec<MarkdownInline> {
        let mut inlines = Vec::new();
        let mut chars: Vec<char> = text.chars().collect();
        let mut i = 0;
        let mut current_text = String::new();

        while i < chars.len() {
            let c = chars[i];

            match c {
                // Escape
                '\\' if i + 1 < chars.len() => {
                    if !current_text.is_empty() {
                        inlines.push(MarkdownInline::Text(current_text.clone()));
                        current_text.clear();
                    }
                    current_text.push(chars[i + 1]);
                    i += 2;
                }

                // Strong and emphasis
                '*' | '_' => {
                    let marker = c;
                    let count = chars[i..].iter().take_while(|&&ch| ch == marker).count();

                    if count >= 2 {
                        // Try strong
                        if let Some((content, consumed)) = self.find_inline_close(&chars[i..], &format!("{}{}", marker, marker)) {
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            let inner = self.parse_inlines(&content);
                            inlines.push(MarkdownInline::Strong(inner));
                            i += consumed;
                            continue;
                        }
                    }

                    if count >= 1 {
                        // Try emphasis
                        if let Some((content, consumed)) = self.find_inline_close(&chars[i..], &format!("{}", marker)) {
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            let inner = self.parse_inlines(&content);
                            inlines.push(MarkdownInline::Emphasis(inner));
                            i += consumed;
                            continue;
                        }
                    }

                    current_text.push(c);
                    i += 1;
                }

                // Strikethrough
                '~' if self.config.strikethrough && i + 1 < chars.len() && chars[i + 1] == '~' => {
                    if let Some((content, consumed)) = self.find_inline_close(&chars[i..], "~~") {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        let inner = self.parse_inlines(&content);
                        inlines.push(MarkdownInline::Strikethrough(inner));
                        i += consumed;
                        continue;
                    }
                    current_text.push(c);
                    i += 1;
                }

                // Inline code
                '`' => {
                    let backticks: String = chars[i..].iter().take_while(|&&ch| ch == '`').collect();
                    let bt_count = backticks.len();

                    if let Some((content, consumed)) = self.find_inline_close(&chars[i..], &backticks) {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        inlines.push(MarkdownInline::Code(content.trim().to_string()));
                        i += consumed;
                        continue;
                    }

                    current_text.push(c);
                    i += 1;
                }

                // Links and images
                '!' if i + 1 < chars.len() && chars[i + 1] == '[' => {
                    if let Some((alt, url, title, consumed)) = self.parse_link_or_image(&chars[i + 1..]) {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        inlines.push(MarkdownInline::Image { url, alt, title });
                        i += consumed + 1;
                        continue;
                    }
                    current_text.push(c);
                    i += 1;
                }

                '[' => {
                    if let Some((text_content, url, title, consumed)) = self.parse_link_or_image(&chars[i..]) {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        let content = self.parse_inlines(&text_content);
                        inlines.push(MarkdownInline::Link { url, title, content });
                        i += consumed;
                        continue;
                    }

                    // Footnote reference [^label]
                    if self.config.footnotes && i + 1 < chars.len() && chars[i + 1] == '^' {
                        if let Some(end) = chars[i..].iter().position(|&c| c == ']') {
                            let label: String = chars[i + 2..i + end].iter().collect();
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            inlines.push(MarkdownInline::FootnoteRef(label));
                            i += end + 1;
                            continue;
                        }
                    }

                    current_text.push(c);
                    i += 1;
                }

                // Inline math
                '$' if self.config.math_support => {
                    if i + 1 < chars.len() && chars[i + 1] != '$' {
                        if let Some((content, consumed)) = self.find_inline_close(&chars[i..], "$") {
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            inlines.push(MarkdownInline::Math(content));
                            i += consumed;
                            continue;
                        }
                    }
                    current_text.push(c);
                    i += 1;
                }

                // Emoji :emoji:
                ':' if self.config.emoji_support => {
                    if let Some(end) = chars[i + 1..].iter().position(|&c| c == ':') {
                        let emoji_name: String = chars[i + 1..i + 1 + end].iter().collect();
                        if emoji_name.chars().all(|c| c.is_alphanumeric() || c == '_' || c == '-') {
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            inlines.push(MarkdownInline::Emoji(emoji_name));
                            i += end + 2;
                            continue;
                        }
                    }
                    current_text.push(c);
                    i += 1;
                }

                // Autolinks <url>
                '<' if self.config.autolinks => {
                    if let Some(end) = chars[i..].iter().position(|&c| c == '>') {
                        let content: String = chars[i + 1..i + end].iter().collect();
                        if content.starts_with("http://") || content.starts_with("https://")
                           || content.starts_with("mailto:") {
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            let text_inlines = vec![MarkdownInline::Text(content.clone())];
                            inlines.push(MarkdownInline::Link {
                                url: content,
                                title: None,
                                content: text_inlines
                            });
                            i += end + 1;
                            continue;
                        }
                    }
                    current_text.push(c);
                    i += 1;
                }

                // Superscript ^text^
                '^' => {
                    if let Some((content, consumed)) = self.find_inline_close(&chars[i..], "^") {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        let inner = self.parse_inlines(&content);
                        inlines.push(MarkdownInline::Superscript(inner));
                        i += consumed;
                        continue;
                    }
                    current_text.push(c);
                    i += 1;
                }

                // Highlight ==text==
                '=' if i + 1 < chars.len() && chars[i + 1] == '=' => {
                    if let Some((content, consumed)) = self.find_inline_close(&chars[i..], "==") {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        let inner = self.parse_inlines(&content);
                        inlines.push(MarkdownInline::Highlight(inner));
                        i += consumed;
                        continue;
                    }
                    current_text.push(c);
                    i += 1;
                }

                // Line breaks
                '\n' => {
                    if self.config.hard_breaks {
                        if !current_text.is_empty() {
                            inlines.push(MarkdownInline::Text(current_text.clone()));
                            current_text.clear();
                        }
                        inlines.push(MarkdownInline::HardBreak);
                    } else {
                        // Check for two trailing spaces (hard break)
                        if current_text.ends_with("  ") {
                            current_text.truncate(current_text.len() - 2);
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            inlines.push(MarkdownInline::HardBreak);
                        } else {
                            if !current_text.is_empty() {
                                inlines.push(MarkdownInline::Text(current_text.clone()));
                                current_text.clear();
                            }
                            inlines.push(MarkdownInline::SoftBreak);
                        }
                    }
                    i += 1;
                }

                // Default
                _ => {
                    current_text.push(c);
                    i += 1;
                }
            }
        }

        if !current_text.is_empty() {
            inlines.push(MarkdownInline::Text(current_text));
        }

        // Smart punctuation
        if self.config.smart_punctuation {
            inlines = self.apply_smart_punctuation(inlines);
        }

        inlines
    }

    fn find_inline_close(&self, chars: &[char], delimiter: &str) -> Option<(String, usize)> {
        let delim_chars: Vec<char> = delimiter.chars().collect();
        let delim_len = delim_chars.len();

        if chars.len() < delim_len * 2 {
            return None;
        }

        // Skip opening delimiter
        let start = delim_len;
        let mut i = start;

        while i <= chars.len() - delim_len {
            // Check for closing delimiter
            let mut matches = true;
            for j in 0..delim_len {
                if chars[i + j] != delim_chars[j] {
                    matches = false;
                    break;
                }
            }

            if matches {
                let content: String = chars[start..i].iter().collect();
                return Some((content, i + delim_len));
            }

            // Handle escape
            if chars[i] == '\\' && i + 1 < chars.len() {
                i += 2;
            } else {
                i += 1;
            }
        }

        None
    }

    fn parse_link_or_image(&self, chars: &[char]) -> Option<(String, String, Option<String>, usize)> {
        // [text](url "title")
        if chars[0] != '[' {
            return None;
        }

        let mut i = 1;
        let mut bracket_depth = 1;

        // Find closing ]
        while i < chars.len() && bracket_depth > 0 {
            match chars[i] {
                '[' => bracket_depth += 1,
                ']' => bracket_depth -= 1,
                '\\' if i + 1 < chars.len() => i += 1,
                _ => {}
            }
            i += 1;
        }

        if bracket_depth != 0 {
            return None;
        }

        let text: String = chars[1..i - 1].iter().collect();

        // Check for (url)
        if i >= chars.len() || chars[i] != '(' {
            return None;
        }

        let url_start = i + 1;
        let mut paren_depth = 1;
        i += 1;

        while i < chars.len() && paren_depth > 0 {
            match chars[i] {
                '(' => paren_depth += 1,
                ')' => paren_depth -= 1,
                '\\' if i + 1 < chars.len() => i += 1,
                _ => {}
            }
            i += 1;
        }

        if paren_depth != 0 {
            return None;
        }

        let url_content: String = chars[url_start..i - 1].iter().collect();

        // Parse URL and optional title
        let (url, title) = if let Some(quote_start) = url_content.find('"') {
            let url = url_content[..quote_start].trim().to_string();
            let title_start = quote_start + 1;
            let title_end = url_content[title_start..].find('"').map(|p| title_start + p).unwrap_or(url_content.len());
            let title = url_content[title_start..title_end].to_string();
            (url, Some(title))
        } else if let Some(quote_start) = url_content.find('\'') {
            let url = url_content[..quote_start].trim().to_string();
            let title_start = quote_start + 1;
            let title_end = url_content[title_start..].find('\'').map(|p| title_start + p).unwrap_or(url_content.len());
            let title = url_content[title_start..title_end].to_string();
            (url, Some(title))
        } else {
            (url_content.trim().to_string(), None)
        };

        Some((text, url, title, i))
    }

    fn apply_smart_punctuation(&self, inlines: Vec<MarkdownInline>) -> Vec<MarkdownInline> {
        inlines.into_iter().map(|inline| {
            match inline {
                MarkdownInline::Text(text) => {
                    let text = text
                        .replace("...", "\u{2026}") // ellipsis
                        .replace("--", "\u{2014}")  // em dash
                        .replace("---", "\u{2014}") // em dash
                        .replace("(c)", "\u{00A9}") // copyright
                        .replace("(r)", "\u{00AE}") // registered
                        .replace("(tm)", "\u{2122}"); // trademark

                    // Smart quotes would require context-aware processing
                    MarkdownInline::Text(text)
                }
                other => other,
            }
        }).collect()
    }

    fn is_thematic_break(&self, line: &str) -> bool {
        let line = line.trim();
        if line.len() < 3 {
            return false;
        }

        let chars: Vec<char> = line.chars().filter(|c| !c.is_whitespace()).collect();

        if chars.is_empty() {
            return false;
        }

        let first = chars[0];
        (first == '-' || first == '*' || first == '_') && chars.iter().all(|&c| c == first) && chars.len() >= 3
    }

    fn is_list_item(&self, line: &str) -> bool {
        let trimmed = line.trim();

        // Unordered
        if trimmed.starts_with("- ") || trimmed.starts_with("* ") || trimmed.starts_with("+ ") {
            return true;
        }

        // Ordered
        let mut chars = trimmed.chars();
        while let Some(c) = chars.next() {
            if c.is_ascii_digit() {
                continue;
            }
            if (c == '.' || c == ')') && chars.next().map(|c| c == ' ').unwrap_or(false) {
                return true;
            }
            break;
        }

        false
    }

    fn get_list_info(&self, line: &str) -> (bool, u32) {
        let trimmed = line.trim();

        if trimmed.starts_with("- ") || trimmed.starts_with("* ") || trimmed.starts_with("+ ") {
            return (false, 1);
        }

        let num_str: String = trimmed.chars().take_while(|c| c.is_ascii_digit()).collect();
        if let Ok(num) = num_str.parse::<u32>() {
            return (true, num);
        }

        (false, 1)
    }

    fn is_table_row(&self, line: &str) -> bool {
        line.contains('|')
    }

    fn is_table_delimiter(&self, line: &str) -> bool {
        let line = line.trim();
        line.chars().all(|c| c == '|' || c == '-' || c == ':' || c == ' ')
            && line.contains('-')
            && line.contains('|')
    }

    fn slugify(&self, text: &str) -> String {
        text.to_lowercase()
            .chars()
            .map(|c| {
                if c.is_alphanumeric() {
                    c
                } else if c.is_whitespace() || c == '-' {
                    '-'
                } else {
                    '\0'
                }
            })
            .filter(|&c| c != '\0')
            .collect::<String>()
            .split('-')
            .filter(|s| !s.is_empty())
            .collect::<Vec<_>>()
            .join("-")
    }

    /// Render markdown AST to HTML
    pub fn render_html(&self, block: &MarkdownBlock) -> String {
        match block {
            MarkdownBlock::Document(blocks) => {
                let mut toc = String::new();
                let mut content = String::new();
                let mut headings = Vec::new();

                for b in blocks {
                    if let MarkdownBlock::Heading { level, content: _, id } = b {
                        headings.push((*level, id.clone()));
                    }
                    content.push_str(&self.render_html(b));
                }

                if self.config.toc_generation {
                    toc = self.generate_toc(&headings);
                }

                format!("{}{}", toc, content)
            }

            MarkdownBlock::Heading { level, content, id } => {
                let inlines = self.render_inlines_html(content);
                let id_attr = id.as_ref().map(|i| format!(" id=\"{}\"", i)).unwrap_or_default();
                format!("<h{}{}>{}</h{}>\n", level, id_attr, inlines, level)
            }

            MarkdownBlock::Paragraph(inlines) => {
                format!("<p>{}</p>\n", self.render_inlines_html(inlines))
            }

            MarkdownBlock::BlockQuote(blocks) => {
                let inner: String = blocks.iter().map(|b| self.render_html(b)).collect();
                format!("<blockquote>\n{}</blockquote>\n", inner)
            }

            MarkdownBlock::CodeBlock { language, content, info: _ } => {
                let lang_class = language.as_ref()
                    .map(|l| format!(" class=\"language-{}\"", l))
                    .unwrap_or_default();

                let highlighted = if self.config.highlight_code {
                    self.highlight_code(content, language.as_deref())
                } else {
                    html_escape(content)
                };

                format!("<pre><code{}>{}</code></pre>\n", lang_class, highlighted)
            }

            MarkdownBlock::List { ordered, start, items } => {
                let tag = if *ordered { "ol" } else { "ul" };
                let start_attr = if *ordered && *start != 1 {
                    format!(" start=\"{}\"", start)
                } else {
                    String::new()
                };

                let items_html: String = items.iter().map(|item| {
                    let checkbox = match item.checked {
                        Some(true) => "<input type=\"checkbox\" checked disabled> ",
                        Some(false) => "<input type=\"checkbox\" disabled> ",
                        None => "",
                    };
                    let content: String = item.content.iter().map(|b| self.render_html(b)).collect();
                    format!("<li>{}{}</li>\n", checkbox, content.trim())
                }).collect();

                format!("<{}{}>\n{}</{}>", tag, start_attr, items_html, tag)
            }

            MarkdownBlock::Table { header, rows, alignments } => {
                let mut html = String::from("<table>\n<thead>\n<tr>\n");

                for (i, cell) in header.iter().enumerate() {
                    let align = alignments.get(i).copied().unwrap_or(Alignment::None);
                    let style = match align {
                        Alignment::Left => " style=\"text-align: left\"",
                        Alignment::Center => " style=\"text-align: center\"",
                        Alignment::Right => " style=\"text-align: right\"",
                        Alignment::None => "",
                    };
                    html.push_str(&format!("<th{}>{}</th>\n", style, self.render_inlines_html(&cell.content)));
                }

                html.push_str("</tr>\n</thead>\n<tbody>\n");

                for row in rows {
                    html.push_str("<tr>\n");
                    for (i, cell) in row.iter().enumerate() {
                        let align = alignments.get(i).copied().unwrap_or(Alignment::None);
                        let style = match align {
                            Alignment::Left => " style=\"text-align: left\"",
                            Alignment::Center => " style=\"text-align: center\"",
                            Alignment::Right => " style=\"text-align: right\"",
                            Alignment::None => "",
                        };
                        html.push_str(&format!("<td{}>{}</td>\n", style, self.render_inlines_html(&cell.content)));
                    }
                    html.push_str("</tr>\n");
                }

                html.push_str("</tbody>\n</table>\n");
                html
            }

            MarkdownBlock::ThematicBreak => "<hr />\n".to_string(),

            MarkdownBlock::HtmlBlock(content) => format!("{}\n", content),

            MarkdownBlock::Footnote { label, content } => {
                let inner: String = content.iter().map(|b| self.render_html(b)).collect();
                format!(
                    "<div class=\"footnote\" id=\"fn-{}\">\n<sup>{}</sup>{}</div>\n",
                    label, label, inner
                )
            }

            MarkdownBlock::DefinitionList(items) => {
                let mut html = String::from("<dl>\n");
                for (term, defs) in items {
                    html.push_str(&format!("<dt>{}</dt>\n", self.render_inlines_html(term)));
                    for def in defs {
                        html.push_str(&format!("<dd>{}</dd>\n", self.render_html(def).trim()));
                    }
                }
                html.push_str("</dl>\n");
                html
            }

            MarkdownBlock::Admonition { kind, title, content } => {
                let kind_str = format!("{:?}", kind).to_lowercase();
                let icon = self.get_admonition_icon(*kind);
                let title_str = title.as_ref()
                    .map(|t| t.clone())
                    .unwrap_or_else(|| format!("{:?}", kind));

                let inner: String = content.iter().map(|b| self.render_html(b)).collect();

                format!(
                    "<div class=\"admonition {}\">\n<div class=\"admonition-title\">{} {}</div>\n<div class=\"admonition-content\">{}</div>\n</div>\n",
                    kind_str, icon, title_str, inner
                )
            }

            MarkdownBlock::MathBlock(content) => {
                format!("<div class=\"math-block\">\\[{}\\]</div>\n", html_escape(content))
            }

            MarkdownBlock::Diagram { kind, source } => {
                match kind {
                    DiagramKind::Mermaid => {
                        format!("<div class=\"mermaid\">\n{}\n</div>\n", source)
                    }
                    DiagramKind::PlantUml => {
                        let encoded = self.encode_plantuml(source);
                        format!("<img src=\"https://www.plantuml.com/plantuml/svg/{}\" alt=\"PlantUML Diagram\">\n", encoded)
                    }
                    _ => {
                        format!("<pre class=\"diagram {:?}\">{}</pre>\n", kind, html_escape(source))
                    }
                }
            }

            MarkdownBlock::Toc { max_level: _ } => {
                String::new() // TOC is generated at document level
            }

            MarkdownBlock::FencedDiv { class, content } => {
                let inner: String = content.iter().map(|b| self.render_html(b)).collect();
                format!("<div class=\"{}\">\n{}</div>\n", class, inner)
            }
        }
    }

    fn render_inlines_html(&self, inlines: &[MarkdownInline]) -> String {
        inlines.iter().map(|inline| {
            match inline {
                MarkdownInline::Text(text) => html_escape(text),
                MarkdownInline::SoftBreak => " ".to_string(),
                MarkdownInline::HardBreak => "<br />\n".to_string(),
                MarkdownInline::Emphasis(inner) => {
                    format!("<em>{}</em>", self.render_inlines_html(inner))
                }
                MarkdownInline::Strong(inner) => {
                    format!("<strong>{}</strong>", self.render_inlines_html(inner))
                }
                MarkdownInline::Strikethrough(inner) => {
                    format!("<del>{}</del>", self.render_inlines_html(inner))
                }
                MarkdownInline::Code(code) => {
                    format!("<code>{}</code>", html_escape(code))
                }
                MarkdownInline::Link { url, title, content } => {
                    let title_attr = title.as_ref()
                        .map(|t| format!(" title=\"{}\"", html_escape(t)))
                        .unwrap_or_default();
                    format!("<a href=\"{}\"{}>{}</a>", html_escape(url), title_attr, self.render_inlines_html(content))
                }
                MarkdownInline::Image { url, alt, title } => {
                    let title_attr = title.as_ref()
                        .map(|t| format!(" title=\"{}\"", html_escape(t)))
                        .unwrap_or_default();
                    format!("<img src=\"{}\" alt=\"{}\"{}/>", html_escape(url), html_escape(alt), title_attr)
                }
                MarkdownInline::FootnoteRef(label) => {
                    format!("<sup><a href=\"#fn-{}\">[{}]</a></sup>", label, label)
                }
                MarkdownInline::Emoji(name) => {
                    self.emoji_to_unicode(name)
                }
                MarkdownInline::Math(content) => {
                    format!("<span class=\"math\">\\({}\\)</span>", html_escape(content))
                }
                MarkdownInline::Html(content) => content.clone(),
                MarkdownInline::Superscript(inner) => {
                    format!("<sup>{}</sup>", self.render_inlines_html(inner))
                }
                MarkdownInline::Subscript(inner) => {
                    format!("<sub>{}</sub>", self.render_inlines_html(inner))
                }
                MarkdownInline::Highlight(inner) => {
                    format!("<mark>{}</mark>", self.render_inlines_html(inner))
                }
                MarkdownInline::Insert(inner) => {
                    format!("<ins>{}</ins>", self.render_inlines_html(inner))
                }
                MarkdownInline::Abbreviation { abbr, full } => {
                    format!("<abbr title=\"{}\">{}</abbr>", html_escape(full), html_escape(abbr))
                }
            }
        }).collect()
    }

    fn generate_toc(&self, headings: &[(u8, Option<String>)]) -> String {
        if headings.is_empty() {
            return String::new();
        }

        let mut html = String::from("<nav class=\"toc\">\n<h2>Table of Contents</h2>\n<ul>\n");

        for (level, id) in headings {
            if let Some(ref id) = id {
                let indent = "  ".repeat(*level as usize);
                html.push_str(&format!("{}<li><a href=\"#{}\">{}</a></li>\n", indent, id, id));
            }
        }

        html.push_str("</ul>\n</nav>\n");
        html
    }

    fn highlight_code(&self, code: &str, language: Option<&str>) -> String {
        // Basic syntax highlighting (would use a proper highlighter in production)
        let lang = language.unwrap_or("");

        match lang {
            "quanta" | "rust" | "rs" => self.highlight_quanta(code),
            "javascript" | "js" | "typescript" | "ts" => self.highlight_js(code),
            "python" | "py" => self.highlight_python(code),
            _ => html_escape(code),
        }
    }

    fn highlight_quanta(&self, code: &str) -> String {
        let keywords = ["fn", "let", "mut", "const", "pub", "struct", "enum", "trait", "impl",
                       "if", "else", "match", "for", "while", "loop", "return", "use", "mod",
                       "async", "await", "self", "Self", "true", "false", "None", "Some"];

        let mut result = html_escape(code);

        for kw in keywords {
            let pattern = format!("\\b{}\\b", kw);
            result = result.replace(&format!(" {} ", kw), &format!(" <span class=\"kw\">{}</span> ", kw));
        }

        result
    }

    fn highlight_js(&self, code: &str) -> String {
        html_escape(code) // Simplified
    }

    fn highlight_python(&self, code: &str) -> String {
        html_escape(code) // Simplified
    }

    fn get_admonition_icon(&self, kind: AdmonitionKind) -> &'static str {
        match kind {
            AdmonitionKind::Note => "\u{1F4DD}",
            AdmonitionKind::Tip => "\u{1F4A1}",
            AdmonitionKind::Info => "\u{2139}\u{FE0F}",
            AdmonitionKind::Warning => "\u{26A0}\u{FE0F}",
            AdmonitionKind::Danger => "\u{1F6A8}",
            AdmonitionKind::Bug => "\u{1F41B}",
            AdmonitionKind::Example => "\u{1F4CB}",
            AdmonitionKind::Quote => "\u{1F4AC}",
            AdmonitionKind::Abstract => "\u{1F4C4}",
            AdmonitionKind::Success => "\u{2705}",
            AdmonitionKind::Question => "\u{2753}",
            AdmonitionKind::Failure => "\u{274C}",
        }
    }

    fn emoji_to_unicode(&self, name: &str) -> String {
        match name {
            "smile" | "smiley" => "\u{1F604}".to_string(),
            "heart" => "\u{2764}\u{FE0F}".to_string(),
            "thumbsup" | "+1" => "\u{1F44D}".to_string(),
            "thumbsdown" | "-1" => "\u{1F44E}".to_string(),
            "star" => "\u{2B50}".to_string(),
            "fire" => "\u{1F525}".to_string(),
            "rocket" => "\u{1F680}".to_string(),
            "check" | "heavy_check_mark" => "\u{2705}".to_string(),
            "x" | "cross_mark" => "\u{274C}".to_string(),
            "warning" => "\u{26A0}\u{FE0F}".to_string(),
            "info" => "\u{2139}\u{FE0F}".to_string(),
            "question" => "\u{2753}".to_string(),
            "bug" => "\u{1F41B}".to_string(),
            "sparkles" => "\u{2728}".to_string(),
            "zap" => "\u{26A1}".to_string(),
            "lock" => "\u{1F512}".to_string(),
            "key" => "\u{1F511}".to_string(),
            "gear" | "wrench" => "\u{2699}\u{FE0F}".to_string(),
            "book" => "\u{1F4D6}".to_string(),
            "memo" => "\u{1F4DD}".to_string(),
            _ => format!(":{}:", name),
        }
    }

    fn encode_plantuml(&self, source: &str) -> String {
        // PlantUML encoding (simplified - would use proper deflate+base64 in production)
        // This is a placeholder
        base64_encode(source)
    }
}

fn base64_encode(input: &str) -> String {
    const ALPHABET: &[u8] = b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

    let bytes = input.as_bytes();
    let mut result = String::new();

    for chunk in bytes.chunks(3) {
        let b0 = chunk[0] as u32;
        let b1 = chunk.get(1).map(|&b| b as u32).unwrap_or(0);
        let b2 = chunk.get(2).map(|&b| b as u32).unwrap_or(0);

        let combined = (b0 << 16) | (b1 << 8) | b2;

        result.push(ALPHABET[((combined >> 18) & 0x3F) as usize] as char);
        result.push(ALPHABET[((combined >> 12) & 0x3F) as usize] as char);

        if chunk.len() > 1 {
            result.push(ALPHABET[((combined >> 6) & 0x3F) as usize] as char);
        } else {
            result.push('=');
        }

        if chunk.len() > 2 {
            result.push(ALPHABET[(combined & 0x3F) as usize] as char);
        } else {
            result.push('=');
        }
    }

    result
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCTEST - Extract and Execute Code Examples from Documentation
// ═══════════════════════════════════════════════════════════════════════════════

/// Doctest runner - extracts and executes code examples from documentation
pub struct DoctestRunner {
    config: DoctestConfig,
    results: Vec<DoctestResult>,
}

#[derive(Clone)]
pub struct DoctestConfig {
    pub timeout_ms: u64,
    pub allow_fail: bool,
    pub show_output: bool,
    pub parallel: bool,
    pub ignore_pattern: Option<String>,
    pub setup_code: Option<String>,
    pub cleanup_code: Option<String>,
}

impl Default for DoctestConfig {
    fn default() -> Self {
        DoctestConfig {
            timeout_ms: 5000,
            allow_fail: false,
            show_output: true,
            parallel: false,
            ignore_pattern: None,
            setup_code: None,
            cleanup_code: None,
        }
    }
}

#[derive(Clone)]
pub struct Doctest {
    pub name: String,
    pub code: String,
    pub source_file: String,
    pub line_number: usize,
    pub expected_output: Option<String>,
    pub should_panic: bool,
    pub no_run: bool,
    pub ignore: bool,
    pub compile_fail: bool,
    pub edition: Option<String>,
}

#[derive(Clone)]
pub struct DoctestResult {
    pub test: Doctest,
    pub status: DoctestStatus,
    pub output: String,
    pub error: Option<String>,
    pub duration_ms: u64,
}

#[derive(Clone, Copy, PartialEq)]
pub enum DoctestStatus {
    Passed,
    Failed,
    Ignored,
    CompileFailed,
    Timeout,
    Panicked,
}

impl DoctestRunner {
    pub fn new(config: DoctestConfig) -> Self {
        DoctestRunner {
            config,
            results: Vec::new(),
        }
    }

    /// Extract doctests from a documentation string
    pub fn extract_doctests(&self, doc: &str, source_file: &str, base_line: usize) -> Vec<Doctest> {
        let mut doctests = Vec::new();
        let mut in_code_block = false;
        let mut current_code = String::new();
        let mut code_start_line = 0;
        let mut code_lang = String::new();
        let mut code_attrs = Vec::new();

        for (line_offset, line) in doc.lines().enumerate() {
            let line_num = base_line + line_offset;

            if line.trim().starts_with("```") {
                if in_code_block {
                    // End of code block
                    if !current_code.trim().is_empty() && self.is_runnable_lang(&code_lang) {
                        let (should_panic, no_run, ignore, compile_fail, edition) =
                            self.parse_code_attrs(&code_attrs);

                        let expected = self.extract_expected_output(&current_code);
                        let clean_code = self.clean_code(&current_code);

                        doctests.push(Doctest {
                            name: format!("{}:{}", source_file, code_start_line),
                            code: clean_code,
                            source_file: source_file.to_string(),
                            line_number: code_start_line,
                            expected_output: expected,
                            should_panic,
                            no_run,
                            ignore,
                            compile_fail,
                            edition,
                        });
                    }

                    current_code.clear();
                    code_attrs.clear();
                    in_code_block = false;
                } else {
                    // Start of code block
                    in_code_block = true;
                    code_start_line = line_num;

                    let info = line.trim().strip_prefix("```").unwrap_or("");
                    let parts: Vec<&str> = info.split(',').collect();
                    code_lang = parts.first().unwrap_or(&"").trim().to_string();
                    code_attrs = parts.iter().skip(1).map(|s| s.trim().to_string()).collect();
                }
            } else if in_code_block {
                current_code.push_str(line);
                current_code.push('\n');
            }
        }

        doctests
    }

    fn is_runnable_lang(&self, lang: &str) -> bool {
        matches!(lang.to_lowercase().as_str(),
            "quanta" | "rust" | "" | "rs" | "no_run" | "should_panic" | "compile_fail")
    }

    fn parse_code_attrs(&self, attrs: &[String]) -> (bool, bool, bool, bool, Option<String>) {
        let mut should_panic = false;
        let mut no_run = false;
        let mut ignore = false;
        let mut compile_fail = false;
        let mut edition = None;

        for attr in attrs {
            match attr.as_str() {
                "should_panic" => should_panic = true,
                "no_run" => no_run = true,
                "ignore" => ignore = true,
                "compile_fail" => compile_fail = true,
                _ if attr.starts_with("edition") => {
                    edition = attr.split('=').nth(1).map(|s| s.to_string());
                }
                _ => {}
            }
        }

        (should_panic, no_run, ignore, compile_fail, edition)
    }

    fn extract_expected_output(&self, code: &str) -> Option<String> {
        let mut expected = Vec::new();

        for line in code.lines() {
            if line.trim().starts_with("// =>") {
                let output = line.trim().strip_prefix("// =>").unwrap_or("").trim();
                expected.push(output.to_string());
            }
        }

        if expected.is_empty() {
            None
        } else {
            Some(expected.join("\n"))
        }
    }

    fn clean_code(&self, code: &str) -> String {
        code.lines()
            .filter(|line| !line.trim().starts_with("// =>"))
            .filter(|line| !line.trim().starts_with("# ")) // Hidden lines
            .collect::<Vec<_>>()
            .join("\n")
    }

    /// Run all extracted doctests
    pub fn run_doctests(&mut self, doctests: Vec<Doctest>) -> DoctestSummary {
        println!("\nRunning {} doctests...\n", doctests.len());

        let mut passed = 0;
        let mut failed = 0;
        let mut ignored = 0;

        for doctest in doctests {
            if doctest.ignore {
                println!("  {} ... ignored", doctest.name);
                self.results.push(DoctestResult {
                    test: doctest,
                    status: DoctestStatus::Ignored,
                    output: String::new(),
                    error: None,
                    duration_ms: 0,
                });
                ignored += 1;
                continue;
            }

            if doctest.no_run {
                // Just compile, don't run
                let result = self.compile_only(&doctest);
                self.results.push(result.clone());

                if result.status == DoctestStatus::Passed {
                    println!("  {} ... ok (compile only)", doctest.name);
                    passed += 1;
                } else {
                    println!("  {} ... FAILED (compile)", doctest.name);
                    failed += 1;
                }
                continue;
            }

            let result = self.run_single(&doctest);
            self.results.push(result.clone());

            match result.status {
                DoctestStatus::Passed => {
                    println!("  {} ... ok", doctest.name);
                    passed += 1;
                }
                DoctestStatus::Failed => {
                    println!("  {} ... FAILED", doctest.name);
                    if let Some(ref err) = result.error {
                        println!("    Error: {}", err);
                    }
                    failed += 1;
                }
                DoctestStatus::Panicked => {
                    if doctest.should_panic {
                        println!("  {} ... ok (panicked as expected)", doctest.name);
                        passed += 1;
                    } else {
                        println!("  {} ... FAILED (unexpected panic)", doctest.name);
                        failed += 1;
                    }
                }
                DoctestStatus::Timeout => {
                    println!("  {} ... FAILED (timeout)", doctest.name);
                    failed += 1;
                }
                DoctestStatus::CompileFailed => {
                    if doctest.compile_fail {
                        println!("  {} ... ok (compile failed as expected)", doctest.name);
                        passed += 1;
                    } else {
                        println!("  {} ... FAILED (compile error)", doctest.name);
                        failed += 1;
                    }
                }
                _ => {}
            }
        }

        println!("\nDoctest result: {} passed, {} failed, {} ignored\n",
            passed, failed, ignored);

        DoctestSummary {
            total: passed + failed + ignored,
            passed,
            failed,
            ignored,
            results: self.results.clone(),
        }
    }

    fn run_single(&self, doctest: &Doctest) -> DoctestResult {
        let start = std::time::Instant::now();

        // Wrap code with necessary boilerplate
        let full_code = self.wrap_code(&doctest.code);

        // In a real implementation, this would compile and execute the code
        // For now, we simulate execution
        let (status, output, error) = self.simulate_execution(&full_code, doctest);

        let duration = start.elapsed().as_millis() as u64;

        DoctestResult {
            test: doctest.clone(),
            status,
            output,
            error,
            duration_ms: duration,
        }
    }

    fn compile_only(&self, doctest: &Doctest) -> DoctestResult {
        let start = std::time::Instant::now();
        let full_code = self.wrap_code(&doctest.code);

        // Simulate compilation check
        let (status, error) = self.simulate_compile(&full_code, doctest);

        let duration = start.elapsed().as_millis() as u64;

        DoctestResult {
            test: doctest.clone(),
            status,
            output: String::new(),
            error,
            duration_ms: duration,
        }
    }

    fn wrap_code(&self, code: &str) -> String {
        let mut wrapped = String::new();

        // Add setup code if any
        if let Some(ref setup) = self.config.setup_code {
            wrapped.push_str(setup);
            wrapped.push('\n');
        }

        // Check if code has main function
        if !code.contains("fn main") {
            wrapped.push_str("fn main() {\n");
            wrapped.push_str(code);
            wrapped.push_str("\n}\n");
        } else {
            wrapped.push_str(code);
        }

        // Add cleanup code if any
        if let Some(ref cleanup) = self.config.cleanup_code {
            wrapped.push_str("\n");
            wrapped.push_str(cleanup);
        }

        wrapped
    }

    fn simulate_execution(&self, code: &str, doctest: &Doctest) -> (DoctestStatus, String, Option<String>) {
        // Simulated execution - in production would use actual compiler/interpreter

        // Check for obvious syntax errors
        if code.contains("syntax_error!") {
            return (DoctestStatus::CompileFailed, String::new(), Some("Syntax error".to_string()));
        }

        // Check for panic
        if code.contains("panic!") && !doctest.should_panic {
            return (DoctestStatus::Panicked, String::new(), Some("Unexpected panic".to_string()));
        }

        if code.contains("panic!") && doctest.should_panic {
            return (DoctestStatus::Panicked, String::new(), None);
        }

        // Check expected output if any
        if let Some(ref expected) = doctest.expected_output {
            // Simulate output matching
            let simulated_output = "output"; // Would come from actual execution
            if simulated_output != expected {
                return (DoctestStatus::Failed, simulated_output.to_string(),
                    Some(format!("Expected: {}, Got: {}", expected, simulated_output)));
            }
        }

        (DoctestStatus::Passed, String::new(), None)
    }

    fn simulate_compile(&self, code: &str, doctest: &Doctest) -> (DoctestStatus, Option<String>) {
        // Check for obvious syntax errors
        if code.contains("syntax_error!") {
            if doctest.compile_fail {
                return (DoctestStatus::Passed, None);
            }
            return (DoctestStatus::CompileFailed, Some("Syntax error".to_string()));
        }

        if doctest.compile_fail {
            return (DoctestStatus::Failed, Some("Expected compilation to fail".to_string()));
        }

        (DoctestStatus::Passed, None)
    }
}

#[derive(Clone)]
pub struct DoctestSummary {
    pub total: usize,
    pub passed: usize,
    pub failed: usize,
    pub ignored: usize,
    pub results: Vec<DoctestResult>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CHANGELOG GENERATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Automatic changelog generation from git history and conventional commits
pub struct ChangelogGenerator {
    config: ChangelogConfig,
}

#[derive(Clone)]
pub struct ChangelogConfig {
    pub repository_url: Option<String>,
    pub output_format: ChangelogFormat,
    pub group_by: ChangelogGrouping,
    pub include_unreleased: bool,
    pub commit_url_template: Option<String>,
    pub issue_url_template: Option<String>,
    pub pr_url_template: Option<String>,
    pub header: Option<String>,
    pub footer: Option<String>,
    pub types: HashMap<String, ChangelogTypeConfig>,
}

#[derive(Clone)]
pub struct ChangelogTypeConfig {
    pub title: String,
    pub hidden: bool,
    pub order: i32,
}

#[derive(Clone, Copy)]
pub enum ChangelogFormat {
    Markdown,
    Html,
    Json,
    Rst,
}

#[derive(Clone, Copy)]
pub enum ChangelogGrouping {
    Version,
    Date,
    Type,
}

#[derive(Clone)]
pub struct ChangelogEntry {
    pub commit_type: String,
    pub scope: Option<String>,
    pub description: String,
    pub body: Option<String>,
    pub breaking_change: bool,
    pub issues: Vec<String>,
    pub pull_requests: Vec<String>,
    pub commit_hash: String,
    pub author: String,
    pub date: String,
}

#[derive(Clone)]
pub struct ChangelogVersion {
    pub version: String,
    pub date: String,
    pub entries: Vec<ChangelogEntry>,
    pub compare_url: Option<String>,
}

impl Default for ChangelogConfig {
    fn default() -> Self {
        let mut types = HashMap::new();
        types.insert("feat".to_string(), ChangelogTypeConfig {
            title: "Features".to_string(),
            hidden: false,
            order: 0,
        });
        types.insert("fix".to_string(), ChangelogTypeConfig {
            title: "Bug Fixes".to_string(),
            hidden: false,
            order: 1,
        });
        types.insert("perf".to_string(), ChangelogTypeConfig {
            title: "Performance Improvements".to_string(),
            hidden: false,
            order: 2,
        });
        types.insert("refactor".to_string(), ChangelogTypeConfig {
            title: "Code Refactoring".to_string(),
            hidden: false,
            order: 3,
        });
        types.insert("docs".to_string(), ChangelogTypeConfig {
            title: "Documentation".to_string(),
            hidden: false,
            order: 4,
        });
        types.insert("style".to_string(), ChangelogTypeConfig {
            title: "Styles".to_string(),
            hidden: true,
            order: 5,
        });
        types.insert("test".to_string(), ChangelogTypeConfig {
            title: "Tests".to_string(),
            hidden: true,
            order: 6,
        });
        types.insert("build".to_string(), ChangelogTypeConfig {
            title: "Build System".to_string(),
            hidden: true,
            order: 7,
        });
        types.insert("ci".to_string(), ChangelogTypeConfig {
            title: "Continuous Integration".to_string(),
            hidden: true,
            order: 8,
        });
        types.insert("chore".to_string(), ChangelogTypeConfig {
            title: "Chores".to_string(),
            hidden: true,
            order: 9,
        });

        ChangelogConfig {
            repository_url: None,
            output_format: ChangelogFormat::Markdown,
            group_by: ChangelogGrouping::Version,
            include_unreleased: true,
            commit_url_template: None,
            issue_url_template: None,
            pr_url_template: None,
            header: Some("# Changelog\n\nAll notable changes to this project will be documented in this file.\n".to_string()),
            footer: None,
            types,
        }
    }
}

impl ChangelogGenerator {
    pub fn new(config: ChangelogConfig) -> Self {
        ChangelogGenerator { config }
    }

    /// Parse a conventional commit message
    pub fn parse_commit(&self, message: &str, hash: &str, author: &str, date: &str) -> Option<ChangelogEntry> {
        let lines: Vec<&str> = message.lines().collect();
        let first_line = lines.first()?;

        // Parse conventional commit: type(scope)!: description
        let mut chars = first_line.chars().peekable();
        let mut commit_type = String::new();
        let mut scope = None;
        let mut breaking = false;

        // Parse type
        while let Some(&c) = chars.peek() {
            if c.is_alphanumeric() {
                commit_type.push(c);
                chars.next();
            } else {
                break;
            }
        }

        if commit_type.is_empty() {
            return None;
        }

        // Parse optional scope
        if chars.peek() == Some(&'(') {
            chars.next(); // consume '('
            let mut scope_str = String::new();
            while let Some(&c) = chars.peek() {
                if c == ')' {
                    chars.next();
                    break;
                }
                scope_str.push(c);
                chars.next();
            }
            if !scope_str.is_empty() {
                scope = Some(scope_str);
            }
        }

        // Check for breaking change marker
        if chars.peek() == Some(&'!') {
            breaking = true;
            chars.next();
        }

        // Expect colon
        if chars.next() != Some(':') {
            return None;
        }

        // Skip space
        while chars.peek() == Some(&' ') {
            chars.next();
        }

        // Rest is description
        let description: String = chars.collect();

        // Parse body for additional info
        let body = if lines.len() > 2 {
            Some(lines[2..].join("\n"))
        } else {
            None
        };

        // Check for BREAKING CHANGE in body
        if let Some(ref body_text) = body {
            if body_text.contains("BREAKING CHANGE:") || body_text.contains("BREAKING-CHANGE:") {
                breaking = true;
            }
        }

        // Extract issue and PR references
        let issues = self.extract_references(message, &["#", "fixes #", "closes #", "resolves #"]);
        let pull_requests = self.extract_references(message, &["PR #", "pull request #"]);

        Some(ChangelogEntry {
            commit_type,
            scope,
            description,
            body,
            breaking_change: breaking,
            issues,
            pull_requests,
            commit_hash: hash.to_string(),
            author: author.to_string(),
            date: date.to_string(),
        })
    }

    fn extract_references(&self, text: &str, patterns: &[&str]) -> Vec<String> {
        let mut refs = Vec::new();

        for pattern in patterns {
            let lower_text = text.to_lowercase();
            let lower_pattern = pattern.to_lowercase();

            let mut search_start = 0;
            while let Some(idx) = lower_text[search_start..].find(&lower_pattern) {
                let actual_idx = search_start + idx + pattern.len();
                let num_start = actual_idx;
                let num: String = text[num_start..]
                    .chars()
                    .take_while(|c| c.is_ascii_digit())
                    .collect();

                if !num.is_empty() {
                    refs.push(format!("#{}", num));
                }

                search_start = actual_idx + num.len();
            }
        }

        refs.sort();
        refs.dedup();
        refs
    }

    /// Generate changelog from versions
    pub fn generate(&self, versions: &[ChangelogVersion]) -> String {
        match self.config.output_format {
            ChangelogFormat::Markdown => self.generate_markdown(versions),
            ChangelogFormat::Html => self.generate_html(versions),
            ChangelogFormat::Json => self.generate_json(versions),
            ChangelogFormat::Rst => self.generate_rst(versions),
        }
    }

    fn generate_markdown(&self, versions: &[ChangelogVersion]) -> String {
        let mut md = String::new();

        // Header
        if let Some(ref header) = self.config.header {
            md.push_str(header);
            md.push_str("\n\n");
        }

        for version in versions {
            // Version header
            md.push_str(&format!("## [{}] - {}\n\n", version.version, version.date));

            // Group entries by type
            let mut grouped: HashMap<String, Vec<&ChangelogEntry>> = HashMap::new();
            for entry in &version.entries {
                grouped.entry(entry.commit_type.clone())
                    .or_insert_with(Vec::new)
                    .push(entry);
            }

            // Breaking changes first
            let breaking: Vec<_> = version.entries.iter()
                .filter(|e| e.breaking_change)
                .collect();

            if !breaking.is_empty() {
                md.push_str("### \u{26A0}\u{FE0F} BREAKING CHANGES\n\n");
                for entry in breaking {
                    md.push_str(&self.format_entry_md(entry));
                }
                md.push('\n');
            }

            // Group by type
            let mut type_order: Vec<_> = self.config.types.iter().collect();
            type_order.sort_by_key(|(_, config)| config.order);

            for (type_key, type_config) in type_order {
                if type_config.hidden {
                    continue;
                }

                if let Some(entries) = grouped.get(type_key) {
                    md.push_str(&format!("### {}\n\n", type_config.title));
                    for entry in entries {
                        if !entry.breaking_change {
                            md.push_str(&self.format_entry_md(entry));
                        }
                    }
                    md.push('\n');
                }
            }

            // Compare URL
            if let Some(ref url) = version.compare_url {
                md.push_str(&format!("[{}]: {}\n\n", version.version, url));
            }
        }

        // Footer
        if let Some(ref footer) = self.config.footer {
            md.push_str(footer);
        }

        md
    }

    fn format_entry_md(&self, entry: &ChangelogEntry) -> String {
        let mut line = String::from("- ");

        if let Some(ref scope) = entry.scope {
            line.push_str(&format!("**{}:** ", scope));
        }

        line.push_str(&entry.description);

        // Add references
        if !entry.issues.is_empty() || !entry.pull_requests.is_empty() {
            line.push_str(" (");

            let mut refs = Vec::new();
            for issue in &entry.issues {
                if let Some(ref template) = self.config.issue_url_template {
                    refs.push(format!("[{}]({})", issue, template.replace("{}", &issue[1..])));
                } else {
                    refs.push(issue.clone());
                }
            }

            for pr in &entry.pull_requests {
                if let Some(ref template) = self.config.pr_url_template {
                    refs.push(format!("[{}]({})", pr, template.replace("{}", &pr[1..])));
                } else {
                    refs.push(pr.clone());
                }
            }

            line.push_str(&refs.join(", "));
            line.push(')');
        }

        // Add commit link
        if let Some(ref template) = self.config.commit_url_template {
            let short_hash = &entry.commit_hash[..7.min(entry.commit_hash.len())];
            line.push_str(&format!(" ([{}]({}))", short_hash, template.replace("{}", &entry.commit_hash)));
        }

        line.push('\n');
        line
    }

    fn generate_html(&self, versions: &[ChangelogVersion]) -> String {
        let mut html = String::from("<!DOCTYPE html>\n<html>\n<head>\n<title>Changelog</title>\n");
        html.push_str("<style>\n");
        html.push_str("body { font-family: -apple-system, sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; }\n");
        html.push_str(".version { margin: 2rem 0; }\n");
        html.push_str(".breaking { color: #d73a49; }\n");
        html.push_str(".scope { font-weight: bold; }\n");
        html.push_str("</style>\n</head>\n<body>\n");

        html.push_str("<h1>Changelog</h1>\n");

        for version in versions {
            html.push_str(&format!("<div class=\"version\">\n<h2>{} - {}</h2>\n", version.version, version.date));

            for entry in &version.entries {
                let class = if entry.breaking_change { " class=\"breaking\"" } else { "" };
                html.push_str(&format!("<p{}>\n", class));

                if let Some(ref scope) = entry.scope {
                    html.push_str(&format!("<span class=\"scope\">{}</span>: ", scope));
                }

                html.push_str(&entry.description);
                html.push_str("\n</p>\n");
            }

            html.push_str("</div>\n");
        }

        html.push_str("</body>\n</html>");
        html
    }

    fn generate_json(&self, versions: &[ChangelogVersion]) -> String {
        let mut json = String::from("{\n  \"versions\": [\n");

        for (i, version) in versions.iter().enumerate() {
            json.push_str("    {\n");
            json.push_str(&format!("      \"version\": \"{}\",\n", version.version));
            json.push_str(&format!("      \"date\": \"{}\",\n", version.date));
            json.push_str("      \"entries\": [\n");

            for (j, entry) in version.entries.iter().enumerate() {
                json.push_str("        {\n");
                json.push_str(&format!("          \"type\": \"{}\",\n", entry.commit_type));
                if let Some(ref scope) = entry.scope {
                    json.push_str(&format!("          \"scope\": \"{}\",\n", scope));
                }
                json.push_str(&format!("          \"description\": \"{}\",\n",
                    entry.description.replace("\"", "\\\"")));
                json.push_str(&format!("          \"breaking\": {},\n", entry.breaking_change));
                json.push_str(&format!("          \"commit\": \"{}\"\n", entry.commit_hash));
                json.push_str("        }");
                if j < version.entries.len() - 1 { json.push(','); }
                json.push('\n');
            }

            json.push_str("      ]\n");
            json.push_str("    }");
            if i < versions.len() - 1 { json.push(','); }
            json.push('\n');
        }

        json.push_str("  ]\n}\n");
        json
    }

    fn generate_rst(&self, versions: &[ChangelogVersion]) -> String {
        let mut rst = String::from("Changelog\n=========\n\n");

        for version in versions {
            rst.push_str(&format!("{} - {}\n", version.version, version.date));
            rst.push_str(&"-".repeat(version.version.len() + version.date.len() + 3));
            rst.push_str("\n\n");

            for entry in &version.entries {
                rst.push_str("* ");
                if let Some(ref scope) = entry.scope {
                    rst.push_str(&format!("**{}**: ", scope));
                }
                rst.push_str(&entry.description);
                rst.push_str("\n");
            }
            rst.push_str("\n");
        }

        rst
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENTATION COVERAGE ANALYZER
// ═══════════════════════════════════════════════════════════════════════════════

/// Analyzes documentation coverage of a codebase
pub struct DocCoverageAnalyzer {
    config: CoverageConfig,
}

#[derive(Clone)]
pub struct CoverageConfig {
    pub require_examples: bool,
    pub require_params: bool,
    pub require_returns: bool,
    pub require_errors: bool,
    pub min_coverage_percent: f64,
    pub exclude_patterns: Vec<String>,
    pub include_private: bool,
}

impl Default for CoverageConfig {
    fn default() -> Self {
        CoverageConfig {
            require_examples: false,
            require_params: true,
            require_returns: true,
            require_errors: false,
            min_coverage_percent: 80.0,
            exclude_patterns: Vec::new(),
            include_private: false,
        }
    }
}

#[derive(Clone)]
pub struct DocCoverageReport {
    pub total_items: usize,
    pub documented_items: usize,
    pub coverage_percent: f64,
    pub by_kind: HashMap<String, KindCoverage>,
    pub missing: Vec<MissingDoc>,
    pub incomplete: Vec<IncompleteDoc>,
    pub warnings: Vec<String>,
}

#[derive(Clone)]
pub struct KindCoverage {
    pub total: usize,
    pub documented: usize,
    pub coverage_percent: f64,
}

#[derive(Clone)]
pub struct MissingDoc {
    pub item_name: String,
    pub item_kind: String,
    pub file: String,
    pub line: usize,
}

#[derive(Clone)]
pub struct IncompleteDoc {
    pub item_name: String,
    pub item_kind: String,
    pub file: String,
    pub line: usize,
    pub missing_sections: Vec<String>,
}

impl DocCoverageAnalyzer {
    pub fn new(config: CoverageConfig) -> Self {
        DocCoverageAnalyzer { config }
    }

    /// Analyze documentation coverage of parsed modules
    pub fn analyze(&self, modules: &HashMap<String, ModuleDoc>) -> DocCoverageReport {
        let mut total_items = 0;
        let mut documented_items = 0;
        let mut by_kind: HashMap<String, (usize, usize)> = HashMap::new();
        let mut missing = Vec::new();
        let mut incomplete = Vec::new();
        let mut warnings = Vec::new();

        for (module_path, module) in modules {
            // Check module documentation
            if !self.is_excluded(module_path) {
                total_items += 1;
                let kind = "module".to_string();
                let entry = by_kind.entry(kind.clone()).or_insert((0, 0));
                entry.0 += 1;

                if module.doc_comment.is_some() {
                    documented_items += 1;
                    entry.1 += 1;
                } else {
                    missing.push(MissingDoc {
                        item_name: module.name.clone(),
                        item_kind: kind,
                        file: module.path.clone(),
                        line: 1,
                    });
                }
            }

            // Check items in module
            for item in &module.items {
                if !self.config.include_private && item.visibility != Visibility::Public {
                    continue;
                }

                let item_path = format!("{}::{}", module_path, item.name);
                if self.is_excluded(&item_path) {
                    continue;
                }

                total_items += 1;
                let kind = format!("{:?}", item.kind).to_lowercase();
                let entry = by_kind.entry(kind.clone()).or_insert((0, 0));
                entry.0 += 1;

                if let Some(ref doc) = item.doc_comment {
                    documented_items += 1;
                    entry.1 += 1;

                    // Check for completeness
                    let missing_sections = self.check_completeness(doc, &item.kind, &item.signature);
                    if !missing_sections.is_empty() {
                        incomplete.push(IncompleteDoc {
                            item_name: item.name.clone(),
                            item_kind: kind,
                            file: item.source_file.clone(),
                            line: item.line_number,
                            missing_sections,
                        });
                    }
                } else {
                    missing.push(MissingDoc {
                        item_name: item.name.clone(),
                        item_kind: kind,
                        file: item.source_file.clone(),
                        line: item.line_number,
                    });
                }
            }
        }

        let coverage_percent = if total_items > 0 {
            (documented_items as f64 / total_items as f64) * 100.0
        } else {
            100.0
        };

        // Generate warnings
        if coverage_percent < self.config.min_coverage_percent {
            warnings.push(format!(
                "Documentation coverage ({:.1}%) is below minimum threshold ({:.1}%)",
                coverage_percent, self.config.min_coverage_percent
            ));
        }

        // Convert kind coverage
        let by_kind_report: HashMap<String, KindCoverage> = by_kind.into_iter()
            .map(|(k, (total, documented))| {
                let pct = if total > 0 {
                    (documented as f64 / total as f64) * 100.0
                } else {
                    100.0
                };
                (k, KindCoverage { total, documented, coverage_percent: pct })
            })
            .collect();

        DocCoverageReport {
            total_items,
            documented_items,
            coverage_percent,
            by_kind: by_kind_report,
            missing,
            incomplete,
            warnings,
        }
    }

    fn is_excluded(&self, path: &str) -> bool {
        for pattern in &self.config.exclude_patterns {
            if path.contains(pattern) {
                return true;
            }
        }
        false
    }

    fn check_completeness(&self, doc: &str, kind: &ItemKind, signature: &str) -> Vec<String> {
        let mut missing = Vec::new();
        let doc_lower = doc.to_lowercase();

        match kind {
            ItemKind::Function | ItemKind::Method => {
                // Check for parameter documentation
                if self.config.require_params && signature.contains('(') {
                    let has_params = signature.contains(':') && !signature.contains("(&self)")
                        && !signature.contains("(&mut self)") && !signature.contains("(self)");

                    if has_params && !doc_lower.contains("# arguments")
                        && !doc_lower.contains("# parameters")
                        && !doc_lower.contains("* `") {
                        missing.push("Parameter documentation".to_string());
                    }
                }

                // Check for return documentation
                if self.config.require_returns && signature.contains("->") {
                    if !doc_lower.contains("# returns") && !doc_lower.contains("returns:") {
                        missing.push("Return value documentation".to_string());
                    }
                }

                // Check for error documentation
                if self.config.require_errors && signature.contains("Result<") {
                    if !doc_lower.contains("# errors") && !doc_lower.contains("# panics") {
                        missing.push("Error documentation".to_string());
                    }
                }

                // Check for examples
                if self.config.require_examples {
                    if !doc_lower.contains("# example") && !doc_lower.contains("```") {
                        missing.push("Example code".to_string());
                    }
                }
            }

            ItemKind::Struct | ItemKind::Enum => {
                if self.config.require_examples && !doc_lower.contains("# example") {
                    missing.push("Example code".to_string());
                }
            }

            _ => {}
        }

        missing
    }

    /// Generate a report as markdown
    pub fn generate_report(&self, report: &DocCoverageReport) -> String {
        let mut md = String::new();

        md.push_str("# Documentation Coverage Report\n\n");

        // Summary
        md.push_str("## Summary\n\n");
        md.push_str(&format!("- **Total Items:** {}\n", report.total_items));
        md.push_str(&format!("- **Documented Items:** {}\n", report.documented_items));
        md.push_str(&format!("- **Coverage:** {:.1}%\n\n", report.coverage_percent));

        // Coverage badge
        let badge_color = if report.coverage_percent >= 90.0 {
            "brightgreen"
        } else if report.coverage_percent >= 70.0 {
            "yellow"
        } else {
            "red"
        };
        md.push_str(&format!("![Coverage](https://img.shields.io/badge/coverage-{:.0}%25-{})\n\n",
            report.coverage_percent, badge_color));

        // By kind breakdown
        md.push_str("## Coverage by Kind\n\n");
        md.push_str("| Kind | Total | Documented | Coverage |\n");
        md.push_str("|------|-------|------------|----------|\n");

        let mut kinds: Vec<_> = report.by_kind.iter().collect();
        kinds.sort_by_key(|(k, _)| k.clone());

        for (kind, coverage) in kinds {
            md.push_str(&format!("| {} | {} | {} | {:.1}% |\n",
                kind, coverage.total, coverage.documented, coverage.coverage_percent));
        }
        md.push('\n');

        // Missing documentation
        if !report.missing.is_empty() {
            md.push_str("## Missing Documentation\n\n");
            md.push_str("| Item | Kind | File | Line |\n");
            md.push_str("|------|------|------|------|\n");

            for item in &report.missing {
                md.push_str(&format!("| `{}` | {} | {} | {} |\n",
                    item.item_name, item.item_kind, item.file, item.line));
            }
            md.push('\n');
        }

        // Incomplete documentation
        if !report.incomplete.is_empty() {
            md.push_str("## Incomplete Documentation\n\n");

            for item in &report.incomplete {
                md.push_str(&format!("### `{}` ({})\n\n", item.item_name, item.item_kind));
                md.push_str(&format!("File: {}:{}\n\n", item.file, item.line));
                md.push_str("Missing sections:\n");
                for section in &item.missing_sections {
                    md.push_str(&format!("- {}\n", section));
                }
                md.push('\n');
            }
        }

        // Warnings
        if !report.warnings.is_empty() {
            md.push_str("## Warnings\n\n");
            for warning in &report.warnings {
                md.push_str(&format!("- \u{26A0}\u{FE0F} {}\n", warning));
            }
        }

        md
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINK VALIDATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Validates links in documentation
pub struct LinkValidator {
    config: LinkValidatorConfig,
    cache: HashMap<String, LinkStatus>,
}

#[derive(Clone)]
pub struct LinkValidatorConfig {
    pub check_external: bool,
    pub check_internal: bool,
    pub check_anchors: bool,
    pub timeout_ms: u64,
    pub max_concurrent: usize,
    pub ignore_patterns: Vec<String>,
    pub allowed_status_codes: Vec<u16>,
}

impl Default for LinkValidatorConfig {
    fn default() -> Self {
        LinkValidatorConfig {
            check_external: true,
            check_internal: true,
            check_anchors: true,
            timeout_ms: 10000,
            max_concurrent: 10,
            ignore_patterns: Vec::new(),
            allowed_status_codes: vec![200, 201, 202, 204, 301, 302, 307, 308],
        }
    }
}

#[derive(Clone)]
pub struct LinkCheckResult {
    pub url: String,
    pub status: LinkStatus,
    pub source_file: String,
    pub source_line: usize,
    pub error_message: Option<String>,
}

#[derive(Clone, Copy, PartialEq)]
pub enum LinkStatus {
    Valid,
    Broken,
    Timeout,
    Ignored,
    Skipped,
}

impl LinkValidator {
    pub fn new(config: LinkValidatorConfig) -> Self {
        LinkValidator {
            config,
            cache: HashMap::new(),
        }
    }

    /// Extract all links from markdown content
    pub fn extract_links(&self, content: &str, source_file: &str) -> Vec<(String, usize)> {
        let mut links = Vec::new();

        for (line_num, line) in content.lines().enumerate() {
            // Markdown links [text](url)
            let mut search_start = 0;
            while let Some(bracket_start) = line[search_start..].find('[') {
                let abs_bracket = search_start + bracket_start;
                if let Some(paren_start) = line[abs_bracket..].find("](") {
                    let url_start = abs_bracket + paren_start + 2;
                    if let Some(paren_end) = line[url_start..].find(')') {
                        let url = &line[url_start..url_start + paren_end];
                        links.push((url.to_string(), line_num + 1));
                        search_start = url_start + paren_end + 1;
                    } else {
                        break;
                    }
                } else {
                    break;
                }
            }

            // HTML links <a href="url">
            let mut search_start = 0;
            while let Some(href_start) = line[search_start..].find("href=\"") {
                let url_start = search_start + href_start + 6;
                if let Some(quote_end) = line[url_start..].find('"') {
                    let url = &line[url_start..url_start + quote_end];
                    links.push((url.to_string(), line_num + 1));
                    search_start = url_start + quote_end + 1;
                } else {
                    break;
                }
            }

            // Image sources <img src="url">
            let mut search_start = 0;
            while let Some(src_start) = line[search_start..].find("src=\"") {
                let url_start = search_start + src_start + 5;
                if let Some(quote_end) = line[url_start..].find('"') {
                    let url = &line[url_start..url_start + quote_end];
                    links.push((url.to_string(), line_num + 1));
                    search_start = url_start + quote_end + 1;
                } else {
                    break;
                }
            }
        }

        links
    }

    /// Validate all extracted links
    pub fn validate_links(&mut self, links: Vec<(String, String, usize)>) -> Vec<LinkCheckResult> {
        let mut results = Vec::new();

        for (url, source_file, line) in links {
            // Check ignore patterns
            if self.should_ignore(&url) {
                results.push(LinkCheckResult {
                    url,
                    status: LinkStatus::Ignored,
                    source_file,
                    source_line: line,
                    error_message: None,
                });
                continue;
            }

            // Check cache
            if let Some(&status) = self.cache.get(&url) {
                results.push(LinkCheckResult {
                    url: url.clone(),
                    status,
                    source_file,
                    source_line: line,
                    error_message: None,
                });
                continue;
            }

            let result = if url.starts_with("http://") || url.starts_with("https://") {
                if self.config.check_external {
                    self.check_external_link(&url, &source_file, line)
                } else {
                    LinkCheckResult {
                        url,
                        status: LinkStatus::Skipped,
                        source_file,
                        source_line: line,
                        error_message: None,
                    }
                }
            } else if url.starts_with('#') {
                if self.config.check_anchors {
                    self.check_anchor(&url, &source_file, line)
                } else {
                    LinkCheckResult {
                        url,
                        status: LinkStatus::Skipped,
                        source_file,
                        source_line: line,
                        error_message: None,
                    }
                }
            } else if self.config.check_internal {
                self.check_internal_link(&url, &source_file, line)
            } else {
                LinkCheckResult {
                    url,
                    status: LinkStatus::Skipped,
                    source_file,
                    source_line: line,
                    error_message: None,
                }
            };

            // Cache result
            self.cache.insert(result.url.clone(), result.status);
            results.push(result);
        }

        results
    }

    fn should_ignore(&self, url: &str) -> bool {
        for pattern in &self.config.ignore_patterns {
            if url.contains(pattern) {
                return true;
            }
        }

        // Ignore common non-checkable URLs
        url.starts_with("mailto:") ||
        url.starts_with("javascript:") ||
        url.starts_with("data:") ||
        url == "#"
    }

    fn check_external_link(&self, url: &str, source_file: &str, line: usize) -> LinkCheckResult {
        // In production, would make actual HTTP request
        // For now, simulate check

        let status = if url.contains("example.com") || url.contains("localhost") {
            LinkStatus::Broken
        } else {
            LinkStatus::Valid
        };

        LinkCheckResult {
            url: url.to_string(),
            status,
            source_file: source_file.to_string(),
            source_line: line,
            error_message: if status == LinkStatus::Broken {
                Some("Failed to fetch URL".to_string())
            } else {
                None
            },
        }
    }

    fn check_internal_link(&self, path: &str, source_file: &str, line: usize) -> LinkCheckResult {
        // Check if file exists
        let base_dir = Path::new(source_file).parent().unwrap_or(Path::new("."));
        let full_path = base_dir.join(path);

        let status = if exists(full_path.to_str().unwrap_or("")) {
            LinkStatus::Valid
        } else {
            LinkStatus::Broken
        };

        LinkCheckResult {
            url: path.to_string(),
            status,
            source_file: source_file.to_string(),
            source_line: line,
            error_message: if status == LinkStatus::Broken {
                Some("File not found".to_string())
            } else {
                None
            },
        }
    }

    fn check_anchor(&self, anchor: &str, source_file: &str, line: usize) -> LinkCheckResult {
        // Would check if anchor exists in document
        // For now, assume valid

        LinkCheckResult {
            url: anchor.to_string(),
            status: LinkStatus::Valid,
            source_file: source_file.to_string(),
            source_line: line,
            error_message: None,
        }
    }

    /// Generate a link check report
    pub fn generate_report(&self, results: &[LinkCheckResult]) -> String {
        let mut md = String::from("# Link Validation Report\n\n");

        let total = results.len();
        let valid = results.iter().filter(|r| r.status == LinkStatus::Valid).count();
        let broken = results.iter().filter(|r| r.status == LinkStatus::Broken).count();
        let timeout = results.iter().filter(|r| r.status == LinkStatus::Timeout).count();
        let ignored = results.iter().filter(|r| r.status == LinkStatus::Ignored).count();
        let skipped = results.iter().filter(|r| r.status == LinkStatus::Skipped).count();

        md.push_str("## Summary\n\n");
        md.push_str(&format!("| Status | Count |\n"));
        md.push_str("|--------|-------|\n");
        md.push_str(&format!("| Valid | {} |\n", valid));
        md.push_str(&format!("| Broken | {} |\n", broken));
        md.push_str(&format!("| Timeout | {} |\n", timeout));
        md.push_str(&format!("| Ignored | {} |\n", ignored));
        md.push_str(&format!("| Skipped | {} |\n", skipped));
        md.push_str(&format!("| **Total** | **{}** |\n\n", total));

        if broken > 0 || timeout > 0 {
            md.push_str("## Broken Links\n\n");
            md.push_str("| URL | File | Line | Error |\n");
            md.push_str("|-----|------|------|-------|\n");

            for result in results {
                if result.status == LinkStatus::Broken || result.status == LinkStatus::Timeout {
                    md.push_str(&format!("| `{}` | {} | {} | {} |\n",
                        result.url,
                        result.source_file,
                        result.source_line,
                        result.error_message.as_ref().unwrap_or(&String::new())
                    ));
                }
            }
        }

        md
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-LANGUAGE DOCUMENTATION SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Multi-language documentation manager
pub struct I18nDocManager {
    config: I18nConfig,
    translations: HashMap<String, HashMap<String, String>>,
    source_strings: Vec<TranslationString>,
}

#[derive(Clone)]
pub struct I18nConfig {
    pub default_locale: String,
    pub available_locales: Vec<String>,
    pub translations_dir: String,
    pub fallback_chain: HashMap<String, Vec<String>>,
    pub placeholder_format: PlaceholderFormat,
}

#[derive(Clone, Copy)]
pub enum PlaceholderFormat {
    Curly,     // {name}
    Percent,   // %s, %d
    Dollar,    // $name
    ICU,       // {name, type, format}
}

#[derive(Clone)]
pub struct TranslationString {
    pub key: String,
    pub source: String,
    pub context: Option<String>,
    pub file: String,
    pub line: usize,
}

impl Default for I18nConfig {
    fn default() -> Self {
        I18nConfig {
            default_locale: "en".to_string(),
            available_locales: vec!["en".to_string()],
            translations_dir: "docs/i18n".to_string(),
            fallback_chain: HashMap::new(),
            placeholder_format: PlaceholderFormat::Curly,
        }
    }
}

impl I18nDocManager {
    pub fn new(config: I18nConfig) -> Self {
        I18nDocManager {
            config,
            translations: HashMap::new(),
            source_strings: Vec::new(),
        }
    }

    /// Load translations from files
    pub fn load_translations(&mut self) -> Result<(), DocError> {
        for locale in &self.config.available_locales {
            let file_path = format!("{}/{}.json", self.config.translations_dir, locale);

            if exists(&file_path) {
                let content = read_to_string(&file_path)?;
                let translations = self.parse_translation_file(&content)?;
                self.translations.insert(locale.clone(), translations);
            }
        }

        Ok(())
    }

    fn parse_translation_file(&self, content: &str) -> Result<HashMap<String, String>, DocError> {
        let mut translations = HashMap::new();

        // Simple JSON parsing
        let content = content.trim();
        if !content.starts_with('{') || !content.ends_with('}') {
            return Err(DocError::ParseError("Invalid JSON".to_string()));
        }

        let inner = &content[1..content.len() - 1];

        for line in inner.lines() {
            let line = line.trim().trim_end_matches(',');
            if let Some(colon_idx) = line.find(':') {
                let key = line[..colon_idx].trim().trim_matches('"');
                let value = line[colon_idx + 1..].trim().trim_matches('"');
                translations.insert(key.to_string(), value.to_string());
            }
        }

        Ok(translations)
    }

    /// Get translation for a key in a specific locale
    pub fn get(&self, key: &str, locale: &str) -> Option<String> {
        // Try exact locale
        if let Some(translations) = self.translations.get(locale) {
            if let Some(value) = translations.get(key) {
                return Some(value.clone());
            }
        }

        // Try fallback chain
        if let Some(fallbacks) = self.config.fallback_chain.get(locale) {
            for fallback in fallbacks {
                if let Some(translations) = self.translations.get(fallback) {
                    if let Some(value) = translations.get(key) {
                        return Some(value.clone());
                    }
                }
            }
        }

        // Try default locale
        if let Some(translations) = self.translations.get(&self.config.default_locale) {
            return translations.get(key).cloned();
        }

        None
    }

    /// Format a translated string with parameters
    pub fn format(&self, template: &str, params: &HashMap<String, String>) -> String {
        let mut result = template.to_string();

        match self.config.placeholder_format {
            PlaceholderFormat::Curly => {
                for (key, value) in params {
                    result = result.replace(&format!("{{{}}}", key), value);
                }
            }
            PlaceholderFormat::Dollar => {
                for (key, value) in params {
                    result = result.replace(&format!("${}", key), value);
                }
            }
            _ => {}
        }

        result
    }

    /// Extract translatable strings from documentation
    pub fn extract_strings(&mut self, content: &str, file: &str) -> Vec<TranslationString> {
        let mut strings = Vec::new();

        for (line_num, line) in content.lines().enumerate() {
            // Extract from markdown headers
            if line.starts_with('#') {
                let header = line.trim_start_matches('#').trim();
                if !header.is_empty() {
                    let key = self.generate_key(header);
                    strings.push(TranslationString {
                        key,
                        source: header.to_string(),
                        context: Some("header".to_string()),
                        file: file.to_string(),
                        line: line_num + 1,
                    });
                }
            }

            // Extract from paragraphs (non-code, non-list)
            if !line.starts_with('#') && !line.starts_with('-') && !line.starts_with('*')
               && !line.starts_with('`') && !line.starts_with('>') && !line.trim().is_empty() {
                let key = self.generate_key(line);
                strings.push(TranslationString {
                    key,
                    source: line.to_string(),
                    context: Some("paragraph".to_string()),
                    file: file.to_string(),
                    line: line_num + 1,
                });
            }
        }

        self.source_strings.extend(strings.clone());
        strings
    }

    fn generate_key(&self, text: &str) -> String {
        // Generate a key from the text
        let normalized: String = text.to_lowercase()
            .chars()
            .map(|c| if c.is_alphanumeric() { c } else { '_' })
            .collect();

        let truncated: String = normalized.chars().take(50).collect();
        truncated.trim_matches('_').to_string()
    }

    /// Generate translation template for a locale
    pub fn generate_template(&self, locale: &str) -> String {
        let mut template = String::from("{\n");

        for string in &self.source_strings {
            let existing = self.get(&string.key, locale);
            let value = existing.unwrap_or_else(|| string.source.clone());

            template.push_str(&format!("  \"{}\": \"{}\",\n",
                string.key,
                value.replace("\"", "\\\"")
            ));
        }

        // Remove trailing comma
        if template.ends_with(",\n") {
            template.truncate(template.len() - 2);
            template.push('\n');
        }

        template.push_str("}\n");
        template
    }

    /// Translate a document to a specific locale
    pub fn translate_doc(&self, content: &str, locale: &str) -> String {
        let mut result = String::new();

        for line in content.lines() {
            let key = self.generate_key(line);

            if let Some(translation) = self.get(&key, locale) {
                result.push_str(&translation);
            } else {
                result.push_str(line);
            }
            result.push('\n');
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEARCH INDEX GENERATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Generates search indexes for documentation
pub struct SearchIndexGenerator {
    config: SearchConfig,
    documents: Vec<SearchDocument>,
    index: SearchIndex,
}

#[derive(Clone)]
pub struct SearchConfig {
    pub output_path: String,
    pub output_format: SearchIndexFormat,
    pub include_content: bool,
    pub max_excerpt_length: usize,
    pub stopwords: Vec<String>,
    pub min_word_length: usize,
    pub boost_title: f32,
    pub boost_heading: f32,
    pub enable_stemming: bool,
}

#[derive(Clone, Copy)]
pub enum SearchIndexFormat {
    Json,
    Lunr,
    Flexsearch,
    Pagefind,
}

impl Default for SearchConfig {
    fn default() -> Self {
        SearchConfig {
            output_path: "search-index.json".to_string(),
            output_format: SearchIndexFormat::Json,
            include_content: true,
            max_excerpt_length: 200,
            stopwords: vec![
                "a", "an", "the", "and", "or", "but", "in", "on", "at", "to", "for",
                "is", "are", "was", "were", "be", "been", "being", "have", "has", "had",
                "do", "does", "did", "will", "would", "could", "should", "may", "might",
                "must", "can", "this", "that", "these", "those", "it", "its"
            ].into_iter().map(String::from).collect(),
            min_word_length: 2,
            boost_title: 10.0,
            boost_heading: 5.0,
            enable_stemming: true,
        }
    }
}

#[derive(Clone)]
pub struct SearchDocument {
    pub id: String,
    pub url: String,
    pub title: String,
    pub content: String,
    pub headings: Vec<String>,
    pub tags: Vec<String>,
    pub category: Option<String>,
}

#[derive(Clone, Default)]
pub struct SearchIndex {
    pub documents: Vec<IndexedDocument>,
    pub terms: HashMap<String, Vec<TermOccurrence>>,
    pub total_docs: usize,
}

#[derive(Clone)]
pub struct IndexedDocument {
    pub id: String,
    pub url: String,
    pub title: String,
    pub excerpt: String,
    pub word_count: usize,
}

#[derive(Clone)]
pub struct TermOccurrence {
    pub doc_id: String,
    pub frequency: usize,
    pub positions: Vec<usize>,
    pub field: String,
    pub boost: f32,
}

impl SearchIndexGenerator {
    pub fn new(config: SearchConfig) -> Self {
        SearchIndexGenerator {
            config,
            documents: Vec::new(),
            index: SearchIndex::default(),
        }
    }

    /// Add a document to the index
    pub fn add_document(&mut self, doc: SearchDocument) {
        self.documents.push(doc);
    }

    /// Build the search index
    pub fn build_index(&mut self) {
        self.index.total_docs = self.documents.len();

        for doc in &self.documents {
            // Create indexed document
            let excerpt = self.create_excerpt(&doc.content);
            let word_count = self.count_words(&doc.content);

            self.index.documents.push(IndexedDocument {
                id: doc.id.clone(),
                url: doc.url.clone(),
                title: doc.title.clone(),
                excerpt,
                word_count,
            });

            // Index title
            self.index_text(&doc.id, &doc.title, "title", self.config.boost_title);

            // Index headings
            for heading in &doc.headings {
                self.index_text(&doc.id, heading, "heading", self.config.boost_heading);
            }

            // Index content
            if self.config.include_content {
                self.index_text(&doc.id, &doc.content, "content", 1.0);
            }

            // Index tags
            for tag in &doc.tags {
                self.index_text(&doc.id, tag, "tag", 3.0);
            }
        }
    }

    fn index_text(&mut self, doc_id: &str, text: &str, field: &str, boost: f32) {
        let tokens = self.tokenize(text);
        let mut positions: HashMap<String, Vec<usize>> = HashMap::new();

        for (pos, token) in tokens.iter().enumerate() {
            positions.entry(token.clone())
                .or_insert_with(Vec::new)
                .push(pos);
        }

        for (term, pos_list) in positions {
            let occurrence = TermOccurrence {
                doc_id: doc_id.to_string(),
                frequency: pos_list.len(),
                positions: pos_list,
                field: field.to_string(),
                boost,
            };

            self.index.terms
                .entry(term)
                .or_insert_with(Vec::new)
                .push(occurrence);
        }
    }

    fn tokenize(&self, text: &str) -> Vec<String> {
        text.to_lowercase()
            .split(|c: char| !c.is_alphanumeric())
            .filter(|s| s.len() >= self.config.min_word_length)
            .filter(|s| !self.config.stopwords.contains(&s.to_string()))
            .map(|s| {
                if self.config.enable_stemming {
                    self.stem(s)
                } else {
                    s.to_string()
                }
            })
            .collect()
    }

    fn stem(&self, word: &str) -> String {
        // Simple Porter-like stemming
        let mut result = word.to_string();

        // Common suffixes
        let suffixes = ["ing", "ed", "es", "s", "ly", "ment", "ness", "tion", "sion"];

        for suffix in suffixes {
            if result.ends_with(suffix) && result.len() > suffix.len() + 2 {
                result.truncate(result.len() - suffix.len());
                break;
            }
        }

        result
    }

    fn create_excerpt(&self, content: &str) -> String {
        let words: Vec<&str> = content.split_whitespace().collect();
        let excerpt_words: Vec<&str> = words.iter()
            .take(self.config.max_excerpt_length / 5) // Approximate words
            .copied()
            .collect();

        let mut excerpt = excerpt_words.join(" ");
        if words.len() > excerpt_words.len() {
            excerpt.push_str("...");
        }

        excerpt
    }

    fn count_words(&self, content: &str) -> usize {
        content.split_whitespace().count()
    }

    /// Generate the search index file
    pub fn generate(&self) -> String {
        match self.config.output_format {
            SearchIndexFormat::Json => self.generate_json(),
            SearchIndexFormat::Lunr => self.generate_lunr(),
            SearchIndexFormat::Flexsearch => self.generate_flexsearch(),
            SearchIndexFormat::Pagefind => self.generate_pagefind(),
        }
    }

    fn generate_json(&self) -> String {
        let mut json = String::from("{\n");

        // Documents
        json.push_str("  \"documents\": [\n");
        for (i, doc) in self.index.documents.iter().enumerate() {
            json.push_str("    {\n");
            json.push_str(&format!("      \"id\": \"{}\",\n", doc.id));
            json.push_str(&format!("      \"url\": \"{}\",\n", doc.url));
            json.push_str(&format!("      \"title\": \"{}\",\n", doc.title.replace("\"", "\\\"")));
            json.push_str(&format!("      \"excerpt\": \"{}\"\n", doc.excerpt.replace("\"", "\\\"")));
            json.push_str("    }");
            if i < self.index.documents.len() - 1 { json.push(','); }
            json.push('\n');
        }
        json.push_str("  ],\n");

        // Terms (inverted index)
        json.push_str("  \"index\": {\n");
        let term_count = self.index.terms.len();
        for (i, (term, occurrences)) in self.index.terms.iter().enumerate() {
            json.push_str(&format!("    \"{}\": [", term));
            let occ_strs: Vec<String> = occurrences.iter()
                .map(|o| format!("{{\"d\":\"{}\",\"f\":{}}}", o.doc_id, o.frequency))
                .collect();
            json.push_str(&occ_strs.join(","));
            json.push(']');
            if i < term_count - 1 { json.push(','); }
            json.push('\n');
        }
        json.push_str("  }\n");

        json.push_str("}\n");
        json
    }

    fn generate_lunr(&self) -> String {
        // Lunr.js compatible format
        let mut js = String::from("var searchIndex = ");
        js.push_str(&self.generate_json());
        js.push_str(";\n");
        js
    }

    fn generate_flexsearch(&self) -> String {
        // FlexSearch compatible format
        self.generate_json() // Similar structure
    }

    fn generate_pagefind(&self) -> String {
        // Pagefind compatible format
        self.generate_json()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PDF/EPUB EXPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Document export to PDF and EPUB formats
pub struct DocExporter {
    config: ExportConfig,
}

#[derive(Clone)]
pub struct ExportConfig {
    pub title: String,
    pub author: String,
    pub language: String,
    pub output_format: ExportFormat,
    pub page_size: PageSize,
    pub margins: Margins,
    pub header: Option<String>,
    pub footer: Option<String>,
    pub cover_image: Option<String>,
    pub toc_depth: u8,
    pub syntax_highlighting: bool,
    pub include_index: bool,
}

#[derive(Clone, Copy)]
pub enum ExportFormat {
    Pdf,
    Epub,
    Mobi,
    Docx,
}

#[derive(Clone, Copy)]
pub enum PageSize {
    A4,
    Letter,
    A5,
    Custom(f32, f32),
}

#[derive(Clone, Copy)]
pub struct Margins {
    pub top: f32,
    pub bottom: f32,
    pub left: f32,
    pub right: f32,
}

impl Default for ExportConfig {
    fn default() -> Self {
        ExportConfig {
            title: "Documentation".to_string(),
            author: "QUANTA-UNIVERSE".to_string(),
            language: "en".to_string(),
            output_format: ExportFormat::Pdf,
            page_size: PageSize::A4,
            margins: Margins { top: 72.0, bottom: 72.0, left: 72.0, right: 72.0 },
            header: None,
            footer: Some("Page {page}".to_string()),
            cover_image: None,
            toc_depth: 3,
            syntax_highlighting: true,
            include_index: true,
        }
    }
}

impl DocExporter {
    pub fn new(config: ExportConfig) -> Self {
        DocExporter { config }
    }

    /// Export documentation to the configured format
    pub fn export(&self, html_content: &str, output_path: &str) -> Result<(), DocError> {
        match self.config.output_format {
            ExportFormat::Pdf => self.export_pdf(html_content, output_path),
            ExportFormat::Epub => self.export_epub(html_content, output_path),
            ExportFormat::Mobi => self.export_mobi(html_content, output_path),
            ExportFormat::Docx => self.export_docx(html_content, output_path),
        }
    }

    fn export_pdf(&self, html_content: &str, output_path: &str) -> Result<(), DocError> {
        // Generate PDF-ready HTML with CSS
        let pdf_html = self.wrap_for_pdf(html_content);

        // In production, would use wkhtmltopdf, puppeteer, or similar
        println!("Generating PDF: {}", output_path);
        println!("  Title: {}", self.config.title);
        println!("  Pages: ~{}", self.estimate_pages(&pdf_html));

        // Save intermediate HTML for now
        let html_path = output_path.replace(".pdf", "_print.html");
        write_string(&html_path, &pdf_html)?;

        println!("  Generated print-ready HTML: {}", html_path);

        Ok(())
    }

    fn wrap_for_pdf(&self, content: &str) -> String {
        let (width, height) = match self.config.page_size {
            PageSize::A4 => ("210mm", "297mm"),
            PageSize::Letter => ("8.5in", "11in"),
            PageSize::A5 => ("148mm", "210mm"),
            PageSize::Custom(w, h) => {
                // Would need string allocation
                ("auto", "auto")
            }
        };

        format!(r#"<!DOCTYPE html>
<html lang="{}">
<head>
    <meta charset="UTF-8">
    <title>{}</title>
    <style>
        @page {{
            size: {} {};
            margin: {}pt {}pt {}pt {}pt;
        }}
        @page :first {{
            margin-top: 0;
        }}
        body {{
            font-family: 'Georgia', serif;
            font-size: 11pt;
            line-height: 1.5;
            color: #333;
        }}
        h1 {{ font-size: 24pt; page-break-before: always; }}
        h2 {{ font-size: 18pt; page-break-after: avoid; }}
        h3 {{ font-size: 14pt; page-break-after: avoid; }}
        pre, code {{ font-family: 'Courier New', monospace; font-size: 9pt; }}
        pre {{ background: #f5f5f5; padding: 1em; page-break-inside: avoid; }}
        table {{ border-collapse: collapse; page-break-inside: avoid; }}
        th, td {{ border: 1px solid #ddd; padding: 8px; }}
        .page-break {{ page-break-after: always; }}
        .no-break {{ page-break-inside: avoid; }}
    </style>
</head>
<body>
{}
</body>
</html>"#,
            self.config.language,
            self.config.title,
            width, height,
            self.config.margins.top,
            self.config.margins.right,
            self.config.margins.bottom,
            self.config.margins.left,
            content
        )
    }

    fn estimate_pages(&self, html: &str) -> usize {
        // Rough estimate: ~3000 characters per page
        (html.len() / 3000).max(1)
    }

    fn export_epub(&self, html_content: &str, output_path: &str) -> Result<(), DocError> {
        println!("Generating EPUB: {}", output_path);

        // EPUB is a ZIP file with specific structure
        // Would need to create:
        // - META-INF/container.xml
        // - OEBPS/content.opf
        // - OEBPS/toc.ncx
        // - OEBPS/content.xhtml
        // - OEBPS/stylesheet.css

        let container_xml = r#"<?xml version="1.0" encoding="UTF-8"?>
<container version="1.0" xmlns="urn:oasis:names:tc:opendocument:xmlns:container">
    <rootfiles>
        <rootfile full-path="OEBPS/content.opf" media-type="application/oebps-package+xml"/>
    </rootfiles>
</container>"#;

        let content_opf = format!(r#"<?xml version="1.0" encoding="UTF-8"?>
<package xmlns="http://www.idpf.org/2007/opf" version="3.0" unique-identifier="uid">
    <metadata xmlns:dc="http://purl.org/dc/elements/1.1/">
        <dc:identifier id="uid">quanta-doc</dc:identifier>
        <dc:title>{}</dc:title>
        <dc:creator>{}</dc:creator>
        <dc:language>{}</dc:language>
    </metadata>
    <manifest>
        <item id="content" href="content.xhtml" media-type="application/xhtml+xml"/>
        <item id="style" href="stylesheet.css" media-type="text/css"/>
    </manifest>
    <spine>
        <itemref idref="content"/>
    </spine>
</package>"#, self.config.title, self.config.author, self.config.language);

        let xhtml = format!(r#"<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="{}">
<head>
    <title>{}</title>
    <link rel="stylesheet" type="text/css" href="stylesheet.css"/>
</head>
<body>
{}
</body>
</html>"#, self.config.language, self.config.title, html_content);

        // Save components for debugging
        println!("  Would create EPUB with {} bytes of content", html_content.len());

        Ok(())
    }

    fn export_mobi(&self, html_content: &str, output_path: &str) -> Result<(), DocError> {
        println!("Generating MOBI: {}", output_path);
        println!("  Note: MOBI export requires KindleGen tool");

        // First generate EPUB, then convert
        let epub_path = output_path.replace(".mobi", ".epub");
        self.export_epub(html_content, &epub_path)?;

        // Would run: kindlegen epub_path -o output_path

        Ok(())
    }

    fn export_docx(&self, html_content: &str, output_path: &str) -> Result<(), DocError> {
        println!("Generating DOCX: {}", output_path);

        // DOCX is also a ZIP with XML files
        // Would need to create:
        // - [Content_Types].xml
        // - _rels/.rels
        // - word/document.xml
        // - word/styles.xml

        println!("  Would create DOCX with {} bytes of content", html_content.len());

        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INCREMENTAL DOCUMENTATION BUILD
// ═══════════════════════════════════════════════════════════════════════════════

/// Incremental documentation builder with caching
pub struct IncrementalDocBuilder {
    config: IncrementalConfig,
    cache: DocCache,
}

#[derive(Clone)]
pub struct IncrementalConfig {
    pub cache_dir: String,
    pub source_dirs: Vec<String>,
    pub output_dir: String,
    pub parallel: bool,
    pub max_workers: usize,
    pub force_rebuild: bool,
}

impl Default for IncrementalConfig {
    fn default() -> Self {
        IncrementalConfig {
            cache_dir: ".doc-cache".to_string(),
            source_dirs: vec![".".to_string()],
            output_dir: "target/doc".to_string(),
            parallel: true,
            max_workers: 4,
            force_rebuild: false,
        }
    }
}

#[derive(Clone)]
pub struct DocCache {
    entries: HashMap<String, CacheEntry>,
    cache_file: String,
}

#[derive(Clone)]
pub struct CacheEntry {
    pub source_hash: String,
    pub output_hash: String,
    pub last_modified: u64,
    pub dependencies: Vec<String>,
}

impl DocCache {
    pub fn new(cache_dir: &str) -> Self {
        DocCache {
            entries: HashMap::new(),
            cache_file: format!("{}/cache.json", cache_dir),
        }
    }

    pub fn load(&mut self) -> Result<(), DocError> {
        if exists(&self.cache_file) {
            let content = read_to_string(&self.cache_file)?;
            // Parse JSON cache
            self.entries = self.parse_cache(&content)?;
        }
        Ok(())
    }

    fn parse_cache(&self, content: &str) -> Result<HashMap<String, CacheEntry>, DocError> {
        let mut entries = HashMap::new();
        // Simple parsing - in production would use proper JSON parser
        Ok(entries)
    }

    pub fn save(&self) -> Result<(), DocError> {
        let mut json = String::from("{\n");

        for (path, entry) in &self.entries {
            json.push_str(&format!("  \"{}\": {{\n", path));
            json.push_str(&format!("    \"source_hash\": \"{}\",\n", entry.source_hash));
            json.push_str(&format!("    \"output_hash\": \"{}\",\n", entry.output_hash));
            json.push_str(&format!("    \"last_modified\": {}\n", entry.last_modified));
            json.push_str("  },\n");
        }

        json.push_str("}\n");

        write_string(&self.cache_file, &json)?;
        Ok(())
    }

    pub fn is_valid(&self, path: &str, current_hash: &str) -> bool {
        if let Some(entry) = self.entries.get(path) {
            return entry.source_hash == current_hash;
        }
        false
    }

    pub fn update(&mut self, path: &str, entry: CacheEntry) {
        self.entries.insert(path.to_string(), entry);
    }
}

impl IncrementalDocBuilder {
    pub fn new(config: IncrementalConfig) -> Self {
        let cache = DocCache::new(&config.cache_dir);
        IncrementalDocBuilder { config, cache }
    }

    /// Build documentation incrementally
    pub fn build(&mut self) -> Result<BuildResult, DocError> {
        println!("Building documentation incrementally...\n");

        // Load cache
        if !self.config.force_rebuild {
            self.cache.load()?;
        }

        // Find all source files
        let source_files = self.find_source_files()?;
        println!("Found {} source files", source_files.len());

        // Determine what needs rebuilding
        let mut to_rebuild = Vec::new();
        let mut unchanged = 0;

        for file in &source_files {
            let hash = self.compute_hash(file)?;

            if self.config.force_rebuild || !self.cache.is_valid(file, &hash) {
                to_rebuild.push((file.clone(), hash));
            } else {
                unchanged += 1;
            }
        }

        println!("{} files need rebuilding, {} unchanged\n", to_rebuild.len(), unchanged);

        // Rebuild changed files
        let mut built = 0;
        let mut errors = Vec::new();

        for (file, hash) in to_rebuild {
            print!("  Building {}...", file);

            match self.build_file(&file) {
                Ok(output_hash) => {
                    self.cache.update(&file, CacheEntry {
                        source_hash: hash,
                        output_hash,
                        last_modified: self.get_mtime(&file),
                        dependencies: Vec::new(),
                    });
                    built += 1;
                    println!(" ok");
                }
                Err(e) => {
                    errors.push(format!("{}: {:?}", file, e));
                    println!(" FAILED");
                }
            }
        }

        // Save cache
        self.cache.save()?;

        println!("\nBuild complete: {} built, {} errors\n", built, errors.len());

        Ok(BuildResult {
            total_files: source_files.len(),
            built_files: built,
            cached_files: unchanged,
            errors,
        })
    }

    fn find_source_files(&self) -> Result<Vec<String>, DocError> {
        let mut files = Vec::new();

        for dir in &self.config.source_dirs {
            for entry in walk_dir(dir)? {
                if entry.ends_with(".quanta") || entry.ends_with(".md") {
                    files.push(entry);
                }
            }
        }

        Ok(files)
    }

    fn compute_hash(&self, file: &str) -> Result<String, DocError> {
        let content = read_to_string(file)?;
        Ok(simple_hash(&content))
    }

    fn build_file(&self, file: &str) -> Result<String, DocError> {
        let content = read_to_string(file)?;

        // Parse and generate documentation
        let mut parser = DocParser::new();
        let module = parser.parse_file(file)?;

        // Generate HTML
        let generator = HtmlGenerator::new(HtmlConfig {
            output_dir: self.config.output_dir.clone(),
            ..Default::default()
        });

        // Would generate actual output
        let output = format!("Generated documentation for {}", module.name);

        Ok(simple_hash(&output))
    }

    fn get_mtime(&self, file: &str) -> u64 {
        // Would get actual modification time
        0
    }
}

#[derive(Clone)]
pub struct BuildResult {
    pub total_files: usize,
    pub built_files: usize,
    pub cached_files: usize,
    pub errors: Vec<String>,
}

fn simple_hash(input: &str) -> String {
    // Simple hash for caching (would use SHA256 in production)
    let mut hash: u64 = 0;
    for byte in input.bytes() {
        hash = hash.wrapping_mul(31).wrapping_add(byte as u64);
    }
    format!("{:016x}", hash)
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGRAM INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Diagram generation and integration
pub struct DiagramGenerator {
    config: DiagramConfig,
}

#[derive(Clone)]
pub struct DiagramConfig {
    pub output_dir: String,
    pub format: DiagramOutputFormat,
    pub theme: DiagramTheme,
    pub font_family: String,
    pub background: Option<String>,
}

#[derive(Clone, Copy)]
pub enum DiagramOutputFormat {
    Svg,
    Png,
    Pdf,
}

#[derive(Clone)]
pub enum DiagramTheme {
    Default,
    Dark,
    Forest,
    Neutral,
    Custom(HashMap<String, String>),
}

impl Default for DiagramConfig {
    fn default() -> Self {
        DiagramConfig {
            output_dir: "target/doc/diagrams".to_string(),
            format: DiagramOutputFormat::Svg,
            theme: DiagramTheme::Default,
            font_family: "sans-serif".to_string(),
            background: None,
        }
    }
}

impl DiagramGenerator {
    pub fn new(config: DiagramConfig) -> Self {
        DiagramGenerator { config }
    }

    /// Generate a diagram from Mermaid source
    pub fn generate_mermaid(&self, source: &str, name: &str) -> Result<String, DocError> {
        let output_path = format!("{}/{}.{}",
            self.config.output_dir,
            name,
            match self.config.format {
                DiagramOutputFormat::Svg => "svg",
                DiagramOutputFormat::Png => "png",
                DiagramOutputFormat::Pdf => "pdf",
            }
        );

        // Generate inline SVG for embedding
        let svg = self.mermaid_to_svg(source)?;

        create_dir_all(&self.config.output_dir)?;
        write_string(&output_path, &svg)?;

        Ok(output_path)
    }

    fn mermaid_to_svg(&self, source: &str) -> Result<String, DocError> {
        // In production, would use mermaid-cli or mermaid.js
        // For now, create placeholder SVG

        let theme_bg = match &self.config.theme {
            DiagramTheme::Dark => "#1a1a2e",
            DiagramTheme::Forest => "#1e3a2f",
            _ => "#ffffff",
        };

        let theme_text = match &self.config.theme {
            DiagramTheme::Dark | DiagramTheme::Forest => "#e0e0e0",
            _ => "#333333",
        };

        let svg = format!(r#"<svg xmlns="http://www.w3.org/2000/svg" width="400" height="200" viewBox="0 0 400 200">
    <rect width="100%" height="100%" fill="{}"/>
    <text x="200" y="100" text-anchor="middle" fill="{}" font-family="{}">
        Mermaid Diagram: {} chars
    </text>
</svg>"#,
            theme_bg,
            theme_text,
            self.config.font_family,
            source.len()
        );

        Ok(svg)
    }

    /// Generate a diagram from PlantUML source
    pub fn generate_plantuml(&self, source: &str, name: &str) -> Result<String, DocError> {
        let output_path = format!("{}/{}.svg", self.config.output_dir, name);

        // PlantUML can be rendered via their server or locally
        // For embedded use, we generate a URL
        let encoded = self.encode_plantuml(source);
        let svg_url = format!("https://www.plantuml.com/plantuml/svg/{}", encoded);

        // Would fetch and save, for now just return URL
        Ok(svg_url)
    }

    fn encode_plantuml(&self, source: &str) -> String {
        // PlantUML uses a custom encoding
        base64_encode(source)
    }

    /// Generate a diagram from DOT/Graphviz source
    pub fn generate_graphviz(&self, source: &str, name: &str) -> Result<String, DocError> {
        let output_path = format!("{}/{}.svg", self.config.output_dir, name);

        // Would use graphviz/dot command
        // dot -Tsvg input.dot -o output.svg

        println!("Would generate Graphviz diagram: {}", output_path);

        Ok(output_path)
    }

    /// Auto-generate diagrams from code structure
    pub fn generate_from_modules(&self, modules: &HashMap<String, ModuleDoc>) -> Result<Vec<String>, DocError> {
        let mut diagrams = Vec::new();

        // Generate module dependency diagram
        let module_diagram = self.generate_module_diagram(modules)?;
        diagrams.push(module_diagram);

        // Generate class/struct diagrams for each module
        for (name, module) in modules {
            if let Some(class_diagram) = self.generate_class_diagram(name, module)? {
                diagrams.push(class_diagram);
            }
        }

        Ok(diagrams)
    }

    fn generate_module_diagram(&self, modules: &HashMap<String, ModuleDoc>) -> Result<String, DocError> {
        let mut mermaid = String::from("graph TD\n");

        for (name, module) in modules {
            let safe_name = name.replace("::", "_");
            mermaid.push_str(&format!("    {}[{}]\n", safe_name, name));

            for submod in &module.submodules {
                let safe_submod = submod.replace("::", "_");
                mermaid.push_str(&format!("    {} --> {}\n", safe_name, safe_submod));
            }
        }

        self.generate_mermaid(&mermaid, "module_dependencies")
    }

    fn generate_class_diagram(&self, module_name: &str, module: &ModuleDoc) -> Result<Option<String>, DocError> {
        let structs: Vec<_> = module.items.iter()
            .filter(|i| i.kind == ItemKind::Struct || i.kind == ItemKind::Enum)
            .collect();

        if structs.is_empty() {
            return Ok(None);
        }

        let mut mermaid = String::from("classDiagram\n");

        for item in structs {
            mermaid.push_str(&format!("    class {} {{\n", item.name));

            // Add methods from impls
            for impl_item in module.items.iter().filter(|i| i.kind == ItemKind::Impl && i.name == item.name) {
                for child in &impl_item.children {
                    if child.kind == ItemKind::Method {
                        mermaid.push_str(&format!("        +{}()\n", child.name));
                    }
                }
            }

            mermaid.push_str("    }\n");
        }

        let safe_name = module_name.replace("::", "_");
        Ok(Some(self.generate_mermaid(&mermaid, &format!("{}_classes", safe_name))?))
    }
}
