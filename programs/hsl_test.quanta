struct RGB { r: f64, g: f64, b: f64 }
struct HSL { h: f64, s: f64, l: f64 }

impl RGB {
    fn new(r: f64, g: f64, b: f64) -> RGB { RGB { r, g, b } }
}

impl HSL {
    fn new(h: f64, s: f64, l: f64) -> HSL { HSL { h, s, l } }

    fn from_rgb(rgb: &RGB) -> HSL {
        let r = rgb.r;
        let g = rgb.g;
        let b = rgb.b;

        let max = if r > g { if r > b { r } else { b } } else { if g > b { g } else { b } };
        let min = if r < g { if r < b { r } else { b } } else { if g < b { g } else { b } };
        let l = (max + min) / 2.0;
        let d = max - min;

        if d < 0.00001 {
            return HSL::new(0.0, 0.0, l);
        }

        let s = if l > 0.5 { d / (2.0 - max - min) } else { d / (max + min) };

        let mut h = if max == r {
            (g - b) / d
        } else if max == g {
            2.0 + (b - r) / d
        } else {
            4.0 + (r - g) / d
        };
        h = h * 60.0;
        if h < 0.0 { h = h + 360.0; }

        HSL::new(h, s, l)
    }
}

fn approx(a: f64, b: f64, tol: f64) -> bool {
    let d = a - b;
    let abs = if d < 0.0 { 0.0 - d } else { d };
    abs < tol
}

fn main() {
    let mut pass = 0;

    // Red → HSL(0, 1, 0.5)
    let r = HSL::from_rgb(&RGB::new(1.0, 0.0, 0.0));
    if approx(r.h, 0.0, 1.0) && approx(r.s, 1.0, 0.01) && approx(r.l, 0.5, 0.01) {
        pass = pass + 1;
    } else {
        println!("FAIL Red HSL: ({}, {}, {})", r.h, r.s, r.l);
    }

    // Green → HSL(120, 1, 0.5)
    let g = HSL::from_rgb(&RGB::new(0.0, 1.0, 0.0));
    if approx(g.h, 120.0, 1.0) && approx(g.s, 1.0, 0.01) && approx(g.l, 0.5, 0.01) {
        pass = pass + 1;
    } else {
        println!("FAIL Green HSL: ({}, {}, {})", g.h, g.s, g.l);
    }

    // Blue → HSL(240, 1, 0.5)
    let b = HSL::from_rgb(&RGB::new(0.0, 0.0, 1.0));
    if approx(b.h, 240.0, 1.0) && approx(b.s, 1.0, 0.01) && approx(b.l, 0.5, 0.01) {
        pass = pass + 1;
    } else {
        println!("FAIL Blue HSL: ({}, {}, {})", b.h, b.s, b.l);
    }

    // White → HSL(0, 0, 1)
    let w = HSL::from_rgb(&RGB::new(1.0, 1.0, 1.0));
    if approx(w.s, 0.0, 0.01) && approx(w.l, 1.0, 0.01) {
        pass = pass + 1;
    } else {
        println!("FAIL White HSL: ({}, {}, {})", w.h, w.s, w.l);
    }

    // Gray → HSL(0, 0, 0.5)
    let gr = HSL::from_rgb(&RGB::new(0.5, 0.5, 0.5));
    if approx(gr.s, 0.0, 0.01) && approx(gr.l, 0.5, 0.01) {
        pass = pass + 1;
    } else {
        println!("FAIL Gray HSL: ({}, {}, {})", gr.h, gr.s, gr.l);
    }

    // Orange (1, 0.5, 0) → HSL(30, 1, 0.5)
    let o = HSL::from_rgb(&RGB::new(1.0, 0.5, 0.0));
    if approx(o.h, 30.0, 1.0) && approx(o.s, 1.0, 0.01) && approx(o.l, 0.5, 0.01) {
        pass = pass + 1;
    } else {
        println!("FAIL Orange HSL: ({}, {}, {})", o.h, o.s, o.l);
    }

    println!("{} / 6 HSL tests passed", pass);
}
