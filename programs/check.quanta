// =============================================================================
// qcheck - QuantaLang Type Checker written in QuantaLang
// =============================================================================
// Fifth self-hosting tool. Reads .quanta source, tokenizes it, then performs
// two-pass semantic analysis:
//   Pass 1 (collection): Register all fn names/arities, struct names/fields,
//                         enum names/variants at the top level.
//   Pass 2 (checking):   Walk function bodies, track variable scopes,
//                         validate calls, field accesses, and definitions.
//
// Checks:
//   - Undefined variable usage
//   - Function call arity mismatches
//   - Duplicate function definitions
//   - Duplicate struct definitions
//   - Duplicate enum definitions
//   - Unused variables (warnings)
//   - Type annotation mismatches (literal vs annotation)
//
// Usage:
//   qcheck file.quanta           check single file
//   qcheck -r dir/               check all .quanta files recursively
//   qcheck --help                usage
// =============================================================================

// ---------------------------------------------------------------------------
// Token type constants (must match tok.quanta / parse.quanta)
// ---------------------------------------------------------------------------
fn TK_KEYWORD() -> i32 { 1 }
fn TK_IDENT() -> i32 { 2 }
fn TK_INT_LIT() -> i32 { 3 }
fn TK_FLOAT_LIT() -> i32 { 4 }
fn TK_STR_LIT() -> i32 { 5 }
fn TK_CHAR_LIT() -> i32 { 6 }
fn TK_PLUS() -> i32 { 10 }
fn TK_MINUS() -> i32 { 11 }
fn TK_STAR() -> i32 { 12 }
fn TK_SLASH() -> i32 { 13 }
fn TK_PERCENT() -> i32 { 14 }
fn TK_ASSIGN() -> i32 { 15 }
fn TK_EQ() -> i32 { 16 }
fn TK_NEQ() -> i32 { 17 }
fn TK_LT() -> i32 { 18 }
fn TK_GT() -> i32 { 19 }
fn TK_LE() -> i32 { 20 }
fn TK_GE() -> i32 { 21 }
fn TK_AND() -> i32 { 22 }
fn TK_OR() -> i32 { 23 }
fn TK_NOT() -> i32 { 24 }
fn TK_BIT_AND() -> i32 { 25 }
fn TK_BIT_OR() -> i32 { 26 }
fn TK_ARROW() -> i32 { 34 }
fn TK_FAT_ARROW() -> i32 { 35 }
fn TK_COLONCOLON() -> i32 { 36 }
fn TK_LPAREN() -> i32 { 40 }
fn TK_RPAREN() -> i32 { 41 }
fn TK_LBRACE() -> i32 { 42 }
fn TK_RBRACE() -> i32 { 43 }
fn TK_LBRACK() -> i32 { 44 }
fn TK_RBRACK() -> i32 { 45 }
fn TK_COMMA() -> i32 { 46 }
fn TK_SEMI() -> i32 { 47 }
fn TK_COLON() -> i32 { 48 }
fn TK_DOT() -> i32 { 49 }

include!("stdlib/chars.quanta");

// ---------------------------------------------------------------------------
// Tokenizer (embedded from tok.quanta)
// ---------------------------------------------------------------------------
struct Tok {
    input: String,
    ilen: i32,
    pos: i32,
    line: i32,
    col: i32,
    pool: String,
    t_types: Vec<i32>,
    t_starts: Vec<i32>,
    t_lens: Vec<i32>,
    t_lines: Vec<i32>,
    t_cols: Vec<i32>,
    count: i32,
}

fn tok_new(input: String) -> Tok {
    let ilen = input.len();
    Tok {
        input: input, ilen: ilen,
        pos: 0, line: 1, col: 1,
        pool: "",
        t_types: vec![], t_starts: vec![], t_lens: vec![],
        t_lines: vec![], t_cols: vec![],
        count: 0,
    }
}

fn pool_add(t: &mut Tok, text: String) -> i32 {
    let st = t.pool.len();
    t.pool = t.pool + text;
    st
}

fn pool_get(t: &Tok, start: i32, length: i32) -> String {
    if length == 0 { return ""; }
    t.pool.substring(start, length)
}

fn emit(t: &mut Tok, ttype: i32, text: String, tline: i32, tcol: i32) {
    let st = pool_add(t, text);
    let tlen = text.len();
    vec_push(t.t_types, ttype);
    vec_push(t.t_starts, st);
    vec_push(t.t_lens, tlen);
    vec_push(t.t_lines, tline);
    vec_push(t.t_cols, tcol);
    t.count = t.count + 1;
}

fn peek_tok(t: &Tok) -> String {
    if t.pos >= t.ilen { return ""; }
    t.input.char_at(t.pos)
}

fn peek_at(t: &Tok, offset: i32) -> String {
    let p = t.pos + offset;
    if p >= t.ilen { return ""; }
    t.input.char_at(p)
}

fn advance_tok(t: &mut Tok) -> String {
    if t.pos >= t.ilen { return ""; }
    let c = t.input.char_at(t.pos);
    t.pos = t.pos + 1;
    if c == "\n" { t.line = t.line + 1; t.col = 1; }
    else { t.col = t.col + 1; }
    c
}

fn is_keyword(s: String) -> bool {
    if s == "fn" { return true; } if s == "let" { return true; }
    if s == "mut" { return true; } if s == "if" { return true; }
    if s == "else" { return true; } if s == "while" { return true; }
    if s == "for" { return true; } if s == "in" { return true; }
    if s == "return" { return true; } if s == "struct" { return true; }
    if s == "enum" { return true; } if s == "impl" { return true; }
    if s == "pub" { return true; } if s == "mod" { return true; }
    if s == "use" { return true; } if s == "match" { return true; }
    if s == "trait" { return true; } if s == "const" { return true; }
    if s == "true" { return true; } if s == "false" { return true; }
    if s == "self" { return true; } if s == "Self" { return true; }
    if s == "super" { return true; } if s == "where" { return true; }
    if s == "as" { return true; } if s == "break" { return true; }
    if s == "continue" { return true; } if s == "loop" { return true; }
    if s == "type" { return true; }
    false
}

fn skip_whitespace(t: &mut Tok) {
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else {
            let c = peek_tok(t);
            if is_whitespace(c) { advance_tok(t); }
            else { go = false; }
        }
    }
}

fn skip_line_comment(t: &mut Tok) {
    advance_tok(t); advance_tok(t);
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else {
            let c = peek_tok(t);
            if c == "\n" { advance_tok(t); go = false; }
            else { advance_tok(t); }
        }
    }
}

fn skip_block_comment(t: &mut Tok) {
    advance_tok(t); advance_tok(t);
    let mut depth: i32 = 1;
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else {
            let c = peek_tok(t);
            let c2 = peek_at(t, 1);
            if c == "/" && c2 == "*" {
                advance_tok(t); advance_tok(t); depth = depth + 1;
            } else if c == "*" && c2 == "/" {
                advance_tok(t); advance_tok(t); depth = depth - 1;
                if depth == 0 { go = false; }
            } else { advance_tok(t); }
        }
    }
}

fn read_string(t: &mut Tok) {
    let tline = t.line; let tcol = t.col;
    let mut text = "\"";
    advance_tok(t);
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else {
            let c = peek_tok(t);
            if c == "\\" {
                text = text + advance_tok(t);
                if t.pos < t.ilen { text = text + advance_tok(t); }
            } else if c == "\"" { text = text + advance_tok(t); go = false; }
            else { text = text + advance_tok(t); }
        }
    }
    emit(t, TK_STR_LIT(), text, tline, tcol);
}

fn read_char_lit(t: &mut Tok) {
    let tline = t.line; let tcol = t.col;
    let mut text = "'";
    advance_tok(t);
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else {
            let c = peek_tok(t);
            if c == "\\" {
                text = text + advance_tok(t);
                if t.pos < t.ilen { text = text + advance_tok(t); }
            } else if c == "'" { text = text + advance_tok(t); go = false; }
            else { text = text + advance_tok(t); }
        }
    }
    emit(t, TK_CHAR_LIT(), text, tline, tcol);
}

fn read_number(t: &mut Tok) {
    let tline = t.line; let tcol = t.col;
    let mut text = "";
    let c0 = peek_tok(t);
    if c0 == "0" {
        let c1 = peek_at(t, 1);
        if c1 == "x" || c1 == "X" {
            text = text + advance_tok(t); text = text + advance_tok(t);
            let mut go = true;
            while go {
                if t.pos >= t.ilen { go = false; }
                else { let c = peek_tok(t); if is_hex_digit(c) || c == "_" { text = text + advance_tok(t); } else { go = false; } }
            }
            emit(t, TK_INT_LIT(), text, tline, tcol); return;
        }
        if c1 == "b" || c1 == "B" {
            text = text + advance_tok(t); text = text + advance_tok(t);
            let mut go = true;
            while go {
                if t.pos >= t.ilen { go = false; }
                else { let c = peek_tok(t); if is_bin_digit(c) || c == "_" { text = text + advance_tok(t); } else { go = false; } }
            }
            emit(t, TK_INT_LIT(), text, tline, tcol); return;
        }
        if c1 == "o" || c1 == "O" {
            text = text + advance_tok(t); text = text + advance_tok(t);
            let mut go = true;
            while go {
                if t.pos >= t.ilen { go = false; }
                else { let c = peek_tok(t); if is_oct_digit(c) || c == "_" { text = text + advance_tok(t); } else { go = false; } }
            }
            emit(t, TK_INT_LIT(), text, tline, tcol); return;
        }
    }
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else { let c = peek_tok(t); if is_digit(c) || c == "_" { text = text + advance_tok(t); } else { go = false; } }
    }
    let mut is_float = false;
    if t.pos < t.ilen {
        let dot = peek_tok(t);
        if dot == "." {
            let after = peek_at(t, 1);
            if is_digit(after) {
                is_float = true;
                text = text + advance_tok(t);
                let mut go2 = true;
                while go2 {
                    if t.pos >= t.ilen { go2 = false; }
                    else { let c = peek_tok(t); if is_digit(c) || c == "_" { text = text + advance_tok(t); } else { go2 = false; } }
                }
            }
        }
    }
    if t.pos < t.ilen {
        let ec = peek_tok(t);
        if ec == "e" || ec == "E" {
            is_float = true;
            text = text + advance_tok(t);
            if t.pos < t.ilen {
                let sign = peek_tok(t);
                if sign == "+" || sign == "-" { text = text + advance_tok(t); }
            }
            let mut go3 = true;
            while go3 {
                if t.pos >= t.ilen { go3 = false; }
                else { let c = peek_tok(t); if is_digit(c) { text = text + advance_tok(t); } else { go3 = false; } }
            }
        }
    }
    if is_float { emit(t, TK_FLOAT_LIT(), text, tline, tcol); }
    else { emit(t, TK_INT_LIT(), text, tline, tcol); }
}

fn read_ident_or_keyword(t: &mut Tok) {
    let tline = t.line; let tcol = t.col;
    let mut text = "";
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else { let c = peek_tok(t); if is_alnum(c) { text = text + advance_tok(t); } else { go = false; } }
    }
    if is_keyword(text) { emit(t, TK_KEYWORD(), text, tline, tcol); }
    else { emit(t, TK_IDENT(), text, tline, tcol); }
}

fn read_operator(t: &mut Tok) {
    let tline = t.line; let tcol = t.col;
    let c = peek_tok(t); let c2 = peek_at(t, 1); let c3 = peek_at(t, 2);
    if c == "." && c2 == "." && c3 == "=" { advance_tok(t); advance_tok(t); advance_tok(t); emit(t, 38, "..=", tline, tcol); return; }
    if c == "<" && c2 == "<" { advance_tok(t); advance_tok(t); emit(t, 28, "<<", tline, tcol); return; }
    if c == ">" && c2 == ">" { advance_tok(t); advance_tok(t); emit(t, 29, ">>", tline, tcol); return; }
    if c == "=" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, TK_EQ(), "==", tline, tcol); return; }
    if c == "!" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, TK_NEQ(), "!=", tline, tcol); return; }
    if c == "<" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, TK_LE(), "<=", tline, tcol); return; }
    if c == ">" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, TK_GE(), ">=", tline, tcol); return; }
    if c == "&" && c2 == "&" { advance_tok(t); advance_tok(t); emit(t, TK_AND(), "&&", tline, tcol); return; }
    if c == "|" && c2 == "|" { advance_tok(t); advance_tok(t); emit(t, TK_OR(), "||", tline, tcol); return; }
    if c == "+" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, 30, "+=", tline, tcol); return; }
    if c == "-" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, 31, "-=", tline, tcol); return; }
    if c == "*" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, 32, "*=", tline, tcol); return; }
    if c == "/" && c2 == "=" { advance_tok(t); advance_tok(t); emit(t, 33, "/=", tline, tcol); return; }
    if c == "-" && c2 == ">" { advance_tok(t); advance_tok(t); emit(t, TK_ARROW(), "->", tline, tcol); return; }
    if c == "=" && c2 == ">" { advance_tok(t); advance_tok(t); emit(t, TK_FAT_ARROW(), "=>", tline, tcol); return; }
    if c == ":" && c2 == ":" { advance_tok(t); advance_tok(t); emit(t, TK_COLONCOLON(), "::", tline, tcol); return; }
    if c == "." && c2 == "." { advance_tok(t); advance_tok(t); emit(t, 37, "..", tline, tcol); return; }
    advance_tok(t);
    if c == "+" { emit(t, TK_PLUS(), "+", tline, tcol); return; }
    if c == "-" { emit(t, TK_MINUS(), "-", tline, tcol); return; }
    if c == "*" { emit(t, TK_STAR(), "*", tline, tcol); return; }
    if c == "/" { emit(t, TK_SLASH(), "/", tline, tcol); return; }
    if c == "%" { emit(t, TK_PERCENT(), "%", tline, tcol); return; }
    if c == "=" { emit(t, TK_ASSIGN(), "=", tline, tcol); return; }
    if c == "<" { emit(t, TK_LT(), "<", tline, tcol); return; }
    if c == ">" { emit(t, TK_GT(), ">", tline, tcol); return; }
    if c == "!" { emit(t, TK_NOT(), "!", tline, tcol); return; }
    if c == "&" { emit(t, TK_BIT_AND(), "&", tline, tcol); return; }
    if c == "|" { emit(t, TK_BIT_OR(), "|", tline, tcol); return; }
    if c == "^" { emit(t, 27, "^", tline, tcol); return; }
    if c == "(" { emit(t, TK_LPAREN(), "(", tline, tcol); return; }
    if c == ")" { emit(t, TK_RPAREN(), ")", tline, tcol); return; }
    if c == "{" { emit(t, TK_LBRACE(), "{", tline, tcol); return; }
    if c == "}" { emit(t, TK_RBRACE(), "}", tline, tcol); return; }
    if c == "[" { emit(t, TK_LBRACK(), "[", tline, tcol); return; }
    if c == "]" { emit(t, TK_RBRACK(), "]", tline, tcol); return; }
    if c == "," { emit(t, TK_COMMA(), ",", tline, tcol); return; }
    if c == ";" { emit(t, TK_SEMI(), ";", tline, tcol); return; }
    if c == ":" { emit(t, TK_COLON(), ":", tline, tcol); return; }
    if c == "." { emit(t, TK_DOT(), ".", tline, tcol); return; }
    if c == "@" { emit(t, 50, "@", tline, tcol); return; }
    if c == "#" { emit(t, 51, "#", tline, tcol); return; }
    if c == "?" { emit(t, 52, "?", tline, tcol); return; }
}

fn tokenize(t: &mut Tok) {
    let mut go = true;
    while go {
        if t.pos >= t.ilen { go = false; }
        else {
            skip_whitespace(t);
            if t.pos >= t.ilen { go = false; }
            else {
                let c = peek_tok(t);
                let c2 = peek_at(t, 1);
                if c == "/" && c2 == "/" { skip_line_comment(t); }
                else if c == "/" && c2 == "*" { skip_block_comment(t); }
                else if c == "\"" { read_string(t); }
                else if c == "'" { read_char_lit(t); }
                else if is_digit(c) { read_number(t); }
                else if is_alpha(c) { read_ident_or_keyword(t); }
                else { read_operator(t); }
            }
        }
    }
}

// ===========================================================================
// CHECKER STATE
// ===========================================================================
// Uses string pool pattern with parallel Vec<i32> arrays for all symbol tables.

struct Checker {
    // Token stream (from tokenizer)
    pool: String,
    tk: Vec<i32>,
    ts: Vec<i32>,
    tl: Vec<i32>,
    t_lines: Vec<i32>,
    count: i32,
    pos: i32,

    // Function registry: name pool indices + arities
    fn_pool: String,
    fn_starts: Vec<i32>,
    fn_lens: Vec<i32>,
    fn_arities: Vec<i32>,
    fn_count: i32,

    // Struct registry: name + field count + field names
    st_pool: String,
    st_starts: Vec<i32>,
    st_lens: Vec<i32>,
    st_fld_offset: Vec<i32>,
    st_fld_count: Vec<i32>,
    st_count: i32,

    // Struct field pool (all fields for all structs, contiguous)
    sf_pool: String,
    sf_starts: Vec<i32>,
    sf_lens: Vec<i32>,
    sf_count: i32,

    // Enum registry: name
    en_pool: String,
    en_starts: Vec<i32>,
    en_lens: Vec<i32>,
    en_count: i32,

    // Variable scope stack
    var_pool: String,
    var_starts: Vec<i32>,
    var_lens: Vec<i32>,
    var_depths: Vec<i32>,
    var_used: Vec<i32>,
    var_lines: Vec<i32>,
    var_count: i32,
    scope_depth: i32,

    // Error/warning tracking
    err_count: i32,
    warn_count: i32,
    filename: String,
}

fn checker_new(t: &Tok, filename: String) -> Checker {
    Checker {
        pool: t.pool,
        tk: t.t_types, ts: t.t_starts, tl: t.t_lens,
        t_lines: t.t_lines,
        count: t.count,
        pos: 0,

        fn_pool: "", fn_starts: vec![], fn_lens: vec![],
        fn_arities: vec![], fn_count: 0,

        st_pool: "", st_starts: vec![], st_lens: vec![],
        st_fld_offset: vec![], st_fld_count: vec![],
        st_count: 0,

        sf_pool: "", sf_starts: vec![], sf_lens: vec![],
        sf_count: 0,

        en_pool: "", en_starts: vec![], en_lens: vec![],
        en_count: 0,

        var_pool: "", var_starts: vec![], var_lens: vec![],
        var_depths: vec![], var_used: vec![], var_lines: vec![],
        var_count: 0, scope_depth: 0,

        err_count: 0, warn_count: 0,
        filename: filename,
    }
}

// ---------------------------------------------------------------------------
// Token access helpers
// ---------------------------------------------------------------------------
fn ck_kind(c: &Checker) -> i32 {
    if c.pos >= c.count { return 0; }
    vec_get(c.tk, c.pos)
}

fn ck_kind_at(c: &Checker, off: i32) -> i32 {
    let i = c.pos + off;
    if i >= c.count { return 0; }
    vec_get(c.tk, i)
}

fn ck_text(c: &Checker) -> String {
    if c.pos >= c.count { return ""; }
    let s = vec_get(c.ts, c.pos);
    let l = vec_get(c.tl, c.pos);
    if l == 0 { return ""; }
    c.pool.substring(s, l)
}

fn ck_text_at(c: &Checker, off: i32) -> String {
    let i = c.pos + off;
    if i >= c.count { return ""; }
    let s = vec_get(c.ts, i);
    let l = vec_get(c.tl, i);
    if l == 0 { return ""; }
    c.pool.substring(s, l)
}

fn ck_line(c: &Checker) -> i32 {
    if c.pos >= c.count { return 0; }
    vec_get(c.t_lines, c.pos)
}

fn ck_line_at(c: &Checker, off: i32) -> i32 {
    let i = c.pos + off;
    if i >= c.count { return 0; }
    vec_get(c.t_lines, i)
}

fn ck_adv(c: &mut Checker) {
    if c.pos < c.count { c.pos = c.pos + 1; }
}

fn ck_at_end(c: &Checker) -> bool { c.pos >= c.count }

fn ck_expect_kind(c: &mut Checker, kind: i32) -> bool {
    if ck_kind(c) == kind { ck_adv(c); return true; }
    false
}

fn ck_expect_text(c: &mut Checker, text: String) -> bool {
    if ck_text(c) == text { ck_adv(c); return true; }
    false
}

// ---------------------------------------------------------------------------
// Error/warning reporting
// ---------------------------------------------------------------------------
fn report_error(c: &mut Checker, line: i32, msg: String) {
    println!("{}:{}: error: {}", c.filename, line, msg);
    c.err_count = c.err_count + 1;
}

fn report_warn(c: &mut Checker, line: i32, msg: String) {
    println!("{}:{}: warning: {}", c.filename, line, msg);
    c.warn_count = c.warn_count + 1;
}

// ---------------------------------------------------------------------------
// Symbol table: function registry
// ---------------------------------------------------------------------------
fn fn_find(c: &Checker, name: String) -> i32 {
    let mut i: i32 = 0;
    while i < c.fn_count {
        let s = vec_get(c.fn_starts, i);
        let l = vec_get(c.fn_lens, i);
        let n = c.fn_pool.substring(s, l);
        if n == name { return i; }
        i = i + 1;
    }
    0 - 1
}

fn fn_register(c: &mut Checker, name: String, arity: i32, line: i32) {
    let existing = fn_find(c, name);
    if existing >= 0 {
        report_error(c, line, "duplicate function definition '" + name + "'");
        return;
    }
    let s = c.fn_pool.len();
    c.fn_pool = c.fn_pool + name;
    let l = name.len();
    vec_push(c.fn_starts, s);
    vec_push(c.fn_lens, l);
    vec_push(c.fn_arities, arity);
    c.fn_count = c.fn_count + 1;
}

fn fn_get_arity(c: &Checker, idx: i32) -> i32 {
    vec_get(c.fn_arities, idx)
}

// ---------------------------------------------------------------------------
// Symbol table: struct registry
// ---------------------------------------------------------------------------
fn st_find(c: &Checker, name: String) -> i32 {
    let mut i: i32 = 0;
    while i < c.st_count {
        let s = vec_get(c.st_starts, i);
        let l = vec_get(c.st_lens, i);
        let n = c.st_pool.substring(s, l);
        if n == name { return i; }
        i = i + 1;
    }
    0 - 1
}

fn st_register(c: &mut Checker, name: String, line: i32) -> i32 {
    let existing = st_find(c, name);
    if existing >= 0 {
        report_error(c, line, "duplicate struct definition '" + name + "'");
        return existing;
    }
    let s = c.st_pool.len();
    c.st_pool = c.st_pool + name;
    let l = name.len();
    vec_push(c.st_starts, s);
    vec_push(c.st_lens, l);
    vec_push(c.st_fld_offset, c.sf_count);
    vec_push(c.st_fld_count, 0);
    let idx = c.st_count;
    c.st_count = c.st_count + 1;
    idx
}

fn st_add_field(c: &mut Checker, st_idx: i32, field_name: String) {
    let s = c.sf_pool.len();
    c.sf_pool = c.sf_pool + field_name;
    let l = field_name.len();
    vec_push(c.sf_starts, s);
    vec_push(c.sf_lens, l);
    c.sf_count = c.sf_count + 1;
    // Increment field count for this struct
    let old_count = vec_get(c.st_fld_count, st_idx);
    // Rebuild the fld_count vec with updated value
    let mut new_fld_count: Vec<i32> = vec![];
    let mut i: i32 = 0;
    while i < c.st_count {
        if i == st_idx {
            vec_push(new_fld_count, old_count + 1);
        } else {
            vec_push(new_fld_count, vec_get(c.st_fld_count, i));
        }
        i = i + 1;
    }
    c.st_fld_count = new_fld_count;
}

fn st_has_field(c: &Checker, st_idx: i32, field_name: String) -> bool {
    let offset = vec_get(c.st_fld_offset, st_idx);
    let fcount = vec_get(c.st_fld_count, st_idx);
    let mut i: i32 = 0;
    while i < fcount {
        let fi = offset + i;
        let s = vec_get(c.sf_starts, fi);
        let l = vec_get(c.sf_lens, fi);
        let n = c.sf_pool.substring(s, l);
        if n == field_name { return true; }
        i = i + 1;
    }
    false
}

// ---------------------------------------------------------------------------
// Symbol table: enum registry
// ---------------------------------------------------------------------------
fn en_find(c: &Checker, name: String) -> i32 {
    let mut i: i32 = 0;
    while i < c.en_count {
        let s = vec_get(c.en_starts, i);
        let l = vec_get(c.en_lens, i);
        let n = c.en_pool.substring(s, l);
        if n == name { return i; }
        i = i + 1;
    }
    0 - 1
}

fn en_register(c: &mut Checker, name: String, line: i32) {
    let existing = en_find(c, name);
    if existing >= 0 {
        report_error(c, line, "duplicate enum definition '" + name + "'");
        return;
    }
    let s = c.en_pool.len();
    c.en_pool = c.en_pool + name;
    let l = name.len();
    vec_push(c.en_starts, s);
    vec_push(c.en_lens, l);
    c.en_count = c.en_count + 1;
}

// ---------------------------------------------------------------------------
// Variable scope management
// ---------------------------------------------------------------------------
fn var_find(c: &Checker, name: String) -> i32 {
    // Search backwards (inner scope first)
    let mut i: i32 = c.var_count - 1;
    while i >= 0 {
        let s = vec_get(c.var_starts, i);
        let l = vec_get(c.var_lens, i);
        let n = c.var_pool.substring(s, l);
        if n == name { return i; }
        i = i - 1;
    }
    0 - 1
}

fn var_push(c: &mut Checker, name: String, line: i32) {
    let s = c.var_pool.len();
    c.var_pool = c.var_pool + name;
    let l = name.len();
    vec_push(c.var_starts, s);
    vec_push(c.var_lens, l);
    vec_push(c.var_depths, c.scope_depth);
    vec_push(c.var_used, 0);
    vec_push(c.var_lines, line);
    c.var_count = c.var_count + 1;
}

fn var_mark_used(c: &mut Checker, idx: i32) {
    // Rebuild var_used with the flag set
    let mut new_used: Vec<i32> = vec![];
    let mut i: i32 = 0;
    while i < c.var_count {
        if i == idx {
            vec_push(new_used, 1);
        } else {
            vec_push(new_used, vec_get(c.var_used, i));
        }
        i = i + 1;
    }
    c.var_used = new_used;
}

fn scope_enter(c: &mut Checker) {
    c.scope_depth = c.scope_depth + 1;
}

fn scope_exit(c: &mut Checker) {
    // Check for unused variables at this depth, then pop them
    let mut i: i32 = c.var_count - 1;
    while i >= 0 {
        let d = vec_get(c.var_depths, i);
        if d < c.scope_depth { i = 0 - 1; }
        else {
            let used = vec_get(c.var_used, i);
            if used == 0 {
                let s = vec_get(c.var_starts, i);
                let l = vec_get(c.var_lens, i);
                let name = c.var_pool.substring(s, l);
                let vline = vec_get(c.var_lines, i);
                // Don't warn about _ prefixed variables or common loop vars
                if name != "_" && name != "go" && name != "go2" && name != "go3" {
                    report_warn(c, vline, "unused variable '" + name + "'");
                }
            }
            i = i - 1;
        }
    }
    // Pop variables at this depth — find new count
    let mut new_count = c.var_count;
    let mut go = true;
    while go {
        if new_count == 0 { go = false; }
        else {
            let d = vec_get(c.var_depths, new_count - 1);
            if d >= c.scope_depth { new_count = new_count - 1; }
            else { go = false; }
        }
    }
    // Rebuild vecs truncated to new_count so future vec_push is correct
    if new_count < c.var_count {
        let mut ns: Vec<i32> = vec![];
        let mut nl: Vec<i32> = vec![];
        let mut nd: Vec<i32> = vec![];
        let mut nu: Vec<i32> = vec![];
        let mut nln: Vec<i32> = vec![];
        let mut j: i32 = 0;
        while j < new_count {
            vec_push(ns, vec_get(c.var_starts, j));
            vec_push(nl, vec_get(c.var_lens, j));
            vec_push(nd, vec_get(c.var_depths, j));
            vec_push(nu, vec_get(c.var_used, j));
            vec_push(nln, vec_get(c.var_lines, j));
            j = j + 1;
        }
        c.var_starts = ns;
        c.var_lens = nl;
        c.var_depths = nd;
        c.var_used = nu;
        c.var_lines = nln;
    }
    c.var_count = new_count;
    c.scope_depth = c.scope_depth - 1;
}

// ---------------------------------------------------------------------------
// Is this a known builtin function?
// ---------------------------------------------------------------------------
fn is_builtin_fn(name: String) -> bool {
    if name == "println" { return true; }
    if name == "print" { return true; }
    if name == "eprintln" { return true; }
    if name == "vec_push" { return true; }
    if name == "vec_get" { return true; }
    if name == "vec_len" { return true; }
    if name == "vec_set" { return true; }
    if name == "to_string_i32" { return true; }
    if name == "to_string_i64" { return true; }
    if name == "to_string_f64" { return true; }
    if name == "read_file" { return true; }
    if name == "write_file" { return true; }
    if name == "file_exists" { return true; }
    if name == "args_count" { return true; }
    if name == "args_get" { return true; }
    if name == "process_exit" { return true; }
    if name == "stdin_is_pipe" { return true; }
    if name == "read_all" { return true; }
    if name == "read_line" { return true; }
    if name == "sqrt" { return true; }
    if name == "sin" { return true; }
    if name == "cos" { return true; }
    if name == "tan" { return true; }
    if name == "abs" { return true; }
    if name == "floor" { return true; }
    if name == "ceil" { return true; }
    if name == "round" { return true; }
    if name == "pow" { return true; }
    if name == "list_dir" { return true; }
    if name == "is_dir" { return true; }
    if name == "vec_new" { return true; }
    if name == "vec_pop" { return true; }
    if name == "vec_new_str" { return true; }
    if name == "vec_push_str" { return true; }
    if name == "vec_get_str" { return true; }
    if name == "vec_len" { return true; }
    false
}

// Is this a known type name?
fn is_type_name(name: String) -> bool {
    if name == "i32" { return true; }
    if name == "i64" { return true; }
    if name == "f64" { return true; }
    if name == "bool" { return true; }
    if name == "String" { return true; }
    if name == "Vec" { return true; }
    if name == "Self" { return true; }
    false
}

// ===========================================================================
// SKIP HELPERS
// ===========================================================================
fn skip_balanced_braces(c: &mut Checker) {
    if ck_kind(c) != TK_LBRACE() { return; }
    ck_adv(c);
    let mut depth: i32 = 1;
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else if ck_kind(c) == TK_LBRACE() { depth = depth + 1; ck_adv(c); }
        else if ck_kind(c) == TK_RBRACE() {
            depth = depth - 1;
            ck_adv(c);
            if depth == 0 { go = false; }
        }
        else { ck_adv(c); }
    }
}

fn skip_balanced_parens(c: &mut Checker) {
    if ck_kind(c) != TK_LPAREN() { return; }
    ck_adv(c);
    let mut depth: i32 = 1;
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else if ck_kind(c) == TK_LPAREN() { depth = depth + 1; ck_adv(c); }
        else if ck_kind(c) == TK_RPAREN() {
            depth = depth - 1;
            ck_adv(c);
            if depth == 0 { go = false; }
        }
        else { ck_adv(c); }
    }
}

fn skip_type(c: &mut Checker) {
    // Skip &, &mut
    if ck_kind(c) == TK_BIT_AND() {
        ck_adv(c);
        if ck_text(c) == "mut" { ck_adv(c); }
    }
    // Skip type name
    if ck_kind(c) == TK_IDENT() || ck_kind(c) == TK_KEYWORD() {
        ck_adv(c);
    }
    // Skip :: path
    let mut go = true;
    while go {
        if ck_kind(c) == TK_COLONCOLON() {
            ck_adv(c);
            if ck_kind(c) == TK_IDENT() || ck_kind(c) == TK_KEYWORD() { ck_adv(c); }
        } else { go = false; }
    }
    // Skip <T> generics
    if ck_kind(c) == TK_LT() {
        ck_adv(c);
        let mut depth: i32 = 1;
        let mut go2 = true;
        while go2 {
            if ck_at_end(c) { go2 = false; }
            else if ck_kind(c) == TK_LT() { depth = depth + 1; ck_adv(c); }
            else if ck_kind(c) == TK_GT() {
                depth = depth - 1;
                ck_adv(c);
                if depth == 0 { go2 = false; }
            }
            else { ck_adv(c); }
        }
    }
}

// ===========================================================================
// PASS 1: COLLECTION
// ===========================================================================
// Scan top-level items and register function names + arities,
// struct names + fields, enum names.

fn collect_fn_params_arity(c: &mut Checker) -> i32 {
    // Count parameters between ( and )
    // Already past the opening (
    let mut arity: i32 = 0;
    let mut depth: i32 = 1;
    if ck_kind(c) == TK_RPAREN() { return 0; }
    arity = 1;
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else if ck_kind(c) == TK_RPAREN() {
            depth = depth - 1;
            if depth == 0 { go = false; }
            else { ck_adv(c); }
        }
        else if ck_kind(c) == TK_LPAREN() {
            depth = depth + 1; ck_adv(c);
        }
        else {
            if depth == 1 && ck_kind(c) == TK_COMMA() {
                arity = arity + 1;
            }
            ck_adv(c);
        }
    }
    // Check if the first "param" was &self or &mut self or self
    // Those don't count toward call arity
    arity
}

fn pass1_fn(c: &mut Checker) {
    // "fn" already consumed. Next is the function name.
    let line = ck_line(c);
    let name = ck_text(c);
    ck_adv(c); // skip name
    // Count params
    if ck_kind(c) == TK_LPAREN() {
        ck_adv(c); // skip (
        let arity = collect_fn_params_arity(c);
        ck_expect_kind(c, TK_RPAREN());
        fn_register(c, name, arity, line);
    }
    // Skip return type
    if ck_kind(c) == TK_ARROW() {
        ck_adv(c);
        skip_type(c);
    }
    // Skip body
    if ck_kind(c) == TK_LBRACE() {
        skip_balanced_braces(c);
    }
}

fn pass1_struct(c: &mut Checker) {
    // "struct" already consumed
    let line = ck_line(c);
    let name = ck_text(c);
    ck_adv(c);
    let st_idx = st_register(c, name, line);
    // Parse fields
    if ck_kind(c) == TK_LBRACE() {
        ck_adv(c);
        let mut go = true;
        while go {
            if ck_at_end(c) || ck_kind(c) == TK_RBRACE() { go = false; }
            else {
                let fname = ck_text(c);
                ck_adv(c); // skip field name
                ck_expect_kind(c, TK_COLON()); // skip :
                skip_type(c); // skip type
                st_add_field(c, st_idx, fname);
                if ck_kind(c) == TK_COMMA() { ck_adv(c); }
            }
        }
        ck_expect_kind(c, TK_RBRACE());
    }
}

fn pass1_enum(c: &mut Checker) {
    // "enum" already consumed
    let line = ck_line(c);
    let name = ck_text(c);
    ck_adv(c);
    en_register(c, name, line);
    // Skip body
    if ck_kind(c) == TK_LBRACE() {
        skip_balanced_braces(c);
    }
}

fn pass1_impl(c: &mut Checker) {
    // "impl" already consumed
    // Skip type name
    skip_type(c);
    // Parse methods inside { }
    if ck_kind(c) == TK_LBRACE() {
        ck_adv(c);
        let mut go = true;
        while go {
            if ck_at_end(c) || ck_kind(c) == TK_RBRACE() { go = false; }
            else {
                if ck_text(c) == "pub" { ck_adv(c); }
                if ck_text(c) == "fn" {
                    ck_adv(c);
                    pass1_fn(c);
                } else {
                    ck_adv(c);
                }
            }
        }
        ck_expect_kind(c, TK_RBRACE());
    }
}

fn pass1_item(c: &mut Checker) {
    let k = ck_kind(c);
    let txt = ck_text(c);

    // Skip "pub"
    if k == TK_KEYWORD() && txt == "pub" {
        ck_adv(c);
        let k2 = ck_kind(c);
        let txt2 = ck_text(c);
        if k2 == TK_KEYWORD() && txt2 == "fn" { ck_adv(c); pass1_fn(c); return; }
        if k2 == TK_KEYWORD() && txt2 == "struct" { ck_adv(c); pass1_struct(c); return; }
        if k2 == TK_KEYWORD() && txt2 == "enum" { ck_adv(c); pass1_enum(c); return; }
        if k2 == TK_KEYWORD() && txt2 == "trait" {
            ck_adv(c); ck_adv(c); // skip "trait" + name
            if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
            return;
        }
        // Skip other pub items
        if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
        else {
            let mut go = true;
            while go {
                if ck_at_end(c) || ck_kind(c) == TK_SEMI() { go = false; }
                else { ck_adv(c); }
            }
            if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        }
        return;
    }

    if k == TK_KEYWORD() && txt == "fn" { ck_adv(c); pass1_fn(c); return; }
    if k == TK_KEYWORD() && txt == "struct" { ck_adv(c); pass1_struct(c); return; }
    if k == TK_KEYWORD() && txt == "enum" { ck_adv(c); pass1_enum(c); return; }
    if k == TK_KEYWORD() && txt == "impl" { ck_adv(c); pass1_impl(c); return; }
    if k == TK_KEYWORD() && txt == "trait" {
        ck_adv(c); ck_adv(c);
        if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
        return;
    }
    if k == TK_KEYWORD() && txt == "mod" {
        ck_adv(c); ck_adv(c); // skip "mod" + name
        if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
        else if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        return;
    }
    if k == TK_KEYWORD() && (txt == "use" || txt == "const" || txt == "type") {
        // Skip to semicolon
        let mut go = true;
        while go {
            if ck_at_end(c) || ck_kind(c) == TK_SEMI() { go = false; }
            else { ck_adv(c); }
        }
        if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        return;
    }
    // Attribute: #[...]
    if k == 51 {
        ck_adv(c);
        if ck_kind(c) == TK_LBRACK() {
            ck_adv(c);
            let mut go = true;
            while go {
                if ck_at_end(c) || ck_kind(c) == TK_RBRACK() { go = false; }
                else { ck_adv(c); }
            }
            ck_expect_kind(c, TK_RBRACK());
        }
        return;
    }
    // Unknown: skip
    if !ck_at_end(c) { ck_adv(c); }
}

fn pass1(c: &mut Checker) {
    c.pos = 0;
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else { pass1_item(c); }
    }
}

// ===========================================================================
// PASS 2: CHECKING
// ===========================================================================
// Walk function bodies, track variables, check calls, etc.

// Determine the "type category" of the current expression start token.
// Returns: "i32", "i64", "f64", "bool", "String", "char", or ""
fn infer_lit_type(c: &Checker) -> String {
    let k = ck_kind(c);
    if k == TK_INT_LIT() { return "i64"; }
    if k == TK_FLOAT_LIT() { return "f64"; }
    if k == TK_STR_LIT() { return "String"; }
    if k == TK_CHAR_LIT() { return "char"; }
    if k == TK_KEYWORD() {
        let txt = ck_text(c);
        if txt == "true" || txt == "false" { return "bool"; }
    }
    ""
}

// Check if two type categories are compatible
fn types_compatible(annotation: String, literal: String) -> bool {
    if annotation == "" || literal == "" { return true; }
    // i32 and i64 are compatible with integer literals
    if literal == "i64" {
        if annotation == "i32" || annotation == "i64" { return true; }
    }
    if annotation == literal { return true; }
    false
}

// Skip an expression (rough: handles nested parens/braces/brackets)
fn skip_expr(c: &mut Checker) {
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else {
            let k = ck_kind(c);
            if k == TK_SEMI() || k == TK_RBRACE() || k == TK_COMMA() {
                go = false;
            }
            else if k == TK_LPAREN() { skip_balanced_parens(c); }
            else if k == TK_LBRACE() { skip_balanced_braces(c); }
            else if k == TK_LBRACK() {
                ck_adv(c);
                let mut d: i32 = 1;
                let mut go2 = true;
                while go2 {
                    if ck_at_end(c) { go2 = false; }
                    else if ck_kind(c) == TK_LBRACK() { d = d + 1; ck_adv(c); }
                    else if ck_kind(c) == TK_RBRACK() {
                        d = d - 1; ck_adv(c);
                        if d == 0 { go2 = false; }
                    }
                    else { ck_adv(c); }
                }
            }
            else { ck_adv(c); }
        }
    }
}

// Skip a postfix chain: .field, .method(), (), [idx], ::Path
fn skip_postfix(c: &mut Checker) {
    let mut go = true;
    while go {
        if ck_kind(c) == TK_DOT() {
            ck_adv(c); // skip .
            // Skip field/method name
            if ck_kind(c) == TK_IDENT() || ck_kind(c) == TK_KEYWORD() {
                ck_adv(c);
            }
            // If followed by ( — method call, skip args
            if ck_kind(c) == TK_LPAREN() {
                skip_balanced_parens(c);
            }
        }
        else if ck_kind(c) == TK_LPAREN() {
            skip_balanced_parens(c);
        }
        else if ck_kind(c) == TK_LBRACK() {
            ck_adv(c);
            let mut d: i32 = 1;
            let mut go2 = true;
            while go2 {
                if ck_at_end(c) { go2 = false; }
                else if ck_kind(c) == TK_LBRACK() { d = d + 1; ck_adv(c); }
                else if ck_kind(c) == TK_RBRACK() {
                    d = d - 1; ck_adv(c);
                    if d == 0 { go2 = false; }
                }
                else { ck_adv(c); }
            }
        }
        else if ck_kind(c) == TK_COLONCOLON() {
            ck_adv(c);
            if ck_kind(c) == TK_IDENT() || ck_kind(c) == TK_KEYWORD() { ck_adv(c); }
        }
        else if ck_kind(c) == TK_NOT() {
            // Macro call: name!( or name![
            ck_adv(c);
            if ck_kind(c) == TK_LPAREN() {
                skip_balanced_parens(c);
            } else if ck_kind(c) == TK_LBRACK() {
                ck_adv(c);
                let mut d: i32 = 1;
                let mut go2 = true;
                while go2 {
                    if ck_at_end(c) { go2 = false; }
                    else if ck_kind(c) == TK_LBRACK() { d = d + 1; ck_adv(c); }
                    else if ck_kind(c) == TK_RBRACK() {
                        d = d - 1; ck_adv(c);
                        if d == 0 { go2 = false; }
                    }
                    else { ck_adv(c); }
                }
            }
        }
        else { go = false; }
    }
}

// Check an expression for variable references and function calls
fn check_expr(c: &mut Checker) {
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else {
            let k = ck_kind(c);
            // Stop at statement/block boundaries
            if k == TK_SEMI() || k == TK_RBRACE() || k == TK_LBRACE() {
                go = false;
            }
            // Stop at assignment operators — caller handles them
            else if k == TK_ASSIGN() || k == 30 || k == 31 || k == 32 || k == 33 {
                go = false;
            }
            else if k == TK_IDENT() {
                let name = ck_text(c);
                let line = ck_line(c);
                ck_adv(c);

                // Handle postfix chain first: check what follows
                // If DOT follows, this is the start of an expr like obj.method()
                // We check 'name' as a variable, then skip the postfix chain.
                if ck_kind(c) == TK_DOT() {
                    // Variable reference with field/method access
                    let var_idx = var_find(c, name);
                    if var_idx >= 0 {
                        var_mark_used(c, var_idx);
                    } else {
                        // Could be a type or struct name
                        let fn_idx = fn_find(c, name);
                        let st_idx = st_find(c, name);
                        let en_idx = en_find(c, name);
                        if fn_idx < 0 && st_idx < 0 && en_idx < 0 &&
                           !is_builtin_fn(name) && !is_type_name(name) &&
                           name != "self" && name != "Self" {
                            report_error(c, line, "undefined variable '" + name + "'");
                        }
                    }
                    skip_postfix(c);
                }
                else if ck_kind(c) == TK_COLONCOLON() {
                    // Path expression: Type::Variant or mod::func
                    skip_postfix(c);
                }
                else if ck_kind(c) == TK_LPAREN() {
                    // Function call — check arity
                    let fn_idx = fn_find(c, name);
                    if fn_idx < 0 && !is_builtin_fn(name) {
                        // Could be a type constructor
                        let st_idx = st_find(c, name);
                        let en_idx = en_find(c, name);
                        if st_idx < 0 && en_idx < 0 && !is_type_name(name) {
                            report_error(c, line, "undefined function '" + name + "'");
                        }
                        skip_balanced_parens(c);
                    } else if fn_idx >= 0 {
                        // Count call arguments
                        ck_adv(c); // skip (
                        let mut arg_count: i32 = 0;
                        if ck_kind(c) != TK_RPAREN() {
                            arg_count = 1;
                            let mut depth: i32 = 1;
                            let mut go2 = true;
                            while go2 {
                                if ck_at_end(c) { go2 = false; }
                                else if ck_kind(c) == TK_LPAREN() {
                                    depth = depth + 1; ck_adv(c);
                                }
                                else if ck_kind(c) == TK_RPAREN() {
                                    depth = depth - 1;
                                    if depth == 0 { go2 = false; }
                                    else { ck_adv(c); }
                                }
                                else {
                                    if depth == 1 && ck_kind(c) == TK_COMMA() {
                                        arg_count = arg_count + 1;
                                    }
                                    ck_adv(c);
                                }
                            }
                        }
                        ck_expect_kind(c, TK_RPAREN());
                        let expected = fn_get_arity(c, fn_idx);
                        if arg_count != expected {
                            report_error(c, line,
                                "function '" + name + "' expects " +
                                to_string_i32(expected) + " arguments, got " +
                                to_string_i32(arg_count));
                        }
                        skip_postfix(c);
                    } else {
                        // Builtin — skip args
                        skip_balanced_parens(c);
                        skip_postfix(c);
                    }
                }
                else if ck_kind(c) == TK_NOT() {
                    // Macro call: name!( or name![
                    // Mark variables inside macro args as used
                    ck_adv(c); // skip !
                    if ck_kind(c) == TK_LPAREN() {
                        ck_adv(c); // skip (
                        // Walk args and mark idents as used
                        let mut depth: i32 = 1;
                        let mut go2 = true;
                        while go2 {
                            if ck_at_end(c) { go2 = false; }
                            else if ck_kind(c) == TK_LPAREN() { depth = depth + 1; ck_adv(c); }
                            else if ck_kind(c) == TK_RPAREN() {
                                depth = depth - 1;
                                if depth == 0 { ck_adv(c); go2 = false; }
                                else { ck_adv(c); }
                            }
                            else if ck_kind(c) == TK_IDENT() {
                                let mname = ck_text(c);
                                let mvar = var_find(c, mname);
                                if mvar >= 0 { var_mark_used(c, mvar); }
                                ck_adv(c);
                            }
                            else { ck_adv(c); }
                        }
                    } else if ck_kind(c) == TK_LBRACK() {
                        ck_adv(c);
                        let mut d: i32 = 1;
                        let mut go2 = true;
                        while go2 {
                            if ck_at_end(c) { go2 = false; }
                            else if ck_kind(c) == TK_LBRACK() { d = d + 1; ck_adv(c); }
                            else if ck_kind(c) == TK_RBRACK() {
                                d = d - 1; ck_adv(c);
                                if d == 0 { go2 = false; }
                            }
                            else { ck_adv(c); }
                        }
                    }
                    skip_postfix(c);
                }
                else if ck_kind(c) == TK_LBRACE() {
                    // Struct literal: Name { field: val, ... }
                    // Check if name is a known struct
                    let st_idx = st_find(c, name);
                    if st_idx < 0 {
                        // Could be a variable being used before a block
                        let var_idx = var_find(c, name);
                        if var_idx >= 0 { var_mark_used(c, var_idx); }
                    }
                    skip_balanced_braces(c);
                }
                else {
                    // Variable reference — check if defined
                    let var_idx = var_find(c, name);
                    if var_idx >= 0 {
                        var_mark_used(c, var_idx);
                    } else {
                        // Not a variable — could be a type, struct name, enum, etc.
                        let fn_idx2 = fn_find(c, name);
                        let st_idx2 = st_find(c, name);
                        let en_idx2 = en_find(c, name);
                        if fn_idx2 < 0 && st_idx2 < 0 && en_idx2 < 0 &&
                           !is_builtin_fn(name) && !is_type_name(name) &&
                           name != "self" && name != "Self" &&
                           name != "vec" {
                            report_error(c, line, "undefined variable '" + name + "'");
                        }
                    }
                    skip_postfix(c);
                }
            }
            else if k == TK_KEYWORD() {
                let txt = ck_text(c);
                if txt == "self" || txt == "true" || txt == "false" {
                    ck_adv(c);
                    skip_postfix(c);
                }
                else if txt == "if" {
                    // Inline if expression — skip it carefully
                    ck_adv(c); // skip "if"
                    check_expr(c); // check condition
                    if ck_kind(c) == TK_LBRACE() {
                        scope_enter(c);
                        ck_adv(c);
                        check_block_inner(c);
                        ck_expect_kind(c, TK_RBRACE());
                        scope_exit(c);
                    }
                    if ck_text(c) == "else" {
                        ck_adv(c);
                        if ck_text(c) == "if" {
                            // else if — recurse
                            ck_adv(c);
                            check_expr(c);
                            if ck_kind(c) == TK_LBRACE() {
                                scope_enter(c);
                                ck_adv(c);
                                check_block_inner(c);
                                ck_expect_kind(c, TK_RBRACE());
                                scope_exit(c);
                            }
                        }
                        if ck_kind(c) == TK_LBRACE() {
                            scope_enter(c);
                            ck_adv(c);
                            check_block_inner(c);
                            ck_expect_kind(c, TK_RBRACE());
                            scope_exit(c);
                        }
                    }
                    go = false;
                }
                else if txt == "mut" || txt == "as" {
                    // Skip keywords that appear in expressions
                    ck_adv(c);
                }
                else {
                    ck_adv(c);
                }
            }
            else if k == TK_LPAREN() {
                ck_adv(c);
                check_expr(c);
                ck_expect_kind(c, TK_RPAREN());
                skip_postfix(c);
            }
            else {
                ck_adv(c);
            }
        }
    }
}

// Check statements inside a block (between { and })
fn check_block_inner(c: &mut Checker) {
    let mut go = true;
    while go {
        if ck_at_end(c) || ck_kind(c) == TK_RBRACE() { go = false; }
        else { check_statement(c); }
    }
}

fn check_block(c: &mut Checker) {
    if ck_kind(c) != TK_LBRACE() { return; }
    ck_adv(c);
    scope_enter(c);
    check_block_inner(c);
    scope_exit(c);
    ck_expect_kind(c, TK_RBRACE());
}

fn check_statement(c: &mut Checker) {
    let k = ck_kind(c);
    let txt = ck_text(c);

    // Let binding
    if k == TK_KEYWORD() && txt == "let" {
        let let_line = ck_line(c);
        ck_adv(c); // skip "let"
        if ck_text(c) == "mut" { ck_adv(c); }
        let name = ck_text(c);
        let name_line = ck_line(c);
        ck_adv(c); // skip name

        // Optional type annotation
        let mut annotation = "";
        if ck_kind(c) == TK_COLON() {
            ck_adv(c);
            annotation = ck_text(c);
            skip_type(c);
        }

        // = initializer
        if ck_kind(c) == TK_ASSIGN() {
            ck_adv(c);
            // Check type mismatch with literal
            let lit_type = infer_lit_type(c);
            if annotation != "" && lit_type != "" {
                if !types_compatible(annotation, lit_type) {
                    report_error(c, let_line,
                        "type mismatch: variable '" + name +
                        "' declared as '" + annotation +
                        "' but initialized with " + lit_type + " literal");
                }
            }
            check_expr(c);
        }
        if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        var_push(c, name, name_line);
        return;
    }

    // If statement
    if k == TK_KEYWORD() && txt == "if" {
        ck_adv(c);
        check_expr(c);
        check_block(c);
        let mut go = true;
        while go {
            if ck_text(c) == "else" {
                ck_adv(c);
                if ck_text(c) == "if" {
                    ck_adv(c);
                    check_expr(c);
                    check_block(c);
                } else {
                    check_block(c);
                    go = false;
                }
            } else { go = false; }
        }
        return;
    }

    // While loop
    if k == TK_KEYWORD() && txt == "while" {
        ck_adv(c);
        check_expr(c);
        check_block(c);
        return;
    }

    // For loop
    if k == TK_KEYWORD() && txt == "for" {
        ck_adv(c);
        let var_name = ck_text(c);
        let var_line = ck_line(c);
        ck_adv(c);
        ck_expect_text(c, "in");
        check_expr(c);
        // The loop var is declared in the block scope
        if ck_kind(c) == TK_LBRACE() {
            ck_adv(c);
            scope_enter(c);
            var_push(c, var_name, var_line);
            check_block_inner(c);
            scope_exit(c);
            ck_expect_kind(c, TK_RBRACE());
        }
        return;
    }

    // Loop
    if k == TK_KEYWORD() && txt == "loop" {
        ck_adv(c);
        check_block(c);
        return;
    }

    // Match
    if k == TK_KEYWORD() && txt == "match" {
        ck_adv(c);
        check_expr(c);
        // Skip entire match block
        if ck_kind(c) == TK_LBRACE() {
            skip_balanced_braces(c);
        }
        return;
    }

    // Return
    if k == TK_KEYWORD() && txt == "return" {
        ck_adv(c);
        if ck_kind(c) != TK_SEMI() {
            check_expr(c);
        }
        if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        return;
    }

    // Break / Continue
    if k == TK_KEYWORD() && (txt == "break" || txt == "continue") {
        ck_adv(c);
        if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        return;
    }

    // Expression statement
    check_expr(c);
    // Assignment operators
    let ak = ck_kind(c);
    if ak == TK_ASSIGN() || ak == 30 || ak == 31 || ak == 32 || ak == 33 {
        ck_adv(c);
        check_expr(c);
    }
    if ck_kind(c) == TK_SEMI() { ck_adv(c); }
}

// Check function parameters — register them as variables
fn check_fn_params(c: &mut Checker) {
    // Already past (
    let mut go = true;
    while go {
        if ck_at_end(c) || ck_kind(c) == TK_RPAREN() { go = false; }
        else {
            // Handle &self, &mut self, self
            if ck_kind(c) == TK_BIT_AND() {
                ck_adv(c);
                if ck_text(c) == "mut" { ck_adv(c); }
                if ck_text(c) == "self" {
                    var_push(c, "self", ck_line(c));
                    var_mark_used(c, c.var_count - 1);
                    ck_adv(c);
                } else {
                    let pname = ck_text(c);
                    let pline = ck_line(c);
                    ck_adv(c);
                    ck_expect_kind(c, TK_COLON());
                    skip_type(c);
                    var_push(c, pname, pline);
                    var_mark_used(c, c.var_count - 1);
                }
            } else if ck_text(c) == "mut" {
                ck_adv(c);
                let pname = ck_text(c);
                let pline = ck_line(c);
                ck_adv(c);
                ck_expect_kind(c, TK_COLON());
                skip_type(c);
                var_push(c, pname, pline);
                var_mark_used(c, c.var_count - 1);
            } else if ck_text(c) == "self" {
                var_push(c, "self", ck_line(c));
                var_mark_used(c, c.var_count - 1);
                ck_adv(c);
            } else {
                let pname = ck_text(c);
                let pline = ck_line(c);
                ck_adv(c);
                ck_expect_kind(c, TK_COLON());
                skip_type(c);
                var_push(c, pname, pline);
                // Mark params as used to avoid noisy warnings
                var_mark_used(c, c.var_count - 1);
            }
            if ck_kind(c) == TK_COMMA() { ck_adv(c); }
            else { go = false; }
        }
    }
}

fn pass2_fn(c: &mut Checker) {
    // "fn" already consumed. Next is the function name.
    ck_adv(c); // skip name
    // Reset variable state for this function
    c.var_pool = "";
    c.var_starts = vec![];
    c.var_lens = vec![];
    c.var_depths = vec![];
    c.var_used = vec![];
    c.var_lines = vec![];
    c.var_count = 0;
    c.scope_depth = 0;
    scope_enter(c);
    // Parse params
    if ck_kind(c) == TK_LPAREN() {
        ck_adv(c);
        check_fn_params(c);
        ck_expect_kind(c, TK_RPAREN());
    }
    // Skip return type
    if ck_kind(c) == TK_ARROW() {
        ck_adv(c);
        skip_type(c);
    }
    // Check body
    if ck_kind(c) == TK_LBRACE() {
        ck_adv(c);
        check_block_inner(c);
        ck_expect_kind(c, TK_RBRACE());
    }
    scope_exit(c);
}

fn pass2_impl(c: &mut Checker) {
    // "impl" already consumed
    skip_type(c);
    if ck_kind(c) == TK_LBRACE() {
        ck_adv(c);
        let mut go = true;
        while go {
            if ck_at_end(c) || ck_kind(c) == TK_RBRACE() { go = false; }
            else {
                if ck_text(c) == "pub" { ck_adv(c); }
                if ck_text(c) == "fn" {
                    ck_adv(c);
                    pass2_fn(c);
                } else {
                    ck_adv(c);
                }
            }
        }
        ck_expect_kind(c, TK_RBRACE());
    }
}

fn pass2_item(c: &mut Checker) {
    let k = ck_kind(c);
    let txt = ck_text(c);

    // Skip "pub"
    if k == TK_KEYWORD() && txt == "pub" {
        ck_adv(c);
        let k2 = ck_kind(c);
        let txt2 = ck_text(c);
        if k2 == TK_KEYWORD() && txt2 == "fn" { ck_adv(c); pass2_fn(c); return; }
        if k2 == TK_KEYWORD() && txt2 == "struct" {
            ck_adv(c); ck_adv(c);
            if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
            return;
        }
        if k2 == TK_KEYWORD() && txt2 == "enum" {
            ck_adv(c); ck_adv(c);
            if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
            return;
        }
        if k2 == TK_KEYWORD() && txt2 == "trait" {
            ck_adv(c); ck_adv(c);
            if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
            return;
        }
        if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
        else {
            let mut go = true;
            while go {
                if ck_at_end(c) || ck_kind(c) == TK_SEMI() { go = false; }
                else { ck_adv(c); }
            }
            if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        }
        return;
    }

    if k == TK_KEYWORD() && txt == "fn" { ck_adv(c); pass2_fn(c); return; }
    if k == TK_KEYWORD() && txt == "impl" { ck_adv(c); pass2_impl(c); return; }

    // Struct, enum, trait, mod — just skip (already collected in pass 1)
    if k == TK_KEYWORD() && (txt == "struct" || txt == "enum" || txt == "trait") {
        ck_adv(c); ck_adv(c);
        if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
        return;
    }
    if k == TK_KEYWORD() && txt == "mod" {
        ck_adv(c); ck_adv(c);
        if ck_kind(c) == TK_LBRACE() { skip_balanced_braces(c); }
        else if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        return;
    }
    if k == TK_KEYWORD() && (txt == "use" || txt == "const" || txt == "type") {
        let mut go = true;
        while go {
            if ck_at_end(c) || ck_kind(c) == TK_SEMI() { go = false; }
            else { ck_adv(c); }
        }
        if ck_kind(c) == TK_SEMI() { ck_adv(c); }
        return;
    }
    // Attribute
    if k == 51 {
        ck_adv(c);
        if ck_kind(c) == TK_LBRACK() {
            ck_adv(c);
            let mut go = true;
            while go {
                if ck_at_end(c) || ck_kind(c) == TK_RBRACK() { go = false; }
                else { ck_adv(c); }
            }
            ck_expect_kind(c, TK_RBRACK());
        }
        return;
    }
    if !ck_at_end(c) { ck_adv(c); }
}

fn pass2(c: &mut Checker) {
    c.pos = 0;
    let mut go = true;
    while go {
        if ck_at_end(c) { go = false; }
        else { pass2_item(c); }
    }
}

// ===========================================================================
// CHECK A SINGLE FILE
// ===========================================================================
fn check_file(filename: String) -> i32 {
    let exists = file_exists(filename);
    if !exists {
        println!("qcheck: {}: No such file or directory", filename);
        return 1;
    }
    let input = read_file(filename);
    if input.len() == 0 { return 0; }

    // Tokenize
    let mut t = tok_new(input);
    tokenize(&mut t);

    // Create checker
    let mut c = checker_new(&t, filename);

    // Pass 1: collect declarations
    pass1(&mut c);

    // Pass 2: check function bodies
    pass2(&mut c);

    // Summary
    if c.err_count == 0 && c.warn_count == 0 {
        println!("{}: no errors found.", filename);
    } else {
        let mut summary = "";
        if c.err_count > 0 {
            summary = to_string_i32(c.err_count) + " error";
            if c.err_count > 1 { summary = summary + "s"; }
        }
        if c.warn_count > 0 {
            if summary != "" { summary = summary + ", "; }
            summary = summary + to_string_i32(c.warn_count) + " warning";
            if c.warn_count > 1 { summary = summary + "s"; }
        }
        println!("{}", summary);
    }
    c.err_count
}

// ===========================================================================
// RECURSIVE DIRECTORY CHECKING
// ===========================================================================
fn is_quanta_file(name: String) -> bool {
    name.ends_with(".quanta")
}

fn should_skip_dir(name: String) -> bool {
    if name == ".git" { return true; }
    if name == "node_modules" { return true; }
    if name == "target" { return true; }
    if name == "__pycache__" { return true; }
    if name == "build" { return true; }
    if name == "dist" { return true; }
    false
}

fn check_dir_recursive(dirpath: String) -> i32 {
    let dir_stack = vec_new_str();
    vec_push_str(dir_stack, dirpath);
    let mut total_errors: i32 = 0;

    let mut stack_done = false;
    while !stack_done {
        let slen = vec_len(dir_stack);
        if slen == 0 {
            stack_done = true;
        } else {
            let cur = vec_get_str(dir_stack, slen - 1);
            vec_pop(dir_stack);

            let entries = list_dir(cur);
            let n = vec_len(entries);
            let mut ei: i64 = 0;

            while ei < n {
                let name = vec_get_str(entries, ei);
                if name.starts_with(".") {
                    ei = ei + 1;
                } else {
                    let full = cur + "/" + name;
                    let isdir = is_dir(full);
                    if isdir {
                        if !should_skip_dir(name) {
                            vec_push_str(dir_stack, full);
                        }
                    } else {
                        if is_quanta_file(name) {
                            let errs = check_file(full);
                            total_errors = total_errors + errs;
                        }
                    }
                    ei = ei + 1;
                }
            }
        }
    }
    total_errors
}

// ===========================================================================
// HELP
// ===========================================================================
fn print_help() {
    println!("qcheck - QuantaLang type checker (self-hosting tool #5)");
    println!("");
    println!("Usage:");
    println!("  qcheck FILE              check a single .quanta file");
    println!("  qcheck -r DIR            check all .quanta files recursively");
    println!("  qcheck --help            display this help and exit");
    println!("");
    println!("Checks:");
    println!("  - Undefined variable usage");
    println!("  - Undefined function calls");
    println!("  - Function call arity mismatches");
    println!("  - Duplicate function/struct/enum definitions");
    println!("  - Unused variables (warnings)");
    println!("  - Type annotation vs literal mismatches");
}

// ===========================================================================
// MAIN
// ===========================================================================
fn main() {
    let nargs = args_count();

    if nargs < 2 {
        print_help();
        process_exit(0);
    }

    let first = args_get(1);
    if first == "--help" || first == "-h" {
        print_help();
        process_exit(0);
    }

    if first == "-r" || first == "--recursive" {
        if nargs < 3 {
            println!("qcheck: -r requires a directory argument");
            process_exit(2);
        }
        let dir = args_get(2);
        let errs = check_dir_recursive(dir);
        if errs > 0 { process_exit(1); }
        process_exit(0);
    }

    // Check each file argument
    let mut total_errors: i32 = 0;
    let mut i: i32 = 1;
    while i < nargs {
        let arg = args_get(i);
        if arg.starts_with("-") {
            println!("qcheck: unknown option '{}'", arg);
            process_exit(2);
        }
        let errs = check_file(arg);
        total_errors = total_errors + errs;
        i = i + 1;
    }
    if total_errors > 0 { process_exit(1); }
}
