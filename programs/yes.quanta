// =============================================================================
// qyes — Repeatedly output a line (GNU yes clone) in QuantaLang
// =============================================================================
// Usage:
//   qyes                 print "y" repeatedly (1000 times max)
//   qyes hello           print "hello" repeatedly
//   qyes -n 10           print "y" 10 times then stop
//   qyes hello -n 5      print "hello" 5 times
//   qyes --help          usage
//
// Without -n, defaults to 1000 iterations to avoid infinite loops in testing.
// =============================================================================

fn print_help() {
    println!("qyes -- output a string repeatedly until killed");
    println!("");
    println!("Usage:");
    println!("  qyes [OPTION]... [STRING]");
    println!("");
    println!("Options:");
    println!("  -n COUNT   stop after COUNT lines (default: 1000)");
    println!("  --help     display this help and exit");
    println!("");
    println!("Repeatedly output STRING (default: 'y'), one per line.");
    println!("Without -n, prints 1000 times.");
}

fn main() {
    let nargs = args_count();

    let mut text = "y";
    let mut limit: i64 = 1000;
    let mut has_text = false;

    // Parse arguments
    let mut i: i64 = 1;
    while i < nargs {
        let arg = args_get(i);

        if arg == "--help" || arg == "-h" {
            print_help();
            process_exit(0);
        } else if arg == "-n" {
            i = i + 1;
            if i < nargs {
                let narg = args_get(i);
                limit = narg.parse_int();
                if limit < 0 {
                    limit = 0;
                }
            }
        } else if arg.starts_with("-n") {
            // -n10 form
            let alen = arg.len();
            let narg = arg.substring(2, alen - 2);
            limit = narg.parse_int();
            if limit < 0 {
                limit = 0;
            }
        } else if arg.starts_with("-") {
            // Unknown flag — ignore
            println!("qyes: unknown option '{}'", arg);
            process_exit(1);
        } else {
            // Positional: the string to repeat
            if !has_text {
                text = arg;
                has_text = true;
            }
        }

        i = i + 1;
    }

    // Output the string `limit` times
    let mut count: i64 = 0;
    while count < limit {
        println!("{}", text);
        count = count + 1;
    }
}
