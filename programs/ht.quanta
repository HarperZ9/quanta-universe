// =============================================================================
// qht - Head/Tail utility (combined head+tail) written in QuantaLang
// =============================================================================
// Usage:
//   qht file.txt              print first 10 lines (default)
//   qht -n 5 file.txt         first 5 lines
//   qht -t 3 file.txt         last 3 lines
//   qht -n 5 -t 3 file.txt   first 5 then last 3
//   cat file.txt | qht -n 20  from stdin
//   qht --help                usage
//
// Design: Parse input into a Vec of line-start/len pairs via char_at scanning.
// For head, print the first N. For tail, print the last N from the vec.
// =============================================================================

// --- Split input into lines, storing start/len pairs ---
// Returns the number of lines found.
// Line starts and lengths are pushed into parallel vecs.
fn split_lines(input: String, starts: Vec<i32>, lens: Vec<i32>) -> i64 {
    let ilen = input.len();
    let mut pos = 0;
    let mut line_start = 0;
    let mut count: i64 = 0;
    let mut go = true;

    while go {
        if pos >= ilen {
            // Last segment (no trailing newline)
            let ln = pos - line_start;
            if ln > 0 {
                vec_push(starts, line_start);
                vec_push(lens, ln);
                count = count + 1;
            }
            go = false;
        } else {
            let c = input.char_at(pos);
            if c == "\n" {
                let mut ln = pos - line_start;
                // Strip trailing \r
                if ln > 0 {
                    let last_pos = line_start + ln - 1;
                    let lc = input.char_at(last_pos);
                    if lc == "\r" { ln = ln - 1; }
                }
                vec_push(starts, line_start);
                vec_push(lens, ln);
                count = count + 1;
                line_start = pos + 1;
                pos = pos + 1;
            } else {
                pos = pos + 1;
            }
        }
    }

    count
}

// --- Print lines from index `from` to `to` (exclusive) ---
fn print_range(input: String, starts: Vec<i32>, lens: Vec<i32>,
               from: i64, to: i64) {
    let mut i = from;
    while i < to {
        let st = vec_get(starts, i);
        let ln = vec_get(lens, i);
        let line = input.substring(st, ln);
        println!("{}", line);
        i = i + 1;
    }
}

// --- Help ---
fn print_help() {
    println!("qht - combined head/tail utility");
    println!("");
    println!("Usage:");
    println!("  qht [OPTION]... [FILE]");
    println!("");
    println!("Options:");
    println!("  -n N    print first N lines (default 10)");
    println!("  -t N    print last N lines");
    println!("  --help  display this help and exit");
    println!("");
    println!("With no FILE, read standard input.");
    println!("With no flags, prints the first 10 lines (head mode).");
    println!("If both -n and -t are given, prints head then tail.");
}

// --- Parse a numeric string to i64 manually ---
fn parse_num(s: String) -> i64 {
    let slen = s.len();
    let mut val: i64 = 0;
    let mut i = 0;
    while i < slen {
        let c = s.char_at(i);
        if c == "0" { val = val * 10; }
        if c == "1" { val = val * 10 + 1; }
        if c == "2" { val = val * 10 + 2; }
        if c == "3" { val = val * 10 + 3; }
        if c == "4" { val = val * 10 + 4; }
        if c == "5" { val = val * 10 + 5; }
        if c == "6" { val = val * 10 + 6; }
        if c == "7" { val = val * 10 + 7; }
        if c == "8" { val = val * 10 + 8; }
        if c == "9" { val = val * 10 + 9; }
        i = i + 1;
    }
    val
}

// --- Main ---
fn main() {
    let nargs = args_count();

    // Parse flags
    let mut head_n: i64 = -1;  // -1 means "not set"
    let mut tail_n: i64 = -1;
    let mut filename = "";
    let mut has_file = false;
    let mut expect_n = false;   // next arg is the N for -n
    let mut expect_t = false;   // next arg is the N for -t

    let mut i: i64 = 1;
    while i < nargs {
        let arg = args_get(i);

        if expect_n {
            head_n = parse_num(arg);
            expect_n = false;
            i = i + 1;
        } else if expect_t {
            tail_n = parse_num(arg);
            expect_t = false;
            i = i + 1;
        } else if arg.starts_with("--") {
            if arg.contains("help") {
                print_help();
                process_exit(0);
            }
            i = i + 1;
        } else if arg.starts_with("-") {
            // Could be -n, -t, or combined
            if arg.contains("n") {
                expect_n = true;
            }
            if arg.contains("t") {
                expect_t = true;
            }
            i = i + 1;
        } else {
            filename = arg;
            has_file = true;
            i = i + 1;
        }
    }

    // Default: if neither -n nor -t specified, show first 10 lines (head mode)
    if head_n < 0 && tail_n < 0 {
        head_n = 10;
    }

    // Read input
    let input = if has_file {
        let exists = file_exists(filename);
        if !exists {
            println!("qht: {}: No such file or directory", filename);
            process_exit(2);
        }
        read_file(filename)
    } else {
        let piped = stdin_is_pipe();
        if !piped {
            print_help();
            process_exit(0);
        }
        read_all()
    };

    // Handle empty input
    if input.len() == 0 {
        process_exit(0);
    }

    // Split into lines
    let starts: Vec<i32> = vec![];
    let lens: Vec<i32> = vec![];
    let total = split_lines(input, starts, lens);

    if total == 0 {
        process_exit(0);
    }

    // Print head portion
    if head_n >= 0 {
        let end = if head_n < total { head_n } else { total };
        print_range(input, starts, lens, 0, end);
    }

    // Print tail portion
    if tail_n >= 0 {
        let start = if tail_n < total { total - tail_n } else { 0 };
        print_range(input, starts, lens, start, total);
    }
}
