#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_sampling_profiler() {
        let config = ProfilerConfig::default();
        let profiler = SamplingProfiler::new(config);

        profiler.add_sample(vec![
            StackFrame {
                function: "main".to_string(),
                module: "test".to_string(),
                file: None,
                line: None,
                column: None,
                address: None,
                is_native: false,
                is_inlined: false,
                compilation_unit: None,
            },
        ]);

        let samples = profiler.samples();
        assert_eq!(samples.len(), 1);
    }

    #[test]
    fn test_memory_profiler() {
        let config = ProfilerConfig::default();
        let profiler = MemoryProfiler::new(config);

        profiler.record_alloc(0x1000, 1024, vec![]);
        profiler.record_alloc(0x2000, 2048, vec![]);

        let stats = profiler.stats();
        assert_eq!(stats.total_allocated, 3072);
        assert_eq!(stats.allocation_count, 2);

        profiler.record_free(0x1000);
        let stats = profiler.stats();
        assert_eq!(stats.total_freed, 1024);
        assert_eq!(stats.current_memory, 2048);
    }

