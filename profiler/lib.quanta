    #[test]
    fn test_profile_comparison() {
        let mut baseline_funcs = vec![
            FunctionStats {
                name: "foo".to_string(),
                self_samples: 100,
                total_samples: 100,
                self_time: Duration::from_millis(100),
                total_time: Duration::from_millis(100),
                callers: HashMap::new(),
                callees: HashMap::new(),
                source_lines: HashMap::new(),
            },
        ];

        let baseline = ProfileReport {
            mode: ProfileMode::Cpu,
            duration: Duration::from_secs(1),
            total_samples: 100,
            dropped_samples: 0,
            functions: baseline_funcs,
            stacks: HashMap::new(),
            thread_samples: HashMap::new(),
            state_samples: HashMap::new(),
            call_tree: CallTree { root: CallTreeNode::new("<root>") },
            hot_paths: vec![],
        };

        let mut current_funcs = vec![
            FunctionStats {
                name: "foo".to_string(),
                self_samples: 150,
                total_samples: 150,
                self_time: Duration::from_millis(150),
                total_time: Duration::from_millis(150),
                callers: HashMap::new(),
                callees: HashMap::new(),
                source_lines: HashMap::new(),
            },
        ];

        let current = ProfileReport {
            mode: ProfileMode::Cpu,
            duration: Duration::from_secs(1),
            total_samples: 150,
            dropped_samples: 0,
            functions: current_funcs,
            stacks: HashMap::new(),
            thread_samples: HashMap::new(),
            state_samples: HashMap::new(),
            call_tree: CallTree { root: CallTreeNode::new("<root>") },
            hot_paths: vec![],
        };

        let comparison = ProfileComparator::compare(&baseline, &current);
        assert_eq!(comparison.regressions.len(), 1);
        assert!(comparison.regressions[0].change_percent > 0.0);
    }

