// =============================================================================
// QUANTA PROFILER - Performance Profiling for QuantaLang
// =============================================================================
// A comprehensive profiling toolkit with CPU profiling, memory tracking,
// sampling, flame graph generation, and performance analysis.
// =============================================================================

use quantalang::prelude::*;
use std::collections::{HashMap, BTreeMap, HashSet, VecDeque};
use std::sync::{Arc, RwLock, Mutex, atomic::{AtomicBool, AtomicU64, AtomicUsize, Ordering}};
use std::path::{Path, PathBuf};
use std::time::{Duration, Instant, SystemTime};
use std::io::{Write, BufWriter, Read};
use std::fs::{self, File};
use std::thread;

// =============================================================================
// PROFILING TYPES
// =============================================================================

/// Profile sample
#[derive(Debug, Clone)]
pub struct Sample {
    pub timestamp: Instant,
    pub thread_id: u64,
    pub stack: Vec<StackFrame>,
    pub cpu_time: Duration,
    pub wall_time: Duration,
    pub thread_name: Option<String>,
    pub state: ThreadState,
}

/// Thread execution state
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ThreadState {
    Running,
    Runnable,
    Blocked,
    Waiting,
    TimedWaiting,
    Terminated,
    Unknown,
}

/// Stack frame in a sample
#[derive(Debug, Clone, PartialEq, Eq, Hash)]
pub struct StackFrame {
    pub function: String,
    pub module: String,
    pub file: Option<PathBuf>,
    pub line: Option<u32>,
    pub column: Option<u32>,
    pub address: Option<u64>,
    pub is_native: bool,
    pub is_inlined: bool,
    pub compilation_unit: Option<String>,
}

impl StackFrame {
    pub fn display_name(&self) -> String {
        if self.module.is_empty() {
            self.function.clone()
        } else {
            format!("{}::{}", self.module, self.function)
        }
    }

    pub fn full_location(&self) -> String {
        let mut loc = self.display_name();
        if let Some(ref file) = self.file {
            loc.push_str(&format!(" ({})", file.display()));
            if let Some(line) = self.line {
                loc.push_str(&format!(":{}", line));
                if let Some(col) = self.column {
                    loc.push_str(&format!(":{}", col));
                }
            }
        }
        loc
    }

    pub fn demangle(&self) -> String {
        // Demangle function name (simplified)
        let name = &self.function;

        // Handle Quanta mangling: _Q prefix
        if name.starts_with("_Q") {
            return self.demangle_quanta(name);
        }

        // Handle C++ mangling: _Z prefix
        if name.starts_with("_Z") {
            return self.demangle_cpp(name);
        }

        // Handle Rust mangling: _R prefix
        if name.starts_with("_R") {
            return self.demangle_rust(name);
        }

        name.clone()
    }

    fn demangle_quanta(&self, name: &str) -> String {
        // Simplified Quanta demangling
        let without_prefix = &name[2..];
        without_prefix.replace("__", "::")
    }

    fn demangle_cpp(&self, name: &str) -> String {
        // Simplified C++ demangling
        name.to_string()
    }

    fn demangle_rust(&self, name: &str) -> String {
        // Simplified Rust demangling
        name.to_string()
    }
}

/// Memory allocation record
#[derive(Debug, Clone)]
pub struct Allocation {
    pub address: u64,
    pub size: usize,
    pub timestamp: Instant,
    pub stack: Vec<StackFrame>,
    pub freed: bool,
    pub free_timestamp: Option<Instant>,
    pub allocation_type: AllocationType,
    pub thread_id: u64,
    pub generation: u32,
}

/// Allocation type
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum AllocationType {
    Heap,
    Stack,
    Mmap,
    Arena,
    Pool,
    Custom(u32),
}

/// Memory snapshot
#[derive(Debug, Clone)]
pub struct MemorySnapshot {
    pub timestamp: Instant,
    pub total_allocated: usize,
    pub total_freed: usize,
    pub live_allocations: usize,
    pub peak_memory: usize,
    pub allocations_by_site: HashMap<String, AllocationSite>,
    pub allocations_by_type: HashMap<AllocationType, TypeAllocationStats>,
    pub heap_regions: Vec<HeapRegion>,
    pub gc_stats: Option<GcStats>,
}

/// Heap region information
#[derive(Debug, Clone)]
pub struct HeapRegion {
    pub start: u64,
    pub end: u64,
    pub used: usize,
    pub capacity: usize,
    pub region_type: HeapRegionType,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HeapRegionType {
    Eden,
    Survivor,
    Old,
    Large,
    Humongous,
    Free,
}

/// GC statistics
#[derive(Debug, Clone)]
pub struct GcStats {
    pub collections: u64,
    pub total_pause_time: Duration,
    pub max_pause_time: Duration,
    pub last_collection: Option<Instant>,
    pub bytes_collected: u64,
    pub gc_type: GcType,
    pub generation_stats: Vec<GenerationStats>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum GcType {
    Minor,
    Major,
    Full,
    Concurrent,
    Incremental,
}

#[derive(Debug, Clone)]
pub struct GenerationStats {
    pub generation: u32,
    pub size: usize,
    pub used: usize,
    pub collections: u64,
    pub promotion_rate: f64,
}

/// Type-based allocation statistics
#[derive(Debug, Clone, Default)]
pub struct TypeAllocationStats {
    pub count: usize,
    pub total_bytes: usize,
    pub live_bytes: usize,
    pub instances: usize,
}

/// Allocation site statistics
#[derive(Debug, Clone, Default)]
pub struct AllocationSite {
    pub location: String,
    pub count: usize,
    pub total_bytes: usize,
    pub live_bytes: usize,
    pub peak_bytes: usize,
    pub avg_lifetime: Duration,
    pub stack_hash: u64,
}

// =============================================================================
// PROFILER CONFIGURATION
// =============================================================================

/// Profiler mode
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ProfileMode {
    /// CPU sampling profiler
    Cpu,
    /// Wall-clock time profiler
    Wall,
    /// Memory allocations profiler
    Memory,
    /// Combined CPU and memory
    Combined,
    /// Lock contention profiler
    Lock,
    /// I/O wait profiler
    Io,
    /// Off-CPU profiler
    OffCpu,
    /// Async profiler
    Async,
}

/// Profiler configuration
#[derive(Debug, Clone)]
pub struct ProfilerConfig {
    /// Profiling mode
    pub mode: ProfileMode,

    /// Sample interval for CPU/wall profiling
    pub sample_interval: Duration,

    /// Maximum number of samples to collect
    pub max_samples: usize,

    /// Stack depth limit
    pub max_stack_depth: usize,

    /// Track allocations
    pub track_allocations: bool,

    /// Track deallocations
    pub track_deallocations: bool,

    /// Minimum allocation size to track
    pub min_allocation_size: usize,

    /// Output file path
    pub output_path: Option<PathBuf>,

    /// Output format
    pub output_format: OutputFormat,

    /// Include native frames
    pub include_native: bool,

    /// Filter by function pattern
    pub filter: Option<String>,

    /// Enable async profiling
    pub async_profiling: bool,

    /// Collect thread names
    pub collect_thread_names: bool,

    /// Enable lock profiling
    pub lock_profiling: bool,

    /// Lock contention threshold
    pub lock_threshold: Duration,

    /// GC profiling
    pub gc_profiling: bool,

    /// Context lines for source annotation
    pub context_lines: usize,

    /// Symbol resolution mode
    pub symbol_resolution: SymbolResolution,

    /// Compression for output
    pub compression: Option<Compression>,
}

/// Symbol resolution strategy
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SymbolResolution {
    None,
    Basic,
    Full,
    Debug,
}

/// Compression algorithm
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Compression {
    Gzip,
    Zstd,
    Lz4,
    Snappy,
}

impl Default for ProfilerConfig {
    fn default() -> Self {
        ProfilerConfig {
            mode: ProfileMode::Cpu,
            sample_interval: Duration::from_millis(10),
            max_samples: 100_000,
            max_stack_depth: 128,
            track_allocations: true,
            track_deallocations: true,
            min_allocation_size: 0,
            output_path: None,
            output_format: OutputFormat::Text,
            include_native: false,
            filter: None,
            async_profiling: false,
            collect_thread_names: true,
            lock_profiling: false,
            lock_threshold: Duration::from_millis(1),
            gc_profiling: false,
            context_lines: 3,
            symbol_resolution: SymbolResolution::Basic,
            compression: None,
        }
    }
}

/// Output format
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OutputFormat {
    Text,
    Json,
    FlameGraph,
    Callgrind,
    Speedscope,
    Pprof,
    ChromeTrace,
    Collapsed,
    Jfr,
}

// =============================================================================
// SAMPLING PROFILER
// =============================================================================

/// Sampling profiler
pub struct SamplingProfiler {
    config: ProfilerConfig,
    samples: RwLock<Vec<Sample>>,
    running: AtomicBool,
    start_time: RwLock<Option<Instant>>,
    sample_count: AtomicUsize,
    dropped_samples: AtomicUsize,
    thread_info: RwLock<HashMap<u64, ThreadInfo>>,
    async_contexts: RwLock<HashMap<u64, AsyncContext>>,
}

/// Thread information
#[derive(Debug, Clone)]
pub struct ThreadInfo {
    pub id: u64,
    pub name: String,
    pub start_time: Instant,
    pub cpu_time: Duration,
    pub state: ThreadState,
    pub priority: i32,
    pub is_daemon: bool,
}

/// Async context for tracking async/await
#[derive(Debug, Clone)]
pub struct AsyncContext {
    pub task_id: u64,
    pub parent_task: Option<u64>,
    pub executor: String,
    pub state: AsyncState,
    pub creation_stack: Vec<StackFrame>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum AsyncState {
    Pending,
    Running,
    Suspended,
    Completed,
    Cancelled,
}

impl SamplingProfiler {
    pub fn new(config: ProfilerConfig) -> Self {
        SamplingProfiler {
            config,
            samples: RwLock::new(Vec::new()),
            running: AtomicBool::new(false),
            start_time: RwLock::new(None),
            sample_count: AtomicUsize::new(0),
            dropped_samples: AtomicUsize::new(0),
            thread_info: RwLock::new(HashMap::new()),
            async_contexts: RwLock::new(HashMap::new()),
        }
    }

    /// Start profiling
    pub fn start(&self) {
        if self.running.swap(true, Ordering::SeqCst) {
            return; // Already running
        }

        *self.start_time.write().unwrap() = Some(Instant::now());

        // Start sampling thread
        let running = Arc::new(AtomicBool::new(true));
        let running_clone = running.clone();
        let interval = self.config.sample_interval;

        thread::spawn(move || {
            while running_clone.load(Ordering::SeqCst) {
                // Take sample
                // In a real implementation, this would capture the actual stack

                thread::sleep(interval);
            }
        });
    }

    /// Stop profiling
    pub fn stop(&self) {
        self.running.store(false, Ordering::SeqCst);
    }

    /// Check if profiling is active
    pub fn is_running(&self) -> bool {
        self.running.load(Ordering::SeqCst)
    }

    /// Add a sample manually
    pub fn add_sample(&self, stack: Vec<StackFrame>) {
        self.add_sample_with_state(stack, ThreadState::Running);
    }

    /// Add a sample with thread state
    pub fn add_sample_with_state(&self, stack: Vec<StackFrame>, state: ThreadState) {
        if !self.running.load(Ordering::SeqCst) {
            return;
        }

        if self.sample_count.load(Ordering::SeqCst) >= self.config.max_samples {
            self.dropped_samples.fetch_add(1, Ordering::SeqCst);
            return;
        }

        let start = self.start_time.read().unwrap().unwrap_or_else(Instant::now);
        let tid = thread_id();

        let thread_name = self.thread_info.read().unwrap()
            .get(&tid)
            .map(|t| t.name.clone());

        let sample = Sample {
            timestamp: Instant::now(),
            thread_id: tid,
            stack,
            cpu_time: start.elapsed(),
            wall_time: start.elapsed(),
            thread_name,
            state,
        };

        self.samples.write().unwrap().push(sample);
        self.sample_count.fetch_add(1, Ordering::SeqCst);
    }

    /// Add async context
    pub fn add_async_context(&self, task_id: u64, context: AsyncContext) {
        self.async_contexts.write().unwrap().insert(task_id, context);
    }

    /// Update thread info
    pub fn update_thread_info(&self, info: ThreadInfo) {
        self.thread_info.write().unwrap().insert(info.id, info);
    }

    /// Get collected samples
    pub fn samples(&self) -> Vec<Sample> {
        self.samples.read().unwrap().clone()
    }

    /// Get sample count
    pub fn sample_count(&self) -> usize {
        self.sample_count.load(Ordering::SeqCst)
    }

    /// Get dropped sample count
    pub fn dropped_count(&self) -> usize {
        self.dropped_samples.load(Ordering::SeqCst)
    }

    /// Clear samples
    pub fn clear(&self) {
        self.samples.write().unwrap().clear();
        self.sample_count.store(0, Ordering::SeqCst);
        self.dropped_samples.store(0, Ordering::SeqCst);
    }

    /// Generate profile report
    pub fn report(&self) -> ProfileReport {
        let samples = self.samples.read().unwrap();

        // Aggregate samples by stack
        let mut stacks: HashMap<Vec<String>, usize> = HashMap::new();
        let mut function_times: HashMap<String, FunctionStats> = HashMap::new();
        let mut thread_samples: HashMap<u64, usize> = HashMap::new();
        let mut state_samples: HashMap<ThreadState, usize> = HashMap::new();

        for sample in samples.iter() {
            let stack_key: Vec<String> = sample.stack.iter()
                .map(|f| f.display_name())
                .collect();

            *stacks.entry(stack_key).or_insert(0) += 1;
            *thread_samples.entry(sample.thread_id).or_insert(0) += 1;
            *state_samples.entry(sample.state).or_insert(0) += 1;

            // Count time per function
            for (idx, frame) in sample.stack.iter().enumerate() {
                let name = frame.display_name();
                let stats = function_times.entry(name.clone()).or_insert(FunctionStats {
                    name,
                    self_samples: 0,
                    total_samples: 0,
                    self_time: Duration::ZERO,
                    total_time: Duration::ZERO,
                    callers: HashMap::new(),
                    callees: HashMap::new(),
                    source_lines: HashMap::new(),
                });

                stats.total_samples += 1;

                // Self time is only for the top of stack
                if idx == 0 {
                    stats.self_samples += 1;
                }

                // Track callers
                if idx + 1 < sample.stack.len() {
                    let caller = sample.stack[idx + 1].display_name();
                    *stats.callers.entry(caller).or_insert(0) += 1;
                }

                // Track callees
                if idx > 0 {
                    let callee = sample.stack[idx - 1].display_name();
                    *stats.callees.entry(callee).or_insert(0) += 1;
                }

                // Track source lines
                if let Some(line) = frame.line {
                    *stats.source_lines.entry(line).or_insert(0) += 1;
                }
            }
        }

        // Calculate times
        let total_samples = samples.len();
        let sample_time = self.config.sample_interval;

        for stats in function_times.values_mut() {
            stats.self_time = sample_time * stats.self_samples as u32;
            stats.total_time = sample_time * stats.total_samples as u32;
        }

        // Sort by self time
        let mut sorted_functions: Vec<_> = function_times.values().cloned().collect();
        sorted_functions.sort_by(|a, b| b.self_time.cmp(&a.self_time));

        let start = self.start_time.read().unwrap().unwrap_or_else(Instant::now);
        let duration = if self.running.load(Ordering::SeqCst) {
            start.elapsed()
        } else {
            samples.last().map(|s| s.wall_time).unwrap_or(Duration::ZERO)
        };

        ProfileReport {
            mode: self.config.mode,
            duration,
            total_samples,
            dropped_samples: self.dropped_samples.load(Ordering::SeqCst),
            functions: sorted_functions,
            stacks: stacks.into_iter()
                .map(|(k, v)| (k.join(";"), v))
                .collect(),
            thread_samples,
            state_samples,
            call_tree: self.build_call_tree(&samples),
            hot_paths: self.find_hot_paths(&samples),
        }
    }

    /// Build call tree from samples
    fn build_call_tree(&self, samples: &[Sample]) -> CallTree {
        let mut root = CallTreeNode::new("<root>");

        for sample in samples {
            let mut current = &mut root;

            // Walk stack bottom-up (caller to callee)
            for frame in sample.stack.iter().rev() {
                let name = frame.display_name();
                current.samples += 1;

                let child_idx = current.children.iter()
                    .position(|c| c.name == name);

                current = if let Some(idx) = child_idx {
                    &mut current.children[idx]
                } else {
                    current.children.push(CallTreeNode::new(&name));
                    current.children.last_mut().unwrap()
                };
            }

            // Mark leaf
            current.samples += 1;
            current.self_samples += 1;
        }

        CallTree { root }
    }

    /// Find hot paths (most common stacks)
    fn find_hot_paths(&self, samples: &[Sample]) -> Vec<HotPath> {
        let mut path_counts: HashMap<String, usize> = HashMap::new();

        for sample in samples {
            let path = sample.stack.iter()
                .map(|f| f.display_name())
                .collect::<Vec<_>>()
                .join(" -> ");
            *path_counts.entry(path).or_insert(0) += 1;
        }

        let total = samples.len();
        let mut hot_paths: Vec<_> = path_counts.into_iter()
            .map(|(path, count)| HotPath {
                path,
                samples: count,
                percentage: (count as f64 / total as f64) * 100.0,
            })
            .collect();

        hot_paths.sort_by(|a, b| b.samples.cmp(&a.samples));
        hot_paths.truncate(20);

        hot_paths
    }
}

/// Function statistics
#[derive(Debug, Clone)]
pub struct FunctionStats {
    pub name: String,
    pub self_samples: usize,
    pub total_samples: usize,
    pub self_time: Duration,
    pub total_time: Duration,
    pub callers: HashMap<String, usize>,
    pub callees: HashMap<String, usize>,
    pub source_lines: HashMap<u32, usize>,
}

impl FunctionStats {
    pub fn self_percent(&self, total: usize) -> f64 {
        if total == 0 { 0.0 } else { (self.self_samples as f64 / total as f64) * 100.0 }
    }

    pub fn total_percent(&self, total: usize) -> f64 {
        if total == 0 { 0.0 } else { (self.total_samples as f64 / total as f64) * 100.0 }
    }

    pub fn top_callers(&self, n: usize) -> Vec<(&String, &usize)> {
        let mut callers: Vec<_> = self.callers.iter().collect();
        callers.sort_by(|a, b| b.1.cmp(a.1));
        callers.truncate(n);
        callers
    }

    pub fn top_callees(&self, n: usize) -> Vec<(&String, &usize)> {
        let mut callees: Vec<_> = self.callees.iter().collect();
        callees.sort_by(|a, b| b.1.cmp(a.1));
        callees.truncate(n);
        callees
    }
}

/// Call tree for hierarchical analysis
#[derive(Debug, Clone)]
pub struct CallTree {
    pub root: CallTreeNode,
}

#[derive(Debug, Clone)]
pub struct CallTreeNode {
    pub name: String,
    pub samples: usize,
    pub self_samples: usize,
    pub children: Vec<CallTreeNode>,
}

impl CallTreeNode {
    pub fn new(name: &str) -> Self {
        CallTreeNode {
            name: name.to_string(),
            samples: 0,
            self_samples: 0,
            children: Vec::new(),
        }
    }

    pub fn percentage(&self, total: usize) -> f64 {
        if total == 0 { 0.0 } else { (self.samples as f64 / total as f64) * 100.0 }
    }

    pub fn self_percentage(&self, total: usize) -> f64 {
        if total == 0 { 0.0 } else { (self.self_samples as f64 / total as f64) * 100.0 }
    }
}

impl CallTree {
    /// Get top-down view (from callers to callees)
    pub fn top_down(&self) -> &CallTreeNode {
        &self.root
    }

    /// Get bottom-up view (from callees to callers)
    pub fn bottom_up(&self) -> CallTreeNode {
        // Invert the tree
        let mut inverted = CallTreeNode::new("<root>");
        self.invert_node(&self.root, &mut inverted, &[]);
        inverted
    }

    fn invert_node(&self, node: &CallTreeNode, inverted: &mut CallTreeNode, path: &[String]) {
        let mut new_path = path.to_vec();
        new_path.push(node.name.clone());

        if node.self_samples > 0 {
            // Add inverted path
            let mut current = inverted;
            for name in new_path.iter() {
                let idx = current.children.iter().position(|c| &c.name == name);
                current = if let Some(idx) = idx {
                    current.children[idx].samples += node.self_samples;
                    &mut current.children[idx]
                } else {
                    current.children.push(CallTreeNode {
                        name: name.clone(),
                        samples: node.self_samples,
                        self_samples: 0,
                        children: Vec::new(),
                    });
                    current.children.last_mut().unwrap()
                };
            }
            current.self_samples += node.self_samples;
        }

        for child in &node.children {
            self.invert_node(child, inverted, &new_path);
        }
    }
}

/// Hot path information
#[derive(Debug, Clone)]
pub struct HotPath {
    pub path: String,
    pub samples: usize,
    pub percentage: f64,
}

/// Profile report
#[derive(Debug, Clone)]
pub struct ProfileReport {
    pub mode: ProfileMode,
    pub duration: Duration,
    pub total_samples: usize,
    pub dropped_samples: usize,
    pub functions: Vec<FunctionStats>,
    pub stacks: HashMap<String, usize>,
    pub thread_samples: HashMap<u64, usize>,
    pub state_samples: HashMap<ThreadState, usize>,
    pub call_tree: CallTree,
    pub hot_paths: Vec<HotPath>,
}

