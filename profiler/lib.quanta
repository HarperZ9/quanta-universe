        graph.nodes.insert(1, ObjectNode {
            address: 1,
            size: 100,
            type_name: "A".to_string(),
            retained_size: 0,
            dominator: None,
            depth: 0,
        });
        graph.nodes.insert(2, ObjectNode {
            address: 2,
            size: 50,
            type_name: "B".to_string(),
            retained_size: 0,
            dominator: None,
            depth: 0,
        });
        graph.edges.insert(1, vec![2]);
        graph.roots = vec![1];

        let mut tree = DominatorTree::new();
        tree.compute_dominators(&graph, 1);

        assert_eq!(tree.immediate_dominator(2), Some(1));
    }
}
