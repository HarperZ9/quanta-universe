// FEATURE ENGINEERING
// ═══════════════════════════════════════════════════════════════════════════════

/// Time series feature generator
pub struct FeatureEngineering {
    lookback: usize,
    features: Vec<FeatureType>,
}

#[derive(Debug, Clone, Copy)]
pub enum FeatureType {
    Returns,
    LogReturns,
    Volatility,
    RSI,
    MACD,
    BollingerBands,
    ATR,
    Volume,
    VolumeMA,
    PriceMA,
    Momentum,
    ROC,
    Stochastic,
    WilliamsR,
    CCI,
    ADX,
    OBV,
    VWAP,
    Autocorrelation,
    PartialAutocorrelation,
}

impl FeatureEngineering {
    pub fn new(lookback: usize) -> Self {
        FeatureEngineering {
            lookback,
            features: vec![
                FeatureType::Returns,
                FeatureType::LogReturns,
                FeatureType::Volatility,
                FeatureType::RSI,
                FeatureType::MACD,
            ],
        }
    }
    
    pub fn with_features(mut self, features: Vec<FeatureType>) -> Self {
        self.features = features;
        self
    }
    
    /// Generate features from price data
    pub fn generate(&self, prices: &[f64], volumes: &[f64]) -> Vec<Vec<f64>> {
        let n = prices.len();
        if n < self.lookback + 1 {
            return Vec::new();
        }
        
        let mut all_features = Vec::new();
        
        for &feature_type in &self.features {
            let feature_values = self.compute_feature(feature_type, prices, volumes);
            all_features.push(feature_values);
        }
        
        // Transpose to get [sample][feature]
        let num_samples = n - self.lookback;
        let num_features = all_features.len();
        
        let mut result = vec![vec![0.0; num_features]; num_samples];
        for f in 0..num_features {
            for s in 0..num_samples {
                if s + self.lookback < all_features[f].len() {
                    result[s][f] = all_features[f][s + self.lookback];
                }
            }
        }
        
        result
    }
    
    fn compute_feature(&self, feature_type: FeatureType, prices: &[f64], volumes: &[f64]) -> Vec<f64> {
        match feature_type {
            FeatureType::Returns => self.returns(prices),
            FeatureType::LogReturns => self.log_returns(prices),
            FeatureType::Volatility => self.rolling_volatility(prices, 20),
            FeatureType::RSI => self.rsi(prices, 14),
            FeatureType::MACD => self.macd(prices),
            FeatureType::Momentum => self.momentum(prices, 10),
            FeatureType::Volume => volumes.to_vec(),
            FeatureType::VolumeMA => self.moving_average(volumes, 20),
            FeatureType::PriceMA => self.moving_average(prices, 20),
            _ => vec![0.0; prices.len()],
        }
    }
    
    fn returns(&self, prices: &[f64]) -> Vec<f64> {
        let mut ret = vec![0.0];
        for i in 1..prices.len() {
            ret.push((prices[i] - prices[i-1]) / prices[i-1]);
        }
        ret
    }
    
    fn log_returns(&self, prices: &[f64]) -> Vec<f64> {
        let mut ret = vec![0.0];
        for i in 1..prices.len() {
            ret.push(log(prices[i] / prices[i-1]));
        }
        ret
    }
    
    fn rolling_volatility(&self, prices: &[f64], window: usize) -> Vec<f64> {
        let returns = self.log_returns(prices);
        let mut vol = vec![0.0; window];
        
        for i in window..returns.len() {
            let slice = &returns[i-window..i];
            let mean: f64 = slice.iter().sum::<f64>() / window as f64;
            let variance: f64 = slice.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / window as f64;
            vol.push(sqrt(variance) * sqrt(252.0)); // Annualized
        }
        
        vol
    }
    
    fn rsi(&self, prices: &[f64], period: usize) -> Vec<f64> {
        let mut rsi = vec![50.0; period];
        let mut gains = VecDeque::with_capacity(period);
        let mut losses = VecDeque::with_capacity(period);
        
        for i in 1..prices.len() {
            let change = prices[i] - prices[i-1];
            let gain = if change > 0.0 { change } else { 0.0 };
            let loss = if change < 0.0 { -change } else { 0.0 };
            
            gains.push_back(gain);
            losses.push_back(loss);
            
            if gains.len() > period {
                gains.pop_front();
                losses.pop_front();
            }
            
            if gains.len() == period {
                let avg_gain: f64 = gains.iter().sum::<f64>() / period as f64;
                let avg_loss: f64 = losses.iter().sum::<f64>() / period as f64;
                
                let rs = if avg_loss > 0.0 { avg_gain / avg_loss } else { 100.0 };
                rsi.push(100.0 - 100.0 / (1.0 + rs));
            }
        }
        
        rsi
    }
    
    fn macd(&self, prices: &[f64]) -> Vec<f64> {
        let ema12 = self.ema(prices, 12);
        let ema26 = self.ema(prices, 26);
        
        ema12.iter().zip(ema26.iter())
            .map(|(e12, e26)| e12 - e26)
            .collect()
    }
    
    fn ema(&self, prices: &[f64], period: usize) -> Vec<f64> {
        let mut ema = vec![prices[0]];
        let multiplier = 2.0 / (period as f64 + 1.0);
        
        for i in 1..prices.len() {
            let new_ema = (prices[i] - ema[i-1]) * multiplier + ema[i-1];
            ema.push(new_ema);
        }
        
        ema
    }
    
    fn moving_average(&self, values: &[f64], window: usize) -> Vec<f64> {
        let mut ma = vec![values[0]; window.min(values.len())];
        
        for i in window..values.len() {
            let sum: f64 = values[i-window..i].iter().sum();
            ma.push(sum / window as f64);
        }
        
        ma
    }
    
    fn momentum(&self, prices: &[f64], period: usize) -> Vec<f64> {
        let mut mom = vec![0.0; period];
        
        for i in period..prices.len() {
            mom.push(prices[i] - prices[i - period]);
        }
        
        mom
    }
    
    /// Normalize features to zero mean, unit variance
    pub fn normalize(&self, features: &mut Vec<Vec<f64>>) {
        let n = features.len();
        if n == 0 { return; }
        
        let num_features = features[0].len();
        
        for f in 0..num_features {
            let values: Vec<f64> = features.iter().map(|row| row[f]).collect();
            let mean = values.iter().sum::<f64>() / n as f64;
            let variance = values.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / n as f64;
            let std = sqrt(variance).max(1e-8);
            
            for row in features.iter_mut() {
                row[f] = (row[f] - mean) / std;
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LSTM NETWORK
// ═══════════════════════════════════════════════════════════════════════════════

/// Long Short-Term Memory cell
pub struct LSTMCell {
    input_size: usize,
    hidden_size: usize,
    
    // Weight matrices
    w_ii: Vec<Vec<f64>>, w_hi: Vec<Vec<f64>>, b_i: Vec<f64>,  // Input gate
    w_if: Vec<Vec<f64>>, w_hf: Vec<Vec<f64>>, b_f: Vec<f64>,  // Forget gate
    w_ig: Vec<Vec<f64>>, w_hg: Vec<Vec<f64>>, b_g: Vec<f64>,  // Cell gate
    w_io: Vec<Vec<f64>>, w_ho: Vec<Vec<f64>>, b_o: Vec<f64>,  // Output gate
}

impl LSTMCell {
    pub fn new(input_size: usize, hidden_size: usize) -> Self {
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / (input_size + hidden_size) as f64);
        
        let init_weight = |rows: usize, cols: usize| -> Vec<Vec<f64>> {
            (0..rows).map(|_| {
                (0..cols).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect()
        };
        
        let init_bias = |size: usize| -> Vec<f64> {
            vec![0.0; size]
        };
        
        LSTMCell {
            input_size,
            hidden_size,
            w_ii: init_weight(hidden_size, input_size),
            w_hi: init_weight(hidden_size, hidden_size),
            b_i: init_bias(hidden_size),
            w_if: init_weight(hidden_size, input_size),
            w_hf: init_weight(hidden_size, hidden_size),
            b_f: vec![1.0; hidden_size], // Initialize forget gate bias to 1
            w_ig: init_weight(hidden_size, input_size),
            w_hg: init_weight(hidden_size, hidden_size),
            b_g: init_bias(hidden_size),
            w_io: init_weight(hidden_size, input_size),
            w_ho: init_weight(hidden_size, hidden_size),
            b_o: init_bias(hidden_size),
        }
    }
    
    /// Forward pass through LSTM cell
    pub fn forward(&self, x: &[f64], h_prev: &[f64], c_prev: &[f64]) -> (Vec<f64>, Vec<f64>) {
        let h = self.hidden_size;
        
        // Input gate
        let i_t = self.sigmoid(&self.gate_output(&self.w_ii, &self.w_hi, &self.b_i, x, h_prev));
        
        // Forget gate
        let f_t = self.sigmoid(&self.gate_output(&self.w_if, &self.w_hf, &self.b_f, x, h_prev));
        
        // Cell candidate
        let g_t = self.tanh_vec(&self.gate_output(&self.w_ig, &self.w_hg, &self.b_g, x, h_prev));
        
        // Output gate
        let o_t = self.sigmoid(&self.gate_output(&self.w_io, &self.w_ho, &self.b_o, x, h_prev));
        
        // New cell state: c_t = f_t * c_prev + i_t * g_t
        let c_t: Vec<f64> = (0..h)
            .map(|i| f_t[i] * c_prev[i] + i_t[i] * g_t[i])
            .collect();
        
        // New hidden state: h_t = o_t * tanh(c_t)
        let h_t: Vec<f64> = (0..h)
            .map(|i| o_t[i] * tanh(c_t[i]))
            .collect();
        
        (h_t, c_t)
    }
    
    fn gate_output(&self, w_i: &[Vec<f64>], w_h: &[Vec<f64>], b: &[f64], x: &[f64], h: &[f64]) -> Vec<f64> {
        let size = b.len();
        let mut output = vec![0.0; size];
        
        for i in 0..size {
            output[i] = b[i];
            for j in 0..x.len() {
                output[i] += w_i[i][j] * x[j];
            }
            for j in 0..h.len() {
                output[i] += w_h[i][j] * h[j];
            }
        }
        
        output
    }
    
    fn sigmoid(&self, x: &[f64]) -> Vec<f64> {
        x.iter().map(|&v| 1.0 / (1.0 + exp(-v))).collect()
    }
    
    fn tanh_vec(&self, x: &[f64]) -> Vec<f64> {
        x.iter().map(|&v| tanh(v)).collect()
    }
}

/// Multi-layer LSTM for sequence prediction
pub struct LSTMPredictor {
    layers: Vec<LSTMCell>,
    output_layer: Vec<Vec<f64>>,
    output_bias: Vec<f64>,
    sequence_length: usize,
}

impl LSTMPredictor {
    pub fn new(input_size: usize, hidden_sizes: &[usize], output_size: usize, sequence_length: usize) -> Self {
        let mut layers = Vec::new();
        let mut prev_size = input_size;
        
        for &hidden_size in hidden_sizes {
            layers.push(LSTMCell::new(prev_size, hidden_size));
            prev_size = hidden_size;
        }
        
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / prev_size as f64);
        
        let output_layer: Vec<Vec<f64>> = (0..output_size)
            .map(|_| (0..prev_size).map(|_| rng.gaussian(0.0, scale)).collect())
            .collect();
        
        LSTMPredictor {
            layers,
            output_layer,
            output_bias: vec![0.0; output_size],
            sequence_length,
        }
    }
    
    /// Predict from sequence of feature vectors
    pub fn predict(&self, sequence: &[Vec<f64>]) -> Vec<f64> {
        let num_layers = self.layers.len();
        let mut hidden_states: Vec<Vec<f64>> = self.layers.iter()
            .map(|l| vec![0.0; l.hidden_size])
            .collect();
        let mut cell_states: Vec<Vec<f64>> = self.layers.iter()
            .map(|l| vec![0.0; l.hidden_size])
            .collect();
        
        // Process sequence
        for x in sequence {
            let mut current_input = x.clone();
            
            for (i, layer) in self.layers.iter().enumerate() {
                let (h, c) = layer.forward(&current_input, &hidden_states[i], &cell_states[i]);
                hidden_states[i] = h.clone();
                cell_states[i] = c;
                current_input = h;
            }
        }
        
        // Output projection
        let final_hidden = &hidden_states[num_layers - 1];
        let mut output = self.output_bias.clone();
        
        for i in 0..output.len() {
            for j in 0..final_hidden.len() {
                output[i] += self.output_layer[i][j] * final_hidden[j];
            }
        }
        
        output
    }
}

