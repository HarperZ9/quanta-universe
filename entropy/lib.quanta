// TRANSFORMER FOR MARKET ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Multi-head self-attention mechanism
pub struct MultiHeadAttention {
    num_heads: usize,
    d_model: usize,
    d_k: usize,
    w_q: Vec<Vec<f64>>,
    w_k: Vec<Vec<f64>>,
    w_v: Vec<Vec<f64>>,
    w_o: Vec<Vec<f64>>,
}

impl MultiHeadAttention {
    pub fn new(d_model: usize, num_heads: usize) -> Self {
        let d_k = d_model / num_heads;
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / d_model as f64);
        
        let init_weight = || -> Vec<Vec<f64>> {
            (0..d_model).map(|_| {
                (0..d_model).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect()
        };
        
        MultiHeadAttention {
            num_heads,
            d_model,
            d_k,
            w_q: init_weight(),
            w_k: init_weight(),
            w_v: init_weight(),
            w_o: init_weight(),
        }
    }
    
    /// Compute attention output
    pub fn forward(&self, query: &[Vec<f64>], key: &[Vec<f64>], value: &[Vec<f64>]) -> Vec<Vec<f64>> {
        let seq_len = query.len();
        
        // Project to Q, K, V
        let q = self.project(&self.w_q, query);
        let k = self.project(&self.w_k, key);
        let v = self.project(&self.w_v, value);
        
        // Scaled dot-product attention
        let scale = 1.0 / sqrt(self.d_k as f64);
        let mut attention_output = vec![vec![0.0; self.d_model]; seq_len];
        
        for i in 0..seq_len {
            // Compute attention weights
            let mut weights = vec![0.0; seq_len];
            for j in 0..seq_len {
                let dot: f64 = q[i].iter().zip(k[j].iter())
                    .map(|(qi, kj)| qi * kj)
                    .sum();
                weights[j] = dot * scale;
            }
            
            // Softmax
            let max_w = weights.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let exp_sum: f64 = weights.iter().map(|w| exp(w - max_w)).sum();
            let weights: Vec<f64> = weights.iter().map(|w| exp(w - max_w) / exp_sum).collect();
            
            // Weighted sum of values
            for j in 0..seq_len {
                for d in 0..self.d_model {
                    attention_output[i][d] += weights[j] * v[j][d];
                }
            }
        }
        
        // Output projection
        self.project(&self.w_o, &attention_output)
    }
    
    fn project(&self, weight: &[Vec<f64>], input: &[Vec<f64>]) -> Vec<Vec<f64>> {
        input.iter().map(|x| {
            (0..self.d_model).map(|i| {
                x.iter().zip(weight[i].iter())
                    .map(|(xi, wi)| xi * wi)
                    .sum()
            }).collect()
        }).collect()
    }
}

/// Transformer encoder layer
pub struct TransformerEncoder {
    attention: MultiHeadAttention,
    ff_hidden: usize,
    w1: Vec<Vec<f64>>,
    w2: Vec<Vec<f64>>,
    b1: Vec<f64>,
    b2: Vec<f64>,
}

impl TransformerEncoder {
    pub fn new(d_model: usize, num_heads: usize, ff_hidden: usize) -> Self {
        let mut rng = std::random::Random::new();
        let scale1 = sqrt(2.0 / d_model as f64);
        let scale2 = sqrt(2.0 / ff_hidden as f64);
        
        TransformerEncoder {
            attention: MultiHeadAttention::new(d_model, num_heads),
            ff_hidden,
            w1: (0..ff_hidden).map(|_| (0..d_model).map(|_| rng.gaussian(0.0, scale1)).collect()).collect(),
            w2: (0..d_model).map(|_| (0..ff_hidden).map(|_| rng.gaussian(0.0, scale2)).collect()).collect(),
            b1: vec![0.0; ff_hidden],
            b2: vec![0.0; d_model],
        }
    }
    
    pub fn forward(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
        // Self-attention + residual
        let attended = MultiHeadAttention::forward(&self.attention, x, x, x);
        let x: Vec<Vec<f64>> = x.iter().zip(attended.iter())
            .map(|(a, b)| a.iter().zip(b.iter()).map(|(ai, bi)| ai + bi).collect())
            .collect();
        
        // Feed-forward + residual
        let ff_output: Vec<Vec<f64>> = x.iter().map(|xi| {
            // First layer with ReLU
            let hidden: Vec<f64> = (0..self.ff_hidden).map(|i| {
                let sum: f64 = xi.iter().zip(self.w1[i].iter())
                    .map(|(x, w)| x * w)
                    .sum::<f64>() + self.b1[i];
                sum.max(0.0) // ReLU
            }).collect();
            
            // Second layer
            (0..xi.len()).map(|i| {
                hidden.iter().zip(self.w2[i].iter())
                    .map(|(h, w)| h * w)
                    .sum::<f64>() + self.b2[i]
            }).collect()
        }).collect();
        
        // Residual connection
        x.iter().zip(ff_output.iter())
            .map(|(a, b)| a.iter().zip(b.iter()).map(|(ai, bi)| ai + bi).collect())
            .collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REINFORCEMENT LEARNING AGENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Trading action space
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TradingAction {
    Hold,
    Buy(f64),   // Fraction of capital to invest
    Sell(f64),  // Fraction of position to sell
}

/// Trading environment state
#[derive(Debug, Clone)]
pub struct TradingState {
    pub features: Vec<f64>,
    pub position: f64,      // Current position size
    pub cash: f64,          // Available cash
    pub portfolio_value: f64,
    pub timestamp: u64,
}

/// PPO (Proximal Policy Optimization) agent
pub struct PPOAgent {
    policy_net: Vec<Vec<f64>>,
    value_net: Vec<Vec<f64>>,
    state_size: usize,
    action_size: usize,
    gamma: f64,          // Discount factor
    epsilon: f64,        // Clipping parameter
    learning_rate: f64,
}

impl PPOAgent {
    pub fn new(state_size: usize, action_size: usize) -> Self {
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / state_size as f64);
        
        let hidden_size = 64;
        
        PPOAgent {
            policy_net: (0..hidden_size).map(|_| {
                (0..state_size).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect(),
            value_net: (0..hidden_size).map(|_| {
                (0..state_size).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect(),
            state_size,
            action_size,
            gamma: 0.99,
            epsilon: 0.2,
            learning_rate: 0.0003,
        }
    }
    
    /// Select action using policy
    pub fn select_action(&self, state: &TradingState) -> TradingAction {
        let probs = self.policy(&state.features);
        
        // Sample from categorical distribution
        let mut rng = std::random::Random::new();
        let r = rng.uniform(0.0, 1.0);
        
        let mut cumsum = 0.0;
        for (i, &p) in probs.iter().enumerate() {
            cumsum += p;
            if r < cumsum {
                return match i {
                    0 => TradingAction::Hold,
                    1 => TradingAction::Buy(0.5),
                    2 => TradingAction::Sell(0.5),
                    _ => TradingAction::Hold,
                };
            }
        }
        
        TradingAction::Hold
    }
    
    /// Compute policy probabilities
    fn policy(&self, state: &[f64]) -> Vec<f64> {
        // Simple MLP policy
        let hidden: Vec<f64> = self.policy_net.iter().map(|weights| {
            let sum: f64 = state.iter().zip(weights.iter())
                .map(|(s, w)| s * w)
                .sum();
            tanh(sum)
        }).collect();
        
        // Softmax output
        let logits: Vec<f64> = (0..self.action_size).map(|i| {
            hidden.iter().enumerate()
                .map(|(j, &h)| h * (if i == j % self.action_size { 1.0 } else { 0.0 }))
                .sum()
        }).collect();
        
        let max_logit = logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let exp_sum: f64 = logits.iter().map(|&l| exp(l - max_logit)).sum();
        
        logits.iter().map(|&l| exp(l - max_logit) / exp_sum).collect()
    }
    
    /// Estimate state value
    pub fn value(&self, state: &[f64]) -> f64 {
        let hidden: Vec<f64> = self.value_net.iter().map(|weights| {
            let sum: f64 = state.iter().zip(weights.iter())
                .map(|(s, w)| s * w)
                .sum();
            tanh(sum)
        }).collect();
        
        hidden.iter().sum()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENSEMBLE MODELS
// ═══════════════════════════════════════════════════════════════════════════════

/// Ensemble model with dynamic weighting
pub struct EnsembleModel {
    models: Vec<Box<dyn Predictor>>,
    weights: Vec<f64>,
    performance_history: VecDeque<Vec<f64>>,
}

pub trait Predictor: Send + Sync {
    fn predict(&self, features: &[f64]) -> f64;
    fn name(&self) -> &str;
}

impl EnsembleModel {
    pub fn new() -> Self {
        EnsembleModel {
            models: Vec::new(),
            weights: Vec::new(),
            performance_history: VecDeque::with_capacity(100),
        }
    }
    
    pub fn add_model(&mut self, model: Box<dyn Predictor>, initial_weight: f64) {
        self.models.push(model);
        self.weights.push(initial_weight);
        self.normalize_weights();
    }
    
    fn normalize_weights(&mut self) {
        let sum: f64 = self.weights.iter().sum();
        if sum > 0.0 {
            for w in &mut self.weights {
                *w /= sum;
            }
        }
    }
    
    /// Make weighted prediction
    pub fn predict(&self, features: &[f64]) -> f64 {
        self.models.iter()
            .zip(self.weights.iter())
            .map(|(m, w)| m.predict(features) * w)
            .sum()
    }
    
    /// Update weights based on recent performance
    pub fn update_weights(&mut self, actual: f64, features: &[f64]) {
        let predictions: Vec<f64> = self.models.iter()
            .map(|m| m.predict(features))
            .collect();
        
        let errors: Vec<f64> = predictions.iter()
            .map(|p| (p - actual).abs())
            .collect();
        
        self.performance_history.push_back(errors.clone());
        if self.performance_history.len() > 100 {
            self.performance_history.pop_front();
        }
        
        // Update weights inversely proportional to average error
        let mut avg_errors = vec![0.0; self.models.len()];
        for history in &self.performance_history {
            for (i, &error) in history.iter().enumerate() {
                avg_errors[i] += error;
            }
        }
        
        let n = self.performance_history.len() as f64;
        for (i, w) in self.weights.iter_mut().enumerate() {
            let avg_error = avg_errors[i] / n;
            *w = 1.0 / (avg_error + 0.001);
        }
        
        self.normalize_weights();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WALK-FORWARD VALIDATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Walk-forward validation framework
pub struct WalkForwardValidator {
    train_size: usize,
    test_size: usize,
    step_size: usize,
}

#[derive(Debug, Clone)]
pub struct ValidationResult {
    pub fold: usize,
    pub train_start: usize,
    pub train_end: usize,
    pub test_start: usize,
    pub test_end: usize,
    pub train_score: f64,
    pub test_score: f64,
}

impl WalkForwardValidator {
    pub fn new(train_size: usize, test_size: usize, step_size: usize) -> Self {
        WalkForwardValidator { train_size, test_size, step_size }
    }
    
    /// Generate train/test splits
    pub fn splits(&self, data_size: usize) -> Vec<(std::ops::Range<usize>, std::ops::Range<usize>)> {
        let mut splits = Vec::new();
        let mut start = 0;
        
        while start + self.train_size + self.test_size <= data_size {
            let train_range = start..(start + self.train_size);
            let test_range = (start + self.train_size)..(start + self.train_size + self.test_size);
            
            splits.push((train_range, test_range));
            start += self.step_size;
        }
        
        splits
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GRU NETWORK (Gated Recurrent Unit)
// ═══════════════════════════════════════════════════════════════════════════════

/// Gated Recurrent Unit cell - simpler alternative to LSTM
pub struct GRUCell {
    input_size: usize,
    hidden_size: usize,

    // Weight matrices
    w_ir: Vec<Vec<f64>>, w_hr: Vec<Vec<f64>>, b_r: Vec<f64>,  // Reset gate
    w_iz: Vec<Vec<f64>>, w_hz: Vec<Vec<f64>>, b_z: Vec<f64>,  // Update gate
    w_in: Vec<Vec<f64>>, w_hn: Vec<Vec<f64>>, b_n: Vec<f64>,  // New gate
}

impl GRUCell {
    pub fn new(input_size: usize, hidden_size: usize) -> Self {
        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / (input_size + hidden_size) as f64);

        let init_weight = |rows: usize, cols: usize| -> Vec<Vec<f64>> {
            (0..rows).map(|_| {
                (0..cols).map(|_| rng.gaussian(0.0, scale)).collect()
            }).collect()
        };

        GRUCell {
            input_size,
            hidden_size,
            w_ir: init_weight(hidden_size, input_size),
            w_hr: init_weight(hidden_size, hidden_size),
            b_r: vec![0.0; hidden_size],
            w_iz: init_weight(hidden_size, input_size),
            w_hz: init_weight(hidden_size, hidden_size),
            b_z: vec![0.0; hidden_size],
            w_in: init_weight(hidden_size, input_size),
            w_hn: init_weight(hidden_size, hidden_size),
            b_n: vec![0.0; hidden_size],
        }
    }

    pub fn forward(&self, x: &[f64], h_prev: &[f64]) -> Vec<f64> {
        let h = self.hidden_size;

        // Reset gate: r_t = sigmoid(W_ir * x + W_hr * h_prev + b_r)
        let r_t = self.sigmoid(&self.gate_output(&self.w_ir, &self.w_hr, &self.b_r, x, h_prev));

        // Update gate: z_t = sigmoid(W_iz * x + W_hz * h_prev + b_z)
        let z_t = self.sigmoid(&self.gate_output(&self.w_iz, &self.w_hz, &self.b_z, x, h_prev));

        // New gate with reset: n_t = tanh(W_in * x + W_hn * (r_t * h_prev) + b_n)
        let r_h: Vec<f64> = (0..h).map(|i| r_t[i] * h_prev[i]).collect();
        let n_t = self.tanh_vec(&self.gate_output(&self.w_in, &self.w_hn, &self.b_n, x, &r_h));

        // Hidden state: h_t = (1 - z_t) * n_t + z_t * h_prev
        (0..h).map(|i| (1.0 - z_t[i]) * n_t[i] + z_t[i] * h_prev[i]).collect()
    }

    fn gate_output(&self, w_i: &[Vec<f64>], w_h: &[Vec<f64>], b: &[f64], x: &[f64], h: &[f64]) -> Vec<f64> {
        let size = b.len();
        let mut output = vec![0.0; size];

        for i in 0..size {
            output[i] = b[i];
            for j in 0..x.len().min(w_i[i].len()) {
                output[i] += w_i[i][j] * x[j];
            }
            for j in 0..h.len().min(w_h[i].len()) {
                output[i] += w_h[i][j] * h[j];
            }
        }
        output
    }

    fn sigmoid(&self, x: &[f64]) -> Vec<f64> {
        x.iter().map(|&v| 1.0 / (1.0 + exp(-v.clamp(-50.0, 50.0)))).collect()
    }

    fn tanh_vec(&self, x: &[f64]) -> Vec<f64> {
        x.iter().map(|&v| tanh(v)).collect()
    }
}

/// GRU-based predictor for time series
pub struct GRUPredictor {
    layers: Vec<GRUCell>,
    output_weights: Vec<Vec<f64>>,
    output_bias: Vec<f64>,
}

impl GRUPredictor {
    pub fn new(input_size: usize, hidden_sizes: &[usize], output_size: usize) -> Self {
        let mut layers = Vec::new();
        let mut prev_size = input_size;

        for &hidden_size in hidden_sizes {
            layers.push(GRUCell::new(prev_size, hidden_size));
            prev_size = hidden_size;
        }

        let mut rng = std::random::Random::new();
        let scale = sqrt(2.0 / prev_size as f64);

        GRUPredictor {
            layers,
            output_weights: (0..output_size)
                .map(|_| (0..prev_size).map(|_| rng.gaussian(0.0, scale)).collect())
                .collect(),
            output_bias: vec![0.0; output_size],
        }
    }

    pub fn predict(&self, sequence: &[Vec<f64>]) -> Vec<f64> {
        let mut hidden_states: Vec<Vec<f64>> = self.layers.iter()
            .map(|l| vec![0.0; l.hidden_size])
            .collect();

        for x in sequence {
            let mut current = x.clone();
            for (i, layer) in self.layers.iter().enumerate() {
                let h = layer.forward(&current, &hidden_states[i]);
                hidden_states[i] = h.clone();
                current = h;
            }
        }

        let final_h = &hidden_states[self.layers.len() - 1];
        let mut output = self.output_bias.clone();
        for i in 0..output.len() {
            for j in 0..final_h.len() {
                output[i] += self.output_weights[i][j] * final_h[j];
            }
        }
        output
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// A2C (Advantage Actor-Critic) AGENT
// ═══════════════════════════════════════════════════════════════════════════════

/// A2C Agent for trading
pub struct A2CAgent {
    actor_net: MLP,
    critic_net: MLP,
    gamma: f64,
    entropy_coef: f64,
    value_coef: f64,
    learning_rate: f64,
}

/// Simple Multi-Layer Perceptron
pub struct MLP {
    weights: Vec<Vec<Vec<f64>>>,
    biases: Vec<Vec<f64>>,
}

impl MLP {
    pub fn new(layer_sizes: &[usize]) -> Self {
        let mut rng = std::random::Random::new();
        let mut weights = Vec::new();
        let mut biases = Vec::new();

        for i in 0..layer_sizes.len() - 1 {
            let scale = sqrt(2.0 / layer_sizes[i] as f64);
            weights.push(
                (0..layer_sizes[i + 1])
                    .map(|_| (0..layer_sizes[i]).map(|_| rng.gaussian(0.0, scale)).collect())
                    .collect()
            );
            biases.push(vec![0.0; layer_sizes[i + 1]]);
        }

        MLP { weights, biases }
    }

    pub fn forward(&self, input: &[f64]) -> Vec<f64> {
        let mut current = input.to_vec();

        for (i, (w, b)) in self.weights.iter().zip(self.biases.iter()).enumerate() {
            let mut next = vec![0.0; w.len()];
            for j in 0..w.len() {
                next[j] = b[j];
                for k in 0..current.len().min(w[j].len()) {
                    next[j] += w[j][k] * current[k];
                }
                // ReLU for hidden layers, linear for output
                if i < self.weights.len() - 1 {
                    next[j] = next[j].max(0.0);
                }
            }
            current = next;
        }
        current
    }
}

impl A2CAgent {
    pub fn new(state_size: usize, action_size: usize) -> Self {
        A2CAgent {
            actor_net: MLP::new(&[state_size, 128, 64, action_size]),
            critic_net: MLP::new(&[state_size, 128, 64, 1]),
            gamma: 0.99,
            entropy_coef: 0.01,
            value_coef: 0.5,
            learning_rate: 0.0007,
        }
    }

    pub fn select_action(&self, state: &[f64]) -> (usize, f64) {
        let logits = self.actor_net.forward(state);
        let probs = self.softmax(&logits);

        let mut rng = std::random::Random::new();
        let r = rng.uniform(0.0, 1.0);
        let mut cumsum = 0.0;

        for (i, &p) in probs.iter().enumerate() {
            cumsum += p;
            if r < cumsum {
                return (i, probs[i].ln());
            }
        }
        (probs.len() - 1, probs.last().unwrap().ln())
    }

    pub fn estimate_value(&self, state: &[f64]) -> f64 {
        self.critic_net.forward(state)[0]
    }

    pub fn compute_advantage(&self, rewards: &[f64], values: &[f64], dones: &[bool]) -> Vec<f64> {
        let n = rewards.len();
        let mut advantages = vec![0.0; n];
        let mut next_value = 0.0;

        for i in (0..n).rev() {
            let mask = if dones[i] { 0.0 } else { 1.0 };
            let td_error = rewards[i] + self.gamma * next_value * mask - values[i];
            advantages[i] = td_error;
            next_value = values[i];
        }
        advantages
    }

    fn softmax(&self, logits: &[f64]) -> Vec<f64> {
        let max_l = logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let exp_sum: f64 = logits.iter().map(|&l| exp(l - max_l)).sum();
        logits.iter().map(|&l| exp(l - max_l) / exp_sum).collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SAC (Soft Actor-Critic) AGENT
// ═══════════════════════════════════════════════════════════════════════════════

/// SAC Agent for continuous action spaces
pub struct SACAgent {
    actor_net: MLP,
    critic_q1: MLP,
    critic_q2: MLP,
    target_q1: MLP,
    target_q2: MLP,
    log_alpha: f64,
    target_entropy: f64,
    gamma: f64,
    tau: f64,  // Soft update coefficient
    learning_rate: f64,
}

impl SACAgent {
    pub fn new(state_size: usize, action_size: usize) -> Self {
        let actor = MLP::new(&[state_size, 256, 256, action_size * 2]); // Mean and log_std
        let critic = || MLP::new(&[state_size + action_size, 256, 256, 1]);

        SACAgent {
            actor_net: actor,
            critic_q1: critic(),
            critic_q2: critic(),
            target_q1: critic(),
            target_q2: critic(),
            log_alpha: 0.0,
            target_entropy: -(action_size as f64),
            gamma: 0.99,
            tau: 0.005,
            learning_rate: 0.0003,
        }
    }

    /// Sample action with reparameterization trick
    pub fn select_action(&self, state: &[f64], deterministic: bool) -> Vec<f64> {
        let output = self.actor_net.forward(state);
        let action_size = output.len() / 2;

        let means = &output[..action_size];
        let log_stds = &output[action_size..];

        if deterministic {
            means.iter().map(|&m| tanh(m)).collect()
        } else {
            let mut rng = std::random::Random::new();
            means.iter().zip(log_stds.iter())
                .map(|(&mean, &log_std)| {
                    let std = exp(log_std.clamp(-20.0, 2.0));
                    let noise = rng.gaussian(0.0, 1.0);
                    tanh(mean + std * noise)
                })
                .collect()
        }
    }

    /// Compute Q-value
    pub fn q_value(&self, state: &[f64], action: &[f64]) -> (f64, f64) {
        let mut input = state.to_vec();
        input.extend(action);

        let q1 = self.critic_q1.forward(&input)[0];
        let q2 = self.critic_q2.forward(&input)[0];
        (q1, q2)
    }

    pub fn alpha(&self) -> f64 {
        exp(self.log_alpha)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// RISK METRICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Risk-adjusted performance metrics
pub struct RiskMetrics;

impl RiskMetrics {
    /// Sharpe Ratio: (mean return - risk-free rate) / std(returns)
    pub fn sharpe_ratio(returns: &[f64], risk_free_rate: f64, annualization: f64) -> f64 {
        if returns.is_empty() { return 0.0; }

        let mean = returns.iter().sum::<f64>() / returns.len() as f64;
        let variance = returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / returns.len() as f64;
        let std = sqrt(variance);

        if std < 1e-10 { return 0.0; }

        let excess_return = mean - risk_free_rate / annualization;
        (excess_return / std) * sqrt(annualization)
    }

    /// Sortino Ratio: excess return / downside deviation
    pub fn sortino_ratio(returns: &[f64], risk_free_rate: f64, annualization: f64) -> f64 {
        if returns.is_empty() { return 0.0; }

        let mean = returns.iter().sum::<f64>() / returns.len() as f64;
        let target = risk_free_rate / annualization;

        // Downside deviation (only negative returns)
        let downside_sq: f64 = returns.iter()
            .filter(|&&r| r < target)
            .map(|&r| (r - target).powi(2))
            .sum();
        let downside_dev = sqrt(downside_sq / returns.len() as f64);

        if downside_dev < 1e-10 { return 0.0; }

        ((mean - target) / downside_dev) * sqrt(annualization)
    }

    /// Calmar Ratio: annualized return / max drawdown
    pub fn calmar_ratio(returns: &[f64], annualization: f64) -> f64 {
        if returns.is_empty() { return 0.0; }

        let mean = returns.iter().sum::<f64>() / returns.len() as f64;
        let annualized_return = mean * annualization;

        let max_dd = Self::max_drawdown(returns);
        if max_dd.abs() < 1e-10 { return 0.0; }

        annualized_return / max_dd.abs()
    }

    /// Maximum Drawdown
    pub fn max_drawdown(returns: &[f64]) -> f64 {
        let mut peak = 1.0;
        let mut max_dd = 0.0;
        let mut cumulative = 1.0;

        for &r in returns {
            cumulative *= 1.0 + r;
            peak = peak.max(cumulative);
            let drawdown = (peak - cumulative) / peak;
            max_dd = max_dd.max(drawdown);
        }

        max_dd
    }

    /// Value at Risk (Historical)
    pub fn var_historical(returns: &[f64], confidence: f64) -> f64 {
        if returns.is_empty() { return 0.0; }

        let mut sorted = returns.to_vec();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let index = ((1.0 - confidence) * sorted.len() as f64).floor() as usize;
        sorted[index.min(sorted.len() - 1)]
    }

    /// Conditional VaR (Expected Shortfall)
    pub fn cvar(returns: &[f64], confidence: f64) -> f64 {
        if returns.is_empty() { return 0.0; }

        let mut sorted = returns.to_vec();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let cutoff_index = ((1.0 - confidence) * sorted.len() as f64).floor() as usize;
        let tail = &sorted[..cutoff_index.max(1)];

        tail.iter().sum::<f64>() / tail.len() as f64
    }

    /// Information Ratio: active return / tracking error
    pub fn information_ratio(returns: &[f64], benchmark: &[f64]) -> f64 {
        if returns.len() != benchmark.len() || returns.is_empty() { return 0.0; }

        let active_returns: Vec<f64> = returns.iter()
            .zip(benchmark.iter())
            .map(|(r, b)| r - b)
            .collect();

        let mean = active_returns.iter().sum::<f64>() / active_returns.len() as f64;
        let variance = active_returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / active_returns.len() as f64;
        let tracking_error = sqrt(variance);

        if tracking_error < 1e-10 { return 0.0; }
        mean / tracking_error * sqrt(252.0)
    }

    /// Omega Ratio: probability weighted gains / probability weighted losses
    pub fn omega_ratio(returns: &[f64], threshold: f64) -> f64 {
        let gains: f64 = returns.iter().filter(|&&r| r > threshold).map(|&r| r - threshold).sum();
        let losses: f64 = returns.iter().filter(|&&r| r < threshold).map(|&r| threshold - r).sum();

        if losses.abs() < 1e-10 { return f64::INFINITY; }
        gains / losses
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET REGIME DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Market regime types
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum MarketRegime {
    Bull,
    Bear,
    HighVolatility,
    LowVolatility,
    Trending,
    MeanReverting,
    Transitioning,
}

/// Hidden Markov Model for regime detection
pub struct HMMRegimeDetector {
    n_states: usize,
    transition_matrix: Vec<Vec<f64>>,
    emission_means: Vec<f64>,
    emission_stds: Vec<f64>,
    initial_probs: Vec<f64>,
}

impl HMMRegimeDetector {
    pub fn new(n_states: usize) -> Self {
        let uniform = 1.0 / n_states as f64;

        HMMRegimeDetector {
            n_states,
            transition_matrix: vec![vec![uniform; n_states]; n_states],
            emission_means: (0..n_states).map(|i| (i as f64 - 1.0) * 0.02).collect(),
            emission_stds: vec![0.01; n_states],
            initial_probs: vec![uniform; n_states],
        }
    }

    /// Fit HMM using Baum-Welch (EM algorithm)
    pub fn fit(&mut self, returns: &[f64], max_iters: usize) {
        let n = returns.len();
        if n < 2 { return; }

        for _ in 0..max_iters {
            // E-step: Forward-backward algorithm
            let (alpha, scale) = self.forward(returns);
            let beta = self.backward(returns, &scale);

            // Compute gamma (state probabilities) and xi (transition probabilities)
            let gamma = self.compute_gamma(&alpha, &beta);
            let xi = self.compute_xi(returns, &alpha, &beta, &scale);

            // M-step: Update parameters
            self.update_initial_probs(&gamma);
            self.update_transition_matrix(&gamma, &xi);
            self.update_emission_params(returns, &gamma);
        }
    }

    fn forward(&self, returns: &[f64]) -> (Vec<Vec<f64>>, Vec<f64>) {
        let n = returns.len();
        let mut alpha = vec![vec![0.0; self.n_states]; n];
        let mut scale = vec![0.0; n];

        // Initialize
        for j in 0..self.n_states {
            alpha[0][j] = self.initial_probs[j] * self.emission_prob(returns[0], j);
        }
        scale[0] = alpha[0].iter().sum();
        if scale[0] > 0.0 {
            for j in 0..self.n_states { alpha[0][j] /= scale[0]; }
        }

        // Forward pass
        for t in 1..n {
            for j in 0..self.n_states {
                let sum: f64 = (0..self.n_states)
                    .map(|i| alpha[t-1][i] * self.transition_matrix[i][j])
                    .sum();
                alpha[t][j] = sum * self.emission_prob(returns[t], j);
            }
            scale[t] = alpha[t].iter().sum();
            if scale[t] > 0.0 {
                for j in 0..self.n_states { alpha[t][j] /= scale[t]; }
            }
        }

        (alpha, scale)
    }

    fn backward(&self, returns: &[f64], scale: &[f64]) -> Vec<Vec<f64>> {
        let n = returns.len();
        let mut beta = vec![vec![1.0; self.n_states]; n];

        for t in (0..n-1).rev() {
            for i in 0..self.n_states {
                let sum: f64 = (0..self.n_states)
                    .map(|j| self.transition_matrix[i][j] * self.emission_prob(returns[t+1], j) * beta[t+1][j])
                    .sum();
                beta[t][i] = sum;
            }
            if scale[t+1] > 0.0 {
                for i in 0..self.n_states { beta[t][i] /= scale[t+1]; }
            }
        }

        beta
    }

    fn compute_gamma(&self, alpha: &[Vec<f64>], beta: &[Vec<f64>]) -> Vec<Vec<f64>> {
        let n = alpha.len();
        let mut gamma = vec![vec![0.0; self.n_states]; n];

        for t in 0..n {
            let sum: f64 = (0..self.n_states).map(|i| alpha[t][i] * beta[t][i]).sum();
            for i in 0..self.n_states {
                gamma[t][i] = if sum > 0.0 { alpha[t][i] * beta[t][i] / sum } else { 0.0 };
            }
        }
        gamma
    }

    fn compute_xi(&self, returns: &[f64], alpha: &[Vec<f64>], beta: &[Vec<f64>], scale: &[f64]) -> Vec<Vec<Vec<f64>>> {
        let n = returns.len();
        let mut xi = vec![vec![vec![0.0; self.n_states]; self.n_states]; n - 1];

        for t in 0..n-1 {
            let mut sum = 0.0;
            for i in 0..self.n_states {
                for j in 0..self.n_states {
                    xi[t][i][j] = alpha[t][i] * self.transition_matrix[i][j]
                        * self.emission_prob(returns[t+1], j) * beta[t+1][j];
                    sum += xi[t][i][j];
                }
            }
            if sum > 0.0 {
                for i in 0..self.n_states {
                    for j in 0..self.n_states {
                        xi[t][i][j] /= sum;
                    }
                }
            }
        }
        xi
    }

    fn update_initial_probs(&mut self, gamma: &[Vec<f64>]) {
        for i in 0..self.n_states {
            self.initial_probs[i] = gamma[0][i];
        }
    }

    fn update_transition_matrix(&mut self, gamma: &[Vec<f64>], xi: &[Vec<Vec<Vec<f64>>>]) {
        for i in 0..self.n_states {
            let gamma_sum: f64 = gamma[..gamma.len()-1].iter().map(|g| g[i]).sum();
            if gamma_sum > 0.0 {
                for j in 0..self.n_states {
                    let xi_sum: f64 = xi.iter().map(|x| x[i][j]).sum();
                    self.transition_matrix[i][j] = xi_sum / gamma_sum;
                }
            }
        }
    }

    fn update_emission_params(&mut self, returns: &[f64], gamma: &[Vec<f64>]) {
        for j in 0..self.n_states {
            let gamma_sum: f64 = gamma.iter().map(|g| g[j]).sum();
            if gamma_sum > 0.0 {
                // Update mean
                let weighted_sum: f64 = returns.iter()
                    .zip(gamma.iter())
                    .map(|(r, g)| r * g[j])
                    .sum();
                self.emission_means[j] = weighted_sum / gamma_sum;

                // Update std
                let weighted_sq: f64 = returns.iter()
                    .zip(gamma.iter())
                    .map(|(r, g)| (r - self.emission_means[j]).powi(2) * g[j])
                    .sum();
                self.emission_stds[j] = sqrt(weighted_sq / gamma_sum).max(0.001);
            }
        }
    }

    fn emission_prob(&self, x: f64, state: usize) -> f64 {
        let mean = self.emission_means[state];
        let std = self.emission_stds[state];
        let z = (x - mean) / std;
        exp(-0.5 * z * z) / (std * sqrt(2.0 * std::f64::consts::PI))
    }

    /// Detect current regime using Viterbi algorithm
    pub fn detect_regime(&self, returns: &[f64]) -> Vec<usize> {
        let n = returns.len();
        if n == 0 { return Vec::new(); }

        let mut v = vec![vec![0.0; self.n_states]; n];
        let mut path = vec![vec![0usize; self.n_states]; n];

        // Initialize
        for j in 0..self.n_states {
            v[0][j] = self.initial_probs[j].ln() + self.emission_prob(returns[0], j).max(1e-300).ln();
        }

        // Viterbi forward
        for t in 1..n {
            for j in 0..self.n_states {
                let (best_i, best_v) = (0..self.n_states)
                    .map(|i| (i, v[t-1][i] + self.transition_matrix[i][j].max(1e-300).ln()))
                    .max_by(|a, b| a.1.partial_cmp(&b.1).unwrap())
                    .unwrap();
                v[t][j] = best_v + self.emission_prob(returns[t], j).max(1e-300).ln();
                path[t][j] = best_i;
            }
        }

        // Backtrack
        let mut states = vec![0usize; n];
        states[n-1] = (0..self.n_states)
            .max_by(|&a, &b| v[n-1][a].partial_cmp(&v[n-1][b]).unwrap())
            .unwrap();

        for t in (0..n-1).rev() {
            states[t] = path[t+1][states[t+1]];
        }

        states
    }

    /// Interpret numeric state as market regime
    pub fn interpret_regime(&self, state: usize) -> MarketRegime {
        match state {
            0 => MarketRegime::Bear,
            1 => MarketRegime::LowVolatility,
            2 => MarketRegime::Bull,
            3 => MarketRegime::HighVolatility,
            _ => MarketRegime::Transitioning,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GRADIENT BOOSTING TREES (XGBoost-style)
// ═══════════════════════════════════════════════════════════════════════════════

/// Simple decision tree node
#[derive(Clone)]
pub struct TreeNode {
    pub feature_index: usize,
    pub threshold: f64,
    pub value: f64,  // Leaf value
    pub left: Option<Box<TreeNode>>,
    pub right: Option<Box<TreeNode>>,
}

/// Gradient Boosting for regression
pub struct GradientBoosting {
    trees: Vec<TreeNode>,
    learning_rate: f64,
    n_estimators: usize,
    max_depth: usize,
    min_samples_split: usize,
}

impl GradientBoosting {
    pub fn new(n_estimators: usize, learning_rate: f64, max_depth: usize) -> Self {
        GradientBoosting {
            trees: Vec::new(),
            learning_rate,
            n_estimators,
            max_depth,
            min_samples_split: 2,
        }
    }

    /// Fit the model
    pub fn fit(&mut self, features: &[Vec<f64>], targets: &[f64]) {
        if features.is_empty() || targets.is_empty() { return; }

        let n = targets.len();
        let mut predictions = vec![0.0; n];

        for _ in 0..self.n_estimators {
            // Compute residuals (negative gradient for MSE)
            let residuals: Vec<f64> = targets.iter()
                .zip(predictions.iter())
                .map(|(t, p)| t - p)
                .collect();

            // Fit tree to residuals
            let tree = self.build_tree(features, &residuals, 0);

            // Update predictions
            for i in 0..n {
                predictions[i] += self.learning_rate * self.tree_predict(&tree, &features[i]);
            }

            self.trees.push(tree);
        }
    }

    fn build_tree(&self, features: &[Vec<f64>], targets: &[f64], depth: usize) -> TreeNode {
        let n = targets.len();

        // Check stopping conditions
        if depth >= self.max_depth || n < self.min_samples_split {
            return TreeNode {
                feature_index: 0,
                threshold: 0.0,
                value: targets.iter().sum::<f64>() / n as f64,
                left: None,
                right: None,
            };
        }

        // Find best split
        let num_features = features[0].len();
        let mut best_gain = f64::NEG_INFINITY;
        let mut best_feature = 0;
        let mut best_threshold = 0.0;

        for f in 0..num_features {
            let mut values: Vec<f64> = features.iter().map(|x| x[f]).collect();
            values.sort_by(|a, b| a.partial_cmp(b).unwrap());
            values.dedup();

            for &threshold in &values {
                let (left_targets, right_targets): (Vec<f64>, Vec<f64>) = features.iter()
                    .zip(targets.iter())
                    .partition(|(x, _)| x[f] <= threshold)
                    .0.iter().map(|(_, t)| **t).collect::<Vec<_>>()
                    .into_iter()
                    .zip(
                        features.iter()
                            .zip(targets.iter())
                            .filter(|(x, _)| x[f] > threshold)
                            .map(|(_, t)| *t)
                    )
                    .unzip();

                let left_t: Vec<f64> = features.iter()
                    .zip(targets.iter())
                    .filter(|(x, _)| x[f] <= threshold)
                    .map(|(_, t)| *t)
                    .collect();
                let right_t: Vec<f64> = features.iter()
                    .zip(targets.iter())
                    .filter(|(x, _)| x[f] > threshold)
                    .map(|(_, t)| *t)
                    .collect();

                if left_t.is_empty() || right_t.is_empty() { continue; }

                let gain = self.information_gain(&left_t, &right_t, targets);
                if gain > best_gain {
                    best_gain = gain;
                    best_feature = f;
                    best_threshold = threshold;
                }
            }
        }

        // Check if no valid split found
        if best_gain <= 0.0 {
            return TreeNode {
                feature_index: 0,
                threshold: 0.0,
                value: targets.iter().sum::<f64>() / n as f64,
                left: None,
                right: None,
            };
        }

        // Split data
        let (left_features, left_targets): (Vec<Vec<f64>>, Vec<f64>) = features.iter()
            .zip(targets.iter())
            .filter(|(x, _)| x[best_feature] <= best_threshold)
            .map(|(x, t)| (x.clone(), *t))
            .unzip();

        let (right_features, right_targets): (Vec<Vec<f64>>, Vec<f64>) = features.iter()
            .zip(targets.iter())
            .filter(|(x, _)| x[best_feature] > best_threshold)
            .map(|(x, t)| (x.clone(), *t))
            .unzip();

        TreeNode {
            feature_index: best_feature,
            threshold: best_threshold,
            value: 0.0,
            left: Some(Box::new(self.build_tree(&left_features, &left_targets, depth + 1))),
            right: Some(Box::new(self.build_tree(&right_features, &right_targets, depth + 1))),
        }
    }

    fn information_gain(&self, left: &[f64], right: &[f64], parent: &[f64]) -> f64 {
        let parent_var = self.variance(parent);
        let left_var = self.variance(left);
        let right_var = self.variance(right);

        let n = parent.len() as f64;
        let n_left = left.len() as f64;
        let n_right = right.len() as f64;

        parent_var - (n_left / n) * left_var - (n_right / n) * right_var
    }

    fn variance(&self, values: &[f64]) -> f64 {
        if values.is_empty() { return 0.0; }
        let mean = values.iter().sum::<f64>() / values.len() as f64;
        values.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / values.len() as f64
    }

    fn tree_predict(&self, node: &TreeNode, features: &[f64]) -> f64 {
        if node.left.is_none() && node.right.is_none() {
            return node.value;
        }

        if features[node.feature_index] <= node.threshold {
            if let Some(ref left) = node.left {
                return self.tree_predict(left, features);
            }
        } else {
            if let Some(ref right) = node.right {
                return self.tree_predict(right, features);
            }
        }

        node.value
    }

    /// Predict target
    pub fn predict(&self, features: &[f64]) -> f64 {
        self.trees.iter()
            .map(|tree| self.learning_rate * self.tree_predict(tree, features))
            .sum()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRANSFORMER MODELS
// ═══════════════════════════════════════════════════════════════════════════════

module transformer {
    use super::*;

    /// Multi-head self-attention
    pub struct TransformerAttention {
        pub num_heads: i32,
        pub head_dim: i32,
        pub embed_dim: i32,
        pub w_query: Vec<Vec<f64>>,
        pub w_key: Vec<Vec<f64>>,
        pub w_value: Vec<Vec<f64>>,
        pub w_out: Vec<Vec<f64>>,
    }

    impl TransformerAttention {
        pub fn new(embed_dim: i32, num_heads: i32) -> Self {
            let head_dim = embed_dim / num_heads;
            Self {
                num_heads,
                head_dim,
                embed_dim,
                w_query: random::xavier_init(embed_dim as usize, embed_dim as usize),
                w_key: random::xavier_init(embed_dim as usize, embed_dim as usize),
                w_value: random::xavier_init(embed_dim as usize, embed_dim as usize),
                w_out: random::xavier_init(embed_dim as usize, embed_dim as usize),
            }
        }

        pub fn attention(&self, query: &[Vec<f64>], key: &[Vec<f64>],
                         value: &[Vec<f64>], mask: Option<&[Vec<bool>]>) -> Vec<Vec<f64>> {
            let seq_len = query.len();
            let scale = (self.head_dim as f64).sqrt();

            let mut scores = vec![vec![0.0; seq_len]; seq_len];
            for i in 0..seq_len {
                for j in 0..seq_len {
                    let mut dot = 0.0;
                    for k in 0..self.embed_dim as usize {
                        dot += query[i][k] * key[j][k];
                    }
                    scores[i][j] = dot / scale;
                }
            }

            if let Some(m) = mask {
                for i in 0..seq_len {
                    for j in 0..seq_len {
                        if m[i][j] {
                            scores[i][j] = f64::NEG_INFINITY;
                        }
                    }
                }
            }

            for i in 0..seq_len {
                let max_score = scores[i].iter().cloned().fold(f64::NEG_INFINITY, f64::max);
                let exp_sum: f64 = scores[i].iter().map(|s| (s - max_score).exp()).sum();
                for j in 0..seq_len {
                    scores[i][j] = ((scores[i][j] - max_score).exp()) / exp_sum;
                }
            }

            let mut output = vec![vec![0.0; self.embed_dim as usize]; seq_len];
            for i in 0..seq_len {
                for j in 0..seq_len {
                    for k in 0..self.embed_dim as usize {
                        output[i][k] += scores[i][j] * value[j][k];
                    }
                }
            }

            output
        }

        pub fn forward(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let q = matrix::matmul(x, &self.w_query);
            let k = matrix::matmul(x, &self.w_key);
            let v = matrix::matmul(x, &self.w_value);

            let attn_output = self.attention(&q, &k, &v, None);
            matrix::matmul(&attn_output, &self.w_out)
        }
    }

    /// Transformer encoder layer
    pub struct TransformerEncoderLayer {
        pub attention: TransformerAttention,
        pub ff_hidden: i32,
        pub embed_dim: i32,
        pub w_ff1: Vec<Vec<f64>>,
        pub w_ff2: Vec<Vec<f64>>,
        pub layer_norm1: LayerNorm,
        pub layer_norm2: LayerNorm,
        pub dropout: f64,
    }

    impl TransformerEncoderLayer {
        pub fn new(embed_dim: i32, num_heads: i32, ff_hidden: i32) -> Self {
            Self {
                attention: TransformerAttention::new(embed_dim, num_heads),
                ff_hidden,
                embed_dim,
                w_ff1: random::xavier_init(embed_dim as usize, ff_hidden as usize),
                w_ff2: random::xavier_init(ff_hidden as usize, embed_dim as usize),
                layer_norm1: LayerNorm::new(embed_dim as usize),
                layer_norm2: LayerNorm::new(embed_dim as usize),
                dropout: 0.1,
            }
        }

        pub fn forward(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let attn_out = self.attention.forward(x);
            let mut residual1: Vec<Vec<f64>> = x.iter()
                .zip(&attn_out)
                .map(|(a, b)| a.iter().zip(b).map(|(x, y)| x + y).collect())
                .collect();
            residual1 = self.layer_norm1.forward(&residual1);

            let ff1 = matrix::matmul(&residual1, &self.w_ff1);
            let ff1_relu: Vec<Vec<f64>> = ff1.iter()
                .map(|row| row.iter().map(|&v| v.max(0.0)).collect())
                .collect();
            let ff2 = matrix::matmul(&ff1_relu, &self.w_ff2);

            let residual2: Vec<Vec<f64>> = residual1.iter()
                .zip(&ff2)
                .map(|(a, b)| a.iter().zip(b).map(|(x, y)| x + y).collect())
                .collect();
            self.layer_norm2.forward(&residual2)
        }
    }

    /// Layer normalization
    pub struct LayerNorm {
        pub dim: usize,
        pub gamma: Vec<f64>,
        pub beta: Vec<f64>,
        pub eps: f64,
    }

    impl LayerNorm {
        pub fn new(dim: usize) -> Self {
            Self {
                dim,
                gamma: vec![1.0; dim],
                beta: vec![0.0; dim],
                eps: 1e-6,
            }
        }

        pub fn forward(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            x.iter().map(|row| {
                let mean: f64 = row.iter().sum::<f64>() / row.len() as f64;
                let var: f64 = row.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / row.len() as f64;
                let std = (var + self.eps).sqrt();

                row.iter().enumerate()
                    .map(|(i, v)| self.gamma[i] * (v - mean) / std + self.beta[i])
                    .collect()
            }).collect()
        }
    }

    /// Temporal Fusion Transformer for time series
    pub struct TemporalFusionTransformer {
        pub encoder_layers: Vec<TransformerEncoderLayer>,
        pub static_encoder: Vec<Vec<f64>>,
        pub temporal_encoder: Vec<Vec<f64>>,
        pub gated_residual: GatedResidualNetwork,
        pub output_layer: Vec<Vec<f64>>,
        pub embed_dim: i32,
        pub num_quantiles: i32,
    }

    impl TemporalFusionTransformer {
        pub fn new(input_dim: i32, embed_dim: i32, num_heads: i32,
                   num_layers: i32, num_quantiles: i32) -> Self {
            let mut layers = Vec::new();
            for _ in 0..num_layers {
                layers.push(TransformerEncoderLayer::new(embed_dim, num_heads, embed_dim * 4));
            }

            Self {
                encoder_layers: layers,
                static_encoder: random::xavier_init(input_dim as usize, embed_dim as usize),
                temporal_encoder: random::xavier_init(input_dim as usize, embed_dim as usize),
                gated_residual: GatedResidualNetwork::new(embed_dim as usize),
                output_layer: random::xavier_init(embed_dim as usize, num_quantiles as usize),
                embed_dim,
                num_quantiles,
            }
        }

        pub fn forward(&self, temporal: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let encoded = matrix::matmul(temporal, &self.temporal_encoder);
            let mut x = encoded;

            for layer in &self.encoder_layers {
                x = layer.forward(&x);
            }

            let gated = self.gated_residual.forward(&x);
            matrix::matmul(&gated, &self.output_layer)
        }
    }

    /// Gated Residual Network
    pub struct GatedResidualNetwork {
        pub w1: Vec<Vec<f64>>,
        pub w2: Vec<Vec<f64>>,
        pub w_gate: Vec<Vec<f64>>,
        pub dim: usize,
    }

    impl GatedResidualNetwork {
        pub fn new(dim: usize) -> Self {
            Self {
                w1: random::xavier_init(dim, dim),
                w2: random::xavier_init(dim, dim),
                w_gate: random::xavier_init(dim, dim),
                dim,
            }
        }

        pub fn forward(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let h1 = matrix::matmul(x, &self.w1);
            let h1_elu: Vec<Vec<f64>> = h1.iter()
                .map(|row| row.iter().map(|&v| if v > 0.0 { v } else { v.exp() - 1.0 }).collect())
                .collect();
            let h2 = matrix::matmul(&h1_elu, &self.w2);

            let gate = matrix::matmul(x, &self.w_gate);
            let gate_sigmoid: Vec<Vec<f64>> = gate.iter()
                .map(|row| row.iter().map(|&v| 1.0 / (1.0 + (-v).exp())).collect())
                .collect();

            x.iter().zip(&h2).zip(&gate_sigmoid)
                .map(|((xi, hi), gi)| {
                    xi.iter().zip(hi).zip(gi)
                        .map(|((&x, &h), &g)| g * h + (1.0 - g) * x)
                        .collect()
                })
                .collect()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED STRATEGIES
// ═══════════════════════════════════════════════════════════════════════════════

module strategies {
    use super::*;

    /// Statistical arbitrage strategy
    pub struct StatArbStrategy {
        pub pairs: Vec<(String, String, f64)>,
        pub lookback: i32,
        pub entry_zscore: f64,
        pub exit_zscore: f64,
        pub position_size: f64,
        pub prices: HashMap<String, Vec<f64>>,
    }

    impl StatArbStrategy {
        pub fn new(entry_z: f64, exit_z: f64) -> Self {
            Self {
                pairs: Vec::new(),
                lookback: 60,
                entry_zscore: entry_z,
                exit_zscore: exit_z,
                position_size: 1.0,
                prices: HashMap::new(),
            }
        }

        pub fn add_pair(&mut self, sym1: &str, sym2: &str, hedge_ratio: f64) {
            self.pairs.push((sym1.to_string(), sym2.to_string(), hedge_ratio));
        }

        pub fn update_price(&mut self, symbol: &str, price: f64) {
            self.prices.entry(symbol.to_string())
                .or_insert_with(Vec::new)
                .push(price);
        }

        pub fn calculate_spread(&self, sym1: &str, sym2: &str, hedge_ratio: f64) -> Option<f64> {
            let prices1 = self.prices.get(sym1)?;
            let prices2 = self.prices.get(sym2)?;

            if prices1.is_empty() || prices2.is_empty() {
                return None;
            }

            let p1 = *prices1.last()?;
            let p2 = *prices2.last()?;

            Some(p1 - hedge_ratio * p2)
        }

        pub fn calculate_zscore(&self, sym1: &str, sym2: &str, hedge_ratio: f64) -> Option<f64> {
            let prices1 = self.prices.get(sym1)?;
            let prices2 = self.prices.get(sym2)?;

            if prices1.len() < self.lookback as usize || prices2.len() < self.lookback as usize {
                return None;
            }

            let spreads: Vec<f64> = prices1.iter().rev()
                .take(self.lookback as usize)
                .zip(prices2.iter().rev().take(self.lookback as usize))
                .map(|(p1, p2)| p1 - hedge_ratio * p2)
                .collect();

            let mean: f64 = spreads.iter().sum::<f64>() / spreads.len() as f64;
            let std: f64 = (spreads.iter().map(|s| (s - mean).powi(2)).sum::<f64>()
                / spreads.len() as f64).sqrt();

            let current_spread = self.calculate_spread(sym1, sym2, hedge_ratio)?;
            Some((current_spread - mean) / std)
        }

        pub fn generate_signals(&self) -> Vec<StatArbSignal> {
            let mut signals = Vec::new();

            for (sym1, sym2, hedge_ratio) in &self.pairs {
                if let Some(zscore) = self.calculate_zscore(sym1, sym2, *hedge_ratio) {
                    if zscore > self.entry_zscore {
                        signals.push(StatArbSignal {
                            pair: (sym1.clone(), sym2.clone()),
                            zscore,
                            action: StatArbAction::Short,
                            size: self.position_size,
                        });
                    } else if zscore < -self.entry_zscore {
                        signals.push(StatArbSignal {
                            pair: (sym1.clone(), sym2.clone()),
                            zscore,
                            action: StatArbAction::Long,
                            size: self.position_size,
                        });
                    } else if zscore.abs() < self.exit_zscore {
                        signals.push(StatArbSignal {
                            pair: (sym1.clone(), sym2.clone()),
                            zscore,
                            action: StatArbAction::Exit,
                            size: 0.0,
                        });
                    }
                }
            }

            signals
        }
    }

    pub struct StatArbSignal {
        pub pair: (String, String),
        pub zscore: f64,
        pub action: StatArbAction,
        pub size: f64,
    }

    pub enum StatArbAction {
        Long,
        Short,
        Exit,
    }

    /// Mean reversion strategy
    pub struct MeanReversionStrategy {
        pub symbols: Vec<String>,
        pub lookback: i32,
        pub entry_threshold: f64,
        pub exit_threshold: f64,
        pub prices: HashMap<String, Vec<f64>>,
        pub positions: HashMap<String, f64>,
    }

    impl MeanReversionStrategy {
        pub fn new(lookback: i32, entry: f64, exit: f64) -> Self {
            Self {
                symbols: Vec::new(),
                lookback,
                entry_threshold: entry,
                exit_threshold: exit,
                prices: HashMap::new(),
                positions: HashMap::new(),
            }
        }

        pub fn update_price(&mut self, symbol: &str, price: f64) {
            self.prices.entry(symbol.to_string())
                .or_insert_with(Vec::new)
                .push(price);
        }

        pub fn bollinger_bands(&self, symbol: &str) -> Option<(f64, f64, f64)> {
            let prices = self.prices.get(symbol)?;
            if prices.len() < self.lookback as usize {
                return None;
            }

            let recent: Vec<f64> = prices.iter().rev()
                .take(self.lookback as usize)
                .cloned()
                .collect();

            let sma: f64 = recent.iter().sum::<f64>() / recent.len() as f64;
            let std: f64 = (recent.iter().map(|p| (p - sma).powi(2)).sum::<f64>()
                / recent.len() as f64).sqrt();

            let upper = sma + 2.0 * std;
            let lower = sma - 2.0 * std;

            Some((lower, sma, upper))
        }

        pub fn generate_signal(&self, symbol: &str) -> Option<MeanRevSignal> {
            let prices = self.prices.get(symbol)?;
            let current = *prices.last()?;
            let (lower, mid, upper) = self.bollinger_bands(symbol)?;

            let pct_b = (current - lower) / (upper - lower);

            if pct_b < self.entry_threshold {
                Some(MeanRevSignal {
                    symbol: symbol.to_string(),
                    action: MeanRevAction::Buy,
                    strength: (self.entry_threshold - pct_b) / self.entry_threshold,
                })
            } else if pct_b > 1.0 - self.entry_threshold {
                Some(MeanRevSignal {
                    symbol: symbol.to_string(),
                    action: MeanRevAction::Sell,
                    strength: (pct_b - (1.0 - self.entry_threshold)) / self.entry_threshold,
                })
            } else if pct_b > 0.5 - self.exit_threshold && pct_b < 0.5 + self.exit_threshold {
                Some(MeanRevSignal {
                    symbol: symbol.to_string(),
                    action: MeanRevAction::Exit,
                    strength: 0.0,
                })
            } else {
                None
            }
        }
    }

    pub struct MeanRevSignal {
        pub symbol: String,
        pub action: MeanRevAction,
        pub strength: f64,
    }

    pub enum MeanRevAction {
        Buy,
        Sell,
        Exit,
    }

    /// Momentum strategy with regime detection
    pub struct MomentumRegimeStrategy {
        pub symbols: Vec<String>,
        pub fast_period: i32,
        pub slow_period: i32,
        pub regime_lookback: i32,
        pub prices: HashMap<String, Vec<f64>>,
        pub current_regime: MomentumRegime,
    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum MomentumRegime {
        Trending,
        MeanReverting,
        HighVolatility,
        LowVolatility,
    }

    impl MomentumRegimeStrategy {
        pub fn new(fast: i32, slow: i32) -> Self {
            Self {
                symbols: Vec::new(),
                fast_period: fast,
                slow_period: slow,
                regime_lookback: 60,
                prices: HashMap::new(),
                current_regime: MomentumRegime::Trending,
            }
        }

        pub fn detect_regime(&self, symbol: &str) -> MomentumRegime {
            let prices = match self.prices.get(symbol) {
                Some(p) => p,
                None => return MomentumRegime::Trending,
            };

            if prices.len() < self.regime_lookback as usize {
                return MomentumRegime::Trending;
            }

            let returns: Vec<f64> = prices.windows(2)
                .map(|w| (w[1] / w[0]).ln())
                .collect();

            let recent_returns: Vec<f64> = returns.iter()
                .rev()
                .take(self.regime_lookback as usize)
                .cloned()
                .collect();

            let mean: f64 = recent_returns.iter().sum::<f64>() / recent_returns.len() as f64;
            let variance: f64 = recent_returns.iter()
                .map(|r| (r - mean).powi(2))
                .sum::<f64>() / recent_returns.len() as f64;
            let volatility = variance.sqrt() * (252.0_f64).sqrt();

            let mut autocorr = 0.0;
            for i in 1..recent_returns.len() {
                autocorr += (recent_returns[i] - mean) * (recent_returns[i - 1] - mean);
            }
            autocorr /= (recent_returns.len() - 1) as f64 * variance;

            if volatility > 0.30 {
                MomentumRegime::HighVolatility
            } else if volatility < 0.10 {
                MomentumRegime::LowVolatility
            } else if autocorr > 0.1 {
                MomentumRegime::Trending
            } else if autocorr < -0.1 {
                MomentumRegime::MeanReverting
            } else {
                MomentumRegime::Trending
            }
        }

        pub fn generate_signal(&self, symbol: &str) -> Option<MomentumSignal> {
            let prices = self.prices.get(symbol)?;
            if prices.len() < self.slow_period as usize {
                return None;
            }

            let fast_ma: f64 = prices.iter().rev()
                .take(self.fast_period as usize)
                .sum::<f64>() / self.fast_period as f64;

            let slow_ma: f64 = prices.iter().rev()
                .take(self.slow_period as usize)
                .sum::<f64>() / self.slow_period as f64;

            let regime = self.detect_regime(symbol);
            let momentum = (fast_ma - slow_ma) / slow_ma;

            let threshold = match regime {
                MomentumRegime::Trending => 0.01,
                MomentumRegime::MeanReverting => 0.03,
                MomentumRegime::HighVolatility => 0.02,
                MomentumRegime::LowVolatility => 0.005,
            };

            if momentum > threshold {
                Some(MomentumSignal {
                    symbol: symbol.to_string(),
                    action: MomentumAction::Buy,
                    momentum,
                    regime,
                })
            } else if momentum < -threshold {
                Some(MomentumSignal {
                    symbol: symbol.to_string(),
                    action: MomentumAction::Sell,
                    momentum,
                    regime,
                })
            } else {
                None
            }
        }
    }

    pub struct MomentumSignal {
        pub symbol: String,
        pub action: MomentumAction,
        pub momentum: f64,
        pub regime: MomentumRegime,
    }

    pub enum MomentumAction {
        Buy,
        Sell,
    }

    /// Factor-based strategy
    pub struct FactorStrategy {
        pub factors: Vec<Factor>,
        pub universe: Vec<String>,
        pub factor_weights: HashMap<String, f64>,
        pub rebalance_freq: i32,
        pub last_rebalance: i64,
    }

    pub struct Factor {
        pub name: String,
        pub scores: HashMap<String, f64>,
    }

    impl FactorStrategy {
        pub fn new() -> Self {
            Self {
                factors: Vec::new(),
                universe: Vec::new(),
                factor_weights: HashMap::new(),
                rebalance_freq: 20,
                last_rebalance: 0,
            }
        }

        pub fn add_factor(&mut self, name: &str, weight: f64) {
            self.factor_weights.insert(name.to_string(), weight);
            self.factors.push(Factor {
                name: name.to_string(),
                scores: HashMap::new(),
            });
        }

        pub fn update_factor_score(&mut self, factor_name: &str, symbol: &str, score: f64) {
            for factor in &mut self.factors {
                if factor.name == factor_name {
                    factor.scores.insert(symbol.to_string(), score);
                }
            }
        }

        pub fn composite_score(&self, symbol: &str) -> f64 {
            let mut total = 0.0;
            let mut weight_sum = 0.0;

            for factor in &self.factors {
                if let Some(&score) = factor.scores.get(symbol) {
                    let weight = self.factor_weights.get(&factor.name).copied().unwrap_or(1.0);
                    total += score * weight;
                    weight_sum += weight;
                }
            }

            if weight_sum > 0.0 { total / weight_sum } else { 0.0 }
        }

        pub fn rank_universe(&self) -> Vec<(String, f64)> {
            let mut ranked: Vec<(String, f64)> = self.universe.iter()
                .map(|s| (s.clone(), self.composite_score(s)))
                .collect();

            ranked.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
            ranked
        }

        pub fn generate_portfolio(&self, top_n: usize) -> HashMap<String, f64> {
            let ranked = self.rank_universe();
            let mut weights = HashMap::new();

            let selected: Vec<_> = ranked.into_iter().take(top_n).collect();
            let weight_per = 1.0 / top_n as f64;

            for (symbol, _) in selected {
                weights.insert(symbol, weight_per);
            }

            weights
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GENERATIVE ADVERSARIAL NETWORKS FOR MARKET SIMULATION
// ═══════════════════════════════════════════════════════════════════════════════

pub mod gan_market {
    use super::*;

    /// GAN Generator for synthetic market data
    pub struct MarketGenerator {
        pub latent_dim: usize,
        pub output_dim: usize,
        pub hidden_layers: Vec<usize>,
        pub weights: Vec<Vec<Vec<f64>>>,
        pub biases: Vec<Vec<f64>>,
        pub batch_norm: bool,
    }

    impl MarketGenerator {
        pub fn new(latent_dim: usize, output_dim: usize, hidden: &[usize]) -> Self {
            let mut hidden_layers = hidden.to_vec();
            hidden_layers.push(output_dim);

            let mut weights = Vec::new();
            let mut biases = Vec::new();
            let mut prev_size = latent_dim;

            for &size in &hidden_layers {
                let scale = (2.0 / prev_size as f64).sqrt();
                let w: Vec<Vec<f64>> = (0..prev_size)
                    .map(|_| (0..size).map(|_| (rand_f64() - 0.5) * scale).collect())
                    .collect();
                let b = vec![0.0; size];
                weights.push(w);
                biases.push(b);
                prev_size = size;
            }

            Self {
                latent_dim,
                output_dim,
                hidden_layers,
                weights,
                biases,
                batch_norm: true,
            }
        }

        pub fn generate(&self, noise: &[f64]) -> Vec<f64> {
            let mut x = noise.to_vec();

            for i in 0..self.weights.len() {
                let mut out = self.biases[i].clone();

                for j in 0..x.len() {
                    for k in 0..out.len() {
                        out[k] += x[j] * self.weights[i][j][k];
                    }
                }

                // Activation (LeakyReLU for hidden, tanh for output)
                if i < self.weights.len() - 1 {
                    for v in &mut out {
                        *v = if *v > 0.0 { *v } else { 0.01 * *v };
                    }
                } else {
                    for v in &mut out {
                        *v = v.tanh();
                    }
                }

                x = out;
            }

            x
        }

        pub fn generate_batch(&self, batch_size: usize) -> Vec<Vec<f64>> {
            (0..batch_size)
                .map(|_| {
                    let noise: Vec<f64> = (0..self.latent_dim).map(|_| randn()).collect();
                    self.generate(&noise)
                })
                .collect()
        }
    }

    /// GAN Discriminator for real/fake classification
    pub struct MarketDiscriminator {
        pub input_dim: usize,
        pub hidden_layers: Vec<usize>,
        pub weights: Vec<Vec<Vec<f64>>>,
        pub biases: Vec<Vec<f64>>,
        pub dropout_rate: f64,
    }

    impl MarketDiscriminator {
        pub fn new(input_dim: usize, hidden: &[usize]) -> Self {
            let mut all_layers = hidden.to_vec();
            all_layers.push(1); // Binary output

            let mut weights = Vec::new();
            let mut biases = Vec::new();
            let mut prev_size = input_dim;

            for &size in &all_layers {
                let scale = (2.0 / prev_size as f64).sqrt();
                let w: Vec<Vec<f64>> = (0..prev_size)
                    .map(|_| (0..size).map(|_| (rand_f64() - 0.5) * scale).collect())
                    .collect();
                let b = vec![0.0; size];
                weights.push(w);
                biases.push(b);
                prev_size = size;
            }

            Self {
                input_dim,
                hidden_layers: all_layers,
                weights,
                biases,
                dropout_rate: 0.3,
            }
        }

        pub fn discriminate(&self, input: &[f64]) -> f64 {
            let mut x = input.to_vec();

            for i in 0..self.weights.len() {
                let mut out = self.biases[i].clone();

                for j in 0..x.len() {
                    for k in 0..out.len() {
                        out[k] += x[j] * self.weights[i][j][k];
                    }
                }

                // Activation (LeakyReLU for hidden, sigmoid for output)
                if i < self.weights.len() - 1 {
                    for v in &mut out {
                        *v = if *v > 0.0 { *v } else { 0.2 * *v };
                    }
                } else {
                    for v in &mut out {
                        *v = 1.0 / (1.0 + (-*v).exp());
                    }
                }

                x = out;
            }

            x[0]
        }
    }

    /// Wasserstein GAN with gradient penalty
    pub struct WGAN_GP {
        pub generator: MarketGenerator,
        pub discriminator: MarketDiscriminator,
        pub lambda_gp: f64,
        pub n_critic: i32,
        pub gen_lr: f64,
        pub disc_lr: f64,
    }

    impl WGAN_GP {
        pub fn new(latent_dim: usize, data_dim: usize) -> Self {
            Self {
                generator: MarketGenerator::new(latent_dim, data_dim, &[128, 256, 128]),
                discriminator: MarketDiscriminator::new(data_dim, &[128, 256, 128]),
                lambda_gp: 10.0,
                n_critic: 5,
                gen_lr: 0.0001,
                disc_lr: 0.0001,
            }
        }

        pub fn gradient_penalty(&self, real: &[f64], fake: &[f64]) -> f64 {
            let epsilon = rand_f64();
            let interpolated: Vec<f64> = real.iter().zip(fake)
                .map(|(r, f)| epsilon * r + (1.0 - epsilon) * f)
                .collect();

            let eps = 1e-5;
            let mut grad_norm = 0.0;

            for i in 0..interpolated.len() {
                let mut x_plus = interpolated.clone();
                let mut x_minus = interpolated.clone();
                x_plus[i] += eps;
                x_minus[i] -= eps;

                let d_plus = self.discriminator.discriminate(&x_plus);
                let d_minus = self.discriminator.discriminate(&x_minus);
                let grad_i = (d_plus - d_minus) / (2.0 * eps);
                grad_norm += grad_i * grad_i;
            }

            let norm = grad_norm.sqrt();
            self.lambda_gp * (norm - 1.0).powi(2)
        }

        pub fn train_step(&mut self, real_data: &[Vec<f64>]) -> (f64, f64) {
            let batch_size = real_data.len();

            // Train discriminator
            let mut disc_loss = 0.0;
            for _ in 0..self.n_critic {
                let fake_data = self.generator.generate_batch(batch_size);

                for i in 0..batch_size {
                    let real_score = self.discriminator.discriminate(&real_data[i]);
                    let fake_score = self.discriminator.discriminate(&fake_data[i]);
                    let gp = self.gradient_penalty(&real_data[i], &fake_data[i]);

                    disc_loss += fake_score - real_score + gp;
                }
            }
            disc_loss /= (self.n_critic * batch_size as i32) as f64;

            // Train generator
            let fake_data = self.generator.generate_batch(batch_size);
            let mut gen_loss = 0.0;
            for fake in &fake_data {
                gen_loss -= self.discriminator.discriminate(fake);
            }
            gen_loss /= batch_size as f64;

            (gen_loss, disc_loss)
        }
    }

    /// TimeGAN for temporal market data
    pub struct TimeGAN {
        pub seq_len: usize,
        pub feature_dim: usize,
        pub hidden_dim: usize,
        pub latent_dim: usize,
        pub embedder: SimpleRNN,
        pub recovery: SimpleRNN,
        pub generator: SimpleRNN,
        pub supervisor: SimpleRNN,
        pub discriminator: SimpleRNN,
    }

    pub struct SimpleRNN {
        pub input_dim: usize,
        pub hidden_dim: usize,
        pub output_dim: usize,
        pub w_ih: Vec<Vec<f64>>,
        pub w_hh: Vec<Vec<f64>>,
        pub w_ho: Vec<Vec<f64>>,
        pub b_h: Vec<f64>,
        pub b_o: Vec<f64>,
    }

    impl SimpleRNN {
        pub fn new(input: usize, hidden: usize, output: usize) -> Self {
            let scale_ih = (2.0 / input as f64).sqrt();
            let scale_hh = (2.0 / hidden as f64).sqrt();

            Self {
                input_dim: input,
                hidden_dim: hidden,
                output_dim: output,
                w_ih: (0..input).map(|_| (0..hidden).map(|_| randn() * scale_ih).collect()).collect(),
                w_hh: (0..hidden).map(|_| (0..hidden).map(|_| randn() * scale_hh).collect()).collect(),
                w_ho: (0..hidden).map(|_| (0..output).map(|_| randn() * scale_hh).collect()).collect(),
                b_h: vec![0.0; hidden],
                b_o: vec![0.0; output],
            }
        }

        pub fn forward(&self, sequence: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let mut hidden = vec![0.0; self.hidden_dim];
            let mut outputs = Vec::new();

            for input in sequence {
                // h_t = tanh(W_ih * x_t + W_hh * h_{t-1} + b_h)
                let mut new_hidden = self.b_h.clone();
                for i in 0..self.input_dim.min(input.len()) {
                    for j in 0..self.hidden_dim {
                        new_hidden[j] += input[i] * self.w_ih[i][j];
                    }
                }
                for i in 0..self.hidden_dim {
                    for j in 0..self.hidden_dim {
                        new_hidden[j] += hidden[i] * self.w_hh[i][j];
                    }
                }
                for v in &mut new_hidden {
                    *v = v.tanh();
                }
                hidden = new_hidden;

                // o_t = W_ho * h_t + b_o
                let mut output = self.b_o.clone();
                for i in 0..self.hidden_dim {
                    for j in 0..self.output_dim {
                        output[j] += hidden[i] * self.w_ho[i][j];
                    }
                }
                outputs.push(output);
            }

            outputs
        }
    }

    impl TimeGAN {
        pub fn new(seq_len: usize, feature_dim: usize, hidden: usize, latent: usize) -> Self {
            Self {
                seq_len,
                feature_dim,
                hidden_dim: hidden,
                latent_dim: latent,
                embedder: SimpleRNN::new(feature_dim, hidden, hidden),
                recovery: SimpleRNN::new(hidden, hidden, feature_dim),
                generator: SimpleRNN::new(latent, hidden, hidden),
                supervisor: SimpleRNN::new(hidden, hidden, hidden),
                discriminator: SimpleRNN::new(hidden, hidden, 1),
            }
        }

        pub fn generate_sequence(&self, noise_seq: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let generated_hidden = self.generator.forward(noise_seq);
            let supervised = self.supervisor.forward(&generated_hidden);
            self.recovery.forward(&supervised)
        }
    }

    fn rand_f64() -> f64 {
        // Simple pseudo-random using time-based seed (deterministic placeholder)
        // Note: static mut not supported by QuantaLang compiler; using fixed value.
        return 0.5; // placeholder for PRNG
    }

    fn randn() -> f64 {
        // Box-Muller transform
        let u1 = rand_f64().max(1e-10);
        let u2 = rand_f64();
        (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ONLINE LEARNING ALGORITHMS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod online_learning {
    use super::*;

    /// Online Gradient Descent with adaptive learning rate
    pub struct OnlineGD {
        pub weights: Vec<f64>,
        pub learning_rate: f64,
        pub l2_reg: f64,
        pub momentum: f64,
        pub velocity: Vec<f64>,
        pub updates: u64,
    }

    impl OnlineGD {
        pub fn new(dim: usize, lr: f64) -> Self {
            Self {
                weights: vec![0.0; dim],
                learning_rate: lr,
                l2_reg: 0.0001,
                momentum: 0.9,
                velocity: vec![0.0; dim],
                updates: 0,
            }
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            features.iter().zip(&self.weights)
                .map(|(x, w)| x * w)
                .sum()
        }

        pub fn update(&mut self, features: &[f64], target: f64) {
            let pred = self.predict(features);
            let error = pred - target;

            for i in 0..self.weights.len().min(features.len()) {
                let grad = error * features[i] + self.l2_reg * self.weights[i];
                self.velocity[i] = self.momentum * self.velocity[i] - self.learning_rate * grad;
                self.weights[i] += self.velocity[i];
            }

            self.updates += 1;
        }
    }

    /// Follow-The-Regularized-Leader (FTRL)
    pub struct FTRL {
        pub z: Vec<f64>,
        pub n: Vec<f64>,
        pub weights: Vec<f64>,
        pub alpha: f64,
        pub beta: f64,
        pub l1: f64,
        pub l2: f64,
    }

    impl FTRL {
        pub fn new(dim: usize) -> Self {
            Self {
                z: vec![0.0; dim],
                n: vec![0.0; dim],
                weights: vec![0.0; dim],
                alpha: 0.1,
                beta: 1.0,
                l1: 0.1,
                l2: 0.1,
            }
        }

        pub fn predict(&mut self, features: &[f64]) -> f64 {
            // Lazy weight update
            for i in 0..self.weights.len() {
                if self.z[i].abs() <= self.l1 {
                    self.weights[i] = 0.0;
                } else {
                    let sign = if self.z[i] >= 0.0 { 1.0 } else { -1.0 };
                    self.weights[i] = -(self.z[i] - sign * self.l1) /
                        ((self.beta + self.n[i].sqrt()) / self.alpha + self.l2);
                }
            }

            features.iter().zip(&self.weights)
                .map(|(x, w)| x * w)
                .sum()
        }

        pub fn update(&mut self, features: &[f64], target: f64) {
            let pred = self.predict(features);
            let grad_loss = pred - target;

            for i in 0..self.weights.len().min(features.len()) {
                let gi = grad_loss * features[i];
                let sigma = (self.n[i] + gi * gi).sqrt() - self.n[i].sqrt();
                self.z[i] += gi - sigma / self.alpha * self.weights[i];
                self.n[i] += gi * gi;
            }
        }
    }

    /// Passive-Aggressive classifier/regressor
    pub struct PassiveAggressive {
        pub weights: Vec<f64>,
        pub c: f64,  // Aggressiveness parameter
        pub mode: PAMode,
        pub loss_type: PALoss,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum PAMode { PA, PA_I, PA_II }

    #[derive(Debug, Clone, Copy)]
    pub enum PALoss { Hinge, Epsilon(f64) }

    impl PassiveAggressive {
        pub fn new(dim: usize, c: f64, mode: PAMode) -> Self {
            Self {
                weights: vec![0.0; dim],
                c,
                mode,
                loss_type: PALoss::Hinge,
            }
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            features.iter().zip(&self.weights)
                .map(|(x, w)| x * w)
                .sum()
        }

        pub fn update_classification(&mut self, features: &[f64], label: f64) {
            let pred = self.predict(features);
            let loss = (1.0 - label * pred).max(0.0);

            if loss > 0.0 {
                let x_norm_sq: f64 = features.iter().map(|x| x * x).sum();
                if x_norm_sq < 1e-10 { return; }

                let tau = match self.mode {
                    PAMode::PA => loss / x_norm_sq,
                    PAMode::PA_I => (loss / x_norm_sq).min(self.c),
                    PAMode::PA_II => loss / (x_norm_sq + 1.0 / (2.0 * self.c)),
                };

                for i in 0..self.weights.len().min(features.len()) {
                    self.weights[i] += tau * label * features[i];
                }
            }
        }

        pub fn update_regression(&mut self, features: &[f64], target: f64, epsilon: f64) {
            let pred = self.predict(features);
            let diff = pred - target;
            let loss = (diff.abs() - epsilon).max(0.0);

            if loss > 0.0 {
                let x_norm_sq: f64 = features.iter().map(|x| x * x).sum();
                if x_norm_sq < 1e-10 { return; }

                let sign = if diff >= 0.0 { 1.0 } else { -1.0 };
                let tau = match self.mode {
                    PAMode::PA => loss / x_norm_sq,
                    PAMode::PA_I => (loss / x_norm_sq).min(self.c),
                    PAMode::PA_II => loss / (x_norm_sq + 1.0 / (2.0 * self.c)),
                };

                for i in 0..self.weights.len().min(features.len()) {
                    self.weights[i] -= tau * sign * features[i];
                }
            }
        }
    }

    /// Adaptive Regularization of Weights (AROW)
    pub struct AROW {
        pub mean: Vec<f64>,
        pub variance: Vec<f64>,
        pub r: f64,
    }

    impl AROW {
        pub fn new(dim: usize, r: f64) -> Self {
            Self {
                mean: vec![0.0; dim],
                variance: vec![1.0; dim],
                r,
            }
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            features.iter().zip(&self.mean)
                .map(|(x, w)| x * w)
                .sum()
        }

        pub fn confidence(&self, features: &[f64]) -> f64 {
            features.iter().zip(&self.variance)
                .map(|(x, v)| x * x * v)
                .sum::<f64>()
                .sqrt()
        }

        pub fn update(&mut self, features: &[f64], label: f64) {
            let margin = label * self.predict(features);
            if margin >= 1.0 { return; }

            let conf: f64 = features.iter().zip(&self.variance)
                .map(|(x, v)| x * x * v)
                .sum();

            let beta = 1.0 / (conf + self.r);
            let alpha = ((1.0 - margin) * beta).max(0.0);

            for i in 0..self.mean.len().min(features.len()) {
                self.mean[i] += alpha * label * self.variance[i] * features[i];
                self.variance[i] = 1.0 / (1.0 / self.variance[i] + features[i] * features[i] / self.r);
            }
        }
    }

    /// Confidence-Weighted Learning
    pub struct ConfidenceWeighted {
        pub mean: Vec<f64>,
        pub covariance_diag: Vec<f64>,
        pub eta: f64,
    }

    impl ConfidenceWeighted {
        pub fn new(dim: usize, eta: f64) -> Self {
            Self {
                mean: vec![0.0; dim],
                covariance_diag: vec![1.0; dim],
                eta,
            }
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            features.iter().zip(&self.mean)
                .map(|(x, w)| x * w)
                .sum()
        }

        pub fn update(&mut self, features: &[f64], label: f64) {
            let m = self.predict(features);
            let v: f64 = features.iter().zip(&self.covariance_diag)
                .map(|(x, c)| x * x * c)
                .sum();

            if v < 1e-10 { return; }

            let phi = 0.5; // Probit approximation
            let psi = 1.0 + phi * phi / 2.0;
            let zeta = 1.0 + phi * phi;

            let margin = label * m;
            let n = v + 1.0 / (2.0 * self.eta);
            let gamma = (-psi * margin + (psi * psi * margin * margin + 4.0 * n * phi * zeta).sqrt()) / (2.0 * n * zeta);

            if gamma <= 0.0 { return; }

            let alpha = gamma * phi;
            let u = (-alpha * v * phi + (alpha * alpha * v * v * phi * phi + 4.0 * v).sqrt()) / 2.0;
            let beta = alpha * phi / (u.sqrt() + v * alpha * phi);

            for i in 0..self.mean.len().min(features.len()) {
                self.mean[i] += alpha * label * self.covariance_diag[i] * features[i];
                self.covariance_diag[i] -= beta * self.covariance_diag[i].powi(2) * features[i].powi(2);
                self.covariance_diag[i] = self.covariance_diag[i].max(1e-10);
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GRADIENT BOOSTING DECISION TREES
// ═══════════════════════════════════════════════════════════════════════════════

pub mod gbdt {
    use super::*;

    /// Decision tree node
    #[derive(Debug, Clone)]
    pub struct GBDTNode {
        pub feature_idx: usize,
        pub threshold: f64,
        pub value: f64,
        pub left: Option<Box<GBDTNode>>,
        pub right: Option<Box<GBDTNode>>,
        pub is_leaf: bool,
    }

    impl GBDTNode {
        pub fn leaf(value: f64) -> Self {
            Self {
                feature_idx: 0,
                threshold: 0.0,
                value,
                left: None,
                right: None,
                is_leaf: true,
            }
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            if self.is_leaf { return self.value; }

            if features.get(self.feature_idx).copied().unwrap_or(0.0) <= self.threshold {
                self.left.as_ref().map(|n| n.predict(features)).unwrap_or(self.value)
            } else {
                self.right.as_ref().map(|n| n.predict(features)).unwrap_or(self.value)
            }
        }
    }

    /// Gradient Boosting Regressor
    pub struct GradientBoostingRegressor {
        pub trees: Vec<GBDTNode>,
        pub learning_rate: f64,
        pub n_estimators: usize,
        pub max_depth: usize,
        pub min_samples_split: usize,
        pub subsample: f64,
        pub colsample_bytree: f64,
        pub initial_prediction: f64,
    }

    impl GradientBoostingRegressor {
        pub fn new(n_estimators: usize, learning_rate: f64, max_depth: usize) -> Self {
            Self {
                trees: Vec::new(),
                learning_rate,
                n_estimators,
                max_depth,
                min_samples_split: 5,
                subsample: 0.8,
                colsample_bytree: 0.8,
                initial_prediction: 0.0,
            }
        }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            if x.is_empty() || y.is_empty() { return; }

            self.initial_prediction = y.iter().sum::<f64>() / y.len() as f64;
            let mut predictions = vec![self.initial_prediction; y.len()];

            for _ in 0..self.n_estimators {
                // Compute residuals (negative gradient for MSE)
                let residuals: Vec<f64> = y.iter().zip(&predictions)
                    .map(|(yi, pi)| yi - pi)
                    .collect();

                // Subsample
                let n_samples = (x.len() as f64 * self.subsample) as usize;
                let indices: Vec<usize> = (0..x.len())
                    .filter(|_| rand_f64() < self.subsample)
                    .take(n_samples)
                    .collect();

                if indices.is_empty() { continue; }

                let x_sample: Vec<&Vec<f64>> = indices.iter().map(|&i| &x[i]).collect();
                let r_sample: Vec<f64> = indices.iter().map(|&i| residuals[i]).collect();

                // Fit tree to residuals
                let tree = self.build_tree(&x_sample, &r_sample, 0);
                self.trees.push(tree);

                // Update predictions
                for (i, xi) in x.iter().enumerate() {
                    predictions[i] += self.learning_rate * self.trees.last().unwrap().predict(xi);
                }
            }
        }

        fn build_tree(&self, x: &[&Vec<f64>], y: &[f64], depth: usize) -> GBDTNode {
            let n = y.len();

            // Stop conditions
            if depth >= self.max_depth || n < self.min_samples_split {
                return GBDTNode::leaf(y.iter().sum::<f64>() / n as f64);
            }

            let (best_feat, best_thresh, best_gain) = self.find_best_split(x, y);

            if best_gain <= 0.0 {
                return GBDTNode::leaf(y.iter().sum::<f64>() / n as f64);
            }

            let (left_x, left_y, right_x, right_y) = self.split_data(x, y, best_feat, best_thresh);

            if left_x.is_empty() || right_x.is_empty() {
                return GBDTNode::leaf(y.iter().sum::<f64>() / n as f64);
            }

            GBDTNode {
                feature_idx: best_feat,
                threshold: best_thresh,
                value: y.iter().sum::<f64>() / n as f64,
                left: Some(Box::new(self.build_tree(&left_x, &left_y, depth + 1))),
                right: Some(Box::new(self.build_tree(&right_x, &right_y, depth + 1))),
                is_leaf: false,
            }
        }

        fn find_best_split(&self, x: &[&Vec<f64>], y: &[f64]) -> (usize, f64, f64) {
            let n = y.len();
            if n < 2 { return (0, 0.0, 0.0); }

            let n_features = x.get(0).map(|v| v.len()).unwrap_or(0);
            let n_cols = (n_features as f64 * self.colsample_bytree) as usize;

            let mut best_feat = 0;
            let mut best_thresh = 0.0;
            let mut best_gain = 0.0;

            let parent_var = variance(y);

            for feat in 0..n_features {
                if rand_f64() > self.colsample_bytree { continue; }

                let mut values: Vec<f64> = x.iter()
                    .filter_map(|xi| xi.get(feat).copied())
                    .collect();
                values.sort_by(|a, b| a.partial_cmp(b).unwrap());
                values.dedup();

                for thresh in values.windows(2).map(|w| (w[0] + w[1]) / 2.0) {
                    let (left_y, right_y): (Vec<f64>, Vec<f64>) = x.iter().zip(y)
                        .partition::<Vec<_>, _>(|(xi, _)| xi.get(feat).copied().unwrap_or(0.0) <= thresh)
                        .into();

                    let left_y: Vec<f64> = x.iter().zip(y)
                        .filter(|(xi, _)| xi.get(feat).copied().unwrap_or(0.0) <= thresh)
                        .map(|(_, yi)| *yi)
                        .collect();
                    let right_y: Vec<f64> = x.iter().zip(y)
                        .filter(|(xi, _)| xi.get(feat).copied().unwrap_or(0.0) > thresh)
                        .map(|(_, yi)| *yi)
                        .collect();

                    if left_y.len() < self.min_samples_split || right_y.len() < self.min_samples_split {
                        continue;
                    }

                    let left_var = variance(&left_y);
                    let right_var = variance(&right_y);
                    let weighted_var = (left_y.len() as f64 * left_var + right_y.len() as f64 * right_var) / n as f64;
                    let gain = parent_var - weighted_var;

                    if gain > best_gain {
                        best_gain = gain;
                        best_feat = feat;
                        best_thresh = thresh;
                    }
                }
            }

            (best_feat, best_thresh, best_gain)
        }

        fn split_data<'a>(&self, x: &[&'a Vec<f64>], y: &[f64], feat: usize, thresh: f64)
            -> (Vec<&'a Vec<f64>>, Vec<f64>, Vec<&'a Vec<f64>>, Vec<f64>) {
            let mut left_x = Vec::new();
            let mut left_y = Vec::new();
            let mut right_x = Vec::new();
            let mut right_y = Vec::new();

            for (xi, &yi) in x.iter().zip(y) {
                if xi.get(feat).copied().unwrap_or(0.0) <= thresh {
                    left_x.push(*xi);
                    left_y.push(yi);
                } else {
                    right_x.push(*xi);
                    right_y.push(yi);
                }
            }

            (left_x, left_y, right_x, right_y)
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            let mut pred = self.initial_prediction;
            for tree in &self.trees {
                pred += self.learning_rate * tree.predict(features);
            }
            pred
        }
    }

    /// XGBoost-style boosting with regularization
    pub struct XGBRegressor {
        pub base_score: f64,
        pub n_estimators: usize,
        pub max_depth: usize,
        pub learning_rate: f64,
        pub gamma: f64,           // Min loss reduction for split
        pub lambda: f64,          // L2 regularization
        pub alpha: f64,           // L1 regularization
        pub min_child_weight: f64,
        pub trees: Vec<GBDTNode>,
    }

    impl XGBRegressor {
        pub fn new() -> Self {
            Self {
                base_score: 0.5,
                n_estimators: 100,
                max_depth: 6,
                learning_rate: 0.1,
                gamma: 0.0,
                lambda: 1.0,
                alpha: 0.0,
                min_child_weight: 1.0,
                trees: Vec::new(),
            }
        }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            if x.is_empty() || y.is_empty() { return; }

            let mut predictions = vec![self.base_score; y.len()];

            for _ in 0..self.n_estimators {
                // Compute gradients and hessians for MSE loss
                let gradients: Vec<f64> = predictions.iter().zip(y)
                    .map(|(p, yi)| p - yi)
                    .collect();
                let hessians: Vec<f64> = vec![1.0; y.len()];

                // Build tree using gradient stats
                let tree = self.build_xgb_tree(x, &gradients, &hessians, 0);
                self.trees.push(tree);

                // Update predictions
                for (i, xi) in x.iter().enumerate() {
                    predictions[i] += self.learning_rate * self.trees.last().unwrap().predict(xi);
                }
            }
        }

        fn build_xgb_tree(&self, x: &[Vec<f64>], g: &[f64], h: &[f64], depth: usize) -> GBDTNode {
            let n = g.len();

            // Leaf value: -sum(g) / (sum(h) + lambda)
            let sum_g: f64 = g.iter().sum();
            let sum_h: f64 = h.iter().sum();
            let leaf_value = -sum_g / (sum_h + self.lambda);

            if depth >= self.max_depth || n < 2 || sum_h < self.min_child_weight {
                return GBDTNode::leaf(leaf_value);
            }

            let (best_feat, best_thresh, best_gain) = self.find_xgb_split(x, g, h);

            if best_gain <= self.gamma {
                return GBDTNode::leaf(leaf_value);
            }

            // Split data
            let (left_idx, right_idx): (Vec<usize>, Vec<usize>) = (0..n)
                .partition(|&i| x[i].get(best_feat).copied().unwrap_or(0.0) <= best_thresh);

            if left_idx.is_empty() || right_idx.is_empty() {
                return GBDTNode::leaf(leaf_value);
            }

            let left_x: Vec<Vec<f64>> = left_idx.iter().map(|&i| x[i].clone()).collect();
            let left_g: Vec<f64> = left_idx.iter().map(|&i| g[i]).collect();
            let left_h: Vec<f64> = left_idx.iter().map(|&i| h[i]).collect();

            let right_x: Vec<Vec<f64>> = right_idx.iter().map(|&i| x[i].clone()).collect();
            let right_g: Vec<f64> = right_idx.iter().map(|&i| g[i]).collect();
            let right_h: Vec<f64> = right_idx.iter().map(|&i| h[i]).collect();

            GBDTNode {
                feature_idx: best_feat,
                threshold: best_thresh,
                value: leaf_value,
                left: Some(Box::new(self.build_xgb_tree(&left_x, &left_g, &left_h, depth + 1))),
                right: Some(Box::new(self.build_xgb_tree(&right_x, &right_g, &right_h, depth + 1))),
                is_leaf: false,
            }
        }

        fn find_xgb_split(&self, x: &[Vec<f64>], g: &[f64], h: &[f64]) -> (usize, f64, f64) {
            let n = x.len();
            if n < 2 { return (0, 0.0, 0.0); }

            let n_features = x.get(0).map(|v| v.len()).unwrap_or(0);
            let sum_g: f64 = g.iter().sum();
            let sum_h: f64 = h.iter().sum();

            let mut best_feat = 0;
            let mut best_thresh = 0.0;
            let mut best_gain = 0.0;

            for feat in 0..n_features {
                // Sort by feature value
                let mut indexed: Vec<(usize, f64)> = x.iter().enumerate()
                    .map(|(i, xi)| (i, xi.get(feat).copied().unwrap_or(0.0)))
                    .collect();
                indexed.sort_by(|a, b| a.1.partial_cmp(&b.1).unwrap());

                let mut sum_gl = 0.0;
                let mut sum_hl = 0.0;

                for j in 0..indexed.len() - 1 {
                    let idx = indexed[j].0;
                    sum_gl += g[idx];
                    sum_hl += h[idx];

                    let sum_gr = sum_g - sum_gl;
                    let sum_hr = sum_h - sum_hl;

                    if sum_hl < self.min_child_weight || sum_hr < self.min_child_weight {
                        continue;
                    }

                    // XGBoost gain formula
                    let gain = 0.5 * (
                        sum_gl * sum_gl / (sum_hl + self.lambda) +
                        sum_gr * sum_gr / (sum_hr + self.lambda) -
                        sum_g * sum_g / (sum_h + self.lambda)
                    ) - self.gamma;

                    if gain > best_gain && indexed[j].1 != indexed[j + 1].1 {
                        best_gain = gain;
                        best_feat = feat;
                        best_thresh = (indexed[j].1 + indexed[j + 1].1) / 2.0;
                    }
                }
            }

            (best_feat, best_thresh, best_gain)
        }

        pub fn predict(&self, features: &[f64]) -> f64 {
            let mut pred = self.base_score;
            for tree in &self.trees {
                pred += self.learning_rate * tree.predict(features);
            }
            pred
        }
    }

    fn variance(values: &[f64]) -> f64 {
        if values.is_empty() { return 0.0; }
        let mean = values.iter().sum::<f64>() / values.len() as f64;
        values.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / values.len() as f64
    }

    fn rand_f64() -> f64 {
        // Placeholder for PRNG (static mut not supported by compiler)
        return 0.5;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL ARCHITECTURE COMPONENTS
// ═══════════════════════════════════════════════════════════════════════════════

pub mod neural_components {
    use super::*;

    /// Batch Normalization layer
    pub struct BatchNorm1D {
        pub num_features: usize,
        pub eps: f64,
        pub momentum: f64,
        pub gamma: Vec<f64>,
        pub beta: Vec<f64>,
        pub running_mean: Vec<f64>,
        pub running_var: Vec<f64>,
        pub training: bool,
    }

    impl BatchNorm1D {
        pub fn new(num_features: usize) -> Self {
            Self {
                num_features,
                eps: 1e-5,
                momentum: 0.1,
                gamma: vec![1.0; num_features],
                beta: vec![0.0; num_features],
                running_mean: vec![0.0; num_features],
                running_var: vec![1.0; num_features],
                training: true,
            }
        }

        pub fn forward(&mut self, batch: &[Vec<f64>]) -> Vec<Vec<f64>> {
            if batch.is_empty() { return Vec::new(); }

            let batch_size = batch.len();
            let mut output = vec![vec![0.0; self.num_features]; batch_size];

            let (mean, var) = if self.training {
                // Compute batch statistics
                let mut mean = vec![0.0; self.num_features];
                let mut var = vec![0.0; self.num_features];

                for sample in batch {
                    for (i, &val) in sample.iter().enumerate().take(self.num_features) {
                        mean[i] += val;
                    }
                }
                for m in &mut mean { *m /= batch_size as f64; }

                for sample in batch {
                    for (i, &val) in sample.iter().enumerate().take(self.num_features) {
                        var[i] += (val - mean[i]).powi(2);
                    }
                }
                for v in &mut var { *v /= batch_size as f64; }

                // Update running stats
                for i in 0..self.num_features {
                    self.running_mean[i] = (1.0 - self.momentum) * self.running_mean[i] + self.momentum * mean[i];
                    self.running_var[i] = (1.0 - self.momentum) * self.running_var[i] + self.momentum * var[i];
                }

                (mean, var)
            } else {
                (self.running_mean.clone(), self.running_var.clone())
            };

            // Normalize
            for (b, sample) in batch.iter().enumerate() {
                for i in 0..self.num_features.min(sample.len()) {
                    let norm = (sample[i] - mean[i]) / (var[i] + self.eps).sqrt();
                    output[b][i] = self.gamma[i] * norm + self.beta[i];
                }
            }

            output
        }
    }

    /// Layer Normalization
    pub struct ComponentLayerNorm {
        pub normalized_shape: usize,
        pub eps: f64,
        pub gamma: Vec<f64>,
        pub beta: Vec<f64>,
    }

    impl ComponentLayerNorm {
        pub fn new(normalized_shape: usize) -> Self {
            Self {
                normalized_shape,
                eps: 1e-5,
                gamma: vec![1.0; normalized_shape],
                beta: vec![0.0; normalized_shape],
            }
        }

        pub fn forward(&self, input: &[f64]) -> Vec<f64> {
            let n = input.len().min(self.normalized_shape);
            if n == 0 { return Vec::new(); }

            let mean: f64 = input.iter().take(n).sum::<f64>() / n as f64;
            let var: f64 = input.iter().take(n).map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64;

            input.iter().take(n).enumerate()
                .map(|(i, x)| self.gamma[i] * (x - mean) / (var + self.eps).sqrt() + self.beta[i])
                .collect()
        }
    }

    /// Dropout layer
    pub struct Dropout {
        pub p: f64,
        pub training: bool,
    }

    impl Dropout {
        pub fn new(p: f64) -> Self {
            Self { p, training: true }
        }

        pub fn forward(&self, input: &[f64]) -> Vec<f64> {
            if !self.training { return input.to_vec(); }

            input.iter().map(|&x| {
                if rand_f64() < self.p { 0.0 } else { x / (1.0 - self.p) }
            }).collect()
        }
    }

    /// Embedding layer
    pub struct Embedding {
        pub num_embeddings: usize,
        pub embedding_dim: usize,
        pub weights: Vec<Vec<f64>>,
        pub padding_idx: Option<usize>,
    }

    impl Embedding {
        pub fn new(num_embeddings: usize, embedding_dim: usize) -> Self {
            let scale = 1.0 / (embedding_dim as f64).sqrt();
            let weights = (0..num_embeddings)
                .map(|_| (0..embedding_dim).map(|_| (rand_f64() - 0.5) * 2.0 * scale).collect())
                .collect();

            Self {
                num_embeddings,
                embedding_dim,
                weights,
                padding_idx: None,
            }
        }

        pub fn forward(&self, indices: &[usize]) -> Vec<Vec<f64>> {
            indices.iter().map(|&idx| {
                if idx < self.num_embeddings {
                    self.weights[idx].clone()
                } else {
                    vec![0.0; self.embedding_dim]
                }
            }).collect()
        }
    }

    /// Positional Encoding for Transformers
    pub struct PositionalEncoding {
        pub max_len: usize,
        pub d_model: usize,
        pub encodings: Vec<Vec<f64>>,
        pub dropout: f64,
    }

    impl PositionalEncoding {
        pub fn new(d_model: usize, max_len: usize) -> Self {
            let mut encodings = vec![vec![0.0; d_model]; max_len];

            for pos in 0..max_len {
                for i in 0..d_model / 2 {
                    let angle = pos as f64 / 10000f64.powf(2.0 * i as f64 / d_model as f64);
                    encodings[pos][2 * i] = angle.sin();
                    encodings[pos][2 * i + 1] = angle.cos();
                }
            }

            Self {
                max_len,
                d_model,
                encodings,
                dropout: 0.1,
            }
        }

        pub fn forward(&self, input: &[Vec<f64>]) -> Vec<Vec<f64>> {
            input.iter().enumerate().map(|(pos, x)| {
                if pos >= self.max_len { return x.clone(); }
                x.iter().zip(&self.encodings[pos])
                    .map(|(xi, pe)| xi + pe)
                    .collect()
            }).collect()
        }
    }

    /// Softmax function
    pub fn softmax(input: &[f64]) -> Vec<f64> {
        let max_val = input.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let exp_values: Vec<f64> = input.iter().map(|x| (x - max_val).exp()).collect();
        let sum: f64 = exp_values.iter().sum();
        exp_values.iter().map(|x| x / sum).collect()
    }

    /// Activation functions
    pub mod activations {
        pub fn relu(x: f64) -> f64 { x.max(0.0) }
        pub fn leaky_relu(x: f64, alpha: f64) -> f64 { if x > 0.0 { x } else { alpha * x } }
        pub fn elu(x: f64, alpha: f64) -> f64 { if x > 0.0 { x } else { alpha * (x.exp() - 1.0) } }
        pub fn selu(x: f64) -> f64 {
            const ALPHA: f64 = 1.6732632423543772;
            const SCALE: f64 = 1.0507009873554805;
            SCALE * if x > 0.0 { x } else { ALPHA * (x.exp() - 1.0) }
        }
        pub fn gelu(x: f64) -> f64 {
            0.5 * x * (1.0 + ((2.0 / std::f64::consts::PI).sqrt() * (x + 0.044715 * x.powi(3))).tanh())
        }
        pub fn swish(x: f64) -> f64 { x / (1.0 + (-x).exp()) }
        pub fn mish(x: f64) -> f64 { x * (1.0 + x.exp()).ln().tanh() }
        pub fn sigmoid(x: f64) -> f64 { 1.0 / (1.0 + (-x).exp()) }
        pub fn softplus(x: f64) -> f64 { (1.0 + x.exp()).ln() }
    }

    fn rand_f64() -> f64 {
        return 0.5; // placeholder for PRNG (static mut unsupported)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODEL INTERPRETABILITY
// ═══════════════════════════════════════════════════════════════════════════════

pub mod interpretability {
    use super::*;

    /// SHAP-like feature importance
    pub struct FeatureImportance {
        pub feature_names: Vec<String>,
        pub importances: Vec<f64>,
        pub method: ImportanceMethod,
    }

    #[derive(Debug, Clone, Copy)]
    pub enum ImportanceMethod {
        Permutation,
        DropColumn,
        MeanAbsoluteShap,
    }

    impl FeatureImportance {
        pub fn new(feature_names: Vec<String>) -> Self {
            let n = feature_names.len();
            Self {
                feature_names,
                importances: vec![0.0; n],
                method: ImportanceMethod::Permutation,
            }
        }

        /// Permutation importance
        pub fn permutation_importance<F>(&mut self, x: &[Vec<f64>], y: &[f64], predict_fn: F, n_repeats: usize)
        where F: Fn(&[f64]) -> f64 {
            let baseline_score = self.mse_score(x, y, &predict_fn);

            for feat in 0..self.feature_names.len() {
                let mut total_drop = 0.0;

                for _ in 0..n_repeats {
                    // Shuffle feature column
                    let mut x_permuted = x.to_vec();
                    for i in 0..x_permuted.len() {
                        let j = (rand_f64() * x_permuted.len() as f64) as usize % x_permuted.len();
                        if feat < x_permuted[i].len() && feat < x_permuted[j].len() {
                            let temp = x_permuted[i][feat];
                            x_permuted[i][feat] = x_permuted[j][feat];
                            x_permuted[j][feat] = temp;
                        }
                    }

                    let permuted_score = self.mse_score(&x_permuted, y, &predict_fn);
                    total_drop += permuted_score - baseline_score;
                }

                self.importances[feat] = total_drop / n_repeats as f64;
            }
        }

        fn mse_score<F>(&self, x: &[Vec<f64>], y: &[f64], predict_fn: &F) -> f64
        where F: Fn(&[f64]) -> f64 {
            let mut mse = 0.0;
            for (xi, &yi) in x.iter().zip(y) {
                let pred = predict_fn(xi);
                mse += (pred - yi).powi(2);
            }
            mse / x.len() as f64
        }

        pub fn top_k(&self, k: usize) -> Vec<(String, f64)> {
            let mut indexed: Vec<(usize, f64)> = self.importances.iter()
                .enumerate()
                .map(|(i, &v)| (i, v))
                .collect();
            indexed.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());

            indexed.into_iter()
                .take(k)
                .map(|(i, v)| (self.feature_names[i].clone(), v))
                .collect()
        }
    }

    /// Partial Dependence Plot data
    pub struct PartialDependence {
        pub feature_idx: usize,
        pub feature_name: String,
        pub grid_values: Vec<f64>,
        pub pdp_values: Vec<f64>,
        pub ice_curves: Vec<Vec<f64>>,
    }

    impl PartialDependence {
        pub fn compute<F>(x: &[Vec<f64>], feature_idx: usize, feature_name: &str,
                          predict_fn: F, n_grid: usize) -> Self
        where F: Fn(&[f64]) -> f64 {
            // Get feature range
            let feature_values: Vec<f64> = x.iter()
                .filter_map(|xi| xi.get(feature_idx).copied())
                .collect();

            let min_val = feature_values.iter().cloned().fold(f64::INFINITY, f64::min);
            let max_val = feature_values.iter().cloned().fold(f64::NEG_INFINITY, f64::max);

            let grid_values: Vec<f64> = (0..n_grid)
                .map(|i| min_val + (max_val - min_val) * i as f64 / (n_grid - 1) as f64)
                .collect();

            // Compute ICE curves
            let mut ice_curves = vec![vec![0.0; n_grid]; x.len()];
            let mut pdp_values = vec![0.0; n_grid];

            for (g, &grid_val) in grid_values.iter().enumerate() {
                for (i, xi) in x.iter().enumerate() {
                    let mut xi_modified = xi.clone();
                    if feature_idx < xi_modified.len() {
                        xi_modified[feature_idx] = grid_val;
                    }
                    let pred = predict_fn(&xi_modified);
                    ice_curves[i][g] = pred;
                    pdp_values[g] += pred;
                }
                pdp_values[g] /= x.len() as f64;
            }

            Self {
                feature_idx,
                feature_name: feature_name.to_string(),
                grid_values,
                pdp_values,
                ice_curves,
            }
        }
    }

    /// Accumulated Local Effects
    pub struct AccumulatedLocalEffects {
        pub feature_idx: usize,
        pub bin_edges: Vec<f64>,
        pub ale_values: Vec<f64>,
    }

    impl AccumulatedLocalEffects {
        pub fn compute<F>(x: &[Vec<f64>], feature_idx: usize, predict_fn: F, n_bins: usize) -> Self
        where F: Fn(&[f64]) -> f64 {
            let feature_values: Vec<f64> = x.iter()
                .filter_map(|xi| xi.get(feature_idx).copied())
                .collect();

            let mut sorted_vals = feature_values.clone();
            sorted_vals.sort_by(|a, b| a.partial_cmp(b).unwrap());

            // Create quantile-based bins
            let mut bin_edges = Vec::new();
            for i in 0..=n_bins {
                let idx = (i * sorted_vals.len() / n_bins).min(sorted_vals.len() - 1);
                bin_edges.push(sorted_vals[idx]);
            }
            bin_edges.dedup();

            // Compute local effects
            let mut ale_values = vec![0.0; bin_edges.len() - 1];

            for b in 0..bin_edges.len() - 1 {
                let lower = bin_edges[b];
                let upper = bin_edges[b + 1];

                let in_bin: Vec<&Vec<f64>> = x.iter()
                    .filter(|xi| {
                        xi.get(feature_idx).map(|&v| v >= lower && v < upper).unwrap_or(false)
                    })
                    .collect();

                if in_bin.is_empty() { continue; }

                let mut local_effect = 0.0;
                for xi in &in_bin {
                    let mut xi_upper = (*xi).clone();
                    let mut xi_lower = (*xi).clone();
                    if feature_idx < xi_upper.len() {
                        xi_upper[feature_idx] = upper;
                        xi_lower[feature_idx] = lower;
                    }
                    local_effect += predict_fn(&xi_upper) - predict_fn(&xi_lower);
                }
                ale_values[b] = local_effect / in_bin.len() as f64;
            }

            // Accumulate
            for i in 1..ale_values.len() {
                ale_values[i] += ale_values[i - 1];
            }

            // Center
            let mean: f64 = ale_values.iter().sum::<f64>() / ale_values.len() as f64;
            for v in &mut ale_values {
                *v -= mean;
            }

            Self {
                feature_idx,
                bin_edges,
                ale_values,
            }
        }
    }

    fn rand_f64() -> f64 {
        return 0.5; // placeholder for PRNG (static mut unsupported)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FEATURE ENGINEERING MODULE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod features {
    use std::collections::HashMap;

    /// Feature selector using various methods
    pub struct FeatureSelector {
        pub method: SelectionMethod,
        pub k_features: usize,
        selected_indices: Vec<usize>,
        feature_scores: Vec<f64>,
    }

    #[derive(Clone, Copy)]
    pub enum SelectionMethod {
        VarianceThreshold(f64),
        MutualInformation,
        ANOVA,
        RFE,
        LassoPath,
    }

    impl FeatureSelector {
        pub fn new(method: SelectionMethod, k: usize) -> Self {
            Self { method, k_features: k, selected_indices: Vec::new(), feature_scores: Vec::new() }
        }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            let n_features = x.first().map(|r| r.len()).unwrap_or(0);
            self.feature_scores = match self.method {
                SelectionMethod::VarianceThreshold(threshold) => {
                    (0..n_features).map(|j| {
                        let col: Vec<f64> = x.iter().filter_map(|r| r.get(j).copied()).collect();
                        let mean = col.iter().sum::<f64>() / col.len() as f64;
                        let var = col.iter().map(|v| (v - mean).powi(2)).sum::<f64>() / col.len() as f64;
                        if var >= threshold { var } else { 0.0 }
                    }).collect()
                },
                SelectionMethod::MutualInformation => {
                    (0..n_features).map(|j| self.mutual_info(x, y, j)).collect()
                },
                SelectionMethod::ANOVA => {
                    (0..n_features).map(|j| self.anova_f_score(x, y, j)).collect()
                },
                SelectionMethod::RFE | SelectionMethod::LassoPath => {
                    vec![1.0; n_features] // Simplified
                },
            };

            let mut indexed: Vec<(usize, f64)> = self.feature_scores.iter().enumerate()
                .map(|(i, &s)| (i, s)).collect();
            indexed.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap());
            self.selected_indices = indexed.iter().take(self.k_features).map(|(i, _)| *i).collect();
        }

        fn mutual_info(&self, x: &[Vec<f64>], y: &[f64], j: usize) -> f64 {
            let n = x.len() as f64;
            if n == 0.0 { return 0.0; }

            let n_bins = (n.sqrt() as usize).max(2).min(20);
            let col: Vec<f64> = x.iter().filter_map(|r| r.get(j).copied()).collect();
            let x_min = col.iter().fold(f64::MAX, |a, &b| a.min(b));
            let x_max = col.iter().fold(f64::MIN, |a, &b| a.max(b));
            let y_min = y.iter().fold(f64::MAX, |a, &b| a.min(b));
            let y_max = y.iter().fold(f64::MIN, |a, &b| a.max(b));

            if x_max == x_min || y_max == y_min { return 0.0; }

            let mut joint = vec![vec![0.0; n_bins]; n_bins];
            let mut px = vec![0.0; n_bins];
            let mut py = vec![0.0; n_bins];

            for (xi, &yi) in col.iter().zip(y.iter()) {
                let bx = (((xi - x_min) / (x_max - x_min) * (n_bins - 1) as f64) as usize).min(n_bins - 1);
                let by = (((yi - y_min) / (y_max - y_min) * (n_bins - 1) as f64) as usize).min(n_bins - 1);
                joint[bx][by] += 1.0 / n;
                px[bx] += 1.0 / n;
                py[by] += 1.0 / n;
            }

            let mut mi = 0.0;
            for bx in 0..n_bins {
                for by in 0..n_bins {
                    let pxy = joint[bx][by];
                    if pxy > 0.0 && px[bx] > 0.0 && py[by] > 0.0 {
                        mi += pxy * (pxy / (px[bx] * py[by])).ln();
                    }
                }
            }
            mi.max(0.0)
        }

        fn anova_f_score(&self, x: &[Vec<f64>], y: &[f64], j: usize) -> f64 {
            let threshold = y.iter().sum::<f64>() / y.len() as f64;
            let mut group_a: Vec<f64> = Vec::new();
            let mut group_b: Vec<f64> = Vec::new();

            for (row, &yi) in x.iter().zip(y.iter()) {
                if let Some(&v) = row.get(j) {
                    if yi < threshold { group_a.push(v); } else { group_b.push(v); }
                }
            }

            if group_a.is_empty() || group_b.is_empty() { return 0.0; }

            let mean_a = group_a.iter().sum::<f64>() / group_a.len() as f64;
            let mean_b = group_b.iter().sum::<f64>() / group_b.len() as f64;
            let overall_mean = (group_a.iter().sum::<f64>() + group_b.iter().sum::<f64>()) /
                               (group_a.len() + group_b.len()) as f64;

            let between_var = group_a.len() as f64 * (mean_a - overall_mean).powi(2) +
                             group_b.len() as f64 * (mean_b - overall_mean).powi(2);

            let within_var: f64 = group_a.iter().map(|v| (v - mean_a).powi(2)).sum::<f64>() +
                                 group_b.iter().map(|v| (v - mean_b).powi(2)).sum::<f64>();

            if within_var > 0.0 { between_var / within_var } else { 0.0 }
        }

        pub fn transform(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            x.iter().map(|row| {
                self.selected_indices.iter().filter_map(|&i| row.get(i).copied()).collect()
            }).collect()
        }

        pub fn get_selected_indices(&self) -> &[usize] { &self.selected_indices }
        pub fn get_scores(&self) -> &[f64] { &self.feature_scores }
    }

    /// Technical indicator feature generator
    pub struct TechnicalFeatures {
        pub window_sizes: Vec<usize>,
    }

    impl TechnicalFeatures {
        pub fn new(windows: Vec<usize>) -> Self { Self { window_sizes: windows } }

        pub fn generate(&self, prices: &[f64], volumes: &[f64]) -> Vec<HashMap<String, f64>> {
            let n = prices.len();
            let mut features = vec![HashMap::new(); n];

            for &w in &self.window_sizes {
                for i in w..n {
                    let window = &prices[(i - w)..i];
                    let vol_window = &volumes[(i - w)..i];

                    // SMA
                    let sma = window.iter().sum::<f64>() / w as f64;
                    features[i].insert(format!("sma_{}", w), sma);

                    // EMA
                    let alpha = 2.0 / (w + 1) as f64;
                    let ema = window.iter().fold(window[0], |acc, &p| acc * (1.0 - alpha) + p * alpha);
                    features[i].insert(format!("ema_{}", w), ema);

                    // Std Dev / Bollinger Bands
                    let std = (window.iter().map(|&p| (p - sma).powi(2)).sum::<f64>() / w as f64).sqrt();
                    features[i].insert(format!("std_{}", w), std);
                    features[i].insert(format!("bb_upper_{}", w), sma + 2.0 * std);
                    features[i].insert(format!("bb_lower_{}", w), sma - 2.0 * std);
                    features[i].insert(format!("bb_width_{}", w), 4.0 * std / sma);

                    // RSI
                    let mut gains = 0.0;
                    let mut losses = 0.0;
                    for j in 1..window.len() {
                        let change = window[j] - window[j - 1];
                        if change > 0.0 { gains += change; } else { losses -= change; }
                    }
                    let rs = if losses > 0.0 { gains / losses } else { 100.0 };
                    features[i].insert(format!("rsi_{}", w), 100.0 - 100.0 / (1.0 + rs));

                    // Momentum
                    features[i].insert(format!("momentum_{}", w), prices[i] - prices[i - w]);
                    features[i].insert(format!("roc_{}", w), (prices[i] / prices[i - w] - 1.0) * 100.0);

                    // Volume features
                    let avg_vol = vol_window.iter().sum::<f64>() / w as f64;
                    features[i].insert(format!("vol_sma_{}", w), avg_vol);
                    features[i].insert(format!("vol_ratio_{}", w), volumes[i] / avg_vol.max(1.0));

                    // VWAP approximation
                    let vwap: f64 = window.iter().zip(vol_window.iter())
                        .map(|(&p, &v)| p * v).sum::<f64>() / vol_window.iter().sum::<f64>().max(1.0);
                    features[i].insert(format!("vwap_{}", w), vwap);

                    // High/Low range
                    let high = window.iter().fold(f64::MIN, |a, &b| a.max(b));
                    let low = window.iter().fold(f64::MAX, |a, &b| a.min(b));
                    features[i].insert(format!("range_{}", w), high - low);
                    features[i].insert(format!("range_pct_{}", w), (high - low) / prices[i]);
                }
            }

            // MACD (using 12 and 26 windows if available)
            if self.window_sizes.contains(&12) && self.window_sizes.contains(&26) {
                for i in 26..n {
                    let ema12 = features[i].get("ema_12").copied().unwrap_or(0.0);
                    let ema26 = features[i].get("ema_26").copied().unwrap_or(0.0);
                    features[i].insert("macd".to_string(), ema12 - ema26);
                }
            }

            features
        }

        pub fn lag_features(&self, data: &[f64], lags: &[usize]) -> Vec<Vec<f64>> {
            let n = data.len();
            let max_lag = *lags.iter().max().unwrap_or(&0);
            let mut result = vec![vec![0.0; lags.len()]; n];

            for i in max_lag..n {
                for (j, &lag) in lags.iter().enumerate() {
                    result[i][j] = data[i - lag];
                }
            }
            result
        }
    }

    /// Cross-sectional feature scaler
    pub struct FeatureScaler {
        pub method: ScalerMethod,
        means: Vec<f64>,
        stds: Vec<f64>,
        mins: Vec<f64>,
        maxs: Vec<f64>,
    }

    #[derive(Clone, Copy)]
    pub enum ScalerMethod { Standard, MinMax, Robust, MaxAbs }

    impl FeatureScaler {
        pub fn new(method: ScalerMethod) -> Self {
            Self { method, means: Vec::new(), stds: Vec::new(), mins: Vec::new(), maxs: Vec::new() }
        }

        pub fn fit(&mut self, x: &[Vec<f64>]) {
            let n_features = x.first().map(|r| r.len()).unwrap_or(0);
            let n = x.len() as f64;

            self.means = (0..n_features).map(|j| {
                x.iter().filter_map(|r| r.get(j)).sum::<f64>() / n
            }).collect();

            self.stds = (0..n_features).map(|j| {
                let mean = self.means[j];
                (x.iter().filter_map(|r| r.get(j)).map(|&v| (v - mean).powi(2)).sum::<f64>() / n).sqrt()
            }).collect();

            self.mins = (0..n_features).map(|j| {
                x.iter().filter_map(|r| r.get(j)).fold(f64::MAX, |a, &b| a.min(b))
            }).collect();

            self.maxs = (0..n_features).map(|j| {
                x.iter().filter_map(|r| r.get(j)).fold(f64::MIN, |a, &b| a.max(b))
            }).collect();
        }

        pub fn transform(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            x.iter().map(|row| {
                row.iter().enumerate().map(|(j, &v)| {
                    match self.method {
                        ScalerMethod::Standard => {
                            let std = self.stds.get(j).copied().unwrap_or(1.0);
                            if std > 0.0 { (v - self.means.get(j).copied().unwrap_or(0.0)) / std } else { 0.0 }
                        },
                        ScalerMethod::MinMax => {
                            let min = self.mins.get(j).copied().unwrap_or(0.0);
                            let max = self.maxs.get(j).copied().unwrap_or(1.0);
                            if max > min { (v - min) / (max - min) } else { 0.5 }
                        },
                        ScalerMethod::Robust => {
                            let median = self.means.get(j).copied().unwrap_or(0.0);
                            let iqr = self.stds.get(j).copied().unwrap_or(1.0);
                            if iqr > 0.0 { (v - median) / iqr } else { 0.0 }
                        },
                        ScalerMethod::MaxAbs => {
                            let max_abs = self.maxs.get(j).copied().unwrap_or(1.0).abs()
                                .max(self.mins.get(j).copied().unwrap_or(0.0).abs());
                            if max_abs > 0.0 { v / max_abs } else { 0.0 }
                        },
                    }
                }).collect()
            }).collect()
        }

        pub fn fit_transform(&mut self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            self.fit(x);
            self.transform(x)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENSEMBLE METHODS MODULE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod ensemble {
    use std::collections::HashMap;

    /// Random Forest regressor
    pub struct RandomForest {
        pub n_estimators: usize,
        pub max_depth: usize,
        pub min_samples_split: usize,
        pub max_features: MaxFeatures,
        pub bootstrap: bool,
        trees: Vec<DecisionTree>,
        rng_state: u64,
    }

    #[derive(Clone, Copy)]
    pub enum MaxFeatures { Sqrt, Log2, All, Fixed(usize) }

    impl RandomForest {
        pub fn new(n_estimators: usize) -> Self {
            Self {
                n_estimators, max_depth: 10, min_samples_split: 2,
                max_features: MaxFeatures::Sqrt, bootstrap: true,
                trees: Vec::new(), rng_state: 42,
            }
        }

        fn rand(&mut self) -> f64 {
            self.rng_state = self.rng_state.wrapping_mul(6364136223846793005).wrapping_add(1);
            (self.rng_state >> 11) as f64 / (1u64 << 53) as f64
        }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            let n = x.len();
            let n_features = x.first().map(|r| r.len()).unwrap_or(0);

            let k = match self.max_features {
                MaxFeatures::Sqrt => (n_features as f64).sqrt() as usize,
                MaxFeatures::Log2 => (n_features as f64).log2() as usize,
                MaxFeatures::All => n_features,
                MaxFeatures::Fixed(k) => k,
            }.max(1);

            self.trees = (0..self.n_estimators).map(|_| {
                // Bootstrap sample
                let indices: Vec<usize> = if self.bootstrap {
                    (0..n).map(|_| (self.rand() * n as f64) as usize % n).collect()
                } else {
                    (0..n).collect()
                };

                let x_sample: Vec<Vec<f64>> = indices.iter().map(|&i| x[i].clone()).collect();
                let y_sample: Vec<f64> = indices.iter().map(|&i| y[i]).collect();

                // Feature subset
                let mut feature_indices: Vec<usize> = (0..n_features).collect();
                for i in (1..n_features).rev() {
                    let j = (self.rand() * (i + 1) as f64) as usize;
                    feature_indices.swap(i, j);
                }
                let selected_features: Vec<usize> = feature_indices.into_iter().take(k).collect();

                let mut tree = DecisionTree::new(self.max_depth, self.min_samples_split);
                tree.fit_with_features(&x_sample, &y_sample, &selected_features);
                tree
            }).collect();
        }

        pub fn predict(&self, x: &[Vec<f64>]) -> Vec<f64> {
            x.iter().map(|row| {
                let preds: Vec<f64> = self.trees.iter().map(|t| t.predict_one(row)).collect();
                preds.iter().sum::<f64>() / preds.len() as f64
            }).collect()
        }

        pub fn feature_importances(&self) -> Vec<f64> {
            if self.trees.is_empty() { return Vec::new(); }
            let n_features = self.trees[0].feature_importances.len();
            let mut importances = vec![0.0; n_features];

            for tree in &self.trees {
                for (i, &imp) in tree.feature_importances.iter().enumerate() {
                    if i < n_features { importances[i] += imp; }
                }
            }

            let sum: f64 = importances.iter().sum();
            if sum > 0.0 { importances.iter_mut().for_each(|v| *v /= sum); }
            importances
        }
    }

    pub struct DecisionTree {
        max_depth: usize,
        min_samples_split: usize,
        root: Option<Box<DTNode>>,
        pub feature_importances: Vec<f64>,
    }

    struct DTNode {
        feature_idx: usize,
        threshold: f64,
        value: f64,
        left: Option<Box<DTNode>>,
        right: Option<Box<DTNode>>,
    }

    impl DecisionTree {
        pub fn new(max_depth: usize, min_samples: usize) -> Self {
            Self { max_depth, min_samples_split: min_samples, root: None, feature_importances: Vec::new() }
        }

        pub fn fit_with_features(&mut self, x: &[Vec<f64>], y: &[f64], features: &[usize]) {
            let n_features = x.first().map(|r| r.len()).unwrap_or(0);
            self.feature_importances = vec![0.0; n_features];
            self.root = self.build_tree(x, y, features, 0);

            let sum: f64 = self.feature_importances.iter().sum();
            if sum > 0.0 { self.feature_importances.iter_mut().for_each(|v| *v /= sum); }
        }

        fn build_tree(&mut self, x: &[Vec<f64>], y: &[f64], features: &[usize], depth: usize) -> Option<Box<DTNode>> {
            if y.is_empty() { return None; }

            let mean = y.iter().sum::<f64>() / y.len() as f64;

            if depth >= self.max_depth || y.len() < self.min_samples_split {
                return Some(Box::new(DTNode {
                    feature_idx: 0, threshold: 0.0, value: mean, left: None, right: None
                }));
            }

            let mut best_gain = 0.0;
            let mut best_feature = 0;
            let mut best_threshold = 0.0;

            let variance = y.iter().map(|&yi| (yi - mean).powi(2)).sum::<f64>();

            for &f in features {
                let mut values: Vec<(f64, f64)> = x.iter().zip(y.iter())
                    .filter_map(|(row, &yi)| row.get(f).map(|&v| (v, yi))).collect();
                values.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap());

                for i in 1..values.len() {
                    let threshold = (values[i - 1].0 + values[i].0) / 2.0;
                    let left: Vec<f64> = values.iter().filter(|(v, _)| *v <= threshold).map(|(_, y)| *y).collect();
                    let right: Vec<f64> = values.iter().filter(|(v, _)| *v > threshold).map(|(_, y)| *y).collect();

                    if left.is_empty() || right.is_empty() { continue; }

                    let mean_left = left.iter().sum::<f64>() / left.len() as f64;
                    let mean_right = right.iter().sum::<f64>() / right.len() as f64;
                    let var_left = left.iter().map(|&yi| (yi - mean_left).powi(2)).sum::<f64>();
                    let var_right = right.iter().map(|&yi| (yi - mean_right).powi(2)).sum::<f64>();

                    let gain = variance - var_left - var_right;
                    if gain > best_gain {
                        best_gain = gain;
                        best_feature = f;
                        best_threshold = threshold;
                    }
                }
            }

            if best_gain <= 0.0 {
                return Some(Box::new(DTNode {
                    feature_idx: 0, threshold: 0.0, value: mean, left: None, right: None
                }));
            }

            self.feature_importances[best_feature] += best_gain;

            let (left_x, left_y): (Vec<Vec<f64>>, Vec<f64>) = x.iter().zip(y.iter())
                .filter(|(row, _)| row.get(best_feature).copied().unwrap_or(0.0) <= best_threshold)
                .map(|(row, &yi)| (row.clone(), yi)).unzip();

            let (right_x, right_y): (Vec<Vec<f64>>, Vec<f64>) = x.iter().zip(y.iter())
                .filter(|(row, _)| row.get(best_feature).copied().unwrap_or(0.0) > best_threshold)
                .map(|(row, &yi)| (row.clone(), yi)).unzip();

            Some(Box::new(DTNode {
                feature_idx: best_feature,
                threshold: best_threshold,
                value: mean,
                left: self.build_tree(&left_x, &left_y, features, depth + 1),
                right: self.build_tree(&right_x, &right_y, features, depth + 1),
            }))
        }

        pub fn predict_one(&self, x: &[f64]) -> f64 {
            let mut node = &self.root;
            while let Some(n) = node {
                if n.left.is_none() && n.right.is_none() { return n.value; }
                let val = x.get(n.feature_idx).copied().unwrap_or(0.0);
                node = if val <= n.threshold { &n.left } else { &n.right };
            }
            0.0
        }
    }

    /// Gradient Boosting classifier/regressor
    pub struct EnsembleGradientBoosting {
        pub n_estimators: usize,
        pub learning_rate: f64,
        pub max_depth: usize,
        pub subsample: f64,
        trees: Vec<DecisionTree>,
        initial_prediction: f64,
        rng_state: u64,
    }

    impl EnsembleGradientBoosting {
        pub fn new(n_estimators: usize, learning_rate: f64) -> Self {
            Self {
                n_estimators, learning_rate, max_depth: 3, subsample: 1.0,
                trees: Vec::new(), initial_prediction: 0.0, rng_state: 42,
            }
        }

        fn rand(&mut self) -> f64 {
            self.rng_state = self.rng_state.wrapping_mul(6364136223846793005).wrapping_add(1);
            (self.rng_state >> 11) as f64 / (1u64 << 53) as f64
        }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            self.initial_prediction = y.iter().sum::<f64>() / y.len() as f64;
            let mut predictions = vec![self.initial_prediction; y.len()];
            let n = x.len();
            let n_features = x.first().map(|r| r.len()).unwrap_or(0);
            let features: Vec<usize> = (0..n_features).collect();

            for _ in 0..self.n_estimators {
                // Compute residuals
                let residuals: Vec<f64> = y.iter().zip(&predictions).map(|(&yi, &pi)| yi - pi).collect();

                // Subsample
                let sample_size = (n as f64 * self.subsample) as usize;
                let indices: Vec<usize> = if self.subsample < 1.0 {
                    (0..sample_size).map(|_| (self.rand() * n as f64) as usize % n).collect()
                } else {
                    (0..n).collect()
                };

                let x_sample: Vec<Vec<f64>> = indices.iter().map(|&i| x[i].clone()).collect();
                let r_sample: Vec<f64> = indices.iter().map(|&i| residuals[i]).collect();

                let mut tree = DecisionTree::new(self.max_depth, 2);
                tree.fit_with_features(&x_sample, &r_sample, &features);

                // Update predictions
                for i in 0..n {
                    predictions[i] += self.learning_rate * tree.predict_one(&x[i]);
                }

                self.trees.push(tree);
            }
        }

        pub fn predict(&self, x: &[Vec<f64>]) -> Vec<f64> {
            x.iter().map(|row| {
                let mut pred = self.initial_prediction;
                for tree in &self.trees {
                    pred += self.learning_rate * tree.predict_one(row);
                }
                pred
            }).collect()
        }
    }

    /// Stacking ensemble
    pub struct StackingEnsemble {
        base_models: Vec<Box<dyn Predictor>>,
        meta_model: Option<Box<dyn Predictor>>,
        use_original_features: bool,
    }

    pub trait Predictor: Send + Sync {
        fn fit(&mut self, x: &[Vec<f64>], y: &[f64]);
        fn predict(&self, x: &[Vec<f64>]) -> Vec<f64>;
    }

    impl StackingEnsemble {
        pub fn new(use_original: bool) -> Self {
            Self { base_models: Vec::new(), meta_model: None, use_original_features: use_original }
        }

        pub fn add_base_model(&mut self, model: Box<dyn Predictor>) { self.base_models.push(model); }
        pub fn set_meta_model(&mut self, model: Box<dyn Predictor>) { self.meta_model = Some(model); }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            // Train base models
            for model in &mut self.base_models { model.fit(x, y); }

            // Generate meta-features
            let meta_features = self.generate_meta_features(x);

            // Train meta-model
            if let Some(meta) = &mut self.meta_model {
                meta.fit(&meta_features, y);
            }
        }

        fn generate_meta_features(&self, x: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let base_preds: Vec<Vec<f64>> = self.base_models.iter().map(|m| m.predict(x)).collect();

            x.iter().enumerate().map(|(i, row)| {
                let mut features: Vec<f64> = base_preds.iter().map(|preds| preds[i]).collect();
                if self.use_original_features { features.extend(row.iter().cloned()); }
                features
            }).collect()
        }

        pub fn predict(&self, x: &[Vec<f64>]) -> Vec<f64> {
            let meta_features = self.generate_meta_features(x);
            if let Some(meta) = &self.meta_model {
                meta.predict(&meta_features)
            } else {
                // Simple average if no meta-model
                let base_preds: Vec<Vec<f64>> = self.base_models.iter().map(|m| m.predict(x)).collect();
                (0..x.len()).map(|i| {
                    base_preds.iter().map(|preds| preds[i]).sum::<f64>() / base_preds.len() as f64
                }).collect()
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEURAL NETWORKS - Deep Learning with Backpropagation
// ═══════════════════════════════════════════════════════════════════════════════

pub mod neural {
    use std::sync::{Arc, RwLock};

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum Activation { ReLU, LeakyReLU(f64), Sigmoid, Tanh, Softmax, GELU, Swish, Mish }

    #[derive(Debug, Clone, Copy)]
    pub enum Initializer { Xavier, He, LeCun, Uniform(f64, f64), Normal(f64, f64) }

    #[derive(Debug, Clone)]
    pub struct DenseLayer {
        pub weights: Vec<Vec<f64>>,
        pub biases: Vec<f64>,
        pub activation: Activation,
        input_cache: Vec<f64>,
        pre_activation: Vec<f64>,
        weight_gradients: Vec<Vec<f64>>,
        bias_gradients: Vec<f64>,
    }

    impl DenseLayer {
        pub fn new(input_size: usize, output_size: usize, activation: Activation, init: Initializer) -> Self {
            let scale = match init {
                Initializer::Xavier => (2.0 / (input_size + output_size) as f64).sqrt(),
                Initializer::He => (2.0 / input_size as f64).sqrt(),
                Initializer::LeCun => (1.0 / input_size as f64).sqrt(),
                Initializer::Uniform(a, b) => (b - a) / 2.0,
                Initializer::Normal(_, std) => std,
            };

            let mut rng = SimpleRng::new(42);
            let weights = (0..output_size).map(|_| {
                (0..input_size).map(|_| rng.next_gaussian() * scale).collect()
            }).collect();

            Self {
                weights, biases: vec![0.0; output_size], activation,
                input_cache: Vec::new(), pre_activation: Vec::new(),
                weight_gradients: vec![vec![0.0; input_size]; output_size],
                bias_gradients: vec![0.0; output_size],
            }
        }

        pub fn forward(&mut self, input: &[f64]) -> Vec<f64> {
            self.input_cache = input.to_vec();
            self.pre_activation = self.weights.iter().zip(self.biases.iter())
                .map(|(w, b)| w.iter().zip(input.iter()).map(|(wi, xi)| wi * xi).sum::<f64>() + b)
                .collect();
            self.apply_activation(&self.pre_activation)
        }

        fn apply_activation(&self, z: &[f64]) -> Vec<f64> {
            match self.activation {
                Activation::ReLU => z.iter().map(|&x| x.max(0.0)).collect(),
                Activation::LeakyReLU(alpha) => z.iter().map(|&x| if x > 0.0 { x } else { alpha * x }).collect(),
                Activation::Sigmoid => z.iter().map(|&x| 1.0 / (1.0 + (-x).exp())).collect(),
                Activation::Tanh => z.iter().map(|&x| x.tanh()).collect(),
                Activation::Softmax => {
                    let max_z = z.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
                    let exp_z: Vec<f64> = z.iter().map(|&x| (x - max_z).exp()).collect();
                    let sum: f64 = exp_z.iter().sum();
                    exp_z.iter().map(|&x| x / sum).collect()
                }
                Activation::GELU => z.iter().map(|&x| 0.5 * x * (1.0 + (0.7978845608 * (x + 0.044715 * x.powi(3))).tanh())).collect(),
                Activation::Swish => z.iter().map(|&x| x / (1.0 + (-x).exp())).collect(),
                Activation::Mish => z.iter().map(|&x| x * ((1.0 + x.exp()).ln()).tanh()).collect(),
            }
        }

        fn activation_derivative(&self, z: &[f64]) -> Vec<f64> {
            match self.activation {
                Activation::ReLU => z.iter().map(|&x| if x > 0.0 { 1.0 } else { 0.0 }).collect(),
                Activation::LeakyReLU(alpha) => z.iter().map(|&x| if x > 0.0 { 1.0 } else { alpha }).collect(),
                Activation::Sigmoid => {
                    let s: Vec<f64> = z.iter().map(|&x| 1.0 / (1.0 + (-x).exp())).collect();
                    s.iter().map(|&si| si * (1.0 - si)).collect()
                }
                Activation::Tanh => z.iter().map(|&x| 1.0 - x.tanh().powi(2)).collect(),
                _ => vec![1.0; z.len()],
            }
        }

        pub fn backward(&mut self, upstream_grad: &[f64], learning_rate: f64) -> Vec<f64> {
            let act_deriv = self.activation_derivative(&self.pre_activation);
            let delta: Vec<f64> = upstream_grad.iter().zip(act_deriv.iter()).map(|(g, d)| g * d).collect();

            for (i, d) in delta.iter().enumerate() {
                self.bias_gradients[i] = *d;
                for (j, x) in self.input_cache.iter().enumerate() {
                    self.weight_gradients[i][j] = d * x;
                }
            }

            let input_grad: Vec<f64> = (0..self.input_cache.len()).map(|j| {
                self.weights.iter().zip(delta.iter()).map(|(w, d)| w[j] * d).sum()
            }).collect();

            for i in 0..self.weights.len() {
                self.biases[i] -= learning_rate * self.bias_gradients[i];
                for j in 0..self.weights[i].len() {
                    self.weights[i][j] -= learning_rate * self.weight_gradients[i][j];
                }
            }
            input_grad
        }
    }

    #[derive(Debug, Clone)]
    pub struct BatchNorm {
        pub gamma: Vec<f64>,
        pub beta: Vec<f64>,
        pub running_mean: Vec<f64>,
        pub running_var: Vec<f64>,
        pub epsilon: f64,
        pub momentum: f64,
        input_normalized: Vec<f64>,
        input_centered: Vec<f64>,
        std_inv: f64,
    }

    impl BatchNorm {
        pub fn new(size: usize) -> Self {
            Self {
                gamma: vec![1.0; size], beta: vec![0.0; size],
                running_mean: vec![0.0; size], running_var: vec![1.0; size],
                epsilon: 1e-5, momentum: 0.1,
                input_normalized: Vec::new(), input_centered: Vec::new(), std_inv: 1.0,
            }
        }

        pub fn forward(&mut self, input: &[f64], training: bool) -> Vec<f64> {
            if training {
                let mean: f64 = input.iter().sum::<f64>() / input.len() as f64;
                self.input_centered = input.iter().map(|x| x - mean).collect();
                let var: f64 = self.input_centered.iter().map(|x| x * x).sum::<f64>() / input.len() as f64;
                self.std_inv = 1.0 / (var + self.epsilon).sqrt();
                self.input_normalized = self.input_centered.iter().map(|x| x * self.std_inv).collect();

                for i in 0..self.running_mean.len().min(1) {
                    self.running_mean[i] = (1.0 - self.momentum) * self.running_mean[i] + self.momentum * mean;
                    self.running_var[i] = (1.0 - self.momentum) * self.running_var[i] + self.momentum * var;
                }

                self.input_normalized.iter().enumerate()
                    .map(|(i, &x)| self.gamma.get(i).unwrap_or(&1.0) * x + self.beta.get(i).unwrap_or(&0.0))
                    .collect()
            } else {
                input.iter().enumerate().map(|(i, &x)| {
                    let norm = (x - self.running_mean.get(i).unwrap_or(&0.0)) /
                              (self.running_var.get(i).unwrap_or(&1.0) + self.epsilon).sqrt();
                    self.gamma.get(i).unwrap_or(&1.0) * norm + self.beta.get(i).unwrap_or(&0.0)
                }).collect()
            }
        }
    }

    #[derive(Debug, Clone)]
    pub struct NeuralDropout { pub rate: f64, mask: Vec<bool> }

    impl NeuralDropout {
        pub fn new(rate: f64) -> Self { Self { rate, mask: Vec::new() } }

        pub fn forward(&mut self, input: &[f64], training: bool) -> Vec<f64> {
            if training {
                let mut rng = SimpleRng::new(input.len() as u64);
                self.mask = (0..input.len()).map(|_| rng.next_f64() > self.rate).collect();
                input.iter().zip(self.mask.iter())
                    .map(|(&x, &keep)| if keep { x / (1.0 - self.rate) } else { 0.0 })
                    .collect()
            } else { input.to_vec() }
        }

        pub fn backward(&self, grad: &[f64]) -> Vec<f64> {
            grad.iter().zip(self.mask.iter())
                .map(|(&g, &keep)| if keep { g / (1.0 - self.rate) } else { 0.0 })
                .collect()
        }
    }

    #[derive(Debug, Clone)]
    pub struct NeuralNetwork {
        pub layers: Vec<DenseLayer>,
        pub dropout_layers: Vec<Option<NeuralDropout>>,
        pub batch_norms: Vec<Option<BatchNorm>>,
        pub learning_rate: f64,
        pub l2_lambda: f64,
    }

    impl NeuralNetwork {
        pub fn new(learning_rate: f64) -> Self {
            Self { layers: Vec::new(), dropout_layers: Vec::new(), batch_norms: Vec::new(),
                   learning_rate, l2_lambda: 0.0 }
        }

        pub fn add_layer(&mut self, layer: DenseLayer, dropout: Option<NeuralDropout>, batch_norm: Option<BatchNorm>) {
            self.layers.push(layer);
            self.dropout_layers.push(dropout);
            self.batch_norms.push(batch_norm);
        }

        pub fn forward(&mut self, input: &[f64], training: bool) -> Vec<f64> {
            let mut x = input.to_vec();
            for i in 0..self.layers.len() {
                x = self.layers[i].forward(&x);
                if let Some(bn) = &mut self.batch_norms[i] { x = bn.forward(&x, training); }
                if let Some(drop) = &mut self.dropout_layers[i] { x = drop.forward(&x, training); }
            }
            x
        }

        pub fn backward(&mut self, loss_gradient: &[f64]) {
            let mut grad = loss_gradient.to_vec();
            for i in (0..self.layers.len()).rev() {
                if let Some(drop) = &self.dropout_layers[i] { grad = drop.backward(&grad); }
                grad = self.layers[i].backward(&grad, self.learning_rate);
            }
        }

        pub fn train(&mut self, x_train: &[Vec<f64>], y_train: &[Vec<f64>], epochs: usize, batch_size: usize) {
            for epoch in 0..epochs {
                let mut total_loss = 0.0;
                for batch_start in (0..x_train.len()).step_by(batch_size) {
                    let batch_end = (batch_start + batch_size).min(x_train.len());
                    for i in batch_start..batch_end {
                        let output = self.forward(&x_train[i], true);
                        let loss_grad: Vec<f64> = output.iter().zip(y_train[i].iter())
                            .map(|(o, t)| o - t).collect();
                        total_loss += loss_grad.iter().map(|g| g * g).sum::<f64>();
                        self.backward(&loss_grad);
                    }
                }
                if epoch % 100 == 0 {
                    let _avg_loss = total_loss / x_train.len() as f64;
                }
            }
        }

        pub fn predict(&mut self, input: &[f64]) -> Vec<f64> { self.forward(input, false) }
    }

    pub struct ConvLayer {
        pub filters: Vec<Vec<Vec<f64>>>,
        pub biases: Vec<f64>,
        pub stride: usize,
        pub padding: usize,
        input_cache: Vec<Vec<f64>>,
    }

    impl ConvLayer {
        pub fn new(num_filters: usize, kernel_size: usize, input_channels: usize) -> Self {
            let mut rng = SimpleRng::new(42);
            let scale = (2.0 / (kernel_size * kernel_size * input_channels) as f64).sqrt();
            let filters = (0..num_filters).map(|_| {
                (0..input_channels).map(|_| {
                    (0..kernel_size * kernel_size).map(|_| rng.next_gaussian() * scale).collect()
                }).collect()
            }).collect();
            Self { filters, biases: vec![0.0; num_filters], stride: 1, padding: 0, input_cache: Vec::new() }
        }

        pub fn forward(&mut self, input: &[Vec<f64>], height: usize, width: usize) -> Vec<Vec<f64>> {
            self.input_cache = input.to_vec();
            let kernel_size = (self.filters[0][0].len() as f64).sqrt() as usize;
            let out_h = (height + 2 * self.padding - kernel_size) / self.stride + 1;
            let out_w = (width + 2 * self.padding - kernel_size) / self.stride + 1;

            self.filters.iter().enumerate().map(|(f, filter)| {
                let mut output = vec![0.0; out_h * out_w];
                for oh in 0..out_h {
                    for ow in 0..out_w {
                        let mut sum = self.biases[f];
                        for (c, channel_filter) in filter.iter().enumerate() {
                            for kh in 0..kernel_size {
                                for kw in 0..kernel_size {
                                    let ih = oh * self.stride + kh;
                                    let iw = ow * self.stride + kw;
                                    if ih < height && iw < width {
                                        sum += input[c][ih * width + iw] * channel_filter[kh * kernel_size + kw];
                                    }
                                }
                            }
                        }
                        output[oh * out_w + ow] = sum.max(0.0);
                    }
                }
                output
            }).collect()
        }
    }

    pub struct MaxPool { pub pool_size: usize, pub stride: usize, indices: Vec<Vec<usize>> }

    impl MaxPool {
        pub fn new(pool_size: usize) -> Self { Self { pool_size, stride: pool_size, indices: Vec::new() } }

        pub fn forward(&mut self, input: &[Vec<f64>], height: usize, width: usize) -> Vec<Vec<f64>> {
            let out_h = height / self.stride;
            let out_w = width / self.stride;
            self.indices = vec![vec![0; out_h * out_w]; input.len()];

            input.iter().enumerate().map(|(c, channel)| {
                let mut output = vec![0.0; out_h * out_w];
                for oh in 0..out_h {
                    for ow in 0..out_w {
                        let mut max_val = f64::NEG_INFINITY;
                        let mut max_idx = 0;
                        for ph in 0..self.pool_size {
                            for pw in 0..self.pool_size {
                                let idx = (oh * self.stride + ph) * width + (ow * self.stride + pw);
                                if channel[idx] > max_val {
                                    max_val = channel[idx];
                                    max_idx = idx;
                                }
                            }
                        }
                        output[oh * out_w + ow] = max_val;
                        self.indices[c][oh * out_w + ow] = max_idx;
                    }
                }
                output
            }).collect()
        }
    }

    pub struct NeuralLSTMCell {
        pub hidden_size: usize,
        wf: Vec<Vec<f64>>, wi: Vec<Vec<f64>>, wc: Vec<Vec<f64>>, wo: Vec<Vec<f64>>,
        bf: Vec<f64>, bi: Vec<f64>, bc: Vec<f64>, bo: Vec<f64>,
    }

    impl NeuralLSTMCell {
        pub fn new(input_size: usize, hidden_size: usize) -> Self {
            let mut rng = SimpleRng::new(42);
            let scale = (1.0 / hidden_size as f64).sqrt();
            let init_weights = |size: usize| -> Vec<Vec<f64>> {
                (0..hidden_size).map(|_| (0..size).map(|_| rng.next_gaussian() * scale).collect()).collect()
            };
            let combined = input_size + hidden_size;
            Self {
                hidden_size,
                wf: init_weights(combined), wi: init_weights(combined),
                wc: init_weights(combined), wo: init_weights(combined),
                bf: vec![1.0; hidden_size], bi: vec![0.0; hidden_size],
                bc: vec![0.0; hidden_size], bo: vec![0.0; hidden_size],
            }
        }

        pub fn forward(&self, x: &[f64], h_prev: &[f64], c_prev: &[f64]) -> (Vec<f64>, Vec<f64>) {
            let combined: Vec<f64> = x.iter().chain(h_prev.iter()).cloned().collect();

            let gate = |w: &[Vec<f64>], b: &[f64]| -> Vec<f64> {
                w.iter().zip(b.iter()).map(|(wi, bi)| {
                    let z: f64 = wi.iter().zip(combined.iter()).map(|(a, b)| a * b).sum::<f64>() + bi;
                    1.0 / (1.0 + (-z).exp())
                }).collect()
            };

            let f = gate(&self.wf, &self.bf);
            let i = gate(&self.wi, &self.bi);
            let o = gate(&self.wo, &self.bo);

            let c_tilde: Vec<f64> = self.wc.iter().zip(self.bc.iter()).map(|(wi, bi)| {
                let z: f64 = wi.iter().zip(combined.iter()).map(|(a, b)| a * b).sum::<f64>() + bi;
                z.tanh()
            }).collect();

            let c: Vec<f64> = f.iter().zip(c_prev.iter()).zip(i.iter().zip(c_tilde.iter()))
                .map(|((fi, ci), (ii, cti))| fi * ci + ii * cti).collect();

            let h: Vec<f64> = o.iter().zip(c.iter()).map(|(oi, ci)| oi * ci.tanh()).collect();
            (h, c)
        }
    }

    pub struct NeuralGRUCell {
        pub hidden_size: usize,
        wz: Vec<Vec<f64>>, wr: Vec<Vec<f64>>, wh: Vec<Vec<f64>>,
        bz: Vec<f64>, br: Vec<f64>, bh: Vec<f64>,
    }

    impl NeuralGRUCell {
        pub fn new(input_size: usize, hidden_size: usize) -> Self {
            let mut rng = SimpleRng::new(42);
            let scale = (1.0 / hidden_size as f64).sqrt();
            let init_weights = |size: usize| -> Vec<Vec<f64>> {
                (0..hidden_size).map(|_| (0..size).map(|_| rng.next_gaussian() * scale).collect()).collect()
            };
            let combined = input_size + hidden_size;
            Self {
                hidden_size,
                wz: init_weights(combined), wr: init_weights(combined), wh: init_weights(combined),
                bz: vec![0.0; hidden_size], br: vec![0.0; hidden_size], bh: vec![0.0; hidden_size],
            }
        }

        pub fn forward(&self, x: &[f64], h_prev: &[f64]) -> Vec<f64> {
            let combined: Vec<f64> = x.iter().chain(h_prev.iter()).cloned().collect();

            let gate = |w: &[Vec<f64>], b: &[f64]| -> Vec<f64> {
                w.iter().zip(b.iter()).map(|(wi, bi)| {
                    let z: f64 = wi.iter().zip(combined.iter()).map(|(a, b)| a * b).sum::<f64>() + bi;
                    1.0 / (1.0 + (-z).exp())
                }).collect()
            };

            let z = gate(&self.wz, &self.bz);
            let r = gate(&self.wr, &self.br);

            let combined_reset: Vec<f64> = x.iter().chain(r.iter().zip(h_prev.iter()).map(|(ri, hi)| ri * hi)).cloned().collect();
            let h_tilde: Vec<f64> = self.wh.iter().zip(self.bh.iter()).map(|(wi, bi)| {
                let sum: f64 = wi.iter().zip(combined_reset.iter()).map(|(a, b)| a * b).sum::<f64>() + bi;
                sum.tanh()
            }).collect();

            z.iter().zip(h_prev.iter().zip(h_tilde.iter()))
                .map(|(zi, (hi, hti))| (1.0 - zi) * hi + zi * hti).collect()
        }
    }

    pub struct Attention {
        pub d_model: usize,
        wq: Vec<Vec<f64>>, wk: Vec<Vec<f64>>, wv: Vec<Vec<f64>>,
    }

    impl Attention {
        pub fn new(d_model: usize) -> Self {
            let mut rng = SimpleRng::new(42);
            let scale = (1.0 / d_model as f64).sqrt();
            let init = || (0..d_model).map(|_| (0..d_model).map(|_| rng.next_gaussian() * scale).collect()).collect();
            Self { d_model, wq: init(), wk: init(), wv: init() }
        }

        pub fn forward(&self, query: &[Vec<f64>], key: &[Vec<f64>], value: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let project = |input: &[Vec<f64>], w: &[Vec<f64>]| -> Vec<Vec<f64>> {
                input.iter().map(|x| {
                    w.iter().map(|wi| wi.iter().zip(x.iter()).map(|(a, b)| a * b).sum()).collect()
                }).collect()
            };

            let q = project(query, &self.wq);
            let k = project(key, &self.wk);
            let v = project(value, &self.wv);

            let scale = (self.d_model as f64).sqrt();

            q.iter().map(|qi| {
                let scores: Vec<f64> = k.iter().map(|ki| {
                    qi.iter().zip(ki.iter()).map(|(a, b)| a * b).sum::<f64>() / scale
                }).collect();

                let max_score = scores.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
                let exp_scores: Vec<f64> = scores.iter().map(|s| (s - max_score).exp()).collect();
                let sum: f64 = exp_scores.iter().sum();
                let weights: Vec<f64> = exp_scores.iter().map(|e| e / sum).collect();

                (0..self.d_model).map(|d| {
                    weights.iter().zip(v.iter()).map(|(w, vi)| w * vi[d]).sum()
                }).collect()
            }).collect()
        }
    }

    struct SimpleRng { state: u64 }
    impl SimpleRng {
        fn new(seed: u64) -> Self { Self { state: seed } }
        fn next_u64(&mut self) -> u64 {
            self.state = self.state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
            self.state
        }
        fn next_f64(&mut self) -> f64 { (self.next_u64() as f64) / (u64::MAX as f64) }
        fn next_gaussian(&mut self) -> f64 {
            let u1 = self.next_f64().max(1e-10);
            let u2 = self.next_f64();
            (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REINFORCEMENT LEARNING - Q-Learning, Policy Gradient, Actor-Critic
// ═══════════════════════════════════════════════════════════════════════════════

pub mod reinforcement {
    use std::collections::HashMap;
    use std::sync::{Arc, RwLock};

    #[derive(Debug, Clone)]
    pub struct State { pub features: Vec<f64>, pub discrete_id: Option<u64> }

    impl State {
        pub fn new(features: Vec<f64>) -> Self { Self { features, discrete_id: None } }
        pub fn discrete(id: u64) -> Self { Self { features: Vec::new(), discrete_id: Some(id) } }
    }

    #[derive(Debug, Clone)]
    pub struct Action { pub discrete: Option<usize>, pub continuous: Option<Vec<f64>> }

    impl Action {
        pub fn discrete(id: usize) -> Self { Self { discrete: Some(id), continuous: None } }
        pub fn continuous(values: Vec<f64>) -> Self { Self { discrete: None, continuous: Some(values) } }
    }

    #[derive(Debug, Clone)]
    pub struct Experience {
        pub state: State, pub action: Action, pub reward: f64,
        pub next_state: State, pub done: bool,
    }

    pub struct ReplayBuffer {
        buffer: Vec<Experience>,
        capacity: usize,
        position: usize,
    }

    impl ReplayBuffer {
        pub fn new(capacity: usize) -> Self {
            Self { buffer: Vec::with_capacity(capacity), capacity, position: 0 }
        }

        pub fn push(&mut self, exp: Experience) {
            if self.buffer.len() < self.capacity {
                self.buffer.push(exp);
            } else {
                self.buffer[self.position] = exp;
            }
            self.position = (self.position + 1) % self.capacity;
        }

        pub fn sample(&self, batch_size: usize) -> Vec<Experience> {
            let mut rng = SimpleRng::new(self.position as u64);
            (0..batch_size.min(self.buffer.len()))
                .map(|_| self.buffer[rng.next_usize(self.buffer.len())].clone())
                .collect()
        }

        pub fn len(&self) -> usize { self.buffer.len() }
    }

    pub struct QTable {
        table: HashMap<(u64, usize), f64>,
        num_actions: usize,
        learning_rate: f64,
        discount_factor: f64,
    }

    impl QTable {
        pub fn new(num_actions: usize, learning_rate: f64, discount_factor: f64) -> Self {
            Self { table: HashMap::new(), num_actions, learning_rate, discount_factor }
        }

        pub fn get_q(&self, state: u64, action: usize) -> f64 {
            *self.table.get(&(state, action)).unwrap_or(&0.0)
        }

        pub fn update(&mut self, state: u64, action: usize, reward: f64, next_state: u64, done: bool) {
            let max_next_q = if done { 0.0 } else {
                (0..self.num_actions).map(|a| self.get_q(next_state, a)).fold(f64::NEG_INFINITY, f64::max)
            };
            let current_q = self.get_q(state, action);
            let new_q = current_q + self.learning_rate * (reward + self.discount_factor * max_next_q - current_q);
            self.table.insert((state, action), new_q);
        }

        pub fn get_best_action(&self, state: u64) -> usize {
            (0..self.num_actions).max_by(|&a, &b| {
                self.get_q(state, a).partial_cmp(&self.get_q(state, b)).unwrap()
            }).unwrap_or(0)
        }

        pub fn get_epsilon_greedy_action(&self, state: u64, epsilon: f64) -> usize {
            let mut rng = SimpleRng::new(state);
            if rng.next_f64() < epsilon {
                rng.next_usize(self.num_actions)
            } else { self.get_best_action(state) }
        }
    }

    pub struct DQN {
        network: Vec<RLDenseLayer>,
        target_network: Vec<RLDenseLayer>,
        replay_buffer: ReplayBuffer,
        learning_rate: f64,
        discount_factor: f64,
        epsilon: f64,
        epsilon_decay: f64,
        min_epsilon: f64,
        target_update_freq: usize,
        steps: usize,
    }

    #[derive(Clone)]
    struct RLDenseLayer { weights: Vec<Vec<f64>>, biases: Vec<f64> }

    impl RLDenseLayer {
        fn new(input_size: usize, output_size: usize) -> Self {
            let mut rng = RLSimpleRng::new(42);
            let scale = (2.0 / input_size as f64).sqrt();
            Self {
                weights: (0..output_size).map(|_| (0..input_size).map(|_| rng.next_gaussian() * scale).collect()).collect(),
                biases: vec![0.0; output_size],
            }
        }

        fn forward(&self, input: &[f64]) -> Vec<f64> {
            self.weights.iter().zip(self.biases.iter())
                .map(|(w, b)| w.iter().zip(input.iter()).map(|(wi, xi)| wi * xi).sum::<f64>() + b)
                .map(|x| x.max(0.0))
                .collect()
        }
    }

    impl DQN {
        pub fn new(state_size: usize, action_size: usize, hidden_sizes: &[usize], buffer_capacity: usize) -> Self {
            let mut layers = Vec::new();
            let mut prev_size = state_size;
            for &size in hidden_sizes {
                layers.push(RLDenseLayer::new(prev_size, size));
                prev_size = size;
            }
            layers.push(RLDenseLayer::new(prev_size, action_size));

            Self {
                network: layers.clone(), target_network: layers,
                replay_buffer: ReplayBuffer::new(buffer_capacity),
                learning_rate: 0.001, discount_factor: 0.99,
                epsilon: 1.0, epsilon_decay: 0.995, min_epsilon: 0.01,
                target_update_freq: 100, steps: 0,
            }
        }

        pub fn select_action(&mut self, state: &[f64]) -> usize {
            let mut rng = RLSimpleRng::new(self.steps as u64);
            if rng.next_f64() < self.epsilon {
                let output_size = self.network.last().map(|l| l.weights.len()).unwrap_or(1);
                rng.next_usize(output_size)
            } else {
                let q_values = self.get_q_values(state);
                q_values.iter().enumerate().max_by(|(_, a), (_, b)| a.partial_cmp(b).unwrap())
                    .map(|(i, _)| i).unwrap_or(0)
            }
        }

        fn get_q_values(&self, state: &[f64]) -> Vec<f64> {
            let mut x = state.to_vec();
            for layer in &self.network { x = layer.forward(&x); }
            x
        }

        pub fn store_experience(&mut self, state: Vec<f64>, action: usize, reward: f64, next_state: Vec<f64>, done: bool) {
            self.replay_buffer.push(Experience {
                state: State::new(state), action: Action::discrete(action),
                reward, next_state: State::new(next_state), done,
            });
        }

        pub fn train(&mut self, batch_size: usize) {
            if self.replay_buffer.len() < batch_size { return; }

            let batch = self.replay_buffer.sample(batch_size);
            for exp in batch {
                let _target = exp.reward + if exp.done { 0.0 } else {
                    let mut x = exp.next_state.features.clone();
                    for layer in &self.target_network { x = layer.forward(&x); }
                    self.discount_factor * x.iter().cloned().fold(f64::NEG_INFINITY, f64::max)
                };
            }

            self.steps += 1;
            if self.steps % self.target_update_freq == 0 {
                self.target_network = self.network.clone();
            }
            self.epsilon = (self.epsilon * self.epsilon_decay).max(self.min_epsilon);
        }
    }

    pub struct PolicyGradient {
        weights: Vec<Vec<f64>>,
        biases: Vec<f64>,
        learning_rate: f64,
        episode_states: Vec<Vec<f64>>,
        episode_actions: Vec<usize>,
        episode_rewards: Vec<f64>,
    }

    impl PolicyGradient {
        pub fn new(state_size: usize, action_size: usize, learning_rate: f64) -> Self {
            let mut rng = RLSimpleRng::new(42);
            let scale = (2.0 / state_size as f64).sqrt();
            Self {
                weights: (0..action_size).map(|_| (0..state_size).map(|_| rng.next_gaussian() * scale).collect()).collect(),
                biases: vec![0.0; action_size], learning_rate,
                episode_states: Vec::new(), episode_actions: Vec::new(), episode_rewards: Vec::new(),
            }
        }

        fn softmax(&self, state: &[f64]) -> Vec<f64> {
            let logits: Vec<f64> = self.weights.iter().zip(self.biases.iter())
                .map(|(w, b)| w.iter().zip(state.iter()).map(|(wi, si)| wi * si).sum::<f64>() + b)
                .collect();
            let max_logit = logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let exp_logits: Vec<f64> = logits.iter().map(|l| (l - max_logit).exp()).collect();
            let sum: f64 = exp_logits.iter().sum();
            exp_logits.iter().map(|e| e / sum).collect()
        }

        pub fn select_action(&self, state: &[f64]) -> usize {
            let probs = self.softmax(state);
            let mut rng = RLSimpleRng::new((state.iter().sum::<f64>() * 1000.0) as u64);
            let r = rng.next_f64();
            let mut cumsum = 0.0;
            for (i, p) in probs.iter().enumerate() {
                cumsum += p;
                if r < cumsum { return i; }
            }
            probs.len() - 1
        }

        pub fn store(&mut self, state: Vec<f64>, action: usize, reward: f64) {
            self.episode_states.push(state);
            self.episode_actions.push(action);
            self.episode_rewards.push(reward);
        }

        pub fn update(&mut self, discount_factor: f64) {
            let n = self.episode_rewards.len();
            if n == 0 { return; }

            let mut returns = vec![0.0; n];
            returns[n - 1] = self.episode_rewards[n - 1];
            for t in (0..n - 1).rev() {
                returns[t] = self.episode_rewards[t] + discount_factor * returns[t + 1];
            }

            let mean: f64 = returns.iter().sum::<f64>() / n as f64;
            let std: f64 = (returns.iter().map(|r| (r - mean).powi(2)).sum::<f64>() / n as f64).sqrt() + 1e-8;
            let normalized: Vec<f64> = returns.iter().map(|r| (r - mean) / std).collect();

            for t in 0..n {
                let probs = self.softmax(&self.episode_states[t]);
                let action = self.episode_actions[t];
                for a in 0..self.weights.len() {
                    let grad = if a == action { 1.0 - probs[a] } else { -probs[a] };
                    for (j, s) in self.episode_states[t].iter().enumerate() {
                        self.weights[a][j] += self.learning_rate * normalized[t] * grad * s;
                    }
                    self.biases[a] += self.learning_rate * normalized[t] * grad;
                }
            }

            self.episode_states.clear();
            self.episode_actions.clear();
            self.episode_rewards.clear();
        }
    }

    pub struct ActorCritic {
        actor_weights: Vec<Vec<f64>>, actor_biases: Vec<f64>,
        critic_weights: Vec<Vec<f64>>, critic_bias: f64,
        actor_lr: f64, critic_lr: f64, discount_factor: f64,
    }

    impl ActorCritic {
        pub fn new(state_size: usize, action_size: usize, actor_lr: f64, critic_lr: f64) -> Self {
            let mut rng = RLSimpleRng::new(42);
            let scale = (2.0 / state_size as f64).sqrt();
            Self {
                actor_weights: (0..action_size).map(|_| (0..state_size).map(|_| rng.next_gaussian() * scale).collect()).collect(),
                actor_biases: vec![0.0; action_size],
                critic_weights: vec![(0..state_size).map(|_| rng.next_gaussian() * scale).collect()],
                critic_bias: 0.0,
                actor_lr, critic_lr, discount_factor: 0.99,
            }
        }

        fn get_value(&self, state: &[f64]) -> f64 {
            self.critic_weights[0].iter().zip(state.iter()).map(|(w, s)| w * s).sum::<f64>() + self.critic_bias
        }

        fn get_policy(&self, state: &[f64]) -> Vec<f64> {
            let logits: Vec<f64> = self.actor_weights.iter().zip(self.actor_biases.iter())
                .map(|(w, b)| w.iter().zip(state.iter()).map(|(wi, si)| wi * si).sum::<f64>() + b)
                .collect();
            let max_logit = logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let exp_logits: Vec<f64> = logits.iter().map(|l| (l - max_logit).exp()).collect();
            let sum: f64 = exp_logits.iter().sum();
            exp_logits.iter().map(|e| e / sum).collect()
        }

        pub fn select_action(&self, state: &[f64]) -> usize {
            let probs = self.get_policy(state);
            let mut rng = RLSimpleRng::new((state.iter().sum::<f64>() * 1000.0) as u64);
            let r = rng.next_f64();
            let mut cumsum = 0.0;
            for (i, p) in probs.iter().enumerate() {
                cumsum += p;
                if r < cumsum { return i; }
            }
            probs.len() - 1
        }

        pub fn update(&mut self, state: &[f64], action: usize, reward: f64, next_state: &[f64], done: bool) {
            let value = self.get_value(state);
            let next_value = if done { 0.0 } else { self.get_value(next_state) };
            let td_error = reward + self.discount_factor * next_value - value;

            for (j, s) in state.iter().enumerate() {
                self.critic_weights[0][j] += self.critic_lr * td_error * s;
            }
            self.critic_bias += self.critic_lr * td_error;

            let probs = self.get_policy(state);
            for a in 0..self.actor_weights.len() {
                let grad = if a == action { 1.0 - probs[a] } else { -probs[a] };
                for (j, s) in state.iter().enumerate() {
                    self.actor_weights[a][j] += self.actor_lr * td_error * grad * s;
                }
                self.actor_biases[a] += self.actor_lr * td_error * grad;
            }
        }
    }

    pub struct PPO {
        actor: PolicyNetwork, critic: ValueNetwork,
        clip_epsilon: f64, epochs: usize, batch_size: usize,
    }

    struct PolicyNetwork { weights: Vec<Vec<f64>>, biases: Vec<f64> }
    struct ValueNetwork { weights: Vec<f64>, bias: f64 }

    impl PPO {
        pub fn new(state_size: usize, action_size: usize) -> Self {
            let mut rng = RLSimpleRng::new(42);
            let scale = (2.0 / state_size as f64).sqrt();
            Self {
                actor: PolicyNetwork {
                    weights: (0..action_size).map(|_| (0..state_size).map(|_| rng.next_gaussian() * scale).collect()).collect(),
                    biases: vec![0.0; action_size],
                },
                critic: ValueNetwork {
                    weights: (0..state_size).map(|_| rng.next_gaussian() * scale).collect(),
                    bias: 0.0,
                },
                clip_epsilon: 0.2, epochs: 10, batch_size: 64,
            }
        }

        pub fn select_action(&self, state: &[f64]) -> (usize, f64) {
            let probs = self.get_probs(state);
            let mut rng = RLSimpleRng::new((state.iter().sum::<f64>() * 1000.0) as u64);
            let r = rng.next_f64();
            let mut cumsum = 0.0;
            for (i, p) in probs.iter().enumerate() {
                cumsum += p;
                if r < cumsum { return (i, probs[i]); }
            }
            (probs.len() - 1, probs[probs.len() - 1])
        }

        fn get_probs(&self, state: &[f64]) -> Vec<f64> {
            let logits: Vec<f64> = self.actor.weights.iter().zip(self.actor.biases.iter())
                .map(|(w, b)| w.iter().zip(state.iter()).map(|(wi, si)| wi * si).sum::<f64>() + b)
                .collect();
            let max_logit = logits.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let exp_logits: Vec<f64> = logits.iter().map(|l| (l - max_logit).exp()).collect();
            let sum: f64 = exp_logits.iter().sum();
            exp_logits.iter().map(|e| e / sum).collect()
        }

        pub fn get_value(&self, state: &[f64]) -> f64 {
            self.critic.weights.iter().zip(state.iter()).map(|(w, s)| w * s).sum::<f64>() + self.critic.bias
        }
    }

    struct RLRLSimpleRng { state: u64 }
    impl RLRLSimpleRng {
        fn new(seed: u64) -> Self { Self { state: seed.wrapping_add(1) } }
        fn next_u64(&mut self) -> u64 {
            self.state = self.state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
            self.state
        }
        fn next_f64(&mut self) -> f64 { (self.next_u64() as f64) / (u64::MAX as f64) }
        fn next_usize(&mut self, max: usize) -> usize { (self.next_u64() as usize) % max }
        fn next_gaussian(&mut self) -> f64 {
            let u1 = self.next_f64().max(1e-10);
            let u2 = self.next_f64();
            (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BAYESIAN LEARNING - Gaussian Processes, Bayesian Optimization
// ═══════════════════════════════════════════════════════════════════════════════

pub mod bayesian {
    use std::collections::HashMap;

    #[derive(Debug, Clone)]
    pub enum Kernel {
        RBF { length_scale: f64, variance: f64 },
        Matern { nu: f64, length_scale: f64, variance: f64 },
        Linear { variance: f64, offset: f64 },
        Polynomial { degree: u32, offset: f64, variance: f64 },
        Periodic { period: f64, length_scale: f64, variance: f64 },
        Sum(Box<Kernel>, Box<Kernel>),
        Product(Box<Kernel>, Box<Kernel>),
    }

    impl Kernel {
        pub fn evaluate(&self, x1: &[f64], x2: &[f64]) -> f64 {
            match self {
                Kernel::RBF { length_scale, variance } => {
                    let sq_dist: f64 = x1.iter().zip(x2.iter()).map(|(a, b)| (a - b).powi(2)).sum();
                    variance * (-sq_dist / (2.0 * length_scale.powi(2))).exp()
                }
                Kernel::Matern { nu, length_scale, variance } => {
                    let dist: f64 = x1.iter().zip(x2.iter()).map(|(a, b)| (a - b).powi(2)).sum::<f64>().sqrt();
                    let r = (2.0 * nu).sqrt() * dist / length_scale;
                    if r < 1e-10 { *variance }
                    else if (*nu - 0.5).abs() < 0.01 { variance * (-r).exp() }
                    else if (*nu - 1.5).abs() < 0.01 { variance * (1.0 + r) * (-r).exp() }
                    else { variance * (1.0 + r + r.powi(2) / 3.0) * (-r).exp() }
                }
                Kernel::Linear { variance, offset } => {
                    let dot: f64 = x1.iter().zip(x2.iter()).map(|(a, b)| a * b).sum();
                    variance * (dot + offset)
                }
                Kernel::Polynomial { degree, offset, variance } => {
                    let dot: f64 = x1.iter().zip(x2.iter()).map(|(a, b)| a * b).sum();
                    variance * (dot + offset).powi(*degree as i32)
                }
                Kernel::Periodic { period, length_scale, variance } => {
                    let dist: f64 = x1.iter().zip(x2.iter()).map(|(a, b)| (a - b).powi(2)).sum::<f64>().sqrt();
                    let sin_term = (std::f64::consts::PI * dist / period).sin();
                    variance * (-2.0 * sin_term.powi(2) / length_scale.powi(2)).exp()
                }
                Kernel::Sum(k1, k2) => k1.evaluate(x1, x2) + k2.evaluate(x1, x2),
                Kernel::Product(k1, k2) => k1.evaluate(x1, x2) * k2.evaluate(x1, x2),
            }
        }
    }

    pub struct GaussianProcess {
        kernel: Kernel,
        noise_variance: f64,
        x_train: Vec<Vec<f64>>,
        y_train: Vec<f64>,
        k_inv: Vec<Vec<f64>>,
        alpha: Vec<f64>,
    }

    impl GaussianProcess {
        pub fn new(kernel: Kernel, noise_variance: f64) -> Self {
            Self { kernel, noise_variance, x_train: Vec::new(), y_train: Vec::new(), k_inv: Vec::new(), alpha: Vec::new() }
        }

        pub fn fit(&mut self, x: &[Vec<f64>], y: &[f64]) {
            self.x_train = x.to_vec();
            self.y_train = y.to_vec();

            let n = x.len();
            let mut k: Vec<Vec<f64>> = vec![vec![0.0; n]; n];
            for i in 0..n {
                for j in 0..n {
                    k[i][j] = self.kernel.evaluate(&x[i], &x[j]);
                    if i == j { k[i][j] += self.noise_variance; }
                }
            }

            self.k_inv = self.invert_matrix(&k);
            self.alpha = self.mat_vec_mul(&self.k_inv, &self.y_train);
        }

        pub fn predict(&self, x_test: &[Vec<f64>]) -> (Vec<f64>, Vec<f64>) {
            let n_train = self.x_train.len();
            let n_test = x_test.len();

            let mut k_star: Vec<Vec<f64>> = vec![vec![0.0; n_train]; n_test];
            for i in 0..n_test {
                for j in 0..n_train {
                    k_star[i][j] = self.kernel.evaluate(&x_test[i], &self.x_train[j]);
                }
            }

            let means: Vec<f64> = k_star.iter()
                .map(|row| row.iter().zip(self.alpha.iter()).map(|(k, a)| k * a).sum())
                .collect();

            let mut variances = Vec::with_capacity(n_test);
            for i in 0..n_test {
                let k_ss = self.kernel.evaluate(&x_test[i], &x_test[i]);
                let v = self.mat_vec_mul(&self.k_inv, &k_star[i]);
                let var = k_ss - k_star[i].iter().zip(v.iter()).map(|(a, b)| a * b).sum::<f64>();
                variances.push(var.max(0.0));
            }

            (means, variances)
        }

        fn invert_matrix(&self, m: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = m.len();
            let mut aug: Vec<Vec<f64>> = m.iter().enumerate()
                .map(|(i, row)| {
                    let mut new_row = row.clone();
                    new_row.extend((0..n).map(|j| if i == j { 1.0 } else { 0.0 }));
                    new_row
                }).collect();

            for i in 0..n {
                let pivot = aug[i][i];
                if pivot.abs() < 1e-10 { continue; }
                for j in 0..2 * n { aug[i][j] /= pivot; }
                for k in 0..n {
                    if k != i {
                        let factor = aug[k][i];
                        for j in 0..2 * n { aug[k][j] -= factor * aug[i][j]; }
                    }
                }
            }

            aug.iter().map(|row| row[n..].to_vec()).collect()
        }

        fn mat_vec_mul(&self, m: &[Vec<f64>], v: &[f64]) -> Vec<f64> {
            m.iter().map(|row| row.iter().zip(v.iter()).map(|(a, b)| a * b).sum()).collect()
        }
    }

    pub enum AcquisitionFunction {
        ExpectedImprovement { xi: f64 },
        ProbabilityOfImprovement { xi: f64 },
        UpperConfidenceBound { beta: f64 },
        ThompsonSampling,
    }

    pub struct BayesianOptimizer {
        gp: GaussianProcess,
        acquisition: AcquisitionFunction,
        bounds: Vec<(f64, f64)>,
        x_observed: Vec<Vec<f64>>,
        y_observed: Vec<f64>,
        best_x: Vec<f64>,
        best_y: f64,
    }

    impl BayesianOptimizer {
        pub fn new(bounds: Vec<(f64, f64)>, acquisition: AcquisitionFunction) -> Self {
            let kernel = Kernel::RBF { length_scale: 1.0, variance: 1.0 };
            Self {
                gp: GaussianProcess::new(kernel, 0.01), acquisition, bounds,
                x_observed: Vec::new(), y_observed: Vec::new(),
                best_x: Vec::new(), best_y: f64::NEG_INFINITY,
            }
        }

        pub fn suggest(&mut self) -> Vec<f64> {
            if self.x_observed.is_empty() {
                return self.bounds.iter().map(|(lo, hi)| (lo + hi) / 2.0).collect();
            }

            self.gp.fit(&self.x_observed, &self.y_observed);

            let n_candidates = 1000;
            let mut rng = SimpleRng::new(self.x_observed.len() as u64);
            let candidates: Vec<Vec<f64>> = (0..n_candidates).map(|_| {
                self.bounds.iter().map(|(lo, hi)| lo + rng.next_f64() * (hi - lo)).collect()
            }).collect();

            let (means, variances) = self.gp.predict(&candidates);
            let acquisition_values: Vec<f64> = means.iter().zip(variances.iter())
                .map(|(m, v)| self.compute_acquisition(*m, *v))
                .collect();

            let best_idx = acquisition_values.iter().enumerate()
                .max_by(|(_, a), (_, b)| a.partial_cmp(b).unwrap())
                .map(|(i, _)| i).unwrap_or(0);

            candidates[best_idx].clone()
        }

        fn compute_acquisition(&self, mean: f64, variance: f64) -> f64 {
            let std = variance.sqrt().max(1e-10);
            match &self.acquisition {
                AcquisitionFunction::ExpectedImprovement { xi } => {
                    let z = (mean - self.best_y - xi) / std;
                    (mean - self.best_y - xi) * norm_cdf(z) + std * norm_pdf(z)
                }
                AcquisitionFunction::ProbabilityOfImprovement { xi } => {
                    let z = (mean - self.best_y - xi) / std;
                    norm_cdf(z)
                }
                AcquisitionFunction::UpperConfidenceBound { beta } => mean + beta * std,
                AcquisitionFunction::ThompsonSampling => {
                    let mut rng = SimpleRng::new((mean * 1e6) as u64);
                    mean + std * rng.next_gaussian()
                }
            }
        }

        pub fn observe(&mut self, x: Vec<f64>, y: f64) {
            if y > self.best_y { self.best_y = y; self.best_x = x.clone(); }
            self.x_observed.push(x);
            self.y_observed.push(y);
        }

        pub fn best(&self) -> (&[f64], f64) { (&self.best_x, self.best_y) }

        pub fn optimize<F>(&mut self, objective: F, n_iterations: usize) -> (Vec<f64>, f64)
        where F: Fn(&[f64]) -> f64 {
            for _ in 0..n_iterations {
                let x = self.suggest();
                let y = objective(&x);
                self.observe(x, y);
            }
            (self.best_x.clone(), self.best_y)
        }
    }

    pub struct VariationalInference {
        mean: Vec<f64>,
        log_var: Vec<f64>,
        learning_rate: f64,
    }

    impl VariationalInference {
        pub fn new(dim: usize, learning_rate: f64) -> Self {
            Self { mean: vec![0.0; dim], log_var: vec![0.0; dim], learning_rate }
        }

        pub fn sample(&self, n_samples: usize) -> Vec<Vec<f64>> {
            let mut rng = SimpleRng::new(42);
            (0..n_samples).map(|_| {
                self.mean.iter().zip(self.log_var.iter()).map(|(&m, &lv)| {
                    m + (lv / 2.0).exp() * rng.next_gaussian()
                }).collect()
            }).collect()
        }

        pub fn kl_divergence(&self) -> f64 {
            -0.5 * self.mean.iter().zip(self.log_var.iter())
                .map(|(&m, &lv)| 1.0 + lv - m.powi(2) - lv.exp())
                .sum::<f64>()
        }

        pub fn elbo<F>(&self, log_likelihood: F, n_samples: usize) -> f64
        where F: Fn(&[f64]) -> f64 {
            let samples = self.sample(n_samples);
            let expected_ll: f64 = samples.iter().map(|s| log_likelihood(s)).sum::<f64>() / n_samples as f64;
            expected_ll - self.kl_divergence()
        }
    }

    fn norm_cdf(x: f64) -> f64 { 0.5 * (1.0 + erf(x / 2.0_f64.sqrt())) }
    fn norm_pdf(x: f64) -> f64 { (-0.5 * x * x).exp() / (2.0 * std::f64::consts::PI).sqrt() }
    fn erf(x: f64) -> f64 {
        let a1 = 0.254829592; let a2 = -0.284496736; let a3 = 1.421413741;
        let a4 = -1.453152027; let a5 = 1.061405429; let p = 0.3275911;
        let sign = if x < 0.0 { -1.0 } else { 1.0 };
        let x = x.abs();
        let t = 1.0 / (1.0 + p * x);
        let y = 1.0 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * (-x * x).exp();
        sign * y
    }

    struct BayesSimpleRng { state: u64 }
    impl BayesSimpleRng {
        fn new(seed: u64) -> Self { Self { state: seed.wrapping_add(1) } }
        fn next_u64(&mut self) -> u64 {
            self.state = self.state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
            self.state
        }
        fn next_f64(&mut self) -> f64 { (self.next_u64() as f64) / (u64::MAX as f64) }
        fn next_gaussian(&mut self) -> f64 {
            let u1 = self.next_f64().max(1e-10);
            let u2 = self.next_f64();
            (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TIME SERIES - ARIMA, State Space, Forecasting
// ═══════════════════════════════════════════════════════════════════════════════

pub mod timeseries {
    #[derive(Debug, Clone)]
    pub struct ARIMAParams { pub p: usize, pub d: usize, pub q: usize }

    pub struct ARIMA {
        params: ARIMAParams,
        ar_coeffs: Vec<f64>,
        ma_coeffs: Vec<f64>,
        intercept: f64,
        residuals: Vec<f64>,
        fitted: bool,
    }

    impl ARIMA {
        pub fn new(p: usize, d: usize, q: usize) -> Self {
            Self {
                params: ARIMAParams { p, d, q },
                ar_coeffs: vec![0.0; p], ma_coeffs: vec![0.0; q],
                intercept: 0.0, residuals: Vec::new(), fitted: false,
            }
        }

        fn difference(&self, series: &[f64], d: usize) -> Vec<f64> {
            let mut result = series.to_vec();
            for _ in 0..d {
                result = result.windows(2).map(|w| w[1] - w[0]).collect();
            }
            result
        }

        fn integrate(&self, diff_series: &[f64], original: &[f64], d: usize) -> Vec<f64> {
            let mut result = diff_series.to_vec();
            for i in (0..d).rev() {
                let start = original[original.len() - d + i];
                let mut integrated = vec![start];
                for &val in &result { integrated.push(integrated.last().unwrap() + val); }
                result = integrated;
            }
            result
        }

        pub fn fit(&mut self, series: &[f64]) {
            let diff_series = self.difference(series, self.params.d);

            self.intercept = diff_series.iter().sum::<f64>() / diff_series.len() as f64;

            if self.params.p > 0 {
                let n = diff_series.len();
                for lag in 1..=self.params.p {
                    if lag < n {
                        let mut sum_xy = 0.0; let mut sum_xx = 0.0;
                        for i in lag..n {
                            let x = diff_series[i - lag] - self.intercept;
                            let y = diff_series[i] - self.intercept;
                            sum_xy += x * y; sum_xx += x * x;
                        }
                        self.ar_coeffs[lag - 1] = if sum_xx > 0.0 { sum_xy / sum_xx } else { 0.0 };
                    }
                }
            }

            self.residuals = Vec::with_capacity(diff_series.len());
            for i in 0..diff_series.len() {
                let mut pred = self.intercept;
                for (lag, coeff) in self.ar_coeffs.iter().enumerate() {
                    if i > lag { pred += coeff * (diff_series[i - lag - 1] - self.intercept); }
                }
                for (lag, coeff) in self.ma_coeffs.iter().enumerate() {
                    if i > lag && i - lag - 1 < self.residuals.len() {
                        pred += coeff * self.residuals[i - lag - 1];
                    }
                }
                self.residuals.push(diff_series[i] - pred);
            }
            self.fitted = true;
        }

        pub fn forecast(&self, series: &[f64], steps: usize) -> Vec<f64> {
            let diff_series = self.difference(series, self.params.d);
            let n = diff_series.len();

            let mut extended_diff = diff_series.clone();
            let mut extended_residuals = self.residuals.clone();

            for _ in 0..steps {
                let mut pred = self.intercept;
                let curr_idx = extended_diff.len();

                for (lag, coeff) in self.ar_coeffs.iter().enumerate() {
                    if curr_idx > lag {
                        pred += coeff * (extended_diff[curr_idx - lag - 1] - self.intercept);
                    }
                }
                for (lag, coeff) in self.ma_coeffs.iter().enumerate() {
                    if curr_idx > lag && curr_idx - lag - 1 < extended_residuals.len() {
                        pred += coeff * extended_residuals[curr_idx - lag - 1];
                    }
                }

                extended_diff.push(pred);
                extended_residuals.push(0.0);
            }

            if self.params.d > 0 {
                self.integrate(&extended_diff[n..], series, self.params.d)
            } else { extended_diff[n..].to_vec() }
        }

        pub fn aic(&self, series: &[f64]) -> f64 {
            let n = self.residuals.len() as f64;
            let rss: f64 = self.residuals.iter().map(|r| r * r).sum();
            let k = (self.params.p + self.params.q + 1) as f64;
            n * (rss / n).ln() + 2.0 * k
        }
    }

    pub struct ExponentialSmoothing {
        alpha: f64, beta: Option<f64>, gamma: Option<f64>,
        level: f64, trend: f64, seasonal: Vec<f64>,
        seasonal_period: usize,
    }

    impl ExponentialSmoothing {
        pub fn simple(alpha: f64) -> Self {
            Self { alpha, beta: None, gamma: None, level: 0.0, trend: 0.0, seasonal: Vec::new(), seasonal_period: 1 }
        }

        pub fn double(alpha: f64, beta: f64) -> Self {
            Self { alpha, beta: Some(beta), gamma: None, level: 0.0, trend: 0.0, seasonal: Vec::new(), seasonal_period: 1 }
        }

        pub fn triple(alpha: f64, beta: f64, gamma: f64, period: usize) -> Self {
            Self { alpha, beta: Some(beta), gamma: Some(gamma), level: 0.0, trend: 0.0, seasonal: vec![0.0; period], seasonal_period: period }
        }

        pub fn fit(&mut self, series: &[f64]) {
            if series.is_empty() { return; }

            self.level = series[0];

            if self.beta.is_some() && series.len() > 1 {
                self.trend = series[1] - series[0];
            }

            if let Some(_gamma) = self.gamma {
                for i in 0..self.seasonal_period.min(series.len()) {
                    self.seasonal[i] = series[i] - self.level;
                }
            }

            for (t, &y) in series.iter().enumerate().skip(1) {
                let season_idx = t % self.seasonal_period;
                let old_level = self.level;

                match (self.beta, self.gamma) {
                    (None, None) => {
                        self.level = self.alpha * y + (1.0 - self.alpha) * self.level;
                    }
                    (Some(beta), None) => {
                        self.level = self.alpha * y + (1.0 - self.alpha) * (old_level + self.trend);
                        self.trend = beta * (self.level - old_level) + (1.0 - beta) * self.trend;
                    }
                    (Some(beta), Some(gamma)) => {
                        let deseasonalized = y - self.seasonal[season_idx];
                        self.level = self.alpha * deseasonalized + (1.0 - self.alpha) * (old_level + self.trend);
                        self.trend = beta * (self.level - old_level) + (1.0 - beta) * self.trend;
                        self.seasonal[season_idx] = gamma * (y - self.level) + (1.0 - gamma) * self.seasonal[season_idx];
                    }
                    _ => {}
                }
            }
        }

        pub fn forecast(&self, steps: usize) -> Vec<f64> {
            (1..=steps).map(|h| {
                let base = self.level + self.trend * h as f64;
                if self.gamma.is_some() {
                    base + self.seasonal[h % self.seasonal_period]
                } else { base }
            }).collect()
        }
    }

    pub struct KalmanFilter {
        state: Vec<f64>,
        covariance: Vec<Vec<f64>>,
        transition: Vec<Vec<f64>>,
        observation: Vec<Vec<f64>>,
        process_noise: Vec<Vec<f64>>,
        measurement_noise: Vec<Vec<f64>>,
    }

    impl KalmanFilter {
        pub fn new(state_dim: usize, obs_dim: usize) -> Self {
            Self {
                state: vec![0.0; state_dim],
                covariance: vec![vec![1.0; state_dim]; state_dim],
                transition: (0..state_dim).map(|i| (0..state_dim).map(|j| if i == j { 1.0 } else { 0.0 }).collect()).collect(),
                observation: (0..obs_dim).map(|i| (0..state_dim).map(|j| if i == j { 1.0 } else { 0.0 }).collect()).collect(),
                process_noise: vec![vec![0.01; state_dim]; state_dim],
                measurement_noise: vec![vec![0.1; obs_dim]; obs_dim],
            }
        }

        pub fn predict(&mut self) {
            self.state = self.mat_vec_mul(&self.transition, &self.state);
            let fp = self.mat_mul(&self.transition, &self.covariance);
            let fpt = self.transpose(&self.transition);
            self.covariance = self.mat_add(&self.mat_mul(&fp, &fpt), &self.process_noise);
        }

        pub fn update(&mut self, observation: &[f64]) {
            let predicted_obs = self.mat_vec_mul(&self.observation, &self.state);
            let innovation: Vec<f64> = observation.iter().zip(predicted_obs.iter()).map(|(o, p)| o - p).collect();

            let hp = self.mat_mul(&self.observation, &self.covariance);
            let ht = self.transpose(&self.observation);
            let s = self.mat_add(&self.mat_mul(&hp, &ht), &self.measurement_noise);

            let s_inv = self.invert_matrix(&s);
            let pht = self.mat_mul(&self.covariance, &ht);
            let kalman_gain = self.mat_mul(&pht, &s_inv);

            let state_update = self.mat_vec_mul(&kalman_gain, &innovation);
            for (i, u) in state_update.iter().enumerate() { self.state[i] += u; }

            let kh = self.mat_mul(&kalman_gain, &self.observation);
            let i_kh: Vec<Vec<f64>> = (0..self.state.len()).map(|i| {
                (0..self.state.len()).map(|j| {
                    if i == j { 1.0 - kh[i][j] } else { -kh[i][j] }
                }).collect()
            }).collect();
            self.covariance = self.mat_mul(&i_kh, &self.covariance);
        }

        pub fn get_state(&self) -> &[f64] { &self.state }
        pub fn set_state(&mut self, state: Vec<f64>) { self.state = state; }

        fn mat_vec_mul(&self, m: &[Vec<f64>], v: &[f64]) -> Vec<f64> {
            m.iter().map(|row| row.iter().zip(v.iter()).map(|(a, b)| a * b).sum()).collect()
        }

        fn mat_mul(&self, a: &[Vec<f64>], b: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = a.len(); let m = b[0].len(); let p = b.len();
            (0..n).map(|i| (0..m).map(|j| (0..p).map(|k| a[i][k] * b[k][j]).sum()).collect()).collect()
        }

        fn mat_add(&self, a: &[Vec<f64>], b: &[Vec<f64>]) -> Vec<Vec<f64>> {
            a.iter().zip(b.iter()).map(|(ar, br)| ar.iter().zip(br.iter()).map(|(x, y)| x + y).collect()).collect()
        }

        fn transpose(&self, m: &[Vec<f64>]) -> Vec<Vec<f64>> {
            if m.is_empty() { return Vec::new(); }
            (0..m[0].len()).map(|j| (0..m.len()).map(|i| m[i][j]).collect()).collect()
        }

        fn invert_matrix(&self, m: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = m.len();
            let mut aug: Vec<Vec<f64>> = m.iter().enumerate()
                .map(|(i, row)| { let mut r = row.clone(); r.extend((0..n).map(|j| if i == j { 1.0 } else { 0.0 })); r })
                .collect();
            for i in 0..n {
                let pivot = aug[i][i];
                if pivot.abs() < 1e-10 { continue; }
                for j in 0..2 * n { aug[i][j] /= pivot; }
                for k in 0..n {
                    if k != i {
                        let factor = aug[k][i];
                        for j in 0..2 * n { aug[k][j] -= factor * aug[i][j]; }
                    }
                }
            }
            aug.iter().map(|row| row[n..].to_vec()).collect()
        }
    }

    pub struct SeasonalDecomposition {
        pub trend: Vec<f64>,
        pub seasonal: Vec<f64>,
        pub residual: Vec<f64>,
        period: usize,
    }

    impl SeasonalDecomposition {
        pub fn decompose(series: &[f64], period: usize, additive: bool) -> Self {
            let n = series.len();

            let trend: Vec<f64> = (0..n).map(|i| {
                let start = i.saturating_sub(period / 2);
                let end = (i + period / 2 + 1).min(n);
                series[start..end].iter().sum::<f64>() / (end - start) as f64
            }).collect();

            let detrended: Vec<f64> = if additive {
                series.iter().zip(trend.iter()).map(|(s, t)| s - t).collect()
            } else {
                series.iter().zip(trend.iter()).map(|(s, t)| if *t != 0.0 { s / t } else { 1.0 }).collect()
            };

            let mut seasonal_pattern = vec![0.0; period];
            let mut counts = vec![0usize; period];
            for (i, &d) in detrended.iter().enumerate() {
                seasonal_pattern[i % period] += d;
                counts[i % period] += 1;
            }
            for i in 0..period {
                if counts[i] > 0 { seasonal_pattern[i] /= counts[i] as f64; }
            }

            let seasonal: Vec<f64> = (0..n).map(|i| seasonal_pattern[i % period]).collect();

            let residual: Vec<f64> = if additive {
                series.iter().zip(trend.iter()).zip(seasonal.iter())
                    .map(|((s, t), sea)| s - t - sea).collect()
            } else {
                series.iter().zip(trend.iter()).zip(seasonal.iter())
                    .map(|((s, t), sea)| if *t * *sea != 0.0 { s / (t * sea) } else { 1.0 }).collect()
            };

            Self { trend, seasonal, residual, period }
        }
    }

    pub fn autocorrelation(series: &[f64], max_lag: usize) -> Vec<f64> {
        let n = series.len();
        let mean: f64 = series.iter().sum::<f64>() / n as f64;
        let var: f64 = series.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64;

        (0..=max_lag).map(|lag| {
            let cov: f64 = (0..n - lag).map(|i| (series[i] - mean) * (series[i + lag] - mean)).sum::<f64>() / n as f64;
            if var > 0.0 { cov / var } else { 0.0 }
        }).collect()
    }

    pub fn partial_autocorrelation(series: &[f64], max_lag: usize) -> Vec<f64> {
        let acf = autocorrelation(series, max_lag);
        let mut pacf = vec![1.0, acf[1]];

        for k in 2..=max_lag {
            let mut phi = vec![vec![0.0; k + 1]; k + 1];
            phi[1][1] = acf[1];

            for j in 2..=k {
                let num: f64 = acf[j] - (1..j).map(|i| phi[j - 1][i] * acf[j - i]).sum::<f64>();
                let den: f64 = 1.0 - (1..j).map(|i| phi[j - 1][i] * acf[i]).sum::<f64>();
                phi[j][j] = if den.abs() > 1e-10 { num / den } else { 0.0 };

                for i in 1..j { phi[j][i] = phi[j - 1][i] - phi[j][j] * phi[j - 1][j - i]; }
            }
            pacf.push(phi[k][k]);
        }
        pacf
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ANOMALY DETECTION - Isolation Forest, LOF, Autoencoders
// ═══════════════════════════════════════════════════════════════════════════════

pub mod anomaly {
    use std::collections::HashMap;

    pub struct IsolationTree {
        split_feature: Option<usize>,
        split_value: f64,
        left: Option<Box<IsolationTree>>,
        right: Option<Box<IsolationTree>>,
        size: usize,
    }

    impl IsolationTree {
        pub fn new(data: &[Vec<f64>], max_depth: usize, current_depth: usize) -> Self {
            if data.len() <= 1 || current_depth >= max_depth {
                return Self { split_feature: None, split_value: 0.0, left: None, right: None, size: data.len() };
            }

            let n_features = data[0].len();
            let mut rng = SimpleRng::new((data.len() * current_depth) as u64);
            let feature = rng.next_usize(n_features);

            let values: Vec<f64> = data.iter().map(|x| x[feature]).collect();
            let min_val = values.iter().cloned().fold(f64::INFINITY, f64::min);
            let max_val = values.iter().cloned().fold(f64::NEG_INFINITY, f64::max);

            if (max_val - min_val).abs() < 1e-10 {
                return Self { split_feature: None, split_value: 0.0, left: None, right: None, size: data.len() };
            }

            let split_value = min_val + rng.next_f64() * (max_val - min_val);

            let (left_data, right_data): (Vec<Vec<f64>>, Vec<Vec<f64>>) =
                data.iter().cloned().partition(|x| x[feature] < split_value);

            Self {
                split_feature: Some(feature), split_value,
                left: Some(Box::new(IsolationTree::new(&left_data, max_depth, current_depth + 1))),
                right: Some(Box::new(IsolationTree::new(&right_data, max_depth, current_depth + 1))),
                size: data.len(),
            }
        }

        pub fn path_length(&self, x: &[f64], current_length: f64) -> f64 {
            match self.split_feature {
                None => current_length + c_factor(self.size),
                Some(feature) => {
                    if x[feature] < self.split_value {
                        self.left.as_ref().map_or(current_length, |l| l.path_length(x, current_length + 1.0))
                    } else {
                        self.right.as_ref().map_or(current_length, |r| r.path_length(x, current_length + 1.0))
                    }
                }
            }
        }
    }

    fn c_factor(n: usize) -> f64 {
        if n <= 1 { 0.0 }
        else { 2.0 * ((n as f64 - 1.0).ln() + 0.5772156649) - 2.0 * (n as f64 - 1.0) / n as f64 }
    }

    pub struct IsolationForest {
        trees: Vec<IsolationTree>,
        sample_size: usize,
        n_estimators: usize,
    }

    impl IsolationForest {
        pub fn new(n_estimators: usize, sample_size: usize) -> Self {
            Self { trees: Vec::new(), sample_size, n_estimators }
        }

        pub fn fit(&mut self, data: &[Vec<f64>]) {
            let max_depth = (self.sample_size as f64).log2().ceil() as usize;
            let mut rng = SimpleRng::new(42);

            self.trees = (0..self.n_estimators).map(|_| {
                let sample: Vec<Vec<f64>> = (0..self.sample_size.min(data.len()))
                    .map(|_| data[rng.next_usize(data.len())].clone())
                    .collect();
                IsolationTree::new(&sample, max_depth, 0)
            }).collect();
        }

        pub fn anomaly_score(&self, x: &[f64]) -> f64 {
            let avg_path = self.trees.iter().map(|t| t.path_length(x, 0.0)).sum::<f64>() / self.trees.len() as f64;
            2.0_f64.powf(-avg_path / c_factor(self.sample_size))
        }

        pub fn predict(&self, data: &[Vec<f64>], threshold: f64) -> Vec<bool> {
            data.iter().map(|x| self.anomaly_score(x) > threshold).collect()
        }
    }

    pub struct LocalOutlierFactor {
        k: usize,
        data: Vec<Vec<f64>>,
        distances: Vec<Vec<(usize, f64)>>,
        lrd: Vec<f64>,
    }

    impl LocalOutlierFactor {
        pub fn new(k: usize) -> Self {
            Self { k, data: Vec::new(), distances: Vec::new(), lrd: Vec::new() }
        }

        pub fn fit(&mut self, data: &[Vec<f64>]) {
            self.data = data.to_vec();
            let n = data.len();

            self.distances = (0..n).map(|i| {
                let mut dists: Vec<(usize, f64)> = (0..n).filter(|&j| i != j)
                    .map(|j| (j, euclidean_distance(&data[i], &data[j])))
                    .collect();
                dists.sort_by(|a, b| a.1.partial_cmp(&b.1).unwrap());
                dists.truncate(self.k);
                dists
            }).collect();

            self.lrd = (0..n).map(|i| {
                let sum: f64 = self.distances[i].iter()
                    .map(|&(j, d)| reachability_distance(d, &self.distances[j]))
                    .sum();
                if sum > 0.0 { self.k as f64 / sum } else { 1.0 }
            }).collect();
        }

        pub fn lof_score(&self, idx: usize) -> f64 {
            if idx >= self.data.len() { return 1.0; }
            let sum: f64 = self.distances[idx].iter()
                .map(|&(j, _)| self.lrd[j] / self.lrd[idx])
                .sum();
            sum / self.k as f64
        }

        pub fn lof_scores(&self) -> Vec<f64> {
            (0..self.data.len()).map(|i| self.lof_score(i)).collect()
        }

        pub fn predict(&self, threshold: f64) -> Vec<bool> {
            self.lof_scores().into_iter().map(|s| s > threshold).collect()
        }
    }

    fn euclidean_distance(a: &[f64], b: &[f64]) -> f64 {
        a.iter().zip(b.iter()).map(|(x, y)| (x - y).powi(2)).sum::<f64>().sqrt()
    }

    fn reachability_distance(dist: f64, neighbors: &[(usize, f64)]) -> f64 {
        neighbors.last().map_or(dist, |&(_, k_dist)| dist.max(k_dist))
    }

    pub struct Autoencoder {
        encoder_weights: Vec<Vec<Vec<f64>>>,
        encoder_biases: Vec<Vec<f64>>,
        decoder_weights: Vec<Vec<Vec<f64>>>,
        decoder_biases: Vec<Vec<f64>>,
        learning_rate: f64,
    }

    impl Autoencoder {
        pub fn new(layer_sizes: &[usize], learning_rate: f64) -> Self {
            let mut rng = SimpleRng::new(42);

            let mut encoder_weights = Vec::new();
            let mut encoder_biases = Vec::new();
            for i in 0..layer_sizes.len() - 1 {
                let scale = (2.0 / layer_sizes[i] as f64).sqrt();
                encoder_weights.push((0..layer_sizes[i + 1]).map(|_| {
                    (0..layer_sizes[i]).map(|_| rng.next_gaussian() * scale).collect()
                }).collect());
                encoder_biases.push(vec![0.0; layer_sizes[i + 1]]);
            }

            let mut decoder_weights = Vec::new();
            let mut decoder_biases = Vec::new();
            for i in (0..layer_sizes.len() - 1).rev() {
                let scale = (2.0 / layer_sizes[i + 1] as f64).sqrt();
                decoder_weights.push((0..layer_sizes[i]).map(|_| {
                    (0..layer_sizes[i + 1]).map(|_| rng.next_gaussian() * scale).collect()
                }).collect());
                decoder_biases.push(vec![0.0; layer_sizes[i]]);
            }

            Self { encoder_weights, encoder_biases, decoder_weights, decoder_biases, learning_rate }
        }

        pub fn encode(&self, input: &[f64]) -> Vec<f64> {
            let mut x = input.to_vec();
            for (weights, biases) in self.encoder_weights.iter().zip(self.encoder_biases.iter()) {
                x = weights.iter().zip(biases.iter())
                    .map(|(w, b)| (w.iter().zip(x.iter()).map(|(a, b)| a * b).sum::<f64>() + b).max(0.0))
                    .collect();
            }
            x
        }

        pub fn decode(&self, encoded: &[f64]) -> Vec<f64> {
            let mut x = encoded.to_vec();
            for (weights, biases) in self.decoder_weights.iter().zip(self.decoder_biases.iter()) {
                x = weights.iter().zip(biases.iter())
                    .map(|(w, b)| (w.iter().zip(x.iter()).map(|(a, b)| a * b).sum::<f64>() + b).max(0.0))
                    .collect();
            }
            x
        }

        pub fn reconstruct(&self, input: &[f64]) -> Vec<f64> {
            self.decode(&self.encode(input))
        }

        pub fn reconstruction_error(&self, input: &[f64]) -> f64 {
            let reconstructed = self.reconstruct(input);
            input.iter().zip(reconstructed.iter()).map(|(a, b)| (a - b).powi(2)).sum::<f64>() / input.len() as f64
        }

        pub fn train(&mut self, data: &[Vec<f64>], epochs: usize) {
            for _ in 0..epochs {
                for sample in data {
                    let _error = self.reconstruction_error(sample);
                }
            }
        }

        pub fn detect_anomalies(&self, data: &[Vec<f64>], threshold: f64) -> Vec<bool> {
            data.iter().map(|x| self.reconstruction_error(x) > threshold).collect()
        }
    }

    pub struct OnlineAnomaly {
        window_size: usize,
        values: Vec<f64>,
        mean: f64,
        m2: f64,
        n: usize,
        threshold_sigma: f64,
    }

    impl OnlineAnomaly {
        pub fn new(window_size: usize, threshold_sigma: f64) -> Self {
            Self { window_size, values: Vec::with_capacity(window_size), mean: 0.0, m2: 0.0, n: 0, threshold_sigma }
        }

        pub fn update(&mut self, value: f64) -> bool {
            let is_anomaly = if self.n > 10 {
                let std = (self.m2 / self.n as f64).sqrt();
                (value - self.mean).abs() > self.threshold_sigma * std
            } else { false };

            self.n += 1;
            let delta = value - self.mean;
            self.mean += delta / self.n as f64;
            self.m2 += delta * (value - self.mean);

            self.values.push(value);
            if self.values.len() > self.window_size {
                let old = self.values.remove(0);
                let old_mean = self.mean;
                self.n -= 1;
                self.mean = (old_mean * (self.n + 1) as f64 - old) / self.n as f64;
            }

            is_anomaly
        }

        pub fn get_stats(&self) -> (f64, f64) {
            let std = if self.n > 0 { (self.m2 / self.n as f64).sqrt() } else { 0.0 };
            (self.mean, std)
        }
    }

    struct AnomalySimpleRng { state: u64 }
    impl AnomalySimpleRng {
        fn new(seed: u64) -> Self { Self { state: seed.wrapping_add(1) } }
        fn next_u64(&mut self) -> u64 {
            self.state = self.state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
            self.state
        }
        fn next_f64(&mut self) -> f64 { (self.next_u64() as f64) / (u64::MAX as f64) }
        fn next_usize(&mut self, max: usize) -> usize { (self.next_u64() as usize) % max }
        fn next_gaussian(&mut self) -> f64 {
            let u1 = self.next_f64().max(1e-10);
            let u2 = self.next_f64();
            (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIMENSIONALITY REDUCTION - PCA, t-SNE, UMAP-style
// ═══════════════════════════════════════════════════════════════════════════════

pub mod dimensionality {
    pub struct PCA {
        n_components: usize,
        mean: Vec<f64>,
        components: Vec<Vec<f64>>,
        explained_variance: Vec<f64>,
    }

    impl PCA {
        pub fn new(n_components: usize) -> Self {
            Self { n_components, mean: Vec::new(), components: Vec::new(), explained_variance: Vec::new() }
        }

        pub fn fit(&mut self, data: &[Vec<f64>]) {
            if data.is_empty() { return; }
            let n = data.len();
            let d = data[0].len();

            self.mean = (0..d).map(|j| data.iter().map(|row| row[j]).sum::<f64>() / n as f64).collect();

            let centered: Vec<Vec<f64>> = data.iter()
                .map(|row| row.iter().zip(self.mean.iter()).map(|(x, m)| x - m).collect())
                .collect();

            let mut cov = vec![vec![0.0; d]; d];
            for i in 0..d {
                for j in 0..=i {
                    let c: f64 = centered.iter().map(|row| row[i] * row[j]).sum::<f64>() / (n - 1) as f64;
                    cov[i][j] = c;
                    cov[j][i] = c;
                }
            }

            let (eigenvalues, eigenvectors) = self.power_iteration(&cov, self.n_components);
            self.explained_variance = eigenvalues;
            self.components = eigenvectors;
        }

        fn power_iteration(&self, matrix: &[Vec<f64>], n_components: usize) -> (Vec<f64>, Vec<Vec<f64>>) {
            let d = matrix.len();
            let mut eigenvalues = Vec::new();
            let mut eigenvectors = Vec::new();
            let mut deflated = matrix.to_vec();

            for _ in 0..n_components.min(d) {
                let mut v: Vec<f64> = (0..d).map(|i| if i == 0 { 1.0 } else { 0.0 }).collect();

                for _ in 0..100 {
                    let new_v: Vec<f64> = deflated.iter()
                        .map(|row| row.iter().zip(v.iter()).map(|(a, b)| a * b).sum())
                        .collect();
                    let norm: f64 = new_v.iter().map(|x| x * x).sum::<f64>().sqrt();
                    if norm < 1e-10 { break; }
                    v = new_v.iter().map(|x| x / norm).collect();
                }

                let eigenvalue: f64 = deflated.iter()
                    .zip(v.iter())
                    .map(|(row, &vi)| vi * row.iter().zip(v.iter()).map(|(a, b)| a * b).sum::<f64>())
                    .sum();

                eigenvalues.push(eigenvalue);
                eigenvectors.push(v.clone());

                for i in 0..d {
                    for j in 0..d {
                        deflated[i][j] -= eigenvalue * v[i] * v[j];
                    }
                }
            }

            (eigenvalues, eigenvectors)
        }

        pub fn transform(&self, data: &[Vec<f64>]) -> Vec<Vec<f64>> {
            data.iter().map(|row| {
                let centered: Vec<f64> = row.iter().zip(self.mean.iter()).map(|(x, m)| x - m).collect();
                self.components.iter().map(|component| {
                    component.iter().zip(centered.iter()).map(|(c, x)| c * x).sum()
                }).collect()
            }).collect()
        }

        pub fn inverse_transform(&self, reduced: &[Vec<f64>]) -> Vec<Vec<f64>> {
            reduced.iter().map(|row| {
                let d = self.mean.len();
                let mut reconstructed = self.mean.clone();
                for (i, component) in self.components.iter().enumerate() {
                    for j in 0..d { reconstructed[j] += row[i] * component[j]; }
                }
                reconstructed
            }).collect()
        }

        pub fn explained_variance_ratio(&self) -> Vec<f64> {
            let total: f64 = self.explained_variance.iter().sum();
            self.explained_variance.iter().map(|v| v / total).collect()
        }
    }

    pub struct TSNE {
        n_components: usize,
        perplexity: f64,
        learning_rate: f64,
        n_iter: usize,
    }

    impl TSNE {
        pub fn new(n_components: usize, perplexity: f64) -> Self {
            Self { n_components, perplexity, learning_rate: 200.0, n_iter: 1000 }
        }

        pub fn fit_transform(&self, data: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = data.len();

            let p = self.compute_pairwise_affinities(data);

            let mut rng = SimpleRng::new(42);
            let mut y: Vec<Vec<f64>> = (0..n).map(|_| {
                (0..self.n_components).map(|_| rng.next_gaussian() * 0.01).collect()
            }).collect();

            let mut velocity: Vec<Vec<f64>> = vec![vec![0.0; self.n_components]; n];
            let momentum = 0.5;

            for iter in 0..self.n_iter {
                let q = self.compute_low_dim_affinities(&y);

                let mut grad: Vec<Vec<f64>> = vec![vec![0.0; self.n_components]; n];
                for i in 0..n {
                    for j in 0..n {
                        if i == j { continue; }
                        let mult = 4.0 * (p[i][j] - q[i][j]) * (1.0 + self.squared_distance(&y[i], &y[j])).powi(-1);
                        for d in 0..self.n_components {
                            grad[i][d] += mult * (y[i][d] - y[j][d]);
                        }
                    }
                }

                let current_momentum = if iter < 250 { momentum } else { 0.8 };
                for i in 0..n {
                    for d in 0..self.n_components {
                        velocity[i][d] = current_momentum * velocity[i][d] - self.learning_rate * grad[i][d];
                        y[i][d] += velocity[i][d];
                    }
                }
            }

            y
        }

        fn compute_pairwise_affinities(&self, data: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = data.len();
            let mut p = vec![vec![0.0; n]; n];

            for i in 0..n {
                let mut beta = 1.0;
                for _ in 0..50 {
                    let mut sum = 0.0;
                    for j in 0..n {
                        if i != j {
                            let d = self.squared_distance(&data[i], &data[j]);
                            p[i][j] = (-d * beta).exp();
                            sum += p[i][j];
                        }
                    }
                    if sum > 0.0 {
                        for j in 0..n { p[i][j] /= sum; }
                    }

                    let entropy: f64 = -p[i].iter().filter(|&&x| x > 0.0).map(|x| x * x.ln()).sum::<f64>();
                    let perp = entropy.exp();
                    if (perp - self.perplexity).abs() < 1.0 { break; }
                    beta *= if perp > self.perplexity { 2.0 } else { 0.5 };
                }
            }

            for i in 0..n {
                for j in i + 1..n {
                    let pij = (p[i][j] + p[j][i]) / (2.0 * n as f64);
                    p[i][j] = pij;
                    p[j][i] = pij;
                }
            }

            p
        }

        fn compute_low_dim_affinities(&self, y: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let n = y.len();
            let mut q = vec![vec![0.0; n]; n];
            let mut sum = 0.0;

            for i in 0..n {
                for j in i + 1..n {
                    let dist = 1.0 / (1.0 + self.squared_distance(&y[i], &y[j]));
                    q[i][j] = dist;
                    q[j][i] = dist;
                    sum += 2.0 * dist;
                }
            }

            for i in 0..n {
                for j in 0..n { q[i][j] /= sum.max(1e-10); }
            }

            q
        }

        fn squared_distance(&self, a: &[f64], b: &[f64]) -> f64 {
            a.iter().zip(b.iter()).map(|(x, y)| (x - y).powi(2)).sum()
        }
    }

    pub struct KernelPCA {
        kernel: KernelType,
        n_components: usize,
        alphas: Vec<Vec<f64>>,
        lambdas: Vec<f64>,
        x_fit: Vec<Vec<f64>>,
    }

    #[derive(Clone)]
    pub enum KernelType {
        Linear,
        Polynomial { degree: u32, coef0: f64 },
        RBF { gamma: f64 },
        Sigmoid { gamma: f64, coef0: f64 },
    }

    impl KernelPCA {
        pub fn new(kernel: KernelType, n_components: usize) -> Self {
            Self { kernel, n_components, alphas: Vec::new(), lambdas: Vec::new(), x_fit: Vec::new() }
        }

        fn kernel_fn(&self, a: &[f64], b: &[f64]) -> f64 {
            match &self.kernel {
                KernelType::Linear => a.iter().zip(b.iter()).map(|(x, y)| x * y).sum(),
                KernelType::Polynomial { degree, coef0 } => {
                    let dot: f64 = a.iter().zip(b.iter()).map(|(x, y)| x * y).sum();
                    (dot + coef0).powi(*degree as i32)
                }
                KernelType::RBF { gamma } => {
                    let sq_dist: f64 = a.iter().zip(b.iter()).map(|(x, y)| (x - y).powi(2)).sum();
                    (-gamma * sq_dist).exp()
                }
                KernelType::Sigmoid { gamma, coef0 } => {
                    let dot: f64 = a.iter().zip(b.iter()).map(|(x, y)| x * y).sum();
                    (gamma * dot + coef0).tanh()
                }
            }
        }

        pub fn fit(&mut self, data: &[Vec<f64>]) {
            self.x_fit = data.to_vec();
            let n = data.len();

            let mut k = vec![vec![0.0; n]; n];
            for i in 0..n {
                for j in 0..=i {
                    let val = self.kernel_fn(&data[i], &data[j]);
                    k[i][j] = val;
                    k[j][i] = val;
                }
            }

            let row_mean: Vec<f64> = k.iter().map(|row| row.iter().sum::<f64>() / n as f64).collect();
            let total_mean: f64 = row_mean.iter().sum::<f64>() / n as f64;

            for i in 0..n {
                for j in 0..n {
                    k[i][j] = k[i][j] - row_mean[i] - row_mean[j] + total_mean;
                }
            }

            let (lambdas, alphas) = self.eigen_decomposition(&k, self.n_components);
            self.lambdas = lambdas;
            self.alphas = alphas;
        }

        fn eigen_decomposition(&self, matrix: &[Vec<f64>], n_components: usize) -> (Vec<f64>, Vec<Vec<f64>>) {
            let n = matrix.len();
            let mut eigenvalues = Vec::new();
            let mut eigenvectors = Vec::new();
            let mut deflated = matrix.to_vec();

            for _ in 0..n_components.min(n) {
                let mut v: Vec<f64> = (0..n).map(|i| if i == 0 { 1.0 } else { 0.0 }).collect();

                for _ in 0..100 {
                    let new_v: Vec<f64> = deflated.iter()
                        .map(|row| row.iter().zip(v.iter()).map(|(a, b)| a * b).sum())
                        .collect();
                    let norm: f64 = new_v.iter().map(|x| x * x).sum::<f64>().sqrt();
                    if norm < 1e-10 { break; }
                    v = new_v.iter().map(|x| x / norm).collect();
                }

                let eigenvalue: f64 = deflated.iter().zip(v.iter())
                    .map(|(row, &vi)| vi * row.iter().zip(v.iter()).map(|(a, b)| a * b).sum::<f64>())
                    .sum();

                if eigenvalue > 1e-10 {
                    let scaled: Vec<f64> = v.iter().map(|x| x / eigenvalue.sqrt()).collect();
                    eigenvalues.push(eigenvalue);
                    eigenvectors.push(scaled);
                }

                for i in 0..n {
                    for j in 0..n { deflated[i][j] -= eigenvalue * v[i] * v[j]; }
                }
            }

            (eigenvalues, eigenvectors)
        }

        pub fn transform(&self, data: &[Vec<f64>]) -> Vec<Vec<f64>> {
            data.iter().map(|x| {
                let k: Vec<f64> = self.x_fit.iter().map(|xi| self.kernel_fn(x, xi)).collect();
                self.alphas.iter().map(|alpha| {
                    alpha.iter().zip(k.iter()).map(|(a, ki)| a * ki).sum()
                }).collect()
            }).collect()
        }
    }

    struct DimSimpleRng { state: u64 }
    impl DimSimpleRng {
        fn new(seed: u64) -> Self { Self { state: seed.wrapping_add(1) } }
        fn next_u64(&mut self) -> u64 {
            self.state = self.state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
            self.state
        }
        fn next_f64(&mut self) -> f64 { (self.next_u64() as f64) / (u64::MAX as f64) }
        fn next_gaussian(&mut self) -> f64 {
            let u1 = self.next_f64().max(1e-10);
            let u2 = self.next_f64();
            (-2.0 * u1.ln()).sqrt() * (2.0 * std::f64::consts::PI * u2).cos()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_feature_engineering() {
        let prices: Vec<f64> = (0..100).map(|i| 100.0 + (i as f64 * 0.1).sin() * 10.0).collect();
        let volumes: Vec<f64> = vec![1000.0; 100];
        
        let fe = FeatureEngineering::new(20);
        let features = fe.generate(&prices, &volumes);
        
        assert!(!features.is_empty());
    }
    
    #[test]
    fn test_lstm() {
        let lstm = LSTMPredictor::new(5, &[32, 16], 1, 10);
        let sequence: Vec<Vec<f64>> = (0..10).map(|_| vec![0.1; 5]).collect();
        
        let output = lstm.predict(&sequence);
        assert_eq!(output.len(), 1);
    }
    
    #[test]
    fn test_ppo_agent() {
        let agent = PPOAgent::new(10, 3);
        let state = TradingState {
            features: vec![0.1; 10],
            position: 0.0,
            cash: 10000.0,
            portfolio_value: 10000.0,
            timestamp: 0,
        };
        
        let action = agent.select_action(&state);
        assert!(matches!(action, TradingAction::Hold | TradingAction::Buy(_) | TradingAction::Sell(_)));
    }
    
    #[test]
    fn test_walk_forward() {
        let validator = WalkForwardValidator::new(100, 20, 20);
        let splits = validator.splits(200);
        
        assert!(!splits.is_empty());
        assert_eq!(splits[0].0, 0..100);
        assert_eq!(splits[0].1, 100..120);
    }
}
