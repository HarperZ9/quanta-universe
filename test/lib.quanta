// =============================================================================
// QUANTA TEST - Test Runner Framework for QuantaLang
// =============================================================================
// A comprehensive testing framework with assertions, fixtures, mocking,
// parallel execution, and coverage tracking.
// =============================================================================

use quantalang::prelude::*;
use std::collections::{HashMap, HashSet, BTreeMap};
use std::sync::{Arc, RwLock, Mutex, atomic::{AtomicBool, AtomicU64, AtomicUsize, Ordering}};
use std::path::{Path, PathBuf};
use std::time::{Duration, Instant};
use std::panic;
use std::io::{Write, BufWriter};
use std::fs;

// =============================================================================
// TEST RESULT TYPES
// =============================================================================

/// Test result status
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TestStatus {
    Passed,
    Failed,
    Skipped,
    Ignored,
    TimedOut,
}

/// Single test result
#[derive(Debug, Clone)]
pub struct TestResult {
    pub name: String,
    pub module: String,
    pub status: TestStatus,
    pub duration: Duration,
    pub message: Option<String>,
    pub location: Option<TestLocation>,
    pub stdout: String,
    pub stderr: String,
}

/// Test location in source
#[derive(Debug, Clone)]
pub struct TestLocation {
    pub file: PathBuf,
    pub line: u32,
    pub column: u32,
}

/// Test suite result
#[derive(Debug, Clone)]
pub struct SuiteResult {
    pub name: String,
    pub tests: Vec<TestResult>,
    pub duration: Duration,
    pub passed: usize,
    pub failed: usize,
    pub skipped: usize,
    pub ignored: usize,
}

impl SuiteResult {
    pub fn new(name: &str) -> Self {
        SuiteResult {
            name: name.to_string(),
            tests: Vec::new(),
            duration: Duration::ZERO,
            passed: 0,
            failed: 0,
            skipped: 0,
            ignored: 0,
        }
    }

    pub fn add_result(&mut self, result: TestResult) {
        match result.status {
            TestStatus::Passed => self.passed += 1,
            TestStatus::Failed | TestStatus::TimedOut => self.failed += 1,
            TestStatus::Skipped => self.skipped += 1,
            TestStatus::Ignored => self.ignored += 1,
        }
        self.tests.push(result);
    }

    pub fn total(&self) -> usize {
        self.passed + self.failed + self.skipped + self.ignored
    }

    pub fn success(&self) -> bool {
        self.failed == 0
    }
}

// =============================================================================
// ASSERTION MACROS AND FUNCTIONS
// =============================================================================

/// Assertion error
#[derive(Debug)]
pub struct AssertionError {
    pub message: String,
    pub expected: Option<String>,
    pub actual: Option<String>,
    pub location: Option<TestLocation>,
}

impl std::fmt::Display for AssertionError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.message)?;
        if let Some(ref expected) = self.expected {
            write!(f, "\n  Expected: {}", expected)?;
        }
        if let Some(ref actual) = self.actual {
            write!(f, "\n    Actual: {}", actual)?;
        }
        Ok(())
    }
}

/// Assert that a condition is true
pub fn assert_true(condition: bool, message: Option<&str>) -> Result<(), AssertionError> {
    if condition {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: expected true").to_string(),
            expected: Some("true".to_string()),
            actual: Some("false".to_string()),
            location: None,
        })
    }
}

/// Assert that a condition is false
pub fn assert_false(condition: bool, message: Option<&str>) -> Result<(), AssertionError> {
    if !condition {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: expected false").to_string(),
            expected: Some("false".to_string()),
            actual: Some("true".to_string()),
            location: None,
        })
    }
}

/// Assert equality
pub fn assert_eq<T: PartialEq + std::fmt::Debug>(
    left: &T,
    right: &T,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if left == right {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: values not equal").to_string(),
            expected: Some(format!("{:?}", right)),
            actual: Some(format!("{:?}", left)),
            location: None,
        })
    }
}

/// Assert inequality
pub fn assert_ne<T: PartialEq + std::fmt::Debug>(
    left: &T,
    right: &T,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if left != right {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: values should not be equal").to_string(),
            expected: Some(format!("not {:?}", right)),
            actual: Some(format!("{:?}", left)),
            location: None,
        })
    }
}

/// Assert that value is None
pub fn assert_none<T: std::fmt::Debug>(value: &Option<T>, message: Option<&str>) -> Result<(), AssertionError> {
    if value.is_none() {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: expected None").to_string(),
            expected: Some("None".to_string()),
            actual: Some(format!("{:?}", value)),
            location: None,
        })
    }
}

/// Assert that value is Some
pub fn assert_some<T: std::fmt::Debug>(value: &Option<T>, message: Option<&str>) -> Result<(), AssertionError> {
    if value.is_some() {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: expected Some").to_string(),
            expected: Some("Some(_)".to_string()),
            actual: Some("None".to_string()),
            location: None,
        })
    }
}

/// Assert that result is Ok
pub fn assert_ok<T: std::fmt::Debug, E: std::fmt::Debug>(
    result: &Result<T, E>,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if result.is_ok() {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: expected Ok").to_string(),
            expected: Some("Ok(_)".to_string()),
            actual: Some(format!("{:?}", result)),
            location: None,
        })
    }
}

/// Assert that result is Err
pub fn assert_err<T: std::fmt::Debug, E: std::fmt::Debug>(
    result: &Result<T, E>,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if result.is_err() {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: expected Err").to_string(),
            expected: Some("Err(_)".to_string()),
            actual: Some(format!("{:?}", result)),
            location: None,
        })
    }
}

/// Assert approximately equal (for floats)
pub fn assert_approx_eq(
    left: f64,
    right: f64,
    epsilon: f64,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if (left - right).abs() < epsilon {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: values not approximately equal").to_string(),
            expected: Some(format!("{} ± {}", right, epsilon)),
            actual: Some(format!("{}", left)),
            location: None,
        })
    }
}

/// Assert that a value is greater than another
pub fn assert_gt<T: PartialOrd + std::fmt::Debug>(
    left: &T,
    right: &T,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if left > right {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: left not greater than right").to_string(),
            expected: Some(format!("> {:?}", right)),
            actual: Some(format!("{:?}", left)),
            location: None,
        })
    }
}

/// Assert that a value is less than another
pub fn assert_lt<T: PartialOrd + std::fmt::Debug>(
    left: &T,
    right: &T,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if left < right {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: left not less than right").to_string(),
            expected: Some(format!("< {:?}", right)),
            actual: Some(format!("{:?}", left)),
            location: None,
        })
    }
}

/// Assert that a string contains a substring
pub fn assert_contains(haystack: &str, needle: &str, message: Option<&str>) -> Result<(), AssertionError> {
    if haystack.contains(needle) {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: string does not contain substring").to_string(),
            expected: Some(format!("to contain \"{}\"", needle)),
            actual: Some(format!("\"{}\"", haystack)),
            location: None,
        })
    }
}

/// Assert that a collection contains an element
pub fn assert_collection_contains<T: PartialEq + std::fmt::Debug>(
    collection: &[T],
    element: &T,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if collection.contains(element) {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: collection does not contain element").to_string(),
            expected: Some(format!("to contain {:?}", element)),
            actual: Some(format!("{:?}", collection)),
            location: None,
        })
    }
}

/// Assert that a collection is empty
pub fn assert_empty<T: std::fmt::Debug>(collection: &[T], message: Option<&str>) -> Result<(), AssertionError> {
    if collection.is_empty() {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: collection not empty").to_string(),
            expected: Some("empty collection".to_string()),
            actual: Some(format!("{:?}", collection)),
            location: None,
        })
    }
}

/// Assert that a collection has a specific length
pub fn assert_len<T: std::fmt::Debug>(
    collection: &[T],
    expected_len: usize,
    message: Option<&str>,
) -> Result<(), AssertionError> {
    if collection.len() == expected_len {
        Ok(())
    } else {
        Err(AssertionError {
            message: message.unwrap_or("Assertion failed: wrong collection length").to_string(),
            expected: Some(format!("length {}", expected_len)),
            actual: Some(format!("length {}", collection.len())),
            location: None,
        })
    }
}

// =============================================================================
// TEST FUNCTION TYPE
// =============================================================================

/// Test function signature
pub type TestFn = Box<dyn Fn() -> Result<(), AssertionError> + Send + Sync>;

/// Test definition
pub struct TestDef {
    pub name: String,
    pub module: String,
    pub function: TestFn,
    pub attributes: TestAttributes,
    pub location: Option<TestLocation>,
}

/// Test attributes
#[derive(Debug, Clone, Default)]
pub struct TestAttributes {
    pub ignore: bool,
    pub should_panic: bool,
    pub expected_panic: Option<String>,
    pub timeout: Option<Duration>,
    pub tags: HashSet<String>,
    pub depends_on: Vec<String>,
}

// =============================================================================
// TEST FIXTURES
// =============================================================================

/// Fixture trait
pub trait Fixture: Send + Sync {
    /// Set up the fixture before tests
    fn setup(&mut self) -> Result<(), Box<dyn std::error::Error>>;

    /// Tear down the fixture after tests
    fn teardown(&mut self) -> Result<(), Box<dyn std::error::Error>>;
}

/// Scoped fixture that automatically cleans up
pub struct ScopedFixture<T> {
    value: Option<T>,
    teardown_fn: Option<Box<dyn FnOnce(&mut T) + Send>>,
}

impl<T> ScopedFixture<T> {
    pub fn new<F>(value: T, teardown: F) -> Self
    where
        F: FnOnce(&mut T) + Send + 'static,
    {
        ScopedFixture {
            value: Some(value),
            teardown_fn: Some(Box::new(teardown)),
        }
    }

    pub fn get(&self) -> &T {
        self.value.as_ref().unwrap()
    }

    pub fn get_mut(&mut self) -> &mut T {
        self.value.as_mut().unwrap()
    }
}

impl<T> Drop for ScopedFixture<T> {
    fn drop(&mut self) {
        if let (Some(mut value), Some(teardown)) = (self.value.take(), self.teardown_fn.take()) {
            teardown(&mut value);
        }
    }
}

/// Temporary directory fixture
pub struct TempDir {
    path: PathBuf,
}

impl TempDir {
    pub fn new() -> std::io::Result<Self> {
        let path = std::env::temp_dir().join(format!("quanta_test_{}", std::process::id()));
        fs::create_dir_all(&path)?;
        Ok(TempDir { path })
    }

    pub fn path(&self) -> &Path {
        &self.path
    }
}

impl Drop for TempDir {
    fn drop(&mut self) {
        let _ = fs::remove_dir_all(&self.path);
    }
}

/// Temporary file fixture
pub struct TempFile {
    path: PathBuf,
}

impl TempFile {
    pub fn new(content: &str) -> std::io::Result<Self> {
        let path = std::env::temp_dir().join(format!("quanta_test_file_{}", std::process::id()));
        fs::write(&path, content)?;
        Ok(TempFile { path })
    }

    pub fn path(&self) -> &Path {
        &self.path
    }
}

impl Drop for TempFile {
    fn drop(&mut self) {
        let _ = fs::remove_file(&self.path);
    }
}

// =============================================================================
// MOCKING FRAMEWORK
// =============================================================================

/// Mock call record
#[derive(Debug, Clone)]
pub struct MockCall {
    pub method: String,
    pub args: Vec<String>,
    pub timestamp: Instant,
}

/// Mock expectation
pub struct MockExpectation {
    method: String,
    args_matcher: Option<Box<dyn Fn(&[String]) -> bool + Send + Sync>>,
    return_value: Option<Box<dyn std::any::Any + Send + Sync>>,
    times: Option<usize>,
    call_count: AtomicUsize,
}

/// Mock object
pub struct Mock {
    name: String,
    calls: RwLock<Vec<MockCall>>,
    expectations: RwLock<Vec<MockExpectation>>,
}

impl Mock {
    pub fn new(name: &str) -> Self {
        Mock {
            name: name.to_string(),
            calls: RwLock::new(Vec::new()),
            expectations: RwLock::new(Vec::new()),
        }
    }

    /// Record a method call
    pub fn record_call(&self, method: &str, args: Vec<String>) {
        self.calls.write().unwrap().push(MockCall {
            method: method.to_string(),
            args,
            timestamp: Instant::now(),
        });
    }

    /// Check if a method was called
    pub fn was_called(&self, method: &str) -> bool {
        self.calls.read().unwrap().iter().any(|c| c.method == method)
    }

    /// Get the number of times a method was called
    pub fn call_count(&self, method: &str) -> usize {
        self.calls.read().unwrap().iter().filter(|c| c.method == method).count()
    }

    /// Get all calls to a method
    pub fn calls_to(&self, method: &str) -> Vec<MockCall> {
        self.calls.read().unwrap()
            .iter()
            .filter(|c| c.method == method)
            .cloned()
            .collect()
    }

    /// Clear all recorded calls
    pub fn clear(&self) {
        self.calls.write().unwrap().clear();
    }

    /// Add an expectation
    pub fn expect(&self, method: &str) -> &Self {
        self.expectations.write().unwrap().push(MockExpectation {
            method: method.to_string(),
            args_matcher: None,
            return_value: None,
            times: None,
            call_count: AtomicUsize::new(0),
        });
        self
    }

    /// Verify all expectations were met
    pub fn verify(&self) -> Result<(), AssertionError> {
        let expectations = self.expectations.read().unwrap();
        let calls = self.calls.read().unwrap();

        for exp in expectations.iter() {
            let actual_count = calls.iter().filter(|c| c.method == exp.method).count();

            if let Some(expected_times) = exp.times {
                if actual_count != expected_times {
                    return Err(AssertionError {
                        message: format!("Mock '{}': method '{}' called wrong number of times", self.name, exp.method),
                        expected: Some(format!("{} times", expected_times)),
                        actual: Some(format!("{} times", actual_count)),
                        location: None,
                    });
                }
            }
        }

        Ok(())
    }
}

/// Mock builder for fluent API
pub struct MockBuilder<'a> {
    mock: &'a Mock,
    method: String,
}

impl<'a> MockBuilder<'a> {
    pub fn times(self, n: usize) -> Self {
        // Update the last expectation
        if let Some(exp) = self.mock.expectations.write().unwrap().last_mut() {
            exp.times = Some(n);
        }
        self
    }

    pub fn never(self) -> Self {
        self.times(0)
    }

    pub fn once(self) -> Self {
        self.times(1)
    }

    pub fn twice(self) -> Self {
        self.times(2)
    }
}

// =============================================================================
// TEST DISCOVERY
// =============================================================================

/// Test discovery result
#[derive(Debug)]
pub struct DiscoveredTest {
    pub name: String,
    pub module: String,
    pub file: PathBuf,
    pub line: u32,
    pub attributes: TestAttributes,
}

/// Discover tests in a directory
pub fn discover_tests(path: &Path) -> Vec<DiscoveredTest> {
    let mut tests = Vec::new();

    if path.is_file() {
        if let Some(file_tests) = discover_tests_in_file(path) {
            tests.extend(file_tests);
        }
    } else if path.is_dir() {
        if let Ok(entries) = fs::read_dir(path) {
            for entry in entries.flatten() {
                let entry_path = entry.path();

                if entry_path.is_dir() {
                    tests.extend(discover_tests(&entry_path));
                } else if entry_path.extension().map(|e| e == "quanta").unwrap_or(false) {
                    if let Some(file_tests) = discover_tests_in_file(&entry_path) {
                        tests.extend(file_tests);
                    }
                }
            }
        }
    }

    tests
}

fn discover_tests_in_file(path: &Path) -> Option<Vec<DiscoveredTest>> {
    let content = fs::read_to_string(path).ok()?;
    let mut tests = Vec::new();
    let module = path.file_stem()?.to_string_lossy().to_string();

    for (line_num, line) in content.lines().enumerate() {
        let trimmed = line.trim();

        // Look for #[test] attribute
        if trimmed.starts_with("#[test]") || trimmed.contains("#[test]") {
            // Parse attributes
            let mut attrs = TestAttributes::default();

            if trimmed.contains("#[ignore]") || trimmed.contains("ignore") {
                attrs.ignore = true;
            }

            if trimmed.contains("#[should_panic]") || trimmed.contains("should_panic") {
                attrs.should_panic = true;
            }

            // Look for the function on the next line(s)
            for next_line in content.lines().skip(line_num + 1) {
                let next_trimmed = next_line.trim();

                if next_trimmed.starts_with("fn ") || next_trimmed.starts_with("pub fn ") {
                    // Extract function name
                    if let Some(name_start) = next_trimmed.find("fn ") {
                        let name_part = &next_trimmed[name_start + 3..];
                        if let Some(name_end) = name_part.find('(') {
                            let name = name_part[..name_end].trim().to_string();

                            tests.push(DiscoveredTest {
                                name,
                                module: module.clone(),
                                file: path.to_path_buf(),
                                line: (line_num + 1) as u32,
                                attributes: attrs,
                            });
                        }
                    }
                    break;
                }

                if next_trimmed.starts_with("#[") {
                    // More attributes, continue
                    continue;
                }

                if !next_trimmed.is_empty() {
                    break;
                }
            }
        }
    }

    if tests.is_empty() {
        None
    } else {
        Some(tests)
    }
}

// =============================================================================
// TEST RUNNER
// =============================================================================

/// Test runner configuration
#[derive(Debug, Clone)]
pub struct RunnerConfig {
    /// Number of parallel threads
    pub threads: usize,

    /// Test timeout
    pub timeout: Duration,

    /// Run ignored tests
    pub run_ignored: bool,

    /// Filter by name pattern
    pub filter: Option<String>,

    /// Filter by tags
    pub tags: HashSet<String>,

    /// Fail fast on first failure
    pub fail_fast: bool,

    /// Show output from passing tests
    pub show_output: bool,

    /// Capture stdout/stderr
    pub capture: bool,

    /// Shuffle test order
    pub shuffle: bool,

    /// Random seed for shuffling
    pub seed: Option<u64>,

    /// Output format
    pub format: OutputFormat,

    /// Generate coverage report
    pub coverage: bool,

    /// Coverage output directory
    pub coverage_dir: Option<PathBuf>,
}

impl Default for RunnerConfig {
    fn default() -> Self {
        RunnerConfig {
            threads: num_cpus::get(),
            timeout: Duration::from_secs(60),
            run_ignored: false,
            filter: None,
            tags: HashSet::new(),
            fail_fast: false,
            show_output: false,
            capture: true,
            shuffle: false,
            seed: None,
            format: OutputFormat::Pretty,
            coverage: false,
            coverage_dir: None,
        }
    }
}

/// Output format
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OutputFormat {
    Pretty,
    Terse,
    Json,
    Junit,
    Tap,
}

/// Test runner
pub struct TestRunner {
    config: RunnerConfig,
    tests: Vec<TestDef>,
    fixtures: HashMap<String, Box<dyn Fixture>>,
    before_all: Vec<Box<dyn Fn() + Send + Sync>>,
    after_all: Vec<Box<dyn Fn() + Send + Sync>>,
    before_each: Vec<Box<dyn Fn() + Send + Sync>>,
    after_each: Vec<Box<dyn Fn() + Send + Sync>>,
}

impl TestRunner {
    pub fn new(config: RunnerConfig) -> Self {
        TestRunner {
            config,
            tests: Vec::new(),
            fixtures: HashMap::new(),
            before_all: Vec::new(),
            after_all: Vec::new(),
            before_each: Vec::new(),
            after_each: Vec::new(),
        }
    }

    /// Add a test
    pub fn add_test(&mut self, test: TestDef) {
        self.tests.push(test);
    }

    /// Add a fixture
    pub fn add_fixture(&mut self, name: &str, fixture: Box<dyn Fixture>) {
        self.fixtures.insert(name.to_string(), fixture);
    }

    /// Add before all hook
    pub fn before_all<F>(&mut self, hook: F)
    where
        F: Fn() + Send + Sync + 'static,
    {
        self.before_all.push(Box::new(hook));
    }

    /// Add after all hook
    pub fn after_all<F>(&mut self, hook: F)
    where
        F: Fn() + Send + Sync + 'static,
    {
        self.after_all.push(Box::new(hook));
    }

    /// Add before each hook
    pub fn before_each<F>(&mut self, hook: F)
    where
        F: Fn() + Send + Sync + 'static,
    {
        self.before_each.push(Box::new(hook));
    }

    /// Add after each hook
    pub fn after_each<F>(&mut self, hook: F)
    where
        F: Fn() + Send + Sync + 'static,
    {
        self.after_each.push(Box::new(hook));
    }

    /// Run all tests
    pub fn run(&mut self) -> SuiteResult {
        let start = Instant::now();
        let mut result = SuiteResult::new("test");

        // Filter tests
        let tests: Vec<&TestDef> = self.tests.iter()
            .filter(|t| self.should_run_test(t))
            .collect();

        // Setup fixtures
        for fixture in self.fixtures.values_mut() {
            if let Err(e) = fixture.setup() {
                eprintln!("Fixture setup failed: {}", e);
                return result;
            }
        }

        // Run before all hooks
        for hook in &self.before_all {
            hook();
        }

        // Print header
        match self.config.format {
            OutputFormat::Pretty => {
                println!("\nrunning {} tests", tests.len());
            }
            OutputFormat::Terse => {}
            OutputFormat::Json => {}
            OutputFormat::Junit => {}
            OutputFormat::Tap => {
                println!("TAP version 13");
                println!("1..{}", tests.len());
            }
        }

        // Shuffle if requested
        let test_order: Vec<usize> = if self.config.shuffle {
            let mut indices: Vec<usize> = (0..tests.len()).collect();
            // Simple shuffle using seed
            let seed = self.config.seed.unwrap_or(42);
            for i in (1..indices.len()).rev() {
                let j = ((seed * (i as u64 + 1)) % (i as u64 + 1)) as usize;
                indices.swap(i, j);
            }
            indices
        } else {
            (0..tests.len()).collect()
        };

        // Run tests
        let failed = AtomicBool::new(false);

        for (test_num, &idx) in test_order.iter().enumerate() {
            if self.config.fail_fast && failed.load(Ordering::SeqCst) {
                break;
            }

            let test = tests[idx];

            // Run before each hooks
            for hook in &self.before_each {
                hook();
            }

            let test_result = self.run_single_test(test, test_num + 1);

            if test_result.status == TestStatus::Failed || test_result.status == TestStatus::TimedOut {
                failed.store(true, Ordering::SeqCst);
            }

            result.add_result(test_result);

            // Run after each hooks
            for hook in &self.after_each {
                hook();
            }
        }

        // Run after all hooks
        for hook in &self.after_all {
            hook();
        }

        // Teardown fixtures
        for fixture in self.fixtures.values_mut() {
            let _ = fixture.teardown();
        }

        result.duration = start.elapsed();

        // Print summary
        self.print_summary(&result);

        result
    }

    fn should_run_test(&self, test: &TestDef) -> bool {
        // Check ignore flag
        if test.attributes.ignore && !self.config.run_ignored {
            return false;
        }

        // Check filter
        if let Some(ref filter) = self.config.filter {
            if !test.name.contains(filter) && !test.module.contains(filter) {
                return false;
            }
        }

        // Check tags
        if !self.config.tags.is_empty() {
            if !self.config.tags.iter().any(|t| test.attributes.tags.contains(t)) {
                return false;
            }
        }

        true
    }

    fn run_single_test(&self, test: &TestDef, test_num: usize) -> TestResult {
        let start = Instant::now();

        // Check if ignored
        if test.attributes.ignore && !self.config.run_ignored {
            self.print_test_result(test, TestStatus::Ignored, None, test_num);
            return TestResult {
                name: test.name.clone(),
                module: test.module.clone(),
                status: TestStatus::Ignored,
                duration: Duration::ZERO,
                message: Some("ignored".to_string()),
                location: test.location.clone(),
                stdout: String::new(),
                stderr: String::new(),
            };
        }

        // Run test with timeout
        let timeout = test.attributes.timeout.unwrap_or(self.config.timeout);

        let result = panic::catch_unwind(panic::AssertUnwindSafe(|| {
            (test.function)()
        }));

        let duration = start.elapsed();

        // Check timeout
        if duration > timeout {
            self.print_test_result(test, TestStatus::TimedOut, None, test_num);
            return TestResult {
                name: test.name.clone(),
                module: test.module.clone(),
                status: TestStatus::TimedOut,
                duration,
                message: Some(format!("test timed out after {:?}", timeout)),
                location: test.location.clone(),
                stdout: String::new(),
                stderr: String::new(),
            };
        }

        let (status, message) = match result {
            Ok(Ok(())) => {
                if test.attributes.should_panic {
                    (TestStatus::Failed, Some("expected panic but test passed".to_string()))
                } else {
                    (TestStatus::Passed, None)
                }
            }
            Ok(Err(e)) => {
                (TestStatus::Failed, Some(e.to_string()))
            }
            Err(panic_info) => {
                if test.attributes.should_panic {
                    // Check expected panic message
                    if let Some(ref expected) = test.attributes.expected_panic {
                        let panic_msg = panic_info.downcast_ref::<&str>()
                            .map(|s| s.to_string())
                            .or_else(|| panic_info.downcast_ref::<String>().cloned())
                            .unwrap_or_else(|| "unknown panic".to_string());

                        if panic_msg.contains(expected) {
                            (TestStatus::Passed, None)
                        } else {
                            (TestStatus::Failed, Some(format!("expected panic '{}' but got '{}'", expected, panic_msg)))
                        }
                    } else {
                        (TestStatus::Passed, None)
                    }
                } else {
                    let panic_msg = panic_info.downcast_ref::<&str>()
                        .map(|s| s.to_string())
                        .or_else(|| panic_info.downcast_ref::<String>().cloned())
                        .unwrap_or_else(|| "unknown panic".to_string());

                    (TestStatus::Failed, Some(format!("panicked: {}", panic_msg)))
                }
            }
        };

        self.print_test_result(test, status, message.as_deref(), test_num);

        TestResult {
            name: test.name.clone(),
            module: test.module.clone(),
            status,
            duration,
            message,
            location: test.location.clone(),
            stdout: String::new(),
            stderr: String::new(),
        }
    }

    fn print_test_result(&self, test: &TestDef, status: TestStatus, message: Option<&str>, test_num: usize) {
        match self.config.format {
            OutputFormat::Pretty => {
                let status_str = match status {
                    TestStatus::Passed => "\x1b[32mok\x1b[0m",
                    TestStatus::Failed => "\x1b[31mFAILED\x1b[0m",
                    TestStatus::Skipped => "\x1b[33mskipped\x1b[0m",
                    TestStatus::Ignored => "\x1b[33mignored\x1b[0m",
                    TestStatus::TimedOut => "\x1b[31mtimed out\x1b[0m",
                };

                println!("test {}::{} ... {}", test.module, test.name, status_str);

                if let Some(msg) = message {
                    if status == TestStatus::Failed {
                        println!("    {}", msg);
                    }
                }
            }
            OutputFormat::Terse => {
                let ch = match status {
                    TestStatus::Passed => '.',
                    TestStatus::Failed => 'F',
                    TestStatus::Skipped => 's',
                    TestStatus::Ignored => 'i',
                    TestStatus::TimedOut => 'T',
                };
                print!("{}", ch);
                let _ = std::io::stdout().flush();
            }
            OutputFormat::Tap => {
                let status_str = match status {
                    TestStatus::Passed => "ok",
                    TestStatus::Failed | TestStatus::TimedOut => "not ok",
                    TestStatus::Skipped | TestStatus::Ignored => "ok # SKIP",
                };
                println!("{} {} - {}::{}", status_str, test_num, test.module, test.name);
            }
            _ => {}
        }
    }

    fn print_summary(&self, result: &SuiteResult) {
        match self.config.format {
            OutputFormat::Pretty | OutputFormat::Terse => {
                if self.config.format == OutputFormat::Terse {
                    println!();
                }

                println!();

                // Print failures
                let failures: Vec<_> = result.tests.iter()
                    .filter(|t| t.status == TestStatus::Failed || t.status == TestStatus::TimedOut)
                    .collect();

                if !failures.is_empty() {
                    println!("failures:\n");
                    for test in &failures {
                        println!("    {}::{}", test.module, test.name);
                        if let Some(ref msg) = test.message {
                            println!("        {}", msg);
                        }
                    }
                    println!();
                }

                // Print summary
                let status = if result.success() {
                    "\x1b[32mok\x1b[0m"
                } else {
                    "\x1b[31mFAILED\x1b[0m"
                };

                println!(
                    "test result: {}. {} passed; {} failed; {} ignored; {} filtered out; finished in {:.2}s",
                    status,
                    result.passed,
                    result.failed,
                    result.ignored,
                    result.skipped,
                    result.duration.as_secs_f64()
                );
            }
            OutputFormat::Json => {
                let json = serde_json::json!({
                    "type": "suite",
                    "passed": result.passed,
                    "failed": result.failed,
                    "ignored": result.ignored,
                    "filtered": result.skipped,
                    "duration_secs": result.duration.as_secs_f64(),
                    "tests": result.tests.iter().map(|t| serde_json::json!({
                        "name": t.name,
                        "module": t.module,
                        "status": format!("{:?}", t.status),
                        "duration_ms": t.duration.as_millis(),
                        "message": t.message,
                    })).collect::<Vec<_>>(),
                });
                println!("{}", serde_json::to_string_pretty(&json).unwrap());
            }
            OutputFormat::Junit => {
                println!(r#"<?xml version="1.0" encoding="UTF-8"?>"#);
                println!(r#"<testsuites name="test" tests="{}" failures="{}" time="{:.3}">"#,
                    result.total(), result.failed, result.duration.as_secs_f64());

                for test in &result.tests {
                    println!(r#"  <testcase name="{}" classname="{}" time="{:.3}">"#,
                        test.name, test.module, test.duration.as_secs_f64());

                    if test.status == TestStatus::Failed {
                        println!(r#"    <failure message="{}">{}</failure>"#,
                            test.message.as_deref().unwrap_or(""),
                            test.message.as_deref().unwrap_or(""));
                    } else if test.status == TestStatus::Skipped || test.status == TestStatus::Ignored {
                        println!("    <skipped />");
                    }

                    println!("  </testcase>");
                }

                println!("</testsuites>");
            }
            OutputFormat::Tap => {
                // TAP output was printed during execution
            }
        }
    }
}

// =============================================================================
// PROPERTY-BASED TESTING
// =============================================================================

/// Arbitrary trait for generating random test values
pub trait Arbitrary: Sized {
    fn arbitrary(g: &mut Generator) -> Self;

    fn shrink(&self) -> Vec<Self> {
        Vec::new()
    }
}

/// Random value generator
pub struct Generator {
    seed: u64,
    size: usize,
}

impl Generator {
    pub fn new(seed: u64) -> Self {
        Generator { seed, size: 100 }
    }

    fn next_u64(&mut self) -> u64 {
        // Simple LCG
        self.seed = self.seed.wrapping_mul(6364136223846793005).wrapping_add(1);
        self.seed
    }

    pub fn range(&mut self, min: i64, max: i64) -> i64 {
        let range = (max - min) as u64;
        if range == 0 {
            return min;
        }
        min + (self.next_u64() % range) as i64
    }

    pub fn bool(&mut self) -> bool {
        self.next_u64() % 2 == 0
    }

    pub fn choose<'a, T>(&mut self, items: &'a [T]) -> Option<&'a T> {
        if items.is_empty() {
            None
        } else {
            Some(&items[self.next_u64() as usize % items.len()])
        }
    }
}

impl Arbitrary for bool {
    fn arbitrary(g: &mut Generator) -> Self {
        g.bool()
    }
}

impl Arbitrary for i32 {
    fn arbitrary(g: &mut Generator) -> Self {
        g.range(i32::MIN as i64, i32::MAX as i64) as i32
    }

    fn shrink(&self) -> Vec<Self> {
        if *self == 0 {
            vec![]
        } else if *self > 0 {
            vec![0, self / 2, self - 1]
        } else {
            vec![0, self / 2, self + 1]
        }
    }
}

impl Arbitrary for i64 {
    fn arbitrary(g: &mut Generator) -> Self {
        g.range(i64::MIN / 2, i64::MAX / 2)
    }

    fn shrink(&self) -> Vec<Self> {
        if *self == 0 {
            vec![]
        } else if *self > 0 {
            vec![0, self / 2, self - 1]
        } else {
            vec![0, self / 2, self + 1]
        }
    }
}

impl Arbitrary for String {
    fn arbitrary(g: &mut Generator) -> Self {
        let len = g.range(0, 100) as usize;
        let chars: Vec<char> = (0..len)
            .map(|_| (g.range(32, 127) as u8) as char)
            .collect();
        chars.into_iter().collect()
    }

    fn shrink(&self) -> Vec<Self> {
        if self.is_empty() {
            vec![]
        } else {
            vec![
                String::new(),
                self[..self.len() / 2].to_string(),
                self[1..].to_string(),
            ]
        }
    }
}

impl<T: Arbitrary> Arbitrary for Vec<T> {
    fn arbitrary(g: &mut Generator) -> Self {
        let len = g.range(0, 50) as usize;
        (0..len).map(|_| T::arbitrary(g)).collect()
    }

    fn shrink(&self) -> Vec<Self> {
        if self.is_empty() {
            vec![]
        } else {
            vec![
                vec![],
                self[..self.len() / 2].to_vec(),
                self[1..].to_vec(),
            ]
        }
    }
}

/// Property-based test runner
pub struct PropTest {
    iterations: usize,
    seed: u64,
}

impl PropTest {
    pub fn new() -> Self {
        PropTest {
            iterations: 100,
            seed: std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_nanos() as u64,
        }
    }

    pub fn iterations(mut self, n: usize) -> Self {
        self.iterations = n;
        self
    }

    pub fn seed(mut self, seed: u64) -> Self {
        self.seed = seed;
        self
    }

    /// Run a property test with one arbitrary argument
    pub fn for_all<A, F>(&self, prop: F) -> Result<(), AssertionError>
    where
        A: Arbitrary + std::fmt::Debug,
        F: Fn(A) -> bool,
    {
        let mut gen = Generator::new(self.seed);

        for i in 0..self.iterations {
            let value = A::arbitrary(&mut gen);

            if !prop(value) {
                // Attempt shrinking
                // ... simplified for now

                return Err(AssertionError {
                    message: format!("Property failed after {} iterations", i + 1),
                    expected: None,
                    actual: None,
                    location: None,
                });
            }
        }

        Ok(())
    }

    /// Run a property test with two arbitrary arguments
    pub fn for_all2<A, B, F>(&self, prop: F) -> Result<(), AssertionError>
    where
        A: Arbitrary + std::fmt::Debug,
        B: Arbitrary + std::fmt::Debug,
        F: Fn(A, B) -> bool,
    {
        let mut gen = Generator::new(self.seed);

        for i in 0..self.iterations {
            let a = A::arbitrary(&mut gen);
            let b = B::arbitrary(&mut gen);

            if !prop(a, b) {
                return Err(AssertionError {
                    message: format!("Property failed after {} iterations", i + 1),
                    expected: None,
                    actual: None,
                    location: None,
                });
            }
        }

        Ok(())
    }
}

