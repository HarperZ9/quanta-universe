// =============================================================================
// CODE COVERAGE
// =============================================================================

/// Code coverage collector
pub struct CoverageCollector {
    files: HashMap<PathBuf, FileCoverage>,
    enabled: bool,
}

#[derive(Debug, Clone)]
pub struct FileCoverage {
    path: PathBuf,
    lines: HashMap<u32, LineCoverage>,
    functions: HashMap<String, FunctionCoverage>,
    branches: HashMap<u32, BranchCoverage>,
}

#[derive(Debug, Clone, Copy)]
pub struct LineCoverage {
    line: u32,
    hits: u64,
}

#[derive(Debug, Clone)]
pub struct FunctionCoverage {
    name: String,
    start_line: u32,
    end_line: u32,
    hits: u64,
}

#[derive(Debug, Clone, Copy)]
pub struct BranchCoverage {
    line: u32,
    branch_id: u32,
    taken: u64,
    not_taken: u64,
}

impl CoverageCollector {
    pub fn new() -> Self {
        CoverageCollector {
            files: HashMap::new(),
            enabled: true,
        }
    }

    pub fn enable(&mut self) {
        self.enabled = true;
    }

    pub fn disable(&mut self) {
        self.enabled = false;
    }

    pub fn record_line(&mut self, file: &Path, line: u32) {
        if !self.enabled { return; }

        let file_cov = self.files.entry(file.to_path_buf())
            .or_insert_with(|| FileCoverage {
                path: file.to_path_buf(),
                lines: HashMap::new(),
                functions: HashMap::new(),
                branches: HashMap::new(),
            });

        file_cov.lines.entry(line)
            .and_modify(|c| c.hits += 1)
            .or_insert(LineCoverage { line, hits: 1 });
    }

    pub fn record_function(&mut self, file: &Path, name: &str, start: u32, end: u32) {
        if !self.enabled { return; }

        let file_cov = self.files.entry(file.to_path_buf())
            .or_insert_with(|| FileCoverage {
                path: file.to_path_buf(),
                lines: HashMap::new(),
                functions: HashMap::new(),
                branches: HashMap::new(),
            });

        file_cov.functions.entry(name.to_string())
            .and_modify(|c| c.hits += 1)
            .or_insert(FunctionCoverage {
                name: name.to_string(),
                start_line: start,
                end_line: end,
                hits: 1,
            });
    }

    pub fn record_branch(&mut self, file: &Path, line: u32, branch_id: u32, taken: bool) {
        if !self.enabled { return; }

        let file_cov = self.files.entry(file.to_path_buf())
            .or_insert_with(|| FileCoverage {
                path: file.to_path_buf(),
                lines: HashMap::new(),
                functions: HashMap::new(),
                branches: HashMap::new(),
            });

        let key = line * 1000 + branch_id;
        file_cov.branches.entry(key)
            .and_modify(|c| {
                if taken { c.taken += 1; } else { c.not_taken += 1; }
            })
            .or_insert(BranchCoverage {
                line,
                branch_id,
                taken: if taken { 1 } else { 0 },
                not_taken: if taken { 0 } else { 1 },
            });
    }

    pub fn generate_report(&self) -> CoverageReport {
        let mut total_lines = 0;
        let mut covered_lines = 0;
        let mut total_functions = 0;
        let mut covered_functions = 0;
        let mut total_branches = 0;
        let mut covered_branches = 0;

        let mut file_reports = Vec::new();

        for (path, file_cov) in &self.files {
            let file_total_lines = file_cov.lines.len();
            let file_covered_lines = file_cov.lines.values()
                .filter(|l| l.hits > 0).count();

            let file_total_functions = file_cov.functions.len();
            let file_covered_functions = file_cov.functions.values()
                .filter(|f| f.hits > 0).count();

            let file_total_branches = file_cov.branches.len();
            let file_covered_branches = file_cov.branches.values()
                .filter(|b| b.taken > 0).count();

            total_lines += file_total_lines;
            covered_lines += file_covered_lines;
            total_functions += file_total_functions;
            covered_functions += file_covered_functions;
            total_branches += file_total_branches;
            covered_branches += file_covered_branches;

            file_reports.push(FileCoverageReport {
                path: path.clone(),
                line_coverage: if file_total_lines > 0 {
                    (file_covered_lines as f64 / file_total_lines as f64) * 100.0
                } else { 100.0 },
                function_coverage: if file_total_functions > 0 {
                    (file_covered_functions as f64 / file_total_functions as f64) * 100.0
                } else { 100.0 },
                branch_coverage: if file_total_branches > 0 {
                    (file_covered_branches as f64 / file_total_branches as f64) * 100.0
                } else { 100.0 },
                uncovered_lines: file_cov.lines.values()
                    .filter(|l| l.hits == 0)
                    .map(|l| l.line)
                    .collect(),
            });
        }

        CoverageReport {
            line_coverage: if total_lines > 0 {
                (covered_lines as f64 / total_lines as f64) * 100.0
            } else { 100.0 },
            function_coverage: if total_functions > 0 {
                (covered_functions as f64 / total_functions as f64) * 100.0
            } else { 100.0 },
            branch_coverage: if total_branches > 0 {
                (covered_branches as f64 / total_branches as f64) * 100.0
            } else { 100.0 },
            files: file_reports,
        }
    }

    pub fn export_lcov(&self, path: &Path) -> std::io::Result<()> {
        let mut output = String::new();

        for (file_path, file_cov) in &self.files {
            output.push_str(&format!("SF:{}\n", file_path.display()));

            for func in file_cov.functions.values() {
                output.push_str(&format!("FN:{},{}\n", func.start_line, func.name));
                output.push_str(&format!("FNDA:{},{}\n", func.hits, func.name));
            }

            output.push_str(&format!("FNF:{}\n", file_cov.functions.len()));
            output.push_str(&format!("FNH:{}\n",
                file_cov.functions.values().filter(|f| f.hits > 0).count()));

            for line in file_cov.lines.values() {
                output.push_str(&format!("DA:{},{}\n", line.line, line.hits));
            }

            output.push_str(&format!("LF:{}\n", file_cov.lines.len()));
            output.push_str(&format!("LH:{}\n",
                file_cov.lines.values().filter(|l| l.hits > 0).count()));

            for branch in file_cov.branches.values() {
                output.push_str(&format!("BRDA:{},{},0,{}\n",
                    branch.line, branch.branch_id, branch.taken));
            }

            output.push_str("end_of_record\n");
        }

        fs::write(path, output)
    }

    pub fn export_cobertura(&self, path: &Path) -> std::io::Result<()> {
        let report = self.generate_report();

        let mut xml = String::from("<?xml version=\"1.0\"?>\n");
        xml.push_str("<coverage version=\"1.0\">\n");
        xml.push_str(&format!("  <line-rate>{:.4}</line-rate>\n", report.line_coverage / 100.0));
        xml.push_str(&format!("  <branch-rate>{:.4}</branch-rate>\n", report.branch_coverage / 100.0));
        xml.push_str("  <packages>\n");
        xml.push_str("    <package name=\".\">\n");
        xml.push_str("      <classes>\n");

        for file in &report.files {
            xml.push_str(&format!("        <class name=\"{}\" filename=\"{}\">\n",
                file.path.file_name().unwrap_or_default().to_string_lossy(),
                file.path.display()));
            xml.push_str(&format!("          <line-rate>{:.4}</line-rate>\n", file.line_coverage / 100.0));
            xml.push_str("        </class>\n");
        }

        xml.push_str("      </classes>\n");
        xml.push_str("    </package>\n");
        xml.push_str("  </packages>\n");
        xml.push_str("</coverage>\n");

        fs::write(path, xml)
    }
}

#[derive(Debug)]
pub struct CoverageReport {
    pub line_coverage: f64,
    pub function_coverage: f64,
    pub branch_coverage: f64,
    pub files: Vec<FileCoverageReport>,
}

#[derive(Debug)]
pub struct FileCoverageReport {
    pub path: PathBuf,
    pub line_coverage: f64,
    pub function_coverage: f64,
    pub branch_coverage: f64,
    pub uncovered_lines: Vec<u32>,
}

impl CoverageReport {
    pub fn print(&self) {
        println!("╔═══════════════════════════════════════╗");
        println!("║         Code Coverage Report          ║");
        println!("╠═══════════════════════════════════════╣");
        println!("║ Line Coverage:     {:>17.1}% ║", self.line_coverage);
        println!("║ Function Coverage: {:>17.1}% ║", self.function_coverage);
        println!("║ Branch Coverage:   {:>17.1}% ║", self.branch_coverage);
        println!("╚═══════════════════════════════════════╝");

        println!("\nFile Coverage:");
        for file in &self.files {
            let name = file.path.file_name()
                .unwrap_or_default()
                .to_string_lossy();
            println!("  {}: {:.1}% lines, {:.1}% branches",
                name, file.line_coverage, file.branch_coverage);
        }
    }
}

// =============================================================================
// TEST DATA BUILDERS
// =============================================================================

/// Builder pattern for test data
pub trait TestDataBuilder: Default {
    type Output;

    fn build(self) -> Self::Output;
}

/// Generic test data factory
pub struct TestDataFactory<T> {
    builders: HashMap<String, Box<dyn Fn() -> T + Send + Sync>>,
    sequences: HashMap<String, AtomicU64>,
}

impl<T> TestDataFactory<T> {
    pub fn new() -> Self {
        TestDataFactory {
            builders: HashMap::new(),
            sequences: HashMap::new(),
        }
    }

    pub fn define<F>(&mut self, name: &str, builder: F)
    where
        F: Fn() -> T + Send + Sync + 'static,
    {
        self.builders.insert(name.to_string(), Box::new(builder));
    }

    pub fn build(&self, name: &str) -> Option<T> {
        self.builders.get(name).map(|b| b())
    }

    pub fn build_list(&self, name: &str, count: usize) -> Vec<T> {
        (0..count).filter_map(|_| self.build(name)).collect()
    }

    pub fn sequence(&self, name: &str) -> u64 {
        self.sequences.entry(name.to_string())
            .or_insert_with(|| AtomicU64::new(0))
            .fetch_add(1, Ordering::SeqCst)
    }

    pub fn reset_sequences(&self) {
        for seq in self.sequences.values() {
            seq.store(0, Ordering::SeqCst);
        }
    }
}

/// Randomized test data generator
pub struct TestDataGen {
    seed: u64,
}

impl TestDataGen {
    pub fn new() -> Self {
        TestDataGen {
            seed: std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_nanos() as u64,
        }
    }

    pub fn with_seed(seed: u64) -> Self {
        TestDataGen { seed }
    }

    fn next(&mut self) -> u64 {
        self.seed = self.seed.wrapping_mul(6364136223846793005).wrapping_add(1);
        self.seed
    }

    pub fn int(&mut self, min: i64, max: i64) -> i64 {
        let range = (max - min) as u64;
        if range == 0 { return min; }
        min + (self.next() % range) as i64
    }

    pub fn uint(&mut self, max: u64) -> u64 {
        if max == 0 { return 0; }
        self.next() % max
    }

    pub fn float(&mut self, min: f64, max: f64) -> f64 {
        let t = (self.next() as f64) / (u64::MAX as f64);
        min + t * (max - min)
    }

    pub fn bool(&mut self) -> bool {
        self.next() % 2 == 0
    }

    pub fn string(&mut self, len: usize) -> String {
        (0..len)
            .map(|_| (self.int(97, 123) as u8) as char)
            .collect()
    }

    pub fn email(&mut self) -> String {
        format!("{}@{}.com", self.string(8), self.string(5))
    }

    pub fn uuid(&mut self) -> String {
        format!("{:08x}-{:04x}-{:04x}-{:04x}-{:012x}",
            self.next() as u32,
            (self.next() as u16) & 0xFFFF,
            (self.next() as u16) & 0x0FFF | 0x4000,
            (self.next() as u16) & 0x3FFF | 0x8000,
            self.next() & 0xFFFFFFFFFFFF)
    }

    pub fn choice<'a, T>(&mut self, items: &'a [T]) -> Option<&'a T> {
        if items.is_empty() { None }
        else { Some(&items[self.uint(items.len() as u64) as usize]) }
    }

    pub fn shuffle<T: Clone>(&mut self, items: &mut [T]) {
        for i in (1..items.len()).rev() {
            let j = self.uint((i + 1) as u64) as usize;
            items.swap(i, j);
        }
    }
}

// =============================================================================
// TEST ISOLATION & SANDBOXING
// =============================================================================

/// Test isolation context
pub struct IsolationContext {
    original_env: HashMap<String, String>,
    original_cwd: PathBuf,
    temp_dir: Option<TempDir>,
    cleaned_up: bool,
}

impl IsolationContext {
    pub fn new() -> Self {
        IsolationContext {
            original_env: std::env::vars().collect(),
            original_cwd: std::env::current_dir().unwrap_or_default(),
            temp_dir: None,
            cleaned_up: false,
        }
    }

    pub fn with_temp_dir(mut self) -> std::io::Result<Self> {
        self.temp_dir = Some(TempDir::new()?);
        Ok(self)
    }

    pub fn temp_path(&self) -> Option<&Path> {
        self.temp_dir.as_ref().map(|t| t.path())
    }

    pub fn set_env(&self, key: &str, value: &str) {
        std::env::set_var(key, value);
    }

    pub fn remove_env(&self, key: &str) {
        std::env::remove_var(key);
    }

    pub fn set_cwd(&self, path: &Path) -> std::io::Result<()> {
        std::env::set_current_dir(path)
    }

    pub fn cleanup(&mut self) {
        if self.cleaned_up { return; }

        // Restore environment
        for (key, value) in &self.original_env {
            std::env::set_var(key, value);
        }

        // Restore cwd
        let _ = std::env::set_current_dir(&self.original_cwd);

        self.cleaned_up = true;
    }
}

impl Drop for IsolationContext {
    fn drop(&mut self) {
        self.cleanup();
    }
}

/// Run test in isolation
pub fn run_isolated<F, R>(f: F) -> R
where
    F: FnOnce(&mut IsolationContext) -> R,
{
    let mut ctx = IsolationContext::new();
    let result = f(&mut ctx);
    ctx.cleanup();
    result
}

// =============================================================================
// INTEGRATION TEST SUPPORT
// =============================================================================

/// Integration test harness
pub struct IntegrationHarness {
    services: HashMap<String, Box<dyn TestService>>,
    cleanup_fns: Vec<Box<dyn FnOnce()>>,
}

pub trait TestService: Send + Sync {
    fn name(&self) -> &str;
    fn start(&mut self) -> Result<(), String>;
    fn stop(&mut self) -> Result<(), String>;
    fn is_ready(&self) -> bool;
    fn health_check(&self) -> Result<(), String>;
}

impl IntegrationHarness {
    pub fn new() -> Self {
        IntegrationHarness {
            services: HashMap::new(),
            cleanup_fns: Vec::new(),
        }
    }

    pub fn add_service<S: TestService + 'static>(&mut self, service: S) {
        self.services.insert(service.name().to_string(), Box::new(service));
    }

    pub fn add_cleanup<F: FnOnce() + 'static>(&mut self, f: F) {
        self.cleanup_fns.push(Box::new(f));
    }

    pub fn start(&mut self) -> Result<(), String> {
        for (name, service) in &mut self.services {
            println!("Starting service: {}", name);
            service.start()?;
        }
        Ok(())
    }

    pub fn stop(&mut self) -> Result<(), String> {
        for (name, service) in &mut self.services {
            println!("Stopping service: {}", name);
            let _ = service.stop();
        }
        Ok(())
    }

    pub fn wait_for_ready(&self, timeout: Duration) -> Result<(), String> {
        let start = Instant::now();

        loop {
            let all_ready = self.services.values().all(|s| s.is_ready());

            if all_ready {
                return Ok(());
            }

            if start.elapsed() > timeout {
                return Err("Services not ready within timeout".to_string());
            }

            std::thread::sleep(Duration::from_millis(100));
        }
    }

    pub fn health_check(&self) -> Result<(), String> {
        for (name, service) in &self.services {
            service.health_check()
                .map_err(|e| format!("Service {} unhealthy: {}", name, e))?;
        }
        Ok(())
    }
}

impl Drop for IntegrationHarness {
    fn drop(&mut self) {
        let _ = self.stop();

        for cleanup in self.cleanup_fns.drain(..) {
            cleanup();
        }
    }
}

/// Docker-based test service
pub struct DockerService {
    name: String,
    image: String,
    ports: Vec<(u16, u16)>,
    env: HashMap<String, String>,
    container_id: Option<String>,
}

impl DockerService {
    pub fn new(name: &str, image: &str) -> Self {
        DockerService {
            name: name.to_string(),
            image: image.to_string(),
            ports: Vec::new(),
            env: HashMap::new(),
            container_id: None,
        }
    }

    pub fn port(mut self, host: u16, container: u16) -> Self {
        self.ports.push((host, container));
        self
    }

    pub fn env(mut self, key: &str, value: &str) -> Self {
        self.env.insert(key.to_string(), value.to_string());
        self
    }
}

impl TestService for DockerService {
    fn name(&self) -> &str { &self.name }

    fn start(&mut self) -> Result<(), String> {
        // In real implementation, use docker command
        self.container_id = Some("test_container".to_string());
        Ok(())
    }

    fn stop(&mut self) -> Result<(), String> {
        self.container_id = None;
        Ok(())
    }

    fn is_ready(&self) -> bool {
        self.container_id.is_some()
    }

    fn health_check(&self) -> Result<(), String> {
        if self.container_id.is_some() {
            Ok(())
        } else {
            Err("Container not running".to_string())
        }
    }
}

// =============================================================================
// TEST REPORTING
// =============================================================================

/// Test report generator
pub struct ReportGenerator {
    results: Vec<SuiteResult>,
    coverage: Option<CoverageReport>,
    mutation: Option<MutationReport>,
}

impl ReportGenerator {
    pub fn new() -> Self {
        ReportGenerator {
            results: Vec::new(),
            coverage: None,
            mutation: None,
        }
    }

    pub fn add_suite(&mut self, result: SuiteResult) {
        self.results.push(result);
    }

    pub fn set_coverage(&mut self, report: CoverageReport) {
        self.coverage = Some(report);
    }

    pub fn set_mutation(&mut self, report: MutationReport) {
        self.mutation = Some(report);
    }

    pub fn generate_html(&self, path: &Path) -> std::io::Result<()> {
        let mut html = String::from(r#"<!DOCTYPE html>
<html>
<head>
    <title>Test Report</title>
    <style>
        body { font-family: sans-serif; margin: 20px; }
        .passed { color: green; }
        .failed { color: red; }
        .summary { background: #f0f0f0; padding: 20px; margin: 10px 0; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #4a4a4a; color: white; }
        tr:nth-child(even) { background: #f9f9f9; }
    </style>
</head>
<body>
    <h1>Test Report</h1>
"#);

        // Summary
        let total_passed: usize = self.results.iter().map(|r| r.passed).sum();
        let total_failed: usize = self.results.iter().map(|r| r.failed).sum();
        let total_duration: f64 = self.results.iter()
            .map(|r| r.duration.as_secs_f64()).sum();

        html.push_str(&format!(r#"
    <div class="summary">
        <h2>Summary</h2>
        <p>Total Tests: {}</p>
        <p class="passed">Passed: {}</p>
        <p class="failed">Failed: {}</p>
        <p>Duration: {:.2}s</p>
    </div>
"#, total_passed + total_failed, total_passed, total_failed, total_duration));

        // Test results table
        html.push_str(r#"
    <h2>Test Results</h2>
    <table>
        <tr><th>Test</th><th>Status</th><th>Duration</th><th>Message</th></tr>
"#);

        for suite in &self.results {
            for test in &suite.tests {
                let status_class = match test.status {
                    TestStatus::Passed => "passed",
                    TestStatus::Failed | TestStatus::TimedOut => "failed",
                    _ => "",
                };

                html.push_str(&format!(r#"
        <tr>
            <td>{}::{}</td>
            <td class="{}">{:?}</td>
            <td>{:.3}s</td>
            <td>{}</td>
        </tr>
"#, test.module, test.name, status_class, test.status,
    test.duration.as_secs_f64(),
    test.message.as_deref().unwrap_or("")));
            }
        }

        html.push_str("    </table>\n");

        // Coverage section
        if let Some(ref cov) = self.coverage {
            html.push_str(&format!(r#"
    <h2>Code Coverage</h2>
    <div class="summary">
        <p>Line Coverage: {:.1}%</p>
        <p>Function Coverage: {:.1}%</p>
        <p>Branch Coverage: {:.1}%</p>
    </div>
"#, cov.line_coverage, cov.function_coverage, cov.branch_coverage));
        }

        // Mutation section
        if let Some(ref mut_report) = self.mutation {
            html.push_str(&format!(r#"
    <h2>Mutation Testing</h2>
    <div class="summary">
        <p>Mutation Score: {:.1}%</p>
        <p>Killed: {}</p>
        <p>Survived: {}</p>
    </div>
"#, mut_report.score, mut_report.killed, mut_report.survived));
        }

        html.push_str("</body>\n</html>");

        fs::write(path, html)
    }

    pub fn generate_json(&self, path: &Path) -> std::io::Result<()> {
        let json = serde_json::json!({
            "suites": self.results.iter().map(|s| {
                serde_json::json!({
                    "name": s.name,
                    "passed": s.passed,
                    "failed": s.failed,
                    "duration_ms": s.duration.as_millis(),
                    "tests": s.tests.iter().map(|t| {
                        serde_json::json!({
                            "name": t.name,
                            "module": t.module,
                            "status": format!("{:?}", t.status),
                            "duration_ms": t.duration.as_millis(),
                            "message": t.message,
                        })
                    }).collect::<Vec<_>>(),
                })
            }).collect::<Vec<_>>(),
            "coverage": self.coverage.as_ref().map(|c| {
                serde_json::json!({
                    "line_coverage": c.line_coverage,
                    "function_coverage": c.function_coverage,
                    "branch_coverage": c.branch_coverage,
                })
            }),
            "mutation": self.mutation.as_ref().map(|m| {
                serde_json::json!({
                    "score": m.score,
                    "killed": m.killed,
                    "survived": m.survived,
                })
            }),
        });

        fs::write(path, serde_json::to_string_pretty(&json).unwrap())
    }
}

// =============================================================================
// TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_assert_eq() {
        assert!(assert_eq(&1, &1, None).is_ok());
        assert!(assert_eq(&1, &2, None).is_err());
    }

    #[test]
    fn test_assert_ne() {
        assert!(assert_ne(&1, &2, None).is_ok());
        assert!(assert_ne(&1, &1, None).is_err());
    }

    #[test]
    fn test_assert_approx_eq() {
        assert!(assert_approx_eq(1.0, 1.0001, 0.001, None).is_ok());
        assert!(assert_approx_eq(1.0, 2.0, 0.001, None).is_err());
    }

    #[test]
    fn test_mock() {
        let mock = Mock::new("test_mock");

        mock.record_call("foo", vec!["arg1".to_string()]);
        mock.record_call("foo", vec!["arg2".to_string()]);
        mock.record_call("bar", vec![]);

        assert!(mock.was_called("foo"));
        assert_eq!(mock.call_count("foo"), 2);
        assert_eq!(mock.call_count("bar"), 1);
        assert!(!mock.was_called("baz"));
    }

    #[test]
    fn test_generator() {
        let mut gen = Generator::new(42);

        let n1 = gen.range(0, 100);
        let n2 = gen.range(0, 100);

        assert!(n1 >= 0 && n1 < 100);
        assert!(n2 >= 0 && n2 < 100);
    }

    #[test]
    fn test_prop_test() {
        let prop = PropTest::new().iterations(50);

        // Addition is commutative
        let result = prop.for_all2(|a: i32, b: i32| {
            a.wrapping_add(b) == b.wrapping_add(a)
        });

        assert!(result.is_ok());
    }

    #[test]
    fn test_suite_result() {
        let mut result = SuiteResult::new("test");

        result.add_result(TestResult {
            name: "test1".to_string(),
            module: "mod".to_string(),
            status: TestStatus::Passed,
            duration: Duration::from_millis(10),
            message: None,
            location: None,
            stdout: String::new(),
            stderr: String::new(),
        });

        result.add_result(TestResult {
            name: "test2".to_string(),
            module: "mod".to_string(),
            status: TestStatus::Failed,
            duration: Duration::from_millis(20),
            message: Some("failed".to_string()),
            location: None,
            stdout: String::new(),
            stderr: String::new(),
        });

        assert_eq!(result.passed, 1);
        assert_eq!(result.failed, 1);
        assert_eq!(result.total(), 2);
        assert!(!result.success());
    }
}
