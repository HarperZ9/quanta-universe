/// Test command options
#[derive(Debug, Clone)]
pub struct TestOptions {
    /// Test paths
    pub paths: Vec<PathBuf>,

    /// Filter pattern
    pub filter: Option<String>,

    /// Number of threads
    pub jobs: Option<usize>,

    /// Run ignored tests
    pub run_ignored: bool,

    /// Fail fast
    pub fail_fast: bool,

    /// Show output
    pub show_output: bool,

    /// No capture
    pub no_capture: bool,

    /// Output format
    pub format: OutputFormat,

    /// Enable coverage
    pub coverage: bool,

    /// List tests only
    pub list: bool,

    /// Test timeout in seconds
    pub timeout: Option<u64>,
}

impl Default for TestOptions {
    fn default() -> Self {
        TestOptions {
            paths: Vec::new(),
            filter: None,
            jobs: None,
            run_ignored: false,
            fail_fast: false,
            show_output: false,
            no_capture: false,
            format: OutputFormat::Pretty,
            coverage: false,
            list: false,
            timeout: None,
        }
    }
}

/// Run tests with options
pub fn run_tests(options: TestOptions) -> i32 {
    let paths = if options.paths.is_empty() {
        vec![PathBuf::from(".")]
    } else {
        options.paths
    };

    // Discover tests
    let mut discovered = Vec::new();
    for path in &paths {
        discovered.extend(discover_tests(path));
    }

    if options.list {
        for test in &discovered {
            println!("{}::{}: {}:{}", test.module, test.name, test.file.display(), test.line);
        }
        return 0;
    }

    // Build runner config
    let config = RunnerConfig {
        threads: options.jobs.unwrap_or(num_cpus::get()),
        timeout: Duration::from_secs(options.timeout.unwrap_or(60)),
        run_ignored: options.run_ignored,
        filter: options.filter,
        tags: HashSet::new(),
        fail_fast: options.fail_fast,
        show_output: options.show_output,
        capture: !options.no_capture,
        shuffle: false,
        seed: None,
        format: options.format,
        coverage: options.coverage,
        coverage_dir: None,
    };

    // Create runner
    let mut runner = TestRunner::new(config);

    // Add discovered tests (simplified - in real implementation would compile and load)
    for test in discovered {
        // Skip if filtered
        if let Some(ref filter) = runner.config.filter {
            if !test.name.contains(filter) && !test.module.contains(filter) {
                continue;
            }
        }

        // Create test definition
        let test_name = test.name.clone();
        runner.add_test(TestDef {
            name: test.name,
            module: test.module,
            function: Box::new(move || {
                // Placeholder - real implementation would run actual test
                Ok(())
            }),
            attributes: test.attributes,
            location: Some(TestLocation {
                file: test.file,
                line: test.line,
                column: 0,
            }),
        });
    }

    // Run tests
    let result = runner.run();

    if result.success() { 0 } else { 1 }
}

/// Main entry point
pub fn main() {
    let args: Vec<String> = std::env::args().collect();

    let mut options = TestOptions::default();
    let mut i = 1;

    while i < args.len() {
        match args[i].as_str() {
            "--filter" | "-f" => {
                i += 1;
                if i < args.len() {
                    options.filter = Some(args[i].clone());
                }
            }
            "--jobs" | "-j" => {
                i += 1;
                if i < args.len() {
                    options.jobs = args[i].parse().ok();
                }
            }
            "--ignored" => {
                options.run_ignored = true;
            }
            "--fail-fast" => {
                options.fail_fast = true;
            }
            "--show-output" => {
                options.show_output = true;
            }
            "--no-capture" => {
                options.no_capture = true;
            }
            "--format" => {
                i += 1;
                if i < args.len() {
                    options.format = match args[i].as_str() {
                        "terse" => OutputFormat::Terse,
                        "json" => OutputFormat::Json,
                        "junit" => OutputFormat::Junit,
                        "tap" => OutputFormat::Tap,
                        _ => OutputFormat::Pretty,
                    };
                }
            }
            "--coverage" => {
                options.coverage = true;
            }
            "--list" => {
                options.list = true;
            }
            "--timeout" => {
                i += 1;
                if i < args.len() {
                    options.timeout = args[i].parse().ok();
                }
            }
            "--help" | "-h" => {
                print_help();
                return;
            }
            "--version" | "-V" => {
                println!("quantatest 1.0.0");
                return;
            }
            arg if !arg.starts_with('-') => {
                options.paths.push(PathBuf::from(arg));
            }
            _ => {
                eprintln!("Unknown option: {}", args[i]);
                std::process::exit(1);
            }
        }
        i += 1;
    }

    let exit_code = run_tests(options);
    std::process::exit(exit_code);
}

fn print_help() {
    println!("quantatest - QuantaLang Test Runner

USAGE:
    quantatest [OPTIONS] [PATHS...]

OPTIONS:
    -f, --filter PATTERN    Filter tests by name pattern
    -j, --jobs N            Number of parallel jobs
    --ignored               Run ignored tests
    --fail-fast             Stop on first failure
    --show-output           Show test output
    --no-capture            Don't capture stdout/stderr
    --format FORMAT         Output format (pretty, terse, json, junit, tap)
    --coverage              Generate coverage report
    --list                  List tests without running
    --timeout SECS          Test timeout in seconds
    -h, --help              Show this help message
    -V, --version           Show version

EXAMPLES:
    quantatest                              Run all tests
    quantatest tests/                       Run tests in directory
    quantatest -f \"parsing\"                 Filter tests by name
    quantatest --format json                JSON output
    quantatest --fail-fast --no-capture     Stop on failure, show output

ATTRIBUTES:
    #[test]                  Mark function as test
    #[ignore]                Skip test unless --ignored
    #[should_panic]          Test should panic
    #[timeout(5000)]         Custom timeout in ms
    #[tag(\"slow\")]           Add tag for filtering
");
}

// =============================================================================
// SNAPSHOT TESTING
// =============================================================================

/// Snapshot testing for regression detection
pub struct SnapshotManager {
    snapshot_dir: PathBuf,
    update_mode: SnapshotUpdateMode,
    snapshots: HashMap<String, Snapshot>,
}

#[derive(Debug, Clone)]
pub struct Snapshot {
    name: String,
    content: String,
    metadata: SnapshotMetadata,
}

#[derive(Debug, Clone)]
pub struct SnapshotMetadata {
    created_at: String,
    updated_at: String,
    test_file: String,
    test_line: u32,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum SnapshotUpdateMode {
    None,      // Fail on mismatch
    New,       // Create new, fail on mismatch
    All,       // Update all mismatches
}

impl SnapshotManager {
    pub fn new(snapshot_dir: &Path) -> Self {
        SnapshotManager {
            snapshot_dir: snapshot_dir.to_path_buf(),
            update_mode: SnapshotUpdateMode::None,
            snapshots: HashMap::new(),
        }
    }

    pub fn with_update_mode(mut self, mode: SnapshotUpdateMode) -> Self {
        self.update_mode = mode;
        self
    }

    pub fn load(&mut self) -> std::io::Result<()> {
        if !self.snapshot_dir.exists() {
            fs::create_dir_all(&self.snapshot_dir)?;
            return Ok(());
        }

        for entry in fs::read_dir(&self.snapshot_dir)? {
            let entry = entry?;
            let path = entry.path();

            if path.extension().map(|e| e == "snap").unwrap_or(false) {
                if let Ok(content) = fs::read_to_string(&path) {
                    let name = path.file_stem()
                        .and_then(|s| s.to_str())
                        .unwrap_or("")
                        .to_string();

                    self.snapshots.insert(name.clone(), Snapshot {
                        name,
                        content,
                        metadata: SnapshotMetadata {
                            created_at: String::new(),
                            updated_at: String::new(),
                            test_file: String::new(),
                            test_line: 0,
                        },
                    });
                }
            }
        }

        Ok(())
    }

    pub fn assert_snapshot(&mut self, name: &str, actual: &str) -> Result<(), AssertionError> {
        let snapshot_path = self.snapshot_dir.join(format!("{}.snap", name));

        if let Some(existing) = self.snapshots.get(name) {
            if existing.content.trim() == actual.trim() {
                return Ok(());
            }

            // Mismatch
            match self.update_mode {
                SnapshotUpdateMode::None => {
                    return Err(AssertionError {
                        message: format!("Snapshot '{}' does not match", name),
                        expected: Some(existing.content.clone()),
                        actual: Some(actual.to_string()),
                        location: None,
                    });
                }
                SnapshotUpdateMode::All => {
                    self.update_snapshot(name, actual)?;
                    return Ok(());
                }
                SnapshotUpdateMode::New => {
                    return Err(AssertionError {
                        message: format!("Snapshot '{}' does not match (use --update to update)", name),
                        expected: Some(existing.content.clone()),
                        actual: Some(actual.to_string()),
                        location: None,
                    });
                }
            }
        }

        // New snapshot
        match self.update_mode {
            SnapshotUpdateMode::None => {
                Err(AssertionError {
                    message: format!("Snapshot '{}' does not exist (use --update-new to create)", name),
                    expected: None,
                    actual: Some(actual.to_string()),
                    location: None,
                })
            }
            _ => {
                self.create_snapshot(name, actual)?;
                Ok(())
            }
        }
    }

    fn create_snapshot(&mut self, name: &str, content: &str) -> std::io::Result<()> {
        fs::create_dir_all(&self.snapshot_dir)?;

        let snapshot_path = self.snapshot_dir.join(format!("{}.snap", name));
        fs::write(&snapshot_path, content)?;

        self.snapshots.insert(name.to_string(), Snapshot {
            name: name.to_string(),
            content: content.to_string(),
            metadata: SnapshotMetadata {
                created_at: chrono_now(),
                updated_at: chrono_now(),
                test_file: String::new(),
                test_line: 0,
            },
        });

        println!("Created snapshot: {}", name);
        Ok(())
    }

    fn update_snapshot(&mut self, name: &str, content: &str) -> std::io::Result<()> {
        let snapshot_path = self.snapshot_dir.join(format!("{}.snap", name));
        fs::write(&snapshot_path, content)?;

        if let Some(snapshot) = self.snapshots.get_mut(name) {
            snapshot.content = content.to_string();
            snapshot.metadata.updated_at = chrono_now();
        }

        println!("Updated snapshot: {}", name);
        Ok(())
    }

    pub fn list_snapshots(&self) -> Vec<&str> {
        self.snapshots.keys().map(|s| s.as_str()).collect()
    }

    pub fn remove_unused(&mut self, used: &HashSet<String>) -> std::io::Result<usize> {
        let unused: Vec<String> = self.snapshots.keys()
            .filter(|k| !used.contains(*k))
            .cloned()
            .collect();

        for name in &unused {
            let path = self.snapshot_dir.join(format!("{}.snap", name));
            fs::remove_file(&path)?;
            self.snapshots.remove(name);
        }

        Ok(unused.len())
    }
}

fn chrono_now() -> String {
    // Simplified timestamp
    format!("{}", std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .unwrap()
        .as_secs())
}

/// Inline snapshot assertion macro helper
pub fn assert_inline_snapshot(actual: &str, expected: &str) -> Result<(), AssertionError> {
    if actual.trim() == expected.trim() {
        Ok(())
    } else {
        Err(AssertionError {
            message: "Inline snapshot does not match".to_string(),
            expected: Some(expected.to_string()),
            actual: Some(actual.to_string()),
            location: None,
        })
    }
}

// =============================================================================
// PARAMETERIZED TESTING
// =============================================================================

/// Parameterized test case
#[derive(Debug, Clone)]
pub struct TestCase<T> {
    pub name: String,
    pub input: T,
    pub expected: Option<String>,
}

/// Parameterized test runner
pub struct ParameterizedTest<T> {
    name: String,
    cases: Vec<TestCase<T>>,
}

impl<T: Clone + std::fmt::Debug> ParameterizedTest<T> {
    pub fn new(name: &str) -> Self {
        ParameterizedTest {
            name: name.to_string(),
            cases: Vec::new(),
        }
    }

    pub fn add_case(mut self, name: &str, input: T) -> Self {
        self.cases.push(TestCase {
            name: name.to_string(),
            input,
            expected: None,
        });
        self
    }

    pub fn add_case_with_expected(mut self, name: &str, input: T, expected: &str) -> Self {
        self.cases.push(TestCase {
            name: name.to_string(),
            input,
            expected: Some(expected.to_string()),
        });
        self
    }

    pub fn run<F>(&self, test_fn: F) -> Vec<TestResult>
    where
        F: Fn(&T) -> Result<(), AssertionError>,
    {
        let mut results = Vec::new();

        for case in &self.cases {
            let start = Instant::now();

            let (status, message) = match test_fn(&case.input) {
                Ok(()) => (TestStatus::Passed, None),
                Err(e) => (TestStatus::Failed, Some(e.to_string())),
            };

            results.push(TestResult {
                name: format!("{}::{}", self.name, case.name),
                module: String::new(),
                status,
                duration: start.elapsed(),
                message,
                location: None,
                stdout: String::new(),
                stderr: String::new(),
            });
        }

        results
    }
}

/// Table-driven test helper
pub struct TableTest<I, O> {
    cases: Vec<(String, I, O)>,
}

impl<I: Clone + std::fmt::Debug, O: Clone + std::fmt::Debug + PartialEq> TableTest<I, O> {
    pub fn new() -> Self {
        TableTest { cases: Vec::new() }
    }

    pub fn case(mut self, name: &str, input: I, expected: O) -> Self {
        self.cases.push((name.to_string(), input, expected));
        self
    }

    pub fn run<F>(&self, f: F) -> Result<(), AssertionError>
    where
        F: Fn(&I) -> O,
    {
        for (name, input, expected) in &self.cases {
            let actual = f(input);

            if actual != *expected {
                return Err(AssertionError {
                    message: format!("Test case '{}' failed", name),
                    expected: Some(format!("{:?}", expected)),
                    actual: Some(format!("{:?}", actual)),
                    location: None,
                });
            }
        }

        Ok(())
    }
}

// =============================================================================
// TEST DOUBLES (SPIES, STUBS, FAKES)
// =============================================================================

/// Spy that records calls and delegates to real implementation
pub struct Spy<T> {
    inner: T,
    calls: RwLock<Vec<SpyCall>>,
}

#[derive(Debug, Clone)]
pub struct SpyCall {
    method: String,
    args: Vec<String>,
    result: String,
    timestamp: Instant,
}

impl<T> Spy<T> {
    pub fn new(inner: T) -> Self {
        Spy {
            inner,
            calls: RwLock::new(Vec::new()),
        }
    }

    pub fn inner(&self) -> &T {
        &self.inner
    }

    pub fn inner_mut(&mut self) -> &mut T {
        &mut self.inner
    }

    pub fn record(&self, method: &str, args: Vec<String>, result: String) {
        self.calls.write().unwrap().push(SpyCall {
            method: method.to_string(),
            args,
            result,
            timestamp: Instant::now(),
        });
    }

    pub fn calls(&self) -> Vec<SpyCall> {
        self.calls.read().unwrap().clone()
    }

    pub fn calls_to(&self, method: &str) -> Vec<SpyCall> {
        self.calls.read().unwrap()
            .iter()
            .filter(|c| c.method == method)
            .cloned()
            .collect()
    }

    pub fn was_called(&self, method: &str) -> bool {
        self.calls.read().unwrap().iter().any(|c| c.method == method)
    }

    pub fn call_count(&self, method: &str) -> usize {
        self.calls.read().unwrap().iter().filter(|c| c.method == method).count()
    }

    pub fn reset(&self) {
        self.calls.write().unwrap().clear();
    }
}

/// Stub that returns predefined values
pub struct Stub<R: Clone> {
    responses: HashMap<String, Vec<R>>,
    default: Option<R>,
    call_index: HashMap<String, usize>,
}

impl<R: Clone> Stub<R> {
    pub fn new() -> Self {
        Stub {
            responses: HashMap::new(),
            default: None,
            call_index: HashMap::new(),
        }
    }

    pub fn when(mut self, method: &str, response: R) -> Self {
        self.responses.entry(method.to_string())
            .or_insert_with(Vec::new)
            .push(response);
        self
    }

    pub fn when_sequence(mut self, method: &str, responses: Vec<R>) -> Self {
        self.responses.insert(method.to_string(), responses);
        self
    }

    pub fn default(mut self, response: R) -> Self {
        self.default = Some(response);
        self
    }

    pub fn call(&mut self, method: &str) -> Option<R> {
        if let Some(responses) = self.responses.get(method) {
            let index = self.call_index.entry(method.to_string()).or_insert(0);

            if *index < responses.len() {
                let response = responses[*index].clone();
                *index += 1;
                return Some(response);
            }
        }

        self.default.clone()
    }

    pub fn reset(&mut self) {
        self.call_index.clear();
    }
}

/// Fake implementation for testing
pub trait Fake: Send + Sync {
    fn is_fake(&self) -> bool { true }
    fn reset(&mut self);
}

/// In-memory fake database
pub struct FakeDatabase {
    tables: HashMap<String, Vec<HashMap<String, String>>>,
    queries: Vec<String>,
}

impl FakeDatabase {
    pub fn new() -> Self {
        FakeDatabase {
            tables: HashMap::new(),
            queries: Vec::new(),
        }
    }

    pub fn insert(&mut self, table: &str, row: HashMap<String, String>) {
        self.tables.entry(table.to_string())
            .or_insert_with(Vec::new)
            .push(row);
    }

    pub fn select(&self, table: &str) -> Vec<HashMap<String, String>> {
        self.tables.get(table).cloned().unwrap_or_default()
    }

    pub fn query(&mut self, sql: &str) -> Vec<HashMap<String, String>> {
        self.queries.push(sql.to_string());
        // Simplified query parsing
        Vec::new()
    }

    pub fn executed_queries(&self) -> &[String] {
        &self.queries
    }
}

impl Fake for FakeDatabase {
    fn reset(&mut self) {
        self.tables.clear();
        self.queries.clear();
    }
}

/// Fake HTTP client
pub struct FakeHttpClient {
    responses: HashMap<String, FakeHttpResponse>,
    requests: Vec<FakeHttpRequest>,
}

#[derive(Debug, Clone)]
pub struct FakeHttpRequest {
    method: String,
    url: String,
    headers: HashMap<String, String>,
    body: Option<String>,
}

#[derive(Debug, Clone)]
pub struct FakeHttpResponse {
    status: u16,
    headers: HashMap<String, String>,
    body: String,
}

impl FakeHttpClient {
    pub fn new() -> Self {
        FakeHttpClient {
            responses: HashMap::new(),
            requests: Vec::new(),
        }
    }

    pub fn stub_response(&mut self, url: &str, response: FakeHttpResponse) {
        self.responses.insert(url.to_string(), response);
    }

    pub fn get(&mut self, url: &str) -> FakeHttpResponse {
        self.requests.push(FakeHttpRequest {
            method: "GET".to_string(),
            url: url.to_string(),
            headers: HashMap::new(),
            body: None,
        });

        self.responses.get(url).cloned().unwrap_or(FakeHttpResponse {
            status: 404,
            headers: HashMap::new(),
            body: "Not Found".to_string(),
        })
    }

    pub fn post(&mut self, url: &str, body: &str) -> FakeHttpResponse {
        self.requests.push(FakeHttpRequest {
            method: "POST".to_string(),
            url: url.to_string(),
            headers: HashMap::new(),
            body: Some(body.to_string()),
        });

        self.responses.get(url).cloned().unwrap_or(FakeHttpResponse {
            status: 404,
            headers: HashMap::new(),
            body: "Not Found".to_string(),
        })
    }

    pub fn requests(&self) -> &[FakeHttpRequest] {
        &self.requests
    }
}

impl Fake for FakeHttpClient {
    fn reset(&mut self) {
        self.responses.clear();
        self.requests.clear();
    }
}

