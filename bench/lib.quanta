// BENCHMARK FUZZING
// ═══════════════════════════════════════════════════════════════════════════════

/// Fuzz benchmark with random inputs
pub struct BenchFuzzer<T> {
    generator: Box<dyn Fn(u64) -> T>,
    seed: u64,
}

impl<T> BenchFuzzer<T> {
    pub fn new<F>(generator: F) -> Self
    where
        F: Fn(u64) -> T + 'static,
    {
        BenchFuzzer {
            generator: Box::new(generator),
            seed: 42,
        }
    }

    /// Generate a random input
    pub fn generate(&mut self) -> T {
        self.seed = self.seed.wrapping_mul(6364136223846793005)
            .wrapping_add(1442695040888963407);
        (self.generator)(self.seed)
    }

    /// Generate N inputs
    pub fn generate_n(&mut self, n: usize) -> Vec<T> {
        (0..n).map(|_| self.generate()).collect()
    }

    /// Set seed for reproducibility
    pub fn set_seed(&mut self, seed: u64) {
        self.seed = seed;
    }
}

/// Fuzzed benchmark runner
pub struct FuzzedBenchRunner {
    bencher: Bencher,
    min_input_size: usize,
    max_input_size: usize,
    num_fuzzes: usize,
}

impl FuzzedBenchRunner {
    pub fn new(min_size: usize, max_size: usize, num_fuzzes: usize) -> Self {
        FuzzedBenchRunner {
            bencher: Bencher::new(),
            min_input_size: min_size,
            max_input_size: max_size,
            num_fuzzes: num_fuzzes,
        }
    }

    /// Run benchmark with fuzzed vector inputs
    pub fn fuzz_bench_vec<F>(&mut self, name: &str, mut f: F)
    where
        F: FnMut(&mut Iteration, &[u8]),
    {
        let mut fuzzer = BenchFuzzer::new(|seed| {
            let size = self.min_input_size +
                (seed as usize % (self.max_input_size - self.min_input_size + 1));
            let mut vec = Vec::with_capacity(size);
            let mut s = seed;
            for _ in 0..size {
                s = s.wrapping_mul(6364136223846793005).wrapping_add(1);
                vec.push((s >> 56) as u8);
            }
            vec
        });

        for i in 0..self.num_fuzzes {
            let input = fuzzer.generate();
            let bench_name = format!("{}_{}", name, i);
            let input_clone = input.clone();

            self.bencher.bench(&bench_name, |iter| {
                f(iter, &input_clone);
            });
        }
    }

    /// Summary of fuzzed results
    pub fn summary(&self) {
        self.bencher.summary();
    }
}

