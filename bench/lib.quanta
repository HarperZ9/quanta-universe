// BENCHMARK ANNOTATIONS / SOURCE INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Benchmark annotation for source code
#[derive(Clone)]
pub struct BenchAnnotation {
    pub file_path: String,
    pub line_number: usize,
    pub function_name: String,
    pub benchmark_name: String,
    pub latest_result: Option<BenchResult>,
    pub history: Vec<HistoryPoint>,
}

/// Annotation manager for IDE integration
pub struct AnnotationManager {
    annotations: Vec<BenchAnnotation>,
    results_cache: HashMap<String, BenchResult>,
}

impl AnnotationManager {
    pub fn new() -> Self {
        AnnotationManager {
            annotations: Vec::new(),
            results_cache: HashMap::new(),
        }
    }

    /// Register a benchmark annotation
    pub fn register(&mut self, file: &str, line: usize, func: &str, bench_name: &str) {
        self.annotations.push(BenchAnnotation {
            file_path: file.to_string(),
            line_number: line,
            function_name: func.to_string(),
            benchmark_name: bench_name.to_string(),
            latest_result: self.results_cache.get(bench_name).cloned(),
            history: Vec::new(),
        });
    }

    /// Update result for a benchmark
    pub fn update_result(&mut self, bench_name: &str, result: BenchResult) {
        self.results_cache.insert(bench_name.to_string(), result.clone());

        for ann in &mut self.annotations {
            if ann.benchmark_name == bench_name {
                ann.latest_result = Some(result.clone());
                ann.history.push(HistoryPoint {
                    timestamp: std::time::SystemTime::now()
                        .duration_since(std::time::UNIX_EPOCH)
                        .unwrap()
                        .as_secs(),
                    commit_hash: None,
                    mean: result.stats.mean,
                    std_dev: result.stats.std_dev,
                });
            }
        }
    }

    /// Generate LSP-compatible annotations
    pub fn generate_lsp_annotations(&self) -> Vec<LspAnnotation> {
        self.annotations.iter().filter_map(|ann| {
            ann.latest_result.as_ref().map(|result| {
                LspAnnotation {
                    file: ann.file_path.clone(),
                    line: ann.line_number,
                    message: format!(
                        "⏱ {} ± {} ({} iterations)",
                        format_duration(result.stats.mean),
                        format_duration(result.stats.std_dev),
                        result.stats.iterations
                    ),
                    severity: LspSeverity::Information,
                }
            })
        }).collect()
    }
}

/// LSP annotation for IDE display
#[derive(Clone)]
pub struct LspAnnotation {
    pub file: String,
    pub line: usize,
    pub message: String,
    pub severity: LspSeverity,
}

#[derive(Clone, Copy, Debug)]
pub enum LspSeverity {
    Information,
    Warning,
    Error,
}

