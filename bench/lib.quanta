        }
    }

    /// Pin to a set of CPUs
    pub fn pin_to_cpus(&self, cpus: &[usize]) -> Result<(), String> {
        #[cfg(target_os = "linux")]
        {
            // Would use sched_setaffinity with mask
            Ok(())
        }
        #[cfg(not(target_os = "linux"))]
        {
            Err("CPU affinity not supported on this platform".to_string())
        }
    }

    /// Isolate to a single CPU for minimal interference
    pub fn isolate_for_benchmarking(&self) -> Result<usize, String> {
        // Find the least-loaded CPU and pin to it
        let cpu = num_cpus() - 1; // Use last CPU typically
        self.pin_to_cpu(cpu)?;
        Ok(cpu)
    }

    /// Restore original affinity
    pub fn restore(&self) -> Result<(), String> {
        self.pin_to_cpus(&self.original_affinity)
    }
}

