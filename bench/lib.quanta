// CUSTOM ALLOCATOR BENCHMARKING
// ═══════════════════════════════════════════════════════════════════════════════

/// Allocation pattern for testing
#[derive(Clone, Copy, Debug)]
pub enum AllocationPattern {
    /// Fixed size allocations
    Fixed(usize),
    /// Random sizes within range
    Random { min: usize, max: usize },
    /// Power-of-two sizes
    PowerOfTwo { min_power: u32, max_power: u32 },
    /// Realistic distribution (based on real-world data)
    Realistic,
}

/// Allocation operation type
#[derive(Clone, Copy, Debug)]
pub enum AllocOp {
    Alloc,
    Dealloc,
    Realloc { new_size: usize },
}

/// Allocator benchmark configuration
#[derive(Clone)]
pub struct AllocatorBenchConfig {
    pub pattern: AllocationPattern,
    pub num_operations: u64,
    pub alloc_dealloc_ratio: f64, // 1.0 = equal, 2.0 = 2x more allocs
    pub max_live_allocations: usize,
    pub measure_fragmentation: bool,
}

impl Default for AllocatorBenchConfig {
    fn default() -> Self {
        AllocatorBenchConfig {
            pattern: AllocationPattern::Random { min: 16, max: 4096 },
            num_operations: 100000,
            alloc_dealloc_ratio: 1.0,
            max_live_allocations: 10000,
            measure_fragmentation: true,
        }
    }
}

/// Allocator benchmark results
#[derive(Clone)]
pub struct AllocatorResult {
    pub name: String,
    pub alloc_latency: LatencyReport,
    pub dealloc_latency: LatencyReport,
    pub total_allocations: u64,
    pub total_deallocations: u64,
    pub total_bytes_allocated: u64,
    pub peak_memory_usage: u64,
    pub fragmentation_ratio: f64,
    pub allocs_per_second: f64,
    pub throughput_mbps: f64,
}

impl AllocatorResult {
    pub fn print(&self) {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  Allocator Benchmark: {}", self.name);
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("  Operations:");
        println!("    Allocations:   {:>12}", self.total_allocations);
        println!("    Deallocations: {:>12}", self.total_deallocations);
        println!("    Allocs/sec:    {:>12.2}", self.allocs_per_second);
        println!();
        println!("  Memory:");
        println!("    Total allocated:  {:>12} bytes", self.total_bytes_allocated);
        println!("    Peak usage:       {:>12} bytes", self.peak_memory_usage);
        println!("    Fragmentation:    {:>12.1}%", self.fragmentation_ratio * 100.0);
        println!();
        println!("  Allocation Latency:");
        println!("    Mean:     {:>12}", format_duration(self.alloc_latency.mean_ns));
        println!("    p99:      {:>12}", format_duration(self.alloc_latency.p99_ns as f64));
        println!();
        println!("  Deallocation Latency:");
        println!("    Mean:     {:>12}", format_duration(self.dealloc_latency.mean_ns));
        println!("    p99:      {:>12}", format_duration(self.dealloc_latency.p99_ns as f64));
    }
}

/// Allocator benchmarker
pub struct AllocatorBencher {
    config: AllocatorBenchConfig,
    rng_seed: u64,
}

impl AllocatorBencher {
    pub fn new(config: AllocatorBenchConfig) -> Self {
        AllocatorBencher {
            config,
            rng_seed: 12345,
        }
    }

    /// Run allocator benchmark
    pub fn run(&mut self, name: &str) -> AllocatorResult {
        let mut alloc_histogram = HdrHistogram::new(1, 1_000_000_000, 3);
        let mut dealloc_histogram = HdrHistogram::new(1, 1_000_000_000, 3);

        let mut live_allocations: Vec<(*mut u8, usize)> = Vec::new();
        let mut total_bytes = 0u64;
        let mut peak_memory = 0u64;
        let mut current_memory = 0u64;

        let start = Instant::now();

        for _ in 0..self.config.num_operations {
            let do_alloc = live_allocations.len() < self.config.max_live_allocations &&
                (live_allocations.is_empty() || self.random_f64() < self.config.alloc_dealloc_ratio / (1.0 + self.config.alloc_dealloc_ratio));

            if do_alloc {
                let size = self.random_size();
                let op_start = Instant::now();

                // Simulate allocation (in real implementation would call allocator)
                let ptr = std::ptr::null_mut();

                alloc_histogram.record_value(op_start.elapsed().as_nanos() as u64);

                live_allocations.push((ptr, size));
                total_bytes += size as u64;
                current_memory += size as u64;
                peak_memory = peak_memory.max(current_memory);
            } else if !live_allocations.is_empty() {
                let idx = self.random() % live_allocations.len();
                let (ptr, size) = live_allocations.swap_remove(idx);

                let op_start = Instant::now();

                // Simulate deallocation
                let _ = ptr;

                dealloc_histogram.record_value(op_start.elapsed().as_nanos() as u64);

                current_memory -= size as u64;
            }
        }

        let duration = start.elapsed().as_secs_f64();

        let alloc_latency = LatencyReport {
            name: format!("{} alloc", name),
            min_ns: alloc_histogram.min(),
            max_ns: alloc_histogram.max(),
            mean_ns: alloc_histogram.mean(),
            std_dev_ns: alloc_histogram.std_deviation(),
            p50_ns: alloc_histogram.value_at_percentile(50.0),
            p75_ns: alloc_histogram.value_at_percentile(75.0),
            p90_ns: alloc_histogram.value_at_percentile(90.0),
            p95_ns: alloc_histogram.value_at_percentile(95.0),
            p99_ns: alloc_histogram.value_at_percentile(99.0),
            p999_ns: alloc_histogram.value_at_percentile(99.9),
            p9999_ns: alloc_histogram.value_at_percentile(99.99),
            count: alloc_histogram.count(),
            throughput: alloc_histogram.count() as f64 / duration,
        };

        let dealloc_latency = LatencyReport {
            name: format!("{} dealloc", name),
            min_ns: dealloc_histogram.min(),
            max_ns: dealloc_histogram.max(),
            mean_ns: dealloc_histogram.mean(),
            std_dev_ns: dealloc_histogram.std_deviation(),
            p50_ns: dealloc_histogram.value_at_percentile(50.0),
            p75_ns: dealloc_histogram.value_at_percentile(75.0),
            p90_ns: dealloc_histogram.value_at_percentile(90.0),
            p95_ns: dealloc_histogram.value_at_percentile(95.0),
            p99_ns: dealloc_histogram.value_at_percentile(99.0),
            p999_ns: dealloc_histogram.value_at_percentile(99.9),
            p9999_ns: dealloc_histogram.value_at_percentile(99.99),
            count: dealloc_histogram.count(),
            throughput: dealloc_histogram.count() as f64 / duration,
        };

        AllocatorResult {
            name: name.to_string(),
            alloc_latency,
            dealloc_latency,
            total_allocations: alloc_histogram.count(),
            total_deallocations: dealloc_histogram.count(),
            total_bytes_allocated: total_bytes,
            peak_memory_usage: peak_memory,
            fragmentation_ratio: 0.0, // Would calculate in real implementation
            allocs_per_second: alloc_histogram.count() as f64 / duration,
            throughput_mbps: (total_bytes as f64 / 1_000_000.0) / duration,
        }
    }

    fn random(&mut self) -> usize {
        self.rng_seed = self.rng_seed.wrapping_mul(6364136223846793005)
            .wrapping_add(1442695040888963407);
        (self.rng_seed >> 33) as usize
    }

    fn random_f64(&mut self) -> f64 {
        self.random() as f64 / usize::MAX as f64
    }

    fn random_size(&mut self) -> usize {
        match self.config.pattern {
            AllocationPattern::Fixed(size) => size,
            AllocationPattern::Random { min, max } => {
                min + self.random() % (max - min + 1)
            }
            AllocationPattern::PowerOfTwo { min_power, max_power } => {
                let power = min_power + (self.random() as u32 % (max_power - min_power + 1));
                1usize << power
            }
            AllocationPattern::Realistic => {
                // Simulated realistic distribution
                let r = self.random_f64();
                if r < 0.6 { 16 + self.random() % 48 }        // 60% small
                else if r < 0.9 { 64 + self.random() % 960 }  // 30% medium
                else { 1024 + self.random() % 15360 }          // 10% large
            }
        }
    }
}

