/// CI benchmark runner
pub struct CiBenchRunner {
    config: CiBenchConfig,
    baseline: HashMap<String, f64>,
    current_results: HashMap<String, Vec<f64>>,
    regressions: Vec<CiRegressionReport>,
    improvements: Vec<CiRegressionReport>,
}

/// CI regression report
#[derive(Clone)]
pub struct CiRegressionReport {
    pub benchmark_name: String,
    pub baseline_mean: f64,
    pub current_mean: f64,
    pub change_percent: f64,
    pub is_regression: bool,
    pub is_significant: bool,
}

impl CiBenchRunner {
    pub fn new(config: CiBenchConfig) -> Self {
        let baseline = Self::load_baseline(&config.baseline_path);

        CiBenchRunner {
            config,
            baseline,
            current_results: HashMap::new(),
            regressions: Vec::new(),
            improvements: Vec::new(),
        }
    }

    fn load_baseline(path: &str) -> HashMap<String, f64> {
        // Load baseline from JSON file
        HashMap::new()
    }

    /// Run benchmarks multiple times for statistical significance
    pub fn run_benches<F>(&mut self, name: &str, mut f: F)
    where
        F: FnMut(&mut Bencher),
    {
        let mut run_results = Vec::new();

        for run in 0..self.config.num_runs {
            println!("Run {}/{} for {}", run + 1, self.config.num_runs, name);

            let mut bencher = Bencher::new();
            f(&mut bencher);

            for result in &bencher.results {
                run_results.push(result.stats.mean);
            }
        }

        self.current_results.insert(name.to_string(), run_results);
    }

    /// Analyze results and detect regressions
    pub fn analyze(&mut self) -> CiAnalysisResult {
        self.regressions.clear();
        self.improvements.clear();

        for (name, current_runs) in &self.current_results {
            let current_mean = current_runs.iter().sum::<f64>() / current_runs.len() as f64;

            if let Some(&baseline_mean) = self.baseline.get(name) {
                let change_percent = (current_mean - baseline_mean) / baseline_mean * 100.0;

                let is_regression = change_percent > self.config.regression_threshold;
                let is_improvement = change_percent < -self.config.improvement_threshold;
                let is_significant = is_regression || is_improvement;

                let report = CiRegressionReport {
                    benchmark_name: name.clone(),
                    baseline_mean,
                    current_mean,
                    change_percent,
                    is_regression,
                    is_significant,
                };

                if is_regression {
                    self.regressions.push(report);
                } else if is_improvement {
                    self.improvements.push(report.clone());
                }
            }
        }

        let has_regressions = !self.regressions.is_empty();
        let should_fail = has_regressions && self.config.fail_on_regression;

        CiAnalysisResult {
            regressions: self.regressions.clone(),
            improvements: self.improvements.clone(),
            has_regressions,
            should_fail,
        }
    }

    /// Generate GitHub comment markdown
    pub fn generate_github_comment(&self) -> String {
        let mut comment = String::new();

        comment.push_str("## 📊 Benchmark Results\n\n");

        if let Some(ref info) = self.config.commit_info {
            comment.push_str(&format!(
                "**Commit:** `{}` on `{}`\n\n",
                info.short_sha, info.branch
            ));
        }

        // Regressions
        if !self.regressions.is_empty() {
            comment.push_str("### ⚠️ Regressions Detected\n\n");
            comment.push_str("| Benchmark | Baseline | Current | Change |\n");
            comment.push_str("|-----------|----------|---------|--------|\n");

            for reg in &self.regressions {
                comment.push_str(&format!(
                    "| {} | {} | {} | 🔴 {:+.1}% |\n",
                    reg.benchmark_name,
                    format_duration(reg.baseline_mean),
                    format_duration(reg.current_mean),
                    reg.change_percent
                ));
            }
            comment.push_str("\n");
        }

        // Improvements
        if !self.improvements.is_empty() {
            comment.push_str("### ✅ Improvements\n\n");
            comment.push_str("| Benchmark | Baseline | Current | Change |\n");
            comment.push_str("|-----------|----------|---------|--------|\n");

            for imp in &self.improvements {
                comment.push_str(&format!(
                    "| {} | {} | {} | 🟢 {:+.1}% |\n",
                    imp.benchmark_name,
                    format_duration(imp.baseline_mean),
                    format_duration(imp.current_mean),
                    imp.change_percent
                ));
            }
            comment.push_str("\n");
        }

        if self.regressions.is_empty() && self.improvements.is_empty() {
            comment.push_str("✅ No significant performance changes detected.\n");
        }

        comment
    }

    /// Send Slack notification
    pub fn send_slack_notification(&self) -> Result<(), String> {
        if let Some(ref webhook_url) = self.config.slack_webhook {
            let message = if self.regressions.is_empty() {
                format!("✅ Benchmarks passed! {} improvements detected.", self.improvements.len())
            } else {
                format!("⚠️ {} benchmark regressions detected!", self.regressions.len())
            };

            // In real implementation, would POST to webhook URL
            println!("Would send to Slack: {}", message);
        }
        Ok(())
    }

    /// Save current results as new baseline
    pub fn save_baseline(&self, path: &str) -> Result<(), String> {
        let mut baseline = HashMap::new();

        for (name, runs) in &self.current_results {
            let mean = runs.iter().sum::<f64>() / runs.len() as f64;
            baseline.insert(name.clone(), mean);
        }

        // Serialize to JSON
        let mut json = String::from("{\n");
        for (i, (name, value)) in baseline.iter().enumerate() {
            json.push_str(&format!("  \"{}\": {:.2}", name, value));
            if i < baseline.len() - 1 {
                json.push_str(",");
            }
            json.push_str("\n");
        }
        json.push_str("}\n");

        write_string(path, &json)?;
        println!("Baseline saved to {}", path);
        Ok(())
    }
}

/// CI analysis result
#[derive(Clone)]
pub struct CiAnalysisResult {
    pub regressions: Vec<CiRegressionReport>,
    pub improvements: Vec<CiRegressionReport>,
    pub has_regressions: bool,
    pub should_fail: bool,
}

impl CiAnalysisResult {
    pub fn exit_code(&self) -> i32 {
        if self.should_fail { 1 } else { 0 }
    }
}

