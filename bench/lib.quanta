// HTML REPORT GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

/// HTML report generator for benchmark results
pub struct ReportGenerator {
    title: String,
    results: Vec<BenchResult>,
    parametric_results: Vec<ParametricResult>,
    comparisons: Vec<RegressionReport>,
}

/// Regression comparison report
#[derive(Clone)]
pub struct RegressionReport {
    pub benchmark_name: String,
    pub baseline_mean: f64,
    pub current_mean: f64,
    pub change_percent: f64,
    pub t_test: TTestResult,
    pub verdict: RegressionVerdict,
}

#[derive(Clone, Copy, Debug)]
pub enum RegressionVerdict {
    NoChange,
    Improved,
    Regressed,
}

impl ReportGenerator {
    pub fn new(title: &str) -> Self {
        ReportGenerator {
            title: title.to_string(),
            results: Vec::new(),
            parametric_results: Vec::new(),
            comparisons: Vec::new(),
        }
    }

    pub fn add_results(&mut self, results: Vec<BenchResult>) {
        self.results.extend(results);
    }

    pub fn add_parametric(&mut self, result: ParametricResult) {
        self.parametric_results.push(result);
    }

    pub fn add_comparison(&mut self, report: RegressionReport) {
        self.comparisons.push(report);
    }

    /// Generate full HTML report
    pub fn generate_html(&self) -> String {
        let mut html = String::new();

        html.push_str("<!DOCTYPE html>\n<html>\n<head>\n");
        html.push_str(&format!("<title>{} - Benchmark Report</title>\n", self.title));
        html.push_str(self.css_styles());
        html.push_str(self.chart_scripts());
        html.push_str("</head>\n<body>\n");

        // Header
        html.push_str(&format!("<h1>{}</h1>\n", self.title));
        html.push_str(&format!("<p>Generated: {}</p>\n", "2024-12-23")); // Placeholder date

        // Summary table
        html.push_str("<h2>Benchmark Results</h2>\n");
        html.push_str(self.results_table());

        // Regression report if any
        if !self.comparisons.is_empty() {
            html.push_str("<h2>Regression Analysis</h2>\n");
            html.push_str(self.regression_table());
        }

        // Parametric results with charts
        if !self.parametric_results.is_empty() {
            html.push_str("<h2>Scaling Analysis</h2>\n");
            for result in &self.parametric_results {
                html.push_str(&self.parametric_chart(result));
            }
        }

        html.push_str("</body>\n</html>");
        html
    }

    fn css_styles(&self) -> &str {
        r#"<style>
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 40px; }
h1 { color: #2c3e50; }
table { border-collapse: collapse; width: 100%; margin: 20px 0; }
th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
th { background-color: #3498db; color: white; }
tr:nth-child(even) { background-color: #f9f9f9; }
.improved { color: #27ae60; font-weight: bold; }
.regressed { color: #e74c3c; font-weight: bold; }
.chart-container { width: 100%; max-width: 800px; margin: 20px 0; }
</style>
"#
    }

    fn chart_scripts(&self) -> &str {
        r#"<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
"#
    }

    fn results_table(&self) -> String {
        let mut table = String::from("<table>\n");
        table.push_str("<tr><th>Benchmark</th><th>Mean</th><th>Std Dev</th><th>Min</th><th>Max</th><th>Iterations</th></tr>\n");

        for result in &self.results {
            table.push_str(&format!(
                "<tr><td>{}</td><td>{}</td><td>{}</td><td>{}</td><td>{}</td><td>{}</td></tr>\n",
                result.name,
                format_duration(result.stats.mean),
                format_duration(result.stats.std_dev),
                format_duration(result.stats.min),
                format_duration(result.stats.max),
                result.stats.iterations
            ));
        }

        table.push_str("</table>\n");
        table
    }

    fn regression_table(&self) -> String {
        let mut table = String::from("<table>\n");
        table.push_str("<tr><th>Benchmark</th><th>Baseline</th><th>Current</th><th>Change</th><th>Verdict</th></tr>\n");

        for comp in &self.comparisons {
            let change_class = match comp.verdict {
                RegressionVerdict::Improved => "improved",
                RegressionVerdict::Regressed => "regressed",
                RegressionVerdict::NoChange => "",
            };

            let verdict_str = match comp.verdict {
                RegressionVerdict::Improved => "✓ Improved",
                RegressionVerdict::Regressed => "✗ Regressed",
                RegressionVerdict::NoChange => "— No Change",
            };

            table.push_str(&format!(
                "<tr><td>{}</td><td>{}</td><td>{}</td><td class=\"{}\">{:+.1}%</td><td class=\"{}\">{}</td></tr>\n",
                comp.benchmark_name,
                format_duration(comp.baseline_mean),
                format_duration(comp.current_mean),
                change_class,
                comp.change_percent,
                change_class,
                verdict_str
            ));
        }

        table.push_str("</table>\n");
        table
    }

    fn parametric_chart(&self, result: &ParametricResult) -> String {
        let sizes_json: Vec<String> = result.sizes.iter().map(|s| s.to_string()).collect();
        let times_json: Vec<String> = result.results.iter()
            .map(|r| format!("{:.2}", r.stats.mean))
            .collect();

        format!(
            r#"<div class="chart-container">
<h3>{}</h3>
<canvas id="chart_{}"></canvas>
<script>
new Chart(document.getElementById('chart_{}'), {{
    type: 'line',
    data: {{
        labels: [{}],
        datasets: [{{
            label: 'Time (ns)',
            data: [{}],
            borderColor: '#3498db',
            fill: false
        }}]
    }},
    options: {{
        responsive: true,
        scales: {{
            y: {{ beginAtZero: true }}
        }}
    }}
}});
</script>
</div>
"#,
            result.name,
            result.name.replace(" ", "_"),
            result.name.replace(" ", "_"),
            sizes_json.join(","),
            times_json.join(",")
        )
    }
}

