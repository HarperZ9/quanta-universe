// PARAMETRIC BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

/// Configuration for parametric benchmarks
#[derive(Clone)]
pub struct ParametricConfig {
    pub sizes: Vec<u64>,
    pub labels: Option<Vec<String>>,
    pub plot_type: PlotType,
}

#[derive(Clone, Copy)]
pub enum PlotType {
    Linear,
    LogLog,
    SemiLogX,
    SemiLogY,
}

impl ParametricConfig {
    /// Create a range of sizes from min to max
    pub fn range(min: u64, max: u64, count: usize) -> Self {
        let step = (max - min) / (count - 1) as u64;
        let sizes: Vec<u64> = (0..count)
            .map(|i| min + step * i as u64)
            .collect();
        ParametricConfig {
            sizes,
            labels: None,
            plot_type: PlotType::Linear,
        }
    }

    /// Create exponential sizes (powers of 2)
    pub fn powers_of_2(min_power: u32, max_power: u32) -> Self {
        let sizes: Vec<u64> = (min_power..=max_power)
            .map(|p| 1u64 << p)
            .collect();
        ParametricConfig {
            sizes,
            labels: None,
            plot_type: PlotType::LogLog,
        }
    }

    /// Create custom sizes
    pub fn custom(sizes: Vec<u64>) -> Self {
        ParametricConfig {
            sizes,
            labels: None,
            plot_type: PlotType::Linear,
        }
    }
}

/// Results from a parametric benchmark
#[derive(Clone)]
pub struct ParametricResult {
    pub name: String,
    pub sizes: Vec<u64>,
    pub results: Vec<BenchResult>,
    pub complexity: Option<ComplexityEstimate>,
}

/// Big-O complexity estimation
#[derive(Clone)]
pub struct ComplexityEstimate {
    pub complexity: Complexity,
    pub coefficient: f64,
    pub r_squared: f64,  // Goodness of fit
}

#[derive(Clone, Copy, Debug)]
pub enum Complexity {
    O1,
    OLogN,
    ON,
    ONLogN,
    ON2,
    ON3,
    O2N,
}

impl Complexity {
    pub fn as_str(&self) -> &str {
        match self {
            Complexity::O1 => "O(1)",
            Complexity::OLogN => "O(log n)",
            Complexity::ON => "O(n)",
            Complexity::ONLogN => "O(n log n)",
            Complexity::ON2 => "O(n²)",
            Complexity::ON3 => "O(n³)",
            Complexity::O2N => "O(2ⁿ)",
        }
    }

    pub fn evaluate(&self, n: f64) -> f64 {
        match self {
            Complexity::O1 => 1.0,
            Complexity::OLogN => n.ln(),
            Complexity::ON => n,
            Complexity::ONLogN => n * n.ln(),
            Complexity::ON2 => n * n,
            Complexity::ON3 => n * n * n,
            Complexity::O2N => 2.0_f64.powf(n),
        }
    }
}

/// Estimate algorithmic complexity from benchmark results
pub fn estimate_complexity(sizes: &[u64], times: &[f64]) -> ComplexityEstimate {
    let complexities = [
        Complexity::O1,
        Complexity::OLogN,
        Complexity::ON,
        Complexity::ONLogN,
        Complexity::ON2,
        Complexity::ON3,
    ];

    let mut best_fit = ComplexityEstimate {
        complexity: Complexity::ON,
        coefficient: 1.0,
        r_squared: 0.0,
    };

    for complexity in complexities.iter() {
        // Transform sizes according to complexity
        let x_vals: Vec<f64> = sizes.iter()
            .map(|&s| complexity.evaluate(s as f64))
            .collect();

        // Linear regression: time = coefficient * complexity(n)
        let (slope, r_squared) = linear_regression(&x_vals, times);

        if r_squared > best_fit.r_squared {
            best_fit = ComplexityEstimate {
                complexity: *complexity,
                coefficient: slope,
                r_squared,
            };
        }
    }

    best_fit
}

/// Simple linear regression returning slope and R²
fn linear_regression(x: &[f64], y: &[f64]) -> (f64, f64) {
    let n = x.len() as f64;
    let sum_x: f64 = x.iter().sum();
    let sum_y: f64 = y.iter().sum();
    let sum_xy: f64 = x.iter().zip(y.iter()).map(|(a, b)| a * b).sum();
    let sum_x2: f64 = x.iter().map(|a| a * a).sum();
    let sum_y2: f64 = y.iter().map(|a| a * a).sum();

    let slope = (n * sum_xy - sum_x * sum_y) / (n * sum_x2 - sum_x * sum_x);

    // R² calculation
    let mean_y = sum_y / n;
    let ss_tot: f64 = y.iter().map(|yi| (yi - mean_y).powi(2)).sum();
    let ss_res: f64 = x.iter().zip(y.iter())
        .map(|(xi, yi)| (yi - slope * xi).powi(2))
        .sum();
    let r_squared = 1.0 - ss_res / ss_tot;

    (slope, r_squared.max(0.0).min(1.0))
}

