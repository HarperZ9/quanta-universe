// TERMINAL UI FOR INTERACTIVE BENCHMARKING
// ═══════════════════════════════════════════════════════════════════════════════

/// Terminal colors
pub mod colors {
    pub const RESET: &str = "\x1b[0m";
    pub const BOLD: &str = "\x1b[1m";
    pub const DIM: &str = "\x1b[2m";
    pub const RED: &str = "\x1b[31m";
    pub const GREEN: &str = "\x1b[32m";
    pub const YELLOW: &str = "\x1b[33m";
    pub const BLUE: &str = "\x1b[34m";
    pub const MAGENTA: &str = "\x1b[35m";
    pub const CYAN: &str = "\x1b[36m";
}

/// Progress bar for long-running benchmarks
pub struct ProgressBar {
    total: u64,
    current: u64,
    width: usize,
    label: String,
    start_time: Instant,
}

impl ProgressBar {
    pub fn new(total: u64, label: &str) -> Self {
        ProgressBar {
            total,
            current: 0,
            width: 40,
            label: label.to_string(),
            start_time: Instant::now(),
        }
    }

    pub fn set(&mut self, current: u64) {
        self.current = current.min(self.total);
        self.draw();
    }

    pub fn inc(&mut self) {
        self.current = (self.current + 1).min(self.total);
        self.draw();
    }

    fn draw(&self) {
        let progress = self.current as f64 / self.total as f64;
        let filled = (progress * self.width as f64) as usize;
        let empty = self.width - filled;

        let bar: String = "█".repeat(filled) + &"░".repeat(empty);

        let elapsed = self.start_time.elapsed().as_secs_f64();
        let eta = if self.current > 0 {
            (elapsed / self.current as f64) * (self.total - self.current) as f64
        } else {
            0.0
        };

        print!("\r{} |{}| {:5.1}% ETA: {:.1}s  ",
            self.label, bar, progress * 100.0, eta);
        std::io::Write::flush(&mut std::io::stdout()).ok();
    }

    pub fn finish(&self) {
        let elapsed = self.start_time.elapsed().as_secs_f64();
        println!("\r{} |{}| 100.0% Done in {:.1}s",
            self.label,
            "█".repeat(self.width),
            elapsed);
    }
}

/// Live benchmark display
pub struct LiveDisplay {
    benchmarks: Vec<LiveBenchStatus>,
    refresh_rate_ms: u64,
}

#[derive(Clone)]
struct LiveBenchStatus {
    name: String,
    status: BenchStatus,
    current_mean: f64,
    samples: u64,
    progress: f64,
}

#[derive(Clone, Copy, Debug, PartialEq)]
pub enum BenchStatus {
    Pending,
    Warmup,
    Running,
    Completed,
    Failed,
}

impl LiveDisplay {
    pub fn new() -> Self {
        LiveDisplay {
            benchmarks: Vec::new(),
            refresh_rate_ms: 100,
        }
    }

    pub fn add_benchmark(&mut self, name: &str) {
        self.benchmarks.push(LiveBenchStatus {
            name: name.to_string(),
            status: BenchStatus::Pending,
            current_mean: 0.0,
            samples: 0,
            progress: 0.0,
        });
    }

    pub fn update(&mut self, name: &str, status: BenchStatus, mean: f64, samples: u64, progress: f64) {
        if let Some(bench) = self.benchmarks.iter_mut().find(|b| b.name == name) {
            bench.status = status;
            bench.current_mean = mean;
            bench.samples = samples;
            bench.progress = progress;
        }
        self.draw();
    }

    fn draw(&self) {
        // Clear screen
        print!("\x1b[2J\x1b[H");

        println!("{}╔═══════════════════════════════════════════════════════════════╗{}",
            colors::CYAN, colors::RESET);
        println!("{}║  Live Benchmark Status                                        ║{}",
            colors::CYAN, colors::RESET);
        println!("{}╚═══════════════════════════════════════════════════════════════╝{}",
            colors::CYAN, colors::RESET);
        println!();

        for bench in &self.benchmarks {
            let status_str = match bench.status {
                BenchStatus::Pending => format!("{}⏳ Pending{}", colors::DIM, colors::RESET),
                BenchStatus::Warmup => format!("{}🔥 Warmup{}", colors::YELLOW, colors::RESET),
                BenchStatus::Running => format!("{}▶️  Running{}", colors::BLUE, colors::RESET),
                BenchStatus::Completed => format!("{}✅ Done{}", colors::GREEN, colors::RESET),
                BenchStatus::Failed => format!("{}❌ Failed{}", colors::RED, colors::RESET),
            };

            let bar_width = 20;
            let filled = (bench.progress * bar_width as f64) as usize;
            let bar: String = "█".repeat(filled) + &"░".repeat(bar_width - filled);

            println!("  {:30} {} |{}| {:>12} ({} samples)",
                bench.name,
                status_str,
                bar,
                format_duration(bench.current_mean),
                bench.samples);
        }

        std::io::Write::flush(&mut std::io::stdout()).ok();
    }
}

