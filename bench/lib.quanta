/// Isolated benchmark runner
pub struct IsolatedBenchRunner {
    affinity: AffinityManager,
    priority: PriorityBooster,
    cpu: Option<usize>,
}

impl IsolatedBenchRunner {
    pub fn new() -> Self {
        IsolatedBenchRunner {
            affinity: AffinityManager::new(),
            priority: PriorityBooster::new(),
            cpu: None,
        }
    }

    /// Setup isolation for benchmarking
    pub fn setup(&mut self) -> Result<(), String> {
        // Pin to isolated CPU
        self.cpu = Some(self.affinity.isolate_for_benchmarking()?);

        // Boost priority
        self.priority.boost()?;

        // Disable frequency scaling if possible
        self.disable_frequency_scaling()?;

        Ok(())
    }

    /// Cleanup after benchmarking
    pub fn cleanup(&self) -> Result<(), String> {
        self.priority.restore()?;
        self.affinity.restore()?;
        Ok(())
    }

    fn disable_frequency_scaling(&self) -> Result<(), String> {
        #[cfg(target_os = "linux")]
        {
            // Would write "performance" to /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
            Ok(())
        }
        #[cfg(not(target_os = "linux"))]
        {
            Ok(())
        }
    }

    /// Run benchmark with isolation
    pub fn run<F, R>(&mut self, f: F) -> Result<R, String>
    where
        F: FnOnce() -> R,
    {
        self.setup()?;
        let result = f();
        self.cleanup()?;
        Ok(result)
    }
}

