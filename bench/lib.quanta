// BENCHMARK FILTERING
// ═══════════════════════════════════════════════════════════════════════════════

/// Filter benchmarks by pattern
#[derive(Clone)]
pub struct BenchFilter {
    include_patterns: Vec<String>,
    exclude_patterns: Vec<String>,
    groups: Option<Vec<String>>,
}

impl BenchFilter {
    pub fn new() -> Self {
        BenchFilter {
            include_patterns: Vec::new(),
            exclude_patterns: Vec::new(),
            groups: None,
        }
    }

    pub fn include(mut self, pattern: &str) -> Self {
        self.include_patterns.push(pattern.to_string());
        self
    }

    pub fn exclude(mut self, pattern: &str) -> Self {
        self.exclude_patterns.push(pattern.to_string());
        self
    }

    pub fn groups(mut self, groups: Vec<String>) -> Self {
        self.groups = Some(groups);
        self
    }

    pub fn matches(&self, name: &str, group: Option<&str>) -> bool {
        // Check group filter
        if let Some(ref allowed_groups) = self.groups {
            if let Some(g) = group {
                if !allowed_groups.iter().any(|ag| ag == g) {
                    return false;
                }
            } else {
                return false;
            }
        }

        // Check exclude patterns
        for pattern in &self.exclude_patterns {
            if glob_match(pattern, name) {
                return false;
            }
        }

        // If no include patterns, match all
        if self.include_patterns.is_empty() {
            return true;
        }

        // Check include patterns
        for pattern in &self.include_patterns {
            if glob_match(pattern, name) {
                return true;
            }
        }

        false
    }
}

/// Simple glob pattern matching
fn glob_match(pattern: &str, text: &str) -> bool {
    // Handle * as wildcard
    if pattern == "*" {
        return true;
    }

    if pattern.starts_with("*") && pattern.ends_with("*") {
        let inner = &pattern[1..pattern.len()-1];
        return text.contains(inner);
    }

    if pattern.starts_with("*") {
        let suffix = &pattern[1..];
        return text.ends_with(suffix);
    }

    if pattern.ends_with("*") {
        let prefix = &pattern[..pattern.len()-1];
        return text.starts_with(prefix);
    }

    pattern == text
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOISE REDUCTION / OUTLIER FILTERING
// ═══════════════════════════════════════════════════════════════════════════════

/// Noise reduction strategy for benchmark measurements
#[derive(Clone, Copy)]
pub enum NoiseReduction {
    None,
    /// Remove samples outside 1.5 * IQR
    IQR,
    /// Remove samples more than N standard deviations from mean
    StdDev(f64),
    /// Keep only the fastest N% of samples
    FastestPercent(f64),
    /// Winsorize extreme values
    Winsorize(f64),
}

impl NoiseReduction {
    pub fn apply(&self, samples: &mut Vec<f64>) {
        match self {
            NoiseReduction::None => {}
            NoiseReduction::IQR => {
                if samples.len() < 4 { return; }

                let mut sorted = samples.clone();
                sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());

                let n = sorted.len();
                let q1 = sorted[n / 4];
                let q3 = sorted[3 * n / 4];
                let iqr = q3 - q1;
                let lower = q1 - 1.5 * iqr;
                let upper = q3 + 1.5 * iqr;

                samples.retain(|&x| x >= lower && x <= upper);
            }
            NoiseReduction::StdDev(n_std) => {
                if samples.len() < 2 { return; }

                let mean: f64 = samples.iter().sum::<f64>() / samples.len() as f64;
                let variance: f64 = samples.iter()
                    .map(|x| (x - mean).powi(2))
                    .sum::<f64>() / (samples.len() - 1) as f64;
                let std_dev = variance.sqrt();

                let lower = mean - n_std * std_dev;
                let upper = mean + n_std * std_dev;

                samples.retain(|&x| x >= lower && x <= upper);
            }
            NoiseReduction::FastestPercent(pct) => {
                samples.sort_by(|a, b| a.partial_cmp(b).unwrap());
                let keep = (samples.len() as f64 * pct / 100.0) as usize;
                samples.truncate(keep.max(1));
            }
            NoiseReduction::Winsorize(pct) => {
                if samples.len() < 4 { return; }

                let mut sorted = samples.clone();
                sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());

                let n = sorted.len();
                let lower_idx = (n as f64 * pct / 100.0) as usize;
                let upper_idx = n - lower_idx - 1;

                let lower_val = sorted[lower_idx];
                let upper_val = sorted[upper_idx];

                for sample in samples.iter_mut() {
                    if *sample < lower_val { *sample = lower_val; }
                    if *sample > upper_val { *sample = upper_val; }
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK HISTORY / TREND ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Historical benchmark data for trend analysis
#[derive(Clone)]
pub struct BenchHistory {
    pub benchmark_name: String,
    pub data_points: Vec<HistoryPoint>,
}

#[derive(Clone)]
pub struct HistoryPoint {
    pub timestamp: u64,
    pub commit_hash: Option<String>,
    pub mean: f64,
    pub std_dev: f64,
}

impl BenchHistory {
    pub fn new(name: &str) -> Self {
        BenchHistory {
            benchmark_name: name.to_string(),
            data_points: Vec::new(),
        }
    }

    pub fn add_point(&mut self, point: HistoryPoint) {
        self.data_points.push(point);
    }

    /// Detect trend direction
    pub fn trend(&self) -> Trend {
        if self.data_points.len() < 3 {
            return Trend::Stable;
        }

        // Use linear regression on recent points
        let recent: Vec<_> = self.data_points.iter()
            .rev()
            .take(10)
            .collect();

        let n = recent.len() as f64;
        let x: Vec<f64> = (0..recent.len()).map(|i| i as f64).collect();
        let y: Vec<f64> = recent.iter().map(|p| p.mean).collect();

        let sum_x: f64 = x.iter().sum();
        let sum_y: f64 = y.iter().sum();
        let sum_xy: f64 = x.iter().zip(y.iter()).map(|(a, b)| a * b).sum();
        let sum_x2: f64 = x.iter().map(|a| a * a).sum();

        let slope = (n * sum_xy - sum_x * sum_y) / (n * sum_x2 - sum_x * sum_x);

        // Determine significance based on coefficient of variation
        let mean_y = sum_y / n;
        let threshold = mean_y * 0.05; // 5% change is significant

        if slope > threshold { Trend::Degrading }
        else if slope < -threshold { Trend::Improving }
        else { Trend::Stable }
    }

    /// Detect sudden spikes/changes
    pub fn detect_anomalies(&self) -> Vec<usize> {
        if self.data_points.len() < 5 {
            return Vec::new();
        }

        let mut anomalies = Vec::new();

        // Rolling window anomaly detection
        for i in 2..self.data_points.len() {
            let window: Vec<f64> = self.data_points[i.saturating_sub(5)..i]
                .iter()
                .map(|p| p.mean)
                .collect();

            let mean: f64 = window.iter().sum::<f64>() / window.len() as f64;
            let variance: f64 = window.iter()
                .map(|x| (x - mean).powi(2))
                .sum::<f64>() / window.len() as f64;
            let std_dev = variance.sqrt();

            let current = self.data_points[i].mean;
            if (current - mean).abs() > 3.0 * std_dev {
                anomalies.push(i);
            }
        }

        anomalies
    }
}

#[derive(Clone, Copy, Debug)]
pub enum Trend {
    Improving,
    Stable,
    Degrading,
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENDED BENCHER WITH ALL FEATURES
// ═══════════════════════════════════════════════════════════════════════════════

/// Extended benchmark runner with all advanced features
pub struct ExtendedBencher {
    inner: Bencher,
    filter: Option<BenchFilter>,
    noise_reduction: NoiseReduction,
    memory_profiler: MemoryProfiler,
    perf_profiler: PerfProfiler,
    parametric_results: Vec<ParametricResult>,
    history: HashMap<String, BenchHistory>,
}

impl ExtendedBencher {
    pub fn new() -> Self {
        ExtendedBencher {
            inner: Bencher::new(),
            filter: None,
            noise_reduction: NoiseReduction::IQR,
            memory_profiler: MemoryProfiler::new(),
            perf_profiler: PerfProfiler::new(),
            parametric_results: Vec::new(),
            history: HashMap::new(),
        }
    }

    pub fn with_filter(mut self, filter: BenchFilter) -> Self {
        self.filter = Some(filter);
        self
    }

    pub fn with_noise_reduction(mut self, nr: NoiseReduction) -> Self {
        self.noise_reduction = nr;
        self
    }

    /// Run parametric benchmark across multiple sizes
    pub fn bench_parametric<F>(&mut self, name: &str, config: &ParametricConfig, mut f: F)
    where
        F: FnMut(u64, &mut Iteration),
    {
        println!("\n{} (parametric)", name);
        println!("{}", "─".repeat(60));

        let mut results = Vec::new();
        let mut times = Vec::new();

        for &size in &config.sizes {
            let bench_name = format!("{}_{}", name, size);

            self.inner.bench(&bench_name, |iter| {
                f(size, iter);
            });

            if let Some(result) = self.inner.results.last() {
                times.push(result.stats.mean);
                results.push(result.clone());
            }
        }

        // Estimate complexity
        let complexity = estimate_complexity(&config.sizes, &times);
        println!("\nEstimated complexity: {} (R² = {:.3})",
            complexity.complexity.as_str(),
            complexity.r_squared);

        self.parametric_results.push(ParametricResult {
            name: name.to_string(),
            sizes: config.sizes.clone(),
            results,
            complexity: Some(complexity),
        });
    }

    /// Benchmark with memory profiling
    pub fn bench_with_memory<F>(&mut self, name: &str, mut f: F) -> MemoryProfile
    where
        F: FnMut(&mut Iteration),
    {
        self.memory_profiler.start();
        self.inner.bench(name, |iter| f(iter));
        self.memory_profiler.stop()
    }

    /// Benchmark with hardware performance counters
    pub fn bench_with_perf<F>(&mut self, name: &str, mut f: F) -> Option<PerfCounters>
    where
        F: FnMut(&mut Iteration),
    {
        if !PerfProfiler::is_available() {
            println!("Warning: Hardware performance counters not available");
            self.inner.bench(name, |iter| f(iter));
            return None;
        }

        self.perf_profiler.start();
        self.inner.bench(name, |iter| f(iter));
        Some(self.perf_profiler.stop())
    }

    /// Generate HTML report
    pub fn generate_report(&self, title: &str) -> String {
        let mut generator = ReportGenerator::new(title);
        generator.add_results(self.inner.results.clone());

        for param in &self.parametric_results {
            generator.add_parametric(param.clone());
        }

        generator.generate_html()
    }

    /// Compare with baseline and detect regressions
    pub fn compare_with_baseline(&self, baseline_path: &str) -> Vec<RegressionReport> {
        let baseline = load_baseline(baseline_path).unwrap_or_default();
        let mut reports = Vec::new();

        for result in &self.inner.results {
            if let Some(&baseline_mean) = baseline.get(&result.name) {
                let change_percent = (result.stats.mean - baseline_mean) / baseline_mean * 100.0;

                // Simple significance test
                let significant = change_percent.abs() > 5.0;

                let verdict = if !significant {
                    RegressionVerdict::NoChange
                } else if change_percent < 0.0 {
                    RegressionVerdict::Improved
                } else {
                    RegressionVerdict::Regressed
                };

                reports.push(RegressionReport {
                    benchmark_name: result.name.clone(),
                    baseline_mean,
                    current_mean: result.stats.mean,
                    change_percent,
                    t_test: TTestResult {
                        t_statistic: 0.0,
                        degrees_of_freedom: 0.0,
                        p_value: 0.0,
                        significant,
                        effect_size: 0.0,
                        effect_magnitude: EffectMagnitude::Negligible,
                    },
                    verdict,
                });
            }
        }

        reports
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CRITERION-COMPATIBLE API
// ═══════════════════════════════════════════════════════════════════════════════

/// Criterion-style benchmark group
pub struct CriterionGroup<'a> {
    name: String,
    bencher: &'a mut Bencher,
}

impl<'a> CriterionGroup<'a> {
    pub fn new(name: &str, bencher: &'a mut Bencher) -> Self {
        bencher.group(name);
        CriterionGroup {
            name: name.to_string(),
            bencher,
        }
    }

    pub fn bench_function<F>(&mut self, name: &str, mut f: F) -> &mut Self
    where
        F: FnMut(&mut Iteration),
    {
        self.bencher.bench(name, |iter| f(iter));
        self
    }

    pub fn bench_with_input<I, F>(&mut self, name: &str, input: I, mut f: F) -> &mut Self
    where
        I: Clone,
        F: FnMut(&mut Iteration, I),
    {
        let input_clone = input.clone();
        self.bencher.bench(name, |iter| {
            f(iter, input_clone.clone());
        });
        self
    }

    pub fn throughput(&mut self, size: u64) -> &mut Self {
        // Set throughput for next benchmark
        self
    }

    pub fn sample_size(&mut self, size: usize) -> &mut Self {
        // Configure sample size
        self
    }

    pub fn measurement_time(&mut self, duration: Duration) -> &mut Self {
        // Configure measurement time
        self
    }
}

impl<'a> Drop for CriterionGroup<'a> {
    fn drop(&mut self) {
        self.bencher.group_end();
    }
}

/// Criterion-style main function
pub fn criterion_main<F>(f: F)
where
    F: FnOnce(&mut Bencher),
{
    let mut bencher = Bencher::new();
    f(&mut bencher);
    bencher.summary();
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPARISON BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

/// Compare multiple implementations
pub struct ComparisonBench<'a> {
    name: String,
    bencher: &'a mut Bencher,
    results: Vec<(String, f64)>,
}

impl<'a> ComparisonBench<'a> {
    pub fn new(name: &str, bencher: &'a mut Bencher) -> Self {
        ComparisonBench {
            name: name.to_string(),
            bencher,
            results: Vec::new(),
        }
    }

    pub fn compare<F>(&mut self, impl_name: &str, mut f: F) -> &mut Self
    where
        F: FnMut(&mut Iteration),
    {
        let bench_name = format!("{}/{}", self.name, impl_name);
        self.bencher.bench(&bench_name, |iter| f(iter));

        if let Some(result) = self.bencher.results.last() {
            self.results.push((impl_name.to_string(), result.stats.mean));
        }

        self
    }

    pub fn summary(&self) {
        if self.results.is_empty() { return; }

        println!("\n{} Comparison:", self.name);
        println!("{}", "─".repeat(40));

        // Find fastest
        let min = self.results.iter()
            .map(|(_, t)| *t)
            .fold(f64::MAX, f64::min);

        for (name, time) in &self.results {
            let ratio = time / min;
            let bar_len = (ratio * 20.0) as usize;
            let bar: String = "█".repeat(bar_len.min(40));

            println!("  {:15} {:>12} {:6.2}x  {}",
                name,
                format_duration(*time),
                ratio,
                bar);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MICRO-BENCHMARK UTILITIES
// ═══════════════════════════════════════════════════════════════════════════════

/// CPU cache flush utility
pub fn flush_cache() {
    // Write to large buffer to evict cache
    const SIZE: usize = 32 * 1024 * 1024; // 32 MB
    let mut buffer = vec![0u8; SIZE];
    for (i, byte) in buffer.iter_mut().enumerate() {
        *byte = (i & 0xFF) as u8;
    }
    Iteration::black_box(buffer);
}

/// Memory barrier
pub fn memory_barrier() {
    #[cfg(target_arch = "x86_64")]
    unsafe {
        core::arch::x86_64::_mm_mfence();
    }
}

/// Prevent instruction reordering
pub fn compiler_fence() {
    core::sync::atomic::compiler_fence(core::sync::atomic::Ordering::SeqCst);
}

/// Read CPU timestamp counter
#[cfg(target_arch = "x86_64")]
pub fn rdtsc() -> u64 {
    unsafe {
        core::arch::x86_64::_rdtsc()
    }
}

#[cfg(not(target_arch = "x86_64"))]
pub fn rdtsc() -> u64 {
    0 // Fallback
}

/// CPU cycles for an operation
pub fn measure_cycles<F, R>(f: F) -> (R, u64)
where
    F: FnOnce() -> R,
{
    compiler_fence();
    let start = rdtsc();
    compiler_fence();

    let result = f();

    compiler_fence();
    let end = rdtsc();
    compiler_fence();

    (result, end - start)
}

// ═══════════════════════════════════════════════════════════════════════════════
// HDR HISTOGRAM FOR LATENCY DISTRIBUTION
// ═══════════════════════════════════════════════════════════════════════════════

/// High Dynamic Range (HDR) Histogram for latency measurements
/// Based on Gil Tene's HdrHistogram algorithm
#[derive(Clone)]
pub struct HdrHistogram {
    /// Number of significant digits of precision
    significant_digits: u8,
    /// Unit magnitude (smallest distinguishable value)
    unit_magnitude: i32,
    /// Sub-bucket count (2^sub_bucket_half_count_magnitude)
    sub_bucket_count: u32,
    sub_bucket_half_count: u32,
    sub_bucket_mask: u64,
    /// Counts array
    counts: Vec<u64>,
    /// Total count of all values
    total_count: u64,
    /// Maximum tracked value
    max_value: u64,
    /// Minimum tracked value (non-zero)
    min_non_zero_value: u64,
    /// Highest value in histogram
    highest_trackable_value: u64,
    /// Lowest value in histogram
    lowest_discernible_value: u64,
}

impl HdrHistogram {
    pub fn new(lowest_discernible: u64, highest_trackable: u64, significant_digits: u8) -> Self {
        let significant_digits = significant_digits.min(5);

        let largest_value_with_single_unit_resolution = 2 * 10u64.pow(significant_digits as u32);
        let sub_bucket_count_magnitude = (largest_value_with_single_unit_resolution as f64).log2().ceil() as u32;
        let sub_bucket_half_count_magnitude = sub_bucket_count_magnitude.saturating_sub(1);

        let sub_bucket_count = 1u32 << (sub_bucket_half_count_magnitude + 1);
        let sub_bucket_half_count = sub_bucket_count >> 1;
        let sub_bucket_mask = (sub_bucket_count as u64 - 1) << 32;

        let unit_magnitude = (lowest_discernible as f64).log2().floor() as i32;

        // Calculate counts array size
        let buckets_needed = Self::buckets_needed_for_value(highest_trackable, sub_bucket_count, unit_magnitude);
        let counts_len = (buckets_needed + 1) * (sub_bucket_half_count as usize);

        HdrHistogram {
            significant_digits,
            unit_magnitude,
            sub_bucket_count,
            sub_bucket_half_count,
            sub_bucket_mask,
            counts: vec![0; counts_len],
            total_count: 0,
            max_value: 0,
            min_non_zero_value: u64::MAX,
            highest_trackable_value: highest_trackable,
            lowest_discernible_value: lowest_discernible,
        }
    }

    fn buckets_needed_for_value(value: u64, sub_bucket_count: u32, unit_magnitude: i32) -> usize {
        let mut smallest_untrackable = (sub_bucket_count as u64) << unit_magnitude;
        let mut buckets_needed = 1usize;

        while smallest_untrackable <= value {
            if smallest_untrackable > u64::MAX / 2 {
                return buckets_needed + 1;
            }
            smallest_untrackable <<= 1;
            buckets_needed += 1;
        }

        buckets_needed
    }

    /// Record a value in the histogram
    pub fn record_value(&mut self, value: u64) -> bool {
        if value > self.highest_trackable_value {
            return false;
        }

        let idx = self.counts_index_for(value);
        if idx >= self.counts.len() {
            return false;
        }

        self.counts[idx] += 1;
        self.total_count += 1;

        if value > self.max_value {
            self.max_value = value;
        }
        if value < self.min_non_zero_value && value > 0 {
            self.min_non_zero_value = value;
        }

        true
    }

    /// Record a value with count
    pub fn record_values(&mut self, value: u64, count: u64) -> bool {
        if value > self.highest_trackable_value {
            return false;
        }

        let idx = self.counts_index_for(value);
        if idx >= self.counts.len() {
            return false;
        }

        self.counts[idx] += count;
        self.total_count += count;

        if value > self.max_value {
            self.max_value = value;
        }
        if value < self.min_non_zero_value && value > 0 {
            self.min_non_zero_value = value;
        }

        true
    }

    fn counts_index_for(&self, value: u64) -> usize {
        let bucket_idx = self.bucket_index(value);
        let sub_bucket_idx = self.sub_bucket_index(value, bucket_idx);
        bucket_idx * self.sub_bucket_half_count as usize + sub_bucket_idx
    }

    fn bucket_index(&self, value: u64) -> usize {
        let pow2ceiling = 64 - (value | self.sub_bucket_mask).leading_zeros() as i32;
        (pow2ceiling - self.unit_magnitude - (self.sub_bucket_half_count as f64).log2() as i32 - 1).max(0) as usize
    }

    fn sub_bucket_index(&self, value: u64, bucket_idx: usize) -> usize {
        (value >> (bucket_idx as i32 + self.unit_magnitude)) as usize
    }

    fn value_from_index(&self, bucket_idx: usize, sub_bucket_idx: usize) -> u64 {
        (sub_bucket_idx as u64) << (bucket_idx as i32 + self.unit_magnitude)
    }

    /// Get value at percentile (0-100)
    pub fn value_at_percentile(&self, percentile: f64) -> u64 {
        let percentile = percentile.max(0.0).min(100.0);
        let count_at_percentile = ((percentile / 100.0 * self.total_count as f64) + 0.5) as u64;

        let mut total = 0u64;

        for bucket_idx in 0..64 {
            for sub_bucket_idx in 0..self.sub_bucket_half_count as usize {
                let idx = bucket_idx * self.sub_bucket_half_count as usize + sub_bucket_idx;
                if idx >= self.counts.len() {
                    break;
                }

                total += self.counts[idx];
                if total >= count_at_percentile {
                    return self.value_from_index(bucket_idx, sub_bucket_idx);
                }
            }
        }

        0
    }

    /// Get percentile at value
    pub fn percentile_at_or_below_value(&self, value: u64) -> f64 {
        if self.total_count == 0 {
            return 100.0;
        }

        let target_idx = self.counts_index_for(value);
        let mut total = 0u64;

        for idx in 0..=target_idx.min(self.counts.len() - 1) {
            total += self.counts[idx];
        }

        (100.0 * total as f64) / self.total_count as f64
    }

    /// Get mean value
    pub fn mean(&self) -> f64 {
        if self.total_count == 0 {
            return 0.0;
        }

        let mut total = 0.0;

        for bucket_idx in 0..64 {
            for sub_bucket_idx in 0..self.sub_bucket_half_count as usize {
                let idx = bucket_idx * self.sub_bucket_half_count as usize + sub_bucket_idx;
                if idx >= self.counts.len() {
                    break;
                }

                let count = self.counts[idx];
                if count > 0 {
                    let value = self.value_from_index(bucket_idx, sub_bucket_idx);
                    total += value as f64 * count as f64;
                }
            }
        }

        total / self.total_count as f64
    }

    /// Get standard deviation
    pub fn std_deviation(&self) -> f64 {
        if self.total_count == 0 {
            return 0.0;
        }

        let mean = self.mean();
        let mut geometric_dev_total = 0.0;

        for bucket_idx in 0..64 {
            for sub_bucket_idx in 0..self.sub_bucket_half_count as usize {
                let idx = bucket_idx * self.sub_bucket_half_count as usize + sub_bucket_idx;
                if idx >= self.counts.len() {
                    break;
                }

                let count = self.counts[idx];
                if count > 0 {
                    let value = self.value_from_index(bucket_idx, sub_bucket_idx);
                    let dev = value as f64 - mean;
                    geometric_dev_total += dev * dev * count as f64;
                }
            }
        }

        (geometric_dev_total / self.total_count as f64).sqrt()
    }

    /// Get min value
    pub fn min(&self) -> u64 {
        if self.min_non_zero_value == u64::MAX { 0 } else { self.min_non_zero_value }
    }

    /// Get max value
    pub fn max(&self) -> u64 {
        self.max_value
    }

    /// Get total count
    pub fn count(&self) -> u64 {
        self.total_count
    }

    /// Reset histogram
    pub fn reset(&mut self) {
        for count in &mut self.counts {
            *count = 0;
        }
        self.total_count = 0;
        self.max_value = 0;
        self.min_non_zero_value = u64::MAX;
    }

    /// Merge another histogram into this one
    pub fn add(&mut self, other: &HdrHistogram) {
        for bucket_idx in 0..64 {
            for sub_bucket_idx in 0..other.sub_bucket_half_count as usize {
                let idx = bucket_idx * other.sub_bucket_half_count as usize + sub_bucket_idx;
                if idx >= other.counts.len() {
                    break;
                }

                let count = other.counts[idx];
                if count > 0 {
                    let value = other.value_from_index(bucket_idx, sub_bucket_idx);
                    self.record_values(value, count);
                }
            }
        }
    }

    /// Generate percentile distribution report
    pub fn percentile_report(&self) -> String {
        let mut report = String::new();
        report.push_str("       Value     Percentile TotalCount 1/(1-Percentile)\n\n");

        let percentiles = [50.0, 75.0, 90.0, 95.0, 99.0, 99.9, 99.99, 99.999, 100.0];

        for &p in &percentiles {
            let value = self.value_at_percentile(p);
            let count_at = ((p / 100.0 * self.total_count as f64) + 0.5) as u64;
            let inv = if p >= 100.0 { f64::INFINITY } else { 1.0 / (1.0 - p / 100.0) };

            report.push_str(&format!(
                "{:12} {:12.6} {:10} {:12.2}\n",
                value,
                p / 100.0,
                count_at,
                inv
            ));
        }

        report.push_str(&format!(
            "\n#[Mean = {:12.3}, StdDeviation = {:12.3}]\n",
            self.mean(),
            self.std_deviation()
        ));
        report.push_str(&format!(
            "#[Max = {:12}, Total count = {:10}]\n",
            self.max(),
            self.count()
        ));

        report
    }

    /// Generate ASCII art histogram
    pub fn ascii_histogram(&self, width: usize) -> String {
        let mut output = String::new();
        let percentiles = [0.0, 10.0, 20.0, 30.0, 40.0, 50.0, 60.0, 70.0, 80.0, 90.0, 95.0, 99.0, 99.9, 100.0];

        let max_val = self.value_at_percentile(100.0) as f64;

        for &p in &percentiles {
            let value = self.value_at_percentile(p);
            let bar_width = if max_val > 0.0 {
                ((value as f64 / max_val) * width as f64) as usize
            } else {
                0
            };

            let bar: String = "█".repeat(bar_width);
            output.push_str(&format!(
                "p{:5.1} {:>12} |{}\n",
                p,
                format_duration(value as f64),
                bar
            ));
        }

        output
    }
}

/// Latency distribution analyzer
pub struct LatencyAnalyzer {
    histogram: HdrHistogram,
    name: String,
    samples_per_second: f64,
}

impl LatencyAnalyzer {
    pub fn new(name: &str, max_latency_ns: u64) -> Self {
        LatencyAnalyzer {
            histogram: HdrHistogram::new(1, max_latency_ns, 3),
            name: name.to_string(),
            samples_per_second: 0.0,
        }
    }

    pub fn record(&mut self, latency_ns: u64) {
        self.histogram.record_value(latency_ns);
    }

    pub fn set_throughput(&mut self, ops_per_sec: f64) {
        self.samples_per_second = ops_per_sec;
    }

    pub fn report(&self) -> LatencyReport {
        LatencyReport {
            name: self.name.clone(),
            min_ns: self.histogram.min(),
            max_ns: self.histogram.max(),
            mean_ns: self.histogram.mean(),
            std_dev_ns: self.histogram.std_deviation(),
            p50_ns: self.histogram.value_at_percentile(50.0),
            p75_ns: self.histogram.value_at_percentile(75.0),
            p90_ns: self.histogram.value_at_percentile(90.0),
            p95_ns: self.histogram.value_at_percentile(95.0),
            p99_ns: self.histogram.value_at_percentile(99.0),
            p999_ns: self.histogram.value_at_percentile(99.9),
            p9999_ns: self.histogram.value_at_percentile(99.99),
            count: self.histogram.count(),
            throughput: self.samples_per_second,
        }
    }

    pub fn reset(&mut self) {
        self.histogram.reset();
    }
}

/// Latency report with all percentiles
#[derive(Clone)]
pub struct LatencyReport {
    pub name: String,
    pub min_ns: u64,
    pub max_ns: u64,
    pub mean_ns: f64,
    pub std_dev_ns: f64,
    pub p50_ns: u64,
    pub p75_ns: u64,
    pub p90_ns: u64,
    pub p95_ns: u64,
    pub p99_ns: u64,
    pub p999_ns: u64,
    pub p9999_ns: u64,
    pub count: u64,
    pub throughput: f64,
}

impl LatencyReport {
    pub fn print(&self) {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  Latency Distribution: {}", self.name);
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("  Samples:    {:>12}", self.count);
        println!("  Throughput: {:>12.2} ops/sec", self.throughput);
        println!();
        println!("  Percentiles:");
        println!("    Min:      {:>12}", format_duration(self.min_ns as f64));
        println!("    p50:      {:>12}", format_duration(self.p50_ns as f64));
        println!("    p75:      {:>12}", format_duration(self.p75_ns as f64));
        println!("    p90:      {:>12}", format_duration(self.p90_ns as f64));
        println!("    p95:      {:>12}", format_duration(self.p95_ns as f64));
        println!("    p99:      {:>12}", format_duration(self.p99_ns as f64));
        println!("    p99.9:    {:>12}", format_duration(self.p999_ns as f64));
        println!("    p99.99:   {:>12}", format_duration(self.p9999_ns as f64));
        println!("    Max:      {:>12}", format_duration(self.max_ns as f64));
        println!();
        println!("  Mean:       {:>12}", format_duration(self.mean_ns));
        println!("  Std Dev:    {:>12}", format_duration(self.std_dev_ns));
    }
}

