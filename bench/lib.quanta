pub fn main() {
    run_example_benchmarks();
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENDED EXAMPLE BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn run_extended_examples() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  QUANTA-UNIVERSE Extended Benchmark Examples                  ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // HDR Histogram demo
    println!("HDR Histogram Demo:");
    let mut histogram = HdrHistogram::new(1, 1_000_000_000, 3);
    for i in 0..10000 {
        let latency = 100 + (i % 500) + (i * 7 % 100);
        histogram.record_value(latency as u64);
    }
    println!("{}", histogram.percentile_report());

    // Concurrent benchmark demo
    println!("\nConcurrent Benchmark Demo:");
    let mut concurrent = ConcurrentBencher::with_config(ConcurrentBenchConfig {
        thread_count: 4,
        duration: Duration::from_millis(500),
        warmup_duration: Duration::from_millis(100),
        ..Default::default()
    });

    let result = concurrent.bench_concurrent("counter_increment", |_thread_id| {
        let mut x = 0u64;
        for _ in 0..1000 {
            x = x.wrapping_add(1);
        }
        Iteration::black_box(x);
    });

    println!("  Throughput: {:.2} ops/sec", result.operations_per_second);
    println!("  p99 latency: {}", format_duration(result.latency.p99_ns as f64));

    // I/O benchmark demo (simulated)
    println!("\nI/O Benchmark Demo:");
    let io_suite = IoBenchSuite::new(
        IoBenchConfig {
            file_size: 1024 * 1024, // 1 MB
            block_size: 4096,
            num_operations: 100,
            ..Default::default()
        },
        "/tmp/bench_test"
    );

    let seq_read = io_suite.bench_sequential_read();
    println!("  Sequential Read: {:.2} MB/s", seq_read.throughput_mbps);

    // Progress bar demo
    println!("\nProgress Bar Demo:");
    let mut progress = ProgressBar::new(50, "Processing");
    for i in 0..=50 {
        progress.set(i);
        std::thread::sleep(Duration::from_millis(20));
    }
    progress.finish();

    // Allocator benchmark demo
    println!("\nAllocator Benchmark Demo:");
    let mut alloc_bencher = AllocatorBencher::new(AllocatorBenchConfig {
        num_operations: 1000,
        ..Default::default()
    });
    let alloc_result = alloc_bencher.run("system_allocator");
    println!("  Allocs/sec: {:.2}", alloc_result.allocs_per_second);
    println!("  Mean latency: {}", format_duration(alloc_result.alloc_latency.mean_ns));

    println!("\n✅ Extended examples complete!");
}
