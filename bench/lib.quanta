// POWER / ENERGY MEASUREMENT (RAPL)
// ═══════════════════════════════════════════════════════════════════════════════

/// Power domain for RAPL measurements
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum PowerDomain {
    Package,    // Entire CPU package
    Cores,      // CPU cores only
    Uncore,     // Integrated GPU, LLC, etc.
    DRAM,       // Memory
}

/// Power reading from RAPL
#[derive(Clone, Default)]
pub struct PowerReading {
    pub package_joules: f64,
    pub cores_joules: f64,
    pub uncore_joules: f64,
    pub dram_joules: f64,
    pub timestamp: u64,
}

impl PowerReading {
    pub fn total_joules(&self) -> f64 {
        self.package_joules + self.dram_joules
    }
}

/// Energy profile from a benchmark
#[derive(Clone)]
pub struct EnergyProfile {
    pub name: String,
    pub duration_secs: f64,
    pub total_energy_joules: f64,
    pub average_power_watts: f64,
    pub package_energy_joules: f64,
    pub cores_energy_joules: f64,
    pub dram_energy_joules: f64,
    pub energy_per_operation_microjoules: f64,
    pub operations: u64,
}

impl EnergyProfile {
    pub fn print(&self) {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  Energy Profile: {}", self.name);
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("  Duration:           {:>12.3} s", self.duration_secs);
        println!("  Total Energy:       {:>12.3} J", self.total_energy_joules);
        println!("  Average Power:      {:>12.3} W", self.average_power_watts);
        println!();
        println!("  Breakdown:");
        println!("    Package (CPU):    {:>12.3} J", self.package_energy_joules);
        println!("    Cores:            {:>12.3} J", self.cores_energy_joules);
        println!("    DRAM:             {:>12.3} J", self.dram_energy_joules);
        println!();
        println!("  Operations:         {:>12}", self.operations);
        println!("  Energy/Op:          {:>12.3} µJ", self.energy_per_operation_microjoules);
    }
}

/// RAPL power profiler
pub struct RaplProfiler {
    enabled: bool,
    start_reading: PowerReading,
    msr_fd: Option<i32>,
    energy_unit: f64,
}

impl RaplProfiler {
    pub fn new() -> Self {
        let mut profiler = RaplProfiler {
            enabled: false,
            start_reading: PowerReading::default(),
            msr_fd: None,
            energy_unit: 0.0,
        };
        profiler.init();
        profiler
    }

    fn init(&mut self) {
        // Check for RAPL availability
        #[cfg(target_os = "linux")]
        {
            // Try to open MSR device
            // In real implementation, would read /dev/cpu/0/msr
            self.energy_unit = 0.000015258789; // Default unit: 2^-16 J
        }
    }

    pub fn is_available() -> bool {
        #[cfg(target_os = "linux")]
        {
            // Check if MSR module is loaded and accessible
            std::path::Path::new("/dev/cpu/0/msr").exists()
        }
        #[cfg(not(target_os = "linux"))]
        {
            false
        }
    }

    pub fn start(&mut self) {
        self.enabled = true;
        self.start_reading = self.read_counters();
    }

    pub fn stop(&mut self) -> PowerReading {
        let end_reading = self.read_counters();
        self.enabled = false;

        PowerReading {
            package_joules: (end_reading.package_joules - self.start_reading.package_joules) * self.energy_unit,
            cores_joules: (end_reading.cores_joules - self.start_reading.cores_joules) * self.energy_unit,
            uncore_joules: (end_reading.uncore_joules - self.start_reading.uncore_joules) * self.energy_unit,
            dram_joules: (end_reading.dram_joules - self.start_reading.dram_joules) * self.energy_unit,
            timestamp: end_reading.timestamp - self.start_reading.timestamp,
        }
    }

    fn read_counters(&self) -> PowerReading {
        // Platform-specific MSR reading
        PowerReading::default()
    }

    /// Profile a benchmark for energy consumption
    pub fn profile<F>(&mut self, name: &str, mut f: F) -> EnergyProfile
    where
        F: FnMut() -> u64, // Returns operation count
    {
        self.start();
        let start = Instant::now();
        let operations = f();
        let duration = start.elapsed();
        let reading = self.stop();

        let duration_secs = duration.as_secs_f64();
        let total_energy = reading.total_joules();

        EnergyProfile {
            name: name.to_string(),
            duration_secs,
            total_energy_joules: total_energy,
            average_power_watts: total_energy / duration_secs,
            package_energy_joules: reading.package_joules,
            cores_energy_joules: reading.cores_joules,
            dram_energy_joules: reading.dram_joules,
            energy_per_operation_microjoules: if operations > 0 {
                (total_energy * 1_000_000.0) / operations as f64
            } else {
                0.0
            },
            operations,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DISK I/O BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

/// I/O benchmark configuration
#[derive(Clone)]
pub struct IoBenchConfig {
    /// File size for the test
    pub file_size: u64,
    /// Block size for I/O operations
    pub block_size: u64,
    /// Number of I/O operations
    pub num_operations: u64,
    /// Use direct I/O (bypass page cache)
    pub direct_io: bool,
    /// Use sync I/O (fsync after each write)
    pub sync_io: bool,
    /// Number of concurrent I/O workers
    pub io_depth: usize,
    /// Random vs sequential access
    pub access_pattern: IoAccessPattern,
    /// Read/Write ratio (0.0 = all writes, 1.0 = all reads)
    pub read_ratio: f64,
}

impl Default for IoBenchConfig {
    fn default() -> Self {
        IoBenchConfig {
            file_size: 1024 * 1024 * 1024, // 1 GB
            block_size: 4096,               // 4 KB
            num_operations: 10000,
            direct_io: true,
            sync_io: false,
            io_depth: 32,
            access_pattern: IoAccessPattern::Sequential,
            read_ratio: 0.5,
        }
    }
}

/// I/O access pattern
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum IoAccessPattern {
    Sequential,
    Random,
    Strided(u64), // Stride in bytes
}

/// I/O benchmark results
#[derive(Clone)]
pub struct IoResult {
    pub name: String,
    pub config: IoBenchConfig,
    pub duration_secs: f64,
    pub total_bytes: u64,
    pub total_operations: u64,
    pub throughput_mbps: f64,
    pub iops: f64,
    pub latency: LatencyReport,
    pub read_throughput_mbps: f64,
    pub write_throughput_mbps: f64,
}

impl IoResult {
    pub fn print(&self) {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  I/O Benchmark: {}", self.name);
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("  Configuration:");
        println!("    Block size:    {:>12} bytes", self.config.block_size);
        println!("    Operations:    {:>12}", self.total_operations);
        println!("    Access:        {:>12?}", self.config.access_pattern);
        println!();
        println!("  Results:");
        println!("    Duration:      {:>12.3} s", self.duration_secs);
        println!("    Throughput:    {:>12.2} MB/s", self.throughput_mbps);
        println!("    IOPS:          {:>12.2}", self.iops);
        println!("    Read:          {:>12.2} MB/s", self.read_throughput_mbps);
        println!("    Write:         {:>12.2} MB/s", self.write_throughput_mbps);
        println!();
        println!("  Latency:");
        println!("    Mean:          {:>12}", format_duration(self.latency.mean_ns));
        println!("    p99:           {:>12}", format_duration(self.latency.p99_ns as f64));
        println!("    Max:           {:>12}", format_duration(self.latency.max_ns as f64));
    }
}

/// I/O benchmark suite
pub struct IoBenchSuite {
    config: IoBenchConfig,
    test_file_path: String,
}

impl IoBenchSuite {
    pub fn new(config: IoBenchConfig, path: &str) -> Self {
        IoBenchSuite {
            config,
            test_file_path: path.to_string(),
        }
    }

    /// Run sequential read benchmark
    pub fn bench_sequential_read(&self) -> IoResult {
        let mut config = self.config.clone();
        config.access_pattern = IoAccessPattern::Sequential;
        config.read_ratio = 1.0;

        self.run_benchmark("Sequential Read", config)
    }

    /// Run sequential write benchmark
    pub fn bench_sequential_write(&self) -> IoResult {
        let mut config = self.config.clone();
        config.access_pattern = IoAccessPattern::Sequential;
        config.read_ratio = 0.0;

        self.run_benchmark("Sequential Write", config)
    }

    /// Run random read benchmark
    pub fn bench_random_read(&self) -> IoResult {
        let mut config = self.config.clone();
        config.access_pattern = IoAccessPattern::Random;
        config.read_ratio = 1.0;

        self.run_benchmark("Random Read", config)
    }

    /// Run random write benchmark
    pub fn bench_random_write(&self) -> IoResult {
        let mut config = self.config.clone();
        config.access_pattern = IoAccessPattern::Random;
        config.read_ratio = 0.0;

        self.run_benchmark("Random Write", config)
    }

    /// Run mixed random read/write benchmark
    pub fn bench_random_mixed(&self, read_ratio: f64) -> IoResult {
        let mut config = self.config.clone();
        config.access_pattern = IoAccessPattern::Random;
        config.read_ratio = read_ratio;

        self.run_benchmark(&format!("Random Mixed ({:.0}% read)", read_ratio * 100.0), config)
    }

    fn run_benchmark(&self, name: &str, config: IoBenchConfig) -> IoResult {
        println!("Running I/O benchmark: {}", name);

        let mut histogram = HdrHistogram::new(1, 1_000_000_000, 3);
        let start = Instant::now();

        let mut total_bytes = 0u64;
        let mut read_bytes = 0u64;
        let mut write_bytes = 0u64;

        // Simulate I/O operations
        for i in 0..config.num_operations {
            let op_start = Instant::now();

            // Simulate I/O (in real implementation, would do actual file I/O)
            let is_read = (i as f64 / config.num_operations as f64) < config.read_ratio;

            // Simulated latency
            std::thread::sleep(Duration::from_micros(10));

            let latency_ns = op_start.elapsed().as_nanos() as u64;
            histogram.record_value(latency_ns);

            if is_read {
                read_bytes += config.block_size;
            } else {
                write_bytes += config.block_size;
            }
            total_bytes += config.block_size;
        }

        let duration = start.elapsed();
        let duration_secs = duration.as_secs_f64();

        let latency = LatencyReport {
            name: name.to_string(),
            min_ns: histogram.min(),
            max_ns: histogram.max(),
            mean_ns: histogram.mean(),
            std_dev_ns: histogram.std_deviation(),
            p50_ns: histogram.value_at_percentile(50.0),
            p75_ns: histogram.value_at_percentile(75.0),
            p90_ns: histogram.value_at_percentile(90.0),
            p95_ns: histogram.value_at_percentile(95.0),
            p99_ns: histogram.value_at_percentile(99.0),
            p999_ns: histogram.value_at_percentile(99.9),
            p9999_ns: histogram.value_at_percentile(99.99),
            count: histogram.count(),
            throughput: config.num_operations as f64 / duration_secs,
        };

        IoResult {
            name: name.to_string(),
            config,
            duration_secs,
            total_bytes,
            total_operations: histogram.count(),
            throughput_mbps: (total_bytes as f64 / 1_000_000.0) / duration_secs,
            iops: histogram.count() as f64 / duration_secs,
            latency,
            read_throughput_mbps: (read_bytes as f64 / 1_000_000.0) / duration_secs,
            write_throughput_mbps: (write_bytes as f64 / 1_000_000.0) / duration_secs,
        }
    }

    /// Run full I/O benchmark suite
    pub fn run_all(&self) -> Vec<IoResult> {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  I/O Benchmark Suite                                          ║");
        println!("╚═══════════════════════════════════════════════════════════════╝\n");

        let mut results = Vec::new();

        results.push(self.bench_sequential_read());
        results.push(self.bench_sequential_write());
        results.push(self.bench_random_read());
        results.push(self.bench_random_write());
        results.push(self.bench_random_mixed(0.5));
        results.push(self.bench_random_mixed(0.7));

        results
    }
}

