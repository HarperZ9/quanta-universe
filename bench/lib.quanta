// FLAMEGRAPH / CALL TREE PROFILING
// ═══════════════════════════════════════════════════════════════════════════════

/// Stack frame for profiling
#[derive(Clone)]
pub struct StackFrame {
    pub function_name: String,
    pub module: String,
    pub file: Option<String>,
    pub line: Option<u32>,
    pub self_time_ns: u64,
    pub total_time_ns: u64,
}

/// Call tree node for hierarchical profiling
#[derive(Clone)]
pub struct CallTreeNode {
    pub frame: StackFrame,
    pub children: Vec<CallTreeNode>,
    pub call_count: u64,
}

impl CallTreeNode {
    pub fn new(frame: StackFrame) -> Self {
        CallTreeNode {
            frame,
            children: Vec::new(),
            call_count: 1,
        }
    }

    pub fn add_child(&mut self, child: CallTreeNode) {
        // Check if child with same name exists
        for existing in &mut self.children {
            if existing.frame.function_name == child.frame.function_name {
                existing.frame.total_time_ns += child.frame.total_time_ns;
                existing.frame.self_time_ns += child.frame.self_time_ns;
                existing.call_count += 1;
                return;
            }
        }
        self.children.push(child);
    }

    /// Calculate percentage of total time
    pub fn time_percent(&self, total_ns: u64) -> f64 {
        self.frame.total_time_ns as f64 / total_ns as f64 * 100.0
    }
}

/// Flamegraph generator
pub struct FlamegraphBuilder {
    stacks: Vec<(Vec<String>, u64)>,  // (stack, count)
    title: String,
}

impl FlamegraphBuilder {
    pub fn new(title: &str) -> Self {
        FlamegraphBuilder {
            stacks: Vec::new(),
            title: title.to_string(),
        }
    }

    pub fn add_stack(&mut self, stack: Vec<String>, count: u64) {
        self.stacks.push((stack, count));
    }

    /// Generate folded stack format for flamegraph tools
    pub fn generate_folded(&self) -> String {
        let mut output = String::new();
        for (stack, count) in &self.stacks {
            let stack_str = stack.join(";");
            output.push_str(&format!("{} {}\n", stack_str, count));
        }
        output
    }

    /// Generate SVG flamegraph (simplified)
    pub fn generate_svg(&self, width: u32, height: u32) -> String {
        let mut svg = format!(
            r#"<svg xmlns="http://www.w3.org/2000/svg" width="{}" height="{}">"#,
            width, height
        );
        svg.push_str(&format!(
            r#"<text x="50%" y="30" text-anchor="middle" font-size="20">{}</text>"#,
            self.title
        ));

        // In real implementation, would render flame stacks
        // This is a simplified placeholder

        svg.push_str("</svg>");
        svg
    }
}

