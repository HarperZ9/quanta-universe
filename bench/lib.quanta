// BENCHMARK SCHEDULER / ADAPTIVE SAMPLING
// ═══════════════════════════════════════════════════════════════════════════════

/// Benchmark execution order
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum BenchOrder {
    /// Run in definition order
    Sequential,
    /// Randomize order to detect ordering effects
    Random,
    /// Interleave benchmarks to reduce temporal variance
    Interleaved,
}

/// Adaptive sampling configuration
#[derive(Clone)]
pub struct AdaptiveSamplingConfig {
    /// Minimum samples
    pub min_samples: usize,
    /// Maximum samples
    pub max_samples: usize,
    /// Target coefficient of variation (0.01 = 1%)
    pub target_cv: f64,
    /// Confidence level for stopping
    pub confidence_level: f64,
}

impl Default for AdaptiveSamplingConfig {
    fn default() -> Self {
        AdaptiveSamplingConfig {
            min_samples: 10,
            max_samples: 1000,
            target_cv: 0.01,
            confidence_level: 0.95,
        }
    }
}

/// Adaptive sampler that stops when statistically significant
pub struct AdaptiveSampler {
    config: AdaptiveSamplingConfig,
    samples: Vec<f64>,
}

impl AdaptiveSampler {
    pub fn new(config: AdaptiveSamplingConfig) -> Self {
        AdaptiveSampler {
            config,
            samples: Vec::new(),
        }
    }

    /// Add a sample and check if we should stop
    pub fn add_sample(&mut self, value: f64) -> bool {
        self.samples.push(value);

        // Always continue until min samples
        if self.samples.len() < self.config.min_samples {
            return false; // Continue sampling
        }

        // Stop if max samples reached
        if self.samples.len() >= self.config.max_samples {
            return true; // Stop
        }

        // Check coefficient of variation
        let cv = self.coefficient_of_variation();
        cv <= self.config.target_cv
    }

    fn coefficient_of_variation(&self) -> f64 {
        let n = self.samples.len() as f64;
        let mean = self.samples.iter().sum::<f64>() / n;
        let variance = self.samples.iter()
            .map(|x| (x - mean).powi(2))
            .sum::<f64>() / (n - 1.0);
        let std_dev = variance.sqrt();

        std_dev / mean
    }

    /// Get current statistics
    pub fn statistics(&self) -> Statistics {
        let mut measurement = Measurement::new();
        for &s in &self.samples {
            measurement.samples.push(s);
        }
        Statistics::from_measurement(&measurement)
    }

    /// Reset sampler
    pub fn reset(&mut self) {
        self.samples.clear();
    }
}

/// Benchmark scheduler
pub struct BenchScheduler {
    order: BenchOrder,
    benchmarks: Vec<ScheduledBench>,
    rng_seed: u64,
}

struct ScheduledBench {
    name: String,
    // Would store closure in real implementation
}

impl BenchScheduler {
    pub fn new(order: BenchOrder) -> Self {
        BenchScheduler {
            order,
            benchmarks: Vec::new(),
            rng_seed: 42,
        }
    }

    /// Schedule benchmarks according to order
    pub fn schedule(&mut self) -> Vec<usize> {
        let n = self.benchmarks.len();
        let mut order: Vec<usize> = (0..n).collect();

        match self.order {
            BenchOrder::Sequential => {
                // Keep original order
            }
            BenchOrder::Random => {
                // Fisher-Yates shuffle
                for i in (1..n).rev() {
                    let j = self.random() % (i + 1);
                    order.swap(i, j);
                }
            }
            BenchOrder::Interleaved => {
                // Interleave benchmarks for multiple rounds
                let rounds = 3;
                let mut interleaved = Vec::new();
                for _ in 0..rounds {
                    for i in 0..n {
                        interleaved.push(i);
                    }
                }
                order = interleaved;
            }
        }

        order
    }

    fn random(&mut self) -> usize {
        // Simple LCG PRNG
        self.rng_seed = self.rng_seed.wrapping_mul(6364136223846793005)
            .wrapping_add(1442695040888963407);
        (self.rng_seed >> 33) as usize
    }
}

