/// JSON report generator for machine-readable output
pub struct JsonReportGenerator {
    benchmarks: Vec<BenchResult>,
    metadata: ReportMetadata,
}

#[derive(Clone)]
pub struct ReportMetadata {
    pub timestamp: u64,
    pub machine_info: MachineInfo,
    pub run_config: BenchConfig,
}

#[derive(Clone)]
pub struct MachineInfo {
    pub hostname: String,
    pub os: String,
    pub arch: String,
    pub cpu_model: String,
    pub cpu_count: usize,
    pub memory_gb: f64,
}

impl MachineInfo {
    pub fn detect() -> Self {
        MachineInfo {
            hostname: "unknown".to_string(),
            os: std::env::consts::OS.to_string(),
            arch: std::env::consts::ARCH.to_string(),
            cpu_model: "Unknown".to_string(),
            cpu_count: num_cpus(),
            memory_gb: 0.0,
        }
    }
}

impl JsonReportGenerator {
    pub fn new() -> Self {
        JsonReportGenerator {
            benchmarks: Vec::new(),
            metadata: ReportMetadata {
                timestamp: std::time::SystemTime::now()
                    .duration_since(std::time::UNIX_EPOCH)
                    .unwrap()
                    .as_secs(),
                machine_info: MachineInfo::detect(),
                run_config: BenchConfig::default(),
            },
        }
    }

    pub fn add_result(&mut self, result: BenchResult) {
        self.benchmarks.push(result);
    }

    pub fn add_results(&mut self, results: Vec<BenchResult>) {
        self.benchmarks.extend(results);
    }

    /// Generate JSON report
    pub fn generate(&self) -> String {
        let mut json = String::from("{\n");

        // Metadata
        json.push_str("  \"metadata\": {\n");
        json.push_str(&format!("    \"timestamp\": {},\n", self.metadata.timestamp));
        json.push_str(&format!("    \"hostname\": \"{}\",\n", self.metadata.machine_info.hostname));
        json.push_str(&format!("    \"os\": \"{}\",\n", self.metadata.machine_info.os));
        json.push_str(&format!("    \"arch\": \"{}\",\n", self.metadata.machine_info.arch));
        json.push_str(&format!("    \"cpu_model\": \"{}\",\n", self.metadata.machine_info.cpu_model));
        json.push_str(&format!("    \"cpu_count\": {},\n", self.metadata.machine_info.cpu_count));
        json.push_str(&format!("    \"memory_gb\": {:.1}\n", self.metadata.machine_info.memory_gb));
        json.push_str("  },\n");

        // Benchmarks
        json.push_str("  \"benchmarks\": [\n");

        for (i, bench) in self.benchmarks.iter().enumerate() {
            json.push_str("    {\n");
            json.push_str(&format!("      \"name\": \"{}\",\n", bench.name));
            if let Some(ref group) = bench.group {
                json.push_str(&format!("      \"group\": \"{}\",\n", group));
            }
            json.push_str("      \"stats\": {\n");
            json.push_str(&format!("        \"mean_ns\": {:.2},\n", bench.stats.mean));
            json.push_str(&format!("        \"median_ns\": {:.2},\n", bench.stats.median));
            json.push_str(&format!("        \"std_dev_ns\": {:.2},\n", bench.stats.std_dev));
            json.push_str(&format!("        \"min_ns\": {:.2},\n", bench.stats.min));
            json.push_str(&format!("        \"max_ns\": {:.2},\n", bench.stats.max));
            json.push_str(&format!("        \"percentile_5\": {:.2},\n", bench.stats.percentile_5));
            json.push_str(&format!("        \"percentile_95\": {:.2},\n", bench.stats.percentile_95));
            json.push_str(&format!("        \"iterations\": {},\n", bench.stats.iterations));
            json.push_str(&format!("        \"sample_count\": {}\n", bench.stats.sample_count));
            json.push_str("      }");

            if let Some(ref throughput) = bench.throughput {
                json.push_str(",\n      \"throughput\": {\n");
                json.push_str(&format!("        \"value\": {:.2},\n", throughput.value));
                json.push_str(&format!("        \"unit\": \"{}\"\n", throughput.unit.as_str()));
                json.push_str("      }");
            }

            if let Some(ref comparison) = bench.comparison {
                json.push_str(",\n      \"comparison\": {\n");
                json.push_str(&format!("        \"baseline_mean\": {:.2},\n", comparison.baseline_mean));
                json.push_str(&format!("        \"change_percent\": {:.2},\n", comparison.change_percent));
                json.push_str(&format!("        \"significant\": {},\n", comparison.significant));
                json.push_str(&format!("        \"faster\": {}\n", comparison.faster));
                json.push_str("      }");
            }

            json.push_str("\n    }");
            if i < self.benchmarks.len() - 1 {
                json.push_str(",");
            }
            json.push_str("\n");
        }

        json.push_str("  ]\n");
        json.push_str("}\n");

        json
    }

    /// Save report to file
    pub fn save(&self, path: &str) -> Result<(), String> {
        let json = self.generate();
        write_string(path, &json)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK PRESETS
// ═══════════════════════════════════════════════════════════════════════════════

/// Predefined benchmark configurations for common scenarios
pub mod presets {
    use super::*;

    /// Quick sanity check benchmarks
    pub fn quick() -> BenchConfig {
        BenchConfig {
            min_iterations: 10,
            max_duration: Duration::from_millis(500),
            warmup_iterations: 3,
            confidence_level: 0.90,
            ..Default::default()
        }
    }

    /// Standard development benchmarks
    pub fn standard() -> BenchConfig {
        BenchConfig::default()
    }

    /// Thorough CI benchmarks
    pub fn ci() -> BenchConfig {
        BenchConfig {
            min_iterations: 200,
            max_duration: Duration::from_secs(10),
            warmup_iterations: 50,
            confidence_level: 0.95,
            compare_baseline: true,
            ..Default::default()
        }
    }

    /// Detailed performance analysis
    pub fn detailed() -> BenchConfig {
        BenchConfig {
            min_iterations: 500,
            max_duration: Duration::from_secs(30),
            warmup_iterations: 100,
            confidence_level: 0.99,
            compare_baseline: true,
            ..Default::default()
        }
    }

    /// Production profiling (minimal overhead)
    pub fn production() -> BenchConfig {
        BenchConfig {
            min_iterations: 50,
            max_duration: Duration::from_secs(1),
            warmup_iterations: 5,
            confidence_level: 0.90,
            ..Default::default()
        }
    }
}

