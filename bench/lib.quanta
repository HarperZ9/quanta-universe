/// Network benchmark configuration
#[derive(Clone)]
pub struct NetworkBenchConfig {
    /// Target host/IP
    pub target: String,
    /// Target port
    pub port: u16,
    /// Number of requests
    pub num_requests: u64,
    /// Request size in bytes
    pub request_size: usize,
    /// Response size in bytes (expected)
    pub response_size: usize,
    /// Connection pooling
    pub connection_pool_size: usize,
    /// Concurrent connections
    pub concurrency: usize,
    /// Request timeout
    pub timeout: Duration,
    /// Protocol
    pub protocol: NetworkProtocol,
}

#[derive(Clone, Copy, Debug, PartialEq)]
pub enum NetworkProtocol {
    TCP,
    UDP,
    HTTP,
    HTTPS,
    gRPC,
}

impl Default for NetworkBenchConfig {
    fn default() -> Self {
        NetworkBenchConfig {
            target: "localhost".to_string(),
            port: 8080,
            num_requests: 10000,
            request_size: 64,
            response_size: 64,
            connection_pool_size: 10,
            concurrency: 10,
            timeout: Duration::from_secs(30),
            protocol: NetworkProtocol::TCP,
        }
    }
}

/// Network benchmark results
#[derive(Clone)]
pub struct NetworkResult {
    pub name: String,
    pub config: NetworkBenchConfig,
    pub duration_secs: f64,
    pub successful_requests: u64,
    pub failed_requests: u64,
    pub requests_per_second: f64,
    pub latency: LatencyReport,
    pub bytes_sent: u64,
    pub bytes_received: u64,
    pub throughput_mbps: f64,
    pub connection_errors: u64,
    pub timeout_errors: u64,
}

impl NetworkResult {
    pub fn print(&self) {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  Network Benchmark: {}", self.name);
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();
        println!("  Target:          {}:{} ({:?})",
            self.config.target, self.config.port, self.config.protocol);
        println!("  Concurrency:     {}", self.config.concurrency);
        println!();
        println!("  Requests:");
        println!("    Total:         {:>12}", self.successful_requests + self.failed_requests);
        println!("    Successful:    {:>12}", self.successful_requests);
        println!("    Failed:        {:>12}", self.failed_requests);
        println!("    RPS:           {:>12.2}", self.requests_per_second);
        println!();
        println!("  Latency:");
        println!("    Mean:          {:>12}", format_duration(self.latency.mean_ns));
        println!("    p50:           {:>12}", format_duration(self.latency.p50_ns as f64));
        println!("    p99:           {:>12}", format_duration(self.latency.p99_ns as f64));
        println!("    Max:           {:>12}", format_duration(self.latency.max_ns as f64));
        println!();
        println!("  Throughput:      {:>12.2} MB/s", self.throughput_mbps);
    }
}

/// Network benchmark suite
pub struct NetworkBenchSuite {
    config: NetworkBenchConfig,
}

impl NetworkBenchSuite {
    pub fn new(config: NetworkBenchConfig) -> Self {
        NetworkBenchSuite { config }
    }

    /// Run ping benchmark (latency only)
    pub fn bench_ping(&self) -> NetworkResult {
        self.run_benchmark("Ping", |_| {
            // Simulated ping
            std::thread::sleep(Duration::from_micros(100));
            Ok(())
        })
    }

    /// Run throughput benchmark
    pub fn bench_throughput(&self) -> NetworkResult {
        let mut config = self.config.clone();
        config.request_size = 65536;  // 64 KB
        config.response_size = 65536;

        self.run_benchmark("Throughput", |_| {
            // Simulated large transfer
            std::thread::sleep(Duration::from_micros(500));
            Ok(())
        })
    }

    /// Run request/response benchmark
    pub fn bench_request_response(&self) -> NetworkResult {
        self.run_benchmark("Request/Response", |_| {
            // Simulated request/response
            std::thread::sleep(Duration::from_micros(200));
            Ok(())
        })
    }

    fn run_benchmark<F>(&self, name: &str, mut f: F) -> NetworkResult
    where
        F: FnMut(usize) -> Result<(), String>,
    {
        println!("Running network benchmark: {}", name);

        let mut histogram = HdrHistogram::new(1, 10_000_000_000, 3);
        let start = Instant::now();

        let mut successful = 0u64;
        let mut failed = 0u64;
        let mut bytes_sent = 0u64;
        let mut bytes_received = 0u64;

        for i in 0..self.config.num_requests {
            let op_start = Instant::now();

            match f(i as usize) {
                Ok(()) => {
                    successful += 1;
                    bytes_sent += self.config.request_size as u64;
                    bytes_received += self.config.response_size as u64;
                }
                Err(_) => {
                    failed += 1;
                }
            }

            let latency_ns = op_start.elapsed().as_nanos() as u64;
            histogram.record_value(latency_ns);
        }

        let duration = start.elapsed();
        let duration_secs = duration.as_secs_f64();

        let total_bytes = bytes_sent + bytes_received;

        let latency = LatencyReport {
            name: name.to_string(),
            min_ns: histogram.min(),
            max_ns: histogram.max(),
            mean_ns: histogram.mean(),
            std_dev_ns: histogram.std_deviation(),
            p50_ns: histogram.value_at_percentile(50.0),
            p75_ns: histogram.value_at_percentile(75.0),
            p90_ns: histogram.value_at_percentile(90.0),
            p95_ns: histogram.value_at_percentile(95.0),
            p99_ns: histogram.value_at_percentile(99.0),
            p999_ns: histogram.value_at_percentile(99.9),
            p9999_ns: histogram.value_at_percentile(99.99),
            count: histogram.count(),
            throughput: successful as f64 / duration_secs,
        };

        NetworkResult {
            name: name.to_string(),
            config: self.config.clone(),
            duration_secs,
            successful_requests: successful,
            failed_requests: failed,
            requests_per_second: successful as f64 / duration_secs,
            latency,
            bytes_sent,
            bytes_received,
            throughput_mbps: (total_bytes as f64 / 1_000_000.0) / duration_secs,
            connection_errors: 0,
            timeout_errors: 0,
        }
    }
}

