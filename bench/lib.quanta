/// Configuration for concurrent benchmarks
#[derive(Clone)]
pub struct ConcurrentBenchConfig {
    /// Number of threads to use
    pub thread_count: usize,
    /// Duration to run the benchmark
    pub duration: Duration,
    /// Warmup duration
    pub warmup_duration: Duration,
    /// Whether to pin threads to CPUs
    pub pin_threads: bool,
    /// CPU affinity mask (if pinning)
    pub cpu_affinity: Option<Vec<usize>>,
    /// Enable per-thread statistics
    pub per_thread_stats: bool,
}

impl Default for ConcurrentBenchConfig {
    fn default() -> Self {
        ConcurrentBenchConfig {
            thread_count: num_cpus(),
            duration: Duration::from_secs(10),
            warmup_duration: Duration::from_secs(2),
            pin_threads: false,
            cpu_affinity: None,
            per_thread_stats: true,
        }
    }
}

/// Get number of CPU cores
fn num_cpus() -> usize {
    #[cfg(target_os = "linux")]
    {
        // Read from /proc/cpuinfo or sysconf
        4 // Placeholder
    }
    #[cfg(not(target_os = "linux"))]
    {
        4 // Default fallback
    }
}

/// Results from a concurrent benchmark
#[derive(Clone)]
pub struct ConcurrentResult {
    pub name: String,
    pub config: ConcurrentBenchConfig,
    pub total_operations: u64,
    pub operations_per_second: f64,
    pub latency: LatencyReport,
    pub per_thread_results: Vec<ThreadResult>,
    pub contention_metrics: ContentionMetrics,
}

/// Per-thread benchmark results
#[derive(Clone)]
pub struct ThreadResult {
    pub thread_id: usize,
    pub operations: u64,
    pub ops_per_second: f64,
    pub mean_latency_ns: f64,
    pub p99_latency_ns: u64,
}

/// Contention analysis metrics
#[derive(Clone, Default)]
pub struct ContentionMetrics {
    pub lock_acquisitions: u64,
    pub lock_contentions: u64,
    pub contention_rate: f64,
    pub avg_wait_time_ns: f64,
    pub max_wait_time_ns: u64,
}

/// Concurrent benchmark runner
pub struct ConcurrentBencher {
    config: ConcurrentBenchConfig,
    results: Vec<ConcurrentResult>,
}

impl ConcurrentBencher {
    pub fn new() -> Self {
        ConcurrentBencher {
            config: ConcurrentBenchConfig::default(),
            results: Vec::new(),
        }
    }

    pub fn with_config(config: ConcurrentBenchConfig) -> Self {
        ConcurrentBencher {
            config,
            results: Vec::new(),
        }
    }

    /// Run a concurrent benchmark
    pub fn bench_concurrent<F>(&mut self, name: &str, f: F) -> ConcurrentResult
    where
        F: Fn(usize) + Send + Sync + Clone,
    {
        println!("Concurrent benchmark: {} ({} threads)", name, self.config.thread_count);

        // Thread-local result storage
        let mut thread_results = Vec::new();
        let mut total_ops = 0u64;
        let mut combined_histogram = HdrHistogram::new(1, 1_000_000_000, 3);

        // Simulate multi-threaded execution
        // In real implementation, this would use actual threads
        for thread_id in 0..self.config.thread_count {
            let start = Instant::now();
            let mut ops = 0u64;
            let mut thread_histogram = HdrHistogram::new(1, 1_000_000_000, 3);

            // Warmup
            while start.elapsed() < self.config.warmup_duration {
                let op_start = Instant::now();
                f(thread_id);
                let latency = op_start.elapsed().as_nanos() as u64;
                thread_histogram.record_value(latency);
            }
            thread_histogram.reset();

            // Measurement
            let measure_start = Instant::now();
            while measure_start.elapsed() < self.config.duration {
                let op_start = Instant::now();
                f(thread_id);
                let latency = op_start.elapsed().as_nanos() as u64;
                thread_histogram.record_value(latency);
                ops += 1;
            }

            let elapsed = measure_start.elapsed().as_secs_f64();
            let ops_per_sec = ops as f64 / elapsed;

            thread_results.push(ThreadResult {
                thread_id,
                operations: ops,
                ops_per_second: ops_per_sec,
                mean_latency_ns: thread_histogram.mean(),
                p99_latency_ns: thread_histogram.value_at_percentile(99.0),
            });

            total_ops += ops;
            combined_histogram.add(&thread_histogram);
        }

        let total_duration = self.config.duration.as_secs_f64();
        let total_ops_per_sec = total_ops as f64 / total_duration;

        let latency = LatencyReport {
            name: name.to_string(),
            min_ns: combined_histogram.min(),
            max_ns: combined_histogram.max(),
            mean_ns: combined_histogram.mean(),
            std_dev_ns: combined_histogram.std_deviation(),
            p50_ns: combined_histogram.value_at_percentile(50.0),
            p75_ns: combined_histogram.value_at_percentile(75.0),
            p90_ns: combined_histogram.value_at_percentile(90.0),
            p95_ns: combined_histogram.value_at_percentile(95.0),
            p99_ns: combined_histogram.value_at_percentile(99.0),
            p999_ns: combined_histogram.value_at_percentile(99.9),
            p9999_ns: combined_histogram.value_at_percentile(99.99),
            count: combined_histogram.count(),
            throughput: total_ops_per_sec,
        };

        let result = ConcurrentResult {
            name: name.to_string(),
            config: self.config.clone(),
            total_operations: total_ops,
            operations_per_second: total_ops_per_sec,
            latency,
            per_thread_results: thread_results,
            contention_metrics: ContentionMetrics::default(),
        };

        self.results.push(result.clone());
        result
    }

    /// Scalability benchmark (vary thread count)
    pub fn bench_scalability<F>(&mut self, name: &str, max_threads: usize, f: F) -> ScalabilityResult
    where
        F: Fn(usize) + Send + Sync + Clone,
    {
        println!("\nScalability benchmark: {}", name);
        println!("{}", "─".repeat(60));

        let mut data_points = Vec::new();

        for thread_count in [1, 2, 4, 8, 16, 32].iter().filter(|&&t| t <= max_threads) {
            self.config.thread_count = *thread_count;
            let result = self.bench_concurrent(&format!("{}_{}t", name, thread_count), f.clone());

            data_points.push(ScalabilityPoint {
                thread_count: *thread_count,
                throughput: result.operations_per_second,
                latency_p99_ns: result.latency.p99_ns,
            });

            println!("  {:2} threads: {:>12.2} ops/sec, p99: {}",
                thread_count,
                result.operations_per_second,
                format_duration(result.latency.p99_ns as f64));
        }

        // Calculate scaling efficiency
        let baseline = data_points[0].throughput;
        let efficiency: Vec<f64> = data_points.iter()
            .map(|p| (p.throughput / baseline) / p.thread_count as f64 * 100.0)
            .collect();

        ScalabilityResult {
            name: name.to_string(),
            data_points,
            scaling_efficiency: efficiency,
        }
    }

    /// Print summary of all concurrent benchmarks
    pub fn summary(&self) {
        println!("\n╔═══════════════════════════════════════════════════════════════╗");
        println!("║  Concurrent Benchmark Summary                                 ║");
        println!("╚═══════════════════════════════════════════════════════════════╝\n");

        for result in &self.results {
            println!("{}: {} threads", result.name, result.config.thread_count);
            println!("  Total ops:     {:>15}", result.total_operations);
            println!("  Throughput:    {:>15.2} ops/sec", result.operations_per_second);
            println!("  Mean latency:  {:>15}", format_duration(result.latency.mean_ns));
            println!("  p99 latency:   {:>15}", format_duration(result.latency.p99_ns as f64));
            println!();
        }
    }
}

/// Scalability data point
#[derive(Clone)]
pub struct ScalabilityPoint {
    pub thread_count: usize,
    pub throughput: f64,
    pub latency_p99_ns: u64,
}

/// Scalability benchmark result
#[derive(Clone)]
pub struct ScalabilityResult {
    pub name: String,
    pub data_points: Vec<ScalabilityPoint>,
    pub scaling_efficiency: Vec<f64>,
}

impl ScalabilityResult {
    pub fn print_report(&self) {
        println!("\nScalability Report: {}", self.name);
        println!("{}", "─".repeat(60));
        println!("{:>10} {:>15} {:>15} {:>12}", "Threads", "Throughput", "p99 Latency", "Efficiency");

        for (i, point) in self.data_points.iter().enumerate() {
            println!("{:>10} {:>15.2} {:>15} {:>11.1}%",
                point.thread_count,
                point.throughput,
                format_duration(point.latency_p99_ns as f64),
                self.scaling_efficiency[i]);
        }
    }
}

