// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Clone)]
pub struct BenchConfig {
    /// Minimum number of iterations
    pub min_iterations: u64,
    /// Maximum duration for a benchmark
    pub max_duration: Duration,
    /// Warmup iterations
    pub warmup_iterations: u64,
    /// Target confidence level (0.95 = 95%)
    pub confidence_level: f64,
    /// Output format
    pub output_format: OutputFormat,
    /// Output file (None for stdout)
    pub output_file: Option<String>,
    /// Enable comparison with baseline
    pub compare_baseline: bool,
    /// Baseline file path
    pub baseline_path: Option<String>,
}

impl Default for BenchConfig {
    fn default() -> Self {
        BenchConfig {
            min_iterations: 100,
            max_duration: Duration::from_secs(5),
            warmup_iterations: 10,
            confidence_level: 0.95,
            output_format: OutputFormat::Pretty,
            output_file: None,
            compare_baseline: false,
            baseline_path: None,
        }
    }
}

#[derive(Clone, Copy)]
pub enum OutputFormat {
    Pretty,
    Json,
    Csv,
    Markdown,
}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK MEASUREMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Raw measurement data from a benchmark run
#[derive(Clone)]
pub struct Measurement {
    pub samples: Vec<f64>,
    pub iterations_per_sample: u64,
}

impl Measurement {
    pub fn new() -> Self {
        Measurement {
            samples: Vec::new(),
            iterations_per_sample: 1,
        }
    }

    pub fn add_sample(&mut self, duration_ns: f64) {
        self.samples.push(duration_ns / self.iterations_per_sample as f64);
    }

    pub fn sample_count(&self) -> usize {
        self.samples.len()
    }
}

/// Statistical analysis of measurements
#[derive(Clone)]
pub struct Statistics {
    pub mean: f64,
    pub median: f64,
    pub std_dev: f64,
    pub min: f64,
    pub max: f64,
    pub percentile_5: f64,
    pub percentile_95: f64,
    pub iterations: u64,
    pub sample_count: usize,
}

impl Statistics {
    pub fn from_measurement(measurement: &Measurement) -> Self {
        let mut samples = measurement.samples.clone();
        samples.sort_by(|a, b| a.partial_cmp(b).unwrap());

        let n = samples.len();
        let sum: f64 = samples.iter().sum();
        let mean = sum / n as f64;

        let variance: f64 = samples.iter()
            .map(|x| (x - mean).powi(2))
            .sum::<f64>() / (n - 1) as f64;
        let std_dev = variance.sqrt();

        let median = if n % 2 == 0 {
            (samples[n / 2 - 1] + samples[n / 2]) / 2.0
        } else {
            samples[n / 2]
        };

        let percentile = |p: f64| -> f64 {
            let idx = ((n as f64 - 1.0) * p) as usize;
            samples[idx]
        };

        Statistics {
            mean,
            median,
            std_dev,
            min: samples[0],
            max: samples[n - 1],
            percentile_5: percentile(0.05),
            percentile_95: percentile(0.95),
            iterations: measurement.iterations_per_sample * n as u64,
            sample_count: n,
        }
    }

    pub fn confidence_interval(&self, level: f64) -> (f64, f64) {
        // Z-score for confidence level
        let z = match level {
            l if l >= 0.99 => 2.576,
            l if l >= 0.95 => 1.96,
            l if l >= 0.90 => 1.645,
            _ => 1.0,
        };

        let margin = z * self.std_dev / (self.sample_count as f64).sqrt();
        (self.mean - margin, self.mean + margin)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK RESULTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Result of a single benchmark
#[derive(Clone)]
pub struct BenchResult {
    pub name: String,
    pub group: Option<String>,
    pub stats: Statistics,
    pub throughput: Option<Throughput>,
    pub comparison: Option<Comparison>,
}

#[derive(Clone)]
pub struct Throughput {
    pub value: f64,
    pub unit: ThroughputUnit,
}

#[derive(Clone, Copy)]
pub enum ThroughputUnit {
    Bytes,
    Elements,
    Operations,
}

impl ThroughputUnit {
    pub fn as_str(&self) -> &str {
        match self {
            ThroughputUnit::Bytes => "B/s",
            ThroughputUnit::Elements => "elem/s",
            ThroughputUnit::Operations => "ops/s",
        }
    }
}

#[derive(Clone)]
pub struct Comparison {
    pub baseline_mean: f64,
    pub change_percent: f64,
    pub significant: bool,
    pub faster: bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// BENCHMARK RUNNER
// ═══════════════════════════════════════════════════════════════════════════════

/// Main benchmark runner
pub struct Bencher {
    config: BenchConfig,
    results: Vec<BenchResult>,
    current_group: Option<String>,
    baseline: HashMap<String, f64>,
}

impl Bencher {
    pub fn new() -> Self {
        Bencher::with_config(BenchConfig::default())
    }

    pub fn with_config(config: BenchConfig) -> Self {
        let baseline = if config.compare_baseline {
            if let Some(ref path) = config.baseline_path {
                load_baseline(path).unwrap_or_default()
            } else {
                HashMap::new()
            }
        } else {
            HashMap::new()
        };

        Bencher {
            config,
            results: Vec::new(),
            current_group: None,
            baseline,
        }
    }

    /// Start a benchmark group
    pub fn group(&mut self, name: &str) {
        self.current_group = Some(name.to_string());
    }

    /// End the current group
    pub fn group_end(&mut self) {
        self.current_group = None;
    }

    /// Run a benchmark
    pub fn bench<F>(&mut self, name: &str, mut f: F)
    where
        F: FnMut(&mut Iteration),
    {
        print!("Benchmarking {}... ", name);

        // Warmup
        for _ in 0..self.config.warmup_iterations {
            let mut iter = Iteration::new();
            f(&mut iter);
        }

        // Measure
        let mut measurement = Measurement::new();
        let start = Instant::now();
        let mut total_iterations = 0u64;

        while start.elapsed() < self.config.max_duration &&
              measurement.sample_count() < self.config.min_iterations as usize {
            let sample_start = Instant::now();

            let mut iter = Iteration::new();
            f(&mut iter);

            let elapsed = sample_start.elapsed().as_nanos() as f64;
            measurement.add_sample(elapsed);
            total_iterations += 1;
        }

        measurement.iterations_per_sample = 1;

        // Analyze
        let stats = Statistics::from_measurement(&measurement);

        // Compare with baseline
        let comparison = if self.config.compare_baseline {
            self.baseline.get(name).map(|&baseline_mean| {
                let change_percent = (stats.mean - baseline_mean) / baseline_mean * 100.0;
                let significant = change_percent.abs() > 5.0; // 5% threshold
                let faster = change_percent < 0.0;
                Comparison {
                    baseline_mean,
                    change_percent,
                    significant,
                    faster,
                }
            })
        } else {
            None
        };

        let result = BenchResult {
            name: name.to_string(),
            group: self.current_group.clone(),
            stats: stats.clone(),
            throughput: None,
            comparison,
        };

        self.results.push(result);

        // Print result
        println!("{}", format_duration(stats.mean));
        if let Some(ref comp) = comparison {
            if comp.significant {
                let symbol = if comp.faster { "▼" } else { "▲" };
                let color = if comp.faster { "\x1b[32m" } else { "\x1b[31m" };
                println!("  {} {}{:.1}%\x1b[0m vs baseline", symbol, color, comp.change_percent.abs());
            }
        }
    }

    /// Run a benchmark with throughput measurement
    pub fn bench_throughput<F>(&mut self, name: &str, size: u64, unit: ThroughputUnit, mut f: F)
    where
        F: FnMut(&mut Iteration),
    {
        self.bench(name, |iter| f(iter));

        // Update last result with throughput
        if let Some(result) = self.results.last_mut() {
            let ops_per_sec = 1_000_000_000.0 / result.stats.mean;
            result.throughput = Some(Throughput {
                value: ops_per_sec * size as f64,
                unit,
            });
        }
    }

    /// Print summary of all benchmarks
    pub fn summary(&self) {
        println!();
        println!("╔═══════════════════════════════════════════════════════════════╗");
        println!("║  Benchmark Summary                                            ║");
        println!("╚═══════════════════════════════════════════════════════════════╝");
        println!();

        match self.config.output_format {
            OutputFormat::Pretty => self.print_pretty(),
            OutputFormat::Markdown => self.print_markdown(),
            OutputFormat::Csv => self.print_csv(),
            OutputFormat::Json => self.print_json(),
        }
    }

    fn print_pretty(&self) {
        let mut current_group: Option<&str> = None;

        for result in &self.results {
            // Print group header
            if result.group.as_deref() != current_group {
                if let Some(ref group) = result.group {
                    println!("\n{}", group);
                    println!("{}", "─".repeat(60));
                }
                current_group = result.group.as_deref();
            }

            // Print result
            print!("  {:40} ", result.name);
            print!("{:>12} ", format_duration(result.stats.mean));
            print!("±{:>10} ", format_duration(result.stats.std_dev));

            if let Some(ref throughput) = result.throughput {
                print!("({:.2} {})", throughput.value, throughput.unit.as_str());
            }

            println!();
        }

        println!();
    }

    fn print_markdown(&self) {
        println!("| Benchmark | Mean | Std Dev | Min | Max |");
        println!("|-----------|------|---------|-----|-----|");

        for result in &self.results {
            println!("| {} | {} | {} | {} | {} |",
                result.name,
                format_duration(result.stats.mean),
                format_duration(result.stats.std_dev),
                format_duration(result.stats.min),
                format_duration(result.stats.max));
        }
    }

    fn print_csv(&self) {
        println!("name,mean_ns,std_dev_ns,min_ns,max_ns,iterations");

        for result in &self.results {
            println!("{},{:.2},{:.2},{:.2},{:.2},{}",
                result.name,
                result.stats.mean,
                result.stats.std_dev,
                result.stats.min,
                result.stats.max,
                result.stats.iterations);
        }
    }

    fn print_json(&self) {
        println!("{{");
        println!("  \"benchmarks\": [");

        for (i, result) in self.results.iter().enumerate() {
            println!("    {{");
            println!("      \"name\": \"{}\",", result.name);
            println!("      \"mean_ns\": {:.2},", result.stats.mean);
            println!("      \"std_dev_ns\": {:.2},", result.stats.std_dev);
            println!("      \"min_ns\": {:.2},", result.stats.min);
            println!("      \"max_ns\": {:.2},", result.stats.max);
            println!("      \"iterations\": {}", result.stats.iterations);
            print!("    }}");
            if i < self.results.len() - 1 {
                println!(",");
            } else {
                println!();
            }
        }

        println!("  ]");
        println!("}}");
    }

    /// Save results as new baseline
    pub fn save_baseline(&self, path: &str) -> Result<(), String> {
        let mut content = String::new();

        for result in &self.results {
            content.push_str(&format!("{}={:.2}\n", result.name, result.stats.mean));
        }

        write_string(path, &content)?;
        println!("Baseline saved to {}", path);
        Ok(())
    }
}

/// Iteration context for benchmarks
pub struct Iteration {
    start: Option<Instant>,
    elapsed: Duration,
}

impl Iteration {
    fn new() -> Self {
        Iteration {
            start: None,
            elapsed: Duration::ZERO,
        }
    }

    /// Start timing
    pub fn start(&mut self) {
        self.start = Some(Instant::now());
    }

    /// Stop timing
    pub fn stop(&mut self) {
        if let Some(start) = self.start.take() {
            self.elapsed = start.elapsed();
        }
    }

    /// Run the closure and time it
    pub fn iter<F, R>(&mut self, f: F) -> R
    where
        F: FnOnce() -> R,
    {
        self.start();
        let result = f();
        self.stop();
        result
    }

    /// Prevent compiler from optimizing away the result
    pub fn black_box<T>(x: T) -> T {
        // In real implementation, use std::hint::black_box or similar
        x
    }
}

fn format_duration(ns: f64) -> String {
    if ns < 1_000.0 {
        format!("{:.2} ns", ns)
    } else if ns < 1_000_000.0 {
        format!("{:.2} µs", ns / 1_000.0)
    } else if ns < 1_000_000_000.0 {
        format!("{:.2} ms", ns / 1_000_000.0)
    } else {
        format!("{:.2} s", ns / 1_000_000_000.0)
    }
}

fn load_baseline(path: &str) -> Result<HashMap<String, f64>, String> {
    let mut baseline = HashMap::new();
    // Parse baseline file
    Ok(baseline)
}

// ═══════════════════════════════════════════════════════════════════════════════
// MACRO-LIKE HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Create a benchmark suite
pub fn benchmark_suite<F>(name: &str, f: F)
where
    F: FnOnce(&mut Bencher),
{
    println!("╔═══════════════════════════════════════════════════════════════╗");
    println!("║  {} Benchmarks", name);
    println!("╚═══════════════════════════════════════════════════════════════╝");
    println!();

    let mut bencher = Bencher::new();
    f(&mut bencher);
    bencher.summary();
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXAMPLE BENCHMARKS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn run_example_benchmarks() {
    benchmark_suite("QUANTA-UNIVERSE", |b| {
        // Memory allocation benchmarks
        b.group("Memory Operations");

        b.bench("vec_push_1000", |iter| {
            iter.iter(|| {
                let mut v = Vec::new();
                for i in 0..1000 {
                    v.push(i);
                }
                Iteration::black_box(v)
            });
        });

        b.bench("hashmap_insert_1000", |iter| {
            iter.iter(|| {
                let mut m = HashMap::new();
                for i in 0..1000 {
                    m.insert(i, i * 2);
                }
                Iteration::black_box(m)
            });
        });

        b.group_end();

        // Math benchmarks
        b.group("Math Operations");

        b.bench("sqrt_1000", |iter| {
            iter.iter(|| {
                let mut sum = 0.0;
                for i in 1..=1000 {
                    sum += sqrt(i as f64);
                }
                Iteration::black_box(sum)
            });
        });

        b.bench("trig_1000", |iter| {
            iter.iter(|| {
                let mut sum = 0.0;
                for i in 1..=1000 {
                    let x = i as f64 * 0.01;
                    sum += sin(x) + cos(x);
                }
                Iteration::black_box(sum)
            });
        });

        b.group_end();

        // String benchmarks
        b.group("String Operations");

        b.bench_throughput("string_concat_1000", 1000, ThroughputUnit::Operations, |iter| {
            iter.iter(|| {
                let mut s = String::new();
                for _ in 0..1000 {
                    s.push_str("hello");
                }
                Iteration::black_box(s)
            });
        });

        b.group_end();
    });
}

fn sin(x: f64) -> f64 { x.sin() }
fn cos(x: f64) -> f64 { x.cos() }

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED STATISTICAL ANALYSIS (CRITERION-STYLE)
// ═══════════════════════════════════════════════════════════════════════════════

/// Outlier classification following Tukey's method
#[derive(Clone, Copy, Debug, PartialEq)]
pub enum OutlierClass {
    LowSevere,
    LowMild,
    None,
    HighMild,
    HighSevere,
}

/// Outlier detection results
#[derive(Clone)]
pub struct OutlierAnalysis {
    pub low_severe: usize,
    pub low_mild: usize,
    pub high_mild: usize,
    pub high_severe: usize,
    pub threshold_low_severe: f64,
    pub threshold_low_mild: f64,
    pub threshold_high_mild: f64,
    pub threshold_high_severe: f64,
    pub variance_effect: OutlierVariance,
}

#[derive(Clone, Copy, Debug)]
pub enum OutlierVariance {
    Unaffected,
    Slight,
    Moderate,
    Severe,
}

impl OutlierVariance {
    pub fn from_ratio(ratio: f64) -> Self {
        if ratio < 0.01 { OutlierVariance::Unaffected }
        else if ratio < 0.1 { OutlierVariance::Slight }
        else if ratio < 0.5 { OutlierVariance::Moderate }
        else { OutlierVariance::Severe }
    }
}

/// Advanced statistics with robust estimators
#[derive(Clone)]
pub struct AdvancedStatistics {
    pub base: Statistics,
    pub outliers: OutlierAnalysis,
    pub iqr: f64,           // Interquartile range
    pub q1: f64,            // First quartile
    pub q3: f64,            // Third quartile
    pub mad: f64,           // Median absolute deviation
    pub skewness: f64,
    pub kurtosis: f64,
    pub coefficient_of_variation: f64,
    pub robust_mean: f64,   // Mean with outliers removed
    pub robust_std_dev: f64,
}

impl AdvancedStatistics {
    pub fn from_samples(samples: &[f64]) -> Self {
        let mut sorted = samples.to_vec();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
        let n = sorted.len();

        // Basic statistics
        let sum: f64 = sorted.iter().sum();
        let mean = sum / n as f64;

        let variance: f64 = sorted.iter()
            .map(|x| (x - mean).powi(2))
            .sum::<f64>() / (n - 1).max(1) as f64;
        let std_dev = variance.sqrt();

        let median = if n % 2 == 0 {
            (sorted[n / 2 - 1] + sorted[n / 2]) / 2.0
        } else {
            sorted[n / 2]
        };

        // Quartiles
        let q1_idx = n / 4;
        let q3_idx = 3 * n / 4;
        let q1 = sorted[q1_idx];
        let q3 = sorted[q3_idx];
        let iqr = q3 - q1;

        // Outlier thresholds (Tukey's fences)
        let threshold_low_mild = q1 - 1.5 * iqr;
        let threshold_low_severe = q1 - 3.0 * iqr;
        let threshold_high_mild = q3 + 1.5 * iqr;
        let threshold_high_severe = q3 + 3.0 * iqr;

        // Count outliers
        let mut low_severe = 0;
        let mut low_mild = 0;
        let mut high_mild = 0;
        let mut high_severe = 0;

        for &x in &sorted {
            if x < threshold_low_severe { low_severe += 1; }
            else if x < threshold_low_mild { low_mild += 1; }
            else if x > threshold_high_severe { high_severe += 1; }
            else if x > threshold_high_mild { high_mild += 1; }
        }

        // Compute variance effect of outliers
        let total_outliers = low_severe + low_mild + high_mild + high_severe;
        let outlier_ratio = total_outliers as f64 / n as f64;
        let variance_effect = OutlierVariance::from_ratio(outlier_ratio);

        // Median absolute deviation (robust spread estimator)
        let mad: f64 = {
            let deviations: Vec<f64> = sorted.iter()
                .map(|x| (x - median).abs())
                .collect();
            let mut dev_sorted = deviations.clone();
            dev_sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
            if n % 2 == 0 {
                (dev_sorted[n / 2 - 1] + dev_sorted[n / 2]) / 2.0
            } else {
                dev_sorted[n / 2]
            }
        };

        // Skewness and Kurtosis
        let m2: f64 = sorted.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64;
        let m3: f64 = sorted.iter().map(|x| (x - mean).powi(3)).sum::<f64>() / n as f64;
        let m4: f64 = sorted.iter().map(|x| (x - mean).powi(4)).sum::<f64>() / n as f64;

        let skewness = m3 / m2.powf(1.5);
        let kurtosis = m4 / m2.powi(2) - 3.0; // Excess kurtosis

        // Coefficient of variation
        let cv = std_dev / mean;

        // Robust mean (trimmed mean, excluding outliers)
        let non_outliers: Vec<f64> = sorted.iter()
            .filter(|&&x| x >= threshold_low_mild && x <= threshold_high_mild)
            .copied()
            .collect();
        let robust_mean = non_outliers.iter().sum::<f64>() / non_outliers.len().max(1) as f64;
        let robust_variance: f64 = non_outliers.iter()
            .map(|x| (x - robust_mean).powi(2))
            .sum::<f64>() / (non_outliers.len() - 1).max(1) as f64;
        let robust_std_dev = robust_variance.sqrt();

        // Percentiles
        let percentile = |p: f64| -> f64 {
            let idx = ((n as f64 - 1.0) * p) as usize;
            sorted[idx.min(n - 1)]
        };

        let base = Statistics {
            mean,
            median,
            std_dev,
            min: sorted[0],
            max: sorted[n - 1],
            percentile_5: percentile(0.05),
            percentile_95: percentile(0.95),
            iterations: n as u64,
            sample_count: n,
        };

        AdvancedStatistics {
            base,
            outliers: OutlierAnalysis {
                low_severe,
                low_mild,
                high_mild,
                high_severe,
                threshold_low_severe,
                threshold_low_mild,
                threshold_high_mild,
                threshold_high_severe,
                variance_effect,
            },
            iqr,
            q1,
            q3,
            mad,
            skewness,
            kurtosis,
            coefficient_of_variation: cv,
            robust_mean,
            robust_std_dev,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WELCH'S T-TEST FOR REGRESSION DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Result of Welch's t-test comparing two samples
#[derive(Clone)]
pub struct TTestResult {
    pub t_statistic: f64,
    pub degrees_of_freedom: f64,
    pub p_value: f64,
    pub significant: bool,       // At 0.05 level
    pub effect_size: f64,        // Cohen's d
    pub effect_magnitude: EffectMagnitude,
}

#[derive(Clone, Copy, Debug)]
pub enum EffectMagnitude {
    Negligible,
    Small,
    Medium,
    Large,
}

impl EffectMagnitude {
    pub fn from_cohens_d(d: f64) -> Self {
        let d_abs = d.abs();
        if d_abs < 0.2 { EffectMagnitude::Negligible }
        else if d_abs < 0.5 { EffectMagnitude::Small }
        else if d_abs < 0.8 { EffectMagnitude::Medium }
        else { EffectMagnitude::Large }
    }
}

/// Perform Welch's t-test comparing two samples
pub fn welch_t_test(sample_a: &[f64], sample_b: &[f64]) -> TTestResult {
    let n1 = sample_a.len() as f64;
    let n2 = sample_b.len() as f64;

    let mean1: f64 = sample_a.iter().sum::<f64>() / n1;
    let mean2: f64 = sample_b.iter().sum::<f64>() / n2;

    let var1: f64 = sample_a.iter().map(|x| (x - mean1).powi(2)).sum::<f64>() / (n1 - 1.0);
    let var2: f64 = sample_b.iter().map(|x| (x - mean2).powi(2)).sum::<f64>() / (n2 - 1.0);

    let se = (var1 / n1 + var2 / n2).sqrt();
    let t_statistic = (mean1 - mean2) / se;

    // Welch-Satterthwaite degrees of freedom
    let num = (var1 / n1 + var2 / n2).powi(2);
    let denom = (var1 / n1).powi(2) / (n1 - 1.0) + (var2 / n2).powi(2) / (n2 - 1.0);
    let df = num / denom;

    // Approximate p-value using normal distribution for large df
    let p_value = 2.0 * (1.0 - normal_cdf(t_statistic.abs()));

    // Cohen's d effect size
    let pooled_std = ((var1 + var2) / 2.0).sqrt();
    let effect_size = (mean1 - mean2) / pooled_std;

    TTestResult {
        t_statistic,
        degrees_of_freedom: df,
        p_value,
        significant: p_value < 0.05,
        effect_size,
        effect_magnitude: EffectMagnitude::from_cohens_d(effect_size),
    }
}

/// Standard normal CDF approximation
fn normal_cdf(x: f64) -> f64 {
    0.5 * (1.0 + erf(x / 2.0_f64.sqrt()))
}

/// Error function approximation (Horner form)
fn erf(x: f64) -> f64 {
    let a1 =  0.254829592;
    let a2 = -0.284496736;
    let a3 =  1.421413741;
    let a4 = -1.453152027;
    let a5 =  1.061405429;
    let p  =  0.3275911;

    let sign = if x < 0.0 { -1.0 } else { 1.0 };
    let x = x.abs();

    let t = 1.0 / (1.0 + p * x);
    let y = 1.0 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * (-x * x).exp();

    sign * y
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEMORY PROFILING
// ═══════════════════════════════════════════════════════════════════════════════

/// Memory allocation tracker for benchmarks
#[derive(Clone)]
pub struct MemoryProfile {
    pub allocations: u64,
    pub deallocations: u64,
    pub bytes_allocated: u64,
    pub bytes_deallocated: u64,
    pub peak_memory: u64,
    pub current_memory: u64,
    pub allocation_sizes: Vec<u64>,
}

impl MemoryProfile {
    pub fn new() -> Self {
        MemoryProfile {
            allocations: 0,
            deallocations: 0,
            bytes_allocated: 0,
            bytes_deallocated: 0,
            peak_memory: 0,
            current_memory: 0,
            allocation_sizes: Vec::new(),
        }
    }

    pub fn record_allocation(&mut self, size: u64) {
        self.allocations += 1;
        self.bytes_allocated += size;
        self.current_memory += size;
        self.peak_memory = self.peak_memory.max(self.current_memory);
        self.allocation_sizes.push(size);
    }

    pub fn record_deallocation(&mut self, size: u64) {
        self.deallocations += 1;
        self.bytes_deallocated += size;
        self.current_memory = self.current_memory.saturating_sub(size);
    }

    pub fn net_allocations(&self) -> i64 {
        self.allocations as i64 - self.deallocations as i64
    }

    pub fn net_bytes(&self) -> i64 {
        self.bytes_allocated as i64 - self.bytes_deallocated as i64
    }

    pub fn average_allocation_size(&self) -> f64 {
        if self.allocations == 0 { 0.0 }
        else { self.bytes_allocated as f64 / self.allocations as f64 }
    }

    pub fn merge(&mut self, other: &MemoryProfile) {
        self.allocations += other.allocations;
        self.deallocations += other.deallocations;
        self.bytes_allocated += other.bytes_allocated;
        self.bytes_deallocated += other.bytes_deallocated;
        self.peak_memory = self.peak_memory.max(other.peak_memory);
    }
}

/// Global memory profiler (thread-local in real implementation)
pub struct MemoryProfiler {
    enabled: bool,
    profile: MemoryProfile,
}

impl MemoryProfiler {
    pub fn new() -> Self {
        MemoryProfiler {
            enabled: false,
            profile: MemoryProfile::new(),
        }
    }

    pub fn start(&mut self) {
        self.enabled = true;
        self.profile = MemoryProfile::new();
    }

    pub fn stop(&mut self) -> MemoryProfile {
        self.enabled = false;
        self.profile.clone()
    }

    pub fn is_enabled(&self) -> bool {
        self.enabled
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CPU PERFORMANCE COUNTERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Hardware performance counter readings
#[derive(Clone, Default)]
pub struct PerfCounters {
    pub cycles: u64,
    pub instructions: u64,
    pub cache_references: u64,
    pub cache_misses: u64,
    pub branch_instructions: u64,
    pub branch_misses: u64,
    pub l1d_read_misses: u64,
    pub l1i_read_misses: u64,
    pub llc_read_misses: u64,
    pub page_faults: u64,
    pub context_switches: u64,
}

impl PerfCounters {
    pub fn new() -> Self {
        PerfCounters::default()
    }

    pub fn ipc(&self) -> f64 {
        if self.cycles == 0 { 0.0 }
        else { self.instructions as f64 / self.cycles as f64 }
    }

    pub fn cache_miss_rate(&self) -> f64 {
        if self.cache_references == 0 { 0.0 }
        else { self.cache_misses as f64 / self.cache_references as f64 * 100.0 }
    }

    pub fn branch_miss_rate(&self) -> f64 {
        if self.branch_instructions == 0 { 0.0 }
        else { self.branch_misses as f64 / self.branch_instructions as f64 * 100.0 }
    }

    pub fn cycles_per_instruction(&self) -> f64 {
        if self.instructions == 0 { 0.0 }
        else { self.cycles as f64 / self.instructions as f64 }
    }
}

/// Hardware performance counter profiler
pub struct PerfProfiler {
    enabled: bool,
    start_counters: PerfCounters,
    perf_fd: Option<i32>,  // File descriptor for perf events
}

impl PerfProfiler {
    pub fn new() -> Self {
        PerfProfiler {
            enabled: false,
            start_counters: PerfCounters::new(),
            perf_fd: None,
        }
    }

    pub fn is_available() -> bool {
        // Check if perf_event_open is available
        #[cfg(target_os = "linux")]
        { true }
        #[cfg(not(target_os = "linux"))]
        { false }
    }

    pub fn start(&mut self) {
        self.enabled = true;
        self.start_counters = self.read_counters();
    }

    pub fn stop(&mut self) -> PerfCounters {
        let end = self.read_counters();
        self.enabled = false;

        PerfCounters {
            cycles: end.cycles - self.start_counters.cycles,
            instructions: end.instructions - self.start_counters.instructions,
            cache_references: end.cache_references - self.start_counters.cache_references,
            cache_misses: end.cache_misses - self.start_counters.cache_misses,
            branch_instructions: end.branch_instructions - self.start_counters.branch_instructions,
            branch_misses: end.branch_misses - self.start_counters.branch_misses,
            l1d_read_misses: end.l1d_read_misses - self.start_counters.l1d_read_misses,
            l1i_read_misses: end.l1i_read_misses - self.start_counters.l1i_read_misses,
            llc_read_misses: end.llc_read_misses - self.start_counters.llc_read_misses,
            page_faults: end.page_faults - self.start_counters.page_faults,
            context_switches: end.context_switches - self.start_counters.context_switches,
        }
    }

    fn read_counters(&self) -> PerfCounters {
        // Platform-specific implementation
        PerfCounters::new()
    }
}

