// TECHNICAL INDICATORS
// ═══════════════════════════════════════════════════════════════════════════════

/// Feature indices for the tensor
pub mod features {
    pub const PRICE: usize = 0;
    pub const VOLUME: usize = 1;
    pub const VOLATILITY: usize = 2;
    pub const MOMENTUM: usize = 3;
    pub const RSI: usize = 4;
    pub const MACD: usize = 5;
    pub const BOLLINGER: usize = 6;
    pub const ATR: usize = 7;
    pub const CORRELATION: usize = 8;
    pub const BETA: usize = 9;
    pub const VWAP: usize = 10;
    pub const OBV: usize = 11;
    pub const ADX: usize = 12;
    pub const STOCHASTIC: usize = 13;
    pub const WILLIAMS_R: usize = 14;
    pub const CCI: usize = 15;
}

/// Derivative indices
pub mod derivatives {
    pub const VALUE: usize = 0;
    pub const FIRST: usize = 1;      // First derivative (returns)
    pub const SECOND: usize = 2;     // Second derivative (acceleration)
    pub const LOG: usize = 3;        // Log transform
}

/// Technical indicator calculator
pub struct TechnicalIndicators;

impl TechnicalIndicators {
    /// Simple Moving Average
    pub fn sma(prices: &[f64], period: usize) -> Vec<f64> {
        if prices.len() < period {
            return vec![0.0; prices.len()];
        }

        let mut result = vec![0.0; prices.len()];
        let mut sum: f64 = prices[..period].iter().sum();
        result[period - 1] = sum / period as f64;

        for i in period..prices.len() {
            sum = sum - prices[i - period] + prices[i];
            result[i] = sum / period as f64;
        }

        result
    }

    /// Exponential Moving Average
    pub fn ema(prices: &[f64], period: usize) -> Vec<f64> {
        if prices.is_empty() {
            return Vec::new();
        }

        let mut result = vec![0.0; prices.len()];
        let multiplier = 2.0 / (period as f64 + 1.0);

        result[0] = prices[0];
        for i in 1..prices.len() {
            result[i] = (prices[i] - result[i - 1]) * multiplier + result[i - 1];
        }

        result
    }

    /// Relative Strength Index
    pub fn rsi(prices: &[f64], period: usize) -> Vec<f64> {
        if prices.len() < period + 1 {
            return vec![50.0; prices.len()];
        }

        let mut result = vec![50.0; prices.len()];
        let mut gains = Vec::new();
        let mut losses = Vec::new();

        // Calculate price changes
        for i in 1..prices.len() {
            let change = prices[i] - prices[i - 1];
            gains.push(if change > 0.0 { change } else { 0.0 });
            losses.push(if change < 0.0 { -change } else { 0.0 });
        }

        // Initial average gain/loss
        let mut avg_gain: f64 = gains[..period].iter().sum::<f64>() / period as f64;
        let mut avg_loss: f64 = losses[..period].iter().sum::<f64>() / period as f64;

        if avg_loss > 0.0 {
            result[period] = 100.0 - (100.0 / (1.0 + avg_gain / avg_loss));
        } else {
            result[period] = 100.0;
        }

        // Subsequent RSI values
        for i in period..gains.len() {
            avg_gain = (avg_gain * (period - 1) as f64 + gains[i]) / period as f64;
            avg_loss = (avg_loss * (period - 1) as f64 + losses[i]) / period as f64;

            if avg_loss > 0.0 {
                result[i + 1] = 100.0 - (100.0 / (1.0 + avg_gain / avg_loss));
            } else {
                result[i + 1] = 100.0;
            }
        }

        result
    }

    /// MACD (Moving Average Convergence Divergence)
    pub fn macd(prices: &[f64], fast: usize, slow: usize, signal: usize) -> (Vec<f64>, Vec<f64>, Vec<f64>) {
        let ema_fast = Self::ema(prices, fast);
        let ema_slow = Self::ema(prices, slow);

        let macd_line: Vec<f64> = ema_fast.iter()
            .zip(ema_slow.iter())
            .map(|(f, s)| f - s)
            .collect();

        let signal_line = Self::ema(&macd_line, signal);

        let histogram: Vec<f64> = macd_line.iter()
            .zip(signal_line.iter())
            .map(|(m, s)| m - s)
            .collect();

        (macd_line, signal_line, histogram)
    }

    /// Bollinger Bands
    pub fn bollinger_bands(prices: &[f64], period: usize, std_dev: f64) -> (Vec<f64>, Vec<f64>, Vec<f64>) {
        let sma = Self::sma(prices, period);
        let mut upper = vec![0.0; prices.len()];
        let mut lower = vec![0.0; prices.len()];

        for i in (period - 1)..prices.len() {
            let window = &prices[(i + 1 - period)..=i];
            let mean = sma[i];
            let variance: f64 = window.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / period as f64;
            let std = variance.sqrt();

            upper[i] = mean + std_dev * std;
            lower[i] = mean - std_dev * std;
        }

        (upper, sma.clone(), lower)
    }

    /// Average True Range
    pub fn atr(high: &[f64], low: &[f64], close: &[f64], period: usize) -> Vec<f64> {
        if high.len() < 2 {
            return vec![0.0; high.len()];
        }

        let mut tr = vec![high[0] - low[0]];

        for i in 1..high.len() {
            let hl = high[i] - low[i];
            let hc = (high[i] - close[i - 1]).abs();
            let lc = (low[i] - close[i - 1]).abs();
            tr.push(hl.max(hc).max(lc));
        }

        Self::ema(&tr, period)
    }

    /// Stochastic Oscillator
    pub fn stochastic(high: &[f64], low: &[f64], close: &[f64], k_period: usize, d_period: usize) -> (Vec<f64>, Vec<f64>) {
        let n = close.len();
        let mut k_values = vec![50.0; n];

        for i in (k_period - 1)..n {
            let window_high = &high[(i + 1 - k_period)..=i];
            let window_low = &low[(i + 1 - k_period)..=i];

            let highest: f64 = window_high.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let lowest: f64 = window_low.iter().cloned().fold(f64::INFINITY, f64::min);

            if (highest - lowest).abs() > 1e-10 {
                k_values[i] = 100.0 * (close[i] - lowest) / (highest - lowest);
            }
        }

        let d_values = Self::sma(&k_values, d_period);

        (k_values, d_values)
    }

    /// Williams %R
    pub fn williams_r(high: &[f64], low: &[f64], close: &[f64], period: usize) -> Vec<f64> {
        let n = close.len();
        let mut result = vec![-50.0; n];

        for i in (period - 1)..n {
            let window_high = &high[(i + 1 - period)..=i];
            let window_low = &low[(i + 1 - period)..=i];

            let highest: f64 = window_high.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
            let lowest: f64 = window_low.iter().cloned().fold(f64::INFINITY, f64::min);

            if (highest - lowest).abs() > 1e-10 {
                result[i] = -100.0 * (highest - close[i]) / (highest - lowest);
            }
        }

        result
    }

    /// Commodity Channel Index
    pub fn cci(high: &[f64], low: &[f64], close: &[f64], period: usize) -> Vec<f64> {
        let n = close.len();
        let mut result = vec![0.0; n];

        // Typical price
        let tp: Vec<f64> = (0..n).map(|i| (high[i] + low[i] + close[i]) / 3.0).collect();
        let tp_sma = Self::sma(&tp, period);

        for i in (period - 1)..n {
            let window = &tp[(i + 1 - period)..=i];
            let mean = tp_sma[i];
            let mean_deviation: f64 = window.iter().map(|x| (x - mean).abs()).sum::<f64>() / period as f64;

            if mean_deviation > 1e-10 {
                result[i] = (tp[i] - mean) / (0.015 * mean_deviation);
            }
        }

        result
    }

    /// Average Directional Index
    pub fn adx(high: &[f64], low: &[f64], close: &[f64], period: usize) -> (Vec<f64>, Vec<f64>, Vec<f64>) {
        let n = close.len();
        let mut plus_dm = vec![0.0; n];
        let mut minus_dm = vec![0.0; n];

        for i in 1..n {
            let up_move = high[i] - high[i - 1];
            let down_move = low[i - 1] - low[i];

            if up_move > down_move && up_move > 0.0 {
                plus_dm[i] = up_move;
            }
            if down_move > up_move && down_move > 0.0 {
                minus_dm[i] = down_move;
            }
        }

        let atr = Self::atr(high, low, close, period);
        let smoothed_plus_dm = Self::ema(&plus_dm, period);
        let smoothed_minus_dm = Self::ema(&minus_dm, period);

        let mut plus_di = vec![0.0; n];
        let mut minus_di = vec![0.0; n];
        let mut dx = vec![0.0; n];

        for i in 0..n {
            if atr[i] > 1e-10 {
                plus_di[i] = 100.0 * smoothed_plus_dm[i] / atr[i];
                minus_di[i] = 100.0 * smoothed_minus_dm[i] / atr[i];
            }

            let di_sum = plus_di[i] + minus_di[i];
            if di_sum > 1e-10 {
                dx[i] = 100.0 * (plus_di[i] - minus_di[i]).abs() / di_sum;
            }
        }

        let adx = Self::ema(&dx, period);

        (adx, plus_di, minus_di)
    }

    /// On-Balance Volume
    pub fn obv(close: &[f64], volume: &[f64]) -> Vec<f64> {
        let mut result = vec![0.0; close.len()];

        if !close.is_empty() {
            result[0] = volume[0];
        }

        for i in 1..close.len() {
            if close[i] > close[i - 1] {
                result[i] = result[i - 1] + volume[i];
            } else if close[i] < close[i - 1] {
                result[i] = result[i - 1] - volume[i];
            } else {
                result[i] = result[i - 1];
            }
        }

        result
    }

    /// Volume Weighted Average Price
    pub fn vwap(high: &[f64], low: &[f64], close: &[f64], volume: &[f64]) -> Vec<f64> {
        let n = close.len();
        let mut result = vec![0.0; n];
        let mut cumulative_tpv = 0.0;
        let mut cumulative_volume = 0.0;

        for i in 0..n {
            let typical_price = (high[i] + low[i] + close[i]) / 3.0;
            cumulative_tpv += typical_price * volume[i];
            cumulative_volume += volume[i];

            if cumulative_volume > 0.0 {
                result[i] = cumulative_tpv / cumulative_volume;
            }
        }

        result
    }

    /// Volatility (rolling standard deviation of returns)
    pub fn volatility(prices: &[f64], period: usize) -> Vec<f64> {
        if prices.len() < 2 {
            return vec![0.0; prices.len()];
        }

        // Calculate returns
        let returns: Vec<f64> = (1..prices.len())
            .map(|i| (prices[i] / prices[i - 1]).ln())
            .collect();

        let mut result = vec![0.0; prices.len()];

        for i in period..returns.len() {
            let window = &returns[(i - period)..i];
            let mean: f64 = window.iter().sum::<f64>() / period as f64;
            let variance: f64 = window.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / (period - 1) as f64;
            result[i + 1] = variance.sqrt() * (252.0_f64).sqrt(); // Annualized
        }

        result
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COVARIANCE AND CORRELATION
// ═══════════════════════════════════════════════════════════════════════════════

impl MarketTensor4D {
    /// Compute covariance matrix between assets
    pub fn asset_covariance(&self) -> Matrix {
        let n_assets = self.shape[1];
        let n_time = self.shape[0];
        let mut cov = Matrix::new(n_assets, n_assets);

        // Get returns (feature index 0, derivative index 1)
        let mut returns = vec![vec![0.0; n_time]; n_assets];
        for a in 0..n_assets {
            for t in 0..n_time {
                returns[a][t] = self.get(t, a, features::PRICE, derivatives::FIRST);
            }
        }

        // Compute means
        let means: Vec<f64> = returns.iter()
            .map(|r| r.iter().sum::<f64>() / n_time as f64)
            .collect();

        // Compute covariance
        for i in 0..n_assets {
            for j in 0..n_assets {
                let mut sum = 0.0;
                for t in 0..n_time {
                    sum += (returns[i][t] - means[i]) * (returns[j][t] - means[j]);
                }
                cov.set(i, j, sum / (n_time - 1) as f64);
            }
        }

        cov
    }

    /// Compute correlation matrix between assets
    pub fn asset_correlation(&self) -> Matrix {
        let cov = self.asset_covariance();
        let n = cov.rows;
        let mut corr = Matrix::new(n, n);

        for i in 0..n {
            for j in 0..n {
                let std_i = cov.get(i, i).sqrt();
                let std_j = cov.get(j, j).sqrt();

                if std_i > 1e-10 && std_j > 1e-10 {
                    corr.set(i, j, cov.get(i, j) / (std_i * std_j));
                } else if i == j {
                    corr.set(i, j, 1.0);
                }
            }
        }

        corr
    }

    /// Exponentially weighted covariance matrix
    pub fn ewm_covariance(&self, half_life: f64) -> Matrix {
        let n_assets = self.shape[1];
        let n_time = self.shape[0];
        let mut cov = Matrix::new(n_assets, n_assets);

        let decay = 0.5_f64.powf(1.0 / half_life);

        // Get returns
        let mut returns = vec![vec![0.0; n_time]; n_assets];
        for a in 0..n_assets {
            for t in 0..n_time {
                returns[a][t] = self.get(t, a, features::PRICE, derivatives::FIRST);
            }
        }

        // Compute weighted means
        let mut weight_sum = 0.0;
        let mut weighted_means = vec![0.0; n_assets];

        for t in 0..n_time {
            let weight = decay.powi((n_time - 1 - t) as i32);
            weight_sum += weight;
            for a in 0..n_assets {
                weighted_means[a] += weight * returns[a][t];
            }
        }

        for a in 0..n_assets {
            weighted_means[a] /= weight_sum;
        }

        // Compute weighted covariance
        let mut weight_sum2 = 0.0;
        for t in 0..n_time {
            let weight = decay.powi((n_time - 1 - t) as i32);
            weight_sum2 += weight;

            for i in 0..n_assets {
                for j in 0..n_assets {
                    let val = cov.get(i, j) + weight * (returns[i][t] - weighted_means[i]) * (returns[j][t] - weighted_means[j]);
                    cov.set(i, j, val);
                }
            }
        }

        for i in 0..n_assets {
            for j in 0..n_assets {
                cov.set(i, j, cov.get(i, j) / weight_sum2);
            }
        }

        cov
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIFFERENTIAL GEOMETRY - METRIC TENSOR & CURVATURE
// ═══════════════════════════════════════════════════════════════════════════════

/// Differential geometry tools for market manifold analysis
pub struct MarketGeometry {
    tensor: MarketTensor4D,
    metric: Matrix,
    metric_inverse: Matrix,
}

impl MarketGeometry {
    pub fn new(tensor: MarketTensor4D) -> Self {
        let cov = tensor.asset_covariance();
        let metric_inverse = cov.inverse().unwrap_or(Matrix::identity(cov.rows));

        MarketGeometry {
            tensor,
            metric: cov,
            metric_inverse,
        }
    }

    /// Get metric tensor g_ij (Fisher-Rao information metric)
    pub fn metric_tensor(&self) -> &Matrix {
        &self.metric
    }

    /// Get inverse metric tensor g^ij
    pub fn inverse_metric(&self) -> &Matrix {
        &self.metric_inverse
    }

    /// Compute Christoffel symbols Γ^k_ij for geodesic navigation
    /// Uses numerical differentiation of the metric tensor
    pub fn christoffel_symbols(&self) -> Vec<Vec<Vec<f64>>> {
        let n = self.metric.rows;
        let mut gamma = vec![vec![vec![0.0; n]; n]; n];
        let epsilon = 0.001;

        // Numerical approximation of metric derivatives
        // For a proper implementation, we'd need perturbations in portfolio space
        // Here we approximate using the structure of the covariance matrix

        for k in 0..n {
            for i in 0..n {
                for j in 0..n {
                    let mut sum = 0.0;
                    for l in 0..n {
                        // Simplified: assume metric varies slowly
                        // In practice, would need numerical derivatives
                        let dg_li_j = 0.0;
                        let dg_lj_i = 0.0;
                        let dg_ij_l = 0.0;

                        sum += self.metric_inverse.get(k, l) * (dg_li_j + dg_lj_i - dg_ij_l);
                    }
                    gamma[k][i][j] = 0.5 * sum;
                }
            }
        }

        gamma
    }

    /// Riemann curvature tensor R^l_ijk
    pub fn riemann_tensor(&self) -> Vec<Vec<Vec<Vec<f64>>>> {
        let n = self.metric.rows;
        let gamma = self.christoffel_symbols();
        let mut riemann = vec![vec![vec![vec![0.0; n]; n]; n]; n];

        for l in 0..n {
            for i in 0..n {
                for j in 0..n {
                    for k in 0..n {
                        // R^l_ijk = ∂_j Γ^l_ik - ∂_k Γ^l_ij + Γ^l_jm Γ^m_ik - Γ^l_km Γ^m_ij
                        let mut sum = 0.0;

                        for m in 0..n {
                            sum += gamma[l][j][m] * gamma[m][i][k] - gamma[l][k][m] * gamma[m][i][j];
                        }

                        riemann[l][i][j][k] = sum;
                    }
                }
            }
        }

        riemann
    }

    /// Ricci curvature tensor R_ij (contraction of Riemann)
    pub fn ricci_tensor(&self) -> Matrix {
        let n = self.metric.rows;
        let riemann = self.riemann_tensor();
        let mut ricci = Matrix::new(n, n);

        for i in 0..n {
            for j in 0..n {
                let mut sum = 0.0;
                for k in 0..n {
                    sum += riemann[k][i][k][j];
                }
                ricci.set(i, j, sum);
            }
        }

        ricci
    }

    /// Scalar curvature R (trace of Ricci)
    pub fn scalar_curvature(&self) -> f64 {
        let ricci = self.ricci_tensor();
        let n = ricci.rows;

        let mut sum = 0.0;
        for i in 0..n {
            for j in 0..n {
                sum += self.metric_inverse.get(i, j) * ricci.get(i, j);
            }
        }

        sum
    }

    /// Sectional curvature for a 2-plane spanned by vectors u, v
    pub fn sectional_curvature(&self, u: &[f64], v: &[f64]) -> f64 {
        let n = u.len();
        let riemann = self.riemann_tensor();

        // K(u,v) = R(u,v,v,u) / (g(u,u)g(v,v) - g(u,v)^2)
        let mut r_uvvu = 0.0;
        for i in 0..n {
            for j in 0..n {
                for k in 0..n {
                    for l in 0..n {
                        // Lower the first index
                        for m in 0..n {
                            r_uvvu += self.metric.get(i, m) * riemann[m][j][k][l] * u[i] * v[j] * v[k] * u[l];
                        }
                    }
                }
            }
        }

        // Compute denominator
        let mut g_uu = 0.0;
        let mut g_vv = 0.0;
        let mut g_uv = 0.0;

        for i in 0..n {
            for j in 0..n {
                g_uu += self.metric.get(i, j) * u[i] * u[j];
                g_vv += self.metric.get(i, j) * v[i] * v[j];
                g_uv += self.metric.get(i, j) * u[i] * v[j];
            }
        }

        let denom = g_uu * g_vv - g_uv * g_uv;

        if denom.abs() > 1e-10 {
            r_uvvu / denom
        } else {
            0.0
        }
    }

    /// Geodesic path in portfolio space (optimal portfolio transition)
    pub fn geodesic_path(&self, start: &[f64], end: &[f64], steps: usize) -> Vec<Vec<f64>> {
        let gamma = self.christoffel_symbols();
        let n = start.len();
        let dt = 1.0 / steps as f64;

        let mut path = vec![start.to_vec()];
        let mut velocity: Vec<f64> = start.iter()
            .zip(end.iter())
            .map(|(s, e)| e - s)
            .collect();

        for _ in 0..steps {
            let current = path.last().unwrap();

            // Geodesic equation: d²x^k/dt² = -Γ^k_ij * dx^i/dt * dx^j/dt
            let mut acceleration = vec![0.0; n];
            for k in 0..n {
                for i in 0..n {
                    for j in 0..n {
                        acceleration[k] -= gamma[k][i][j] * velocity[i] * velocity[j];
                    }
                }
            }

            // Update velocity and position (Euler integration)
            for i in 0..n {
                velocity[i] += acceleration[i] * dt;
            }

            let next: Vec<f64> = current.iter()
                .zip(velocity.iter())
                .map(|(x, v)| x + v * dt)
                .collect();

            path.push(next);
        }

        path
    }

    /// Parallel transport of a vector along a geodesic
    pub fn parallel_transport(&self, vector: &[f64], path: &[Vec<f64>]) -> Vec<f64> {
        let gamma = self.christoffel_symbols();
        let n = vector.len();
        let mut v = vector.to_vec();

        for i in 1..path.len() {
            let tangent: Vec<f64> = path[i].iter()
                .zip(path[i - 1].iter())
                .map(|(a, b)| a - b)
                .collect();

            // dv^k/dt = -Γ^k_ij v^i dx^j/dt
            let mut dv = vec![0.0; n];
            for k in 0..n {
                for ii in 0..n {
                    for j in 0..n {
                        dv[k] -= gamma[k][ii][j] * v[ii] * tangent[j];
                    }
                }
            }

            for k in 0..n {
                v[k] += dv[k];
            }
        }

        v
    }

    /// Geodesic distance between two points
    pub fn geodesic_distance(&self, p1: &[f64], p2: &[f64]) -> f64 {
        let path = self.geodesic_path(p1, p2, 100);
        let mut distance = 0.0;

        for i in 1..path.len() {
            let mut ds2 = 0.0;
            for j in 0..p1.len() {
                for k in 0..p1.len() {
                    let dx_j = path[i][j] - path[i - 1][j];
                    let dx_k = path[i][k] - path[i - 1][k];
                    ds2 += self.metric.get(j, k) * dx_j * dx_k;
                }
            }
            distance += ds2.abs().sqrt();
        }

        distance
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GAUGE PORTFOLIO THEORY™
// ═══════════════════════════════════════════════════════════════════════════════

/// Gauge transformation framework for portfolio analysis
/// Inspired by gauge theories in physics (U(1), SU(n) symmetries)
pub struct GaugePortfolio {
    n_assets: usize,
    connection: Matrix,  // Gauge connection A_μ
}

impl GaugePortfolio {
    pub fn new(n_assets: usize) -> Self {
        GaugePortfolio {
            n_assets,
            connection: Matrix::new(n_assets, n_assets),
        }
    }

    /// Set gauge connection from market data
    pub fn set_connection(&mut self, covariance: &Matrix) {
        // Use log of covariance as connection (U(n) gauge field)
        // A_ij ≈ ln(Σ_ij / sqrt(Σ_ii Σ_jj))
        for i in 0..self.n_assets {
            for j in 0..self.n_assets {
                let diag_i = covariance.get(i, i);
                let diag_j = covariance.get(j, j);

                if diag_i > 1e-10 && diag_j > 1e-10 {
                    let corr = covariance.get(i, j) / (diag_i * diag_j).sqrt();
                    // Avoid log of non-positive numbers
                    if corr > 0.0 && corr <= 1.0 {
                        self.connection.set(i, j, -corr.ln());
                    }
                }
            }
        }
    }

    /// Compute field strength tensor F_μν = ∂_μ A_ν - ∂_ν A_μ + [A_μ, A_ν]
    pub fn field_strength(&self) -> Matrix {
        let n = self.n_assets;
        let mut f = Matrix::new(n, n);

        // Simplified: F = A - A^T + [A, A]
        // The commutator term captures non-abelian structure
        for i in 0..n {
            for j in 0..n {
                let antisym = self.connection.get(i, j) - self.connection.get(j, i);

                // Commutator [A, A]_ij = Σ_k (A_ik A_kj - A_jk A_ki)
                let mut commutator = 0.0;
                for k in 0..n {
                    commutator += self.connection.get(i, k) * self.connection.get(k, j)
                               - self.connection.get(j, k) * self.connection.get(k, i);
                }

                f.set(i, j, antisym + commutator);
            }
        }

        f
    }

    /// Gauge invariant measure: Wilson loop W = Tr(exp(∮ A))
    pub fn wilson_loop(&self, path: &[usize]) -> f64 {
        let n = self.n_assets;

        // Product of exponentials along path (path-ordered)
        let mut product = Matrix::identity(n);

        for i in 0..path.len() {
            let j = (i + 1) % path.len();
            let a_idx = path[i];
            let b_idx = path[j];

            // Approximate exp(A) ≈ I + A for small A
            let mut exp_a = Matrix::identity(n);
            exp_a.set(a_idx, b_idx, exp_a.get(a_idx, b_idx) + self.connection.get(a_idx, b_idx));

            product = product.matmul(&exp_a);
        }

        product.trace()
    }

    /// Gauge covariant derivative D_μ = ∂_μ + A_μ
    pub fn covariant_derivative(&self, field: &[f64]) -> Vec<f64> {
        let n = field.len();
        let mut result = vec![0.0; n];

        for i in 0..n {
            result[i] = field[i]; // ∂_μ term (identity for portfolio weights)
            for j in 0..n {
                result[i] += self.connection.get(i, j) * field[j]; // A_μ term
            }
        }

        result
    }

    /// Gauge transform portfolio weights
    /// w' = U w where U = exp(iθ) ∈ U(n)
    pub fn gauge_transform(&self, weights: &[f64], theta: &Matrix) -> Vec<f64> {
        let n = weights.len();
        let mut result = vec![0.0; n];

        // U = exp(iθ) ≈ I + iθ - θ²/2 + ...
        // For simplicity, use U ≈ I + θ
        for i in 0..n {
            result[i] = weights[i];
            for j in 0..n {
                result[i] += theta.get(i, j) * weights[j];
            }
        }

        // Normalize to maintain sum = 1
        let sum: f64 = result.iter().sum();
        if sum.abs() > 1e-10 {
            for i in 0..n {
                result[i] /= sum;
            }
        }

        result
    }

    /// Compute gauge-invariant portfolio risk
    /// Uses field strength tensor for curvature-aware risk
    pub fn gauge_invariant_risk(&self, weights: &[f64], covariance: &Matrix) -> f64 {
        let f = self.field_strength();
        let n = weights.len();

        // Standard portfolio variance
        let mut variance = 0.0;
        for i in 0..n {
            for j in 0..n {
                variance += weights[i] * weights[j] * covariance.get(i, j);
            }
        }

        // Gauge correction term
        let mut gauge_correction = 0.0;
        for i in 0..n {
            for j in 0..n {
                gauge_correction += weights[i] * weights[j] * f.get(i, j).powi(2);
            }
        }

        variance.sqrt() * (1.0 + 0.1 * gauge_correction)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PORTFOLIO OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Portfolio optimization algorithms
pub struct PortfolioOptimizer {
    returns: Vec<f64>,
    covariance: Matrix,
    n_assets: usize,
}

impl PortfolioOptimizer {
    pub fn new(returns: Vec<f64>, covariance: Matrix) -> Self {
        let n_assets = returns.len();
        PortfolioOptimizer {
            returns,
            covariance,
            n_assets,
        }
    }

    /// Mean-variance optimization (Markowitz)
    /// Minimize: w^T Σ w - λ * w^T μ
    /// Subject to: Σw_i = 1, w_i >= 0
    pub fn mean_variance(&self, risk_aversion: f64) -> Vec<f64> {
        // Closed-form solution for unconstrained case
        // Then project onto simplex for constraints

        let n = self.n_assets;
        let mut weights = vec![0.0; n];

        if let Some(cov_inv) = self.covariance.inverse() {
            // Unconstrained optimal: w* = (1/λ) Σ^(-1) μ
            let mut raw_weights = vec![0.0; n];
            for i in 0..n {
                for j in 0..n {
                    raw_weights[i] += cov_inv.get(i, j) * self.returns[j];
                }
                raw_weights[i] /= risk_aversion;
            }

            // Project onto simplex (sum = 1, non-negative)
            weights = self.project_simplex(&raw_weights);
        } else {
            // Fallback to equal weight
            weights = vec![1.0 / n as f64; n];
        }

        weights
    }

    /// Minimum variance portfolio
    pub fn minimum_variance(&self) -> Vec<f64> {
        let n = self.n_assets;

        if let Some(cov_inv) = self.covariance.inverse() {
            let ones = vec![1.0; n];

            // w = Σ^(-1) 1 / (1^T Σ^(-1) 1)
            let mut numerator = vec![0.0; n];
            let mut denominator = 0.0;

            for i in 0..n {
                for j in 0..n {
                    numerator[i] += cov_inv.get(i, j) * ones[j];
                }
            }

            for i in 0..n {
                for j in 0..n {
                    denominator += ones[i] * cov_inv.get(i, j) * ones[j];
                }
            }

            if denominator.abs() > 1e-10 {
                for i in 0..n {
                    numerator[i] /= denominator;
                }
                return self.project_simplex(&numerator);
            }
        }

        vec![1.0 / n as f64; n]
    }

    /// Maximum Sharpe ratio portfolio
    pub fn maximum_sharpe(&self, risk_free_rate: f64) -> Vec<f64> {
        let n = self.n_assets;
        let excess_returns: Vec<f64> = self.returns.iter().map(|r| r - risk_free_rate).collect();

        if let Some(cov_inv) = self.covariance.inverse() {
            let mut raw_weights = vec![0.0; n];

            for i in 0..n {
                for j in 0..n {
                    raw_weights[i] += cov_inv.get(i, j) * excess_returns[j];
                }
            }

            // Normalize so sum = 1
            let sum: f64 = raw_weights.iter().sum();
            if sum.abs() > 1e-10 {
                for i in 0..n {
                    raw_weights[i] /= sum;
                }
            }

            return self.project_simplex(&raw_weights);
        }

        vec![1.0 / n as f64; n]
    }

    /// Risk parity portfolio (equal risk contribution)
    pub fn risk_parity(&self, iterations: usize) -> Vec<f64> {
        let n = self.n_assets;
        let target_risk = 1.0 / n as f64;

        // Start with equal weights
        let mut weights = vec![1.0 / n as f64; n];

        for _ in 0..iterations {
            // Calculate marginal risk contributions
            let mut mrc = vec![0.0; n];
            let mut total_risk = 0.0;

            for i in 0..n {
                for j in 0..n {
                    mrc[i] += self.covariance.get(i, j) * weights[j];
                }
                total_risk += weights[i] * mrc[i];
            }

            if total_risk.abs() < 1e-10 {
                break;
            }

            let portfolio_vol = total_risk.sqrt();

            // Risk contributions
            let rc: Vec<f64> = (0..n).map(|i| weights[i] * mrc[i] / portfolio_vol).collect();
            let rc_sum: f64 = rc.iter().sum();

            // Adjust weights to equalize risk contributions
            for i in 0..n {
                let current_rc = if rc_sum > 1e-10 { rc[i] / rc_sum } else { 1.0 / n as f64 };
                let adjustment = (target_risk - current_rc) * 0.5;
                weights[i] *= 1.0 + adjustment;
            }

            // Normalize
            let sum: f64 = weights.iter().sum();
            for i in 0..n {
                weights[i] /= sum;
            }
        }

        weights
    }

    /// Black-Litterman model
    pub fn black_litterman(
        &self,
        market_weights: &[f64],
        views: &[(Vec<f64>, f64, f64)], // (asset pick vector, expected return, confidence)
        tau: f64,
    ) -> Vec<f64> {
        let n = self.n_assets;
        let k = views.len();

        if k == 0 {
            return market_weights.to_vec();
        }

        // Implied equilibrium returns: π = λΣw
        let lambda = 2.5; // Risk aversion
        let mut pi = vec![0.0; n];
        for i in 0..n {
            for j in 0..n {
                pi[i] += self.covariance.get(i, j) * market_weights[j];
            }
            pi[i] *= lambda;
        }

        // View matrix P and view returns Q
        let mut p = Matrix::new(k, n);
        let mut q = vec![0.0; k];
        let mut omega = Matrix::new(k, k); // View uncertainty

        for (idx, (pick, ret, confidence)) in views.iter().enumerate() {
            for j in 0..n.min(pick.len()) {
                p.set(idx, j, pick[j]);
            }
            q[idx] = *ret;
            omega.set(idx, idx, 1.0 / confidence);
        }

        // Black-Litterman formula (simplified)
        // E[R] = [(τΣ)^(-1) + P^T Ω^(-1) P]^(-1) [(τΣ)^(-1) π + P^T Ω^(-1) Q]

        // For simplicity, use a weighted average
        let view_weight = 0.5;

        let mut view_returns = pi.clone();
        for (pick, ret, _) in views {
            for i in 0..n.min(pick.len()) {
                if pick[i].abs() > 0.0 {
                    view_returns[i] = (1.0 - view_weight) * pi[i] + view_weight * ret;
                }
            }
        }

        // Optimize with adjusted returns
        let adjusted_optimizer = PortfolioOptimizer::new(view_returns, self.covariance.clone());
        adjusted_optimizer.mean_variance(lambda)
    }

    /// Project onto probability simplex
    fn project_simplex(&self, v: &[f64]) -> Vec<f64> {
        let n = v.len();
        let mut u: Vec<f64> = v.to_vec();
        u.sort_by(|a, b| b.partial_cmp(a).unwrap_or(std::cmp::Ordering::Equal));

        let mut cssv = 0.0;
        let mut rho = 0;

        for j in 0..n {
            cssv += u[j];
            if u[j] - (cssv - 1.0) / (j + 1) as f64 > 0.0 {
                rho = j + 1;
            }
        }

        let theta = (u[..rho].iter().sum::<f64>() - 1.0) / rho as f64;

        v.iter().map(|x| (x - theta).max(0.0)).collect()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TENSOR BUILDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Builder for MarketTensor from OHLCV data
pub struct MarketTensorBuilder {
    symbols: Vec<String>,
    data: HashMap<String, Vec<OHLCVCandle>>,
    compute_indicators: bool,
}

/// Single OHLCV candle
pub struct OHLCVCandle {
    pub timestamp: u64,
    pub open: f64,
    pub high: f64,
    pub low: f64,
    pub close: f64,
    pub volume: f64,
}

impl MarketTensorBuilder {
    pub fn new() -> Self {
        MarketTensorBuilder {
            symbols: Vec::new(),
            data: HashMap::new(),
            compute_indicators: true,
        }
    }

    pub fn with_indicators(mut self, compute: bool) -> Self {
        self.compute_indicators = compute;
        self
    }

    pub fn add_symbol(&mut self, symbol: &str) {
        if !self.symbols.contains(&symbol.to_string()) {
            self.symbols.push(symbol.to_string());
            self.data.insert(symbol.to_string(), Vec::new());
        }
    }

    pub fn add_candle(&mut self, symbol: &str, candle: OHLCVCandle) {
        if let Some(candles) = self.data.get_mut(symbol) {
            candles.push(candle);
        }
    }

    pub fn add_ohlcv(&mut self, symbol: &str, timestamp: u64, open: f64, high: f64, low: f64, close: f64, volume: f64) {
        self.add_candle(symbol, OHLCVCandle { timestamp, open, high, low, close, volume });
    }

    /// Build the 4D market tensor
    pub fn build(&self, lookback: usize) -> MarketTensor4D {
        let n_assets = self.symbols.len();
        let n_features = 16;
        let n_derivatives = 4;

        let mut tensor = MarketTensor4D::new(lookback, n_assets, n_features, n_derivatives);

        for (asset_idx, symbol) in self.symbols.iter().enumerate() {
            if let Some(candles) = self.data.get(symbol) {
                let start = if candles.len() > lookback { candles.len() - lookback } else { 0 };
                let slice = &candles[start..];

                // Extract price series
                let closes: Vec<f64> = slice.iter().map(|c| c.close).collect();
                let highs: Vec<f64> = slice.iter().map(|c| c.high).collect();
                let lows: Vec<f64> = slice.iter().map(|c| c.low).collect();
                let volumes: Vec<f64> = slice.iter().map(|c| c.volume).collect();

                // Basic price data
                for (t, candle) in slice.iter().enumerate() {
                    // Price
                    tensor.set(t, asset_idx, features::PRICE, derivatives::VALUE, candle.close);
                    if candle.close > 0.0 {
                        tensor.set(t, asset_idx, features::PRICE, derivatives::LOG, candle.close.ln());
                    }

                    // Volume
                    tensor.set(t, asset_idx, features::VOLUME, derivatives::VALUE, candle.volume);

                    // Returns
                    if t > 0 {
                        let prev_close = slice[t - 1].close;
                        if prev_close > 0.0 {
                            let ret = (candle.close - prev_close) / prev_close;
                            tensor.set(t, asset_idx, features::PRICE, derivatives::FIRST, ret);

                            let log_ret = (candle.close / prev_close).ln();
                            tensor.set(t, asset_idx, features::PRICE, derivatives::LOG, log_ret);
                        }
                    }

                    // Acceleration
                    if t > 1 {
                        let prev_ret = tensor.get(t - 1, asset_idx, features::PRICE, derivatives::FIRST);
                        let curr_ret = tensor.get(t, asset_idx, features::PRICE, derivatives::FIRST);
                        tensor.set(t, asset_idx, features::PRICE, derivatives::SECOND, curr_ret - prev_ret);
                    }
                }

                // Compute technical indicators if enabled
                if self.compute_indicators && !closes.is_empty() {
                    // RSI
                    let rsi = TechnicalIndicators::rsi(&closes, 14);
                    for (t, &value) in rsi.iter().enumerate() {
                        tensor.set(t, asset_idx, features::RSI, derivatives::VALUE, value);
                    }

                    // MACD
                    let (macd, signal, hist) = TechnicalIndicators::macd(&closes, 12, 26, 9);
                    for (t, &value) in macd.iter().enumerate() {
                        tensor.set(t, asset_idx, features::MACD, derivatives::VALUE, value);
                        tensor.set(t, asset_idx, features::MACD, derivatives::FIRST, signal[t]);
                        tensor.set(t, asset_idx, features::MACD, derivatives::SECOND, hist[t]);
                    }

                    // Bollinger Bands
                    let (upper, middle, lower) = TechnicalIndicators::bollinger_bands(&closes, 20, 2.0);
                    for (t, _) in closes.iter().enumerate() {
                        tensor.set(t, asset_idx, features::BOLLINGER, derivatives::VALUE, middle[t]);
                        tensor.set(t, asset_idx, features::BOLLINGER, derivatives::FIRST, upper[t]);
                        tensor.set(t, asset_idx, features::BOLLINGER, derivatives::SECOND, lower[t]);
                    }

                    // ATR
                    let atr = TechnicalIndicators::atr(&highs, &lows, &closes, 14);
                    for (t, &value) in atr.iter().enumerate() {
                        tensor.set(t, asset_idx, features::ATR, derivatives::VALUE, value);
                    }

                    // Volatility
                    let vol = TechnicalIndicators::volatility(&closes, 20);
                    for (t, &value) in vol.iter().enumerate() {
                        tensor.set(t, asset_idx, features::VOLATILITY, derivatives::VALUE, value);
                    }

                    // VWAP
                    let vwap = TechnicalIndicators::vwap(&highs, &lows, &closes, &volumes);
                    for (t, &value) in vwap.iter().enumerate() {
                        tensor.set(t, asset_idx, features::VWAP, derivatives::VALUE, value);
                    }

                    // OBV
                    let obv = TechnicalIndicators::obv(&closes, &volumes);
                    for (t, &value) in obv.iter().enumerate() {
                        tensor.set(t, asset_idx, features::OBV, derivatives::VALUE, value);
                    }

                    // ADX
                    let (adx, plus_di, minus_di) = TechnicalIndicators::adx(&highs, &lows, &closes, 14);
                    for (t, &value) in adx.iter().enumerate() {
                        tensor.set(t, asset_idx, features::ADX, derivatives::VALUE, value);
                        tensor.set(t, asset_idx, features::ADX, derivatives::FIRST, plus_di[t]);
                        tensor.set(t, asset_idx, features::ADX, derivatives::SECOND, minus_di[t]);
                    }

                    // Stochastic
                    let (stoch_k, stoch_d) = TechnicalIndicators::stochastic(&highs, &lows, &closes, 14, 3);
                    for (t, &value) in stoch_k.iter().enumerate() {
                        tensor.set(t, asset_idx, features::STOCHASTIC, derivatives::VALUE, value);
                        tensor.set(t, asset_idx, features::STOCHASTIC, derivatives::FIRST, stoch_d[t]);
                    }

                    // Williams %R
                    let williams = TechnicalIndicators::williams_r(&highs, &lows, &closes, 14);
                    for (t, &value) in williams.iter().enumerate() {
                        tensor.set(t, asset_idx, features::WILLIAMS_R, derivatives::VALUE, value);
                    }

                    // CCI
                    let cci = TechnicalIndicators::cci(&highs, &lows, &closes, 20);
                    for (t, &value) in cci.iter().enumerate() {
                        tensor.set(t, asset_idx, features::CCI, derivatives::VALUE, value);
                    }

                    // Momentum
                    for t in 10..closes.len() {
                        let momentum = closes[t] / closes[t - 10] - 1.0;
                        tensor.set(t, asset_idx, features::MOMENTUM, derivatives::VALUE, momentum);
                    }
                }
            }
        }

        // Set metadata
        tensor.metadata.symbols = self.symbols.clone();

        tensor
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PARALLEL TENSOR OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

module parallel {
    use super::*;

    /// Thread pool for parallel tensor operations
    pub struct TensorThreadPool {
        num_threads: usize,
        chunk_size: usize,
    }

    impl TensorThreadPool {
        pub fn new(threads: usize) -> Self {
            Self {
                num_threads: threads.max(1),
                chunk_size: 1024,
            }
        }

        pub fn parallel_map<F>(&self, data: &mut [f64], f: F)
        where F: Fn(f64) -> f64 + Sync {
            let chunk_size = (data.len() / self.num_threads).max(self.chunk_size);
            data.chunks_mut(chunk_size)
                .for_each(|chunk| {
                    for elem in chunk {
                        *elem = f(*elem);
                    }
                });
        }

        pub fn parallel_reduce<F>(&self, data: &[f64], initial: f64, f: F) -> f64
        where F: Fn(f64, f64) -> f64 + Sync {
            let chunk_size = (data.len() / self.num_threads).max(self.chunk_size);
            data.chunks(chunk_size)
                .map(|chunk| chunk.iter().fold(initial, |acc, &x| f(acc, x)))
                .fold(initial, |acc, x| f(acc, x))
        }

        pub fn parallel_matmul(&self, a: &Matrix, b: &Matrix) -> Matrix {
            assert_eq!(a.cols, b.rows);
            let mut result = Matrix::new(a.rows, b.cols);

            for i in 0..a.rows {
                for j in 0..b.cols {
                    let mut sum = 0.0;
                    for k in 0..a.cols {
                        sum += a.get(i, k) * b.get(k, j);
                    }
                    result.set(i, j, sum);
                }
            }

            result
        }
    }

    /// SIMD-accelerated vector operations
    pub struct SimdVec {
        data: Vec<f64>,
        len: usize,
    }

    impl SimdVec {
        pub fn new(size: usize) -> Self {
            Self {
                data: vec![0.0; size],
                len: size,
            }
        }

        pub fn from_slice(data: &[f64]) -> Self {
            Self {
                data: data.to_vec(),
                len: data.len(),
            }
        }

        pub fn add(&self, other: &SimdVec) -> SimdVec {
            assert_eq!(self.len, other.len);
            let mut result = SimdVec::new(self.len);
            for i in 0..self.len {
                result.data[i] = self.data[i] + other.data[i];
            }
            result
        }

        pub fn mul(&self, other: &SimdVec) -> SimdVec {
            assert_eq!(self.len, other.len);
            let mut result = SimdVec::new(self.len);
            for i in 0..self.len {
                result.data[i] = self.data[i] * other.data[i];
            }
            result
        }

        pub fn dot(&self, other: &SimdVec) -> f64 {
            assert_eq!(self.len, other.len);
            let mut sum = 0.0;
            for i in 0..self.len {
                sum += self.data[i] * other.data[i];
            }
            sum
        }

        pub fn sum(&self) -> f64 {
            self.data.iter().sum()
        }

        pub fn max(&self) -> f64 {
            self.data.iter().cloned().fold(f64::NEG_INFINITY, f64::max)
        }

        pub fn min(&self) -> f64 {
            self.data.iter().cloned().fold(f64::INFINITY, f64::min)
        }
    }

    /// GPU tensor operations interface
    pub struct GpuTensor {
        shape: Vec<usize>,
        data: Vec<f64>,
        device_id: i32,
        is_on_device: bool,
    }

    impl GpuTensor {
        pub fn new(shape: Vec<usize>) -> Self {
            let size: usize = shape.iter().product();
            Self {
                shape,
                data: vec![0.0; size],
                device_id: 0,
                is_on_device: false,
            }
        }

        pub fn to_device(&mut self) {
            self.is_on_device = true;
        }

        pub fn to_host(&mut self) {
            self.is_on_device = false;
        }

        pub fn cuda_matmul(&self, other: &GpuTensor) -> GpuTensor {
            assert!(self.shape.len() >= 2 && other.shape.len() >= 2);
            let m = self.shape[self.shape.len() - 2];
            let k = self.shape[self.shape.len() - 1];
            let n = other.shape[other.shape.len() - 1];

            assert_eq!(k, other.shape[other.shape.len() - 2]);

            let mut result = GpuTensor::new(vec![m, n]);
            result.is_on_device = true;

            for i in 0..m {
                for j in 0..n {
                    let mut sum = 0.0;
                    for l in 0..k {
                        sum += self.data[i * k + l] * other.data[l * n + j];
                    }
                    result.data[i * n + j] = sum;
                }
            }

            result
        }

        pub fn cuda_relu(&mut self) {
            for elem in &mut self.data {
                *elem = elem.max(0.0);
            }
        }

        pub fn cuda_softmax(&mut self) {
            let last_dim = *self.shape.last().unwrap_or(&1);
            let batch_size = self.data.len() / last_dim;

            for b in 0..batch_size {
                let start = b * last_dim;
                let end = start + last_dim;
                let slice = &self.data[start..end];

                let max_val = slice.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
                let exp_sum: f64 = slice.iter().map(|x| (x - max_val).exp()).sum();

                for i in start..end {
                    self.data[i] = (self.data[i] - max_val).exp() / exp_sum;
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BOOK TENSOR
// ═══════════════════════════════════════════════════════════════════════════════

module orderbook {
    use super::*;

    /// Level 2 order book as tensor representation
    pub struct OrderBookTensor {
        pub symbol: String,
        pub bid_prices: Vec<f64>,
        pub bid_sizes: Vec<f64>,
        pub ask_prices: Vec<f64>,
        pub ask_sizes: Vec<f64>,
        pub depth: usize,
        pub timestamp: u64,
    }

    impl OrderBookTensor {
        pub fn new(symbol: &str, depth: usize) -> Self {
            Self {
                symbol: symbol.to_string(),
                bid_prices: vec![0.0; depth],
                bid_sizes: vec![0.0; depth],
                ask_prices: vec![0.0; depth],
                ask_sizes: vec![0.0; depth],
                depth,
                timestamp: 0,
            }
        }

        pub fn update_bid(&mut self, level: usize, price: f64, size: f64) {
            if level < self.depth {
                self.bid_prices[level] = price;
                self.bid_sizes[level] = size;
            }
        }

        pub fn update_ask(&mut self, level: usize, price: f64, size: f64) {
            if level < self.depth {
                self.ask_prices[level] = price;
                self.ask_sizes[level] = size;
            }
        }

        pub fn mid_price(&self) -> f64 {
            if self.bid_prices[0] > 0.0 && self.ask_prices[0] > 0.0 {
                (self.bid_prices[0] + self.ask_prices[0]) / 2.0
            } else {
                0.0
            }
        }

        pub fn spread(&self) -> f64 {
            if self.bid_prices[0] > 0.0 && self.ask_prices[0] > 0.0 {
                self.ask_prices[0] - self.bid_prices[0]
            } else {
                0.0
            }
        }

        pub fn weighted_mid(&self) -> f64 {
            let bid_vol = self.bid_sizes[0];
            let ask_vol = self.ask_sizes[0];
            let total = bid_vol + ask_vol;

            if total > 0.0 {
                (self.bid_prices[0] * ask_vol + self.ask_prices[0] * bid_vol) / total
            } else {
                self.mid_price()
            }
        }

        pub fn order_imbalance(&self) -> f64 {
            let bid_vol: f64 = self.bid_sizes.iter().sum();
            let ask_vol: f64 = self.ask_sizes.iter().sum();
            let total = bid_vol + ask_vol;

            if total > 0.0 {
                (bid_vol - ask_vol) / total
            } else {
                0.0
            }
        }

        pub fn depth_imbalance(&self, levels: usize) -> Vec<f64> {
            let levels = levels.min(self.depth);
            (0..levels).map(|i| {
                let total = self.bid_sizes[i] + self.ask_sizes[i];
                if total > 0.0 {
                    (self.bid_sizes[i] - self.ask_sizes[i]) / total
                } else {
                    0.0
                }
            }).collect()
        }

        pub fn to_tensor(&self) -> Vec<f64> {
            let mut tensor = Vec::with_capacity(self.depth * 4);
            tensor.extend(&self.bid_prices);
            tensor.extend(&self.bid_sizes);
            tensor.extend(&self.ask_prices);
            tensor.extend(&self.ask_sizes);
            tensor
        }

        pub fn vwap_bid(&self, levels: usize) -> f64 {
            let levels = levels.min(self.depth);
            let mut weighted_sum = 0.0;
            let mut volume_sum = 0.0;

            for i in 0..levels {
                weighted_sum += self.bid_prices[i] * self.bid_sizes[i];
                volume_sum += self.bid_sizes[i];
            }

            if volume_sum > 0.0 { weighted_sum / volume_sum } else { 0.0 }
        }

        pub fn vwap_ask(&self, levels: usize) -> f64 {
            let levels = levels.min(self.depth);
            let mut weighted_sum = 0.0;
            let mut volume_sum = 0.0;

            for i in 0..levels {
                weighted_sum += self.ask_prices[i] * self.ask_sizes[i];
                volume_sum += self.ask_sizes[i];
            }

            if volume_sum > 0.0 { weighted_sum / volume_sum } else { 0.0 }
        }
    }

    /// Order flow tensor for trade analysis
    pub struct OrderFlowTensor {
        pub trades: Vec<TradeEvent>,
        pub aggregation_period_ms: u64,
        pub buckets: Vec<FlowBucket>,
    }

    pub struct TradeEvent {
        pub timestamp: u64,
        pub price: f64,
        pub size: f64,
        pub is_buy: bool,
    }

    pub struct FlowBucket {
        pub start_time: u64,
        pub buy_volume: f64,
        pub sell_volume: f64,
        pub buy_count: i32,
        pub sell_count: i32,
        pub vwap: f64,
    }

    impl OrderFlowTensor {
        pub fn new(aggregation_ms: u64) -> Self {
            Self {
                trades: Vec::new(),
                aggregation_period_ms: aggregation_ms,
                buckets: Vec::new(),
            }
        }

        pub fn add_trade(&mut self, timestamp: u64, price: f64, size: f64, is_buy: bool) {
            self.trades.push(TradeEvent { timestamp, price, size, is_buy });
        }

        pub fn aggregate(&mut self) {
            if self.trades.is_empty() {
                return;
            }

            let min_time = self.trades.iter().map(|t| t.timestamp).min().unwrap();
            let max_time = self.trades.iter().map(|t| t.timestamp).max().unwrap();

            let mut buckets = Vec::new();
            let mut current_time = min_time;

            while current_time <= max_time {
                let end_time = current_time + self.aggregation_period_ms;

                let bucket_trades: Vec<_> = self.trades.iter()
                    .filter(|t| t.timestamp >= current_time && t.timestamp < end_time)
                    .collect();

                let mut buy_volume = 0.0;
                let mut sell_volume = 0.0;
                let mut buy_count = 0;
                let mut sell_count = 0;
                let mut weighted_sum = 0.0;
                let mut total_volume = 0.0;

                for trade in &bucket_trades {
                    if trade.is_buy {
                        buy_volume += trade.size;
                        buy_count += 1;
                    } else {
                        sell_volume += trade.size;
                        sell_count += 1;
                    }
                    weighted_sum += trade.price * trade.size;
                    total_volume += trade.size;
                }

                let vwap = if total_volume > 0.0 { weighted_sum / total_volume } else { 0.0 };

                buckets.push(FlowBucket {
                    start_time: current_time,
                    buy_volume,
                    sell_volume,
                    buy_count,
                    sell_count,
                    vwap,
                });

                current_time = end_time;
            }

            self.buckets = buckets;
        }

        pub fn cumulative_delta(&self) -> Vec<f64> {
            let mut cumsum = 0.0;
            self.buckets.iter().map(|b| {
                cumsum += b.buy_volume - b.sell_volume;
                cumsum
            }).collect()
        }

        pub fn volume_profile(&self) -> HashMap<i64, f64> {
            let mut profile = HashMap::new();

            for trade in &self.trades {
                let price_level = (trade.price * 100.0).round() as i64;
                *profile.entry(price_level).or_insert(0.0) += trade.size;
            }

            profile
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONVOLUTIONAL LAYERS
// ═══════════════════════════════════════════════════════════════════════════════

module conv {
    use super::*;

    /// 1D Convolution for time series
    pub struct Conv1D {
        pub in_channels: usize,
        pub out_channels: usize,
        pub kernel_size: usize,
        pub stride: usize,
        pub padding: usize,
        pub weights: Vec<Vec<Vec<f64>>>,
        pub bias: Vec<f64>,
    }

    impl Conv1D {
        pub fn new(in_ch: usize, out_ch: usize, kernel: usize) -> Self {
            let scale = (2.0 / (in_ch * kernel) as f64).sqrt();
            let mut weights = vec![vec![vec![0.0; kernel]; in_ch]; out_ch];

            for oc in 0..out_ch {
                for ic in 0..in_ch {
                    for k in 0..kernel {
                        weights[oc][ic][k] = random::uniform(-scale, scale);
                    }
                }
            }

            Self {
                in_channels: in_ch,
                out_channels: out_ch,
                kernel_size: kernel,
                stride: 1,
                padding: kernel / 2,
                weights,
                bias: vec![0.0; out_ch],
            }
        }

        pub fn forward(&self, input: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let seq_len = input[0].len();
            let out_len = (seq_len + 2 * self.padding - self.kernel_size) / self.stride + 1;

            let mut output = vec![vec![0.0; out_len]; self.out_channels];

            for oc in 0..self.out_channels {
                for i in 0..out_len {
                    let mut sum = self.bias[oc];

                    for ic in 0..self.in_channels {
                        for k in 0..self.kernel_size {
                            let pos = i * self.stride + k;
                            if pos >= self.padding && pos < seq_len + self.padding {
                                let idx = pos - self.padding;
                                sum += input[ic][idx] * self.weights[oc][ic][k];
                            }
                        }
                    }

                    output[oc][i] = sum;
                }
            }

            output
        }
    }

    /// 2D Convolution for market heatmaps
    pub struct Conv2D {
        pub in_channels: usize,
        pub out_channels: usize,
        pub kernel_h: usize,
        pub kernel_w: usize,
        pub stride: (usize, usize),
        pub padding: (usize, usize),
        pub weights: Vec<Vec<Vec<Vec<f64>>>>,
        pub bias: Vec<f64>,
    }

    impl Conv2D {
        pub fn new(in_ch: usize, out_ch: usize, kernel_h: usize, kernel_w: usize) -> Self {
            let scale = (2.0 / (in_ch * kernel_h * kernel_w) as f64).sqrt();
            let mut weights = vec![vec![vec![vec![0.0; kernel_w]; kernel_h]; in_ch]; out_ch];

            for oc in 0..out_ch {
                for ic in 0..in_ch {
                    for kh in 0..kernel_h {
                        for kw in 0..kernel_w {
                            weights[oc][ic][kh][kw] = random::uniform(-scale, scale);
                        }
                    }
                }
            }

            Self {
                in_channels: in_ch,
                out_channels: out_ch,
                kernel_h,
                kernel_w,
                stride: (1, 1),
                padding: (kernel_h / 2, kernel_w / 2),
                weights,
                bias: vec![0.0; out_ch],
            }
        }

        pub fn forward(&self, input: &[Vec<Vec<f64>>]) -> Vec<Vec<Vec<f64>>> {
            let in_h = input[0].len();
            let in_w = input[0][0].len();
            let out_h = (in_h + 2 * self.padding.0 - self.kernel_h) / self.stride.0 + 1;
            let out_w = (in_w + 2 * self.padding.1 - self.kernel_w) / self.stride.1 + 1;

            let mut output = vec![vec![vec![0.0; out_w]; out_h]; self.out_channels];

            for oc in 0..self.out_channels {
                for oh in 0..out_h {
                    for ow in 0..out_w {
                        let mut sum = self.bias[oc];

                        for ic in 0..self.in_channels {
                            for kh in 0..self.kernel_h {
                                for kw in 0..self.kernel_w {
                                    let ih = oh * self.stride.0 + kh;
                                    let iw = ow * self.stride.1 + kw;

                                    if ih >= self.padding.0 && ih < in_h + self.padding.0 &&
                                       iw >= self.padding.1 && iw < in_w + self.padding.1 {
                                        let pi = ih - self.padding.0;
                                        let pj = iw - self.padding.1;
                                        sum += input[ic][pi][pj] * self.weights[oc][ic][kh][kw];
                                    }
                                }
                            }
                        }

                        output[oc][oh][ow] = sum;
                    }
                }
            }

            output
        }
    }

    /// Temporal Convolutional Network
    pub struct TCN {
        pub layers: Vec<Conv1D>,
        pub dilations: Vec<usize>,
        pub residual: bool,
    }

    impl TCN {
        pub fn new(in_channels: usize, hidden: usize, kernel: usize, num_layers: usize) -> Self {
            let mut layers = Vec::new();
            let mut dilations = Vec::new();

            layers.push(Conv1D::new(in_channels, hidden, kernel));
            dilations.push(1);

            for i in 1..num_layers {
                let dilation = 2usize.pow(i as u32);
                let mut conv = Conv1D::new(hidden, hidden, kernel);
                conv.padding = dilation * (kernel / 2);
                layers.push(conv);
                dilations.push(dilation);
            }

            Self {
                layers,
                dilations,
                residual: true,
            }
        }

        pub fn forward(&self, input: &[Vec<f64>]) -> Vec<Vec<f64>> {
            let mut x = input.to_vec();

            for (i, layer) in self.layers.iter().enumerate() {
                let out = layer.forward(&x);

                let activated: Vec<Vec<f64>> = out.iter()
                    .map(|ch| ch.iter().map(|&v| v.max(0.0)).collect())
                    .collect();

                if self.residual && i > 0 && x.len() == activated.len() {
                    x = x.iter().zip(&activated)
                        .map(|(a, b)| {
                            let len = a.len().min(b.len());
                            (0..len).map(|j| a[j] + b[j]).collect()
                        })
                        .collect();
                } else {
                    x = activated;
                }
            }

            x
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIGH-FREQUENCY TRADING INFRASTRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// Order book representation with price-time priority
pub mod order_book {
    use super::*;

    /// Single order in the book
    pub struct Order {
        pub id: u64,
        pub price: f64,
        pub quantity: f64,
        pub side: Side,
        pub timestamp_ns: u64,
        pub order_type: OrderType,
    }

    pub enum Side { Bid, Ask }
    pub enum OrderType { Limit, Market, IOC, FOK, PostOnly }

    /// Price level aggregation
    pub struct PriceLevel {
        pub price: f64,
        pub total_quantity: f64,
        pub order_count: usize,
        pub orders: Vec<Order>,
    }

    impl PriceLevel {
        pub fn new(price: f64) -> Self {
            Self { price, total_quantity: 0.0, order_count: 0, orders: Vec::new() }
        }

        pub fn add_order(&mut self, order: Order) {
            self.total_quantity += order.quantity;
            self.order_count += 1;
            self.orders.push(order);
        }

        pub fn remove_order(&mut self, order_id: u64) -> Option<Order> {
            if let Some(idx) = self.orders.iter().position(|o| o.id == order_id) {
                let order = self.orders.remove(idx);
                self.total_quantity -= order.quantity;
                self.order_count -= 1;
                Some(order)
            } else { None }
        }
    }

    /// Full limit order book with L3 depth
    pub struct LimitOrderBook {
        pub symbol: String,
        pub bids: Vec<PriceLevel>,
        pub asks: Vec<PriceLevel>,
        pub last_update_ns: u64,
        pub sequence_num: u64,
    }

    impl LimitOrderBook {
        pub fn new(symbol: &str) -> Self {
            Self {
                symbol: symbol.to_string(),
                bids: Vec::new(),
                asks: Vec::new(),
                last_update_ns: 0,
                sequence_num: 0,
            }
        }

        pub fn best_bid(&self) -> Option<f64> {
            self.bids.first().map(|l| l.price)
        }

        pub fn best_ask(&self) -> Option<f64> {
            self.asks.first().map(|l| l.price)
        }

        pub fn mid_price(&self) -> Option<f64> {
            match (self.best_bid(), self.best_ask()) {
                (Some(b), Some(a)) => Some((b + a) / 2.0),
                _ => None,
            }
        }

        pub fn spread(&self) -> Option<f64> {
            match (self.best_bid(), self.best_ask()) {
                (Some(b), Some(a)) => Some(a - b),
                _ => None,
            }
        }

        pub fn spread_bps(&self) -> Option<f64> {
            match (self.spread(), self.mid_price()) {
                (Some(s), Some(m)) if m > 0.0 => Some(s / m * 10000.0),
                _ => None,
            }
        }

        /// Volume-weighted mid price
        pub fn vwap_mid(&self) -> Option<f64> {
            let bb = self.bids.first()?;
            let ba = self.asks.first()?;
            let total = bb.total_quantity + ba.total_quantity;
            if total > 0.0 {
                Some((bb.price * ba.total_quantity + ba.price * bb.total_quantity) / total)
            } else { None }
        }

        /// Microprice (imbalance-weighted)
        pub fn microprice(&self) -> Option<f64> {
            let bb = self.bids.first()?;
            let ba = self.asks.first()?;
            let imb = bb.total_quantity / (bb.total_quantity + ba.total_quantity);
            Some(ba.price * imb + bb.price * (1.0 - imb))
        }

        /// Book imbalance [-1, 1]
        pub fn imbalance(&self, depth: usize) -> f64 {
            let bid_vol: f64 = self.bids.iter().take(depth).map(|l| l.total_quantity).sum();
            let ask_vol: f64 = self.asks.iter().take(depth).map(|l| l.total_quantity).sum();
            let total = bid_vol + ask_vol;
            if total > 0.0 { (bid_vol - ask_vol) / total } else { 0.0 }
        }

        /// Depth available at price impact
        pub fn depth_at_impact(&self, side: &Side, bps: f64) -> f64 {
            let mid = match self.mid_price() { Some(m) => m, None => return 0.0 };
            let threshold = mid * bps / 10000.0;
            let levels = match side { Side::Bid => &self.asks, Side::Ask => &self.bids };
            let mut volume = 0.0;
            for level in levels {
                let dist = match side {
                    Side::Bid => level.price - mid,
                    Side::Ask => mid - level.price,
                };
                if dist.abs() <= threshold { volume += level.total_quantity; }
                else { break; }
            }
            volume
        }

        /// Estimated price impact for given size
        pub fn price_impact(&self, side: &Side, size: f64) -> f64 {
            let levels = match side { Side::Bid => &self.asks, Side::Ask => &self.bids };
            let start_price = match side {
                Side::Bid => self.best_ask().unwrap_or(0.0),
                Side::Ask => self.best_bid().unwrap_or(0.0),
            };
            let mut remaining = size;
            let mut last_price = start_price;
            for level in levels {
                if remaining <= 0.0 { break; }
                let filled = remaining.min(level.total_quantity);
                last_price = level.price;
                remaining -= filled;
            }
            (last_price - start_price).abs()
        }
    }

    /// Order book snapshot for analysis
    pub struct BookSnapshot {
        pub timestamp_ns: u64,
        pub bid_prices: Vec<f64>,
        pub bid_sizes: Vec<f64>,
        pub ask_prices: Vec<f64>,
        pub ask_sizes: Vec<f64>,
    }

    impl BookSnapshot {
        pub fn from_book(book: &LimitOrderBook, depth: usize) -> Self {
            Self {
                timestamp_ns: book.last_update_ns,
                bid_prices: book.bids.iter().take(depth).map(|l| l.price).collect(),
                bid_sizes: book.bids.iter().take(depth).map(|l| l.total_quantity).collect(),
                ask_prices: book.asks.iter().take(depth).map(|l| l.price).collect(),
                ask_sizes: book.asks.iter().take(depth).map(|l| l.total_quantity).collect(),
            }
        }

        pub fn to_feature_vector(&self) -> Vec<f64> {
            let mut features = Vec::new();
            features.extend(&self.bid_prices);
            features.extend(&self.bid_sizes);
            features.extend(&self.ask_prices);
            features.extend(&self.ask_sizes);
            features
        }
    }
}

/// Market microstructure analysis
pub mod microstructure {
    use super::*;

    /// Trade classification (Lee-Ready algorithm)
    pub struct TradeClassifier {
        pub quote_delay_ns: u64,
        prev_mid: f64,
    }

    impl TradeClassifier {
        pub fn new(quote_delay_ns: u64) -> Self {
            Self { quote_delay_ns, prev_mid: 0.0 }
        }

        /// Classify trade as buy (+1) or sell (-1) using tick test
        pub fn tick_test(&mut self, price: f64) -> i32 {
            let sign = if price > self.prev_mid { 1 }
                       else if price < self.prev_mid { -1 }
                       else { 0 };
            self.prev_mid = price;
            sign
        }

        /// Lee-Ready: quote test with tick test fallback
        pub fn lee_ready(&mut self, price: f64, bid: f64, ask: f64) -> i32 {
            let mid = (bid + ask) / 2.0;
            if price > mid { 1 }
            else if price < mid { -1 }
            else { self.tick_test(price) }
        }
    }

    /// Kyle's Lambda (price impact coefficient)
    pub struct KyleLambda {
        pub lambda: f64,
        pub r_squared: f64,
    }

    impl KyleLambda {
        /// Estimate from signed volume and price changes
        pub fn estimate(signed_volumes: &[f64], price_changes: &[f64]) -> Self {
            let n = signed_volumes.len().min(price_changes.len()) as f64;
            if n < 2.0 { return Self { lambda: 0.0, r_squared: 0.0 }; }

            let sum_xy: f64 = signed_volumes.iter().zip(price_changes)
                .map(|(v, p)| v * p).sum();
            let sum_x: f64 = signed_volumes.iter().sum();
            let sum_y: f64 = price_changes.iter().sum();
            let sum_xx: f64 = signed_volumes.iter().map(|v| v * v).sum();
            let sum_yy: f64 = price_changes.iter().map(|p| p * p).sum();

            let denom = n * sum_xx - sum_x * sum_x;
            let lambda = if denom.abs() > 1e-10 {
                (n * sum_xy - sum_x * sum_y) / denom
            } else { 0.0 };

            let ss_tot = sum_yy - sum_y * sum_y / n;
            let ss_res = sum_yy - lambda * sum_xy - (sum_y - lambda * sum_x).powi(2) / n;
            let r_squared = if ss_tot > 0.0 { 1.0 - ss_res / ss_tot } else { 0.0 };

            Self { lambda: lambda.max(0.0), r_squared: r_squared.max(0.0).min(1.0) }
        }
    }

    /// Roll's spread estimator
    pub fn roll_spread(price_changes: &[f64]) -> f64 {
        if price_changes.len() < 2 { return 0.0; }
        let mut cov = 0.0;
        for i in 1..price_changes.len() {
            cov += price_changes[i] * price_changes[i-1];
        }
        cov /= (price_changes.len() - 1) as f64;
        if cov < 0.0 { 2.0 * (-cov).sqrt() } else { 0.0 }
    }

    /// Amihud illiquidity measure
    pub fn amihud_illiquidity(returns: &[f64], volumes: &[f64]) -> f64 {
        let n = returns.len().min(volumes.len());
        if n == 0 { return 0.0; }
        let sum: f64 = returns.iter().zip(volumes).take(n)
            .filter(|(_, v)| **v > 0.0)
            .map(|(r, v)| r.abs() / v)
            .sum();
        sum / n as f64
    }

    /// Realized volatility from high-frequency returns
    pub struct RealizedVolatility {
        pub rv: f64,
        pub bv: f64,  // Bipower variation (jump-robust)
        pub jump_test: f64,
    }

    impl RealizedVolatility {
        pub fn compute(returns: &[f64]) -> Self {
            let n = returns.len();
            if n < 3 { return Self { rv: 0.0, bv: 0.0, jump_test: 0.0 }; }

            let rv: f64 = returns.iter().map(|r| r * r).sum();

            // Bipower variation
            let mu1 = (2.0_f64 / PI).sqrt();
            let bv: f64 = returns.windows(2)
                .map(|w| w[0].abs() * w[1].abs())
                .sum::<f64>() * PI / 2.0;

            // Jump test statistic
            let jump_test = if bv > 0.0 { (rv - bv) / bv } else { 0.0 };

            Self { rv, bv, jump_test }
        }
    }

    /// Order flow toxicity (VPIN approximation)
    pub struct VPIN {
        pub bucket_size: f64,
        pub num_buckets: usize,
        buckets: Vec<(f64, f64)>,  // (buy_volume, sell_volume)
    }

    impl VPIN {
        pub fn new(bucket_size: f64, num_buckets: usize) -> Self {
            Self { bucket_size, num_buckets, buckets: Vec::new() }
        }

        pub fn add_trade(&mut self, volume: f64, is_buy: bool) {
            if self.buckets.is_empty() {
                self.buckets.push((0.0, 0.0));
            }
            let last = self.buckets.last_mut().unwrap();
            let current_vol = last.0 + last.1;

            if current_vol + volume > self.bucket_size {
                let remaining = self.bucket_size - current_vol;
                if is_buy { last.0 += remaining; } else { last.1 += remaining; }
                self.buckets.push((0.0, 0.0));
                if self.buckets.len() > self.num_buckets {
                    self.buckets.remove(0);
                }
                let excess = volume - remaining;
                let new_last = self.buckets.last_mut().unwrap();
                if is_buy { new_last.0 += excess; } else { new_last.1 += excess; }
            } else {
                if is_buy { last.0 += volume; } else { last.1 += volume; }
            }
        }

        pub fn compute(&self) -> f64 {
            if self.buckets.len() < self.num_buckets { return 0.0; }
            let sum_imbalance: f64 = self.buckets.iter()
                .map(|(b, s)| (b - s).abs())
                .sum();
            let sum_volume: f64 = self.buckets.iter()
                .map(|(b, s)| b + s)
                .sum();
            if sum_volume > 0.0 { sum_imbalance / sum_volume } else { 0.0 }
        }
    }
}

/// Smart order routing
pub mod smart_routing {
    use super::*;

    /// Venue characteristics
    pub struct Venue {
        pub id: String,
        pub latency_ns: u64,
        pub maker_fee: f64,
        pub taker_fee: f64,
        pub rebate: f64,
        pub fill_rate: f64,
        pub avg_queue_position: f64,
    }

    /// Route decision
    pub struct RouteDecision {
        pub venue_id: String,
        pub quantity: f64,
        pub order_type: String,
        pub expected_cost: f64,
    }

    /// Smart Order Router
    pub struct SmartOrderRouter {
        pub venues: Vec<Venue>,
        pub latency_weight: f64,
        pub cost_weight: f64,
        pub fill_weight: f64,
    }

    impl SmartOrderRouter {
        pub fn new() -> Self {
            Self {
                venues: Vec::new(),
                latency_weight: 0.3,
                cost_weight: 0.4,
                fill_weight: 0.3,
            }
        }

        pub fn add_venue(&mut self, venue: Venue) {
            self.venues.push(venue);
        }

        /// Score venue for aggressive order
        fn score_venue_aggressive(&self, venue: &Venue, urgency: f64) -> f64 {
            let latency_score = 1.0 / (1.0 + venue.latency_ns as f64 / 1_000_000.0);
            let cost_score = 1.0 - venue.taker_fee.min(0.01) / 0.01;
            let fill_score = venue.fill_rate;

            let base = self.latency_weight * latency_score
                     + self.cost_weight * cost_score
                     + self.fill_weight * fill_score;

            // Urgency increases latency importance
            base + urgency * latency_score * 0.5
        }

        /// Score venue for passive order
        fn score_venue_passive(&self, venue: &Venue) -> f64 {
            let rebate_score = (venue.rebate + 0.005) / 0.005;  // Normalize rebate
            let queue_score = 1.0 / (1.0 + venue.avg_queue_position / 100.0);
            let fill_score = venue.fill_rate;

            0.4 * rebate_score + 0.3 * queue_score + 0.3 * fill_score
        }

        /// Route order across venues
        pub fn route(&self, total_qty: f64, is_aggressive: bool, urgency: f64) -> Vec<RouteDecision> {
            if self.venues.is_empty() { return Vec::new(); }

            let mut scored: Vec<(&Venue, f64)> = self.venues.iter()
                .map(|v| {
                    let score = if is_aggressive {
                        self.score_venue_aggressive(v, urgency)
                    } else {
                        self.score_venue_passive(v)
                    };
                    (v, score)
                })
                .collect();

            scored.sort_by(|a, b| b.1.partial_cmp(&a.1).unwrap_or(std::cmp::Ordering::Equal));

            // Allocate: 50% to best, 30% to second, 20% to third (if available)
            let allocations = [0.5, 0.3, 0.2];
            let mut decisions = Vec::new();
            let mut remaining = total_qty;

            for (i, (venue, _score)) in scored.iter().take(3).enumerate() {
                let qty = if i == scored.len().min(3) - 1 {
                    remaining
                } else {
                    (total_qty * allocations[i]).min(remaining)
                };
                if qty > 0.0 {
                    let fee = if is_aggressive { venue.taker_fee } else { -venue.rebate };
                    decisions.push(RouteDecision {
                        venue_id: venue.id.clone(),
                        quantity: qty,
                        order_type: if is_aggressive { "Market".to_string() } else { "Limit".to_string() },
                        expected_cost: qty * fee,
                    });
                    remaining -= qty;
                }
            }

            decisions
        }
    }

    /// Execution quality analyzer
    pub struct ExecutionAnalyzer {
        pub executions: Vec<Execution>,
    }

    pub struct Execution {
        pub venue: String,
        pub price: f64,
        pub quantity: f64,
        pub arrival_price: f64,
        pub timestamp_ns: u64,
    }

    impl ExecutionAnalyzer {
        pub fn new() -> Self {
            Self { executions: Vec::new() }
        }

        pub fn add(&mut self, exec: Execution) {
            self.executions.push(exec);
        }

        /// Implementation shortfall
        pub fn implementation_shortfall(&self) -> f64 {
            if self.executions.is_empty() { return 0.0; }
            let total_qty: f64 = self.executions.iter().map(|e| e.quantity).sum();
            let vwap: f64 = self.executions.iter()
                .map(|e| e.price * e.quantity)
                .sum::<f64>() / total_qty;
            let arrival = self.executions[0].arrival_price;
            (vwap - arrival) / arrival * 10000.0  // In bps
        }

        /// Execution VWAP
        pub fn vwap(&self) -> f64 {
            let total_qty: f64 = self.executions.iter().map(|e| e.quantity).sum();
            if total_qty > 0.0 {
                self.executions.iter().map(|e| e.price * e.quantity).sum::<f64>() / total_qty
            } else { 0.0 }
        }

        /// Venue breakdown
        pub fn venue_stats(&self) -> HashMap<String, (f64, f64)> {
            let mut stats: HashMap<String, (f64, f64)> = HashMap::new();
            for exec in &self.executions {
                let entry = stats.entry(exec.venue.clone()).or_insert((0.0, 0.0));
                entry.0 += exec.quantity;
                entry.1 += exec.price * exec.quantity;
            }
            for (_, (qty, notional)) in stats.iter_mut() {
                if *qty > 0.0 { *notional /= *qty; }  // Convert to avg price
            }
            stats
        }
    }
}

/// Latency optimization and measurement
pub mod latency {
    use super::*;

    /// Latency histogram with nanosecond precision
    pub struct LatencyHistogram {
        buckets: Vec<u64>,
        bucket_width_ns: u64,
        count: u64,
        sum_ns: u64,
        min_ns: u64,
        max_ns: u64,
    }

    impl LatencyHistogram {
        pub fn new(bucket_width_ns: u64, num_buckets: usize) -> Self {
            Self {
                buckets: vec![0; num_buckets],
                bucket_width_ns,
                count: 0,
                sum_ns: 0,
                min_ns: u64::MAX,
                max_ns: 0,
            }
        }

        pub fn record(&mut self, latency_ns: u64) {
            let idx = (latency_ns / self.bucket_width_ns) as usize;
            if idx < self.buckets.len() {
                self.buckets[idx] += 1;
            } else {
                *self.buckets.last_mut().unwrap() += 1;
            }
            self.count += 1;
            self.sum_ns += latency_ns;
            self.min_ns = self.min_ns.min(latency_ns);
            self.max_ns = self.max_ns.max(latency_ns);
        }

        pub fn mean_ns(&self) -> f64 {
            if self.count > 0 { self.sum_ns as f64 / self.count as f64 } else { 0.0 }
        }

        pub fn percentile(&self, p: f64) -> u64 {
            let target = (self.count as f64 * p) as u64;
            let mut cumulative = 0u64;
            for (i, &count) in self.buckets.iter().enumerate() {
                cumulative += count;
                if cumulative >= target {
                    return (i as u64 + 1) * self.bucket_width_ns;
                }
            }
            self.max_ns
        }

        pub fn p50(&self) -> u64 { self.percentile(0.50) }
        pub fn p95(&self) -> u64 { self.percentile(0.95) }
        pub fn p99(&self) -> u64 { self.percentile(0.99) }
        pub fn p999(&self) -> u64 { self.percentile(0.999) }
    }

    /// Timestamping utilities
    pub struct TimeStamper {
        pub rdtsc_freq_ghz: f64,
    }

    impl TimeStamper {
        pub fn new(freq_ghz: f64) -> Self {
            Self { rdtsc_freq_ghz: freq_ghz }
        }

        /// Convert TSC ticks to nanoseconds
        pub fn tsc_to_ns(&self, ticks: u64) -> u64 {
            (ticks as f64 / self.rdtsc_freq_ghz) as u64
        }

        /// Estimate network one-way delay from RTT
        pub fn estimate_owd(rtt_ns: u64) -> u64 {
            rtt_ns / 2
        }
    }

    /// Jitter analysis
    pub struct JitterAnalyzer {
        samples: Vec<u64>,
        max_samples: usize,
    }

    impl JitterAnalyzer {
        pub fn new(max_samples: usize) -> Self {
            Self { samples: Vec::new(), max_samples }
        }

        pub fn add_sample(&mut self, latency_ns: u64) {
            self.samples.push(latency_ns);
            if self.samples.len() > self.max_samples {
                self.samples.remove(0);
            }
        }

        /// Inter-arrival jitter (RFC 3550 style)
        pub fn compute_jitter(&self) -> f64 {
            if self.samples.len() < 2 { return 0.0; }
            let mut jitter = 0.0;
            for i in 1..self.samples.len() {
                let diff = (self.samples[i] as i64 - self.samples[i-1] as i64).abs() as f64;
                jitter += (diff - jitter) / 16.0;
            }
            jitter
        }

        /// Standard deviation of latencies
        pub fn std_dev(&self) -> f64 {
            if self.samples.len() < 2 { return 0.0; }
            let mean = self.samples.iter().sum::<u64>() as f64 / self.samples.len() as f64;
            let variance = self.samples.iter()
                .map(|&s| (s as f64 - mean).powi(2))
                .sum::<f64>() / self.samples.len() as f64;
            variance.sqrt()
        }
    }
}

/// Market impact models
pub mod market_impact {
    use super::*;

    /// Almgren-Chriss temporary impact model
    pub struct AlmgrenChriss {
        pub eta: f64,      // Temporary impact coefficient
        pub gamma: f64,    // Permanent impact coefficient
        pub sigma: f64,    // Volatility
        pub lambda: f64,   // Risk aversion
    }

    impl AlmgrenChriss {
        pub fn new(eta: f64, gamma: f64, sigma: f64, lambda: f64) -> Self {
            Self { eta, gamma, sigma, lambda }
        }

        /// Optimal execution trajectory
        pub fn optimal_trajectory(&self, x0: f64, t_horizon: f64, n_steps: usize) -> Vec<f64> {
            let dt = t_horizon / n_steps as f64;
            let kappa = (self.lambda * self.sigma.powi(2) / self.eta).sqrt();

            let mut trajectory = vec![x0];
            for i in 1..=n_steps {
                let t = i as f64 * dt;
                let remaining = x0 * (kappa * (t_horizon - t)).sinh() / (kappa * t_horizon).sinh();
                trajectory.push(remaining);
            }
            trajectory
        }

        /// Temporary impact for trade rate
        pub fn temporary_impact(&self, trade_rate: f64) -> f64 {
            self.eta * trade_rate
        }

        /// Permanent impact
        pub fn permanent_impact(&self, quantity: f64) -> f64 {
            self.gamma * quantity
        }

        /// Expected execution cost
        pub fn expected_cost(&self, x0: f64, t_horizon: f64) -> f64 {
            let kappa = (self.lambda * self.sigma.powi(2) / self.eta).sqrt();
            let tanh_kt = (kappa * t_horizon).tanh();

            0.5 * self.gamma * x0.powi(2)
            + self.eta * x0.powi(2) * kappa * (1.0 - tanh_kt.powi(2)) / (2.0 * tanh_kt)
        }
    }

    /// Square-root impact model
    pub struct SqrtImpact {
        pub sigma: f64,     // Volatility
        pub adv: f64,       // Average daily volume
        pub impact_coef: f64,
    }

    impl SqrtImpact {
        pub fn new(sigma: f64, adv: f64) -> Self {
            Self { sigma, adv, impact_coef: 0.1 }  // Typical coefficient
        }

        /// Price impact for given trade size
        pub fn impact(&self, quantity: f64, is_buy: bool) -> f64 {
            let sign = if is_buy { 1.0 } else { -1.0 };
            sign * self.impact_coef * self.sigma * (quantity.abs() / self.adv).sqrt()
        }

        /// Optimal slice size for target impact
        pub fn optimal_slice(&self, target_impact_bps: f64) -> f64 {
            let target = target_impact_bps / 10000.0;
            let ratio = (target / (self.impact_coef * self.sigma)).powi(2);
            ratio * self.adv
        }
    }

    /// Obizhaeva-Wang transient impact
    pub struct ObizhaevaWang {
        pub kappa: f64,     // Decay rate
        pub lambda_0: f64,  // Initial impact
    }

    impl ObizhaevaWang {
        pub fn new(kappa: f64, lambda_0: f64) -> Self {
            Self { kappa, lambda_0 }
        }

        /// Transient impact at time t after trade
        pub fn transient_impact(&self, quantity: f64, t: f64) -> f64 {
            self.lambda_0 * quantity * (-self.kappa * t).exp()
        }

        /// Optimal trade schedule for n slices
        pub fn optimal_schedule(&self, x0: f64, n: usize, dt: f64) -> Vec<f64> {
            let decay = (-self.kappa * dt).exp();
            let sum: f64 = (0..n).map(|i| decay.powi(i as i32)).sum();
            let base_trade = x0 / sum;

            (0..n).map(|i| base_trade * decay.powi(i as i32)).collect()
        }
    }
}

/// Tick-by-tick processing
pub mod tick_processor {
    use super::*;

    /// Single market tick
    pub struct Tick {
        pub timestamp_ns: u64,
        pub price: f64,
        pub size: f64,
        pub side: i8,  // 1=buy, -1=sell, 0=unknown
        pub flags: u32,
    }

    /// Tick aggregator
    pub struct TickAggregator {
        ticks: Vec<Tick>,
        bar_duration_ns: u64,
        current_bar_start: u64,
    }

    impl TickAggregator {
        pub fn new(bar_duration_ns: u64) -> Self {
            Self {
                ticks: Vec::new(),
                bar_duration_ns,
                current_bar_start: 0,
            }
        }

        pub fn add_tick(&mut self, tick: Tick) -> Option<Bar> {
            if self.current_bar_start == 0 {
                self.current_bar_start = tick.timestamp_ns;
            }

            if tick.timestamp_ns >= self.current_bar_start + self.bar_duration_ns {
                let bar = self.finalize_bar();
                self.current_bar_start = tick.timestamp_ns;
                self.ticks.clear();
                self.ticks.push(tick);
                Some(bar)
            } else {
                self.ticks.push(tick);
                None
            }
        }

        fn finalize_bar(&self) -> Bar {
            if self.ticks.is_empty() {
                return Bar::empty(self.current_bar_start);
            }

            let open = self.ticks.first().unwrap().price;
            let close = self.ticks.last().unwrap().price;
            let high = self.ticks.iter().map(|t| t.price).fold(f64::MIN, f64::max);
            let low = self.ticks.iter().map(|t| t.price).fold(f64::MAX, f64::min);
            let volume: f64 = self.ticks.iter().map(|t| t.size).sum();
            let buy_volume: f64 = self.ticks.iter()
                .filter(|t| t.side > 0)
                .map(|t| t.size)
                .sum();
            let vwap = if volume > 0.0 {
                self.ticks.iter().map(|t| t.price * t.size).sum::<f64>() / volume
            } else { close };

            Bar {
                timestamp_ns: self.current_bar_start,
                open, high, low, close,
                volume, buy_volume,
                vwap,
                tick_count: self.ticks.len() as u32,
            }
        }
    }

    /// OHLCV bar
    pub struct Bar {
        pub timestamp_ns: u64,
        pub open: f64,
        pub high: f64,
        pub low: f64,
        pub close: f64,
        pub volume: f64,
        pub buy_volume: f64,
        pub vwap: f64,
        pub tick_count: u32,
    }

    impl Bar {
        pub fn empty(timestamp_ns: u64) -> Self {
            Self {
                timestamp_ns,
                open: 0.0, high: 0.0, low: 0.0, close: 0.0,
                volume: 0.0, buy_volume: 0.0, vwap: 0.0, tick_count: 0,
            }
        }

        pub fn range(&self) -> f64 { self.high - self.low }
        pub fn body(&self) -> f64 { (self.close - self.open).abs() }
        pub fn is_bullish(&self) -> bool { self.close > self.open }
        pub fn buy_ratio(&self) -> f64 {
            if self.volume > 0.0 { self.buy_volume / self.volume } else { 0.5 }
        }
    }

    /// Volume bar generator (bars based on volume, not time)
    pub struct VolumeBarGenerator {
        volume_threshold: f64,
        accumulated: Vec<Tick>,
        accumulated_volume: f64,
    }

    impl VolumeBarGenerator {
        pub fn new(volume_threshold: f64) -> Self {
            Self {
                volume_threshold,
                accumulated: Vec::new(),
                accumulated_volume: 0.0,
            }
        }

        pub fn add_tick(&mut self, tick: Tick) -> Option<Bar> {
            self.accumulated_volume += tick.size;
            self.accumulated.push(tick);

            if self.accumulated_volume >= self.volume_threshold {
                let bar = self.finalize();
                self.accumulated.clear();
                self.accumulated_volume = 0.0;
                Some(bar)
            } else { None }
        }

        fn finalize(&self) -> Bar {
            let open = self.accumulated.first().unwrap().price;
            let close = self.accumulated.last().unwrap().price;
            let high = self.accumulated.iter().map(|t| t.price).fold(f64::MIN, f64::max);
            let low = self.accumulated.iter().map(|t| t.price).fold(f64::MAX, f64::min);
            let volume = self.accumulated_volume;
            let buy_volume: f64 = self.accumulated.iter()
                .filter(|t| t.side > 0)
                .map(|t| t.size).sum();
            let vwap = self.accumulated.iter().map(|t| t.price * t.size).sum::<f64>() / volume;

            Bar {
                timestamp_ns: self.accumulated.first().unwrap().timestamp_ns,
                open, high, low, close,
                volume, buy_volume, vwap,
                tick_count: self.accumulated.len() as u32,
            }
        }
    }

    /// Dollar bar generator
    pub struct DollarBarGenerator {
        dollar_threshold: f64,
        accumulated: Vec<Tick>,
        accumulated_dollars: f64,
    }

    impl DollarBarGenerator {
        pub fn new(dollar_threshold: f64) -> Self {
            Self {
                dollar_threshold,
                accumulated: Vec::new(),
                accumulated_dollars: 0.0,
            }
        }

        pub fn add_tick(&mut self, tick: Tick) -> Option<Bar> {
            self.accumulated_dollars += tick.price * tick.size;
            self.accumulated.push(tick);

            if self.accumulated_dollars >= self.dollar_threshold {
                let bar = self.finalize();
                self.accumulated.clear();
                self.accumulated_dollars = 0.0;
                Some(bar)
            } else { None }
        }

        fn finalize(&self) -> Bar {
            let open = self.accumulated.first().unwrap().price;
            let close = self.accumulated.last().unwrap().price;
            let high = self.accumulated.iter().map(|t| t.price).fold(f64::MIN, f64::max);
            let low = self.accumulated.iter().map(|t| t.price).fold(f64::MAX, f64::min);
            let volume: f64 = self.accumulated.iter().map(|t| t.size).sum();
            let buy_volume: f64 = self.accumulated.iter()
                .filter(|t| t.side > 0)
                .map(|t| t.size).sum();
            let vwap = self.accumulated_dollars / volume;

            Bar {
                timestamp_ns: self.accumulated.first().unwrap().timestamp_ns,
                open, high, low, close,
                volume, buy_volume, vwap,
                tick_count: self.accumulated.len() as u32,
            }
        }
    }
}

/// Order flow analysis
pub mod order_flow {
    use super::*;

    /// Cumulative delta tracker
    pub struct CumulativeDelta {
        pub delta: f64,
        pub max_delta: f64,
        pub min_delta: f64,
        history: Vec<f64>,
    }

    impl CumulativeDelta {
        pub fn new() -> Self {
            Self { delta: 0.0, max_delta: 0.0, min_delta: 0.0, history: Vec::new() }
        }

        pub fn update(&mut self, volume: f64, is_buy: bool) {
            let signed = if is_buy { volume } else { -volume };
            self.delta += signed;
            self.max_delta = self.max_delta.max(self.delta);
            self.min_delta = self.min_delta.min(self.delta);
            self.history.push(self.delta);
        }

        pub fn reset(&mut self) {
            self.delta = 0.0;
            self.max_delta = 0.0;
            self.min_delta = 0.0;
            self.history.clear();
        }

        pub fn divergence(&self, price_direction: i32) -> bool {
            if self.history.len() < 10 { return false; }
            let recent_delta = self.history[self.history.len()-5..].iter().sum::<f64>();
            let earlier_delta = self.history[self.history.len()-10..self.history.len()-5].iter().sum::<f64>();
            let delta_direction = if recent_delta > earlier_delta { 1 } else { -1 };
            delta_direction != price_direction
        }
    }

    /// Footprint chart data
    pub struct FootprintLevel {
        pub price: f64,
        pub bid_volume: f64,
        pub ask_volume: f64,
        pub trades: u32,
    }

    impl FootprintLevel {
        pub fn new(price: f64) -> Self {
            Self { price, bid_volume: 0.0, ask_volume: 0.0, trades: 0 }
        }

        pub fn imbalance(&self) -> f64 {
            let total = self.bid_volume + self.ask_volume;
            if total > 0.0 { (self.bid_volume - self.ask_volume) / total } else { 0.0 }
        }

        pub fn delta(&self) -> f64 { self.ask_volume - self.bid_volume }
    }

    /// Footprint chart (bid/ask volume at each price)
    pub struct FootprintChart {
        pub levels: HashMap<i64, FootprintLevel>,
        pub tick_size: f64,
    }

    impl FootprintChart {
        pub fn new(tick_size: f64) -> Self {
            Self { levels: HashMap::new(), tick_size }
        }

        fn price_to_key(&self, price: f64) -> i64 {
            (price / self.tick_size).round() as i64
        }

        pub fn add_trade(&mut self, price: f64, volume: f64, is_buy: bool) {
            let key = self.price_to_key(price);
            let level = self.levels.entry(key)
                .or_insert_with(|| FootprintLevel::new(key as f64 * self.tick_size));

            if is_buy { level.ask_volume += volume; }
            else { level.bid_volume += volume; }
            level.trades += 1;
        }

        pub fn total_delta(&self) -> f64 {
            self.levels.values().map(|l| l.delta()).sum()
        }

        /// Find absorption levels (high volume, low delta)
        pub fn absorption_levels(&self, volume_threshold: f64) -> Vec<f64> {
            self.levels.values()
                .filter(|l| {
                    let total = l.bid_volume + l.ask_volume;
                    total >= volume_threshold && l.imbalance().abs() < 0.2
                })
                .map(|l| l.price)
                .collect()
        }

        /// Find initiative levels (high imbalance)
        pub fn initiative_levels(&self, imbalance_threshold: f64) -> Vec<(f64, i32)> {
            self.levels.values()
                .filter(|l| l.imbalance().abs() >= imbalance_threshold)
                .map(|l| (l.price, if l.imbalance() > 0.0 { 1 } else { -1 }))
                .collect()
        }
    }

    /// Point of Control calculator
    pub struct VolumeProfile {
        volumes: HashMap<i64, f64>,
        tick_size: f64,
    }

    impl VolumeProfile {
        pub fn new(tick_size: f64) -> Self {
            Self { volumes: HashMap::new(), tick_size }
        }

        pub fn add_volume(&mut self, price: f64, volume: f64) {
            let key = (price / self.tick_size).round() as i64;
            *self.volumes.entry(key).or_insert(0.0) += volume;
        }

        /// Point of Control (price with highest volume)
        pub fn poc(&self) -> Option<f64> {
            self.volumes.iter()
                .max_by(|a, b| a.1.partial_cmp(b.1).unwrap())
                .map(|(k, _)| *k as f64 * self.tick_size)
        }

        /// Value Area (70% of volume)
        pub fn value_area(&self) -> (f64, f64) {
            let total: f64 = self.volumes.values().sum();
            let target = total * 0.7;

            let poc_key = self.volumes.iter()
                .max_by(|a, b| a.1.partial_cmp(b.1).unwrap())
                .map(|(k, _)| *k)
                .unwrap_or(0);

            let mut included = vec![poc_key];
            let mut accumulated = *self.volumes.get(&poc_key).unwrap_or(&0.0);

            let mut upper = poc_key;
            let mut lower = poc_key;

            while accumulated < target {
                let upper_vol = self.volumes.get(&(upper + 1)).copied().unwrap_or(0.0);
                let lower_vol = self.volumes.get(&(lower - 1)).copied().unwrap_or(0.0);

                if upper_vol >= lower_vol && upper_vol > 0.0 {
                    upper += 1;
                    accumulated += upper_vol;
                    included.push(upper);
                } else if lower_vol > 0.0 {
                    lower -= 1;
                    accumulated += lower_vol;
                    included.push(lower);
                } else { break; }
            }

            (lower as f64 * self.tick_size, upper as f64 * self.tick_size)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXECUTION ENGINE MODULE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod execution {
    use std::collections::{HashMap, VecDeque};

    /// Execution algorithm types
    #[derive(Clone, Copy, PartialEq)]
    pub enum AlgoType { TWAP, VWAP, POV, IS, Iceberg, Sniper, Adaptive }

    /// Parent order with child order management
    pub struct ParentOrder {
        pub order_id: String,
        pub symbol: String,
        pub side: OrderSide,
        pub total_qty: f64,
        pub filled_qty: f64,
        pub algo_type: AlgoType,
        pub start_time: u64,
        pub end_time: u64,
        pub limit_price: Option<f64>,
        pub urgency: f32,
        pub children: Vec<ChildOrder>,
    }

    #[derive(Clone, Copy, PartialEq)]
    pub enum OrderSide { Buy, Sell }

    pub struct ChildOrder {
        pub child_id: String,
        pub parent_id: String,
        pub qty: f64,
        pub price: f64,
        pub status: OrderStatus,
        pub venue: String,
        pub timestamp: u64,
    }

    #[derive(Clone, Copy, PartialEq)]
    pub enum OrderStatus { Pending, Sent, PartialFill, Filled, Cancelled, Rejected }

    impl ParentOrder {
        pub fn new(id: &str, symbol: &str, side: OrderSide, qty: f64, algo: AlgoType) -> Self {
            Self {
                order_id: id.to_string(), symbol: symbol.to_string(), side, total_qty: qty,
                filled_qty: 0.0, algo_type: algo, start_time: 0, end_time: 0,
                limit_price: None, urgency: 0.5, children: Vec::new(),
            }
        }

        pub fn remaining(&self) -> f64 { self.total_qty - self.filled_qty }
        pub fn fill_rate(&self) -> f64 { if self.total_qty > 0.0 { self.filled_qty / self.total_qty } else { 0.0 } }

        pub fn add_fill(&mut self, qty: f64) { self.filled_qty = (self.filled_qty + qty).min(self.total_qty); }
        pub fn is_complete(&self) -> bool { self.remaining() < 1e-9 }
    }

    /// TWAP (Time-Weighted Average Price) scheduler
    pub struct TwapScheduler {
        pub num_slices: u32,
        pub randomize: bool,
        pub variance_pct: f32,
        rng_state: u64,
    }

    impl TwapScheduler {
        pub fn new(slices: u32) -> Self {
            Self { num_slices: slices, randomize: true, variance_pct: 0.1, rng_state: 12345 }
        }

        fn rand(&mut self) -> f64 {
            self.rng_state = self.rng_state.wrapping_mul(6364136223846793005).wrapping_add(1);
            (self.rng_state >> 11) as f64 / (1u64 << 53) as f64
        }

        pub fn schedule(&mut self, order: &ParentOrder) -> Vec<(u64, f64)> {
            let duration = order.end_time.saturating_sub(order.start_time);
            let interval = duration / self.num_slices as u64;
            let base_qty = order.remaining() / self.num_slices as f64;

            (0..self.num_slices).map(|i| {
                let time = order.start_time + i as u64 * interval;
                let qty = if self.randomize {
                    let var = (self.rand() * 2.0 - 1.0) * self.variance_pct as f64;
                    base_qty * (1.0 + var)
                } else { base_qty };
                (time, qty)
            }).collect()
        }
    }

    /// VWAP scheduler with volume profile
    pub struct VwapScheduler {
        volume_profile: Vec<f64>,
        interval_minutes: u32,
    }

    impl VwapScheduler {
        pub fn new(profile: Vec<f64>) -> Self {
            Self { volume_profile: profile, interval_minutes: 5 }
        }

        pub fn from_historical(volumes: &[f64], intervals: u32) -> Self {
            let total: f64 = volumes.iter().sum();
            let profile: Vec<f64> = if total > 0.0 {
                volumes.iter().map(|v| v / total).collect()
            } else {
                vec![1.0 / intervals as f64; intervals as usize]
            };
            Self { volume_profile: profile, interval_minutes: 5 }
        }

        pub fn schedule(&self, order: &ParentOrder) -> Vec<(u64, f64)> {
            let interval_ns = self.interval_minutes as u64 * 60_000_000_000;
            self.volume_profile.iter().enumerate().map(|(i, &pct)| {
                (order.start_time + i as u64 * interval_ns, order.remaining() * pct)
            }).collect()
        }

        pub fn participation_rate(&self, current_time: u64, market_volume: f64, order: &ParentOrder) -> f64 {
            let elapsed = (current_time.saturating_sub(order.start_time)) as f64;
            let total = (order.end_time.saturating_sub(order.start_time)) as f64;
            let progress = if total > 0.0 { elapsed / total } else { 1.0 };

            let expected_fill = order.total_qty * progress;
            let lag = expected_fill - order.filled_qty;

            let target_pct = self.volume_profile.get((progress * self.volume_profile.len() as f64) as usize)
                .copied().unwrap_or(0.05);

            let base_rate = market_volume * target_pct;
            base_rate * (1.0 + (lag / order.total_qty).clamp(-0.5, 0.5))
        }
    }

    /// POV (Percentage of Volume) executor
    pub struct PovExecutor {
        pub target_pct: f64,
        pub min_pct: f64,
        pub max_pct: f64,
        pub lookback_trades: usize,
        recent_market_volume: VecDeque<f64>,
    }

    impl PovExecutor {
        pub fn new(target: f64) -> Self {
            Self {
                target_pct: target, min_pct: target * 0.5, max_pct: target * 1.5,
                lookback_trades: 100, recent_market_volume: VecDeque::new(),
            }
        }

        pub fn on_market_trade(&mut self, volume: f64) {
            self.recent_market_volume.push_back(volume);
            while self.recent_market_volume.len() > self.lookback_trades {
                self.recent_market_volume.pop_front();
            }
        }

        pub fn calculate_order_qty(&self, order: &ParentOrder) -> f64 {
            let market_vol: f64 = self.recent_market_volume.iter().sum();
            let our_pct = if market_vol > 0.0 { order.filled_qty / market_vol } else { 0.0 };

            let adjustment = if our_pct < self.target_pct { 1.2 } else if our_pct > self.target_pct { 0.8 } else { 1.0 };
            let target_qty = market_vol * self.target_pct * adjustment;

            target_qty.clamp(market_vol * self.min_pct, market_vol * self.max_pct)
                .min(order.remaining())
        }
    }

    /// Implementation Shortfall minimizer
    pub struct ISExecutor {
        pub risk_aversion: f64,
        pub market_impact_coef: f64,
        pub volatility: f64,
        pub daily_volume: f64,
    }

    impl ISExecutor {
        pub fn new(risk_aversion: f64, volatility: f64, daily_volume: f64) -> Self {
            Self { risk_aversion, market_impact_coef: 0.1, volatility, daily_volume }
        }

        pub fn optimal_trajectory(&self, order: &ParentOrder, num_periods: u32) -> Vec<f64> {
            // Almgren-Chriss optimal execution
            let lambda = self.risk_aversion;
            let sigma = self.volatility;
            let eta = self.market_impact_coef;
            let x_total = order.remaining();

            let kappa = ((lambda * sigma * sigma) / eta).sqrt();
            let tau = 1.0 / num_periods as f64;

            (0..=num_periods).map(|j| {
                let t = j as f64 * tau;
                x_total * (1.0 - t).sinh() / 1.0f64.sinh()
            }).collect()
        }

        pub fn expected_cost(&self, trajectory: &[f64]) -> f64 {
            let mut cost = 0.0;
            for i in 1..trajectory.len() {
                let trade = trajectory[i - 1] - trajectory[i];
                cost += self.market_impact_coef * trade.abs().sqrt() * trade;
            }
            cost
        }
    }

    /// Iceberg order manager
    pub struct IcebergManager {
        pub display_qty: f64,
        pub refresh_threshold: f64,
        pub randomize_qty: bool,
        pub qty_variance: f64,
        rng_state: u64,
    }

    impl IcebergManager {
        pub fn new(display: f64) -> Self {
            Self {
                display_qty: display, refresh_threshold: 0.2, randomize_qty: true,
                qty_variance: 0.15, rng_state: 98765,
            }
        }

        fn rand(&mut self) -> f64 {
            self.rng_state = self.rng_state.wrapping_mul(6364136223846793005).wrapping_add(1);
            (self.rng_state >> 11) as f64 / (1u64 << 53) as f64
        }

        pub fn get_display_qty(&mut self, remaining: f64) -> f64 {
            let base = self.display_qty.min(remaining);
            if self.randomize_qty {
                let var = (self.rand() * 2.0 - 1.0) * self.qty_variance;
                (base * (1.0 + var)).min(remaining)
            } else { base }
        }

        pub fn should_refresh(&self, displayed_remaining: f64) -> bool {
            displayed_remaining <= self.display_qty * self.refresh_threshold
        }
    }

    /// Smart order router
    pub struct SmartRouter {
        venues: HashMap<String, VenueStats>,
        pub routing_mode: RoutingMode,
    }

    #[derive(Clone)]
    pub struct VenueStats {
        pub name: String,
        pub fill_rate: f64,
        pub avg_latency_ns: u64,
        pub rebate_bps: f64,
        pub available_liquidity: f64,
        pub last_update: u64,
    }

    #[derive(Clone, Copy)]
    pub enum RoutingMode { BestPrice, LowestCost, FastestFill, ProRata }

    impl SmartRouter {
        pub fn new() -> Self {
            Self { venues: HashMap::new(), routing_mode: RoutingMode::BestPrice }
        }

        pub fn add_venue(&mut self, stats: VenueStats) {
            self.venues.insert(stats.name.clone(), stats);
        }

        pub fn update_venue(&mut self, name: &str, liquidity: f64, latency: u64) {
            if let Some(v) = self.venues.get_mut(name) {
                v.available_liquidity = liquidity;
                v.avg_latency_ns = latency;
            }
        }

        pub fn route(&self, qty: f64, price: f64) -> Vec<(String, f64)> {
            match self.routing_mode {
                RoutingMode::BestPrice => self.route_best_price(qty),
                RoutingMode::LowestCost => self.route_lowest_cost(qty),
                RoutingMode::FastestFill => self.route_fastest(qty),
                RoutingMode::ProRata => self.route_prorata(qty),
            }
        }

        fn route_best_price(&self, qty: f64) -> Vec<(String, f64)> {
            let mut venues: Vec<_> = self.venues.values().collect();
            venues.sort_by(|a, b| b.rebate_bps.partial_cmp(&a.rebate_bps).unwrap());

            let mut remaining = qty;
            let mut routes = Vec::new();
            for v in venues {
                if remaining <= 0.0 { break; }
                let fill = v.available_liquidity.min(remaining);
                if fill > 0.0 {
                    routes.push((v.name.clone(), fill));
                    remaining -= fill;
                }
            }
            routes
        }

        fn route_lowest_cost(&self, qty: f64) -> Vec<(String, f64)> {
            let mut venues: Vec<_> = self.venues.values().collect();
            venues.sort_by(|a, b| {
                let cost_a = -a.rebate_bps + (a.avg_latency_ns as f64 / 1000.0) * 0.001;
                let cost_b = -b.rebate_bps + (b.avg_latency_ns as f64 / 1000.0) * 0.001;
                cost_a.partial_cmp(&cost_b).unwrap()
            });

            let mut remaining = qty;
            venues.iter().filter_map(|v| {
                if remaining <= 0.0 { return None; }
                let fill = v.available_liquidity.min(remaining);
                remaining -= fill;
                if fill > 0.0 { Some((v.name.clone(), fill)) } else { None }
            }).collect()
        }

        fn route_fastest(&self, qty: f64) -> Vec<(String, f64)> {
            let mut venues: Vec<_> = self.venues.values().collect();
            venues.sort_by_key(|v| v.avg_latency_ns);

            let mut remaining = qty;
            venues.iter().filter_map(|v| {
                if remaining <= 0.0 { return None; }
                let fill = v.available_liquidity.min(remaining);
                remaining -= fill;
                if fill > 0.0 { Some((v.name.clone(), fill)) } else { None }
            }).collect()
        }

        fn route_prorata(&self, qty: f64) -> Vec<(String, f64)> {
            let total_liq: f64 = self.venues.values().map(|v| v.available_liquidity).sum();
            if total_liq <= 0.0 { return Vec::new(); }

            self.venues.values().filter_map(|v| {
                let pct = v.available_liquidity / total_liq;
                let alloc = qty * pct;
                if alloc > 0.0 { Some((v.name.clone(), alloc)) } else { None }
            }).collect()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIFFERENTIAL GEOMETRY - Manifolds, Curvature, Geodesics
// ═══════════════════════════════════════════════════════════════════════════════

pub mod differential_geometry {
    use std::collections::HashMap;

    #[derive(Debug, Clone)]
    pub struct Point { pub coords: Vec<f64> }

    impl Point {
        pub fn new(coords: Vec<f64>) -> Self { Self { coords } }
        pub fn dim(&self) -> usize { self.coords.len() }
        pub fn distance(&self, other: &Point) -> f64 {
            self.coords.iter().zip(other.coords.iter())
                .map(|(a, b)| (a - b).powi(2)).sum::<f64>().sqrt()
        }
    }

    #[derive(Debug, Clone)]
    pub struct TangentVector { pub base_point: Point, pub components: Vec<f64> }

    impl TangentVector {
        pub fn new(base_point: Point, components: Vec<f64>) -> Self { Self { base_point, components } }
        pub fn norm(&self, metric: &MetricTensor) -> f64 {
            metric.inner_product(&self.components, &self.components).sqrt()
        }
        pub fn add(&self, other: &TangentVector) -> TangentVector {
            let components = self.components.iter().zip(other.components.iter())
                .map(|(a, b)| a + b).collect();
            TangentVector::new(self.base_point.clone(), components)
        }
        pub fn scale(&self, scalar: f64) -> TangentVector {
            TangentVector::new(self.base_point.clone(),
                self.components.iter().map(|c| c * scalar).collect())
        }
    }

    #[derive(Debug, Clone)]
    pub struct MetricTensor {
        pub dim: usize,
        pub components: Vec<Vec<f64>>,
    }

    impl MetricTensor {
        pub fn euclidean(dim: usize) -> Self {
            let components = (0..dim).map(|i| (0..dim).map(|j| if i == j { 1.0 } else { 0.0 }).collect()).collect();
            Self { dim, components }
        }

        pub fn minkowski(dim: usize) -> Self {
            let components = (0..dim).map(|i| {
                (0..dim).map(|j| {
                    if i == j { if i == 0 { -1.0 } else { 1.0 } } else { 0.0 }
                }).collect()
            }).collect();
            Self { dim, components }
        }

        pub fn schwarzschild(r: f64, rs: f64) -> Self {
            let factor = 1.0 - rs / r;
            let mut components = vec![vec![0.0; 4]; 4];
            components[0][0] = -factor;
            components[1][1] = 1.0 / factor;
            components[2][2] = r * r;
            components[3][3] = r * r * (std::f64::consts::PI / 2.0).sin().powi(2);
            Self { dim: 4, components }
        }

        pub fn inner_product(&self, v1: &[f64], v2: &[f64]) -> f64 {
            let mut result = 0.0;
            for i in 0..self.dim {
                for j in 0..self.dim {
                    result += self.components[i][j] * v1[i] * v2[j];
                }
            }
            result
        }

        pub fn raise_index(&self, covector: &[f64]) -> Vec<f64> {
            let inv = self.inverse();
            (0..self.dim).map(|i| {
                (0..self.dim).map(|j| inv.components[i][j] * covector[j]).sum()
            }).collect()
        }

        pub fn lower_index(&self, vector: &[f64]) -> Vec<f64> {
            (0..self.dim).map(|i| {
                (0..self.dim).map(|j| self.components[i][j] * vector[j]).sum()
            }).collect()
        }

        pub fn inverse(&self) -> MetricTensor {
            let n = self.dim;
            let mut aug: Vec<Vec<f64>> = self.components.iter().enumerate()
                .map(|(i, row)| {
                    let mut r = row.clone();
                    r.extend((0..n).map(|j| if i == j { 1.0 } else { 0.0 }));
                    r
                }).collect();

            for i in 0..n {
                let pivot = aug[i][i];
                if pivot.abs() < 1e-10 { continue; }
                for j in 0..2 * n { aug[i][j] /= pivot; }
                for k in 0..n {
                    if k != i {
                        let factor = aug[k][i];
                        for j in 0..2 * n { aug[k][j] -= factor * aug[i][j]; }
                    }
                }
            }

            MetricTensor { dim: n, components: aug.iter().map(|row| row[n..].to_vec()).collect() }
        }

        pub fn determinant(&self) -> f64 {
            let n = self.dim;
            let mut m = self.components.clone();
            let mut det = 1.0;

            for i in 0..n {
                let mut max_row = i;
                for k in i + 1..n {
                    if m[k][i].abs() > m[max_row][i].abs() { max_row = k; }
                }
                if max_row != i {
                    m.swap(i, max_row);
                    det *= -1.0;
                }
                if m[i][i].abs() < 1e-10 { return 0.0; }
                det *= m[i][i];
                for k in i + 1..n {
                    let factor = m[k][i] / m[i][i];
                    for j in i..n { m[k][j] -= factor * m[i][j]; }
                }
            }
            det
        }
    }

    #[derive(Debug, Clone)]
    pub struct ChristoffelSymbols {
        pub dim: usize,
        symbols: Vec<Vec<Vec<f64>>>,
    }

    impl ChristoffelSymbols {
        pub fn compute(metric: &MetricTensor, h: f64) -> Self {
            let n = metric.dim;
            let inv = metric.inverse();
            let mut symbols = vec![vec![vec![0.0; n]; n]; n];

            for sigma in 0..n {
                for mu in 0..n {
                    for nu in 0..n {
                        let mut gamma = 0.0;
                        for rho in 0..n {
                            let dg_mu = Self::partial_derivative(metric, rho, nu, mu, h);
                            let dg_nu = Self::partial_derivative(metric, rho, mu, nu, h);
                            let dg_rho = Self::partial_derivative(metric, mu, nu, rho, h);
                            gamma += 0.5 * inv.components[sigma][rho] * (dg_mu + dg_nu - dg_rho);
                        }
                        symbols[sigma][mu][nu] = gamma;
                    }
                }
            }

            Self { dim: n, symbols }
        }

        fn partial_derivative(_metric: &MetricTensor, _i: usize, _j: usize, _k: usize, _h: f64) -> f64 {
            0.0
        }

        pub fn get(&self, upper: usize, lower1: usize, lower2: usize) -> f64 {
            self.symbols[upper][lower1][lower2]
        }
    }

    #[derive(Debug, Clone)]
    pub struct RiemannTensor {
        pub dim: usize,
        components: Vec<Vec<Vec<Vec<f64>>>>,
    }

    impl RiemannTensor {
        pub fn compute(christoffel: &ChristoffelSymbols, h: f64) -> Self {
            let n = christoffel.dim;
            let mut components = vec![vec![vec![vec![0.0; n]; n]; n]; n];

            for rho in 0..n {
                for sigma in 0..n {
                    for mu in 0..n {
                        for nu in 0..n {
                            let mut r = 0.0;
                            r += Self::partial_gamma(christoffel, rho, nu, sigma, mu, h);
                            r -= Self::partial_gamma(christoffel, rho, mu, sigma, nu, h);
                            for lambda in 0..n {
                                r += christoffel.get(rho, mu, lambda) * christoffel.get(lambda, nu, sigma);
                                r -= christoffel.get(rho, nu, lambda) * christoffel.get(lambda, mu, sigma);
                            }
                            components[rho][sigma][mu][nu] = r;
                        }
                    }
                }
            }

            Self { dim: n, components }
        }

        fn partial_gamma(_christoffel: &ChristoffelSymbols, _rho: usize, _mu: usize, _sigma: usize, _nu: usize, _h: f64) -> f64 {
            0.0
        }

        pub fn get(&self, i: usize, j: usize, k: usize, l: usize) -> f64 {
            self.components[i][j][k][l]
        }
    }

    #[derive(Debug, Clone)]
    pub struct RicciTensor {
        pub dim: usize,
        pub components: Vec<Vec<f64>>,
    }

    impl RicciTensor {
        pub fn from_riemann(riemann: &RiemannTensor) -> Self {
            let n = riemann.dim;
            let mut components = vec![vec![0.0; n]; n];

            for mu in 0..n {
                for nu in 0..n {
                    for rho in 0..n {
                        components[mu][nu] += riemann.get(rho, mu, rho, nu);
                    }
                }
            }

            Self { dim: n, components }
        }

        pub fn scalar_curvature(&self, metric: &MetricTensor) -> f64 {
            let inv = metric.inverse();
            let mut r = 0.0;
            for mu in 0..self.dim {
                for nu in 0..self.dim {
                    r += inv.components[mu][nu] * self.components[mu][nu];
                }
            }
            r
        }
    }

    pub struct GeodesicSolver {
        metric: MetricTensor,
        christoffel: ChristoffelSymbols,
    }

    impl GeodesicSolver {
        pub fn new(metric: MetricTensor, h: f64) -> Self {
            let christoffel = ChristoffelSymbols::compute(&metric, h);
            Self { metric, christoffel }
        }

        pub fn solve(&self, initial_pos: &[f64], initial_vel: &[f64], t_final: f64, steps: usize) -> Vec<(Vec<f64>, Vec<f64>)> {
            let dt = t_final / steps as f64;
            let n = initial_pos.len();
            let mut trajectory = Vec::with_capacity(steps);

            let mut x = initial_pos.to_vec();
            let mut v = initial_vel.to_vec();

            for _ in 0..steps {
                trajectory.push((x.clone(), v.clone()));

                let mut dv = vec![0.0; n];
                for mu in 0..n {
                    for alpha in 0..n {
                        for beta in 0..n {
                            dv[mu] -= self.christoffel.get(mu, alpha, beta) * v[alpha] * v[beta];
                        }
                    }
                }

                for mu in 0..n {
                    x[mu] += v[mu] * dt;
                    v[mu] += dv[mu] * dt;
                }
            }

            trajectory
        }

        pub fn parallel_transport(&self, vector: &[f64], path: &[(Vec<f64>, Vec<f64>)]) -> Vec<f64> {
            let n = vector.len();
            let mut v = vector.to_vec();

            for i in 0..path.len() - 1 {
                let tangent = &path[i].1;
                let mut dv = vec![0.0; n];
                for mu in 0..n {
                    for alpha in 0..n {
                        for beta in 0..n {
                            dv[mu] -= self.christoffel.get(mu, alpha, beta) * v[alpha] * tangent[beta];
                        }
                    }
                }
                for mu in 0..n { v[mu] += dv[mu]; }
            }

            v
        }
    }

    pub struct Manifold {
        pub dim: usize,
        pub metric: MetricTensor,
        pub charts: Vec<Chart>,
    }

    pub struct Chart {
        pub name: String,
        pub domain: Box<dyn Fn(&[f64]) -> bool + Send + Sync>,
    }

    impl Manifold {
        pub fn new(dim: usize, metric: MetricTensor) -> Self {
            Self { dim, metric, charts: Vec::new() }
        }

        pub fn euclidean(dim: usize) -> Self {
            Self::new(dim, MetricTensor::euclidean(dim))
        }

        pub fn sphere(radius: f64) -> Self {
            let mut components = vec![vec![0.0; 2]; 2];
            components[0][0] = radius * radius;
            components[1][1] = radius * radius;
            Self::new(2, MetricTensor { dim: 2, components })
        }

        pub fn add_chart(&mut self, name: String, domain: impl Fn(&[f64]) -> bool + Send + Sync + 'static) {
            self.charts.push(Chart { name, domain: Box::new(domain) });
        }

        pub fn volume_element(&self, point: &[f64]) -> f64 {
            self.metric.determinant().abs().sqrt()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QUANTUM MECHANICS - Operators, States, Measurements
// ═══════════════════════════════════════════════════════════════════════════════

pub mod quantum {
    use std::f64::consts::PI;

    #[derive(Debug, Clone)]
    pub struct Complex { pub re: f64, pub im: f64 }

    impl Complex {
        pub fn new(re: f64, im: f64) -> Self { Self { re, im } }
        pub fn from_polar(r: f64, theta: f64) -> Self { Self { re: r * theta.cos(), im: r * theta.sin() } }
        pub fn zero() -> Self { Self { re: 0.0, im: 0.0 } }
        pub fn one() -> Self { Self { re: 1.0, im: 0.0 } }
        pub fn i() -> Self { Self { re: 0.0, im: 1.0 } }
        pub fn conj(&self) -> Self { Self { re: self.re, im: -self.im } }
        pub fn norm_sq(&self) -> f64 { self.re * self.re + self.im * self.im }
        pub fn norm(&self) -> f64 { self.norm_sq().sqrt() }
        pub fn add(&self, other: &Complex) -> Complex { Complex::new(self.re + other.re, self.im + other.im) }
        pub fn sub(&self, other: &Complex) -> Complex { Complex::new(self.re - other.re, self.im - other.im) }
        pub fn mul(&self, other: &Complex) -> Complex {
            Complex::new(self.re * other.re - self.im * other.im, self.re * other.im + self.im * other.re)
        }
        pub fn div(&self, other: &Complex) -> Complex {
            let denom = other.norm_sq();
            Complex::new((self.re * other.re + self.im * other.im) / denom,
                        (self.im * other.re - self.re * other.im) / denom)
        }
        pub fn scale(&self, s: f64) -> Complex { Complex::new(self.re * s, self.im * s) }
        pub fn exp(&self) -> Complex {
            let r = self.re.exp();
            Complex::new(r * self.im.cos(), r * self.im.sin())
        }
    }

    #[derive(Debug, Clone)]
    pub struct QuantumState { pub amplitudes: Vec<Complex>, pub dim: usize }

    impl QuantumState {
        pub fn new(amplitudes: Vec<Complex>) -> Self {
            let dim = amplitudes.len();
            Self { amplitudes, dim }
        }

        pub fn zero_state(n_qubits: usize) -> Self {
            let dim = 1 << n_qubits;
            let mut amplitudes = vec![Complex::zero(); dim];
            amplitudes[0] = Complex::one();
            Self { amplitudes, dim }
        }

        pub fn computational_basis(n_qubits: usize, state: usize) -> Self {
            let dim = 1 << n_qubits;
            let mut amplitudes = vec![Complex::zero(); dim];
            amplitudes[state % dim] = Complex::one();
            Self { amplitudes, dim }
        }

        pub fn superposition(n_qubits: usize) -> Self {
            let dim = 1 << n_qubits;
            let amp = Complex::new(1.0 / (dim as f64).sqrt(), 0.0);
            Self { amplitudes: vec![amp; dim], dim }
        }

        pub fn bell_state(bell_type: usize) -> Self {
            let sqrt2 = 1.0 / 2.0_f64.sqrt();
            let mut amplitudes = vec![Complex::zero(); 4];
            match bell_type % 4 {
                0 => { amplitudes[0] = Complex::new(sqrt2, 0.0); amplitudes[3] = Complex::new(sqrt2, 0.0); }
                1 => { amplitudes[0] = Complex::new(sqrt2, 0.0); amplitudes[3] = Complex::new(-sqrt2, 0.0); }
                2 => { amplitudes[1] = Complex::new(sqrt2, 0.0); amplitudes[2] = Complex::new(sqrt2, 0.0); }
                3 => { amplitudes[1] = Complex::new(sqrt2, 0.0); amplitudes[2] = Complex::new(-sqrt2, 0.0); }
                _ => {}
            }
            Self { amplitudes, dim: 4 }
        }

        pub fn normalize(&mut self) {
            let norm: f64 = self.amplitudes.iter().map(|a| a.norm_sq()).sum::<f64>().sqrt();
            if norm > 1e-10 {
                for a in &mut self.amplitudes { *a = a.scale(1.0 / norm); }
            }
        }

        pub fn inner_product(&self, other: &QuantumState) -> Complex {
            self.amplitudes.iter().zip(other.amplitudes.iter())
                .fold(Complex::zero(), |acc, (a, b)| acc.add(&a.conj().mul(b)))
        }

        pub fn probability(&self, state: usize) -> f64 {
            if state < self.dim { self.amplitudes[state].norm_sq() } else { 0.0 }
        }

        pub fn measure(&self) -> usize {
            let mut rng = SimpleRng::new(42);
            let r = rng.next_f64();
            let mut cumsum = 0.0;
            for (i, a) in self.amplitudes.iter().enumerate() {
                cumsum += a.norm_sq();
                if r < cumsum { return i; }
            }
            self.dim - 1
        }

        pub fn tensor_product(&self, other: &QuantumState) -> QuantumState {
            let new_dim = self.dim * other.dim;
            let mut amplitudes = Vec::with_capacity(new_dim);
            for a in &self.amplitudes {
                for b in &other.amplitudes {
                    amplitudes.push(a.mul(b));
                }
            }
            QuantumState { amplitudes, dim: new_dim }
        }
    }

    #[derive(Debug, Clone)]
    pub struct Operator { pub matrix: Vec<Vec<Complex>>, pub dim: usize }

    impl Operator {
        pub fn new(matrix: Vec<Vec<Complex>>) -> Self {
            let dim = matrix.len();
            Self { matrix, dim }
        }

        pub fn identity(dim: usize) -> Self {
            let matrix = (0..dim).map(|i| {
                (0..dim).map(|j| if i == j { Complex::one() } else { Complex::zero() }).collect()
            }).collect();
            Self { matrix, dim }
        }

        pub fn pauli_x() -> Self {
            Self::new(vec![
                vec![Complex::zero(), Complex::one()],
                vec![Complex::one(), Complex::zero()],
            ])
        }

        pub fn pauli_y() -> Self {
            Self::new(vec![
                vec![Complex::zero(), Complex::new(0.0, -1.0)],
                vec![Complex::new(0.0, 1.0), Complex::zero()],
            ])
        }

        pub fn pauli_z() -> Self {
            Self::new(vec![
                vec![Complex::one(), Complex::zero()],
                vec![Complex::zero(), Complex::new(-1.0, 0.0)],
            ])
        }

        pub fn hadamard() -> Self {
            let s = 1.0 / 2.0_f64.sqrt();
            Self::new(vec![
                vec![Complex::new(s, 0.0), Complex::new(s, 0.0)],
                vec![Complex::new(s, 0.0), Complex::new(-s, 0.0)],
            ])
        }

        pub fn phase(theta: f64) -> Self {
            Self::new(vec![
                vec![Complex::one(), Complex::zero()],
                vec![Complex::zero(), Complex::from_polar(1.0, theta)],
            ])
        }

        pub fn rotation_x(theta: f64) -> Self {
            let c = (theta / 2.0).cos();
            let s = (theta / 2.0).sin();
            Self::new(vec![
                vec![Complex::new(c, 0.0), Complex::new(0.0, -s)],
                vec![Complex::new(0.0, -s), Complex::new(c, 0.0)],
            ])
        }

        pub fn rotation_y(theta: f64) -> Self {
            let c = (theta / 2.0).cos();
            let s = (theta / 2.0).sin();
            Self::new(vec![
                vec![Complex::new(c, 0.0), Complex::new(-s, 0.0)],
                vec![Complex::new(s, 0.0), Complex::new(c, 0.0)],
            ])
        }

        pub fn rotation_z(theta: f64) -> Self {
            let half = theta / 2.0;
            Self::new(vec![
                vec![Complex::from_polar(1.0, -half), Complex::zero()],
                vec![Complex::zero(), Complex::from_polar(1.0, half)],
            ])
        }

        pub fn cnot() -> Self {
            Self::new(vec![
                vec![Complex::one(), Complex::zero(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::one(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::zero(), Complex::one()],
                vec![Complex::zero(), Complex::zero(), Complex::one(), Complex::zero()],
            ])
        }

        pub fn swap() -> Self {
            Self::new(vec![
                vec![Complex::one(), Complex::zero(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::one(), Complex::zero()],
                vec![Complex::zero(), Complex::one(), Complex::zero(), Complex::zero()],
                vec![Complex::zero(), Complex::zero(), Complex::zero(), Complex::one()],
            ])
        }

        pub fn toffoli() -> Self {
            let mut matrix = vec![vec![Complex::zero(); 8]; 8];
            for i in 0..6 { matrix[i][i] = Complex::one(); }
            matrix[6][7] = Complex::one();
            matrix[7][6] = Complex::one();
            Self::new(matrix)
        }

        pub fn apply(&self, state: &QuantumState) -> QuantumState {
            let mut result = vec![Complex::zero(); self.dim];
            for i in 0..self.dim {
                for j in 0..self.dim {
                    result[i] = result[i].add(&self.matrix[i][j].mul(&state.amplitudes[j]));
                }
            }
            QuantumState::new(result)
        }

        pub fn compose(&self, other: &Operator) -> Operator {
            let n = self.dim;
            let mut result = vec![vec![Complex::zero(); n]; n];
            for i in 0..n {
                for j in 0..n {
                    for k in 0..n {
                        result[i][j] = result[i][j].add(&self.matrix[i][k].mul(&other.matrix[k][j]));
                    }
                }
            }
            Operator::new(result)
        }

        pub fn tensor_product(&self, other: &Operator) -> Operator {
            let new_dim = self.dim * other.dim;
            let mut matrix = vec![vec![Complex::zero(); new_dim]; new_dim];
            for i in 0..self.dim {
                for j in 0..self.dim {
                    for k in 0..other.dim {
                        for l in 0..other.dim {
                            matrix[i * other.dim + k][j * other.dim + l] =
                                self.matrix[i][j].mul(&other.matrix[k][l]);
                        }
                    }
                }
            }
            Operator::new(matrix)
        }

        pub fn dagger(&self) -> Operator {
            let matrix = (0..self.dim).map(|i| {
                (0..self.dim).map(|j| self.matrix[j][i].conj()).collect()
            }).collect();
            Operator::new(matrix)
        }

        pub fn is_unitary(&self) -> bool {
            let prod = self.compose(&self.dagger());
            for i in 0..self.dim {
                for j in 0..self.dim {
                    let expected = if i == j { Complex::one() } else { Complex::zero() };
                    if prod.matrix[i][j].sub(&expected).norm() > 1e-10 { return false; }
                }
            }
            true
        }

        pub fn trace(&self) -> Complex {
            (0..self.dim).fold(Complex::zero(), |acc, i| acc.add(&self.matrix[i][i]))
        }
    }

    pub struct QuantumCircuit {
        pub n_qubits: usize,
        gates: Vec<(Operator, Vec<usize>)>,
    }

    impl QuantumCircuit {
        pub fn new(n_qubits: usize) -> Self { Self { n_qubits, gates: Vec::new() } }

        pub fn add_gate(&mut self, gate: Operator, qubits: Vec<usize>) {
            self.gates.push((gate, qubits));
        }

        pub fn h(&mut self, qubit: usize) { self.add_gate(Operator::hadamard(), vec![qubit]); }
        pub fn x(&mut self, qubit: usize) { self.add_gate(Operator::pauli_x(), vec![qubit]); }
        pub fn y(&mut self, qubit: usize) { self.add_gate(Operator::pauli_y(), vec![qubit]); }
        pub fn z(&mut self, qubit: usize) { self.add_gate(Operator::pauli_z(), vec![qubit]); }
        pub fn cnot(&mut self, control: usize, target: usize) {
            self.add_gate(Operator::cnot(), vec![control, target]);
        }

        pub fn execute(&self, initial_state: &QuantumState) -> QuantumState {
            let mut state = initial_state.clone();
            for (gate, qubits) in &self.gates {
                state = self.apply_gate(gate, qubits, &state);
            }
            state
        }

        fn apply_gate(&self, gate: &Operator, qubits: &[usize], state: &QuantumState) -> QuantumState {
            if qubits.len() == 1 {
                self.apply_single_qubit_gate(gate, qubits[0], state)
            } else {
                gate.apply(state)
            }
        }

        fn apply_single_qubit_gate(&self, gate: &Operator, qubit: usize, state: &QuantumState) -> QuantumState {
            let dim = state.dim;
            let mut result = vec![Complex::zero(); dim];

            for i in 0..dim {
                let bit = (i >> qubit) & 1;
                let paired = i ^ (1 << qubit);

                if bit == 0 {
                    result[i] = result[i].add(&gate.matrix[0][0].mul(&state.amplitudes[i]));
                    result[i] = result[i].add(&gate.matrix[0][1].mul(&state.amplitudes[paired]));
                } else {
                    result[i] = result[i].add(&gate.matrix[1][0].mul(&state.amplitudes[paired]));
                    result[i] = result[i].add(&gate.matrix[1][1].mul(&state.amplitudes[i]));
                }
            }

            QuantumState::new(result)
        }
    }

    pub struct DensityMatrix { pub matrix: Vec<Vec<Complex>>, pub dim: usize }

    impl DensityMatrix {
        pub fn from_pure_state(state: &QuantumState) -> Self {
            let n = state.dim;
            let matrix = (0..n).map(|i| {
                (0..n).map(|j| state.amplitudes[i].mul(&state.amplitudes[j].conj())).collect()
            }).collect();
            Self { matrix, dim: n }
        }

        pub fn mixed(states: &[(QuantumState, f64)]) -> Self {
            let n = states[0].0.dim;
            let mut matrix = vec![vec![Complex::zero(); n]; n];

            for (state, prob) in states {
                for i in 0..n {
                    for j in 0..n {
                        let elem = state.amplitudes[i].mul(&state.amplitudes[j].conj()).scale(*prob);
                        matrix[i][j] = matrix[i][j].add(&elem);
                    }
                }
            }

            Self { matrix, dim: n }
        }

        pub fn trace(&self) -> f64 {
            (0..self.dim).map(|i| self.matrix[i][i].re).sum()
        }

        pub fn purity(&self) -> f64 {
            let mut sum = 0.0;
            for i in 0..self.dim {
                for j in 0..self.dim {
                    sum += self.matrix[i][j].mul(&self.matrix[j][i]).re;
                }
            }
            sum
        }

        pub fn von_neumann_entropy(&self) -> f64 {
            let eigenvalues = self.eigenvalues();
            -eigenvalues.iter().filter(|&&e| e > 1e-10).map(|e| e * e.ln()).sum::<f64>()
        }

        fn eigenvalues(&self) -> Vec<f64> {
            (0..self.dim).map(|i| self.matrix[i][i].re).collect()
        }
    }

    struct SimpleRng { state: u64 }
    impl SimpleRng {
        fn new(seed: u64) -> Self { Self { state: seed.wrapping_add(1) } }
        fn next_u64(&mut self) -> u64 {
            self.state = self.state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
            self.state
        }
        fn next_f64(&mut self) -> f64 { (self.next_u64() as f64) / (u64::MAX as f64) }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ELECTRODYNAMICS - Maxwell Equations, EM Fields
// ═══════════════════════════════════════════════════════════════════════════════

pub mod electrodynamics {
    use std::f64::consts::PI;

    pub const EPSILON_0: f64 = 8.854187817e-12;
    pub const MU_0: f64 = 1.2566370614e-6;
    pub const C: f64 = 299792458.0;

    #[derive(Debug, Clone)]
    pub struct Vec3 { pub x: f64, pub y: f64, pub z: f64 }

    impl Vec3 {
        pub fn new(x: f64, y: f64, z: f64) -> Self { Self { x, y, z } }
        pub fn zero() -> Self { Self { x: 0.0, y: 0.0, z: 0.0 } }
        pub fn add(&self, other: &Vec3) -> Vec3 { Vec3::new(self.x + other.x, self.y + other.y, self.z + other.z) }
        pub fn sub(&self, other: &Vec3) -> Vec3 { Vec3::new(self.x - other.x, self.y - other.y, self.z - other.z) }
        pub fn scale(&self, s: f64) -> Vec3 { Vec3::new(self.x * s, self.y * s, self.z * s) }
        pub fn dot(&self, other: &Vec3) -> f64 { self.x * other.x + self.y * other.y + self.z * other.z }
        pub fn cross(&self, other: &Vec3) -> Vec3 {
            Vec3::new(self.y * other.z - self.z * other.y,
                     self.z * other.x - self.x * other.z,
                     self.x * other.y - self.y * other.x)
        }
        pub fn norm(&self) -> f64 { self.dot(self).sqrt() }
        pub fn normalize(&self) -> Vec3 { let n = self.norm(); if n > 1e-10 { self.scale(1.0 / n) } else { Vec3::zero() } }
    }

    #[derive(Debug, Clone)]
    pub struct EMField {
        pub e: Vec3,
        pub b: Vec3,
    }

    impl EMField {
        pub fn new(e: Vec3, b: Vec3) -> Self { Self { e, b } }
        pub fn zero() -> Self { Self { e: Vec3::zero(), b: Vec3::zero() } }

        pub fn energy_density(&self) -> f64 {
            0.5 * EPSILON_0 * self.e.dot(&self.e) + 0.5 / MU_0 * self.b.dot(&self.b)
        }

        pub fn poynting_vector(&self) -> Vec3 {
            self.e.cross(&self.b).scale(1.0 / MU_0)
        }

        pub fn lorentz_force(&self, charge: f64, velocity: &Vec3) -> Vec3 {
            self.e.scale(charge).add(&velocity.cross(&self.b).scale(charge))
        }
    }

    #[derive(Debug, Clone)]
    pub struct PointCharge { pub charge: f64, pub position: Vec3, pub velocity: Vec3 }

    impl PointCharge {
        pub fn new(charge: f64, position: Vec3) -> Self {
            Self { charge, position, velocity: Vec3::zero() }
        }

        pub fn electric_field(&self, point: &Vec3) -> Vec3 {
            let r = point.sub(&self.position);
            let r_mag = r.norm();
            if r_mag < 1e-10 { return Vec3::zero(); }
            r.normalize().scale(self.charge / (4.0 * PI * EPSILON_0 * r_mag * r_mag))
        }

        pub fn potential(&self, point: &Vec3) -> f64 {
            let r = point.sub(&self.position).norm();
            if r < 1e-10 { 0.0 } else { self.charge / (4.0 * PI * EPSILON_0 * r) }
        }
    }

    #[derive(Debug, Clone)]
    pub struct CurrentLoop { pub current: f64, pub radius: f64, pub center: Vec3, pub normal: Vec3 }

    impl CurrentLoop {
        pub fn new(current: f64, radius: f64, center: Vec3, normal: Vec3) -> Self {
            Self { current, radius, center, normal: normal.normalize() }
        }

        pub fn magnetic_dipole_moment(&self) -> Vec3 {
            self.normal.scale(self.current * PI * self.radius * self.radius)
        }

        pub fn magnetic_field_on_axis(&self, z: f64) -> Vec3 {
            let r = self.radius;
            let factor = MU_0 * self.current * r * r /
                        (2.0 * (r * r + z * z).powf(1.5));
            self.normal.scale(factor)
        }
    }

    pub struct PlaneWave {
        pub e0: Vec3,
        pub k: Vec3,
        pub omega: f64,
        pub phase: f64,
    }

    impl PlaneWave {
        pub fn new(e0: Vec3, k: Vec3, omega: f64) -> Self {
            Self { e0, k, omega, phase: 0.0 }
        }

        pub fn field_at(&self, position: &Vec3, time: f64) -> EMField {
            let phase = self.k.dot(position) - self.omega * time + self.phase;
            let e = self.e0.scale(phase.cos());
            let k_norm = self.k.normalize();
            let b = k_norm.cross(&e).scale(1.0 / C);
            EMField::new(e, b)
        }

        pub fn intensity(&self) -> f64 {
            0.5 * C * EPSILON_0 * self.e0.dot(&self.e0)
        }

        pub fn wavelength(&self) -> f64 {
            2.0 * PI * C / self.omega
        }

        pub fn frequency(&self) -> f64 {
            self.omega / (2.0 * PI)
        }
    }

    pub struct EMFieldGrid {
        pub nx: usize, pub ny: usize, pub nz: usize,
        pub dx: f64,
        e: Vec<Vec<Vec<Vec3>>>,
        b: Vec<Vec<Vec<Vec3>>>,
    }

    impl EMFieldGrid {
        pub fn new(nx: usize, ny: usize, nz: usize, dx: f64) -> Self {
            let e = vec![vec![vec![Vec3::zero(); nz]; ny]; nx];
            let b = vec![vec![vec![Vec3::zero(); nz]; ny]; nx];
            Self { nx, ny, nz, dx, e, b }
        }

        pub fn get_e(&self, i: usize, j: usize, k: usize) -> &Vec3 { &self.e[i][j][k] }
        pub fn get_b(&self, i: usize, j: usize, k: usize) -> &Vec3 { &self.b[i][j][k] }
        pub fn set_e(&mut self, i: usize, j: usize, k: usize, e: Vec3) { self.e[i][j][k] = e; }
        pub fn set_b(&mut self, i: usize, j: usize, k: usize, b: Vec3) { self.b[i][j][k] = b; }

        pub fn curl_e(&self, i: usize, j: usize, k: usize) -> Vec3 {
            let dx = self.dx;
            let dey_dz = if k + 1 < self.nz { (self.e[i][j][k + 1].y - self.e[i][j][k].y) / dx } else { 0.0 };
            let dez_dy = if j + 1 < self.ny { (self.e[i][j + 1][k].z - self.e[i][j][k].z) / dx } else { 0.0 };
            let dez_dx = if i + 1 < self.nx { (self.e[i + 1][j][k].z - self.e[i][j][k].z) / dx } else { 0.0 };
            let dex_dz = if k + 1 < self.nz { (self.e[i][j][k + 1].x - self.e[i][j][k].x) / dx } else { 0.0 };
            let dex_dy = if j + 1 < self.ny { (self.e[i][j + 1][k].x - self.e[i][j][k].x) / dx } else { 0.0 };
            let dey_dx = if i + 1 < self.nx { (self.e[i + 1][j][k].y - self.e[i][j][k].y) / dx } else { 0.0 };
            Vec3::new(dey_dz - dez_dy, dez_dx - dex_dz, dex_dy - dey_dx)
        }

        pub fn curl_b(&self, i: usize, j: usize, k: usize) -> Vec3 {
            let dx = self.dx;
            let dby_dz = if k + 1 < self.nz { (self.b[i][j][k + 1].y - self.b[i][j][k].y) / dx } else { 0.0 };
            let dbz_dy = if j + 1 < self.ny { (self.b[i][j + 1][k].z - self.b[i][j][k].z) / dx } else { 0.0 };
            let dbz_dx = if i + 1 < self.nx { (self.b[i + 1][j][k].z - self.b[i][j][k].z) / dx } else { 0.0 };
            let dbx_dz = if k + 1 < self.nz { (self.b[i][j][k + 1].x - self.b[i][j][k].x) / dx } else { 0.0 };
            let dbx_dy = if j + 1 < self.ny { (self.b[i][j + 1][k].x - self.b[i][j][k].x) / dx } else { 0.0 };
            let dby_dx = if i + 1 < self.nx { (self.b[i + 1][j][k].y - self.b[i][j][k].y) / dx } else { 0.0 };
            Vec3::new(dby_dz - dbz_dy, dbz_dx - dbx_dz, dbx_dy - dby_dx)
        }

        pub fn fdtd_step(&mut self, dt: f64) {
            for i in 0..self.nx {
                for j in 0..self.ny {
                    for k in 0..self.nz {
                        let curl_e = self.curl_e(i, j, k);
                        self.b[i][j][k] = self.b[i][j][k].sub(&curl_e.scale(dt));
                    }
                }
            }

            for i in 0..self.nx {
                for j in 0..self.ny {
                    for k in 0..self.nz {
                        let curl_b = self.curl_b(i, j, k);
                        self.e[i][j][k] = self.e[i][j][k].add(&curl_b.scale(C * C * dt));
                    }
                }
            }
        }

        pub fn total_energy(&self) -> f64 {
            let mut energy = 0.0;
            let dv = self.dx.powi(3);
            for i in 0..self.nx {
                for j in 0..self.ny {
                    for k in 0..self.nz {
                        let e = &self.e[i][j][k];
                        let b = &self.b[i][j][k];
                        energy += (0.5 * EPSILON_0 * e.dot(e) + 0.5 / MU_0 * b.dot(b)) * dv;
                    }
                }
            }
            energy
        }
    }

    pub fn multipole_expansion(charges: &[PointCharge], order: usize) -> Vec<f64> {
        let mut moments = vec![0.0; order + 1];
        if order >= 0 {
            moments[0] = charges.iter().map(|c| c.charge).sum();
        }
        if order >= 1 {
            moments[1] = charges.iter().map(|c| c.charge * c.position.norm()).sum();
        }
        moments
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FLUID DYNAMICS - Navier-Stokes, Flow Computations
// ═══════════════════════════════════════════════════════════════════════════════

pub mod fluid_dynamics {
    use std::f64::consts::PI;

    #[derive(Debug, Clone)]
    pub struct Vec3 { pub x: f64, pub y: f64, pub z: f64 }

    impl Vec3 {
        pub fn new(x: f64, y: f64, z: f64) -> Self { Self { x, y, z } }
        pub fn zero() -> Self { Self { x: 0.0, y: 0.0, z: 0.0 } }
        pub fn add(&self, other: &Vec3) -> Vec3 { Vec3::new(self.x + other.x, self.y + other.y, self.z + other.z) }
        pub fn sub(&self, other: &Vec3) -> Vec3 { Vec3::new(self.x - other.x, self.y - other.y, self.z - other.z) }
        pub fn scale(&self, s: f64) -> Vec3 { Vec3::new(self.x * s, self.y * s, self.z * s) }
        pub fn dot(&self, other: &Vec3) -> f64 { self.x * other.x + self.y * other.y + self.z * other.z }
        pub fn norm(&self) -> f64 { self.dot(self).sqrt() }
    }

    #[derive(Debug, Clone)]
    pub struct FluidProperties {
        pub density: f64,
        pub viscosity: f64,
        pub thermal_conductivity: f64,
        pub specific_heat: f64,
    }

    impl FluidProperties {
        pub fn water() -> Self { Self { density: 1000.0, viscosity: 1.0e-3, thermal_conductivity: 0.6, specific_heat: 4186.0 } }
        pub fn air() -> Self { Self { density: 1.225, viscosity: 1.81e-5, thermal_conductivity: 0.0257, specific_heat: 1005.0 } }
        pub fn kinematic_viscosity(&self) -> f64 { self.viscosity / self.density }
    }

    #[derive(Debug, Clone)]
    pub struct FluidCell {
        pub velocity: Vec3,
        pub pressure: f64,
        pub density: f64,
        pub temperature: f64,
    }

    impl FluidCell {
        pub fn new() -> Self {
            Self { velocity: Vec3::zero(), pressure: 101325.0, density: 1.0, temperature: 300.0 }
        }
    }

    pub struct FluidGrid {
        pub nx: usize, pub ny: usize, pub nz: usize,
        pub dx: f64, pub dy: f64, pub dz: f64,
        cells: Vec<Vec<Vec<FluidCell>>>,
        properties: FluidProperties,
    }

    impl FluidGrid {
        pub fn new(nx: usize, ny: usize, nz: usize, dx: f64, dy: f64, dz: f64, properties: FluidProperties) -> Self {
            let cells = vec![vec![vec![FluidCell::new(); nz]; ny]; nx];
            Self { nx, ny, nz, dx, dy, dz, cells, properties }
        }

        pub fn get(&self, i: usize, j: usize, k: usize) -> &FluidCell { &self.cells[i][j][k] }
        pub fn get_mut(&mut self, i: usize, j: usize, k: usize) -> &mut FluidCell { &mut self.cells[i][j][k] }

        pub fn divergence(&self, i: usize, j: usize, k: usize) -> f64 {
            let du_dx = if i + 1 < self.nx && i > 0 {
                (self.cells[i + 1][j][k].velocity.x - self.cells[i - 1][j][k].velocity.x) / (2.0 * self.dx)
            } else { 0.0 };
            let dv_dy = if j + 1 < self.ny && j > 0 {
                (self.cells[i][j + 1][k].velocity.y - self.cells[i][j - 1][k].velocity.y) / (2.0 * self.dy)
            } else { 0.0 };
            let dw_dz = if k + 1 < self.nz && k > 0 {
                (self.cells[i][j][k + 1].velocity.z - self.cells[i][j][k - 1].velocity.z) / (2.0 * self.dz)
            } else { 0.0 };
            du_dx + dv_dy + dw_dz
        }

        pub fn curl(&self, i: usize, j: usize, k: usize) -> Vec3 {
            let dw_dy = if j + 1 < self.ny && j > 0 {
                (self.cells[i][j + 1][k].velocity.z - self.cells[i][j - 1][k].velocity.z) / (2.0 * self.dy)
            } else { 0.0 };
            let dv_dz = if k + 1 < self.nz && k > 0 {
                (self.cells[i][j][k + 1].velocity.y - self.cells[i][j][k - 1].velocity.y) / (2.0 * self.dz)
            } else { 0.0 };
            let du_dz = if k + 1 < self.nz && k > 0 {
                (self.cells[i][j][k + 1].velocity.x - self.cells[i][j][k - 1].velocity.x) / (2.0 * self.dz)
            } else { 0.0 };
            let dw_dx = if i + 1 < self.nx && i > 0 {
                (self.cells[i + 1][j][k].velocity.z - self.cells[i - 1][j][k].velocity.z) / (2.0 * self.dx)
            } else { 0.0 };
            let dv_dx = if i + 1 < self.nx && i > 0 {
                (self.cells[i + 1][j][k].velocity.y - self.cells[i - 1][j][k].velocity.y) / (2.0 * self.dx)
            } else { 0.0 };
            let du_dy = if j + 1 < self.ny && j > 0 {
                (self.cells[i][j + 1][k].velocity.x - self.cells[i][j - 1][k].velocity.x) / (2.0 * self.dy)
            } else { 0.0 };
            Vec3::new(dw_dy - dv_dz, du_dz - dw_dx, dv_dx - du_dy)
        }

        pub fn laplacian_velocity(&self, i: usize, j: usize, k: usize) -> Vec3 {
            let v = &self.cells[i][j][k].velocity;
            let mut lap = Vec3::zero();

            if i > 0 && i + 1 < self.nx {
                let d2u = (self.cells[i + 1][j][k].velocity.x - 2.0 * v.x + self.cells[i - 1][j][k].velocity.x) / (self.dx * self.dx);
                let d2v = (self.cells[i + 1][j][k].velocity.y - 2.0 * v.y + self.cells[i - 1][j][k].velocity.y) / (self.dx * self.dx);
                let d2w = (self.cells[i + 1][j][k].velocity.z - 2.0 * v.z + self.cells[i - 1][j][k].velocity.z) / (self.dx * self.dx);
                lap = lap.add(&Vec3::new(d2u, d2v, d2w));
            }
            if j > 0 && j + 1 < self.ny {
                let d2u = (self.cells[i][j + 1][k].velocity.x - 2.0 * v.x + self.cells[i][j - 1][k].velocity.x) / (self.dy * self.dy);
                let d2v = (self.cells[i][j + 1][k].velocity.y - 2.0 * v.y + self.cells[i][j - 1][k].velocity.y) / (self.dy * self.dy);
                let d2w = (self.cells[i][j + 1][k].velocity.z - 2.0 * v.z + self.cells[i][j - 1][k].velocity.z) / (self.dy * self.dy);
                lap = lap.add(&Vec3::new(d2u, d2v, d2w));
            }
            if k > 0 && k + 1 < self.nz {
                let d2u = (self.cells[i][j][k + 1].velocity.x - 2.0 * v.x + self.cells[i][j][k - 1].velocity.x) / (self.dz * self.dz);
                let d2v = (self.cells[i][j][k + 1].velocity.y - 2.0 * v.y + self.cells[i][j][k - 1].velocity.y) / (self.dz * self.dz);
                let d2w = (self.cells[i][j][k + 1].velocity.z - 2.0 * v.z + self.cells[i][j][k - 1].velocity.z) / (self.dz * self.dz);
                lap = lap.add(&Vec3::new(d2u, d2v, d2w));
            }
            lap
        }

        pub fn advection_term(&self, i: usize, j: usize, k: usize) -> Vec3 {
            let v = &self.cells[i][j][k].velocity;
            let mut adv = Vec3::zero();

            if i > 0 && i + 1 < self.nx {
                let du = (self.cells[i + 1][j][k].velocity.x - self.cells[i - 1][j][k].velocity.x) / (2.0 * self.dx);
                let dv = (self.cells[i + 1][j][k].velocity.y - self.cells[i - 1][j][k].velocity.y) / (2.0 * self.dx);
                let dw = (self.cells[i + 1][j][k].velocity.z - self.cells[i - 1][j][k].velocity.z) / (2.0 * self.dx);
                adv = adv.add(&Vec3::new(v.x * du, v.x * dv, v.x * dw));
            }
            if j > 0 && j + 1 < self.ny {
                let du = (self.cells[i][j + 1][k].velocity.x - self.cells[i][j - 1][k].velocity.x) / (2.0 * self.dy);
                let dv = (self.cells[i][j + 1][k].velocity.y - self.cells[i][j - 1][k].velocity.y) / (2.0 * self.dy);
                let dw = (self.cells[i][j + 1][k].velocity.z - self.cells[i][j - 1][k].velocity.z) / (2.0 * self.dy);
                adv = adv.add(&Vec3::new(v.y * du, v.y * dv, v.y * dw));
            }
            if k > 0 && k + 1 < self.nz {
                let du = (self.cells[i][j][k + 1].velocity.x - self.cells[i][j][k - 1].velocity.x) / (2.0 * self.dz);
                let dv = (self.cells[i][j][k + 1].velocity.y - self.cells[i][j][k - 1].velocity.y) / (2.0 * self.dz);
                let dw = (self.cells[i][j][k + 1].velocity.z - self.cells[i][j][k - 1].velocity.z) / (2.0 * self.dz);
                adv = adv.add(&Vec3::new(v.z * du, v.z * dv, v.z * dw));
            }
            adv
        }

        pub fn pressure_gradient(&self, i: usize, j: usize, k: usize) -> Vec3 {
            let dp_dx = if i > 0 && i + 1 < self.nx {
                (self.cells[i + 1][j][k].pressure - self.cells[i - 1][j][k].pressure) / (2.0 * self.dx)
            } else { 0.0 };
            let dp_dy = if j > 0 && j + 1 < self.ny {
                (self.cells[i][j + 1][k].pressure - self.cells[i][j - 1][k].pressure) / (2.0 * self.dy)
            } else { 0.0 };
            let dp_dz = if k > 0 && k + 1 < self.nz {
                (self.cells[i][j][k + 1].pressure - self.cells[i][j][k - 1].pressure) / (2.0 * self.dz)
            } else { 0.0 };
            Vec3::new(dp_dx, dp_dy, dp_dz)
        }

        pub fn step(&mut self, dt: f64) {
            let nu = self.properties.kinematic_viscosity();
            let mut new_velocities = vec![vec![vec![Vec3::zero(); self.nz]; self.ny]; self.nx];

            for i in 1..self.nx - 1 {
                for j in 1..self.ny - 1 {
                    for k in 1..self.nz - 1 {
                        let v = &self.cells[i][j][k].velocity;
                        let adv = self.advection_term(i, j, k);
                        let lap = self.laplacian_velocity(i, j, k);
                        let grad_p = self.pressure_gradient(i, j, k);
                        let rho = self.cells[i][j][k].density;

                        new_velocities[i][j][k] = v.sub(&adv.scale(dt))
                            .add(&lap.scale(nu * dt))
                            .sub(&grad_p.scale(dt / rho));
                    }
                }
            }

            for i in 1..self.nx - 1 {
                for j in 1..self.ny - 1 {
                    for k in 1..self.nz - 1 {
                        self.cells[i][j][k].velocity = new_velocities[i][j][k].clone();
                    }
                }
            }
        }

        pub fn reynolds_number(&self, length_scale: f64, velocity_scale: f64) -> f64 {
            self.properties.density * velocity_scale * length_scale / self.properties.viscosity
        }

        pub fn total_kinetic_energy(&self) -> f64 {
            let dv = self.dx * self.dy * self.dz;
            let mut energy = 0.0;
            for i in 0..self.nx {
                for j in 0..self.ny {
                    for k in 0..self.nz {
                        let cell = &self.cells[i][j][k];
                        energy += 0.5 * cell.density * cell.velocity.dot(&cell.velocity) * dv;
                    }
                }
            }
            energy
        }

        pub fn total_enstrophy(&self) -> f64 {
            let dv = self.dx * self.dy * self.dz;
            let mut enstrophy = 0.0;
            for i in 1..self.nx - 1 {
                for j in 1..self.ny - 1 {
                    for k in 1..self.nz - 1 {
                        let vort = self.curl(i, j, k);
                        enstrophy += 0.5 * vort.dot(&vort) * dv;
                    }
                }
            }
            enstrophy
        }
    }

    pub struct LatticeBotzmann2D {
        pub nx: usize, pub ny: usize,
        f: Vec<Vec<[f64; 9]>>,
        feq: Vec<Vec<[f64; 9]>>,
        rho: Vec<Vec<f64>>,
        ux: Vec<Vec<f64>>,
        uy: Vec<Vec<f64>>,
        omega: f64,
    }

    impl LatticeBotzmann2D {
        const W: [f64; 9] = [4.0/9.0, 1.0/9.0, 1.0/9.0, 1.0/9.0, 1.0/9.0, 1.0/36.0, 1.0/36.0, 1.0/36.0, 1.0/36.0];
        const CX: [i32; 9] = [0, 1, 0, -1, 0, 1, -1, -1, 1];
        const CY: [i32; 9] = [0, 0, 1, 0, -1, 1, 1, -1, -1];

        pub fn new(nx: usize, ny: usize, viscosity: f64) -> Self {
            let omega = 1.0 / (3.0 * viscosity + 0.5);
            Self {
                nx, ny,
                f: vec![vec![[0.0; 9]; ny]; nx],
                feq: vec![vec![[0.0; 9]; ny]; nx],
                rho: vec![vec![1.0; ny]; nx],
                ux: vec![vec![0.0; ny]; nx],
                uy: vec![vec![0.0; ny]; nx],
                omega,
            }
        }

        pub fn initialize(&mut self, density: f64, ux: f64, uy: f64) {
            for i in 0..self.nx {
                for j in 0..self.ny {
                    self.rho[i][j] = density;
                    self.ux[i][j] = ux;
                    self.uy[i][j] = uy;
                    self.compute_equilibrium(i, j);
                    self.f[i][j] = self.feq[i][j];
                }
            }
        }

        fn compute_equilibrium(&mut self, i: usize, j: usize) {
            let rho = self.rho[i][j];
            let ux = self.ux[i][j];
            let uy = self.uy[i][j];
            let u2 = ux * ux + uy * uy;

            for k in 0..9 {
                let cu = Self::CX[k] as f64 * ux + Self::CY[k] as f64 * uy;
                self.feq[i][j][k] = Self::W[k] * rho * (1.0 + 3.0 * cu + 4.5 * cu * cu - 1.5 * u2);
            }
        }

        pub fn collide(&mut self) {
            for i in 0..self.nx {
                for j in 0..self.ny {
                    self.compute_equilibrium(i, j);
                    for k in 0..9 {
                        self.f[i][j][k] += self.omega * (self.feq[i][j][k] - self.f[i][j][k]);
                    }
                }
            }
        }

        pub fn stream(&mut self) {
            let mut f_new = self.f.clone();

            for i in 0..self.nx {
                for j in 0..self.ny {
                    for k in 0..9 {
                        let ni = ((i as i32 + Self::CX[k] + self.nx as i32) % self.nx as i32) as usize;
                        let nj = ((j as i32 + Self::CY[k] + self.ny as i32) % self.ny as i32) as usize;
                        f_new[ni][nj][k] = self.f[i][j][k];
                    }
                }
            }

            self.f = f_new;
        }

        pub fn compute_macroscopic(&mut self) {
            for i in 0..self.nx {
                for j in 0..self.ny {
                    self.rho[i][j] = self.f[i][j].iter().sum();
                    self.ux[i][j] = 0.0;
                    self.uy[i][j] = 0.0;
                    for k in 0..9 {
                        self.ux[i][j] += Self::CX[k] as f64 * self.f[i][j][k];
                        self.uy[i][j] += Self::CY[k] as f64 * self.f[i][j][k];
                    }
                    if self.rho[i][j] > 1e-10 {
                        self.ux[i][j] /= self.rho[i][j];
                        self.uy[i][j] /= self.rho[i][j];
                    }
                }
            }
        }

        pub fn step(&mut self) {
            self.collide();
            self.stream();
            self.compute_macroscopic();
        }

        pub fn get_velocity(&self, i: usize, j: usize) -> (f64, f64) {
            (self.ux[i][j], self.uy[i][j])
        }

        pub fn get_density(&self, i: usize, j: usize) -> f64 {
            self.rho[i][j]
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GENERAL RELATIVITY - Metric Tensors, Einstein Equations
// ═══════════════════════════════════════════════════════════════════════════════

pub mod general_relativity {
    use std::f64::consts::PI;

    pub const G: f64 = 6.67430e-11;
    pub const C: f64 = 299792458.0;

    #[derive(Debug, Clone)]
    pub struct Metric4D {
        pub components: [[f64; 4]; 4],
    }

    impl Metric4D {
        pub fn minkowski() -> Self {
            let mut components = [[0.0; 4]; 4];
            components[0][0] = -1.0;
            components[1][1] = 1.0;
            components[2][2] = 1.0;
            components[3][3] = 1.0;
            Self { components }
        }

        pub fn schwarzschild(r: f64, m: f64) -> Self {
            let rs = 2.0 * G * m / (C * C);
            let factor = 1.0 - rs / r;
            let mut components = [[0.0; 4]; 4];
            components[0][0] = -factor;
            components[1][1] = 1.0 / factor;
            components[2][2] = r * r;
            components[3][3] = r * r;
            Self { components }
        }

        pub fn kerr(r: f64, theta: f64, m: f64, a: f64) -> Self {
            let rs = 2.0 * G * m / (C * C);
            let sigma = r * r + a * a * theta.cos().powi(2);
            let delta = r * r - rs * r + a * a;
            let sin2 = theta.sin().powi(2);

            let mut components = [[0.0; 4]; 4];
            components[0][0] = -(1.0 - rs * r / sigma);
            components[0][3] = -rs * r * a * sin2 / sigma;
            components[3][0] = components[0][3];
            components[1][1] = sigma / delta;
            components[2][2] = sigma;
            components[3][3] = (r * r + a * a + rs * r * a * a * sin2 / sigma) * sin2;
            Self { components }
        }

        pub fn flrw(a: f64, k: f64) -> Self {
            let mut components = [[0.0; 4]; 4];
            components[0][0] = -1.0;
            components[1][1] = a * a;
            components[2][2] = a * a;
            components[3][3] = a * a;
            Self { components }
        }

        pub fn inverse(&self) -> Metric4D {
            let mut inv = [[0.0; 4]; 4];
            let det = self.determinant();
            if det.abs() < 1e-20 { return Metric4D { components: inv }; }

            for i in 0..4 {
                for j in 0..4 {
                    inv[i][j] = self.cofactor(j, i) / det;
                }
            }
            Metric4D { components: inv }
        }

        pub fn determinant(&self) -> f64 {
            let m = &self.components;
            m[0][0] * self.minor(0, 0) - m[0][1] * self.minor(0, 1) +
            m[0][2] * self.minor(0, 2) - m[0][3] * self.minor(0, 3)
        }

        fn minor(&self, row: usize, col: usize) -> f64 {
            let mut sub = [[0.0; 3]; 3];
            let mut si = 0;
            for i in 0..4 {
                if i == row { continue; }
                let mut sj = 0;
                for j in 0..4 {
                    if j == col { continue; }
                    sub[si][sj] = self.components[i][j];
                    sj += 1;
                }
                si += 1;
            }
            sub[0][0] * (sub[1][1] * sub[2][2] - sub[1][2] * sub[2][1]) -
            sub[0][1] * (sub[1][0] * sub[2][2] - sub[1][2] * sub[2][0]) +
            sub[0][2] * (sub[1][0] * sub[2][1] - sub[1][1] * sub[2][0])
        }

        fn cofactor(&self, i: usize, j: usize) -> f64 {
            let sign = if (i + j) % 2 == 0 { 1.0 } else { -1.0 };
            sign * self.minor(i, j)
        }

        pub fn raise_index(&self, covector: &[f64; 4]) -> [f64; 4] {
            let inv = self.inverse();
            let mut result = [0.0; 4];
            for i in 0..4 {
                for j in 0..4 {
                    result[i] += inv.components[i][j] * covector[j];
                }
            }
            result
        }

        pub fn lower_index(&self, vector: &[f64; 4]) -> [f64; 4] {
            let mut result = [0.0; 4];
            for i in 0..4 {
                for j in 0..4 {
                    result[i] += self.components[i][j] * vector[j];
                }
            }
            result
        }
    }

    #[derive(Debug, Clone)]
    pub struct StressEnergyTensor {
        pub components: [[f64; 4]; 4],
    }

    impl StressEnergyTensor {
        pub fn vacuum() -> Self { Self { components: [[0.0; 4]; 4] } }

        pub fn perfect_fluid(rho: f64, p: f64, u: &[f64; 4], metric: &Metric4D) -> Self {
            let mut t = [[0.0; 4]; 4];
            for mu in 0..4 {
                for nu in 0..4 {
                    t[mu][nu] = (rho + p / (C * C)) * u[mu] * u[nu] + p * metric.components[mu][nu];
                }
            }
            Self { components: t }
        }

        pub fn em_field(e: &[f64; 3], b: &[f64; 3]) -> Self {
            let e2: f64 = e.iter().map(|x| x * x).sum();
            let b2: f64 = b.iter().map(|x| x * x).sum();
            let u = 0.5 * (e2 + b2);

            let mut t = [[0.0; 4]; 4];
            t[0][0] = u;
            for i in 0..3 {
                t[0][i + 1] = e[(i + 1) % 3] * b[(i + 2) % 3] - e[(i + 2) % 3] * b[(i + 1) % 3];
                t[i + 1][0] = t[0][i + 1];
            }
            for i in 0..3 {
                for j in 0..3 {
                    let delta = if i == j { 1.0 } else { 0.0 };
                    t[i + 1][j + 1] = -e[i] * e[j] - b[i] * b[j] + delta * u;
                }
            }
            Self { components: t }
        }

        pub fn trace(&self, metric: &Metric4D) -> f64 {
            let inv = metric.inverse();
            let mut t = 0.0;
            for mu in 0..4 {
                for nu in 0..4 {
                    t += inv.components[mu][nu] * self.components[mu][nu];
                }
            }
            t
        }
    }

    pub struct EinsteinTensor {
        pub components: [[f64; 4]; 4],
    }

    impl EinsteinTensor {
        pub fn from_ricci(ricci: &[[f64; 4]; 4], scalar_curvature: f64, metric: &Metric4D) -> Self {
            let mut g = [[0.0; 4]; 4];
            for mu in 0..4 {
                for nu in 0..4 {
                    g[mu][nu] = ricci[mu][nu] - 0.5 * scalar_curvature * metric.components[mu][nu];
                }
            }
            Self { components: g }
        }

        pub fn field_equations(&self, stress_energy: &StressEnergyTensor, cosmological_constant: f64, metric: &Metric4D) -> [[f64; 4]; 4] {
            let kappa = 8.0 * PI * G / (C * C * C * C);
            let mut residual = [[0.0; 4]; 4];
            for mu in 0..4 {
                for nu in 0..4 {
                    residual[mu][nu] = self.components[mu][nu] +
                        cosmological_constant * metric.components[mu][nu] -
                        kappa * stress_energy.components[mu][nu];
                }
            }
            residual
        }
    }

    pub struct BlackHole {
        pub mass: f64,
        pub spin: f64,
        pub charge: f64,
    }

    impl BlackHole {
        pub fn schwarzschild(mass: f64) -> Self { Self { mass, spin: 0.0, charge: 0.0 } }
        pub fn kerr(mass: f64, spin: f64) -> Self { Self { mass, spin, charge: 0.0 } }

        pub fn schwarzschild_radius(&self) -> f64 { 2.0 * G * self.mass / (C * C) }

        pub fn event_horizon_radius(&self) -> f64 {
            let rs = self.schwarzschild_radius();
            let a = self.spin * G * self.mass / (C * C * C);
            0.5 * rs + (0.25 * rs * rs - a * a).sqrt()
        }

        pub fn hawking_temperature(&self) -> f64 {
            let hbar = 1.054571817e-34;
            let kb = 1.380649e-23;
            hbar * C * C * C / (8.0 * PI * G * self.mass * kb)
        }

        pub fn entropy(&self) -> f64 {
            let hbar = 1.054571817e-34;
            let kb = 1.380649e-23;
            let area = 4.0 * PI * self.schwarzschild_radius().powi(2);
            kb * C * C * C * area / (4.0 * G * hbar)
        }

        pub fn isco_radius(&self) -> f64 {
            let rs = self.schwarzschild_radius();
            if self.spin.abs() < 1e-10 { 3.0 * rs }
            else {
                let a = self.spin * G * self.mass / (C * C * C);
                let z1 = 1.0 + (1.0 - (a / (0.5 * rs)).powi(2)).cbrt() *
                    ((1.0 + a / (0.5 * rs)).cbrt() + (1.0 - a / (0.5 * rs)).cbrt());
                let z2 = (3.0 * (a / (0.5 * rs)).powi(2) + z1 * z1).sqrt();
                0.5 * rs * (3.0 + z2 - ((3.0 - z1) * (3.0 + z1 + 2.0 * z2)).sqrt())
            }
        }
    }

    pub struct CosmologicalModel {
        pub hubble_constant: f64,
        pub omega_matter: f64,
        pub omega_lambda: f64,
        pub omega_radiation: f64,
    }

    impl CosmologicalModel {
        pub fn lambda_cdm() -> Self {
            Self { hubble_constant: 67.4, omega_matter: 0.315, omega_lambda: 0.685, omega_radiation: 9e-5 }
        }

        pub fn scale_factor(&self, t: f64) -> f64 {
            let h0 = self.hubble_constant * 1e3 / (3.086e22);
            let om = self.omega_matter;
            let ol = self.omega_lambda;

            if ol.abs() < 1e-10 {
                ((1.5 * h0 * t * om.sqrt()).sinh() / (1.5 * h0 * t * om.sqrt())).powf(2.0 / 3.0)
            } else {
                let eta = (ol / om).powf(1.0 / 3.0) * (1.5 * ol.sqrt() * h0 * t).sinh();
                eta.powf(2.0 / 3.0) * (om / ol).powf(1.0 / 3.0)
            }
        }

        pub fn hubble_parameter(&self, a: f64) -> f64 {
            let h0 = self.hubble_constant * 1e3 / (3.086e22);
            let om = self.omega_matter;
            let ol = self.omega_lambda;
            let or = self.omega_radiation;
            h0 * (or / a.powi(4) + om / a.powi(3) + ol).sqrt()
        }

        pub fn age_of_universe(&self) -> f64 {
            let h0 = self.hubble_constant * 1e3 / (3.086e22);
            let ol = self.omega_lambda;
            if ol > 0.0 {
                2.0 / (3.0 * h0 * ol.sqrt()) * ((ol / self.omega_matter).sqrt() + (1.0 + ol / self.omega_matter).sqrt()).ln()
            } else {
                2.0 / (3.0 * h0)
            }
        }

        pub fn comoving_distance(&self, z: f64) -> f64 {
            let h0 = self.hubble_constant * 1e3 / (3.086e22);
            let n = 1000;
            let dz = z / n as f64;
            let mut d = 0.0;
            for i in 0..n {
                let zi = (i as f64 + 0.5) * dz;
                let hz = self.hubble_parameter(1.0 / (1.0 + zi));
                d += C / hz * dz;
            }
            d
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NUMERICAL METHODS - Finite Elements, Spectral Methods
// ═══════════════════════════════════════════════════════════════════════════════

pub mod numerical_methods {
    use std::f64::consts::PI;

    pub struct FiniteElement1D {
        pub n_elements: usize,
        pub nodes: Vec<f64>,
        pub stiffness: Vec<Vec<f64>>,
        pub mass: Vec<Vec<f64>>,
    }

    impl FiniteElement1D {
        pub fn new(domain: (f64, f64), n_elements: usize) -> Self {
            let n_nodes = n_elements + 1;
            let dx = (domain.1 - domain.0) / n_elements as f64;
            let nodes: Vec<f64> = (0..n_nodes).map(|i| domain.0 + i as f64 * dx).collect();

            let mut stiffness = vec![vec![0.0; n_nodes]; n_nodes];
            let mut mass = vec![vec![0.0; n_nodes]; n_nodes];

            for e in 0..n_elements {
                let h = nodes[e + 1] - nodes[e];
                stiffness[e][e] += 1.0 / h;
                stiffness[e][e + 1] += -1.0 / h;
                stiffness[e + 1][e] += -1.0 / h;
                stiffness[e + 1][e + 1] += 1.0 / h;

                mass[e][e] += h / 3.0;
                mass[e][e + 1] += h / 6.0;
                mass[e + 1][e] += h / 6.0;
                mass[e + 1][e + 1] += h / 3.0;
            }

            Self { n_elements, nodes, stiffness, mass }
        }

        pub fn assemble_load(&self, f: impl Fn(f64) -> f64) -> Vec<f64> {
            let n_nodes = self.nodes.len();
            let mut load = vec![0.0; n_nodes];

            for e in 0..self.n_elements {
                let x0 = self.nodes[e];
                let x1 = self.nodes[e + 1];
                let h = x1 - x0;

                let f0 = f(x0);
                let f1 = f(x1);

                load[e] += h * (2.0 * f0 + f1) / 6.0;
                load[e + 1] += h * (f0 + 2.0 * f1) / 6.0;
            }

            load
        }

        pub fn solve_dirichlet(&self, load: &[f64], bc_left: f64, bc_right: f64) -> Vec<f64> {
            let n = self.nodes.len();
            let mut a = self.stiffness.clone();
            let mut b = load.to_vec();

            a[0] = vec![0.0; n];
            a[0][0] = 1.0;
            b[0] = bc_left;

            a[n - 1] = vec![0.0; n];
            a[n - 1][n - 1] = 1.0;
            b[n - 1] = bc_right;

            self.solve_linear_system(&a, &b)
        }

        fn solve_linear_system(&self, a: &[Vec<f64>], b: &[f64]) -> Vec<f64> {
            let n = b.len();
            let mut aug: Vec<Vec<f64>> = a.iter().enumerate()
                .map(|(i, row)| { let mut r = row.clone(); r.push(b[i]); r }).collect();

            for i in 0..n {
                let pivot = aug[i][i];
                if pivot.abs() < 1e-10 { continue; }
                for j in 0..=n { aug[i][j] /= pivot; }
                for k in 0..n {
                    if k != i {
                        let factor = aug[k][i];
                        for j in 0..=n { aug[k][j] -= factor * aug[i][j]; }
                    }
                }
            }

            aug.iter().map(|row| row[n]).collect()
        }
    }

    pub struct SpectralMethod {
        pub n_modes: usize,
        pub domain: (f64, f64),
    }

    impl SpectralMethod {
        pub fn new(n_modes: usize, domain: (f64, f64)) -> Self { Self { n_modes, domain } }

        pub fn fft(&self, signal: &[f64]) -> Vec<(f64, f64)> {
            let n = signal.len();
            if n <= 1 { return signal.iter().map(|&x| (x, 0.0)).collect(); }

            let even: Vec<f64> = signal.iter().step_by(2).cloned().collect();
            let odd: Vec<f64> = signal.iter().skip(1).step_by(2).cloned().collect();

            let even_fft = self.fft(&even);
            let odd_fft = self.fft(&odd);

            let mut result = vec![(0.0, 0.0); n];
            for k in 0..n / 2 {
                let angle = -2.0 * PI * k as f64 / n as f64;
                let twiddle_re = angle.cos();
                let twiddle_im = angle.sin();

                let odd_re = odd_fft[k].0 * twiddle_re - odd_fft[k].1 * twiddle_im;
                let odd_im = odd_fft[k].0 * twiddle_im + odd_fft[k].1 * twiddle_re;

                result[k] = (even_fft[k].0 + odd_re, even_fft[k].1 + odd_im);
                result[k + n / 2] = (even_fft[k].0 - odd_re, even_fft[k].1 - odd_im);
            }

            result
        }

        pub fn ifft(&self, spectrum: &[(f64, f64)]) -> Vec<f64> {
            let n = spectrum.len();
            let conj: Vec<f64> = spectrum.iter().map(|(re, im)| re - im).collect();
            let transformed = self.fft(&conj);
            transformed.iter().map(|(re, _)| re / n as f64).collect()
        }

        pub fn chebyshev_nodes(&self) -> Vec<f64> {
            (0..self.n_modes).map(|k| {
                let theta = PI * (2.0 * k as f64 + 1.0) / (2.0 * self.n_modes as f64);
                0.5 * (self.domain.0 + self.domain.1) +
                0.5 * (self.domain.1 - self.domain.0) * theta.cos()
            }).collect()
        }

        pub fn chebyshev_coefficients(&self, f: impl Fn(f64) -> f64) -> Vec<f64> {
            let nodes = self.chebyshev_nodes();
            let values: Vec<f64> = nodes.iter().map(|&x| f(x)).collect();

            (0..self.n_modes).map(|k| {
                let sum: f64 = values.iter().enumerate().map(|(j, &fj)| {
                    let theta = PI * (2.0 * j as f64 + 1.0) / (2.0 * self.n_modes as f64);
                    fj * (k as f64 * theta).cos()
                }).sum();
                2.0 * sum / self.n_modes as f64
            }).collect()
        }

        pub fn evaluate_chebyshev(&self, coeffs: &[f64], x: f64) -> f64 {
            let x_normalized = 2.0 * (x - self.domain.0) / (self.domain.1 - self.domain.0) - 1.0;
            let mut result = 0.0;
            for (k, &c) in coeffs.iter().enumerate() {
                result += c * self.chebyshev_polynomial(k, x_normalized);
            }
            result
        }

        fn chebyshev_polynomial(&self, n: usize, x: f64) -> f64 {
            if n == 0 { 1.0 }
            else if n == 1 { x }
            else {
                let mut t_prev = 1.0;
                let mut t_curr = x;
                for _ in 2..=n {
                    let t_next = 2.0 * x * t_curr - t_prev;
                    t_prev = t_curr;
                    t_curr = t_next;
                }
                t_curr
            }
        }

        pub fn differentiation_matrix(&self) -> Vec<Vec<f64>> {
            let nodes = self.chebyshev_nodes();
            let n = nodes.len();
            let mut d = vec![vec![0.0; n]; n];

            for i in 0..n {
                for j in 0..n {
                    if i != j {
                        let ci = if i == 0 || i == n - 1 { 2.0 } else { 1.0 };
                        let cj = if j == 0 || j == n - 1 { 2.0 } else { 1.0 };
                        let sign = if (i + j) % 2 == 0 { 1.0 } else { -1.0 };
                        d[i][j] = ci / cj * sign / (nodes[i] - nodes[j]);
                    }
                }
                d[i][i] = -d[i].iter().enumerate().filter(|(k, _)| *k != i).map(|(_, &v)| v).sum::<f64>();
            }

            d
        }
    }

    pub struct RungeKutta {
        pub order: usize,
    }

    impl RungeKutta {
        pub fn rk4() -> Self { Self { order: 4 } }

        pub fn step<F>(&self, f: &F, t: f64, y: &[f64], h: f64) -> Vec<f64>
        where F: Fn(f64, &[f64]) -> Vec<f64> {
            let n = y.len();

            let k1 = f(t, y);
            let y1: Vec<f64> = (0..n).map(|i| y[i] + 0.5 * h * k1[i]).collect();
            let k2 = f(t + 0.5 * h, &y1);
            let y2: Vec<f64> = (0..n).map(|i| y[i] + 0.5 * h * k2[i]).collect();
            let k3 = f(t + 0.5 * h, &y2);
            let y3: Vec<f64> = (0..n).map(|i| y[i] + h * k3[i]).collect();
            let k4 = f(t + h, &y3);

            (0..n).map(|i| y[i] + h / 6.0 * (k1[i] + 2.0 * k2[i] + 2.0 * k3[i] + k4[i])).collect()
        }

        pub fn solve<F>(&self, f: &F, t_span: (f64, f64), y0: &[f64], n_steps: usize) -> Vec<(f64, Vec<f64>)>
        where F: Fn(f64, &[f64]) -> Vec<f64> {
            let h = (t_span.1 - t_span.0) / n_steps as f64;
            let mut trajectory = Vec::with_capacity(n_steps + 1);

            let mut t = t_span.0;
            let mut y = y0.to_vec();
            trajectory.push((t, y.clone()));

            for _ in 0..n_steps {
                y = self.step(f, t, &y, h);
                t += h;
                trajectory.push((t, y.clone()));
            }

            trajectory
        }
    }

    pub struct GaussQuadrature {
        pub n_points: usize,
        nodes: Vec<f64>,
        weights: Vec<f64>,
    }

    impl GaussQuadrature {
        pub fn new(n_points: usize) -> Self {
            let (nodes, weights) = Self::compute_gauss_legendre(n_points);
            Self { n_points, nodes, weights }
        }

        fn compute_gauss_legendre(n: usize) -> (Vec<f64>, Vec<f64>) {
            let mut nodes = Vec::with_capacity(n);
            let mut weights = Vec::with_capacity(n);

            for i in 0..n {
                let mut x = (PI * (4.0 * i as f64 + 3.0) / (4.0 * n as f64 + 2.0)).cos();

                for _ in 0..100 {
                    let (p, dp) = Self::legendre_poly_deriv(n, x);
                    let x_new = x - p / dp;
                    if (x_new - x).abs() < 1e-15 { break; }
                    x = x_new;
                }

                let (_, dp) = Self::legendre_poly_deriv(n, x);
                let w = 2.0 / ((1.0 - x * x) * dp * dp);

                nodes.push(x);
                weights.push(w);
            }

            (nodes, weights)
        }

        fn legendre_poly_deriv(n: usize, x: f64) -> (f64, f64) {
            if n == 0 { return (1.0, 0.0); }
            if n == 1 { return (x, 1.0); }

            let mut p_prev = 1.0;
            let mut p_curr = x;
            let mut dp_prev = 0.0;
            let mut dp_curr = 1.0;

            for k in 2..=n {
                let k_f = k as f64;
                let p_next = ((2.0 * k_f - 1.0) * x * p_curr - (k_f - 1.0) * p_prev) / k_f;
                let dp_next = dp_prev + (2.0 * k_f - 1.0) * p_curr;

                p_prev = p_curr;
                p_curr = p_next;
                dp_prev = dp_curr;
                dp_curr = dp_next;
            }

            (p_curr, dp_curr)
        }

        pub fn integrate<F>(&self, f: F, a: f64, b: f64) -> f64
        where F: Fn(f64) -> f64 {
            let scale = (b - a) / 2.0;
            let shift = (b + a) / 2.0;

            self.nodes.iter().zip(self.weights.iter())
                .map(|(&xi, &wi)| wi * f(shift + scale * xi))
                .sum::<f64>() * scale
        }
    }

    pub struct SparseMatrix {
        pub rows: usize,
        pub cols: usize,
        data: Vec<(usize, usize, f64)>,
    }

    impl SparseMatrix {
        pub fn new(rows: usize, cols: usize) -> Self {
            Self { rows, cols, data: Vec::new() }
        }

        pub fn insert(&mut self, i: usize, j: usize, val: f64) {
            if val.abs() > 1e-15 { self.data.push((i, j, val)); }
        }

        pub fn mul_vec(&self, x: &[f64]) -> Vec<f64> {
            let mut result = vec![0.0; self.rows];
            for &(i, j, val) in &self.data {
                result[i] += val * x[j];
            }
            result
        }

        pub fn conjugate_gradient(&self, b: &[f64], tol: f64, max_iter: usize) -> Vec<f64> {
            let n = b.len();
            let mut x = vec![0.0; n];
            let mut r: Vec<f64> = b.to_vec();
            let mut p = r.clone();
            let mut rs_old: f64 = r.iter().map(|ri| ri * ri).sum();

            for _ in 0..max_iter {
                let ap = self.mul_vec(&p);
                let alpha = rs_old / p.iter().zip(ap.iter()).map(|(pi, api)| pi * api).sum::<f64>();

                for i in 0..n {
                    x[i] += alpha * p[i];
                    r[i] -= alpha * ap[i];
                }

                let rs_new: f64 = r.iter().map(|ri| ri * ri).sum();
                if rs_new.sqrt() < tol { break; }

                let beta = rs_new / rs_old;
                for i in 0..n { p[i] = r[i] + beta * p[i]; }
                rs_old = rs_new;
            }

            x
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_tensor_creation() {
        let tensor = MarketTensor4D::new(100, 5, 16, 4);
        assert_eq!(tensor.shape, [100, 5, 16, 4]);
    }

    #[test]
    fn test_tensor_access() {
        let mut tensor = MarketTensor4D::new(10, 3, 5, 2);
        tensor.set(5, 1, 2, 0, 42.0);
        assert_eq!(tensor.get(5, 1, 2, 0), 42.0);
    }

    #[test]
    fn test_matrix_operations() {
        let mut m = Matrix::new(2, 2);
        m.set(0, 0, 1.0);
        m.set(0, 1, 2.0);
        m.set(1, 0, 3.0);
        m.set(1, 1, 4.0);

        assert_eq!(m.determinant(), -2.0);
        assert_eq!(m.trace(), 5.0);
    }

    #[test]
    fn test_matrix_inverse() {
        let mut m = Matrix::new(2, 2);
        m.set(0, 0, 4.0);
        m.set(0, 1, 7.0);
        m.set(1, 0, 2.0);
        m.set(1, 1, 6.0);

        if let Some(inv) = m.inverse() {
            let product = m.matmul(&inv);
            assert!((product.get(0, 0) - 1.0).abs() < 1e-10);
            assert!((product.get(1, 1) - 1.0).abs() < 1e-10);
        }
    }

    #[test]
    fn test_sma() {
        let prices = vec![10.0, 11.0, 12.0, 13.0, 14.0];
        let sma = TechnicalIndicators::sma(&prices, 3);
        assert!((sma[2] - 11.0).abs() < 1e-10);
        assert!((sma[4] - 13.0).abs() < 1e-10);
    }

    #[test]
    fn test_ema() {
        let prices = vec![10.0, 11.0, 12.0, 13.0, 14.0];
        let ema = TechnicalIndicators::ema(&prices, 3);
        assert!(!ema.is_empty());
        assert!(ema[4] > ema[0]);
    }

    #[test]
    fn test_rsi() {
        let prices: Vec<f64> = (0..20).map(|i| 100.0 + (i as f64)).collect();
        let rsi = TechnicalIndicators::rsi(&prices, 14);
        // Strictly increasing prices should give high RSI
        assert!(rsi[19] > 50.0);
    }

    #[test]
    fn test_portfolio_optimizer() {
        let returns = vec![0.10, 0.15, 0.12];
        let mut cov = Matrix::new(3, 3);
        cov.set(0, 0, 0.04);
        cov.set(1, 1, 0.09);
        cov.set(2, 2, 0.0625);
        cov.set(0, 1, 0.01);
        cov.set(1, 0, 0.01);

        let optimizer = PortfolioOptimizer::new(returns, cov);
        let weights = optimizer.mean_variance(2.0);

        let sum: f64 = weights.iter().sum();
        assert!((sum - 1.0).abs() < 1e-10);
        assert!(weights.iter().all(|&w| w >= 0.0));
    }

    #[test]
    fn test_minimum_variance() {
        let returns = vec![0.10, 0.15, 0.12];
        let mut cov = Matrix::new(3, 3);
        cov.set(0, 0, 0.04);
        cov.set(1, 1, 0.09);
        cov.set(2, 2, 0.0625);

        let optimizer = PortfolioOptimizer::new(returns, cov);
        let weights = optimizer.minimum_variance();

        // Lowest variance asset should have highest weight
        assert!(weights[0] > weights[1]);
    }

    #[test]
    fn test_gauge_portfolio() {
        let mut gauge = GaugePortfolio::new(3);
        let mut cov = Matrix::new(3, 3);
        cov.set(0, 0, 0.04);
        cov.set(1, 1, 0.09);
        cov.set(2, 2, 0.0625);
        cov.set(0, 1, 0.02);
        cov.set(1, 0, 0.02);

        gauge.set_connection(&cov);
        let f = gauge.field_strength();

        // Field strength should be antisymmetric-ish
        assert!(f.rows == 3);
    }

    #[test]
    fn test_tensor_builder() {
        let mut builder = MarketTensorBuilder::new();
        builder.add_symbol("AAPL");
        builder.add_symbol("GOOGL");

        for i in 0..50 {
            builder.add_ohlcv("AAPL", i as u64, 100.0 + i as f64, 102.0 + i as f64, 99.0 + i as f64, 101.0 + i as f64, 1000000.0);
            builder.add_ohlcv("GOOGL", i as u64, 200.0 + i as f64 * 2.0, 205.0 + i as f64 * 2.0, 198.0 + i as f64 * 2.0, 202.0 + i as f64 * 2.0, 500000.0);
        }

        let tensor = builder.build(30);

        assert_eq!(tensor.shape[0], 30); // Time
        assert_eq!(tensor.shape[1], 2);  // Assets
        assert_eq!(tensor.shape[2], 16); // Features
        assert_eq!(tensor.shape[3], 4);  // Derivatives
    }

    #[test]
    fn test_market_geometry() {
        let mut tensor = MarketTensor4D::new(100, 3, 16, 4);

        // Add some random-ish returns
        for t in 0..100 {
            for a in 0..3 {
                let ret = 0.01 * ((t * (a + 1)) % 7) as f64 - 0.03;
                tensor.set(t, a, features::PRICE, derivatives::FIRST, ret);
            }
        }

        let geometry = MarketGeometry::new(tensor);
        let scalar = geometry.scalar_curvature();

        // Scalar curvature should be finite
        assert!(scalar.is_finite());
    }
}
