// MATRIX OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Dense matrix for linear algebra operations
pub struct Matrix {
    data: Vec<f64>,
    pub rows: usize,
    pub cols: usize,
}

impl Matrix {
    pub fn new(rows: usize, cols: usize) -> Self {
        Matrix {
            data: vec![0.0; rows * cols],
            rows,
            cols,
        }
    }

    pub fn from_data(data: Vec<f64>, rows: usize, cols: usize) -> Self {
        Matrix { data, rows, cols }
    }

    pub fn identity(n: usize) -> Self {
        let mut m = Matrix::new(n, n);
        for i in 0..n {
            m.set(i, i, 1.0);
        }
        m
    }

    pub fn get(&self, row: usize, col: usize) -> f64 {
        self.data[row * self.cols + col]
    }

    pub fn set(&mut self, row: usize, col: usize, value: f64) {
        self.data[row * self.cols + col] = value;
    }

    /// Matrix multiplication
    pub fn matmul(&self, other: &Matrix) -> Matrix {
        assert_eq!(self.cols, other.rows, "Matrix dimensions incompatible");

        let mut result = Matrix::new(self.rows, other.cols);

        for i in 0..self.rows {
            for j in 0..other.cols {
                let mut sum = 0.0;
                for k in 0..self.cols {
                    sum += self.get(i, k) * other.get(k, j);
                }
                result.set(i, j, sum);
            }
        }

        result
    }

    /// Matrix transpose
    pub fn transpose(&self) -> Matrix {
        let mut result = Matrix::new(self.cols, self.rows);
        for i in 0..self.rows {
            for j in 0..self.cols {
                result.set(j, i, self.get(i, j));
            }
        }
        result
    }

    /// Trace of matrix
    pub fn trace(&self) -> f64 {
        let n = min(self.rows, self.cols);
        (0..n).map(|i| self.get(i, i)).sum()
    }

    /// Frobenius norm
    pub fn frobenius_norm(&self) -> f64 {
        self.data.iter().map(|x| x * x).sum::<f64>().sqrt()
    }

    /// Determinant (for small matrices)
    pub fn determinant(&self) -> f64 {
        assert_eq!(self.rows, self.cols, "Matrix must be square");

        match self.rows {
            1 => self.get(0, 0),
            2 => self.get(0, 0) * self.get(1, 1) - self.get(0, 1) * self.get(1, 0),
            3 => {
                self.get(0, 0) * (self.get(1, 1) * self.get(2, 2) - self.get(1, 2) * self.get(2, 1))
                - self.get(0, 1) * (self.get(1, 0) * self.get(2, 2) - self.get(1, 2) * self.get(2, 0))
                + self.get(0, 2) * (self.get(1, 0) * self.get(2, 1) - self.get(1, 1) * self.get(2, 0))
            }
            _ => self.lu_determinant(),
        }
    }

    /// LU decomposition for determinant of larger matrices
    fn lu_determinant(&self) -> f64 {
        let n = self.rows;
        let mut lu = self.clone();
        let mut det = 1.0;

        for k in 0..n {
            // Find pivot
            let mut max_row = k;
            let mut max_val = lu.get(k, k).abs();

            for i in (k + 1)..n {
                if lu.get(i, k).abs() > max_val {
                    max_val = lu.get(i, k).abs();
                    max_row = i;
                }
            }

            if max_val < 1e-12 {
                return 0.0;
            }

            // Swap rows if needed
            if max_row != k {
                for j in 0..n {
                    let temp = lu.get(k, j);
                    lu.set(k, j, lu.get(max_row, j));
                    lu.set(max_row, j, temp);
                }
                det *= -1.0;
            }

            det *= lu.get(k, k);

            // Eliminate
            for i in (k + 1)..n {
                let factor = lu.get(i, k) / lu.get(k, k);
                for j in k..n {
                    lu.set(i, j, lu.get(i, j) - factor * lu.get(k, j));
                }
            }
        }

        det
    }

    /// Matrix inverse using Gauss-Jordan elimination
    pub fn inverse(&self) -> Option<Matrix> {
        assert_eq!(self.rows, self.cols, "Matrix must be square");
        let n = self.rows;

        // Augmented matrix [A | I]
        let mut augmented = Matrix::new(n, 2 * n);
        for i in 0..n {
            for j in 0..n {
                augmented.set(i, j, self.get(i, j));
            }
            augmented.set(i, n + i, 1.0);
        }

        // Forward elimination
        for k in 0..n {
            // Find pivot
            let mut max_row = k;
            let mut max_val = augmented.get(k, k).abs();

            for i in (k + 1)..n {
                if augmented.get(i, k).abs() > max_val {
                    max_val = augmented.get(i, k).abs();
                    max_row = i;
                }
            }

            if max_val < 1e-12 {
                return None; // Singular matrix
            }

            // Swap rows
            if max_row != k {
                for j in 0..(2 * n) {
                    let temp = augmented.get(k, j);
                    augmented.set(k, j, augmented.get(max_row, j));
                    augmented.set(max_row, j, temp);
                }
            }

            // Scale pivot row
            let pivot = augmented.get(k, k);
            for j in 0..(2 * n) {
                augmented.set(k, j, augmented.get(k, j) / pivot);
            }

            // Eliminate column
            for i in 0..n {
                if i != k {
                    let factor = augmented.get(i, k);
                    for j in 0..(2 * n) {
                        augmented.set(i, j, augmented.get(i, j) - factor * augmented.get(k, j));
                    }
                }
            }
        }

        // Extract inverse
        let mut inv = Matrix::new(n, n);
        for i in 0..n {
            for j in 0..n {
                inv.set(i, j, augmented.get(i, n + j));
            }
        }

        Some(inv)
    }

    /// Cholesky decomposition for positive definite matrices
    pub fn cholesky(&self) -> Option<Matrix> {
        assert_eq!(self.rows, self.cols, "Matrix must be square");
        let n = self.rows;
        let mut l = Matrix::new(n, n);

        for i in 0..n {
            for j in 0..=i {
                let mut sum = 0.0;

                if i == j {
                    for k in 0..j {
                        sum += l.get(j, k) * l.get(j, k);
                    }
                    let val = self.get(j, j) - sum;
                    if val <= 0.0 {
                        return None; // Not positive definite
                    }
                    l.set(j, j, val.sqrt());
                } else {
                    for k in 0..j {
                        sum += l.get(i, k) * l.get(j, k);
                    }
                    l.set(i, j, (self.get(i, j) - sum) / l.get(j, j));
                }
            }
        }

        Some(l)
    }

    /// Eigenvalues using QR algorithm (power iteration for dominant)
    pub fn eigenvalues(&self, iterations: usize) -> Vec<f64> {
        assert_eq!(self.rows, self.cols, "Matrix must be square");
        let n = self.rows;
        let mut eigenvalues = Vec::new();

        // Power iteration for each eigenvalue
        let mut deflated = self.clone();

        for _ in 0..n {
            let (eigenvalue, eigenvector) = deflated.power_iteration(iterations);
            eigenvalues.push(eigenvalue);

            // Deflate matrix
            for i in 0..deflated.rows {
                for j in 0..deflated.cols {
                    let val = deflated.get(i, j) - eigenvalue * eigenvector[i] * eigenvector[j];
                    deflated.set(i, j, val);
                }
            }
        }

        eigenvalues
    }

    /// Power iteration for dominant eigenvalue
    fn power_iteration(&self, iterations: usize) -> (f64, Vec<f64>) {
        let n = self.rows;
        let mut v: Vec<f64> = (0..n).map(|_| 1.0 / (n as f64).sqrt()).collect();
        let mut eigenvalue = 0.0;

        for _ in 0..iterations {
            // Matrix-vector multiplication
            let mut w = vec![0.0; n];
            for i in 0..n {
                for j in 0..n {
                    w[i] += self.get(i, j) * v[j];
                }
            }

            // Rayleigh quotient
            let mut numerator = 0.0;
            let mut denominator = 0.0;
            for i in 0..n {
                numerator += w[i] * v[i];
                denominator += v[i] * v[i];
            }
            eigenvalue = numerator / denominator;

            // Normalize
            let norm: f64 = w.iter().map(|x| x * x).sum::<f64>().sqrt();
            if norm > 1e-10 {
                v = w.iter().map(|x| x / norm).collect();
            }
        }

        (eigenvalue, v)
    }

    fn clone(&self) -> Matrix {
        Matrix {
            data: self.data.clone(),
            rows: self.rows,
            cols: self.cols,
        }
    }
}

