// CORE TENSOR STRUCTURES
// ═══════════════════════════════════════════════════════════════════════════════

/// 4th-order tensor for unified market state: [Time, Asset, Feature, Derivative]
/// This tensor encapsulates the entire market state in a differential-geometric framework
pub struct MarketTensor4D {
    data: Vec<f64>,
    pub shape: [usize; 4],
    strides: [usize; 4],
    metadata: TensorMetadata,
}

/// Metadata for tensor provenance and configuration
pub struct TensorMetadata {
    pub created_at: u64,
    pub symbols: Vec<String>,
    pub timeframe: Timeframe,
    pub normalization: NormalizationType,
}

/// Timeframe for market data
pub enum Timeframe {
    Tick,
    Second(u32),
    Minute(u32),
    Hour(u32),
    Day,
    Week,
    Month,
}

/// Normalization strategy for tensor values
pub enum NormalizationType {
    None,
    ZScore,
    MinMax,
    RobustScaler,
    LogTransform,
}

impl MarketTensor4D {
    /// Create a new zero-initialized tensor
    pub fn new(time_steps: usize, assets: usize, features: usize, derivatives: usize) -> Self {
        let shape = [time_steps, assets, features, derivatives];
        let strides = [
            assets * features * derivatives,
            features * derivatives,
            derivatives,
            1,
        ];
        let size: usize = shape.iter().product();

        MarketTensor4D {
            data: vec![0.0; size],
            shape,
            strides,
            metadata: TensorMetadata {
                created_at: 0,
                symbols: Vec::new(),
                timeframe: Timeframe::Day,
                normalization: NormalizationType::None,
            },
        }
    }

    /// Create tensor from raw data
    pub fn from_data(data: Vec<f64>, shape: [usize; 4]) -> Self {
        let strides = [
            shape[1] * shape[2] * shape[3],
            shape[2] * shape[3],
            shape[3],
            1,
        ];
        MarketTensor4D {
            data,
            shape,
            strides,
            metadata: TensorMetadata {
                created_at: 0,
                symbols: Vec::new(),
                timeframe: Timeframe::Day,
                normalization: NormalizationType::None,
            },
        }
    }

    /// Create tensor with specified metadata
    pub fn with_metadata(mut self, metadata: TensorMetadata) -> Self {
        self.metadata = metadata;
        self
    }

    /// Compute linear index from 4D coordinates
    fn index(&self, t: usize, a: usize, f: usize, d: usize) -> usize {
        t * self.strides[0] + a * self.strides[1] + f * self.strides[2] + d
    }

    /// Get value at coordinates
    pub fn get(&self, t: usize, a: usize, f: usize, d: usize) -> f64 {
        if t >= self.shape[0] || a >= self.shape[1] || f >= self.shape[2] || d >= self.shape[3] {
            return 0.0;
        }
        self.data[self.index(t, a, f, d)]
    }

    /// Set value at coordinates
    pub fn set(&mut self, t: usize, a: usize, f: usize, d: usize, value: f64) {
        if t < self.shape[0] && a < self.shape[1] && f < self.shape[2] && d < self.shape[3] {
            let idx = self.index(t, a, f, d);
            self.data[idx] = value;
        }
    }

    /// Get a slice along the time dimension for a specific asset/feature/derivative
    pub fn time_series(&self, asset: usize, feature: usize, derivative: usize) -> Vec<f64> {
        (0..self.shape[0])
            .map(|t| self.get(t, asset, feature, derivative))
            .collect()
    }

    /// Get cross-sectional slice at a specific time
    pub fn cross_section(&self, time: usize) -> Matrix {
        let rows = self.shape[1]; // assets
        let cols = self.shape[2] * self.shape[3]; // features * derivatives
        let mut data = vec![0.0; rows * cols];

        for a in 0..self.shape[1] {
            for f in 0..self.shape[2] {
                for d in 0..self.shape[3] {
                    data[a * cols + f * self.shape[3] + d] = self.get(time, a, f, d);
                }
            }
        }

        Matrix::from_data(data, rows, cols)
    }

    /// Contract along dimension with weights
    pub fn contract(&self, dim: usize, weights: &[f64]) -> MarketTensor4D {
        let mut new_shape = self.shape;
        new_shape[dim] = 1;

        let mut result = MarketTensor4D::new(new_shape[0], new_shape[1], new_shape[2], new_shape[3]);

        match dim {
            0 => { // Contract time
                for a in 0..self.shape[1] {
                    for f in 0..self.shape[2] {
                        for d in 0..self.shape[3] {
                            let mut sum = 0.0;
                            for t in 0..self.shape[0] {
                                sum += self.get(t, a, f, d) * weights.get(t).unwrap_or(&1.0);
                            }
                            result.set(0, a, f, d, sum);
                        }
                    }
                }
            }
            1 => { // Contract assets
                for t in 0..self.shape[0] {
                    for f in 0..self.shape[2] {
                        for d in 0..self.shape[3] {
                            let mut sum = 0.0;
                            for a in 0..self.shape[1] {
                                sum += self.get(t, a, f, d) * weights.get(a).unwrap_or(&1.0);
                            }
                            result.set(t, 0, f, d, sum);
                        }
                    }
                }
            }
            2 => { // Contract features
                for t in 0..self.shape[0] {
                    for a in 0..self.shape[1] {
                        for d in 0..self.shape[3] {
                            let mut sum = 0.0;
                            for f in 0..self.shape[2] {
                                sum += self.get(t, a, f, d) * weights.get(f).unwrap_or(&1.0);
                            }
                            result.set(t, a, 0, d, sum);
                        }
                    }
                }
            }
            3 => { // Contract derivatives
                for t in 0..self.shape[0] {
                    for a in 0..self.shape[1] {
                        for f in 0..self.shape[2] {
                            let mut sum = 0.0;
                            for d in 0..self.shape[3] {
                                sum += self.get(t, a, f, d) * weights.get(d).unwrap_or(&1.0);
                            }
                            result.set(t, a, f, 0, sum);
                        }
                    }
                }
            }
            _ => {}
        }

        result
    }

    /// Apply element-wise function
    pub fn map<F: Fn(f64) -> f64>(&self, f: F) -> MarketTensor4D {
        let data: Vec<f64> = self.data.iter().map(|&x| f(x)).collect();
        MarketTensor4D::from_data(data, self.shape)
    }

    /// Normalize tensor using specified strategy
    pub fn normalize(&self, strategy: NormalizationType) -> MarketTensor4D {
        match strategy {
            NormalizationType::None => self.clone(),
            NormalizationType::ZScore => self.z_score_normalize(),
            NormalizationType::MinMax => self.min_max_normalize(),
            NormalizationType::RobustScaler => self.robust_normalize(),
            NormalizationType::LogTransform => self.map(|x| if x > 0.0 { x.ln() } else { 0.0 }),
        }
    }

    fn z_score_normalize(&self) -> MarketTensor4D {
        let mean: f64 = self.data.iter().sum::<f64>() / self.data.len() as f64;
        let variance: f64 = self.data.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / self.data.len() as f64;
        let std = variance.sqrt();

        if std > 1e-10 {
            self.map(|x| (x - mean) / std)
        } else {
            self.clone()
        }
    }

    fn min_max_normalize(&self) -> MarketTensor4D {
        let min_val = self.data.iter().cloned().fold(f64::INFINITY, f64::min);
        let max_val = self.data.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
        let range = max_val - min_val;

        if range > 1e-10 {
            self.map(|x| (x - min_val) / range)
        } else {
            self.clone()
        }
    }

    fn robust_normalize(&self) -> MarketTensor4D {
        let mut sorted = self.data.clone();
        sorted.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));

        let q1_idx = sorted.len() / 4;
        let q3_idx = 3 * sorted.len() / 4;
        let median_idx = sorted.len() / 2;

        let median = sorted[median_idx];
        let iqr = sorted[q3_idx] - sorted[q1_idx];

        if iqr > 1e-10 {
            self.map(|x| (x - median) / iqr)
        } else {
            self.clone()
        }
    }

    fn clone(&self) -> MarketTensor4D {
        MarketTensor4D {
            data: self.data.clone(),
            shape: self.shape,
            strides: self.strides,
            metadata: TensorMetadata {
                created_at: self.metadata.created_at,
                symbols: self.metadata.symbols.clone(),
                timeframe: Timeframe::Day,
                normalization: NormalizationType::None,
            },
        }
    }
}

