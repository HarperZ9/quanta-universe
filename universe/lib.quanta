/// Module status with detailed state tracking
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ModuleStatus {
    Unloaded,
    Loading,
    Initializing,
    Ready,
    Active,
    Degraded,
    Error,
    Suspended,
    ShuttingDown,
    Terminated,
}

impl ModuleStatus {
    pub fn is_healthy(&self) -> bool {
        matches!(self, ModuleStatus::Ready | ModuleStatus::Active)
    }

    pub fn can_receive_requests(&self) -> bool {
        matches!(self, ModuleStatus::Ready | ModuleStatus::Active | ModuleStatus::Degraded)
    }

    pub fn can_transition_to(&self, target: ModuleStatus) -> bool {
        match (self, target) {
            (ModuleStatus::Unloaded, ModuleStatus::Loading) => true,
            (ModuleStatus::Loading, ModuleStatus::Initializing) => true,
            (ModuleStatus::Loading, ModuleStatus::Error) => true,
            (ModuleStatus::Initializing, ModuleStatus::Ready) => true,
            (ModuleStatus::Initializing, ModuleStatus::Error) => true,
            (ModuleStatus::Ready, ModuleStatus::Active) => true,
            (ModuleStatus::Ready, ModuleStatus::Suspended) => true,
            (ModuleStatus::Active, ModuleStatus::Ready) => true,
            (ModuleStatus::Active, ModuleStatus::Degraded) => true,
            (ModuleStatus::Active, ModuleStatus::Suspended) => true,
            (ModuleStatus::Active, ModuleStatus::ShuttingDown) => true,
            (ModuleStatus::Degraded, ModuleStatus::Active) => true,
            (ModuleStatus::Degraded, ModuleStatus::ShuttingDown) => true,
            (ModuleStatus::Suspended, ModuleStatus::Ready) => true,
            (ModuleStatus::Suspended, ModuleStatus::ShuttingDown) => true,
            (ModuleStatus::ShuttingDown, ModuleStatus::Terminated) => true,
            (ModuleStatus::Error, ModuleStatus::Loading) => true, // Retry
            (ModuleStatus::Error, ModuleStatus::Terminated) => true,
            _ => false,
        }
    }
}

/// Health check result
#[derive(Debug, Clone)]
pub struct HealthCheck {
    pub timestamp: u64,
    pub status: HealthStatus,
    pub latency_ms: u64,
    pub checks: Vec<ComponentHealth>,
    pub message: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HealthStatus {
    Healthy,
    Degraded,
    Unhealthy,
    Unknown,
}

#[derive(Debug, Clone)]
pub struct ComponentHealth {
    pub name: String,
    pub status: HealthStatus,
    pub details: Option<String>,
}

/// Module information with comprehensive metadata
#[derive(Debug, Clone)]
pub struct ModuleInfo {
    pub name: String,
    pub version: String,
    pub layer: Layer,
    pub status: ModuleStatus,
    pub dependencies: Vec<String>,
    pub optional_dependencies: Vec<String>,
    pub reverse_dependencies: Vec<String>,
    pub patents: Vec<String>,
    pub trademarks: Vec<String>,
    pub value_min: u64,
    pub value_max: u64,
    pub load_time_ms: u64,
    pub init_time_ms: u64,
    pub memory_bytes: u64,
    pub last_health_check: Option<HealthCheck>,
    pub error_count: u64,
    pub request_count: u64,
    pub capabilities: Vec<Capability>,
    pub config: ModuleConfig,
}

#[derive(Debug, Clone)]
pub struct Capability {
    pub name: String,
    pub version: String,
    pub enabled: bool,
}

#[derive(Debug, Clone)]
pub struct ModuleConfig {
    pub settings: HashMap<String, ConfigValue>,
    pub env_overrides: bool,
    pub hot_reload: bool,
}

#[derive(Debug, Clone)]
pub enum ConfigValue {
    String(String),
    Int(i64),
    Float(f64),
    Bool(bool),
    Array(Vec<ConfigValue>),
    Map(HashMap<String, ConfigValue>),
}

impl ModuleInfo {
    pub fn is_ready(&self) -> bool {
        self.status == ModuleStatus::Ready || self.status == ModuleStatus::Active
    }

    pub fn uptime_ms(&self) -> u64 {
        // Would calculate from activation time
        self.load_time_ms + self.init_time_ms
    }

    pub fn error_rate(&self) -> f64 {
        if self.request_count == 0 {
            0.0
        } else {
            self.error_count as f64 / self.request_count as f64
        }
    }
}

/// The central module registry with dependency management
pub struct ModuleRegistry {
    modules: HashMap<String, ModuleInfo>,
    load_order: Vec<String>,
    dependency_graph: DependencyGraph,
    initialized: bool,
    version: u64,
}

/// Dependency graph for topological ordering
pub struct DependencyGraph {
    nodes: HashSet<String>,
    edges: HashMap<String, Vec<String>>,
    reverse_edges: HashMap<String, Vec<String>>,
}

impl DependencyGraph {
    pub fn new() -> Self {
        DependencyGraph {
            nodes: HashSet::new(),
            edges: HashMap::new(),
            reverse_edges: HashMap::new(),
        }
    }

    pub fn add_node(&mut self, name: &str) {
        self.nodes.insert(name.to_string());
        self.edges.entry(name.to_string()).or_insert_with(Vec::new);
        self.reverse_edges.entry(name.to_string()).or_insert_with(Vec::new);
    }

    pub fn add_edge(&mut self, from: &str, to: &str) {
        self.edges.entry(from.to_string())
            .or_insert_with(Vec::new)
            .push(to.to_string());
        self.reverse_edges.entry(to.to_string())
            .or_insert_with(Vec::new)
            .push(from.to_string());
    }

    pub fn has_cycle(&self) -> bool {
        let mut visited = HashSet::new();
        let mut rec_stack = HashSet::new();

        for node in &self.nodes {
            if self.has_cycle_util(node, &mut visited, &mut rec_stack) {
                return true;
            }
        }
        false
    }

    fn has_cycle_util(&self, node: &str, visited: &mut HashSet<String>,
                      rec_stack: &mut HashSet<String>) -> bool {
        if rec_stack.contains(node) {
            return true;
        }
        if visited.contains(node) {
            return false;
        }

        visited.insert(node.to_string());
        rec_stack.insert(node.to_string());

        if let Some(deps) = self.edges.get(node) {
            for dep in deps {
                if self.has_cycle_util(dep, visited, rec_stack) {
                    return true;
                }
            }
        }

        rec_stack.remove(node);
        false
    }

    pub fn topological_sort(&self) -> Result<Vec<String>, String> {
        if self.has_cycle() {
            return Err("Dependency graph contains a cycle".to_string());
        }

        let mut in_degree: HashMap<String, usize> = HashMap::new();
        for node in &self.nodes {
            in_degree.insert(node.clone(), 0);
        }

        for edges in self.edges.values() {
            for target in edges {
                *in_degree.get_mut(target).unwrap() += 1;
            }
        }

        let mut queue: VecDeque<String> = VecDeque::new();
        for (node, &degree) in &in_degree {
            if degree == 0 {
                queue.push_back(node.clone());
            }
        }

        let mut result = Vec::new();
        while let Some(node) = queue.pop_front() {
            result.push(node.clone());

            if let Some(deps) = self.edges.get(&node) {
                for dep in deps {
                    let degree = in_degree.get_mut(dep).unwrap();
                    *degree -= 1;
                    if *degree == 0 {
                        queue.push_back(dep.clone());
                    }
                }
            }
        }

        if result.len() != self.nodes.len() {
            Err("Could not complete topological sort".to_string())
        } else {
            Ok(result)
        }
    }

    pub fn get_dependents(&self, module: &str) -> Vec<String> {
        self.reverse_edges.get(module)
            .cloned()
            .unwrap_or_default()
    }

    pub fn get_dependencies(&self, module: &str) -> Vec<String> {
        self.edges.get(module)
            .cloned()
            .unwrap_or_default()
    }

    pub fn transitive_dependencies(&self, module: &str) -> Vec<String> {
        let mut result = Vec::new();
        let mut visited = HashSet::new();
        let mut stack = vec![module.to_string()];

        while let Some(current) = stack.pop() {
            if visited.contains(&current) {
                continue;
            }
            visited.insert(current.clone());

            if current != module {
                result.push(current.clone());
            }

            if let Some(deps) = self.edges.get(&current) {
                for dep in deps {
                    stack.push(dep.clone());
                }
            }
        }

        result
    }
}

