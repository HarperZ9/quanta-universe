#[derive(Debug, Clone)]
pub enum ControlImplementation {
    Technical { system: String, automated: bool },
    Procedural { document: String, frequency: String },
    Administrative { policy: String },
    Combined { components: Vec<String> },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ControlStatus {
    Implemented,
    PartiallyImplemented,
    Planned,
    NotApplicable,
    Failed,
    NeedsReview,
}

impl ComplianceFramework {
    pub fn compliance_score(&self) -> f64 {
        if self.controls.is_empty() {
            return 0.0;
        }

        let applicable: Vec<_> = self.controls.iter()
            .filter(|c| c.status != ControlStatus::NotApplicable)
            .collect();

        if applicable.is_empty() {
            return 100.0;
        }

        let implemented = applicable.iter()
            .filter(|c| c.status == ControlStatus::Implemented)
            .count();

        let partial = applicable.iter()
            .filter(|c| c.status == ControlStatus::PartiallyImplemented)
            .count();

        ((implemented as f64 + partial as f64 * 0.5) / applicable.len() as f64) * 100.0
    }

    pub fn gaps(&self) -> Vec<&ComplianceControl> {
        self.controls.iter()
            .filter(|c| matches!(c.status,
                ControlStatus::Failed |
                ControlStatus::PartiallyImplemented |
                ControlStatus::NeedsReview))
            .collect()
    }
}

/// Security certification tracking
pub struct Certification {
    pub standard: CertificationStandard,
    pub scope: String,
    pub valid_from: String,
    pub valid_until: String,
    pub certifying_body: String,
    pub certificate_id: String,
    pub surveillance_audits: Vec<SurveillanceAudit>,
}

#[derive(Debug, Clone)]
pub enum CertificationStandard {
    ISO27001,
    ISO27017,
    ISO27018,
    SOC1Type1,
    SOC1Type2,
    SOC2Type1,
    SOC2Type2,
    SOC3,
    HIPAA,
    HITRUST,
    GDPR,
    CCPA,
    PCI_DSS,
    FedRAMP,
    StateRAMP,
    CMMC,
    NIST800_53,
    NIST800_171,
    CSA_STAR,
    Custom(String),
}

pub struct SurveillanceAudit {
    pub date: String,
    pub auditor: String,
    pub findings: Vec<AuditFinding>,
    pub outcome: AuditOutcome,
}

pub struct AuditFinding {
    pub id: String,
    pub severity: FindingSeverity,
    pub description: String,
    pub control_id: String,
    pub remediation: String,
    pub status: FindingStatus,
}

#[derive(Debug, Clone, Copy)]
pub enum FindingSeverity {
    Critical,
    High,
    Medium,
    Low,
    Informational,
}

#[derive(Debug, Clone, Copy)]
pub enum FindingStatus {
    Open,
    InProgress,
    Remediated,
    Accepted,
    Closed,
}

