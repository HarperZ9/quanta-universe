/// Audit log entry with cryptographic integrity
pub struct AuditEntry {
    pub id: u64,
    pub timestamp: u64,
    pub actor: ActorInfo,
    pub action: AuditAction,
    pub resource: ResourceInfo,
    pub outcome: AuditOutcome,
    pub metadata: HashMap<String, String>,
    pub signature: Option<String>,
    pub previous_hash: String,
    pub hash: String,
}

pub struct ActorInfo {
    pub id: String,
    pub name: String,
    pub actor_type: ActorType,
    pub ip_address: Option<String>,
    pub user_agent: Option<String>,
}

#[derive(Debug, Clone)]
pub enum ActorType {
    User,
    ServiceAccount,
    System,
    External,
}

pub struct ResourceInfo {
    pub id: String,
    pub resource_type: String,
    pub path: String,
    pub version: Option<String>,
}

#[derive(Debug, Clone)]
pub enum AuditAction {
    Create,
    Read,
    Update,
    Delete,
    Execute,
    Authenticate,
    Authorize,
    Configure,
    Deploy,
    Rollback,
    Export,
    Import,
    Share,
    Revoke,
    Approve,
    Reject,
}

#[derive(Debug, Clone)]
pub enum AuditOutcome {
    Success,
    Failure { reason: String },
    Denied { policy: String },
    Error { message: String },
    Timeout,
    Partial { completed: usize, total: usize },
}

/// Audit log with integrity guarantees
pub struct AuditLog {
    entries: Vec<AuditEntry>,
    last_hash: String,
    sealed: bool,
}

impl AuditLog {
    pub fn new() -> Self {
        AuditLog {
            entries: Vec::new(),
            last_hash: "genesis".to_string(),
            sealed: false,
        }
    }

    pub fn append(&mut self, mut entry: AuditEntry) -> Result<u64, String> {
        if self.sealed {
            return Err("Audit log is sealed".to_string());
        }

        entry.id = self.entries.len() as u64 + 1;
        entry.previous_hash = self.last_hash.clone();
        entry.hash = self.compute_hash(&entry);
        self.last_hash = entry.hash.clone();

        let id = entry.id;
        self.entries.push(entry);
        Ok(id)
    }

    fn compute_hash(&self, entry: &AuditEntry) -> String {
        // Would use proper cryptographic hash
        format!("hash_{}", entry.id)
    }

    pub fn verify_integrity(&self) -> bool {
        if self.entries.is_empty() {
            return true;
        }

        let mut expected_prev = "genesis".to_string();
        for entry in &self.entries {
            if entry.previous_hash != expected_prev {
                return false;
            }
            expected_prev = entry.hash.clone();
        }

        true
    }

    pub fn seal(&mut self) {
        self.sealed = true;
    }

    pub fn query(&self, filter: &AuditFilter) -> Vec<&AuditEntry> {
        self.entries.iter()
            .filter(|e| filter.matches(e))
            .collect()
    }

    pub fn len(&self) -> usize {
        self.entries.len()
    }
}

pub struct AuditFilter {
    pub actor_id: Option<String>,
    pub action: Option<AuditAction>,
    pub resource_type: Option<String>,
    pub from_timestamp: Option<u64>,
    pub to_timestamp: Option<u64>,
    pub outcome_success: Option<bool>,
}

impl AuditFilter {
    pub fn new() -> Self {
        AuditFilter {
            actor_id: None,
            action: None,
            resource_type: None,
            from_timestamp: None,
            to_timestamp: None,
            outcome_success: None,
        }
    }

    pub fn matches(&self, entry: &AuditEntry) -> bool {
        if let Some(ref id) = self.actor_id {
            if &entry.actor.id != id {
                return false;
            }
        }

        if let Some(ref from) = self.from_timestamp {
            if entry.timestamp < *from {
                return false;
            }
        }

        if let Some(ref to) = self.to_timestamp {
            if entry.timestamp > *to {
                return false;
            }
        }

        if let Some(ref res_type) = self.resource_type {
            if &entry.resource.resource_type != res_type {
                return false;
            }
        }

        if let Some(success) = self.outcome_success {
            let is_success = matches!(entry.outcome, AuditOutcome::Success);
            if is_success != success {
                return false;
            }
        }

        true
    }
}

