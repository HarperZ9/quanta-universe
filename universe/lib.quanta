// ENTERPRISE FEATURES: SERVICE LEVEL AGREEMENTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Service Level Agreement with comprehensive tracking
pub struct SLA {
    pub id: String,
    pub name: String,
    pub service: String,
    pub customer: String,
    pub objectives: Vec<SLO>,
    pub reporting_period: ReportingPeriod,
    pub penalties: Vec<Penalty>,
    pub exclusions: Vec<SLAExclusion>,
    pub effective_from: String,
    pub effective_until: String,
}

pub struct SLO {
    pub id: String,
    pub name: String,
    pub description: String,
    pub metric: SLOMetric,
    pub target: f64,
    pub warning_threshold: Option<f64>,
    pub measurement: MeasurementMethod,
    pub weight: f64,
}

#[derive(Debug, Clone)]
pub enum SLOMetric {
    Availability { percentage: f64, measurement_window: String },
    Latency { p50_ms: f64, p90_ms: f64, p99_ms: f64 },
    Throughput { requests_per_second: f64 },
    ErrorRate { percentage: f64, error_types: Vec<String> },
    MTTR { minutes: f64 },
    MTBF { hours: f64 },
    SuccessRate { percentage: f64 },
    ResponseTime { target_ms: f64, percentile: u8 },
    Custom { name: String, unit: String, description: String },
}

#[derive(Debug, Clone, Copy)]
pub enum ReportingPeriod {
    Hourly,
    Daily,
    Weekly,
    Monthly,
    Quarterly,
    Annually,
}

pub struct MeasurementMethod {
    pub source: String,
    pub aggregation: Aggregation,
    pub exclusions: Vec<String>,
    pub sample_rate: Option<f64>,
}

#[derive(Debug, Clone, Copy)]
pub enum Aggregation {
    Average,
    Median,
    P50,
    P90,
    P95,
    P99,
    P999,
    Max,
    Min,
    Sum,
    Count,
}

pub struct Penalty {
    pub threshold: f64,
    pub action: PenaltyAction,
    pub cumulative: bool,
}

#[derive(Debug, Clone)]
pub enum PenaltyAction {
    CreditPercentage(f64),
    FixedCredit(f64),
    ContractTermination,
    EscalationRequired,
    WarningOnly,
    ServiceExtension { days: u32 },
}

pub struct SLAExclusion {
    pub description: String,
    pub condition: String,
}

/// SLA monitoring and reporting
pub struct SLAMonitor {
    pub sla: SLA,
    pub measurements: Vec<SLOMeasurement>,
    pub incidents: Vec<SLAIncident>,
}

pub struct SLOMeasurement {
    pub slo_id: String,
    pub timestamp: u64,
    pub value: f64,
    pub within_target: bool,
    pub excluded: bool,
    pub exclusion_reason: Option<String>,
}

pub struct SLAIncident {
    pub id: String,
    pub slo_id: String,
    pub started_at: u64,
    pub ended_at: Option<u64>,
    pub impact: IncidentImpact,
    pub root_cause: Option<String>,
    pub downtime_minutes: f64,
}

#[derive(Debug, Clone, Copy)]
pub enum IncidentImpact {
    None,
    Minor,
    Moderate,
    Major,
    Critical,
}

impl SLAMonitor {
    pub fn new(sla: SLA) -> Self {
        SLAMonitor {
            sla,
            measurements: Vec::new(),
            incidents: Vec::new(),
        }
    }

    pub fn record(&mut self, slo_id: &str, value: f64, timestamp: u64) {
        let slo = self.sla.objectives.iter().find(|s| s.id == slo_id);
        let within_target = slo.map(|s| value >= s.target).unwrap_or(false);

        self.measurements.push(SLOMeasurement {
            slo_id: slo_id.to_string(),
            timestamp,
            value,
            within_target,
            excluded: false,
            exclusion_reason: None,
        });
    }

    pub fn compliance_rate(&self, slo_id: &str) -> f64 {
        let relevant: Vec<_> = self.measurements.iter()
            .filter(|m| m.slo_id == slo_id && !m.excluded)
            .collect();

        if relevant.is_empty() { return 0.0; }

        let within = relevant.iter().filter(|m| m.within_target).count();
        within as f64 / relevant.len() as f64
    }

    pub fn overall_compliance(&self) -> f64 {
        if self.sla.objectives.is_empty() {
            return 0.0;
        }

        let total_weight: f64 = self.sla.objectives.iter().map(|s| s.weight).sum();
        if total_weight == 0.0 {
            return 0.0;
        }

        let weighted_sum: f64 = self.sla.objectives.iter()
            .map(|s| self.compliance_rate(&s.id) * s.weight)
            .sum();

        weighted_sum / total_weight
    }

    pub fn calculate_penalties(&self) -> Vec<(String, PenaltyAction)> {
        let mut penalties = Vec::new();

        for slo in &self.sla.objectives {
            let compliance = self.compliance_rate(&slo.id);

            for penalty in &self.sla.penalties {
                if compliance < penalty.threshold {
                    penalties.push((slo.id.clone(), penalty.action.clone()));
                    if !penalty.cumulative {
                        break;
                    }
                }
            }
        }

        penalties
    }

    pub fn uptime_percentage(&self, slo_id: &str, period_minutes: f64) -> f64 {
        let downtime: f64 = self.incidents.iter()
            .filter(|i| i.slo_id == slo_id)
            .map(|i| i.downtime_minutes)
            .sum();

        ((period_minutes - downtime) / period_minutes) * 100.0
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENTERPRISE FEATURES: DISTRIBUTED TRACING
// ═══════════════════════════════════════════════════════════════════════════════

/// Distributed trace with full span tree
pub struct Trace {
    pub trace_id: String,
    pub root_span_id: String,
    pub spans: HashMap<String, Span>,
    pub start_time: u64,
    pub end_time: Option<u64>,
    pub tags: HashMap<String, String>,
    pub service_count: usize,
}

pub struct Span {
    pub span_id: String,
    pub parent_id: Option<String>,
    pub operation_name: String,
    pub service_name: String,
    pub start_time: u64,
    pub duration_us: u64,
    pub status: SpanStatus,
    pub kind: SpanKind,
    pub tags: HashMap<String, String>,
    pub logs: Vec<SpanLog>,
    pub baggage: HashMap<String, String>,
    pub links: Vec<SpanLink>,
}

#[derive(Debug, Clone)]
pub enum SpanStatus {
    Unset,
    Ok,
    Error { message: String, code: Option<i32> },
}

#[derive(Debug, Clone, Copy)]
pub enum SpanKind {
    Internal,
    Server,
    Client,
    Producer,
    Consumer,
}

pub struct SpanLog {
    pub timestamp: u64,
    pub message: String,
    pub level: LogLevel,
    pub fields: HashMap<String, String>,
}

pub struct SpanLink {
    pub trace_id: String,
    pub span_id: String,
    pub attributes: HashMap<String, String>,
}

impl Trace {
    pub fn new(trace_id: String) -> Self {
        Trace {
            trace_id,
            root_span_id: String::new(),
            spans: HashMap::new(),
            start_time: 0,
            end_time: None,
            tags: HashMap::new(),
            service_count: 0,
        }
    }

    pub fn add_span(&mut self, span: Span) {
        if span.parent_id.is_none() {
            self.root_span_id = span.span_id.clone();
            self.start_time = span.start_time;
        }

        self.spans.insert(span.span_id.clone(), span);
        self.update_service_count();
    }

    fn update_service_count(&mut self) {
        let services: HashSet<_> = self.spans.values()
            .map(|s| &s.service_name)
            .collect();
        self.service_count = services.len();
    }

    pub fn duration_us(&self) -> u64 {
        if let Some(root) = self.spans.get(&self.root_span_id) {
            root.duration_us
        } else {
            0
        }
    }

    pub fn is_error(&self) -> bool {
        self.spans.values().any(|s| matches!(s.status, SpanStatus::Error { .. }))
    }

    pub fn critical_path(&self) -> Vec<&Span> {
        // Find the longest path through the span tree
        let mut path = Vec::new();

        if let Some(root) = self.spans.get(&self.root_span_id) {
            self.find_critical_path(root, &mut path);
        }

        path
    }

    fn find_critical_path<'a>(&'a self, span: &'a Span, path: &mut Vec<&'a Span>) {
        path.push(span);

        let children: Vec<_> = self.spans.values()
            .filter(|s| s.parent_id.as_ref() == Some(&span.span_id))
            .collect();

        if let Some(longest_child) = children.into_iter()
            .max_by_key(|s| s.duration_us)
        {
            self.find_critical_path(longest_child, path);
        }
    }
}

/// Trace context for propagation
pub struct TraceContext {
    pub trace_id: String,
    pub span_id: String,
    pub parent_id: Option<String>,
    pub trace_flags: TraceFlags,
    pub trace_state: TraceState,
    pub baggage: HashMap<String, String>,
}

pub struct TraceFlags {
    pub sampled: bool,
    pub random: bool,
}

pub struct TraceState {
    pub entries: Vec<(String, String)>,
}

impl TraceContext {
    /// W3C Trace Context format (traceparent header)
    pub fn to_traceparent(&self) -> String {
        let flags = if self.trace_flags.sampled { "01" } else { "00" };
        format!("00-{}-{}-{}", self.trace_id, self.span_id, flags)
    }

    pub fn from_traceparent(header: &str) -> Option<Self> {
        let parts: Vec<&str> = header.split('-').collect();
        if parts.len() != 4 || parts[0] != "00" {
            return None;
        }

        Some(TraceContext {
            trace_id: parts[1].to_string(),
            span_id: parts[2].to_string(),
            parent_id: None,
            trace_flags: TraceFlags {
                sampled: parts[3] == "01",
                random: false,
            },
            trace_state: TraceState { entries: Vec::new() },
            baggage: HashMap::new(),
        })
    }

    /// W3C Trace Context format (tracestate header)
    pub fn to_tracestate(&self) -> String {
        self.trace_state.entries.iter()
            .map(|(k, v)| format!("{}={}", k, v))
            .collect::<Vec<_>>()
            .join(",")
    }

    pub fn parse_tracestate(header: &str) -> TraceState {
        let entries = header.split(',')
            .filter_map(|entry| {
                let parts: Vec<_> = entry.splitn(2, '=').collect();
                if parts.len() == 2 {
                    Some((parts[0].trim().to_string(), parts[1].trim().to_string()))
                } else {
                    None
                }
            })
            .collect();

        TraceState { entries }
    }

    /// Create a child context for a new span
    pub fn child(&self, new_span_id: String) -> TraceContext {
        TraceContext {
            trace_id: self.trace_id.clone(),
            span_id: new_span_id,
            parent_id: Some(self.span_id.clone()),
            trace_flags: self.trace_flags.clone(),
            trace_state: TraceState { entries: self.trace_state.entries.clone() },
            baggage: self.baggage.clone(),
        }
    }
}

impl Clone for TraceFlags {
    fn clone(&self) -> Self {
        TraceFlags {
            sampled: self.sampled,
            random: self.random,
        }
    }
}

/// Trace sampler for controlling trace collection
pub trait Sampler {
    fn should_sample(&self, ctx: &TraceContext, operation: &str) -> SamplingDecision;
}

pub struct SamplingDecision {
    pub sample: bool,
    pub record: bool,
    pub attributes: HashMap<String, String>,
}

pub struct AlwaysOnSampler;
pub struct AlwaysOffSampler;
pub struct RatioSampler { ratio: f64 }

impl Sampler for AlwaysOnSampler {
    fn should_sample(&self, _ctx: &TraceContext, _operation: &str) -> SamplingDecision {
        SamplingDecision {
            sample: true,
            record: true,
            attributes: HashMap::new(),
        }
    }
}

impl Sampler for AlwaysOffSampler {
    fn should_sample(&self, _ctx: &TraceContext, _operation: &str) -> SamplingDecision {
        SamplingDecision {
            sample: false,
            record: false,
            attributes: HashMap::new(),
        }
    }
}

impl Sampler for RatioSampler {
    fn should_sample(&self, _ctx: &TraceContext, _operation: &str) -> SamplingDecision {
        // Would use proper random sampling
        SamplingDecision {
            sample: self.ratio >= 0.5,
            record: true,
            attributes: HashMap::new(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENTERPRISE FEATURES: FEATURE FLAGS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct FeatureFlagManager {
    flags: RwLock<HashMap<String, FeatureFlag>>,
    overrides: RwLock<HashMap<String, HashMap<String, bool>>>,
    evaluations: AtomicU64,
}

pub struct FeatureFlag {
    pub key: String,
    pub name: String,
    pub description: String,
    pub enabled: bool,
    pub rollout_percentage: f64,
    pub targeting_rules: Vec<TargetingRule>,
    pub variants: Option<Vec<FlagVariant>>,
    pub created_at: u64,
    pub updated_at: u64,
    pub owner: String,
}

pub struct TargetingRule {
    pub id: String,
    pub priority: u32,
    pub conditions: Vec<TargetingCondition>,
    pub serve: FlagValue,
}

pub struct TargetingCondition {
    pub attribute: String,
    pub operator: ConditionOperator,
    pub values: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum ConditionOperator {
    Equals,
    NotEquals,
    Contains,
    StartsWith,
    EndsWith,
    GreaterThan,
    LessThan,
    In,
    NotIn,
    Matches,
}

pub struct FlagVariant {
    pub key: String,
    pub name: String,
    pub weight: f64,
    pub payload: Option<String>,
}

#[derive(Debug, Clone)]
pub enum FlagValue {
    Bool(bool),
    String(String),
    Number(f64),
    Json(String),
}

pub struct EvaluationContext {
    pub user_id: Option<String>,
    pub attributes: HashMap<String, String>,
    pub timestamp: u64,
}

impl FeatureFlagManager {
    pub fn new() -> Self {
        FeatureFlagManager {
            flags: RwLock::new(HashMap::new()),
            overrides: RwLock::new(HashMap::new()),
            evaluations: AtomicU64::new(0),
        }
    }

    pub fn register(&self, flag: FeatureFlag) {
        self.flags.write().unwrap().insert(flag.key.clone(), flag);
    }

    pub fn is_enabled(&self, key: &str, ctx: &EvaluationContext) -> bool {
        self.evaluations.fetch_add(1, Ordering::Relaxed);

        // Check user override first
        if let Some(user_id) = &ctx.user_id {
            let overrides = self.overrides.read().unwrap();
            if let Some(user_overrides) = overrides.get(user_id) {
                if let Some(&override_value) = user_overrides.get(key) {
                    return override_value;
                }
            }
        }

        let flags = self.flags.read().unwrap();
        if let Some(flag) = flags.get(key) {
            // Check targeting rules
            for rule in &flag.targeting_rules {
                if self.evaluate_rule(rule, ctx) {
                    return match &rule.serve {
                        FlagValue::Bool(b) => *b,
                        _ => flag.enabled,
                    };
                }
            }

            // Apply rollout percentage
            if flag.rollout_percentage >= 100.0 {
                return flag.enabled;
            } else if flag.rollout_percentage <= 0.0 {
                return false;
            }

            // Would use consistent hashing for gradual rollout
            flag.enabled
        } else {
            false
        }
    }

    fn evaluate_rule(&self, rule: &TargetingRule, ctx: &EvaluationContext) -> bool {
        rule.conditions.iter().all(|c| self.evaluate_condition(c, ctx))
    }

    fn evaluate_condition(&self, cond: &TargetingCondition, ctx: &EvaluationContext) -> bool {
        let attr_value = ctx.attributes.get(&cond.attribute);

        match (&cond.operator, attr_value) {
            (ConditionOperator::Equals, Some(v)) => cond.values.contains(v),
            (ConditionOperator::NotEquals, Some(v)) => !cond.values.contains(v),
            (ConditionOperator::Contains, Some(v)) => {
                cond.values.iter().any(|target| v.contains(target))
            }
            (ConditionOperator::In, Some(v)) => cond.values.contains(v),
            (ConditionOperator::NotIn, Some(v)) => !cond.values.contains(v),
            _ => false,
        }
    }

    pub fn set_override(&self, user_id: &str, key: &str, value: bool) {
        let mut overrides = self.overrides.write().unwrap();
        overrides.entry(user_id.to_string())
            .or_insert_with(HashMap::new)
            .insert(key.to_string(), value);
    }

    pub fn clear_override(&self, user_id: &str, key: &str) {
        let mut overrides = self.overrides.write().unwrap();
        if let Some(user_overrides) = overrides.get_mut(user_id) {
            user_overrides.remove(key);
        }
    }

    pub fn evaluation_count(&self) -> u64 {
        self.evaluations.load(Ordering::Relaxed)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENTERPRISE FEATURES: RATE LIMITING
// ═══════════════════════════════════════════════════════════════════════════════

pub struct RateLimiter {
    config: RateLimitConfig,
    buckets: RwLock<HashMap<String, TokenBucket>>,
}

pub struct RateLimitConfig {
    pub requests_per_second: f64,
    pub burst_size: u64,
    pub key_extractor: KeyExtractor,
}

#[derive(Debug, Clone)]
pub enum KeyExtractor {
    ByIp,
    ByUser,
    ByApiKey,
    ByEndpoint,
    Custom(String),
}

struct TokenBucket {
    tokens: f64,
    last_refill: Instant,
    rate: f64,
    capacity: f64,
}

impl TokenBucket {
    fn new(rate: f64, capacity: f64) -> Self {
        TokenBucket {
            tokens: capacity,
            last_refill: Instant::now(),
            rate,
            capacity,
        }
    }

    fn try_consume(&mut self, tokens: f64) -> bool {
        self.refill();

        if self.tokens >= tokens {
            self.tokens -= tokens;
            true
        } else {
            false
        }
    }

    fn refill(&mut self) {
        let now = Instant::now();
        let elapsed = now.duration_since(self.last_refill).as_secs_f64();
        self.tokens = (self.tokens + elapsed * self.rate).min(self.capacity);
        self.last_refill = now;
    }
}

impl RateLimiter {
    pub fn new(config: RateLimitConfig) -> Self {
        RateLimiter {
            config,
            buckets: RwLock::new(HashMap::new()),
        }
    }

    pub fn allow(&self, key: &str) -> RateLimitResult {
        self.allow_n(key, 1.0)
    }

    pub fn allow_n(&self, key: &str, tokens: f64) -> RateLimitResult {
        let mut buckets = self.buckets.write().unwrap();

        let bucket = buckets.entry(key.to_string())
            .or_insert_with(|| TokenBucket::new(
                self.config.requests_per_second,
                self.config.burst_size as f64,
            ));

        if bucket.try_consume(tokens) {
            RateLimitResult::Allowed {
                remaining: bucket.tokens as u64,
                reset_at: bucket.last_refill + Duration::from_secs_f64(bucket.capacity / bucket.rate),
            }
        } else {
            let wait_time = (tokens - bucket.tokens) / bucket.rate;
            RateLimitResult::Limited {
                retry_after: Duration::from_secs_f64(wait_time),
            }
        }
    }

    pub fn reset(&self, key: &str) {
        let mut buckets = self.buckets.write().unwrap();
        buckets.remove(key);
    }
}

pub enum RateLimitResult {
    Allowed { remaining: u64, reset_at: Instant },
    Limited { retry_after: Duration },
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_module_registry() {
        let registry = ModuleRegistry::new();

        assert!(registry.get_module("quantalang").is_some());
        assert!(registry.get_module("photon").is_some());
        assert!(registry.get_module("nonexistent").is_none());

        let (val_min, val_max) = registry.total_value_range();
        assert!(val_min > 8_000_000);
        assert!(val_max > val_min);
    }

    #[test]
    fn test_load_order() {
        let registry = ModuleRegistry::new();
        let order = registry.get_load_order();

        // quantalang must come before foundation
        let ql_pos = order.iter().position(|s| s == "quantalang").unwrap();
        let fd_pos = order.iter().position(|s| s == "foundation").unwrap();
        assert!(ql_pos < fd_pos);

        // foundation must come before photon
        let ph_pos = order.iter().position(|s| s == "photon").unwrap();
        assert!(fd_pos < ph_pos);
    }

    #[test]
    fn test_message_bus() {
        let bus = MessageBus::new();

        let channel_a = bus.register_module("module_a");
        let channel_b = bus.register_module("module_b");

        bus.subscribe("module_b", "events");

        // Send direct message
        bus.send(Message::Request {
            id: 1,
            from: "module_a".to_string(),
            to: "module_b".to_string(),
            payload: vec![1, 2, 3],
            timeout_ms: None,
            priority: MessagePriority::Normal,
        }).unwrap();

        let msg = channel_b.receive().unwrap();
        match msg {
            Message::Request { id, .. } => assert_eq!(id, 1),
            _ => panic!("Expected Request message"),
        }
    }

    #[test]
    fn test_universe_layers() {
        let registry = ModuleRegistry::new();

        let foundation = registry.get_modules_by_layer(Layer::Foundation);
        assert_eq!(foundation.len(), 2);

        let rendering = registry.get_modules_by_layer(Layer::Rendering);
        assert_eq!(rendering.len(), 8);

        let trading = registry.get_modules_by_layer(Layer::Trading);
        assert_eq!(trading.len(), 4);
    }

    #[test]
    fn test_dependency_graph() {
        let mut graph = DependencyGraph::new();
        graph.add_node("a");
        graph.add_node("b");
        graph.add_node("c");
        graph.add_edge("a", "b");
        graph.add_edge("b", "c");

        assert!(!graph.has_cycle());

        let order = graph.topological_sort().unwrap();
        assert!(order.iter().position(|x| x == "c").unwrap() <
                order.iter().position(|x| x == "b").unwrap());
    }

    #[test]
    fn test_identity_type() {
        let refl = IdentityType::refl(42);
        assert!(refl.is_reflexive());

        let result = refl.j_elim(|x| x * 2);
        assert_eq!(result, Some(84));
    }

    #[test]
    fn test_matrix_operations() {
        let mut m = Matrix::<f64>::identity(3);
        assert_eq!(m.get(0, 0), &1.0);
        assert_eq!(m.get(0, 1), &0.0);

        let trace = m.trace().unwrap();
        assert_eq!(trace, 3.0);

        let det = m.determinant().unwrap();
        assert!((det - 1.0).abs() < 1e-10);
    }

    #[test]
    fn test_complex_field() {
        let a = Complex::new(1.0, 2.0);
        let b = Complex::new(3.0, 4.0);

        let sum = Complex::add(a.clone(), b.clone());
        assert_eq!(sum.re, 4.0);
        assert_eq!(sum.im, 6.0);

        let prod = Complex::mul(a.clone(), b.clone());
        assert_eq!(prod.re, -5.0);  // 1*3 - 2*4
        assert_eq!(prod.im, 10.0);  // 1*4 + 2*3
    }

    #[test]
    fn test_proof_state() {
        let goal = Proposition::Implies(
            Box::new(Proposition::Atom("A".to_string())),
            Box::new(Proposition::Atom("A".to_string())),
        );

        let mut proof = ProofState::new(goal);
        assert!(!proof.is_complete());

        proof.intro("h").unwrap();
        proof.assumption().unwrap();

        assert!(proof.is_complete() || proof.goal_count() == 0);
    }

    #[test]
    fn test_audit_log() {
        let mut log = AuditLog::new();

        let entry = AuditEntry {
            id: 0,
            timestamp: 1000,
            actor: ActorInfo {
                id: "user1".to_string(),
                name: "Test User".to_string(),
                actor_type: ActorType::User,
                ip_address: None,
                user_agent: None,
            },
            action: AuditAction::Create,
            resource: ResourceInfo {
                id: "res1".to_string(),
                resource_type: "document".to_string(),
                path: "/docs/test".to_string(),
                version: None,
            },
            outcome: AuditOutcome::Success,
            metadata: HashMap::new(),
            signature: None,
            previous_hash: String::new(),
            hash: String::new(),
        };

        log.append(entry).unwrap();
        assert_eq!(log.len(), 1);
        assert!(log.verify_integrity());
    }

    #[test]
    fn test_trace_context() {
        let header = "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01";
        let ctx = TraceContext::from_traceparent(header).unwrap();

        assert_eq!(ctx.trace_id, "0af7651916cd43dd8448eb211c80319c");
        assert_eq!(ctx.span_id, "b7ad6b7169203331");
        assert!(ctx.trace_flags.sampled);

        let regenerated = ctx.to_traceparent();
        assert_eq!(regenerated, header);
    }

    #[test]
    fn test_feature_flags() {
        let manager = FeatureFlagManager::new();

        manager.register(FeatureFlag {
            key: "new_feature".to_string(),
            name: "New Feature".to_string(),
            description: "A new feature".to_string(),
            enabled: true,
            rollout_percentage: 100.0,
            targeting_rules: Vec::new(),
            variants: None,
            created_at: 0,
            updated_at: 0,
            owner: "test".to_string(),
        });

        let ctx = EvaluationContext {
            user_id: Some("user1".to_string()),
            attributes: HashMap::new(),
            timestamp: 0,
        };

        assert!(manager.is_enabled("new_feature", &ctx));
        assert!(!manager.is_enabled("nonexistent", &ctx));
    }

    #[test]
    fn test_sla_monitor() {
        let sla = SLA {
            id: "sla1".to_string(),
            name: "Test SLA".to_string(),
            service: "api".to_string(),
            customer: "customer1".to_string(),
            objectives: vec![SLO {
                id: "availability".to_string(),
                name: "Availability".to_string(),
                description: "Service availability".to_string(),
                metric: SLOMetric::Availability {
                    percentage: 99.9,
                    measurement_window: "monthly".to_string(),
                },
                target: 99.9,
                warning_threshold: Some(99.5),
                measurement: MeasurementMethod {
                    source: "monitoring".to_string(),
                    aggregation: Aggregation::Average,
                    exclusions: Vec::new(),
                    sample_rate: None,
                },
                weight: 1.0,
            }],
            reporting_period: ReportingPeriod::Monthly,
            penalties: Vec::new(),
            exclusions: Vec::new(),
            effective_from: "2025-01-01".to_string(),
            effective_until: "2025-12-31".to_string(),
        };

        let mut monitor = SLAMonitor::new(sla);
        monitor.record("availability", 100.0, 1000);
        monitor.record("availability", 99.95, 2000);
        monitor.record("availability", 99.8, 3000);

        let compliance = monitor.compliance_rate("availability");
        assert!(compliance > 0.5);
    }
}
