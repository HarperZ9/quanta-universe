pub struct Reproducibility {
    pub independent_replications: usize,
    pub successful_replications: usize,
    pub failed_replications: usize,
    pub code_available: bool,
    pub data_available: bool,
    pub protocol_detailed: bool,
    pub materials_available: bool,
}

impl Reproducibility {
    pub fn score(&self) -> f64 {
        let replication_rate = if self.independent_replications > 0 {
            self.successful_replications as f64 / self.independent_replications as f64
        } else { 0.0 };

        let openness = (self.code_available as u8 +
                        self.data_available as u8 +
                        self.protocol_detailed as u8 +
                        self.materials_available as u8) as f64 / 4.0;

        (replication_rate * 0.6 + openness * 0.4)
    }

    pub fn grade(&self) -> char {
        let score = self.score();
        if score >= 0.9 { 'A' }
        else if score >= 0.8 { 'B' }
        else if score >= 0.7 { 'C' }
        else if score >= 0.6 { 'D' }
        else { 'F' }
    }
}

