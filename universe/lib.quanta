pub const GIT_COMMIT: &str = env!("GIT_COMMIT", "unknown");

/// Universe layer classification
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub enum Layer {
    Foundation,  // Layer 0: quantalang, foundation
    Core,        // Layer 1: quantaos, axiom
    Rendering,   // Layer 2: photon, spectrum, chromatic, lumina, neutrino, prism, refract, nexus
    Trading,     // Layer 3: quantum-finance, field-tensor, delta, entropy
    Intelligence,// Layer 4: oracle, wavelength
    Integration, // Layer 5: entangle, calibrate, nova
    Tools,       // Layer 6: forge
}

impl Layer {
    pub fn priority(&self) -> u8 {
        match self {
            Layer::Foundation => 0,
            Layer::Core => 1,
            Layer::Rendering => 2,
            Layer::Trading => 3,
            Layer::Intelligence => 4,
            Layer::Integration => 5,
            Layer::Tools => 6,
        }
    }

    pub fn name(&self) -> &'static str {
        match self {
            Layer::Foundation => "Foundation",
            Layer::Core => "Core",
            Layer::Rendering => "Rendering",
            Layer::Trading => "Trading",
            Layer::Intelligence => "Intelligence",
            Layer::Integration => "Integration",
            Layer::Tools => "Tools",
        }
    }

    pub fn description(&self) -> &'static str {
        match self {
            Layer::Foundation => "Core language and foundational abstractions",
            Layer::Core => "Operating system and mathematical axioms",
            Layer::Rendering => "Graphics, UI, and visual processing",
            Layer::Trading => "Financial modeling and market analysis",
            Layer::Intelligence => "AI, ML, and predictive systems",
            Layer::Integration => "External system connectivity",
            Layer::Tools => "Development and deployment tools",
        }
    }

    pub fn all() -> Vec<Layer> {
        vec![
            Layer::Foundation,
            Layer::Core,
            Layer::Rendering,
            Layer::Trading,
            Layer::Intelligence,
            Layer::Integration,
            Layer::Tools,
        ]
    }

    pub fn from_priority(priority: u8) -> Option<Layer> {
        match priority {
            0 => Some(Layer::Foundation),
            1 => Some(Layer::Core),
            2 => Some(Layer::Rendering),
            3 => Some(Layer::Trading),
            4 => Some(Layer::Intelligence),
            5 => Some(Layer::Integration),
            6 => Some(Layer::Tools),
            _ => None,
        }
    }
}

