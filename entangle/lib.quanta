/// Media type being played
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum MediaType {
    Audio,
    Video,
    Podcast,
    Audiobook,
    Livestream,
}

/// Media playback state
#[derive(Debug, Clone)]
pub struct MediaPlaybackState {
    pub media_id: String,
    pub title: String,
    pub artist: Option<String>,
    pub album: Option<String>,
    pub media_type: MediaType,
    pub source: String,          // App/service name
    pub position_ms: u64,
    pub duration_ms: u64,
    pub is_playing: bool,
    pub volume: f32,
    pub playback_rate: f32,
    pub artwork_url: Option<String>,
    pub source_device: String,
}

/// Media handoff manager - continue playback across devices
pub struct MediaHandoff {
    current_state: RwLock<Option<MediaPlaybackState>>,
    device_mesh: Arc<DeviceMesh>,
    supported_apps: Vec<String>,
}

impl MediaHandoff {
    pub fn new(mesh: Arc<DeviceMesh>) -> Self {
        MediaHandoff {
            current_state: RwLock::new(None),
            device_mesh: mesh,
            supported_apps: vec![
                "Spotify".to_string(),
                "Apple Music".to_string(),
                "YouTube Music".to_string(),
                "Netflix".to_string(),
                "YouTube".to_string(),
                "VLC".to_string(),
                "Plex".to_string(),
                "Disney+".to_string(),
                "Prime Video".to_string(),
            ],
        }
    }

    /// Update current playback state
    pub fn update_state(&self, state: MediaPlaybackState) {
        *self.current_state.write().unwrap() = Some(state.clone());

        // Broadcast to other devices
        let data = self.serialize_state(&state);
        for device in self.device_mesh.connected_devices() {
            let _ = self.device_mesh.send(&device.id, &data);
        }
    }

    /// Hand off playback to another device
    pub fn handoff_to(&self, target_device_id: &str) -> Result<(), GenesisError> {
        let state = self.current_state.read().unwrap()
            .clone()
            .ok_or(GenesisError::NoMediaPlaying)?;

        // Send handoff command with current position
        let command = HandoffCommand {
            action: HandoffAction::Transfer,
            state: state.clone(),
            timestamp: DateTime::now(),
        };

        let data = self.serialize_command(&command);
        self.device_mesh.send(target_device_id, &data)?;

        // Pause on current device
        // media_controller.pause();

        Ok(())
    }

    /// Handle incoming handoff request
    pub fn on_handoff_received(&self, command: HandoffCommand) {
        match command.action {
            HandoffAction::Transfer => {
                // Start playback at the specified position
                // open_media(command.state.media_id);
                // seek_to(command.state.position_ms);
                // if command.state.is_playing { play(); }
            }
            HandoffAction::Pause => {
                // Pause local playback
            }
            HandoffAction::Resume => {
                // Resume local playback
            }
            HandoffAction::Sync => {
                // Sync position with source
            }
        }
    }

    fn serialize_state(&self, state: &MediaPlaybackState) -> Vec<u8> {
        vec![] // Would serialize to binary
    }

    fn serialize_command(&self, command: &HandoffCommand) -> Vec<u8> {
        vec![]
    }
}

#[derive(Debug, Clone)]
struct HandoffCommand {
    action: HandoffAction,
    state: MediaPlaybackState,
    timestamp: DateTime,
}

#[derive(Debug, Clone, Copy)]
enum HandoffAction {
    Transfer,
    Pause,
    Resume,
    Sync,
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE TRANSFER
// ═══════════════════════════════════════════════════════════════════════════════

/// File transfer status
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TransferStatus {
    Pending,
    Preparing,
    Transferring,
    Paused,
    Completed,
    Failed,
    Cancelled,
}

/// File transfer entry
#[derive(Debug, Clone)]
pub struct FileTransfer {
    pub id: String,
    pub filename: String,
    pub size_bytes: u64,
    pub transferred_bytes: u64,
    pub source_device: String,
    pub target_device: String,
    pub status: TransferStatus,
    pub speed_bps: u64,
    pub eta_seconds: Option<u32>,
    pub started_at: DateTime,
    pub completed_at: Option<DateTime>,
    pub checksum: String,
}

impl FileTransfer {
    pub fn progress(&self) -> f32 {
        if self.size_bytes == 0 {
            return 1.0;
        }
        self.transferred_bytes as f32 / self.size_bytes as f32
    }
}

/// Cross-device file transfer manager
pub struct FileTransferManager {
    transfers: RwLock<HashMap<String, FileTransfer>>,
    device_mesh: Arc<DeviceMesh>,
    chunk_size: usize,
    max_parallel: usize,
    download_dir: String,
}

impl FileTransferManager {
    pub fn new(mesh: Arc<DeviceMesh>, download_dir: &str) -> Self {
        FileTransferManager {
            transfers: RwLock::new(HashMap::new()),
            device_mesh: mesh,
            chunk_size: 64 * 1024, // 64KB chunks
            max_parallel: 4,
            download_dir: download_dir.to_string(),
        }
    }

    /// Send file to device
    pub fn send_file(&self, file_path: &str, target_device_id: &str) -> Result<String, GenesisError> {
        let transfer_id = uuid::Uuid::new_v4().to_string();

        // Read file metadata
        let filename = std::path::Path::new(file_path)
            .file_name()
            .map(|n| n.to_string_lossy().to_string())
            .unwrap_or_else(|| "unknown".to_string());

        let size_bytes = 0u64; // Would get actual file size

        let transfer = FileTransfer {
            id: transfer_id.clone(),
            filename,
            size_bytes,
            transferred_bytes: 0,
            source_device: "local".to_string(),
            target_device: target_device_id.to_string(),
            status: TransferStatus::Pending,
            speed_bps: 0,
            eta_seconds: None,
            started_at: DateTime::now(),
            completed_at: None,
            checksum: String::new(),
        };

        self.transfers.write().unwrap().insert(transfer_id.clone(), transfer);

        // Start transfer in background
        // spawn(self.transfer_loop(transfer_id.clone()));

        Ok(transfer_id)
    }

    /// Send multiple files
    pub fn send_files(&self, file_paths: &[&str], target_device_id: &str) -> Result<Vec<String>, GenesisError> {
        let mut transfer_ids = Vec::new();
        for path in file_paths {
            transfer_ids.push(self.send_file(path, target_device_id)?);
        }
        Ok(transfer_ids)
    }

    /// Pause transfer
    pub fn pause(&self, transfer_id: &str) -> Result<(), GenesisError> {
        let mut transfers = self.transfers.write().unwrap();
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            transfer.status = TransferStatus::Paused;
            Ok(())
        } else {
            Err(GenesisError::TransferNotFound)
        }
    }

    /// Resume transfer
    pub fn resume(&self, transfer_id: &str) -> Result<(), GenesisError> {
        let mut transfers = self.transfers.write().unwrap();
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            if transfer.status == TransferStatus::Paused {
                transfer.status = TransferStatus::Transferring;
                Ok(())
            } else {
                Err(GenesisError::InvalidTransferState)
            }
        } else {
            Err(GenesisError::TransferNotFound)
        }
    }

    /// Cancel transfer
    pub fn cancel(&self, transfer_id: &str) -> Result<(), GenesisError> {
        let mut transfers = self.transfers.write().unwrap();
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            transfer.status = TransferStatus::Cancelled;
            Ok(())
        } else {
            Err(GenesisError::TransferNotFound)
        }
    }

    /// Get transfer status
    pub fn get_transfer(&self, transfer_id: &str) -> Option<FileTransfer> {
        self.transfers.read().unwrap().get(transfer_id).cloned()
    }

    /// Get all active transfers
    pub fn active_transfers(&self) -> Vec<FileTransfer> {
        self.transfers.read().unwrap().values()
            .filter(|t| matches!(t.status, TransferStatus::Pending | TransferStatus::Preparing | TransferStatus::Transferring))
            .cloned()
            .collect()
    }

    /// Handle incoming file chunk
    fn on_chunk_received(&self, transfer_id: &str, chunk_index: u64, data: &[u8]) {
        let mut transfers = self.transfers.write().unwrap();
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            transfer.transferred_bytes += data.len() as u64;
            // Write chunk to file
        }
    }
}

