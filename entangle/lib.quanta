// REMOTE DEVICE CONTROL
// ═══════════════════════════════════════════════════════════════════════════════

/// Remote control command types
#[derive(Debug, Clone)]
pub enum RemoteCommand {
    // Media controls
    Play,
    Pause,
    Stop,
    NextTrack,
    PreviousTrack,
    VolumeUp,
    VolumeDown,
    Mute,
    SetVolume(f32),

    // System controls
    Lock,
    Unlock,
    Sleep,
    Wake,
    Shutdown,
    Restart,

    // App controls
    LaunchApp(String),
    CloseApp(String),
    BringToFront(String),

    // Camera controls
    TakePhoto,
    StartRecording,
    StopRecording,
    FlashOn,
    FlashOff,
    SwitchCamera,

    // Display controls
    BrightnessUp,
    BrightnessDown,
    SetBrightness(f32),
    RotationLock(bool),

    // Custom
    Custom(String, Vec<u8>),
}

/// Remote control manager
pub struct RemoteControl {
    device_mesh: Arc<DeviceMesh>,
    pending_commands: RwLock<HashMap<String, RemoteCommand>>,
    command_history: RwLock<VecDeque<CommandExecution>>,
}

#[derive(Debug, Clone)]
struct CommandExecution {
    command: RemoteCommand,
    target_device: String,
    timestamp: DateTime,
    success: bool,
}

impl RemoteControl {
    pub fn new(mesh: Arc<DeviceMesh>) -> Self {
        RemoteControl {
            device_mesh: mesh,
            pending_commands: RwLock::new(HashMap::new()),
            command_history: RwLock::new(VecDeque::with_capacity(100)),
        }
    }

    /// Send command to device
    pub fn send_command(&self, device_id: &str, command: RemoteCommand) -> Result<String, GenesisError> {
        let command_id = uuid::Uuid::new_v4().to_string();

        let data = self.serialize_command(&command);
        self.device_mesh.send(device_id, &data)?;

        self.pending_commands.write().unwrap()
            .insert(command_id.clone(), command.clone());

        Ok(command_id)
    }

    /// Find and ring phone
    pub fn find_phone(&self) -> Result<(), GenesisError> {
        let devices = self.device_mesh.connected_devices();
        let phone = devices.iter()
            .find(|d| d.is_mobile())
            .ok_or(GenesisError::NoPhoneConnected)?;

        // Send ring command
        self.send_command(&phone.id, RemoteCommand::Custom(
            "FIND".to_string(),
            vec![]
        ))?;

        Ok(())
    }

    /// Get device camera preview
    pub fn start_camera_preview(&self, device_id: &str) -> Result<(), GenesisError> {
        self.send_command(device_id, RemoteCommand::Custom(
            "CAMERA_PREVIEW".to_string(),
            vec![]
        ))?;
        Ok(())
    }

    /// Take photo remotely
    pub fn take_remote_photo(&self, device_id: &str) -> Result<(), GenesisError> {
        self.send_command(device_id, RemoteCommand::TakePhoto)?;
        Ok(())
    }

    /// Handle command response
    fn on_command_response(&self, command_id: &str, success: bool) {
        if let Some(command) = self.pending_commands.write().unwrap().remove(command_id) {
            let mut history = self.command_history.write().unwrap();
            history.push_front(CommandExecution {
                command,
                target_device: String::new(),
                timestamp: DateTime::now(),
                success,
            });
            if history.len() > 100 {
                history.pop_back();
            }
        }
    }

    fn serialize_command(&self, command: &RemoteCommand) -> Vec<u8> {
        vec![]
    }
}

