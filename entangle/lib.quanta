// AMBIENT AI WATCHER
// ═══════════════════════════════════════════════════════════════════════════════

/// Ambient AI context types
#[derive(Debug, Clone)]
pub enum AmbientContext {
    ScreenContent {
        text: String,
        app: String,
        url: Option<String>,
    },
    ClipboardContent(String),
    Notification(MirroredNotification),
    Calendar {
        event_title: String,
        start_time: DateTime,
        participants: Vec<String>,
    },
    Location(Location),
    CurrentTask(String),
}

/// AI suggestion from ambient watching
#[derive(Debug, Clone)]
pub struct AISuggestion {
    pub id: String,
    pub suggestion_type: SuggestionType,
    pub title: String,
    pub description: String,
    pub actions: Vec<SuggestionAction>,
    pub confidence: f32,
    pub context: String,
    pub timestamp: DateTime,
    pub dismissed: bool,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum SuggestionType {
    QuickReply,
    Reminder,
    Information,
    Action,
    Search,
    Translation,
    Definition,
    CalendarConflict,
    TravelTime,
    PackageTracking,
    FlightStatus,
}

#[derive(Debug, Clone)]
pub struct SuggestionAction {
    pub id: String,
    pub label: String,
    pub action_type: SuggestionActionType,
    pub payload: String,
}

#[derive(Debug, Clone, Copy)]
pub enum SuggestionActionType {
    OpenUrl,
    CopyText,
    CreateReminder,
    SendMessage,
    MakeCall,
    Navigate,
    AddToCalendar,
    Dismiss,
}

/// Ambient AI watcher - provides contextual assistance
pub struct AmbientAIWatcher {
    context_history: RwLock<VecDeque<AmbientContext>>,
    suggestions: RwLock<VecDeque<AISuggestion>>,
    ai_orchestrator: Arc<Mutex<AIOrchestrator>>,
    enabled_features: HashSet<String>,
    privacy_mode: bool,
}

impl AmbientAIWatcher {
    pub fn new(ai: Arc<Mutex<AIOrchestrator>>) -> Self {
        AmbientAIWatcher {
            context_history: RwLock::new(VecDeque::with_capacity(100)),
            suggestions: RwLock::new(VecDeque::with_capacity(50)),
            ai_orchestrator: ai,
            enabled_features: HashSet::new(),
            privacy_mode: false,
        }
    }

    /// Enable a feature
    pub fn enable_feature(&mut self, feature: &str) {
        self.enabled_features.insert(feature.to_string());
    }

    /// Disable a feature
    pub fn disable_feature(&mut self, feature: &str) {
        self.enabled_features.remove(feature);
    }

    /// Set privacy mode (no screen reading)
    pub fn set_privacy_mode(&mut self, enabled: bool) {
        self.privacy_mode = enabled;
    }

    /// Process new context
    pub fn on_context(&self, context: AmbientContext) {
        if self.privacy_mode {
            return;
        }

        // Add to history
        let mut history = self.context_history.write().unwrap();
        history.push_front(context.clone());
        if history.len() > 100 {
            history.pop_back();
        }

        // Generate suggestions based on context
        if let Some(suggestion) = self.analyze_context(&context) {
            let mut suggestions = self.suggestions.write().unwrap();
            suggestions.push_front(suggestion);
            if suggestions.len() > 50 {
                suggestions.pop_back();
            }
        }
    }

    fn analyze_context(&self, context: &AmbientContext) -> Option<AISuggestion> {
        match context {
            AmbientContext::ScreenContent { text, app, url } => {
                // Detect trackable items
                if let Some(tracking) = self.detect_tracking_number(text) {
                    return Some(AISuggestion {
                        id: uuid::Uuid::new_v4().to_string(),
                        suggestion_type: SuggestionType::PackageTracking,
                        title: "Track Package".to_string(),
                        description: format!("Tracking number detected: {}", tracking),
                        actions: vec![SuggestionAction {
                            id: "track".to_string(),
                            label: "Track Package".to_string(),
                            action_type: SuggestionActionType::OpenUrl,
                            payload: format!("https://parcelsapp.com/en/tracking/{}", tracking),
                        }],
                        confidence: 0.9,
                        context: text.clone(),
                        timestamp: DateTime::now(),
                        dismissed: false,
                    });
                }

                // Detect flight numbers
                if let Some(flight) = self.detect_flight_number(text) {
                    return Some(AISuggestion {
                        id: uuid::Uuid::new_v4().to_string(),
                        suggestion_type: SuggestionType::FlightStatus,
                        title: "Check Flight Status".to_string(),
                        description: format!("Flight {} detected", flight),
                        actions: vec![SuggestionAction {
                            id: "check".to_string(),
                            label: "Check Status".to_string(),
                            action_type: SuggestionActionType::OpenUrl,
                            payload: format!("https://www.flightaware.com/live/flight/{}", flight),
                        }],
                        confidence: 0.85,
                        context: text.clone(),
                        timestamp: DateTime::now(),
                        dismissed: false,
                    });
                }

                None
            }
            AmbientContext::Notification(notif) => {
                if notif.category == NotificationCategory::Message {
                    // Generate smart reply suggestions
                    // Would call AI for reply suggestions
                    None
                } else {
                    None
                }
            }
            AmbientContext::Calendar { event_title, start_time, participants } => {
                // Check for upcoming meeting
                let minutes_until = (*start_time - DateTime::now()).num_minutes();
                if minutes_until > 0 && minutes_until <= 15 {
                    Some(AISuggestion {
                        id: uuid::Uuid::new_v4().to_string(),
                        suggestion_type: SuggestionType::Reminder,
                        title: format!("Meeting in {} minutes", minutes_until),
                        description: event_title.clone(),
                        actions: vec![],
                        confidence: 1.0,
                        context: event_title.clone(),
                        timestamp: DateTime::now(),
                        dismissed: false,
                    })
                } else {
                    None
                }
            }
            _ => None,
        }
    }

    fn detect_tracking_number(&self, text: &str) -> Option<String> {
        // Common tracking number patterns
        let patterns = [
            r"1Z[A-Z0-9]{16}",           // UPS
            r"\d{20,22}",                 // USPS
            r"\d{12,15}",                 // FedEx
            r"JD\d{18}",                  // DHL
        ];

        for pattern in patterns {
            if let Some(m) = regex::Regex::new(pattern).ok()?.find(text) {
                return Some(m.as_str().to_string());
            }
        }
        None
    }

    fn detect_flight_number(&self, text: &str) -> Option<String> {
        // Flight number pattern: 2-3 letter code + 1-4 digits
        let pattern = r"[A-Z]{2,3}\d{1,4}";
        regex::Regex::new(pattern).ok()?.find(text)
            .map(|m| m.as_str().to_string())
    }

    /// Get recent suggestions
    pub fn recent_suggestions(&self, count: usize) -> Vec<AISuggestion> {
        self.suggestions.read().unwrap()
            .iter()
            .filter(|s| !s.dismissed)
            .take(count)
            .cloned()
            .collect()
    }

    /// Dismiss a suggestion
    pub fn dismiss_suggestion(&self, suggestion_id: &str) {
        let mut suggestions = self.suggestions.write().unwrap();
        if let Some(s) = suggestions.iter_mut().find(|s| s.id == suggestion_id) {
            s.dismissed = true;
        }
    }

    /// Execute suggestion action
    pub fn execute_action(&self, suggestion_id: &str, action_id: &str) -> Result<(), GenesisError> {
        let suggestions = self.suggestions.read().unwrap();
        let suggestion = suggestions.iter()
            .find(|s| s.id == suggestion_id)
            .ok_or(GenesisError::SuggestionNotFound)?;

        let action = suggestion.actions.iter()
            .find(|a| a.id == action_id)
            .ok_or(GenesisError::ActionNotFound)?;

        match action.action_type {
            SuggestionActionType::OpenUrl => {
                // open_url(&action.payload);
            }
            SuggestionActionType::CopyText => {
                // clipboard_copy(&action.payload);
            }
            SuggestionActionType::CreateReminder => {
                // create_reminder(&action.payload);
            }
            _ => {}
        }

        Ok(())
    }
}

