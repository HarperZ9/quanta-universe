// NOTIFICATION MIRRORING
// ═══════════════════════════════════════════════════════════════════════════════

/// Notification priority level
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum NotificationPriority {
    Low,
    Normal,
    High,
    Urgent,
}

/// Notification category
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum NotificationCategory {
    Message,
    Email,
    Call,
    Social,
    News,
    Calendar,
    Reminder,
    System,
    App,
    Other,
}

/// Mirrored notification
#[derive(Debug, Clone)]
pub struct MirroredNotification {
    pub id: String,
    pub source_device: String,
    pub app_name: String,
    pub app_package: String,
    pub title: String,
    pub body: String,
    pub category: NotificationCategory,
    pub priority: NotificationPriority,
    pub timestamp: DateTime,
    pub actions: Vec<NotificationAction>,
    pub icon: Option<Vec<u8>>,
    pub image: Option<Vec<u8>>,
    pub dismissed: bool,
    pub actioned: bool,
}

#[derive(Debug, Clone)]
pub struct NotificationAction {
    pub id: String,
    pub label: String,
    pub requires_input: bool,
}

/// Notification mirror manager
pub struct NotificationMirror {
    notifications: RwLock<VecDeque<MirroredNotification>>,
    device_mesh: Arc<DeviceMesh>,
    filters: NotificationFilters,
    max_history: usize,
}

#[derive(Debug, Clone)]
struct NotificationFilters {
    blocked_apps: HashSet<String>,
    blocked_categories: HashSet<NotificationCategory>,
    quiet_hours: Option<(u32, u32)>,
    min_priority: NotificationPriority,
}

impl NotificationMirror {
    pub fn new(mesh: Arc<DeviceMesh>) -> Self {
        NotificationMirror {
            notifications: RwLock::new(VecDeque::with_capacity(500)),
            device_mesh: mesh,
            filters: NotificationFilters {
                blocked_apps: HashSet::new(),
                blocked_categories: HashSet::new(),
                quiet_hours: None,
                min_priority: NotificationPriority::Low,
            },
            max_history: 500,
        }
    }

    /// Process incoming notification from device
    pub fn on_notification(&self, notification: MirroredNotification) {
        // Check filters
        if self.filters.blocked_apps.contains(&notification.app_package) {
            return;
        }
        if self.filters.blocked_categories.contains(&notification.category) {
            return;
        }
        if notification.priority < self.filters.min_priority {
            return;
        }
        if let Some((start, end)) = self.filters.quiet_hours {
            let hour = DateTime::now().hour();
            if hour >= start || hour < end {
                return;
            }
        }

        // Add to history
        let mut notifications = self.notifications.write().unwrap();
        notifications.push_front(notification.clone());
        if notifications.len() > self.max_history {
            notifications.pop_back();
        }

        // Show on PC
        // show_toast(notification);
    }

    /// Dismiss notification on source device
    pub fn dismiss(&self, notification_id: &str) -> Result<(), GenesisError> {
        let notifications = self.notifications.read().unwrap();
        let notif = notifications.iter()
            .find(|n| n.id == notification_id)
            .ok_or(GenesisError::NotificationNotFound)?;

        let command = format!("DISMISS:{}", notification_id);
        self.device_mesh.send(&notif.source_device, command.as_bytes())
    }

    /// Execute action on notification
    pub fn execute_action(&self, notification_id: &str, action_id: &str, input: Option<&str>) -> Result<(), GenesisError> {
        let notifications = self.notifications.read().unwrap();
        let notif = notifications.iter()
            .find(|n| n.id == notification_id)
            .ok_or(GenesisError::NotificationNotFound)?;

        let command = if let Some(text) = input {
            format!("ACTION:{}:{}:{}", notification_id, action_id, text)
        } else {
            format!("ACTION:{}:{}", notification_id, action_id)
        };

        self.device_mesh.send(&notif.source_device, command.as_bytes())
    }

    /// Block app from mirroring
    pub fn block_app(&mut self, package: &str) {
        self.filters.blocked_apps.insert(package.to_string());
    }

    /// Unblock app
    pub fn unblock_app(&mut self, package: &str) {
        self.filters.blocked_apps.remove(package);
    }

    /// Set quiet hours
    pub fn set_quiet_hours(&mut self, start_hour: u32, end_hour: u32) {
        self.filters.quiet_hours = Some((start_hour, end_hour));
    }

    /// Get recent notifications
    pub fn recent(&self, count: usize) -> Vec<MirroredNotification> {
        self.notifications.read().unwrap()
            .iter()
            .take(count)
            .cloned()
            .collect()
    }
}

