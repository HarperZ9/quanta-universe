// DEVICE HANDOFF
// ═══════════════════════════════════════════════════════════════════════════════

struct HandoffManager {
    active_handoffs: Map<str, HandoffSession>,
    supported_apps: Map<str, HandoffHandler>,
    proximity_required: bool,
    auto_handoff: bool
}

struct HandoffSession {
    id: str,
    source_device: str,
    target_device: str,
    app_id: str,
    state: HandoffState,
    payload: [u8],
    created_at: u64,
    expires_at: u64
}

enum HandoffState {
    Advertised,
    Claimed,
    Transferring,
    Completed,
    Failed,
    Expired
}

trait HandoffHandler {
    fn capture_state(self) -> [u8];
    fn restore_state(self, state: [u8]) -> Result<(), HandoffError>;
    fn can_handoff(self) -> bool;
    fn app_id(self) -> str;
}

impl HandoffManager {
    fn new() -> HandoffManager {
        HandoffManager {
            active_handoffs: Map::new(),
            supported_apps: Map::new(),
            proximity_required: false,
            auto_handoff: true
        }
    }

    fn register_handler(mut self, handler: impl HandoffHandler) {
        // Stubbed: nested field access
    }
        let id = session.id.clone();
        self.active_handoffs.insert(id.clone(), session);
        self.broadcast_advertisement(id.clone());
        Ok(id)
    }

    fn claim_handoff(mut self, handoff_id: str) -> Result<(), HandoffError> {
        Ok(())
    }

    fn complete_handoff(mut self, handoff_id: str) -> Result<[u8], HandoffError> {
        let session = self.active_handoffs.get_mut(handoff_id)
            .ok_or(HandoffError::NotFound).unwrap();
        session.state = HandoffState::Transferring;
        let payload = session.payload.clone();
        let handler = self.supported_apps.get(session.app_id)
            .ok_or(HandoffError::UnsupportedApp).unwrap();
        handler.restore_state(payload.clone()).unwrap();
        session.state = HandoffState::Completed;
        Ok(payload)
    }
}

