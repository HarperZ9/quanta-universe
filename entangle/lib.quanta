/// Message source platforms
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum MessagePlatform {
    SMS,
    iMessage,
    WhatsApp,
    Telegram,
    Signal,
    Slack,
    Discord,
    Teams,
    Email,
    Messenger,
    Twitter,
    LinkedIn,
}

/// Unified message representation
#[derive(Debug, Clone)]
pub struct UnifiedMessage {
    pub id: String,
    pub platform: MessagePlatform,
    pub platform_id: String,  // Original ID on platform
    pub conversation_id: String,
    pub sender: Contact,
    pub recipients: Vec<Contact>,
    pub content: MessageContent,
    pub timestamp: DateTime,
    pub read: bool,
    pub replied: bool,
    pub attachments: Vec<Attachment>,
}

#[derive(Debug, Clone)]
pub enum MessageContent {
    Text(String),
    Image { url: String, caption: Option<String> },
    Video { url: String, duration_secs: u32 },
    Audio { url: String, duration_secs: u32, transcript: Option<String> },
    File { url: String, filename: String, size_bytes: u64 },
    Location { lat: f64, lng: f64, name: Option<String> },
    Contact(Contact),
    Reaction { emoji: String, target_message_id: String },
}

#[derive(Debug, Clone)]
pub struct Contact {
    pub id: String,
    pub name: String,
    pub email: Option<String>,
    pub phone: Option<String>,
    pub avatar_url: Option<String>,
    pub platform_ids: HashMap<MessagePlatform, String>,
}

#[derive(Debug, Clone)]
pub struct Attachment {
    pub id: String,
    pub filename: String,
    pub mime_type: String,
    pub size_bytes: u64,
    pub url: String,
    pub thumbnail_url: Option<String>,
}

/// Unified message hub
pub struct MessageHub {
    messages: RwLock<Vec<UnifiedMessage>>,
    conversations: RwLock<HashMap<String, Conversation>>,
    contacts: RwLock<HashMap<String, Contact>>,
    platform_adapters: HashMap<MessagePlatform, Box<dyn MessageAdapter>>,
    ai_orchestrator: Arc<Mutex<AIOrchestrator>>,
}

#[derive(Debug, Clone)]
pub struct Conversation {
    pub id: String,
    pub platform: MessagePlatform,
    pub participants: Vec<Contact>,
    pub last_message: Option<UnifiedMessage>,
    pub unread_count: u32,
    pub pinned: bool,
    pub muted: bool,
}

/// Platform adapter trait
pub trait MessageAdapter: Send + Sync {
    fn platform(&self) -> MessagePlatform;
    fn connect(&mut self) -> Result<(), GenesisError>;
    fn disconnect(&mut self) -> Result<(), GenesisError>;
    fn fetch_messages(&self, since: DateTime) -> Result<Vec<UnifiedMessage>, GenesisError>;
    fn send_message(&self, conversation_id: &str, content: MessageContent) -> Result<String, GenesisError>;
    fn mark_read(&self, message_id: &str) -> Result<(), GenesisError>;
}

impl MessageHub {
    pub fn new(ai: Arc<Mutex<AIOrchestrator>>) -> Self {
        MessageHub {
            messages: RwLock::new(Vec::new()),
            conversations: RwLock::new(HashMap::new()),
            contacts: RwLock::new(HashMap::new()),
            platform_adapters: HashMap::new(),
            ai_orchestrator: ai,
        }
    }
    
    /// Register a platform adapter
    pub fn register_adapter(&mut self, adapter: Box<dyn MessageAdapter>) {
        let platform = adapter.platform();
        self.platform_adapters.insert(platform, adapter);
    }
    
    /// Sync all platforms
    pub fn sync_all(&self) -> Result<u32, GenesisError> {
        let mut total_new = 0;
        
        for adapter in self.platform_adapters.values() {
            let messages = adapter.fetch_messages(DateTime::now() - Duration::hours(24))?;
            total_new += messages.len() as u32;
            
            let mut msgs = self.messages.write().unwrap();
            msgs.extend(messages);
        }
        
        Ok(total_new)
    }
    
    /// Send message to any platform
    pub fn send(&self, platform: MessagePlatform, conversation_id: &str, content: MessageContent) -> Result<String, GenesisError> {
        let adapter = self.platform_adapters.get(&platform)
            .ok_or(GenesisError::PlatformNotConnected)?;
        
        adapter.send_message(conversation_id, content)
    }
    
    /// AI-powered smart reply suggestions
    pub fn get_smart_replies(&self, conversation_id: &str) -> Result<Vec<String>, GenesisError> {
        let conversations = self.conversations.read().unwrap();
        let conv = conversations.get(conversation_id)
            .ok_or(GenesisError::ConversationNotFound)?;
        
        // Get recent messages for context
        let messages = self.messages.read().unwrap();
        let recent: Vec<&UnifiedMessage> = messages.iter()
            .filter(|m| m.conversation_id == conversation_id)
            .take(10)
            .collect();
        
        // Build context
        let context = recent.iter()
            .filter_map(|m| {
                if let MessageContent::Text(text) = &m.content {
                    Some(format!("{}: {}", m.sender.name, text))
                } else {
                    None
                }
            })
            .collect::<Vec<_>>()
            .join("\n");
        
        // Ask AI for suggestions
        let prompt = format!(
            "Based on this conversation, suggest 3 short, natural reply options:\n\n{}\n\nReplies (one per line):",
            context
        );
        
        let mut ai = self.ai_orchestrator.lock().unwrap();
        let response = ai.route_task(AICapability::TextGeneration, &prompt)?;
        
        Ok(response.text.lines().map(|s| s.to_string()).take(3).collect())
    }
    
    /// Search across all messages
    pub fn search(&self, query: &str) -> Vec<UnifiedMessage> {
        let messages = self.messages.read().unwrap();
        
        messages.iter()
            .filter(|m| {
                if let MessageContent::Text(text) = &m.content {
                    text.to_lowercase().contains(&query.to_lowercase())
                } else {
                    false
                }
            })
            .cloned()
            .collect()
    }
}

