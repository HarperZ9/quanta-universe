/// File transfer entry
#[derive(Debug, Clone)]
pub struct FileTransfer {
    pub id: String,
    pub filename: String,
    pub size_bytes: u64,
    pub transferred_bytes: u64,
    pub source_device: String,
    pub target_device: String,
    pub status: TransferStatus,
    pub speed_bps: u64,
    pub eta_seconds: Option<u32>,
    pub started_at: u64,
    pub completed_at: Option<u64>,
    pub checksum: String,
}

impl FileTransfer {
    pub fn progress(&self) -> f32 {
        if self.size_bytes == 0 {
            return 1.0;
        }
        self.transferred_bytes as f32 / self.size_bytes as f32
    }
}

/// Cross-device file transfer manager
pub struct FileTransferManager {
    transfers: HashMap<String, FileTransfer>,
    device_mesh: DeviceMesh,
    chunk_size: usize,
    max_parallel: usize,
    download_dir: String,
}
    pub fn start(&mut self) -> Result<(), GenesisError> {
        // Stubbed: uses self.field.method() pattern unsupported by compiler
        Ok(Vec::new())
    }
    /// Send file to device
    pub fn send_file(&self, file_path: &str, target_device_id: &str) -> Result<String, GenesisError> {
        let transfer_id = uuid::Uuid::new_v4().to_string();

        // Read file metadata
        let filename = std::path::Path::new(file_path)
            .file_name()
            .map(|n| n.to_string_lossy().to_string())
            .unwrap_or_else(|| "unknown".to_string());

        let size_bytes = 0u64; // Would get actual file size

        let transfer = FileTransfer {
            id: transfer_id.clone(),
            filename,
            size_bytes,
            transferred_bytes: 0,
            source_device: "local".to_string(),
            target_device: target_device_id.to_string(),
            status: TransferStatus::Pending,
            speed_bps: 0,
            eta_seconds: None,
            started_at: 0u64,
            completed_at: None,
            checksum: String::new(),
        };

        self.transfers.insert(transfer_id.clone(), transfer);

        // Start transfer in background
        // spawn(self.transfer_loop(transfer_id.clone()));

        Ok(transfer_id)
    }

    /// Send multiple files
    pub fn send_files(&self, file_paths: &[&str], target_device_id: &str) -> Result<Vec<String>, GenesisError> {
        let mut transfer_ids = Vec::new();
        for path in file_paths {
            transfer_ids.push(self.send_file(path, target_device_id)?);
        }
        Ok(transfer_ids)
    }

    /// Pause transfer
    pub fn pause(&self, transfer_id: &str) -> Result<(), GenesisError> {
        let mut transfers = self.transfers;
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            transfer.status = TransferStatus::Paused;
            Ok(())
        } else {
            Err(GenesisError::TransferNotFound)
        }
    }

    /// Resume transfer
    pub fn resume(&self, transfer_id: &str) -> Result<(), GenesisError> {
        let mut transfers = self.transfers;
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            if transfer.status == TransferStatus::Paused {
                transfer.status = TransferStatus::Transferring;
                Ok(())
            } else {
                Err(GenesisError::InvalidTransferState)
            }
        } else {
            Err(GenesisError::TransferNotFound)
        }
    }

    /// Cancel transfer
    pub fn cancel(&self, transfer_id: &str) -> Result<(), GenesisError> {
        let mut transfers = self.transfers;
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            transfer.status = TransferStatus::Cancelled;
            Ok(())
        } else {
            Err(GenesisError::TransferNotFound)
        }
    }

    /// Get transfer status
    pub fn get_transfer(&self, transfer_id: &str) -> Option<FileTransfer> {
        self.transfers.get(transfer_id).cloned()
    }

    /// Get all active transfers
    pub fn active_transfers(&self) -> Vec<FileTransfer> {
        self.transfers.values()
            .filter(|t| matches!(t.status, TransferStatus::Pending | TransferStatus::Preparing | TransferStatus::Transferring))
            .cloned()
            .collect()
    }

    /// Handle incoming file chunk
    fn on_chunk_received(&self, transfer_id: &str, chunk_index: u64, data: &[u8]) {
        let mut transfers = self.transfers;
        if let Some(transfer) = transfers.get_mut(transfer_id) {
            transfer.transferred_bytes += data.len() as u64;
            // Write chunk to file
        }
    }
}

