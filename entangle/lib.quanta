/// Device type classification
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum DeviceType {
    Desktop,
    Laptop,
    Phone,
    Tablet,
    Watch,
    TV,
    IoT,
    Server,
}

/// Device operating system
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum DeviceOS {
    Windows,
    MacOS,
    Linux,
    Android,
    iOS,
    WatchOS,
    TizenOS,
    Custom(u32),
}

/// Connection status
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum ConnectionStatus {
    Connected,
    Connecting,
    Disconnected,
    Pairing,
    Error,
}

/// AI model provider
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum AIProvider {
    Claude,
    GPT4,
    GPT35,
    OllamaLlama,
    LMStudio,
    Local,
}

/// Messaging platform
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum MessagePlatform {
    SMS,
    Slack,
    Teams,
    Discord,
    Email,
    Internal,
}

/// File transfer status
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TransferStatus {
    Pending,
    Preparing,
    Transferring,
    Paused,
    Completed,
    Failed,
    Cancelled,
}

/// Device capability flags
#[derive(Debug, Clone)]
pub struct DeviceCapabilities {
    pub can_send_sms: bool,
    pub can_make_calls: bool,
    pub has_camera: bool,
    pub has_microphone: bool,
    pub has_speakers: bool,
    pub has_display: bool,
    pub has_keyboard: bool,
    pub has_mouse: bool,
    pub has_touch: bool,
    pub has_gps: bool,
    pub has_biometrics: bool,
    pub has_nfc: bool,
    pub storage_gb: f32,
    pub ram_gb: f32,
    pub battery_percent: Option<u8>,
}

/// Connected device representation
#[derive(Debug, Clone)]
pub struct Device {
    pub id: String,
    pub name: String,
    pub device_type: DeviceType,
    pub os: DeviceOS,
    pub os_version: String,
    pub model: String,
    pub capabilities: DeviceCapabilities,
    pub status: ConnectionStatus,
    pub last_seen: u64,
    pub ip_address: Option<String>,
    pub public_key: Vec<u8>,
}

impl Device {
    pub fn is_mobile(&self) -> bool {
        matches!(self.device_type, DeviceType::Phone | DeviceType::Tablet | DeviceType::Watch)
    }
    
    pub fn is_primary_compute(&self) -> bool {
        matches!(self.device_type, DeviceType::Desktop | DeviceType::Laptop | DeviceType::Server)
    }
}

