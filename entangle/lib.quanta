    }

    /// Hand off playback to another device
    pub fn handoff_to(&self, target_device_id: &str) -> Result<(), GenesisError> {
        let state = self.current_state
            .clone()
            .ok_or(GenesisError::NoMediaPlaying).unwrap();

        // Send handoff command with current position
        let command = HandoffCommand {
            action: HandoffAction::Transfer,
            state: state.clone(),
            timestamp: 0u64,
        };

        let data = self.serialize_command(&command);
        self.device_mesh.send(target_device_id, &data).unwrap();

        // Pause on current device
        // media_controller.pause();

        Ok(())
    }

    /// Handle incoming handoff request
    pub fn on_handoff_received(&self, command: HandoffCommand) {
        match command.action {
            HandoffAction::Transfer => {
                // Start playback at the specified position
