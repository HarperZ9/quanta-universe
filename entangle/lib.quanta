// PRESENCE DETECTION & AUTO-ROUTING
// ═══════════════════════════════════════════════════════════════════════════════

/// User presence state
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum PresenceState {
    Active,          // User is actively using device
    Idle,            // Device on but not in use
    Away,            // User stepped away (motion/location)
    DoNotDisturb,    // Manual DND mode
    Sleeping,        // Night mode / screen off
    Unknown,
}

/// Device proximity to user
#[derive(Debug, Clone, Copy, PartialEq, PartialOrd)]
pub enum Proximity {
    InHand,      // Holding the device
    OnDesk,      // Within arm's reach
    InRoom,      // Same room
    InBuilding,  // Same building/home
    Remote,      // Different location
}

/// Device presence info
#[derive(Debug, Clone)]
pub struct DevicePresence {
    pub device_id: String,
    pub state: PresenceState,
    pub proximity: Proximity,
    pub last_activity: DateTime,
    pub location: Option<Location>,
    pub connected_peripherals: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct Location {
    pub latitude: f64,
    pub longitude: f64,
    pub accuracy_meters: f32,
    pub altitude: Option<f32>,
    pub source: LocationSource,
}

#[derive(Debug, Clone, Copy)]
pub enum LocationSource {
    GPS,
    WiFi,
    Cellular,
    Bluetooth,
    IP,
}

/// Presence detection manager
pub struct PresenceManager {
    device_presence: RwLock<HashMap<String, DevicePresence>>,
    device_mesh: Arc<DeviceMesh>,
    routing_rules: Vec<RoutingRule>,
}

#[derive(Debug, Clone)]
pub struct RoutingRule {
    pub name: String,
    pub condition: RoutingCondition,
    pub action: RoutingAction,
    pub priority: u32,
}

#[derive(Debug, Clone)]
pub enum RoutingCondition {
    DeviceActive(String),
    DeviceIdle(String),
    ProximityCloser(String, String),  // device1 closer than device2
    TimeRange { start: u32, end: u32 },  // Hour of day
    Location { lat: f64, lng: f64, radius_m: f32 },
    And(Vec<RoutingCondition>),
    Or(Vec<RoutingCondition>),
}

#[derive(Debug, Clone)]
pub enum RoutingAction {
    RouteNotificationsTo(String),
    RouteCalls(String),
    MutDevice(String),
    TransferMedia(String),
    Custom(String),
}

impl PresenceManager {
    pub fn new(mesh: Arc<DeviceMesh>) -> Self {
        PresenceManager {
            device_presence: RwLock::new(HashMap::new()),
            device_mesh: mesh,
            routing_rules: Vec::new(),
        }
    }

    /// Update device presence
    pub fn update_presence(&self, device_id: &str, state: PresenceState) {
        let mut presence = self.device_presence.write().unwrap();
        if let Some(p) = presence.get_mut(device_id) {
            p.state = state;
            p.last_activity = DateTime::now();
        }
    }

    /// Get primary device (closest active device)
    pub fn primary_device(&self) -> Option<String> {
        let presence = self.device_presence.read().unwrap();

        presence.values()
            .filter(|p| p.state == PresenceState::Active)
            .min_by_key(|p| p.proximity as u8)
            .map(|p| p.device_id.clone())
    }

    /// Add routing rule
    pub fn add_rule(&mut self, rule: RoutingRule) {
        self.routing_rules.push(rule);
        self.routing_rules.sort_by(|a, b| b.priority.cmp(&a.priority));
    }

    /// Evaluate and apply routing rules
    pub fn evaluate_routing(&self) -> Vec<RoutingAction> {
        let mut actions = Vec::new();

        for rule in &self.routing_rules {
            if self.evaluate_condition(&rule.condition) {
                actions.push(rule.action.clone());
            }
        }

        actions
    }

    fn evaluate_condition(&self, condition: &RoutingCondition) -> bool {
        match condition {
            RoutingCondition::DeviceActive(id) => {
                let presence = self.device_presence.read().unwrap();
                presence.get(id).map(|p| p.state == PresenceState::Active).unwrap_or(false)
            }
            RoutingCondition::DeviceIdle(id) => {
                let presence = self.device_presence.read().unwrap();
                presence.get(id).map(|p| p.state == PresenceState::Idle).unwrap_or(false)
            }
            RoutingCondition::ProximityCloser(a, b) => {
                let presence = self.device_presence.read().unwrap();
                let pa = presence.get(a).map(|p| p.proximity);
                let pb = presence.get(b).map(|p| p.proximity);
                match (pa, pb) {
                    (Some(a), Some(b)) => a < b,
                    _ => false,
                }
            }
            RoutingCondition::TimeRange { start, end } => {
                let hour = DateTime::now().hour();
                hour >= *start && hour < *end
            }
            RoutingCondition::Location { lat, lng, radius_m } => {
                // Check if any device is within radius
                false // Placeholder
            }
            RoutingCondition::And(conditions) => {
                conditions.iter().all(|c| self.evaluate_condition(c))
            }
            RoutingCondition::Or(conditions) => {
                conditions.iter().any(|c| self.evaluate_condition(c))
            }
        }
    }

    /// Detect motion via device sensors
    fn detect_motion(&self, device_id: &str) -> bool {
        // Query accelerometer/gyroscope
        false
    }
}

