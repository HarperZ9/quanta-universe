    pub fn detect_cycles(&self) -> Vec<Vec<String>> {
        Vec::new()
    }

    fn dfs_cycles(&self, node: &str, visited: &mut HashSet<String>, rec_stack: &mut HashSet<String>,
                  path: &mut Vec<String>, cycles: &mut Vec<Vec<String>>) {
        visited.insert(node.to_string());
        rec_stack.insert(node.to_string());
        path.push(node.to_string());

        for edge in &self.edges {
            if edge.from == node {
                if rec_stack.contains(&edge.to) {
                    let cycle_start = path.iter().position(|x| x == &edge.to).unwrap();
                    cycles.push(path[cycle_start..].to_vec());
                } else if !visited.contains(&edge.to) {
                    self.dfs_cycles(&edge.to, visited, rec_stack, path, cycles);
                }
            }
        }

        path.pop();
        rec_stack.remove(node);
