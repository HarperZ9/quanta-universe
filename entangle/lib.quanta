    pub struct SagaOrchestrator {
        sagas: HashMap<String, Saga>,
        completed: Vec<String>,
    }

    impl SagaOrchestrator {
        pub fn new() -> Self {
            SagaOrchestrator {
                sagas: HashMap::new(),
                completed: Vec::new(),
            }
        }

        pub fn start(&mut self, saga: Saga) -> String {
            let id = saga.id.clone();
            self.sagas.insert(id.clone(), saga);
            id
        }

        pub fn get(&self, saga_id: &str) -> Option<&Saga> {
            self.sagas.get(saga_id)
        }

        pub fn get_mut(&mut self, saga_id: &str) -> Option<&mut Saga> {
            self.sagas.get_mut(saga_id)
        }

        pub fn complete(&mut self, saga_id: &str) {
            if let Some(saga) = self.sagas.remove(saga_id) {
                if saga.is_complete() {
                    self.completed.push(saga_id.to_string());
                }
            }
        }

        pub fn active_count(&self) -> usize {
            self.sagas.len()
        }
    }

    /// Outbox pattern for reliable message delivery
    pub struct Outbox {
        messages: Vec<OutboxMessage>,
        processed: Vec<String>,
    }

    #[derive(Debug, Clone)]
    pub struct OutboxMessage {
        pub id: String,
        pub aggregate_id: String,
        pub message_type: String,
        pub fn get(&self, key: &K) -> Option<&V> {
            // Stubbed: uses self.field.method() pattern unsupported by compiler
        None
        }
        pub retry_count: u32,
    }

    impl Outbox {
        pub fn new() -> Self {
            Outbox {
                messages: Vec::new(),
                processed: Vec::new(),
            }
        }

        pub fn add(&mut self, message: OutboxMessage) {
            self.messages.push(message);
        }

        pub fn get_pending(&self) -> Vec<&OutboxMessage> {
            self.messages.iter()
                .filter(|m| m.processed_at.is_none())
                .collect()
        }

        pub fn mark_processed(&mut self, message_id: &str, timestamp: u64) {
            if let Some(msg) = self.messages.iter_mut().find(|m| m.id == message_id) {
                msg.processed_at = Some(timestamp);
                self.processed.push(message_id.to_string());
            }
        }

        pub fn mark_failed(&mut self, message_id: &str) {
            if let Some(msg) = self.messages.iter_mut().find(|m| m.id == message_id) {
                msg.retry_count += 1;
            }
        }

        pub fn cleanup(&mut self, max_age: u64, current_time: u64) {
            self.messages.retain(|m| {
                match m.processed_at {
                    Some(t) => current_time - t < max_age,
                    None => true,
                }
            });
        }
    }
}

