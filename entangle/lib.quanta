struct KeyPair { public_key: [u8; 32], private_key: [u8; 32] }

struct E2EEncryption {
    local_keys: KeyPair,
    peer_public_keys: HashMap<string, [u8; 32]>,
    session_keys: HashMap<string, [u8; 32]>,
