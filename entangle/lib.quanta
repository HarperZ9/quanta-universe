// CLIPBOARD SYNC WITH AI
// ═══════════════════════════════════════════════════════════════════════════════

/// Clipboard item type
#[derive(Debug, Clone)]
pub enum ClipboardContent {
    Text(String),
    RichText(String),  // HTML/RTF
    Image(Vec<u8>),
    Files(Vec<String>),
    Custom { mime_type: String, data: Vec<u8> },
}

/// Clipboard history item
#[derive(Debug, Clone)]
pub struct ClipboardItem {
    pub id: String,
    pub content: ClipboardContent,
    pub source_device: String,
    pub timestamp: DateTime,
    pub pinned: bool,
    pub tags: Vec<String>,
    pub ai_summary: Option<String>,
}

/// Cross-device clipboard manager
pub struct ClipboardManager {
    history: RwLock<VecDeque<ClipboardItem>>,
    max_history: usize,
    device_mesh: Arc<DeviceMesh>,
    ai_orchestrator: Arc<Mutex<AIOrchestrator>>,
}

impl ClipboardManager {
    pub fn new(mesh: Arc<DeviceMesh>, ai: Arc<Mutex<AIOrchestrator>>) -> Self {
        ClipboardManager {
            history: RwLock::new(VecDeque::with_capacity(1000)),
            max_history: 1000,
            device_mesh: mesh,
            ai_orchestrator: ai,
        }
    }
    
    /// Copy content to clipboard and sync
    pub fn copy(&self, content: ClipboardContent) -> Result<String, GenesisError> {
        let id = uuid::Uuid::new_v4().to_string();
        
        // AI summarization for text
        let ai_summary = if let ClipboardContent::Text(text) = &content {
            if text.len() > 100 {
                let mut ai = self.ai_orchestrator.lock().unwrap();
                ai.route_task(
                    AICapability::Summarization,
                    &format!("Summarize in 10 words or less: {}", text)
                ).ok().map(|r| r.text)
            } else {
                None
            }
        } else {
            None
        };
        
        let item = ClipboardItem {
            id: id.clone(),
            content,
            source_device: "local".to_string(),
            timestamp: DateTime::now(),
            pinned: false,
            tags: Vec::new(),
            ai_summary,
        };
        
        // Add to history
        let mut history = self.history.write().unwrap();
        history.push_front(item.clone());
        if history.len() > self.max_history {
            history.pop_back();
        }
        
        // Sync to other devices
        self.sync_to_devices(&item)?;
        
        Ok(id)
    }
    
    /// Paste from history
    pub fn paste(&self, id: &str) -> Option<ClipboardContent> {
        let history = self.history.read().unwrap();
        history.iter()
            .find(|item| item.id == id)
            .map(|item| item.content.clone())
    }
    
    /// Get recent clipboard history
    pub fn recent(&self, count: usize) -> Vec<ClipboardItem> {
        let history = self.history.read().unwrap();
        history.iter().take(count).cloned().collect()
    }
    
    /// Search clipboard history
    pub fn search(&self, query: &str) -> Vec<ClipboardItem> {
        let history = self.history.read().unwrap();
        history.iter()
            .filter(|item| {
                if let ClipboardContent::Text(text) = &item.content {
                    text.to_lowercase().contains(&query.to_lowercase())
                } else if let Some(summary) = &item.ai_summary {
                    summary.to_lowercase().contains(&query.to_lowercase())
                } else {
                    false
                }
            })
            .cloned()
            .collect()
    }
    
    fn sync_to_devices(&self, item: &ClipboardItem) -> Result<(), GenesisError> {
        let devices = self.device_mesh.connected_devices();
        
        for device in devices {
            // Serialize and encrypt
            let data = serialize_clipboard_item(item);
            self.device_mesh.send(&device.id, &data)?;
        }
        
        Ok(())
    }
}

