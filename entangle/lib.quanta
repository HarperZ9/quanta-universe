                self.current_step += 1;
                Some(step)
            }
        }

        pub fn complete_step(&mut self, step_name: &str) {
            if let Some(step) = self.steps.iter_mut().find(|s| s.name == step_name) {
                if self.compensating {
                    step.compensated = true;
                } else {
                    step.completed = true;
                }
            }

            if !self.compensating && self.current_step >= self.steps.len() {
                self.state = SagaState::Completed;
            }
        }

        pub fn fail_step(&mut self, _step_name: &str) {
            self.state = SagaState::Compensating;
            self.compensating = true;
            self.current_step = self.steps.iter()
                .rposition(|s| s.completed)
                .map(|i| i + 1)
                .unwrap_or(0);
        }
