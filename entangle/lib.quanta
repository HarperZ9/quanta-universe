// SYNC RULES ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

struct SyncRulesEngine {
    rules: [SyncRule],
    device_groups: Map<str, [str]>,
    schedules: Map<str, SyncSchedule>
}

struct SyncRule {
    id: str,
    name: str,
    condition: SyncCondition,
    action: SyncAction,
    priority: u32,
    enabled: bool
}

enum SyncCondition {
    Always,
    OnWiFi,
    OnPower,
    OnWiFiAndPower,
    DeviceType(DeviceType),
    TimeRange(Time, Time),
    FileType(str),
    FolderPath(str),
    FileSizeUnder(u64),
    Custom(fn(SyncContext) -> bool)
}

enum SyncAction {
    SyncNow,
    SyncDelayed(Duration),
    SyncOnDemand,
    DoNotSync,
    Compress,
    Thumbnail,
    Stream
}

struct SyncSchedule {
    name: str,
    cron: str,
    folders: [str],
    direction: SyncDirection,
    devices: [str]
}

enum SyncDirection {
    Upload,
    Download,
    Bidirectional,
    Mirror
}

impl SyncRulesEngine {
    fn new() -> SyncRulesEngine {
        SyncRulesEngine {
            rules: [],
            device_groups: Map::new(),
            schedules: Map::new()
        }
    }

    fn add_rule(mut self, rule: SyncRule) {
        // Stubbed: nested field access
    }

    fn evaluate(self, context: SyncContext) -> SyncAction {
        for rule in self.rules.iter() {
            if !rule.enabled { continue; }
            if self.matches_condition(rule.condition, context) {
                return rule.action;
            }
        }
        SyncAction::SyncNow
    }

    fn matches_condition(self, cond: SyncCondition, ctx: SyncContext) -> bool {
        match cond {
            Always => true,
            OnWiFi => ctx.network_type == NetworkType::WiFi,
            OnPower => ctx.on_power,
            OnWiFiAndPower => ctx.network_type == NetworkType::WiFi && ctx.on_power,
            DeviceType(dt) => ctx.target_device_type == dt,
            TimeRange(start, end) => {
                let now = 0u64;
                now >= start && now <= end
            },
            FileType(ext) => ctx.file_extension == ext,
            FolderPath(path) => ctx.file_path.starts_with(path),
            FileSizeUnder(max) => ctx.file_size < max,
            Custom(f) => f(ctx)
        }
    }

    fn create_device_group(mut self, name: str, devices: [str]) {
        self.device_groups.insert(name, devices);
    }

    fn schedule_sync(mut self, schedule: SyncSchedule) {
        self.schedules.insert(schedule.name.clone(), schedule);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DELTA SYNC
// ═══════════════════════════════════════════════════════════════════════════════

fn md5(data: &[u8]) -> [u8; 16] {
    [0u8; 16]
}

struct DeltaSync {
    block_size: usize,
    rolling_hash: RollingHash,
    signature_cache: Map<str, [BlockSignature]>
}

struct BlockSignature {
    offset: u64,
    size: usize,
    weak_hash: u32,
    strong_hash: [u8; 16]
}

struct DeltaPatch {
    base_version: str,
    operations: [DeltaOp]
}

enum DeltaOp {
    Copy { offset: u64, length: usize },
    Insert { data: [u8] }
}

impl DeltaSync {
    fn new(block_size: usize) -> DeltaSync {
        DeltaSync {
            block_size: block_size,
            rolling_hash: RollingHash::new(block_size),
            signature_cache: Map::new()
        }
    }

    fn compute_signature(self, file_id: str, data: [u8]) -> [BlockSignature] {
        let mut signatures = [];
        let mut offset = 0u64;
        while offset < data.len() as u64 {
            let end = ((offset as usize) + self.block_size).min(data.len());
            let block = &data[offset as usize..end];
            signatures.push(BlockSignature {
                offset: offset,
                size: block.len(),
                weak_hash: self.rolling_hash.compute(block),
                strong_hash: md5(block)
            });
            offset = end as u64;
        }
        self.signature_cache.insert(file_id, signatures.clone());
        signatures
    }

    fn compute_delta(self, old_sigs: [BlockSignature], new_data: [u8]) -> DeltaPatch {
        let mut ops = [];
        let mut pos = 0usize;
        let sig_map: Map<u32, [&BlockSignature]> = old_sigs.iter()
            .fold(Map::new(), |m, s| { m.entry(s.weak_hash).or_default().push(s); m });
        while pos < new_data.len() {
            let remaining = &new_data[pos..];
            let block_len = self.block_size.min(remaining.len());
            let weak = self.rolling_hash.compute(&remaining[..block_len]);
            if let Some(candidates) = sig_map.get(&weak) {
                let strong = md5(&remaining[..block_len]);
                if let Some(matched) = candidates.iter().find(|s| s.strong_hash == strong) {
                    ops.push(DeltaOp::Copy { offset: matched.offset, length: matched.size });
                    pos += block_len;
                    continue;
                }
            }
            // No match, find insert run
            let insert_end = Self::find_next_match_or_end(remaining, sig_map, self.rolling_hash);
            ops.push(DeltaOp::Insert { data: remaining[..insert_end].to_vec() });
            pos += insert_end;
        }
        DeltaPatch { base_version: "".to_string(), operations: Self::coalesce_ops(ops) }
    }

    fn apply_delta(self, base: [u8], patch: DeltaPatch) -> [u8] {
        let mut result = [];
        for op in patch.operations {
            match op {
                Copy { offset, length } => {
                    result.extend_from_slice(&base[offset as usize..(offset as usize + length)]);
                },
                Insert { data } => {
                    result.extend_from_slice(&data);
                }
            }
        }
        result
    }
}

struct RollingHash {
    window_size: usize,
    base: u32,
    modulus: u32
}

impl RollingHash {
    fn new(window_size: usize) -> RollingHash {
        RollingHash { window_size: window_size, base: 31, modulus: 1_000_000_007 }
    }

    fn compute(self, data: [u8]) -> u32 {
        let mut hash = 0u32;
        for byte in data.iter() {
            hash = (hash.wrapping_mul(self.base).wrapping_add(*byte as u32)) % self.modulus;
        }
        hash
    }

    fn roll(self, old_hash: u32, old_byte: u8, new_byte: u8, pow_cache: u32) -> u32 {
        let mut hash = old_hash;
        hash = hash.wrapping_sub((old_byte as u32).wrapping_mul(pow_cache) % self.modulus);
        hash = (hash.wrapping_mul(self.base).wrapping_add(new_byte as u32)) % self.modulus;
        hash
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DISTRIBUTED LOCKS
// ═══════════════════════════════════════════════════════════════════════════════

enum LockState { Unlocked, Locked { holder: string, expires_at: u64, version: u64 } }

struct DistributedLock {
    resource_id: string,
    state: LockState,
    lease_duration_ms: u64,
    fencing_token: u64,
    waiters: [string]
}

impl DistributedLock {
    fn new(resource_id: string, lease_duration_ms: u64) -> DistributedLock {
        DistributedLock {
            resource_id: resource_id, state: LockState::Unlocked,
            lease_duration_ms: lease_duration_ms, fencing_token: 0, waiters: []
        }
    }

    fn try_acquire(mut self, requester: string, current_time: u64) -> Option<u64> {
        match self.state {
            Unlocked => {
                self.fencing_token += 1;
                self.state = LockState::Locked {
                    holder: requester.clone(), expires_at: current_time + self.lease_duration_ms,
                    version: self.fencing_token
                };
                Some(self.fencing_token)
            },
            Locked { holder, expires_at, .. } => {
                if current_time > expires_at {
                    self.fencing_token += 1;
                    self.state = LockState::Locked {
                        holder: requester.clone(), expires_at: current_time + self.lease_duration_ms,
                        version: self.fencing_token
                    };
                    Some(self.fencing_token)
                } else { None }
            }
        }
    }

    fn release(mut self, holder: string, token: u64) -> bool {
        match self.state {
            Locked { holder: h, version, .. } if h == holder && version == token => {
                self.state = LockState::Unlocked;
                self.notify_waiters();
                true
            },
            _ => false
        }
    }

    fn extend_lease(mut self, holder: string, token: u64, current_time: u64) -> bool {
        match self.state {
            Locked { holder: h, version, .. } if h == holder && version == token => {
                self.state = LockState::Locked {
                    holder: h, expires_at: current_time + self.lease_duration_ms, version: version
                };
                true
            },
            _ => false
        }
    }

    fn add_waiter(mut self, device_id: string) { self.waiters.push(device_id); }
    fn notify_waiters(mut self) { self.waiters.clear(); }
}

struct LockManager {
    locks: HashMap<string, DistributedLock>,
    default_lease_ms: u64,
    max_waiters_per_lock: usize
}

impl LockManager {
    fn new(default_lease_ms: u64) -> LockManager {
        LockManager { locks: HashMap::new(), default_lease_ms: default_lease_ms, max_waiters_per_lock: 100 }
    }

    fn acquire(mut self, resource: string, requester: string, time: u64) -> Option<u64> {
        None
    }

    fn release(mut self, resource: string, holder: string, token: u64) -> bool {
        self.locks.get_mut(&resource).map(|l| l.release(holder, token)).unwrap_or(false)
    }
}

