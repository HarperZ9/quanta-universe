/// Extended Genesis controller with all features
pub struct GenesisControllerFull {
    pub device_mesh: Arc<DeviceMesh>,
    pub ai_orchestrator: Arc<Mutex<AIOrchestrator>>,
    pub message_hub: Arc<MessageHub>,
    pub clipboard: Arc<ClipboardManager>,
    pub phone_calls: Arc<PhoneCallManager>,
    pub two_factor: Arc<TwoFactorManager>,
    pub media_handoff: Arc<MediaHandoff>,
    pub file_transfer: Arc<FileTransferManager>,
    pub screen_mirror: Arc<ScreenMirror>,
    pub presence: Arc<PresenceManager>,
    pub notifications: Arc<NotificationMirror>,
    pub sessions: Arc<SessionContinuity>,
    pub ambient_ai: Arc<Mutex<AmbientAIWatcher>>,
    pub remote_control: Arc<RemoteControl>,
}

impl GenesisControllerFull {
    pub fn new(local_device: Device, download_dir: &str) -> Self {
        let mesh = Arc::new(DeviceMesh::new(local_device));
        let ai = Arc::new(Mutex::new(AIOrchestrator::new()));

        GenesisControllerFull {
            device_mesh: Arc::clone(&mesh),
            ai_orchestrator: Arc::clone(&ai),
            message_hub: Arc::new(MessageHub::new(Arc::clone(&ai))),
            clipboard: Arc::new(ClipboardManager::new(Arc::clone(&mesh), Arc::clone(&ai))),
            phone_calls: Arc::new(PhoneCallManager::new(Arc::clone(&mesh))),
            two_factor: Arc::new(TwoFactorManager::new(Arc::clone(&mesh))),
            media_handoff: Arc::new(MediaHandoff::new(Arc::clone(&mesh))),
            file_transfer: Arc::new(FileTransferManager::new(Arc::clone(&mesh), download_dir)),
            screen_mirror: Arc::new(ScreenMirror::new(Arc::clone(&mesh))),
            presence: Arc::new(PresenceManager::new(Arc::clone(&mesh))),
            notifications: Arc::new(NotificationMirror::new(Arc::clone(&mesh))),
            sessions: Arc::new(SessionContinuity::new(Arc::clone(&mesh))),
            ambient_ai: Arc::new(Mutex::new(AmbientAIWatcher::new(Arc::clone(&ai)))),
            remote_control: Arc::new(RemoteControl::new(Arc::clone(&mesh))),
        }
    }

    /// Start all services
    pub fn start(&mut self) -> Result<(), GenesisError> {
        // Auto-detect AI agents
        self.ai_orchestrator.lock().unwrap().auto_detect_agents();

        // Enable ambient AI features
        let mut ambient = self.ambient_ai.lock().unwrap();
        ambient.enable_feature("package_tracking");
        ambient.enable_feature("flight_status");
        ambient.enable_feature("smart_replies");
        ambient.enable_feature("meeting_reminders");

        Ok(())
    }

    /// Get comprehensive status
    pub fn status(&self) -> GenesisStatusFull {
        GenesisStatusFull {
            connected_devices: self.device_mesh.connected_devices().len(),
            ai_agents_available: self.ai_orchestrator.lock().unwrap().agents.len(),
            active_call: self.phone_calls.active_call.read().unwrap().is_some(),
            unread_messages: 0,
            pending_2fa_codes: self.two_factor.codes.read().unwrap()
                .iter()
                .filter(|c| !c.used && c.expires_at > DateTime::now())
                .count(),
            active_transfers: self.file_transfer.active_transfers().len(),
            mirroring_active: self.screen_mirror.active_session.read().unwrap().is_some(),
            pending_suggestions: self.ambient_ai.lock().unwrap().recent_suggestions(10).len(),
        }
    }
}

#[derive(Debug, Clone)]
pub struct GenesisStatusFull {
    pub connected_devices: usize,
    pub ai_agents_available: usize,
    pub active_call: bool,
    pub unread_messages: usize,
    pub pending_2fa_codes: usize,
    pub active_transfers: usize,
    pub mirroring_active: bool,
    pub pending_suggestions: usize,
}

