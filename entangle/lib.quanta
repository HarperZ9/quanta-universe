    }

    #[derive(Debug, Clone, Copy, PartialEq)]
    pub enum SagaState {
        Running,
        Completed,
        Compensating,
        Failed,
    }

    impl Saga {
        pub fn new(id: &str, steps: Vec<SagaStep>) -> Self {
            Saga {
